    string host = "127.0.0.1";
    HttpClientResponse* resp = client->post(host, g_srv_port, "/echo", "ping");

    result &= Test("POST /echo not null", resp != nullptr, true);
    if (resp != nullptr)
    {
        result &= Test("POST /echo valid",  resp->valid,      true);
        result &= Test("POST /echo status", resp->statusCode, 200);
        result &= Test("POST /echo body",   resp->body.contains("ping"), true);
        delete resp;
