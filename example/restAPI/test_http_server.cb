import "list.cb";
import "thread.cb";
import "stop_token.cb";
import "test_helper.cb";
import "network/http_server.cb";
import "network/http_client.cb";

int g_srv_port   = 17899;
int g_small_port = 17905;   // server with a small maxRequestBytes for the 413 test

// ---------------------------------------------------------------------------
// Request handler shared by all tests
// ---------------------------------------------------------------------------

HttpResponse* testHandler(HttpRequest* req)
{
    // GET /hello -> 200 "Hello, World!"
    if (req->method == "GET" && req->path == "/hello")
        return HttpResponse.ok("Hello, World!");

    // POST /echo -> 200 <body>
    if (req->method == "POST" && req->path == "/echo")
    {
        if (req->body.length() > 0) return HttpResponse.ok(req->body);
        return HttpResponse.ok("(no body)");
    }

    // PUT /replace -> 200 "replaced"
    if (req->method == "PUT" && req->path == "/replace")
        return HttpResponse.ok("replaced");

    // DELETE /item -> 200 "deleted"
    if (req->method == "DELETE" && req->path == "/item")
        return HttpResponse.ok("deleted");

    // GET /json -> 200 application/json
    if (req->method == "GET" && req->path == "/json")
        return HttpResponse.okJson("\{\"key\":\"value\"\}");

    return HttpResponse.notFound();
}

// ---------------------------------------------------------------------------
// Tests
// ---------------------------------------------------------------------------

bool testGetHello(HttpClient* client)
{
    bool result = true;
    string host = "127.0.0.1";
    HttpClientResponse* resp = client->get(host, g_srv_port, "/hello");

    result &= Test("GET /hello not null", resp != nullptr, true);
    if (resp != nullptr)
    {
        result &= Test("GET /hello valid",      resp->valid,      true);
        result &= Test("GET /hello status",     resp->statusCode, 200);
        result &= Test("GET /hello body match", resp->body.contains("Hello, World!"), true);
        delete resp;
    }
    return result;
}

bool testGetNotFound(HttpClient* client)
{
    bool result = true;
    string host = "127.0.0.1";
    HttpClientResponse* resp = client->get(host, g_srv_port, "/missing");

    result &= Test("GET /missing not null", resp != nullptr, true);
    if (resp != nullptr)
    {
        result &= Test("GET /missing status", resp->statusCode, 404);
        delete resp;
    }
    return result;
}

