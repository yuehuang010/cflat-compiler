bool testPostEmptyBody(HttpClient* client)
{
    bool result = true;
    string host = "127.0.0.1";
    HttpClientResponse* resp = client->post(host, g_srv_port, "/echo", "");

    result &= Test("POST /echo empty not null", resp != nullptr, true);
    if (resp != nullptr)
    {
        result &= Test("POST /echo empty status", resp->statusCode, 200);
        result &= Test("POST /echo empty body",   resp->body.contains("(no body)"), true);
        delete resp;
    }
    return result;
}

// 32KB POST /echo round-trip: forces the server's read loop to assemble the body
// across multiple recv() calls, and the response build/send to handle a >8KB body.
bool testPostLarge(HttpClient* client)
{
    bool result = true;
    string host = "127.0.0.1";

    int n = 32768;
    stringbuilder body;
    int bi = 0;
    while (bi < n) { body.appendChar((i8)('A' + (bi % 26))); bi++; }
    string bodyStr = body.toString();

    HttpClientResponse* resp = client->post(host, g_srv_port, "/echo", bodyStr);
    result &= Test("POST /echo 32K not null", resp != nullptr, true);
    if (resp != nullptr)
    {
        result &= Test("POST /echo 32K status", resp->statusCode, 200);
        result &= Test("POST /echo 32K length", resp->body.length(), n);
        result &= Test("POST /echo 32K roundtrip", resp->body == bodyStr, true);
        delete resp;
    }
    return result;
}

// Read a full HTTP response off a raw socket into an owned string.
string _readAll(Socket* s)
{
    stringbuilder sb;
    i8* buf = new i8[8192];
    bool done = false;
    while (!done)
    {
        int n = s->recv(buf, 8192);
        if (n <= 0) { done = true; }
        else
        {
            string view = default;
            view._ptr = buf;
            view._len = n;
            sb.append(view);
        }
    }
    delete buf;
    return sb.toString();
}

// Split request: send the headers, pause, then the body in a separate packet.
// The server's blocking Content-Length read loop must wait for the second packet.
bool testSplitRequest()
{
    bool result = true;
    string host = "127.0.0.1";

    Socket* c = new Socket;
    if (!c->createTcp())               { delete c; Test("split connect", false, true); return false; }
    if (!c->connect(host, g_srv_port)) { delete c; Test("split connect", false, true); return false; }
    c->setNoDelay(true);

    string headers = "POST /echo HTTP/1.1\r\nHost: x\r\nContent-Length: 11\r\nConnection: close\r\n\r\n";
    c->send(headers.data(), headers.length());
    os.windows.Sleep(50);
    string bodyPart = "hello world";
    c->send(bodyPart.data(), bodyPart.length());

    string resp = _readAll(c);
    delete c;

    result &= Test("split request status", resp.startsWith("HTTP/1.1 200"), true);
    result &= Test("split request body",   resp.contains("hello world"), true);
    return result;
}

// 413: a body larger than the server's maxRequestBytes must be rejected.
bool testPayloadTooLarge(HttpClient* client)
{
    bool result = true;
    string host = "127.0.0.1";

    int n = 32768;            // > the small server's 16384 cap
    stringbuilder body;
    int bi = 0;
    while (bi < n) { body.appendChar('x'); bi++; }
    string bodyStr = body.toString();

    HttpClientResponse* resp = client->post(host, g_small_port, "/echo", bodyStr);
    result &= Test("413 not null", resp != nullptr, true);
    if (resp != nullptr)
    {
        result &= Test("413 status", resp->statusCode, 413);
        delete resp;
    }
    return result;
}

// ---------------------------------------------------------------------------

extern int main()
{
    if (!Socket.initNetwork())
    {
        printf("FAIL: initNetwork\n");
        return 1;
    }

    stop_source src;
    src.init();

    HttpServer srv;
    srv.port        = g_srv_port;
    srv.workerCount = 4;
    srv.stopToken   = src.get_token();
    srv.handler     = testHandler;

    // Second server with a small request cap, for the 413 test.
    stop_source srcSmall;
    srcSmall.init();

    HttpServer srvSmall;
    srvSmall.port            = g_small_port;
    srvSmall.workerCount     = 2;
    srvSmall.maxRequestBytes = 16384;
    srvSmall.stopToken       = srcSmall.get_token();
    srvSmall.handler         = testHandler;

    list<string> srvArgs;
    srv.run(srvArgs);
    list<string> smallArgs;
    srvSmall.run(smallArgs);
    os.windows.Sleep(50);   // give the server threads time to start listening

    HttpClient client;
    bool ok = true;

    ok &= testGetHello(&client);
    ok &= testGetNotFound(&client);
    ok &= testPostEcho(&client);
    ok &= testPutReplace(&client);
    ok &= testDeleteItem(&client);
    ok &= testGetJson(&client);
    ok &= testPostEmptyBody(&client);
    ok &= testPostLarge(&client);
    ok &= testSplitRequest();
    ok &= testPayloadTooLarge(&client);

    src.request_stop();
    srv.WaitForExit();
    src.dispose();

    srcSmall.request_stop();
    srvSmall.WaitForExit();
    srcSmall.dispose();

    Socket.shutdownNetwork();

    if (ok) printf("HTTP server/client tests: all passed.\n");
    else    printf("HTTP server/client tests: FAILED.\n");
    return ok ? 0 : 1;
}
