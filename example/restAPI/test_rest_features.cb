import "list.cb";
import "thread.cb";
import "stop_token.cb";
import "test_helper.cb";
import "json.cb";
import "network/rest_server.cb";
import "network/http_client.cb";
import "network/http_json.cb";

int g_feat_port = 17901;

// ── Request handlers ──────────────────────────────────────────────────────────

HttpResponse* featHelloHandler(HttpRequest* req)
{
    return HttpResponse.ok("hello");
}

HttpResponse* featUserHandler(HttpRequest* req)
{
    if (!req->hasParam("id")) return HttpResponse.badRequest("missing id");
    return HttpResponse.ok(req->getParam("id"));
}

HttpResponse* featOrgRepoHandler(HttpRequest* req)
{
    if (!req->hasParam("org") || !req->hasParam("repo"))
        return HttpResponse.badRequest("missing param");
    // String idioms: combine org/repo with operator+ into the response body.
    return HttpResponse.ok(req->getParam("org") + "/" + req->getParam("repo"));
}

HttpResponse* featMeHandler(HttpRequest* req)
{
    return HttpResponse.ok("me-exact");
}

HttpResponse* featSearchHandler(HttpRequest* req)
{
    if (!req->hasQuery("q")) return HttpResponse.badRequest("missing q");
    if (req->hasQuery("page"))
        return HttpResponse.ok(req->getQuery("q") + ":" + req->getQuery("page"));
    return HttpResponse.ok(req->getQuery("q"));
}

// Status code handlers
HttpResponse* featCreatedHandler(HttpRequest* req) { return HttpResponse.created("born"); }
HttpResponse* featNoContentHandler(HttpRequest* req) { return HttpResponse.noContent(); }
HttpResponse* featBadRequestHandler(HttpRequest* req) { return HttpResponse.badRequest("nope"); }
HttpResponse* featUnauthorizedHandler(HttpRequest* req) { return HttpResponse.unauthorized("denied"); }
HttpResponse* featForbiddenHandler(HttpRequest* req) { return HttpResponse.forbidden("forbidden"); }
HttpResponse* featMethodHandler(HttpRequest* req) { return HttpResponse.methodNotAllowed(); }

// Large-body echo through the router path.
HttpResponse* featBigHandler(HttpRequest* req) { return HttpResponse.ok(req->body); }

// JSON handler
struct FeatureItem {
    int id = 0;
};

HttpResponse* featJsonEchoHandler(HttpRequest* req)
{
    FeatureItem item = HttpJson.parse<FeatureItem>(req);
    return HttpJson.respond<FeatureItem>(item);
}

// ── Main ──────────────────────────────────────────────────────────────────────

extern int main()
{
    if (!Socket.initNetwork()) { printf("FAIL: initNetwork\n"); return 1; }

    stop_source src;
    src.init();

    RestServer srv;
    srv.port        = g_feat_port;
    srv.workerCount = 4;
    srv.stopToken   = src.get_token();

    // Path params
    srv.get("/hello",              featHelloHandler);
    srv.get("/users/me",           featMeHandler);        // exact - takes priority over :id
    srv.get("/users/:id",          featUserHandler);
    srv.get("/orgs/:org/repos/:repo", featOrgRepoHandler);

    // Query string
    srv.get("/search",             featSearchHandler);

    // Status codes
    srv.post("/status/created",    featCreatedHandler);
    srv.get("/status/nocontent",   featNoContentHandler);
    srv.get("/status/badrequest",  featBadRequestHandler);
    srv.get("/status/unauthorized",featUnauthorizedHandler);
    srv.get("/status/forbidden",   featForbiddenHandler);
    srv.get("/status/notallowed",  featMethodHandler);

    // JSON body
    srv.post("/json/echo",         featJsonEchoHandler);

    // Large body
    srv.post("/big",               featBigHandler);

    list<string> srvArgs;
    srv.run(srvArgs);
    os.windows.Sleep(50);

    HttpClient client;
    bool ok = true;
    string host = "127.0.0.1";

    // ── Path parameters ───────────────────────────────────────────────────────

    {
        HttpClientResponse* resp = client.get(host, g_feat_port, "/users/42");
        ok &= Test("param /users/:id not null", resp != nullptr, true);
        if (resp != nullptr)
        {
            ok &= Test("param /users/:id status", resp->statusCode, 200);
            ok &= Test("param /users/:id body", resp->body.contains("42"), true);
            delete resp;
        }
    }

    {
        HttpClientResponse* resp = client.get(host, g_feat_port, "/orgs/acme/repos/widget");
        ok &= Test("param /orgs/:org/repos/:repo not null", resp != nullptr, true);
        if (resp != nullptr)
        {
            ok &= Test("param two-param status", resp->statusCode, 200);
            ok &= Test("param two-param body", resp->body.contains("acme/widget"), true);
            delete resp;
        }
    }

    {
        // Exact route /users/me must win over parameterized /users/:id
        HttpClientResponse* resp = client.get(host, g_feat_port, "/users/me");
        ok &= Test("exact beats param not null", resp != nullptr, true);
        if (resp != nullptr)
        {
            ok &= Test("exact beats param status", resp->statusCode, 200);
            ok &= Test("exact beats param body", resp->body.contains("me-exact"), true);
            delete resp;
        }
    }

    // ── Query string ──────────────────────────────────────────────────────────

    {
        HttpClientResponse* resp = client.get(host, g_feat_port, "/search?q=hello&page=2");
        ok &= Test("query multi-param not null", resp != nullptr, true);
        if (resp != nullptr)
        {
            ok &= Test("query multi-param status", resp->statusCode, 200);
            ok &= Test("query multi-param body q",    resp->body.contains("hello"), true);
            ok &= Test("query multi-param body page", resp->body.contains("2"), true);
            delete resp;
        }
    }

    {
        HttpClientResponse* resp = client.get(host, g_feat_port, "/search?q=hello%20world");
        ok &= Test("query url-decode not null", resp != nullptr, true);
        if (resp != nullptr)
        {
            ok &= Test("query url-decode status", resp->statusCode, 200);
            ok &= Test("query url-decode body", resp->body.contains("hello world"), true);
            delete resp;
        }
    }

    {
        HttpClientResponse* resp = client.get(host, g_feat_port, "/search?q=a+b");
        ok &= Test("query plus-space not null", resp != nullptr, true);
        if (resp != nullptr)
        {
            ok &= Test("query plus-space status", resp->statusCode, 200);
            ok &= Test("query plus-space body", resp->body.contains("a b"), true);
            delete resp;
        }
    }

    // ── Status codes ─────────────────────────────────────────────────────────

    {
        HttpClientResponse* resp = client.post(host, g_feat_port, "/status/created", "");
        ok &= Test("201 created not null", resp != nullptr, true);
        if (resp != nullptr) { ok &= Test("201 created status", resp->statusCode, 201); delete resp; }
    }
    {
        HttpClientResponse* resp = client.get(host, g_feat_port, "/status/nocontent");
        ok &= Test("204 nocontent not null", resp != nullptr, true);
        if (resp != nullptr) { ok &= Test("204 nocontent status", resp->statusCode, 204); delete resp; }
    }
    {
        HttpClientResponse* resp = client.get(host, g_feat_port, "/status/badrequest");
        ok &= Test("400 bad request not null", resp != nullptr, true);
        if (resp != nullptr) { ok &= Test("400 bad request status", resp->statusCode, 400); delete resp; }
    }
    {
        HttpClientResponse* resp = client.get(host, g_feat_port, "/status/unauthorized");
        ok &= Test("401 unauthorized not null", resp != nullptr, true);
        if (resp != nullptr) { ok &= Test("401 unauthorized status", resp->statusCode, 401); delete resp; }
    }
    {
        HttpClientResponse* resp = client.get(host, g_feat_port, "/status/forbidden");
        ok &= Test("403 forbidden not null", resp != nullptr, true);
        if (resp != nullptr) { ok &= Test("403 forbidden status", resp->statusCode, 403); delete resp; }
    }
    {
        HttpClientResponse* resp = client.get(host, g_feat_port, "/status/notallowed");
        ok &= Test("405 method not allowed not null", resp != nullptr, true);
        if (resp != nullptr) { ok &= Test("405 method not allowed status", resp->statusCode, 405); delete resp; }
    }

    // ── JSON body (HttpJson) ──────────────────────────────────────────────────

    {
        HttpClientResponse* resp = client.post(host, g_feat_port, "/json/echo", "\{\"id\":99\}");
        ok &= Test("json echo not null", resp != nullptr, true);
        if (resp != nullptr)
        {
            ok &= Test("json echo status", resp->statusCode, 200);
            ok &= Test("json echo content-type",
                       resp->getHeader("Content-Type") == "application/json", true);
            ok &= Test("json echo body has 99", resp->body.contains("99"), true);
            delete resp;
        }
    }

    // ── Large body POST through the router ─────────────────────────────────────

    {
        int n = 50000;
        stringbuilder body;
        int bi = 0;
        while (bi < n) { body.appendChar((i8)('0' + (bi % 10))); bi++; }
        string bodyStr = body.toString();

        HttpClientResponse* resp = client.post(host, g_feat_port, "/big", bodyStr);
        ok &= Test("big POST not null", resp != nullptr, true);
        if (resp != nullptr)
        {
            ok &= Test("big POST status", resp->statusCode, 200);
            ok &= Test("big POST length", resp->body.length(), n);
            ok &= Test("big POST roundtrip", resp->body == bodyStr, true);
            delete resp;
        }
    }

    // ── Concurrent connections ────────────────────────────────────────────────

    {
        bool concOk = true;
        int ci = 0;
        while (ci < 5)
        {
            HttpClientResponse* resp = client.get(host, g_feat_port, "/hello");
            if (resp == nullptr || resp->statusCode != 200)
                concOk = false;
            if (resp != nullptr) delete resp;
            ci++;
        }
        ok &= Test("concurrent 5x GET /hello", concOk, true);
    }

    src.request_stop();
    srv.WaitForExit();
    src.dispose();

    Socket.shutdownNetwork();

    if (ok) printf("test_rest_features: all passed.\n");
    else    printf("test_rest_features: FAILED.\n");
    return ok ? 0 : 1;
}
