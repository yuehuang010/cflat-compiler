import "network/http_parser.cb";
import "network/http_response.cb";

extern int main()
{
    bool ok = true;

    // ── 1. GET with two headers ───────────────────────────────────────────────

    i8* raw1 = "GET /api/users HTTP/1.1\r\nHost: localhost\r\nAccept: application/json\r\n\r\n";
    HttpRequest* req1 = parseHttpRequest(raw1, strlen(raw1));

    if (!req1->valid)                       { printf("FAIL 1: GET not valid\n");    ok = false; }
    if (req1->method  != "GET")             { printf("FAIL 1: method\n");           ok = false; }
    if (req1->path    != "/api/users")      { printf("FAIL 1: path\n");             ok = false; }
    if (req1->version != "HTTP/1.1")        { printf("FAIL 1: version\n");          ok = false; }
    if (req1->headerCount() != 2)           { printf("FAIL 1: headerCount\n");      ok = false; }
    if (req1->body.length() != 0)           { printf("FAIL 1: body should be 0\n"); ok = false; }

    if (req1->getHeader("Host") != "localhost")
        { printf("FAIL 1: Host header\n"); ok = false; }
    if (req1->getHeader("Accept") != "application/json")
        { printf("FAIL 1: Accept header\n"); ok = false; }

    delete req1;

    // ── 2. POST with body ─────────────────────────────────────────────────────

    i8* raw2 = "POST /submit HTTP/1.1\r\nContent-Length: 6\r\nContent-Type: text/plain\r\n\r\nhello!";
    HttpRequest* req2 = parseHttpRequest(raw2, strlen(raw2));

    if (!req2->valid)                    { printf("FAIL 2: POST not valid\n");  ok = false; }
    if (req2->method != "POST")          { printf("FAIL 2: method\n");          ok = false; }
    if (req2->path != "/submit")         { printf("FAIL 2: path\n");            ok = false; }
    if (req2->contentLength() != 6)      { printf("FAIL 2: Content-Length\n");  ok = false; }
    if (req2->body.length() != 6)        { printf("FAIL 2: body len\n");        ok = false; }
    if (req2->body != "hello!")          { printf("FAIL 2: body content\n");    ok = false; }

    delete req2;

    // ── 3. Empty input -> valid=false ─────────────────────────────────────────

    i8* raw3 = "";
    HttpRequest* req3 = parseHttpRequest(raw3, 0);
    if (req3->valid) { printf("FAIL 3: empty input should be invalid\n"); ok = false; }
    delete req3;

    // ── 4. No CRLF -> valid=false ─────────────────────────────────────────────

    i8* raw4 = "GET / HTTP/1.1";
    HttpRequest* req4 = parseHttpRequest(raw4, strlen(raw4));
    if (req4->valid) { printf("FAIL 4: no CRLF should be invalid\n"); ok = false; }
    delete req4;

    // ── 5. No headers, blank line only ───────────────────────────────────────

    i8* raw5 = "GET / HTTP/1.0\r\n\r\n";
    HttpRequest* req5 = parseHttpRequest(raw5, strlen(raw5));

    if (!req5->valid)                  { printf("FAIL 5: no-header not valid\n"); ok = false; }
    if (req5->method  != "GET")        { printf("FAIL 5: method\n");              ok = false; }
    if (req5->path    != "/")          { printf("FAIL 5: path\n");                ok = false; }
    if (req5->version != "HTTP/1.0")   { printf("FAIL 5: version\n");             ok = false; }
    if (req5->headerCount() != 0)      { printf("FAIL 5: headerCount\n");         ok = false; }
    if (req5->body.length() != 0)      { printf("FAIL 5: body\n");                ok = false; }

    delete req5;

    // ── 6. Header value with leading and trailing whitespace ─────────────────

    i8* raw6 = "GET / HTTP/1.1\r\nX-Pad:   hello   \r\n\r\n";
    HttpRequest* req6 = parseHttpRequest(raw6, strlen(raw6));

    if (!req6->valid) { printf("FAIL 6: not valid\n"); ok = false; }
    if (req6->getHeader("X-Pad") != "hello")
        { printf("FAIL 6: whitespace not trimmed\n"); ok = false; }

    delete req6;

    // ── 7. Header value containing a colon ───────────────────────────────────

    i8* raw7 = "GET / HTTP/1.1\r\nAuthorization: Bearer tok:en\r\n\r\n";
    HttpRequest* req7 = parseHttpRequest(raw7, strlen(raw7));

    if (!req7->valid) { printf("FAIL 7: not valid\n"); ok = false; }
    if (req7->getHeader("Authorization") != "Bearer tok:en")
        { printf("FAIL 7: colon in value\n"); ok = false; }

    delete req7;

    // ── 8. DELETE method and query-string path ────────────────────────────────

    i8* raw8 = "DELETE /res/42?cascade=true HTTP/1.1\r\nHost: api.example.com\r\n\r\n";
    HttpRequest* req8 = parseHttpRequest(raw8, strlen(raw8));

    if (!req8->valid)                         { printf("FAIL 8: not valid\n");   ok = false; }
    if (req8->method != "DELETE")             { printf("FAIL 8: method\n");      ok = false; }
    if (req8->path   != "/res/42")            { printf("FAIL 8: path\n");        ok = false; }
    if (req8->queryCount() != 1)              { printf("FAIL 8: queryCount\n");  ok = false; }
    if (req8->getQuery("cascade") != "true")  { printf("FAIL 8: query\n");       ok = false; }

    delete req8;

    // ── 9. getHeader miss -> "" / not present; missing Content-Length -> 0 ────

    i8* raw9 = "GET / HTTP/1.1\r\nHost: x\r\n\r\n";
    HttpRequest* req9 = parseHttpRequest(raw9, strlen(raw9));

    if (req9->hasHeader("X-Missing"))
        { printf("FAIL 9: missing header should not be present\n"); ok = false; }
    if (!req9->getHeader("X-Missing").isEmpty())
        { printf("FAIL 9: missing header should return empty\n"); ok = false; }
    if (req9->contentLength() != 0)
        { printf("FAIL 9: missing Content-Length should return 0\n"); ok = false; }

    delete req9;

    // ── 10. PUT with body ─────────────────────────────────────────────────────

    i8* raw10 = "PUT /items/1 HTTP/1.1\r\nContent-Length: 4\r\n\r\ndata";
    HttpRequest* req10 = parseHttpRequest(raw10, strlen(raw10));

    if (!req10->valid)               { printf("FAIL 10: not valid\n");  ok = false; }
    if (req10->method != "PUT")      { printf("FAIL 10: method\n");     ok = false; }
    if (req10->body.length() != 4)   { printf("FAIL 10: bodyLen\n");    ok = false; }
    if (req10->body != "data")       { printf("FAIL 10: body\n");       ok = false; }

    delete req10;

    // ── 11. Four headers - all parsed and retrievable ─────────────────────────

    i8* raw11 = "GET / HTTP/1.1\r\nA: 1\r\nB: 2\r\nC: 3\r\nD: 4\r\n\r\n";
    HttpRequest* req11 = parseHttpRequest(raw11, strlen(raw11));

    if (!req11->valid)              { printf("FAIL 11: not valid\n");   ok = false; }
    if (req11->headerCount() != 4)  { printf("FAIL 11: headerCount\n"); ok = false; }
    if (req11->getHeader("A") != "1") { printf("FAIL 11: A\n"); ok = false; }
    if (req11->getHeader("B") != "2") { printf("FAIL 11: B\n"); ok = false; }
    if (req11->getHeader("C") != "3") { printf("FAIL 11: C\n"); ok = false; }
    if (req11->getHeader("D") != "4") { printf("FAIL 11: D\n"); ok = false; }

    delete req11;

    // ── 12. Header with empty value ───────────────────────────────────────────

    i8* raw12 = "GET / HTTP/1.1\r\nX-Empty:\r\n\r\n";
    HttpRequest* req12 = parseHttpRequest(raw12, strlen(raw12));

    if (!req12->valid) { printf("FAIL 12: not valid\n"); ok = false; }
    if (!req12->hasHeader("X-Empty"))             { printf("FAIL 12: X-Empty should be present\n"); ok = false; }
    if (!req12->getHeader("X-Empty").isEmpty())   { printf("FAIL 12: X-Empty should be empty\n");   ok = false; }

    delete req12;

    // ── 13. Response: no body -> Content-Length absent ─────────────────────────

    HttpResponse* r13 = new HttpResponse;
    r13->setStatus(204, "No Content");
    string out13 = r13->build();

    if (!out13.startsWith("HTTP/1.1 204 No Content\r\n"))
        { printf("FAIL 13: 204 status line\n"); ok = false; }
    if (out13.contains("Content-Length"))
        { printf("FAIL 13: Content-Length should be absent\n"); ok = false; }
    if (!out13.contains("Connection: close\r\n"))
        { printf("FAIL 13: Connection: close missing\n"); ok = false; }

    delete r13;

    // ── 14. setBody() called twice -> second replaces first ────────────────────

    HttpResponse* r14 = HttpResponse.ok();
    r14->setBody("first");
    r14->setBody("second");
    string out14 = r14->build();

    if (!out14.contains("second"))
        { printf("FAIL 14: second body missing\n"); ok = false; }
    if (out14.contains("first"))
        { printf("FAIL 14: first body should be gone\n"); ok = false; }
    if (out14.contains("Content-Length: 5"))
        { printf("FAIL 14: old Content-Length still present\n"); ok = false; }
    if (!out14.contains("Content-Length: 6"))
        { printf("FAIL 14: new Content-Length missing\n"); ok = false; }

    delete r14;

    // ── 15. Multiple addHeader calls - all appear in output ───────────────────

    HttpResponse* r15 = HttpResponse.ok();
    r15->addHeader("X-A", "alpha");
    r15->addHeader("X-B", "beta");
    string out15 = r15->build();

    if (!out15.contains("X-A: alpha\r\n")) { printf("FAIL 15: X-A header missing\n"); ok = false; }
    if (!out15.contains("X-B: beta\r\n"))  { printf("FAIL 15: X-B header missing\n"); ok = false; }

    delete r15;

    // ── 16. Blank line separator before body ──────────────────────────────────

    HttpResponse* r16 = HttpResponse.ok("hi");
    string out16 = r16->build();

    if (!out16.contains("\r\n\r\n"))
        { printf("FAIL 16: blank line separator missing\n"); ok = false; }

    delete r16;

    // ── 17. setStatus() custom 201 Created ───────────────────────────────────

    HttpResponse* r17 = new HttpResponse;
    r17->setStatus(201, "Created");
    r17->setBody("new");
    string out17 = r17->build();

    if (!out17.startsWith("HTTP/1.1 201 Created\r\n"))
        { printf("FAIL 17: 201 Created status\n"); ok = false; }

    delete r17;

    // ── 18. Content-Length matches body size ─────────────────────────────────

    HttpResponse* r18 = HttpResponse.ok("hello");
    string out18 = r18->build();

    if (!out18.contains("Content-Length: 5\r\n"))
        { printf("FAIL 18: Content-Length should be 5\n"); ok = false; }

    delete r18;

    // ── 19. build() length matches strlen of output ───────────────────────────

    HttpResponse* r19 = HttpResponse.ok("abc");
    string out19 = r19->build();

    if (out19.length() != strlen(out19.data()))
        { printf("FAIL 19: length mismatch\n"); ok = false; }

    delete r19;

    // ── 20. serverError() -> default body ──────────────────────────────────────

    HttpResponse* r20 = HttpResponse.serverError();
    string out20 = r20->build();

    if (!out20.startsWith("HTTP/1.1 500 Internal Server Error\r\n"))
        { printf("FAIL 20: 500 status line\n"); ok = false; }
    if (!out20.contains("Internal Server Error"))
        { printf("FAIL 20: default body missing\n"); ok = false; }

    delete r20;

    // ── 21. okJson - Content-Type and body ───────────────────────────────────

    HttpResponse* r21 = HttpResponse.okJson();
    r21->setBody("42");
    string out21 = r21->build();

    if (!out21.contains("Content-Type: application/json\r\n"))
        { printf("FAIL 21: Content-Type\n"); ok = false; }
    if (!out21.contains("42"))
        { printf("FAIL 21: body\n"); ok = false; }

    delete r21;

    // ── 22. 404 Not Found ─────────────────────────────────────────────────────

    HttpResponse* r22 = HttpResponse.notFound();
    string out22 = r22->build();

    if (!out22.startsWith("HTTP/1.1 404 Not Found\r\n"))
        { printf("FAIL 22: 404 status line\n"); ok = false; }

    delete r22;

    // ── 23. Header with colon in value survives round-trip ───────────────────

    i8* raw23 = "GET / HTTP/1.1\r\nAuthorization: Basic dXNlcjpwYXNz\r\n\r\n";
    HttpRequest* req23 = parseHttpRequest(raw23, strlen(raw23));

    HttpResponse* r23 = HttpResponse.ok();
    if (req23->hasHeader("Authorization"))
        r23->addHeader("X-Echo-Auth", req23->getHeader("Authorization"));
    string out23 = r23->build();

    if (!out23.contains("X-Echo-Auth: Basic dXNlcjpwYXNz\r\n"))
        { printf("FAIL 23: auth echo\n"); ok = false; }

    delete req23;
    delete r23;

    // ── 24. PATCH method ─────────────────────────────────────────────────────

    i8* raw24 = "PATCH /doc/7 HTTP/1.1\r\nContent-Length: 3\r\n\r\nfoo";
    HttpRequest* req24 = parseHttpRequest(raw24, strlen(raw24));

    if (!req24->valid)              { printf("FAIL 24: not valid\n"); ok = false; }
    if (req24->method != "PATCH")   { printf("FAIL 24: method\n");    ok = false; }
    if (req24->body.length() != 3)  { printf("FAIL 24: bodyLen\n");   ok = false; }
    if (req24->body != "foo")       { printf("FAIL 24: body\n");      ok = false; }

    delete req24;

    // ── 25. Large response body (>100KB) through build() ──────────────────────
    // The old fixed-buffer build() overflowed an i8[65536]; the stringbuilder
    // version must handle bodies larger than that without truncation.

    {
        int bigLen = 200000;
        i8* big = new i8[bigLen + 1];
        int bi = 0;
        while (bi < bigLen) { big[bi] = (i8)('A' + (bi % 26)); bi++; }
        big[bigLen] = 0;
        string bigBody = default;
        bigBody._ptr = big;
        bigBody._len = bigLen;

        HttpResponse* r25 = HttpResponse.ok(bigBody);
        string out25 = r25->build();

        if (!out25.contains("Content-Length: 200000\r\n"))
            { printf("FAIL 25: large Content-Length\n"); ok = false; }
        // Header block + CRLFCRLF + body; the full output must be at least as long
        // as the body (the old fixed i8[65536] build would have truncated/overflowed).
        if (out25.length() < bigLen)
            { printf("FAIL 25: large body truncated\n"); ok = false; }
        // Verify the body bytes survived verbatim: the response ends with the
        // original buffer, so its tail must equal the tail of bigBody.
        if (!out25.endsWith(bigBody.substring(bigLen - 64)))
            { printf("FAIL 25: large body tail corrupted\n"); ok = false; }

        delete r25;
        delete big;
    }

    // ── 26. Body containing an embedded \r\n\r\n (length-based copy) ───────────
    // A naive scan would treat the inner blank line as the header terminator and
    // mis-copy the body; the length-based copy must preserve all bytes.

    {
        i8* raw26 = "POST /p HTTP/1.1\r\nContent-Length: 10\r\n\r\nab\r\n\r\ncdef";
        HttpRequest* req26 = parseHttpRequest(raw26, strlen(raw26));

        if (!req26->valid)              { printf("FAIL 26: not valid\n");  ok = false; }
        if (req26->body.length() != 10) { printf("FAIL 26: body length\n"); ok = false; }
        if (req26->body != "ab\r\n\r\ncdef") { printf("FAIL 26: body content\n"); ok = false; }
        if (req26->contentLength() != 10) { printf("FAIL 26: content-length\n"); ok = false; }

        delete req26;
    }

    if (ok) printf("PASS: http comprehensive tests\n");
    return ok ? 0 : 1;
}
