// mkdir.cb - create a directory.
//
// Build: x64/Debug/cflat.exe example/shell/mkdir.cb -o out/mkdir.exe
// Run:   out\mkdir.exe path

import "filesystem.cb";

extern int main(int argc, char** argv)
{
    if (argc < 2) { printf("Usage: mkdir <path>\n"); return 1; }
    string path = (string)argv[1];
    if (!Directory.create(path))
    {
        printf("A subdirectory or file '%s' already exists.\n", path.data());
        return 1;
    }
    return 0;
}
