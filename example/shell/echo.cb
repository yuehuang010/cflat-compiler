// echo.cb - print the arguments, separated by single spaces.
//
// Build: x64/Debug/cflat.exe example/shell/echo.cb -o out/echo.exe
// Run:   out\echo.exe hello world

extern int main(int argc, char** argv)
{
    int i = 1;
    while (i < argc)
    {
        if (i > 1) printf(" ");
        printf("%s", argv[i]);
        i++;
    }
    printf("\n");
    return 0;
}
