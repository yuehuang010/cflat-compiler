// rmdir.cb - remove an empty directory.
//
// Build: x64/Debug/cflat.exe example/shell/rmdir.cb -o out/rmdir.exe
// Run:   out\rmdir.exe path

import "filesystem.cb";

extern int main(int argc, char** argv)
{
    if (argc < 2) { printf("Usage: rmdir <path>\n"); return 1; }
    string path = (string)argv[1];
    if (!Directory.remove(path))
    {
        printf("The directory is not empty or does not exist: '%s'\n", path.data());
        return 1;
    }
    return 0;
}
