// Test BlockAllocator — fixed-block-size page allocator
import "block_allocator.cb";

extern int main()
{
    // ── basic alloc ───────────────────────────────────────────────────────────
    BlockAllocator ba;

    void* p1 = ba.alloc(32);
    if (p1 == nullptr) return 1;

    void* p2 = ba.alloc(16);
    if (p2 == nullptr) return 2;
    if (p1 == p2) return 3;   // must be distinct blocks

    if (ba.usedBlocks() != 2) return 4;
    if (ba.totalBlocks() < 2) return 5;

    // ── dealloc decrements usedBlocks ─────────────────────────────────────────
    ba.dealloc(p1);
    if (ba.usedBlocks() != 1) return 6;

    // ── re-alloc reuses freed slot ────────────────────────────────────────────
    void* p3 = ba.alloc(8);
    if (p3 == nullptr) return 7;
    if (p3 != p1) return 8;   // slot 0 was freed; scanner finds it first
    if (ba.usedBlocks() != 2) return 9;

    // ── oversized request returns nullptr ─────────────────────────────────────
    void* big = ba.alloc(128);   // 128 > blockSize (64)
    if (big != nullptr) return 10;

    // ── write and read back through allocated block ───────────────────────────
    i32* nums = (i32*)ba.alloc(16);
    if (nums == nullptr) return 11;
    nums[0] = 10;
    nums[1] = 20;
    nums[2] = 30;
    nums[3] = 40;
    if (nums[0] != 10) return 12;
    if (nums[3] != 40) return 13;
    ba.dealloc((void*)nums);

    ba.PrintUsage();

    // ── page overflow: filling a page creates a second one ────────────────────
    BlockAllocator ba2;

    // Alloc until we know one page's capacity.
    void* first = ba2.alloc(1);
    if (first == nullptr) return 14;

    i64 pageCapacity = ba2.totalBlocks();   // blocks in the first page
    if (pageCapacity < 2) return 15;

    // Fill the rest of the page.
    i64 filled = 1;
    while (filled < pageCapacity)
    {
        void* slot = ba2.alloc(1);
        if (slot == nullptr) return 16;
        filled = filled + 1;
    }
    if (ba2.usedBlocks() != pageCapacity) return 17;
    if (ba2.totalBlocks() != pageCapacity) return 18;   // still one page

    // One more alloc triggers a second page.
    void* overflow = ba2.alloc(1);
    if (overflow == nullptr) return 19;
    if (ba2.totalBlocks() <= pageCapacity) return 20;   // second page added

    ba2.PrintUsage();

    return 0;
}
