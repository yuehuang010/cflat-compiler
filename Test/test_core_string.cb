import "string.cb";
import "test_helper.cb";

// ── string / stringbuilder ────────────────────────────────────────────────────

int testString()
{
    int passed = 0;

    string s = "hello";
    passed += Test("string literal length", s.length(), 5);
    passed += Test("string literal data",   s.data(),   "hello");

    string empty = "";
    passed += Test("empty string length", empty.length(), 0);

    stringbuilder sb;
    passed += Test("sb initial length", sb.length(), 0);

    sb.appendCStr("foo");
    passed += Test("sb after appendCStr length", sb.length(), 3);
    passed += Test("sb after appendCStr data",   sb.data(),   "foo");

    sb.appendChar('!');
    passed += Test("sb after appendChar length", sb.length(), 4);
    passed += Test("sb after appendChar data",   sb.data(),   "foo!");

    string view = sb.toString();
    passed += Test("sb toString length", view.length(), 4);
    passed += Test("sb toString data",   view.data(),   "foo!");

    sb.clear();
    passed += Test("sb after clear length", sb.length(), 0);

    return passed;
}

// ── string operator+ ─────────────────────────────────────────────────────────

int testStringConcat()
{
    int passed = 0;

    string a = "hello";
    string b = " world";

    string c = a + b;
    passed += Test("concat length",  c.length(), 11);
    passed += Test("concat data",    c.data(),   "hello world");

    string d = a + " there";
    passed += Test("concat char* length", d.length(), 11);
    passed += Test("concat char* data",   d.data(),   "hello there");

    string e = c + b;
    passed += Test("chained concat length", e.length(), 17);
    passed += Test("chained concat data",   e.data(),   "hello world world");

    string empty = "";
    string f = empty + a;
    passed += Test("empty + s length", f.length(), 5);
    passed += Test("empty + s data",   f.data(),   "hello");

    string g = a + empty;
    passed += Test("s + empty length", g.length(), 5);
    passed += Test("s + empty data",   g.data(),   "hello");

    return passed;
}

// ── string + IString ─────────────────────────────────────────────────────────

class Greeting : IString
{
    string ToString()
    {
        string s = "world";
        return s;
    }
};

int testStringIString()
{
    int passed = 0;

    string prefix = "hello ";
    Greeting g;

    string result = prefix + g;
    passed += Test("istring concat length", result.length(), 11);
    passed += Test("istring concat data",   result.data(),   "hello world");

    string result2 = "goodbye " + g;
    passed += Test("istring literal concat length", result2.length(), 13);
    passed += Test("istring literal concat data",   result2.data(),   "goodbye world");

    return passed;
}

// ── string interpolation ─────────────────────────────────────────────────────

class Color : IString
{
    i32 r = 0;
    i32 g = 0;
    i32 b = 0;

    string ToString()
    {
        return "rgb({r},{g},{b})";
    }
};

int testInterpolation()
{
    int passed = 0;

    string name = "World";
    passed += Test("interp_simple",    "Hello {name}!",  "Hello World!");

    string a = "foo";
    string b = "bar";
    passed += Test("interp_two_vars",  "{a} and {b}",    "foo and bar");

    string x = "AB";
    string y = "CD";
    passed += Test("interp_adjacent",  "{x}{y}",         "ABCD");

    string mid = "mid";
    passed += Test("interp_sandwich",  "pre-{mid}-suf",  "pre-mid-suf");

    i32 n = 42;
    passed += Test("interp_int",       "n={n}",          "n=42");

    i32 big = 1000;
    passed += Test("interp_int_big",   "big={big}",      "big=1000");

    Color c;
    c.r = 255;
    c.g = 128;
    c.b = 0;
    passed += Test("interp_istring",   "color={c}",      "color=rgb(255,128,0)");

    string label = "score";
    i32 value = 99;
    passed += Test("interp_mixed",     "{label}={value}", "score=99");

    return passed;
}

// ── string switch/case ───────────────────────────────────────────────────────

int testStringSwitch()
{
    int passed = 0;

    string fruit = "Apple";
    int result = -1;
    switch (fruit)
    {
        case "Apple":  result = 1; break;
        case "Banana": result = 2; break;
        case "Cherry": result = 3; break;
        default:       result = 0; break;
    }
    passed += Test("switch_match_apple", result, 1);

    fruit = "Banana";
    result = -1;
    switch (fruit)
    {
        case "Apple":  result = 1; break;
        case "Banana": result = 2; break;
        case "Cherry": result = 3; break;
        default:       result = 0; break;
    }
    passed += Test("switch_match_banana", result, 2);

    fruit = "Mango";
    result = -1;
    switch (fruit)
    {
        case "Apple":  result = 1; break;
        case "Banana": result = 2; break;
        case "Cherry": result = 3; break;
        default:       result = 0; break;
    }
    passed += Test("switch_default", result, 0);

    string a = "hello";
    string b = "hello";
    string c = "world";
    passed += Test("str_eq_same",  a == b, true);
    passed += Test("str_eq_diff",  a == c, false);
    passed += Test("str_neq_diff", a != c, true);

    return passed;
}

// ── stringbuilder (new overloads) ────────────────────────────────────────────

int testStringBuilder()
{
    int passed = 0;

    stringbuilder sb;
    string s = "hello";
    sb.append(s);
    passed += Test("sb_append_str_len",  sb.length(), 5);
    passed += Test("sb_append_str_data", sb.toString(), "hello");

    sb.append(", world");
    passed += Test("sb_append_cstr_len",  sb.length(), 12);
    passed += Test("sb_append_cstr_data", sb.toString(), "hello, world");

    sb.clear();
    sb.append(42);
    passed += Test("sb_append_int_pos",  sb.toString(), "42");

    sb.clear();
    sb.append(0);
    passed += Test("sb_append_int_zero", sb.toString(), "0");

    sb.clear();
    sb.append(-7);
    passed += Test("sb_append_int_neg",  sb.toString(), "-7");

    sb.clear();
    sb.append(true);
    passed += Test("sb_append_bool_true",  sb.toString(), "true");

    sb.clear();
    sb.append(false);
    passed += Test("sb_append_bool_false", sb.toString(), "false");

    sb.clear();
    sb.appendLine("hello");
    passed += Test("sb_appendLine_cstr_len",  sb.length(), 6);
    passed += Test("sb_appendLine_cstr_data", sb.toString(), "hello\n");

    sb.clear();
    string line = "world";
    sb.appendLine(line);
    passed += Test("sb_appendLine_str_len",  sb.length(), 6);
    passed += Test("sb_appendLine_str_data", sb.toString(), "world\n");

    sb.clear();
    sb.append("abc");
    passed += Test("sb_ToString", sb.ToString(), "abc");

    sb.clear();
    sb.append("score=");
    sb.append(99);
    sb.append(",done=");
    sb.append(true);
    passed += Test("sb_mixed_build", sb.toString(), "score=99,done=true");

    sb.clear();
    sb.appendLine("line1");
    sb.appendLine("line2");
    passed += Test("sb_multi_line_len",  sb.length(), 12);
    passed += Test("sb_multi_line_data", sb.toString(), "line1\nline2\n");

    sb.clear();
    int i = 0;
    while (i < 10)
    {
        sb.append("01234567890123456789");
        i++;
    }
    passed += Test("sb_growth_len", sb.length(), 200);

    sb.clear();
    passed += Test("sb_clear_len",  sb.length(), 0);
    sb.append("reused");
    passed += Test("sb_reuse_data", sb.toString(), "reused");

    return passed;
}

// ── string_view / view / span ─────────────────────────────────────────────────

int testStringView()
{
    int passed = 0;

    string source = "hello world";

    // view() - whole string
    string_view* wholeView = source.view();
    passed += Test("view_length", wholeView->length(), 11);
    passed += Test("view_data",   wholeView->data(),   "hello world");
    delete wholeView;

    // span() - middle slice "world"
    string_view* wordView = source.span(6, 11);
    passed += Test("span_mid_length", wordView->length(), 5);
    passed += Test("span_mid_get0",   (int)wordView->get(0), (int)'w');
    passed += Test("span_mid_get4",   (int)wordView->get(4), (int)'d');
    delete wordView;

    // span() - prefix "hello"
    string_view* prefixView = source.span(0, 5);
    passed += Test("span_prefix_length", prefixView->length(), 5);
    passed += Test("span_prefix_get0",   (int)prefixView->get(0), (int)'h');
    passed += Test("span_prefix_get4",   (int)prefixView->get(4), (int)'o');
    delete prefixView;

    // span() - empty slice (start == end)
    string_view* emptyView = source.span(3, 3);
    passed += Test("span_empty_length", emptyView->length(), 0);
    delete emptyView;

    // span() - out-of-bounds clamped to full string
    string_view* clampedView = source.span(-5, 100);
    passed += Test("span_clamp_length", clampedView->length(), 11);
    delete clampedView;

    // span() - inverted indices (start > end) clamped to empty
    string_view* invertedView = source.span(7, 3);
    passed += Test("span_inv_length", invertedView->length(), 0);
    delete invertedView;

    // view() on empty string
    string emptySource = "";
    string_view* emptyStringView = emptySource.view();
    passed += Test("view_empty_length", emptyStringView->length(), 0);
    delete emptyStringView;

    return passed;
}

// ── main ─────────────────────────────────────────────────────────────────────

extern int main()
{
    int passed = 0;
    int total  = 0;

    int r;

    r = testString();        passed += r; total += 11;
    r = testStringConcat();  passed += r; total += 10;
    r = testStringIString(); passed += r; total += 4;
    r = testInterpolation(); passed += r; total += 8;
    r = testStringSwitch();  passed += r; total += 6;
    r = testStringBuilder(); passed += r; total += 20;
    r = testStringView();    passed += r; total += 12;

    printf("\n%d / %d tests passed.\n", passed, total);
    return passed == total ? 0 : 1;
}
