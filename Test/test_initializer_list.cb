// Comprehensive positional / key:value brace-initializer tests across element types and constructs.
//   list<T>          = {v0, v1, ...}    -> add() per element
//   array<T>         = {v0, v1, ...}    -> init(N) then set(i, v)
//   dictionary<K,V>  = {k: v, ...}      -> set(k, v) per pair
//   T[N]             = {v0, v1, ...}    -> positional stores, trailing slots zero-filled
//   T[]              = {v0, v1, ...}    -> length-inferred backing array; thin T* points at elem 0
//
// CFlat does NOT implicitly down-convert, and the container paths (list/array/dictionary) drive
// add()/set() through overload resolution, so a genuinely narrowing element literal does not
// match: `list<u8> = {255}` (literal wider than u8) is intentionally rejected today, and is
// DISABLED below pending narrowing-conversion work. Note float literals default to f32 (1.5 is
// float, not double), so `list<float> = {1.5}` is NOT a narrow and is exercised here.
//
// Note: nested generic containers (list<list<int>>) are a separate, unrelated generics
// limitation - that type does not instantiate at all today - so they are out of scope here.
import "string.cb";
import "list.cb";
import "array.cb";
import "dictionary.cb";
import "test_helper.cb";

extern int main()
{
    int passed = 0;
    int total = 0;

    // ===== list<T> across element types =====
    list<int> li = {10, 20, 30};
    total++; passed += Test("list<int> count", li.count(), 3);
    total++; passed += Test("list<int> sum", li.get(0) + li.get(1) + li.get(2), 60);

    list<i64> lbig = {1000000000000, 2000000000000};
    total++; passed += Test("list<i64> count", lbig.count(), 2);
    total++; passed += Test("list<i64>[1]", lbig.get(1), (i64)2000000000000);

    list<bool> lbool = {true, false, true};
    total++; passed += Test("list<bool> count", lbool.count(), 3);
    total++; passed += Test("list<bool>[0]", lbool.get(0), true);
    total++; passed += Test("list<bool>[1]", lbool.get(1), false);

    list<string> ls = {"alpha", "beta", "gamma"};   // char* literals coerced to string
    total++; passed += Test("list<string> count", ls.count(), 3);
    total++; passed += Test("list<string>[0]", ls.get(0), "alpha");
    total++; passed += Test("list<string>[2]", ls.get(2), "gamma");

    list<float> lf = {1.5, 2.5};   // 1.5/2.5 are f32 literals -> match float element
    total++; passed += Test("list<float> count", lf.count(), 2);
    total++; passed += Test("list<float>[0]", lf.get(0), 1.5f);
    total++; passed += Test("list<float>[1]", lf.get(1), 2.5f);

    // DISABLED (genuine narrowing - no implicit down-convert; pending later work):
    //   list<u8>    lu = {1, 2, 255};      // int literal -> u8 narrows

    // ===== array<T> =====
    array<int> ai = {1, 2, 3, 4};
    total++; passed += Test("array<int> count", ai.count(), 4);
    total++; passed += Test("array<int>[3]", ai.get(3), 4);

    array<i64> al = {100, 200};                // widening: int literals -> i64 (allowed)
    total++; passed += Test("array<i64>[0]", al.get(0), (i64)100);

    array<float> af = {1.5, 2.5};              // f32 literals -> float element
    total++; passed += Test("array<float>[0]", af.get(0), 1.5f);
    total++; passed += Test("array<float>[1]", af.get(1), 2.5f);

    // ===== dictionary<K,V> =====
    dictionary<int, int> di = {1: 100, 2: 200, 3: 300};
    total++; passed += Test("dict<int,int> count", di.count(), 3);
    total++; passed += Test("dict<int,int>[2]", di.get(2), 200);

    dictionary<string, string> ds = {"k1": "v1", "k2": "v2"};
    total++; passed += Test("dict<string,string> count", ds.count(), 2);
    total++; passed += Test("dict<string,string>[k1]", ds.get("k1"), "v1");
    total++; passed += Test("dict<string,string>[k2]", ds.get("k2"), "v2");

    dictionary<int, string> dis = {1: "one", 2: "two"};
    total++; passed += Test("dict<int,string>[1]", dis.get(1), "one");

    // DISABLED (narrowing K and V): dictionary<u8, float> duf = {1: 1.5, 2: 2.5};

    // ===== fixed array T[N] =====
    int[5] fa = {7, 8, 9};                     // partial fill: trailing slots zero-filled
    total++; passed += Test("int[5][0]", fa[0], 7);
    total++; passed += Test("int[5][2]", fa[2], 9);
    total++; passed += Test("int[5][3] zero-fill", fa[3], 0);
    total++; passed += Test("int[5][4] zero-fill", fa[4], 0);

    int[3] fb = {100, 200, 300};               // fully populated
    total++; passed += Test("int[3] sum", fb[0] + fb[1] + fb[2], 600);

    i64[2] fd = {5000000000, 1};
    total++; passed += Test("i64[2][0]", fd[0], (i64)5000000000);

    char[4] fe = {72, 73, 0, 0};               // 'H', 'I' (char-from-int-constant, like C)
    total++; passed += Test("char[4][0]", (int)fe[0], 72);
    total++; passed += Test("char[4][1]", (int)fe[1], 73);

    bool[3] fg = {true, false, true};
    total++; passed += Test("bool[3][0]", fg[0], true);
    total++; passed += Test("bool[3][2]", fg[2], true);

    float[3] fc = {1.5, 2.5, 3.0};             // f32 literals
    total++; passed += Test("float[3][0]", fc[0], 1.5f);
    total++; passed += Test("float[3][2]", fc[2], 3.0f);

    // ===== length-inferred array-view T[] (thin T* over a backing array) =====
    int[] iv = {11, 22, 33};
    total++; passed += Test("int[] iv[0]", iv[0], 11);
    total++; passed += Test("int[] iv[2]", iv[2], 33);

    i64[] lv = {9000000000, 1};
    total++; passed += Test("i64[] lv[0]", lv[0], (i64)9000000000);

    string[] sv = {"x", "y"};
    total++; passed += Test("string[] sv[0]", sv[0], "x");
    total++; passed += Test("string[] sv[1]", sv[1], "y");

    float[] fv = {1.5, 2.5};                   // f32 literals; thin float* over backing array
    total++; passed += Test("float[] fv[0]", fv[0], 1.5f);
    total++; passed += Test("float[] fv[1]", fv[1], 2.5f);

    // ===== identifier / expression elements =====
    // Regression: a bare-identifier element (e.g. `{ e0 }`) was parsed with its
    // VariableName set and the synthesized add()/set() then treated it as a NAMED
    // argument ("named argument 'e0' does not match any parameter"). Literal elements
    // worked; identifier elements did not. All container forms must accept them.
    int e0 = 10;
    int e1 = 20;
    list<int> lid = {e0, e1, e0 + e1};
    total++; passed += Test("list<int> ident elems count", lid.count(), 3);
    total++; passed += Test("list<int> ident elems[2]", lid.get(2), 30);

    array<int> aid = {e0, e1};
    total++; passed += Test("array<int> ident elems[1]", aid.get(1), 20);

    int dk = 5;
    dictionary<int, int> did = {dk: e0, 6: e1};
    total++; passed += Test("dict<int,int> ident key/val", did.get(5), 10);

    string se = "elem";                        // owning local moved positionally into list
    list<string> lse = {se};
    total++; passed += Test("list<string> ident elem", lse.get(0), "elem");

    // ===== array<string> ownership (regression: double-free / heap corruption) =====
    // array<T>.set() copy-assigned an owning element while the by-value parameter's
    // scope-exit destructor freed the same buffer. The array brace-initializer drives
    // set() per element, so populating + destructing array<string> corrupted the heap.
    // Build, overwrite, and let it destruct inside a scope; then allocate again so any
    // heap corruption from the buggy path would surface here.
    {
        array<string> sarr = {"aa", "bb", "cc"};
        total++; passed += Test("array<string>[0]", sarr.get(0), "aa");
        total++; passed += Test("array<string>[2]", sarr.get(2), "cc");
        sarr.set(1, "OVER");
        total++; passed += Test("array<string> overwrite", sarr.get(1), "OVER");
    }
    list<string> afterArr = {"x", "y", "z"};   // alloc after array<string> destruct
    total++; passed += Test("post array<string> alloc ok", afterArr.count(), 3);

    if (passed == total)
    {
        printf("ALL %d initializer-list tests passed.\n", total);
        return 0;
    }
    printf("%d of %d initializer-list tests FAILED.\n", total - passed, total);
    return 1;
}
