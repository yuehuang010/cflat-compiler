import "list.cb";
import "thread.cb";
import "filesystem.cb";
import "malloc_allocator.cb";
import "test_helper.cb";
import program "library/hello_imported.cb" as Hello;
import program "library/hello_c_program.c" as HelloC;

// ---------------------------------------------------------------------------
// Program definitions
// ---------------------------------------------------------------------------

// Minimal program: no config fields, always returns 0
program Minimal {
    int main(move list<string> args) {
        return 0;
    }
};

// Counter: int field + args.count() (baseline test)
program Counter {
    int startFrom = 0;

    int main(move list<string> args) {
        int* heap = new int;
        *heap = startFrom + args.count();
        int result = *heap;
        // heap is freed by BucketAllocator on run() exit
        return result;
    }
};

// FixedExit: returns whatever code is set in the config field
program FixedExit {
    int code = 0;

    int main(move list<string> args) {
        return code;
    }
};

// MultiField: three independent int fields summed in main
program MultiField {
    int a = 0;
    int b = 0;
    int c = 0;

    int main(move list<string> args) {
        return a + b + c;
    }
};

// UserDtor: a program with an explicit ~UserDtor(). The compiler emits exactly ONE
// destructor - the user body runs first, then the builtin field teardown (allocator,
// stop_source, inbox) is appended at the end. The user body bumps a global counter so
// the test can confirm the user destructor executed.
int g_userDtorRuns = 0;

program UserDtor {
    int code = 0;

    int main(move list<string> args) {
        return code;
    }

    ~UserDtor() {
        g_userDtorRuns = g_userDtorRuns + 1;
    }
};

// Resource: simple heap-allocated struct used by ListOwnership
struct Resource {
    int id    = 0;
    int value = 0;
};

// ListOwnership: adds `count` heap-allocated Resource* into a list<unique Resource*>;
// the list destructor frees all elements, leaving zero leaks.
program ListOwnership {
    int count = 0;

    int main(move list<string> args) {
        list<unique Resource*> items;
        int i = 0;
        while (i < count) {
            Resource* r = new Resource;
            r->id    = i;
            r->value = i * 10;
            items.add(r);   // `unique` element type: the parameter is already a sink
            i++;
        }
        return 0;
    }
};

// HeapStress: allocates `count` ints on the heap, returns their sum;
// BlockAllocator is responsible for cleanup
program HeapStress {
    int count = 0;

    int main(move list<string> args) {
        int sum = 0;
        int i = 0;
        while (i < count) {
            int* p = new int;
            *p = i + 1;
            sum = sum + *p;
            i++;
        }
        return sum;
    }
};

// ArgsSum: returns startFrom + args.count(), testing both sources
program ArgsSum {
    int startFrom = 0;

    int main(move list<string> args) {
        return startFrom + args.count();
    }
};

// CrashNull: dereferences a null pointer - triggers an access violation.
// SEH in the trampoline catches it and stores exitCode = -1.
program CrashNull {
    int main(move list<string> args) {
        int* p = nullptr;
        return *p;
    }
};

// SupervisedWorker: computes sum 1..workload, returns it as exit code
program SupervisedWorker {
    int workload = 0;

    int main(move list<string> args) {
        int sum = 0;
        int i = 1;
        while (i <= workload) {
            sum = sum + i;
            i++;
        }
        return sum;
    }
};

// Supervisor: spawns 3 SupervisedWorkers concurrently, waits for all,
// returns sum of their exit codes
program Supervisor {
    int main(move list<string> args) {
        SupervisedWorker w0;
        SupervisedWorker w1;
        SupervisedWorker w2;
        w0.workload = 3;   // sum(1..3)  = 6
        w1.workload = 5;   // sum(1..5)  = 15
        w2.workload = 10;  // sum(1..10) = 55

        list<string> args0;
        list<string> args1;
        list<string> args2;
        w0.run(args0);
        w1.run(args1);
        w2.run(args2);

        w0.WaitForExit();
        w1.WaitForExit();
        w2.WaitForExit();

        return w0.exitCode + w1.exitCode + w2.exitCode;
    }
};

// ---------------------------------------------------------------------------
// Test functions
// ---------------------------------------------------------------------------

bool testProgramBasicArgsAndField() {
    bool result = true;
    Counter c;
    c.startFrom = 10;
    list<string> args;
    string sa = "" + "a";
    string sb = "" + "b";
    args.add(sa);
    args.add(sb);
    c.run(args);
    c.WaitForExit();
    result &= Test("basic counter", c.exitCode, 12);
    result &= Test("basic counter usedBytes", c._allocator.usedBytes(), 0);
    return result;
}

bool testProgramUserDestructor() {
    bool result = true;
    g_userDtorRuns = 0;
    {
        UserDtor u;
        u.code = 7;
        list<string> args;
        u.run(args);
        u.WaitForExit();
        result &= Test("user dtor exit code", u.exitCode, 7);
        // Destructor has not run yet - u is still in scope.
        result &= Test("user dtor not yet run", g_userDtorRuns, 0);
    }
    // u left scope: the single ~UserDtor() ran (user body bumped the global, then the
    // builtin teardown freed _allocator / _stop_source / inbox).
    result &= Test("user dtor ran once", g_userDtorRuns, 1);
    return result;
}

