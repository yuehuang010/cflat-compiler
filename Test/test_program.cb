// ---------------------------------------------------------------------------
// Allocator inspection tests
// ---------------------------------------------------------------------------

bool testAllocatorNonNullAfterRun() {
    bool result = true;
    Minimal m;
    list<string> args;
    m.run(args);
    m.WaitForExit();
    result &= Test("_allocator non-null after run", m._allocator != nullptr, true);
    return result;
}

bool testAllocatorNullBeforeRun() {
    bool result = true;
    Minimal m;
    result &= Test("_allocator null before run", m._allocator == nullptr, true);
    return result;
}

bool testAllocatorUsedBlocksCleanExit() {
    bool result = true;
    Minimal m;
    list<string> args;
    m.run(args);
    m.WaitForExit();
    // Minimal.main() makes no allocations - 0 blocks in use
    result &= Test("usedBytes clean exit", m._allocator.usedBytes(), 0);
    return result;
}

bool testAllocatorUsedBlocksLeaked() {
    bool result = true;
    HeapStress h;
    h.count = 5;
    list<string> args;
    h.run(args);
    h.WaitForExit();
    result &= Test("heap stress sum 5", h.exitCode, 15);
    result &= Test("usedBytes no leak after exit", h._allocator.usedBytes(), 0);
    return result;
}

// Regression: assigning `new <Allocator>` to the synthetic `_allocator` field
// must compile. `_allocator` is an IAllocator fat-ptr declared with both Pointer
// and IsInterface set; the assignment path used to misfire a "cannot assign a
// value of type 'MallocAllocator' to pointer variable" error after performing a
// correct interface upcast, because the pointer/struct-value guard did not
// exempt interface targets.
bool testAllocatorCustomAssignedBeforeRun() {
    bool result = true;
    HeapStress h;
    h.count = 5;
    h._allocator = new MallocAllocator;   // <- the assignment that used to fail to compile
    list<string> args;
    h.run(args);
    h.WaitForExit();
    result &= Test("custom allocator exit code", h.exitCode, 15);
    // MallocAllocator tracks cumulative alloc bytes; 5x `new int` => at least 20 bytes,
    // proving the user-assigned allocator (not the default) actually serviced main().
    result &= Test("custom allocator was used", h._allocator.totalBytes() >= 20, true);
    return result;
}

// ---------------------------------------------------------------------------
// onStdout tests
// ---------------------------------------------------------------------------

int g_stdout_count = 0;

void capture_stdout(char* s) {
    g_stdout_count++;
}

// Program that calls printf three times
program StdoutCapture {
    int main(move list<string> args) {
        printf("line 1\n");
        printf("line 2\n");
        printf("line 3\n");
        return 0;
    }
};

bool testOnStdoutNamedCallback() {
    bool result = true;
    g_stdout_count = 0;
    StdoutCapture p;
    p.onStdout = capture_stdout;
    list<string> args;
    p.run(args);
    p.WaitForExit();
    result &= Test("onStdout named callback count", g_stdout_count, 3);
    result &= Test("onStdout exitCode", p.exitCode, 0);
    return result;
}

void capture_stdout2(char* s) {
    g_stdout_count = g_stdout_count + 10;
}

bool testOnStdoutSecondCallback() {
    bool result = true;
    g_stdout_count = 0;
    StdoutCapture p;
    p.onStdout = capture_stdout2;
    list<string> args;
    p.run(args);
    p.WaitForExit();
    result &= Test("onStdout second callback count", g_stdout_count, 30);
    return result;
}

bool testOnStdoutNullByDefault() {
    bool result = true;
    g_stdout_count = 0;
    StdoutCapture p;
    // onStdout is null by default - output goes to console (we just verify callback not called)
    list<string> args;
    p.run(args);
    p.WaitForExit();
    result &= Test("onStdout default null count", g_stdout_count, 0);
    return result;
}

// ---------------------------------------------------------------------------
// onStdin tests
// ---------------------------------------------------------------------------

// Canned line provider: returns malloc'd copies of lines by index, then nullptr (EOF).
// The runtime's __stdin_next_char frees each returned pointer, so we must heap-allocate.
int g_stdin_idx = 0;

char* provide_stdin() {
    int idx = g_stdin_idx;
    g_stdin_idx++;
    const char* src = nullptr;
    if (idx == 0) src = "hello\n";
    else if (idx == 1) src = "world\n";
    else if (idx == 2) src = "foo\n";
    else return nullptr;
    i64 len = strlen(src);
    char* s = (char*)malloc(len + 1);
    strcpy(s, src);
    return s;
}

// Canned integer provider for scanf tests - same malloc convention.
int g_scanf_idx = 0;

char* provide_stdin_scanf() {
    int idx = g_scanf_idx;
    g_scanf_idx++;
    const char* src = nullptr;
    if (idx == 0) src = "10\n";
    else if (idx == 1) src = "20\n";
    else if (idx == 2) src = "30\n";
    else return nullptr;
    i64 len = strlen(src);
    char* s = (char*)malloc(len + 1);
    strcpy(s, src);
    return s;
}

// Program that reads lineCount lines via fgets and accumulates their lengths.
program ReadLinesFgets {
    int lineCount = 3;
    int totalLen  = 0;

    int main(move list<string> args) {
        char* buf = (char*)malloc(256);
        int i = 0;
        while (i < lineCount) {
            void* stdinStream = __std_iob(0);
            if (fgets(buf, 256, stdinStream) == nullptr) break;
            totalLen += strlen(buf);
            i++;
        }
        free(buf);
        return totalLen;
    }
};

// Program that reads lineCount integers via scanf and sums them.
program ReadLinesScanf {
    int lineCount = 3;
    int total     = 0;

    int main(move list<string> args) {
        int i = 0;
        while (i < lineCount) {
            int n = 0;
            if (scanf("%d", &n) != 1) break;
            total += n;
            i++;
        }
        return total;
    }
};

bool testOnStdinFgets() {
    bool result = true;
    g_stdin_idx = 0;
    ReadLinesFgets p;
    p.lineCount = 3;
    p.onStdin = provide_stdin;
    list<string> args;
    p.run(args);
    p.WaitForExit();
    // "hello\n"=6, "world\n"=6, "foo\n"=4 -> 16
    result &= Test("onStdin fgets total", p.exitCode, 16);
    result &= Test("onStdin fgets totalLen", p.totalLen, 16);
    return result;
}

bool testOnStdinScanf() {
    bool result = true;
    g_scanf_idx = 0;
    ReadLinesScanf p;
    p.lineCount = 3;
    p.onStdin = provide_stdin_scanf;
    list<string> args;
    p.run(args);
    p.WaitForExit();
    // 10 + 20 + 30 = 60
    result &= Test("onStdin scanf total", p.exitCode, 60);
    result &= Test("onStdin scanf field", p.total, 60);
    return result;
}

bool testOnStdinNullByDefault() {
    bool result = true;
    // When onStdin is not set, the program should still run (it won't block since
    // lineCount=0 means no reads). We just verify exitCode is correct.
    ReadLinesFgets p;
    p.lineCount = 0;
    list<string> args;
    p.run(args);
    p.WaitForExit();
    result &= Test("onStdin default null exitCode", p.exitCode, 0);
    return result;
}

// ---------------------------------------------------------------------------
// inbox messaging tests (arena_channel mailbox, wired with `producer >> consumer`)
// ---------------------------------------------------------------------------

class PingMsg : IMessage { int value = 0; };
class SumMsg  : IMessage { int a = 0; int b = 0; };

// The program mailbox is the arena_channel `inbox` / `outbox` pair, wired by `p >> w`:
// the consumer (w) owns the channel (its `inbox`), the producer (p) gets a handle in
// its `outbox`. Each side knows how many messages to send/receive (no sentinel needed);
// payloads are bump-allocated inside the producer's page_arena and transferred zero-copy.

// Consumer: receives `count` messages, sums the value of any PingMsg (ignores others).
program EchoWorker {
    int count    = 0;
    int received = 0;

    int main(move list<string> args) {
        int i = 0;
        while (i < count) {
            page_arena<IMessage>* pa = inbox.recv();
            IMessage root = pa._root;
            if (root is PingMsg) {
                PingMsg* ping = root as PingMsg;
                received = received + ping.value;
            }
            inbox.release_arena(pa);
            i++;
        }
        return received;
    }
};

// Consumer: receives `count` messages, sums a+b of any SumMsg.
program SumWorker {
    int count = 0;
    int total = 0;

    int main(move list<string> args) {
        int i = 0;
        while (i < count) {
            page_arena<IMessage>* pa = inbox.recv();
            IMessage root = pa._root;
            if (root is SumMsg) {
                SumMsg* s = root as SumMsg;
                total = total + s.a + s.b;
            }
            inbox.release_arena(pa);
            i++;
        }
        return total;
    }
};

// Producer: sends `count` PingMsgs with values base..base+count-1.
program PingProducer {
    int count = 0;
    int base  = 0;

    int main(move list<string> args) {
        int i = 0;
        while (i < count) {
            page_arena<IMessage>* pa = outbox.acquire_arena();
            PingMsg* msg = (PingMsg*)pa.alloc((i64)sizeof(PingMsg));
            msg.value = base + i;
            pa._root = msg;
            outbox.send(pa);
            i++;
        }
        return 0;
    }
};

// Producer: sends two fixed SumMsgs.
program SumPairProducer {
    int main(move list<string> args) {
        page_arena<IMessage>* pa1 = outbox.acquire_arena();
        SumMsg* m1 = (SumMsg*)pa1.alloc((i64)sizeof(SumMsg));
        m1.a = 3;  m1.b = 4;   pa1._root = m1;  outbox.send(pa1);

        page_arena<IMessage>* pa2 = outbox.acquire_arena();
        SumMsg* m2 = (SumMsg*)pa2.alloc((i64)sizeof(SumMsg));
        m2.a = 10; m2.b = 20;  pa2._root = m2;  outbox.send(pa2);
        return 0;
    }
};

// Producer: sends a SumMsg (which EchoWorker ignores) then a PingMsg(42).
program MixedProducer {
    int main(move list<string> args) {
        page_arena<IMessage>* pa1 = outbox.acquire_arena();
        SumMsg* skip = (SumMsg*)pa1.alloc((i64)sizeof(SumMsg));
        skip.a = 99; skip.b = 99; pa1._root = skip; outbox.send(pa1);

        page_arena<IMessage>* pa2 = outbox.acquire_arena();
        PingMsg* ping = (PingMsg*)pa2.alloc((i64)sizeof(PingMsg));
        ping.value = 42; pa2._root = ping; outbox.send(pa2);
        return 0;
    }
};

// Wire producer >> consumer, run the consumer first (it blocks on recv), then the
// producer, and join both. Returns the consumer's exit code.
bool testInboxSingleMessage() {
    bool result = true;
    PingProducer p;
    EchoWorker w;
    p.count = 1;
    p.base  = 7;
    w.count = 1;
    p.useChannel = true;   // opt in to the arena mailbox
    w.useChannel = true;
    p >> w;

    list<string> a1;
    list<string> a2;
    w.run(a2);
    p.run(a1);
    p.WaitForExit();
    w.WaitForExit();
    result &= Test("inbox single ping", w.exitCode, 7);
    return result;
}

bool testInboxMultipleMessages() {
    bool result = true;
    PingProducer p;
    EchoWorker w;
    p.count = 5;
    p.base  = 1;   // values 1..5 -> sum 15
    w.count = 5;
    p.useChannel = true;
    w.useChannel = true;
    p >> w;

    list<string> a1;
    list<string> a2;
    w.run(a2);
    p.run(a1);
    p.WaitForExit();
    w.WaitForExit();
    result &= Test("inbox five pings sum", w.exitCode, 15);
    return result;
}

bool testInboxSumMessages() {
    bool result = true;
    SumPairProducer p;
    SumWorker w;
    w.count = 2;
    p.useChannel = true;
    w.useChannel = true;
    p >> w;

    list<string> a1;
    list<string> a2;
    w.run(a2);
    p.run(a1);
    p.WaitForExit();
    w.WaitForExit();
    result &= Test("inbox sum messages", w.exitCode, 37);
    return result;
}

bool testInboxPolymorphicMessages() {
    bool result = true;
    MixedProducer p;
    EchoWorker w;
    w.count = 2;   // receives SumMsg (ignored) + PingMsg(42)
    p.useChannel = true;
    w.useChannel = true;
    p >> w;

    list<string> a1;
    list<string> a2;
    w.run(a2);
    p.run(a1);
    p.WaitForExit();
    w.WaitForExit();
    result &= Test("inbox polymorphic skip", w.exitCode, 42);
    return result;
}

// ---------------------------------------------------------------------------
// Arena-channel pipe tests (`producer >> consumer` rich messaging)
// ---------------------------------------------------------------------------

// The consumer owns the arena_channel (its synthetic inbox); `p >> c` lazily
// allocates it and binds the producer's outbox handle to it. The producer
// acquires a page_arena per message, bump-allocates the payload inside it, and
// transfers ownership zero-copy; the consumer reads pa._root and recycles the
// arena. No per-thread-allocator crosses the seam - the page-pool owns the memory.
program ArenaPipeProducer {
    int count = 0;

    int main(move list<string> args) {
        int i = 0;
        while (i < count) {
            page_arena<IMessage>* pa = outbox.acquire_arena();
            PingMsg* msg = (PingMsg*)pa.alloc((i64)sizeof(PingMsg));
            msg.value = i + 1;
            pa._root = msg;            // PingMsg* -> IMessage upcast (typed root)
            outbox.send(pa);
            i++;
        }
        return 0;
    }
};

program ArenaPipeConsumer {
    int count = 0;
    int total = 0;

    int main(move list<string> args) {
        int i = 0;
        while (i < count) {
            page_arena<IMessage>* pa = inbox.recv();
            IMessage root = pa._root;
            PingMsg* msg = root as PingMsg;
            total = total + msg.value;
            inbox.release_arena(pa);
            i++;
        }
        return total;
    }
};

bool testProgramArenaPipe() {
    bool result = true;
    ArenaPipeProducer p;
    ArenaPipeConsumer c;
    p.count = 10;
    c.count = 10;
    p.useChannel = true;   // opt in to the arena mailbox
    c.useChannel = true;

    p >> c;   // consumer owns the channel; producer gets a handle to it

    list<string> a1;
    list<string> a2;
    c.run(a2);   // consumer blocks on recv()
    p.run(a1);   // producer sends 10 messages

    p.WaitForExit();
    c.WaitForExit();
    // sum of 1+2+...+10 = 55
    result &= Test("arena pipe sum 1..10", c.exitCode, 55);
    return result;
}

// ---------------------------------------------------------------------------
// Unwired-mailbox tests (lightweight arena_channel shell; quiet until init())
// ---------------------------------------------------------------------------
// A program's inbox/outbox are non-null lightweight arena_channel shells by default
// (allocated in the ctor, self-loopback). Until `>>` (with both useChannel set) calls
// init(), the shell's ring is empty (_ring._cap==0), so send/recv/acquire_arena are
// silent no-ops instead of dereferencing a null `this`. These tests pin that contract:
// an unwired consumer's recv() returns nullptr immediately (no block, no crash) and an
// unwired producer's acquire_arena() returns nullptr (so send() drops harmlessly).

program UnwiredConsumer {
    int got_null = 0;

    int main(move list<string> args) {
        page_arena<IMessage>* pa = inbox.recv();   // unwired shell: nullptr, no block, no crash
        if (pa == nullptr) { got_null = 1; }
        return got_null;
    }
};

program UnwiredProducer {
    int main(move list<string> args) {
        page_arena<IMessage>* pa = outbox.acquire_arena();   // unwired shell: nullptr
        if (pa == nullptr) { return 1; }
        outbox.send(pa);   // would be a silent no-op too, but acquire already guards
        return 0;
    }
};

// Consumer never wired by `>>` and never opted into useChannel: recv() must no-op.
bool testUnwiredConsumerRecvIsQuiet() {
    bool result = true;
    UnwiredConsumer w;
    list<string> args;
    w.run(args);
    w.WaitForExit();
    result &= Test("unwired recv() returns null (no crash)", w.exitCode, 1);
    return result;
}

// Producer never wired by `>>`: acquire_arena() must no-op (returns null).
bool testUnwiredProducerSendIsQuiet() {
    bool result = true;
    UnwiredProducer p;
    list<string> args;
    p.run(args);
    p.WaitForExit();
    result &= Test("unwired acquire_arena() returns null (no crash)", p.exitCode, 1);
    return result;
}

// `p >> w` is issued, but neither program set useChannel, so the useChannel gate skips
// init() - the mailbox stays an inert shell on both ends. This is the exact footgun that
// used to AV (null inbox `this`); now both sides quietly no-op.
bool testPipeWithoutUseChannelIsQuiet() {
    bool result = true;
    UnwiredProducer p;
    UnwiredConsumer w;
    // useChannel deliberately left false on both ends.
    p >> w;
    list<string> a1;
    list<string> a2;
    w.run(a2);
    p.run(a1);
    p.WaitForExit();
    w.WaitForExit();
    result &= Test("pipe without useChannel: consumer recv quiet", w.exitCode, 1);
    result &= Test("pipe without useChannel: producer send quiet", p.exitCode, 1);
    return result;
}

// ---------------------------------------------------------------------------
// stop_token tests
// ---------------------------------------------------------------------------

// ListStringOwnership: adds string literals into a list<string>.
// String literals point to static memory, so only the list's backing array
// goes through operator new. The list destructor frees it, leaving no leaks.
// Count is capped at 4: sizeof(string)==16, so 4 strings fill exactly one
// 64-byte block; growing to capacity 8 (128 bytes) would exceed the block
// allocator's block size and return null.
program ListStringOwnership {
    int count = 0;

    int main(move list<string> args) {
        list<string> items;
        int i = 0;
        while (i < count) {
            string s = "hello";
            items.add(s);
            i++;
        }
        return 0;
    }
};

bool testListStringNoLeaks() {
    bool result = true;
    ListStringOwnership p;
    p.count = 4;  // 4 strings x 16 bytes = 64 bytes = one block; count>4 would overflow
    list<string> args;
    p.run(args);
    p.WaitForExit();
    result &= Test("list<string> exit code", p.exitCode, 0);
    result &= Test("list<string> no leaks", p._allocator.usedBytes(), 0);
    return result;
}

// ListStringCopyOwnership: builds a list<string> whose elements are heap-OWNING
// copies (inline `.copy()`), unlike ListStringOwnership which only adds literals
// (no owned buffers). This is the exact shape that used to leak: an owning-string
// temporary passed straight into list.add(move string) hit a defensive re-copy
// that cloned the buffer and orphaned the freshly returned one. The list
// destructor frees each element, so a balanced allocator returns to zero.
program ListStringCopyOwnership {
    int count = 0;

    int main(move list<string> args) {
        list<string> items;
        int i = 0;
        while (i < count) {
            string seed = "element";
            items.add(seed.copy());   // owning-string temporary -> move string param
            i++;
        }
        return 0;
    }
};

bool testListStringCopyNoLeaks() {
    bool result = true;
    ListStringCopyOwnership p;
    p.count = 8;
    p._allocator = new MallocAllocator;   // no block-size cap; tracks live bytes
    list<string> args;
    p.run(args);
    p.WaitForExit();
    result &= Test("list<string> copy exit code", p.exitCode, 0);
    result &= Test("list<string> copy no leaks", p._allocator.usedBytes(), 0);
    return result;
}

// ListStringConcatOwnership: same leak shape as ListStringCopyOwnership but the
// owning-string temporary comes from `operator+` (concatenation) instead of
// copy(). Inline operator+ args leaked identically pre-fix: the owning temporary
// was re-copied by the defensive move-string path and the original orphaned.
program ListStringConcatOwnership {
    int count = 0;

    int main(move list<string> args) {
        list<string> items;
        int i = 0;
        while (i < count) {
            string a = "el";
            string b = "ement";
            items.add(a + b);   // operator+ owning temporary -> move string param
            i++;
        }
        return 0;
    }
};

bool testListStringConcatNoLeaks() {
    bool result = true;
    ListStringConcatOwnership p;
    p.count = 8;
    p._allocator = new MallocAllocator;   // no block-size cap; tracks live bytes
    list<string> args;
    p.run(args);
    p.WaitForExit();
    result &= Test("list<string> concat exit code", p.exitCode, 0);
    result &= Test("list<string> concat no leaks", p._allocator.usedBytes(), 0);
    return result;
}

bool testListOwnershipNoLeaks() {
    bool result = true;
    ListOwnership p;
    p.count = 5;
    list<string> args;
    p.run(args);
    p.WaitForExit();
    result &= Test("list ownership exit code", p.exitCode, 0);
    result &= Test("list ownership no leaks", p._allocator.usedBytes(), 0);
    return result;
}

bool testProgramCrashRecovery() {
    // Crash recovery is Win64-only: it relies on SEH (catchswitch/catchpad). Win32's LLVM x86
    // backend drops the catch body, and POSIX has no SEH (a fault is a process-killing signal).
    if const (__WINDOWS__) {
        if const (__PLATFORM__ == 64) {
            bool result = true;
            CrashNull p;
            list<string> args;
            p.run(args);
            p.WaitForExit();
            // SEH catches the access violation; trampoline stores -1 and exits the thread cleanly.
            result &= Test("crash recovery exit code", p.exitCode, -1);
            return result;
        }
    }
    return true; // No SEH crash recovery (Win32 / POSIX) - skip.
}

bool testWaitForExitWithToken() {
    bool result = true;

    // Thread completes naturally -> WaitForExit(token) returns true
    stop_source src;
    src.init();
    stop_token token = src.get_token();

    Minimal prog;
    list<string> args;
    prog.run(args);
    bool done = prog.WaitForExit(token);
    result &= Test("WaitForExit(token) completes", done, true);
    result &= Test("WaitForExit(token) exitCode", prog.exitCode, 0);
    src.dispose();

    return result;
}

bool testWaitForExitCancelled() {
    bool result = true;

    // Pre-cancelled token -> WaitForExit returns false immediately
    stop_source src;
    src.init();
    src.request_stop();
    stop_token token = src.get_token();

    Minimal prog;
    list<string> args;
    prog.run(args);
    bool done = prog.WaitForExit(token);
    result &= Test("WaitForExit(cancelled token) returns false", done, false);
    src.dispose();

    // WaitForExit(token) returning false does NOT join - caller must join before
    // the program goes out of scope, otherwise the thread is still accessing the struct.
    prog.WaitForExit();

    return result;
}

// ---------------------------------------------------------------------------
// WaitForExit(int) and Kill() tests
// ---------------------------------------------------------------------------

program SpinForever {
    int main(move list<string> args) {
        while (true) { }
        return 0;
    }
};

// Loops until its stop token is signalled; returns 42 on clean exit.
program CoopLoop {
    stop_token token = default;

    int main(move list<string> args) {
        while (!token.stop_requested()) { }
        return 42;
    }
};

bool testRequestStop() {
    bool result = true;
    CoopLoop prog;
    list<string> args;
    stop_source src;
    src.init();
    prog.token = src.get_token();
    prog.run(args);
    src.request_stop();
    prog.WaitForExit();
    result &= Test("RequestStop cooperative exit", prog.exitCode, 42);
    src.dispose();
    return result;
}

bool testWaitForExitTimeoutFast() {
    bool result = true;
    // Fast program: WaitForExit with a generous timeout should return true.
    Minimal prog;
    list<string> args;
    prog.run(args);
    bool done = prog.WaitForExit(5000);
    result &= Test("WaitForExit(ms) fast program", done, true);
    result &= Test("WaitForExit(ms) exitCode", prog.exitCode, 0);
    return result;
}

bool testKillInfiniteLoop() {
    bool result = true;
    SpinForever prog;
    list<string> args;
    prog.run(args);
    // Short timeout - infinite loop won't finish.
    bool done = prog.WaitForExit(100);
    result &= Test("WaitForExit(ms) infinite loop timeout", done, false);
    // Kill the stuck thread so the test process can exit cleanly.
    prog.Kill();
    return result;
}

// ---------------------------------------------------------------------------
// Supervisor tests
// ---------------------------------------------------------------------------

bool testSupervisorSpawnsChildren() {
    bool result = true;
    Supervisor sup;
    list<string> args;
    sup.run(args);
    sup.WaitForExit();
    // 6 + 15 + 55 = 76
    result &= Test("supervisor spawns children", sup.exitCode, 76);
    return result;
}

// ---------------------------------------------------------------------------
// Handle tracker tests
// ---------------------------------------------------------------------------

program TrackHandlesCrash {
    string _path = "";

    int main(move list<string> args) {
        File f;
        f.openWrite(_path);
        // Intentionally crash without closing - tracker must close the handle
        int* p = nullptr;
        return *p;
    }
};

bool testTrackHandles() {
    // Depends on crash recovery (the handle is leaked by an intentional fault and the trampoline
    // must close it on the SEH path) - Win64-only, like testProgramCrashRecovery above.
    if const (__WINDOWS__) {
        if const (__PLATFORM__ == 64) {
            bool result = true;
            string path = "test_track_tmp.txt";
            File.remove(path);

            TrackHandlesCrash p;
            p._path = path;
            p.trackHandles = true;
            list<string> args;
            p.run(args);
            p.WaitForExit();
            result &= Test("trackHandles crash exitCode", p.exitCode, -1);

            // If the tracker closed the handle, we can delete the file (no sharing violation).
            result &= Test("trackHandles handle closed on crash", File.remove(path), true);
            return result;
        }
    }
    return true; // No SEH crash recovery (Win32 / POSIX) - skip.
}

// ---------------------------------------------------------------------------
// Cross-thread allocator inheritance
// ---------------------------------------------------------------------------

// A child Thread spawned inside main must inherit __active_allocator from the
// program thread. Without inheritance, the child's `new` falls through to
// CRT malloc and the program's allocator never sees the allocations.
//
// Signal: the program is configured with a MallocAllocator (which tracks
// cumulative alloc bytes in totalBytes()). main does no allocations itself;
// the child thread does `count` allocations and frees them. After join, the
// MallocAllocator's totalBytes should equal count * 4. Pre-fix the child
// would use CRT malloc directly and totalBytes would be 0.
program ChildThreadInheritsAllocator {
    int count = 0;

    int main(move list<string> args) {
        int n = count;
        Thread t;
        t.start((void* ctx) => {
            int* np = (int*)ctx;
            int local_n = *np;
            int i = 0;
            while (i < local_n) {
                int* p = new int;
                *p = i;
                delete p;
                i++;
            }
            return 0;
        }, (void*)&n);
        t.join();
        return 0;
    }
};

bool testChildThreadInheritsAllocator() {
    bool result = true;
    ChildThreadInheritsAllocator p;
    p._allocator = new MallocAllocator;
    p.count = 5;
    list<string> args;
    p.run(args);
    p.WaitForExit();
    // Child allocated 5 ints. MallocAllocator's totalBytes is cumulative and
    // survives the program teardown's allocator-cleanup step.
    // Inheritance working -> totalBytes >= 20 (5 * sizeof(int)).
    // Inheritance broken  -> child used CRT malloc; MA never saw allocs;
    //                        totalBytes is 0.
    result &= Test("child inherited allocator totalBytes", p._allocator.totalBytes() >= 20, true);
    return result;
}

// ---------------------------------------------------------------------------
// Main signature variants
// ---------------------------------------------------------------------------

// NoArgs: main() with no parameters
program NoArgsMain {
    int result = 0;

    int main() {
        return 42;
    }
};

bool testNoArgsMain() {
    bool ok = true;
    NoArgsMain p;
    list<string> args;
    p.run(args);
    p.WaitForExit();
    ok &= Test("NoArgs main() returns 42", p.exitCode, 42);
    return ok;
}

// ArgcArgv: main(int argc, char** argv) style
program ArgcArgvMain {
    int result = 0;

    int main(int argc, char** argv) {
        return argc;
    }
};

bool testArgcArgvMain() {
    bool ok = true;

    // Empty args -> argc = 0
    ArgcArgvMain p0;
    list<string> empty;
    p0.run(empty);
    p0.WaitForExit();
    ok &= Test("ArgcArgv argc empty", p0.exitCode, 0);

    // Two args -> argc = 2
    ArgcArgvMain p2;
    list<string> twoArgs;
    string s1 = "" + "hello";
    string s2 = "" + "world";
    twoArgs.add(s1);
    twoArgs.add(s2);
    p2.run(twoArgs);
    p2.WaitForExit();
    ok &= Test("ArgcArgv argc two args", p2.exitCode, 2);

    return ok;
}

bool testImportedProgram() {
    bool ok = true;

    // Empty args -> argc = 0
    Hello h0;
    list<string> empty;
    h0.run(empty);
    h0.WaitForExit();
    ok &= Test("imported program empty args", h0.exitCode, 0);

    // Two args -> argc = 2
    Hello h2;
    list<string> twoArgs;
    string s1 = "" + "hello";
    string s2 = "" + "world";
    twoArgs.add(s1);
    twoArgs.add(s2);
    h2.run(twoArgs);
    h2.WaitForExit();
    ok &= Test("imported program two args", h2.exitCode, 2);

    return ok;
}

// Same as testImportedProgram, but the imported program is a real C file
// (compiled by clang-cl, linked by lld-link). Verifies that 'import program "x.c"'
// wires the C main into the program runtime just like a .cb main.
bool testImportedCProgram() {
    bool ok = true;

    // Empty args -> argc = 0
    HelloC h0;
    list<string> empty;
    h0.run(empty);
    h0.WaitForExit();
    ok &= Test("imported C program empty args", h0.exitCode, 0);

    // Two args -> argc = 2
    HelloC h2;
    list<string> twoArgs;
    string s1 = "" + "hello";
    string s2 = "" + "world";
    twoArgs.add(s1);
    twoArgs.add(s2);
    h2.run(twoArgs);
    h2.WaitForExit();
    ok &= Test("imported C program two args", h2.exitCode, 2);

    return ok;
}

// ---------------------------------------------------------------------------
// Interface fields on a program implementor
// ---------------------------------------------------------------------------

// A `program X : IFace` builds its own vtable (GetOrCreateProgramVTable). An
// interface FIELD resolves to the byte offset of that program's config field,
// so config can be read and written through the interface value.
interface ITagged {
    int bumped();
    int count;
};

program TaggedProgram : ITagged {
    int pad   = 0;
    int count = 5;

    int bumped() { return count + 1; }

    int main() {
        return count;
    }
};

bool testProgramInterfaceField() {
    bool ok = true;
    TaggedProgram p;
    ITagged t = p;                       // stack program bound to the interface (borrow)

    ok &= Test("program iface field read",   t.count,    5);
    t.count = 9;                         // write through the interface's offset slot
    ok &= Test("program iface field write",  p.count,    9);
    ok &= Test("program iface method",       t.bumped(), 10);

    list<string> args;
    p.run(args);
    p.WaitForExit();
    ok &= Test("program iface field drives main", p.exitCode, 9);
    return ok;
}

// ---------------------------------------------------------------------------
// Entry point
// ---------------------------------------------------------------------------

extern int main() {
    int passed = 0;
    int total  = 0;

    total++; passed += testProgramBasicArgsAndField()    ? 1 : 0;
    total++; passed += testProgramMinimalNoFields()      ? 1 : 0;
    total++; passed += testProgramUserDestructor()       ? 1 : 0;
    total++; passed += testProgramEmptyArgs()            ? 1 : 0;
    total++; passed += testProgramExitCodeZero()         ? 1 : 0;
    total++; passed += testProgramExitCodeNonZero()      ? 1 : 0;
    total++; passed += testProgramMultipleFields()       ? 1 : 0;
    total++; passed += testProgramFieldDefaultValues()   ? 1 : 0;
    total++; passed += testProgramHeapAllocationsFreed() ? 1 : 0;
    total++; passed += testProgramMultipleRuns()         ? 1 : 0;
    total++; passed += testProgramArgsManyItems()        ? 1 : 0;
    total++; passed += testProgramArgsAndFieldCombined() ? 1 : 0;
    total++; passed += testTwoDifferentPrograms()        ? 1 : 0;
    total++; passed += testProgramHeapStressLarge()      ? 1 : 0;
    total++; passed += testListStringNoLeaks()           ? 1 : 0;
    total++; passed += testListStringCopyNoLeaks()       ? 1 : 0;
    total++; passed += testListStringConcatNoLeaks()     ? 1 : 0;
    total++; passed += testListOwnershipNoLeaks()        ? 1 : 0;
    total++; passed += testWaitForExitWithToken()        ? 1 : 0;
    total++; passed += testWaitForExitCancelled()        ? 1 : 0;
    total++; passed += testAllocatorNonNullAfterRun()    ? 1 : 0;
    total++; passed += testAllocatorNullBeforeRun()      ? 1 : 0;
    total++; passed += testAllocatorUsedBlocksCleanExit() ? 1 : 0;
    total++; passed += testAllocatorUsedBlocksLeaked()   ? 1 : 0;
    total++; passed += testAllocatorCustomAssignedBeforeRun() ? 1 : 0;
    total++; passed += testOnStdoutNamedCallback()       ? 1 : 0;
    total++; passed += testOnStdoutSecondCallback()      ? 1 : 0;
    total++; passed += testOnStdoutNullByDefault()       ? 1 : 0;
    total++; passed += testOnStdinFgets()                ? 1 : 0;
    total++; passed += testOnStdinScanf()                ? 1 : 0;
    total++; passed += testOnStdinNullByDefault()        ? 1 : 0;
    total++; passed += testInboxSingleMessage()          ? 1 : 0;
    total++; passed += testInboxMultipleMessages()       ? 1 : 0;
    total++; passed += testInboxSumMessages()            ? 1 : 0;
    total++; passed += testInboxPolymorphicMessages()    ? 1 : 0;
    total++; passed += testProgramArenaPipe()            ? 1 : 0;
    total++; passed += testUnwiredConsumerRecvIsQuiet()  ? 1 : 0;
    total++; passed += testUnwiredProducerSendIsQuiet()  ? 1 : 0;
    total++; passed += testPipeWithoutUseChannelIsQuiet() ? 1 : 0;
    total++; passed += testProgramCrashRecovery()        ? 1 : 0;
    total++; passed += testRequestStop()                 ? 1 : 0;
    total++; passed += testWaitForExitTimeoutFast()      ? 1 : 0;
    total++; passed += testKillInfiniteLoop()            ? 1 : 0;
    total++; passed += testSupervisorSpawnsChildren()    ? 1 : 0;
    total++; passed += testTrackHandles()                ? 1 : 0;
    total++; passed += testNoArgsMain()                  ? 1 : 0;
    total++; passed += testArgcArgvMain()                ? 1 : 0;
    total++; passed += testImportedProgram()             ? 1 : 0;
    total++; passed += testImportedCProgram()            ? 1 : 0;
    total++; passed += testChildThreadInheritsAllocator() ? 1 : 0;
    total++; passed += testProgramInterfaceField()        ? 1 : 0;

    printf("Program tests: %d/%d passed.\n", passed, total);
    return passed == total ? 0 : 1;
}
