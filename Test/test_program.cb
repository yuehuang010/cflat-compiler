import "list.cb";
import "thread.cb";
import "test_helper.cb";

program Counter {
    int startFrom = 0;

    int main(list<string> args) {
        return 42;
    }
};

extern int main() {
    Counter c;
    c.startFrom = 10;
    list<string> args;
    string sa = "a";
    string sb = "b";
    args.add(sa);
    args.add(sb);
    int code = c.run(args);
    if (code != 12) { printf("FAILED: expected 12, got %d\n", code); return 1; }
    printf("program test passed\n");
    return 0;
}
