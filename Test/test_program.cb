import "list.cb";
import "thread.cb";
import "filesystem.cb";
import "test_helper.cb";

// ---------------------------------------------------------------------------
// Program definitions
// ---------------------------------------------------------------------------

// Minimal program: no config fields, always returns 0
program Minimal {
    int main(move list<string> args) {
        return 0;
    }
};

// Counter: int field + args.count() (baseline test)
program Counter {
    int startFrom = 0;

    int main(move list<string> args) {
        int* heap = new int;
        *heap = startFrom + args.count();
        int result = *heap;
        // heap is freed by BlockAllocator on run() exit
        return result;
    }
};

// FixedExit: returns whatever code is set in the config field
program FixedExit {
    int code = 0;

    int main(move list<string> args) {
        return code;
    }
};

// MultiField: three independent int fields summed in main
program MultiField {
    int a = 0;
    int b = 0;
    int c = 0;

    int main(move list<string> args) {
        return a + b + c;
    }
};

// Resource: simple heap-allocated struct used by ListOwnership
struct Resource {
    int id    = 0;
    int value = 0;
};

// ListOwnership: adds `count` heap-allocated Resource* into a list<Resource*>
// via move; the list destructor frees all elements, leaving zero leaks.
program ListOwnership {
    int count = 0;

    int main(move list<string> args) {
        list<Resource*> items;
        int i = 0;
        while (i < count) {
            Resource* r = new Resource;
            r->id    = i;
            r->value = i * 10;
            items.add(move r);
            i++;
        }
        return 0;
    }
};

// HeapStress: allocates `count` ints on the heap, returns their sum;
// BlockAllocator is responsible for cleanup
program HeapStress {
    int count = 0;

    int main(move list<string> args) {
        int sum = 0;
        int i = 0;
        while (i < count) {
            int* p = new int;
            *p = i + 1;
            sum = sum + *p;
            i++;
        }
        return sum;
    }
};

// ArgsSum: returns startFrom + args.count(), testing both sources
program ArgsSum {
    int startFrom = 0;

    int main(move list<string> args) {
        return startFrom + args.count();
    }
};

// CrashNull: dereferences a null pointer — triggers an access violation.
// SEH in the trampoline catches it and stores exitCode = -1.
program CrashNull {
    int main(move list<string> args) {
        int* p = nullptr;
        return *p;
    }
};

// SupervisedWorker: computes sum 1..workload, returns it as exit code
program SupervisedWorker {
    int workload = 0;

    int main(move list<string> args) {
        int sum = 0;
        int i = 1;
        while (i <= workload) {
            sum = sum + i;
            i++;
        }
        return sum;
    }
};

// Supervisor: spawns 3 SupervisedWorkers concurrently, waits for all,
// returns sum of their exit codes
program Supervisor {
    int main(move list<string> args) {
        SupervisedWorker w0;
        SupervisedWorker w1;
        SupervisedWorker w2;
        w0.workload = 3;   // sum(1..3)  = 6
        w1.workload = 5;   // sum(1..5)  = 15
        w2.workload = 10;  // sum(1..10) = 55

        list<string> empty;
        w0.run(empty);
        w1.run(empty);
        w2.run(empty);

        w0.WaitForExit();
        w1.WaitForExit();
        w2.WaitForExit();

        return w0.exitCode + w1.exitCode + w2.exitCode;
    }
};

// ---------------------------------------------------------------------------
// Test functions
// ---------------------------------------------------------------------------

bool testProgramBasicArgsAndField() {
    bool result = true;
    Counter c;
    c.startFrom = 10;
    list<string> args;
    string sa = "" + "a";
    string sb = "" + "b";
    args.add(sa);
    args.add(sb);
    c.run(args);
    c.WaitForExit();
    result &= Test("basic counter", c.exitCode, 12);
    return result;
}

bool testProgramMinimalNoFields() {
    bool result = true;
    Minimal m;
    list<string> args;
    m.run(args);
    m.WaitForExit();
    result &= Test("minimal no fields", m.exitCode, 0);
    return result;
}

bool testProgramEmptyArgs() {
    bool result = true;
    Counter c;
    c.startFrom = 5;
    list<string> args;
    c.run(args);
    c.WaitForExit();
    result &= Test("empty args", c.exitCode, 5);
    return result;
}

bool testProgramExitCodeZero() {
    bool result = true;
    FixedExit f;
    f.code = 0;
    list<string> args;
    f.run(args);
    f.WaitForExit();
    result &= Test("exit code 0", f.exitCode, 0);
    return result;
}

bool testProgramExitCodeNonZero() {
    bool result = true;
    FixedExit f;
    f.code = 42;
    list<string> args;
    f.run(args);
    f.WaitForExit();
    result &= Test("exit code 42", f.exitCode, 42);
    return result;
}

bool testProgramMultipleFields() {
    bool result = true;
    MultiField m;
    m.a = 3;
    m.b = 7;
    m.c = 5;
    list<string> args;
    m.run(args);
    m.WaitForExit();
    result &= Test("multiple fields sum", m.exitCode, 15);
    return result;
}

bool testProgramFieldDefaultValues() {
    bool result = true;
    // No fields set — all default to 0, so a+b+c = 0
    MultiField m;
    list<string> args;
    m.run(args);
    m.WaitForExit();
    result &= Test("field defaults zero", m.exitCode, 0);
    return result;
}

bool testProgramHeapAllocationsFreed() {
    bool result = true;
    HeapStress h;
    h.count = 10;
    list<string> args;
    h.run(args);
    h.WaitForExit();
    // sum of 1+2+...+10 = 55
    result &= Test("heap stress sum 10", h.exitCode, 55);
    return result;
}

bool testProgramMultipleRuns() {
    bool result = true;
    FixedExit f;

    f.code = 7;
    list<string> args1;
    f.run(args1);
    f.WaitForExit();
    result &= Test("multiple runs first", f.exitCode, 7);

    f.code = 13;
    list<string> args2;
    f.run(args2);
    f.WaitForExit();
    result &= Test("multiple runs second", f.exitCode, 13);

    return result;
}

bool testProgramArgsManyItems() {
    bool result = true;
