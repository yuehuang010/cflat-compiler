bool testTwoDifferentPrograms() {
    bool result = true;

    Counter c;
    c.startFrom = 20;
    list<string> cargs;
    c.run(cargs);
    c.WaitForExit();
    result &= Test("two programs - counter", c.exitCode, 20);

    FixedExit f;
    f.code = 99;
    list<string> fargs;
    f.run(fargs);
    f.WaitForExit();
    result &= Test("two programs - fixed", f.exitCode, 99);

    return result;
}

bool testProgramHeapStressLarge() {
    bool result = true;
    HeapStress h;
    h.count = 50;
    list<string> args;
    h.run(args);
    h.WaitForExit();
    // sum of 1+2+...+50 = 1275
    result &= Test("heap stress sum 50", h.exitCode, 1275);
    return result;
}

// ---------------------------------------------------------------------------
// Allocator inspection tests
// ---------------------------------------------------------------------------

bool testAllocatorNonNullAfterRun() {
    bool result = true;
    Minimal m;
    list<string> args;
    m.run(args);
    m.WaitForExit();
    result &= Test("_allocator non-null after run", m._allocator != nullptr, true);
    return result;
}

bool testAllocatorNullBeforeRun() {
    bool result = true;
    Minimal m;
    result &= Test("_allocator null before run", m._allocator == nullptr, true);
    return result;
}

bool testAllocatorUsedBlocksCleanExit() {
    bool result = true;
    Minimal m;
    list<string> args;
    m.run(args);
    m.WaitForExit();
    // Minimal.main() makes no allocations — 0 blocks in use
    result &= Test("usedBytes clean exit", m._allocator.usedBytes(), (i64)0);
    return result;
}

bool testAllocatorUsedBlocksLeaked() {
    bool result = true;
    HeapStress h;
    h.count = 5;
    list<string> args;
    h.run(args);
    h.WaitForExit();
    result &= Test("heap stress sum 5", h.exitCode, 15);
    result &= Test("totalBytes allocated", h._allocator.totalBytes(), (i64)20);
    return result;
}

// ---------------------------------------------------------------------------
// onStdout tests
// ---------------------------------------------------------------------------

int g_stdout_count = 0;

void capture_stdout(char* s) {
    g_stdout_count++;
}

// Program that calls printf three times
program StdoutCapture {
    int main(move list<string> args) {
        printf("line 1\n");
        printf("line 2\n");
        printf("line 3\n");
        return 0;
    }
};

bool testOnStdoutNamedCallback() {
    bool result = true;
    g_stdout_count = 0;
    StdoutCapture p;
    p.onStdout = capture_stdout;
    list<string> args;
    p.run(args);
    p.WaitForExit();
    result &= Test("onStdout named callback count", g_stdout_count, 3);
    result &= Test("onStdout exitCode", p.exitCode, 0);
    return result;
}

void capture_stdout2(char* s) {
    g_stdout_count = g_stdout_count + 10;
}

bool testOnStdoutSecondCallback() {
    bool result = true;
    g_stdout_count = 0;
    StdoutCapture p;
    p.onStdout = capture_stdout2;
    list<string> args;
    p.run(args);
    p.WaitForExit();
    result &= Test("onStdout second callback count", g_stdout_count, 30);
    return result;
}

bool testOnStdoutNullByDefault() {
    bool result = true;
    g_stdout_count = 0;
    StdoutCapture p;
    // onStdout is null by default — output goes to console (we just verify callback not called)
    list<string> args;
    p.run(args);
    p.WaitForExit();
    result &= Test("onStdout default null count", g_stdout_count, 0);
    return result;
}

// ---------------------------------------------------------------------------
// onStdin tests
// ---------------------------------------------------------------------------

// Canned line provider: returns malloc'd copies of lines by index, then nullptr (EOF).
// The runtime's __stdin_next_char frees each returned pointer, so we must heap-allocate.
int g_stdin_idx = 0;

char* provide_stdin() {
    int idx = g_stdin_idx;
    g_stdin_idx++;
    const char* src = nullptr;
    if (idx == 0) src = "hello\n";
    else if (idx == 1) src = "world\n";
    else if (idx == 2) src = "foo\n";
    else return nullptr;
    i64 len = (i64)strlen(src);
    char* s = (char*)malloc(len + 1);
    strcpy(s, src);
    return s;
}

// Canned integer provider for scanf tests — same malloc convention.
int g_scanf_idx = 0;

char* provide_stdin_scanf() {
    int idx = g_scanf_idx;
    g_scanf_idx++;
    const char* src = nullptr;
    if (idx == 0) src = "10\n";
    else if (idx == 1) src = "20\n";
    else if (idx == 2) src = "30\n";
    else return nullptr;
    i64 len = (i64)strlen(src);
    char* s = (char*)malloc(len + 1);
    strcpy(s, src);
    return s;
}

// Program that reads lineCount lines via fgets and accumulates their lengths.
program ReadLinesFgets {
    int lineCount = 3;
    int totalLen  = 0;

    int main(move list<string> args) {
        char* buf = (char*)malloc(256);
        int i = 0;
        while (i < lineCount) {
            void* stdinStream = __acrt_iob_func(0);
            if (fgets(buf, 256, stdinStream) == nullptr) break;
            totalLen += strlen(buf);
            i++;
        }
        free(buf);
        return totalLen;
    }
};

// Program that reads lineCount integers via scanf and sums them.
program ReadLinesScanf {
    int lineCount = 3;
    int total     = 0;

    int main(move list<string> args) {
        int i = 0;
        while (i < lineCount) {
            int n = 0;
            if (scanf("%d", &n) != 1) break;
            total += n;
            i++;
        }
        return total;
    }
};

bool testOnStdinFgets() {
    bool result = true;
    g_stdin_idx = 0;
    ReadLinesFgets p;
    p.lineCount = 3;
    p.onStdin = provide_stdin;
    list<string> args;
    p.run(args);
    p.WaitForExit();
    // "hello\n"=6, "world\n"=6, "foo\n"=4 -> 16
    result &= Test("onStdin fgets total", p.exitCode, 16);
    result &= Test("onStdin fgets totalLen", p.totalLen, 16);
    return result;
}

bool testOnStdinScanf() {
    bool result = true;
    g_scanf_idx = 0;
    ReadLinesScanf p;
    p.lineCount = 3;
    p.onStdin = provide_stdin_scanf;
    list<string> args;
    p.run(args);
    p.WaitForExit();
    // 10 + 20 + 30 = 60
    result &= Test("onStdin scanf total", p.exitCode, 60);
    result &= Test("onStdin scanf field", p.total, 60);
    return result;
}

bool testOnStdinNullByDefault() {
    bool result = true;
    // When onStdin is not set, the program should still run (it won't block since
    // lineCount=0 means no reads). We just verify exitCode is correct.
    ReadLinesFgets p;
    p.lineCount = 0;
    list<string> args;
    p.run(args);
    p.WaitForExit();
    result &= Test("onStdin default null exitCode", p.exitCode, 0);
    return result;
}

// ---------------------------------------------------------------------------
// inbox (actor mailbox) tests
// ---------------------------------------------------------------------------

class StopMsg : IMessage { };
class PingMsg : IMessage { int value = 0; };
class SumMsg  : IMessage { int a = 0; int b = 0; };

program EchoWorker {
    int received = 0;

    int main(move list<string> args) {
        while (true) {
            IMessage msg = inbox.receive();
            if (msg is StopMsg) break;
            if (msg is PingMsg) {
                PingMsg* ping = msg as PingMsg;
                received = received + ping.value;
            }
        }
        return received;
    }
};

program SumWorker {
    int total = 0;

    int main(move list<string> args) {
        while (true) {
            IMessage msg = inbox.receive();
            if (msg is StopMsg) break;
            if (msg is SumMsg) {
                SumMsg* s = msg as SumMsg;
                total = total + s.a + s.b;
            }
        }
        return total;
    }
};

bool testInboxSingleMessage() {
    bool result = true;
    EchoWorker w;
    w.inbox.init(8);
    list<string> args;
    w.run(args);
    PingMsg* m = new PingMsg;
    m.value = 7;
    w.inbox.send(move m);
    w.inbox.send(new StopMsg);
    w.WaitForExit();
    result &= Test("inbox single ping", w.exitCode, 7);
    return result;
}

bool testInboxMultipleMessages() {
    bool result = true;
    EchoWorker w;
    w.inbox.init(8);
    list<string> args;
    w.run(args);

    int i = 0;
    while (i < 5) {
        PingMsg* m = new PingMsg;
        m.value = i + 1;
        w.inbox.send(move m);
        i++;
    }
    w.inbox.send(new StopMsg);

    w.WaitForExit();
    result &= Test("inbox five pings sum", w.exitCode, 15);
    return result;
}

bool testInboxSumMessages() {
    bool result = true;
    SumWorker w;
    w.inbox.init(4);
    list<string> args;
    w.run(args);

    SumMsg* m1 = new SumMsg;
    m1.a = 3;
    m1.b = 4;
    w.inbox.send(move m1);

    SumMsg* m2 = new SumMsg;
    m2.a = 10;
    m2.b = 20;
    w.inbox.send(move m2);

    w.inbox.send(new StopMsg);
    w.WaitForExit();
    result &= Test("inbox sum messages", w.exitCode, 37);
    return result;
}

bool testInboxPolymorphicMessages() {
    bool result = true;
    EchoWorker w;
    w.inbox.init(8);
    list<string> args;
    w.run(args);

    // Mix PingMsg and SumMsg — worker only handles PingMsg
    SumMsg* skip = new SumMsg;
    skip.a = 99;
    skip.b = 99;
    w.inbox.send(move skip);

    PingMsg* ping = new PingMsg;
    ping.value = 42;
    w.inbox.send(move ping);

    w.inbox.send(new StopMsg);
    w.WaitForExit();
    result &= Test("inbox polymorphic skip", w.exitCode, 42);
    return result;
}

// ---------------------------------------------------------------------------
// stop_token tests
// ---------------------------------------------------------------------------

// ListStringOwnership: adds string literals into a list<string>.
// String literals point to static memory, so only the list's backing array
// goes through operator new. The list destructor frees it, leaving no leaks.
// Count is capped at 4: sizeof(string)==16, so 4 strings fill exactly one
// 64-byte block; growing to capacity 8 (128 bytes) would exceed the block
// allocator's block size and return null.
program ListStringOwnership {
    int count = 0;

    int main(move list<string> args) {
        list<string> items;
        int i = 0;
        while (i < count) {
            string s = "hello";
            items.add(s);
            i++;
        }
        return 0;
    }
};

bool testListStringNoLeaks() {
    bool result = true;
    ListStringOwnership p;
    p.count = 4;  // 4 strings × 16 bytes = 64 bytes = one block; count>4 would overflow
    list<string> args;
    p.run(args);
    p.WaitForExit();
    result &= Test("list<string> exit code", p.exitCode, 0);
    result &= Test("list<string> no leaks", p._allocator.usedBytes(), (i64)0);
    return result;
}

bool testListOwnershipNoLeaks() {
    bool result = true;
    ListOwnership p;
    p.count = 5;
    list<string> args;
    p.run(args);
    p.WaitForExit();
    result &= Test("list ownership exit code", p.exitCode, 0);
    result &= Test("list ownership no leaks", p._allocator.usedBytes(), (i64)0);
    return result;
}

bool testProgramCrashRecovery() {
    bool result = true;
    CrashNull p;
    list<string> args;
    p.run(args);
    p.WaitForExit();
    // SEH catches the access violation; trampoline stores -1 and exits the thread cleanly.
    result &= Test("crash recovery exit code", p.exitCode, -1);
    return result;
}

bool testWaitForExitWithToken() {
    bool result = true;

    // Thread completes naturally -> WaitForExit(token) returns true
    stop_source src;
    src.init();
    stop_token token = src.get_token();

    Minimal prog;
    list<string> args;
    prog.run(args);
    bool done = prog.WaitForExit(token);
    result &= Test("WaitForExit(token) completes", done, true);
    result &= Test("WaitForExit(token) exitCode", prog.exitCode, 0);
    src.dispose();

    return result;
}

bool testWaitForExitCancelled() {
    bool result = true;

    // Pre-cancelled token -> WaitForExit returns false immediately
    stop_source src;
    src.init();
    src.request_stop();
    stop_token token = src.get_token();

    Minimal prog;
    list<string> args;
    prog.run(args);
    bool done = prog.WaitForExit(token);
    result &= Test("WaitForExit(cancelled token) returns false", done, false);
    src.dispose();

    // WaitForExit(token) returning false does NOT join — caller must join before
    // the program goes out of scope, otherwise the thread is still accessing the struct.
    prog.WaitForExit();

    return result;
}

// ---------------------------------------------------------------------------
// WaitForExit(int) and Kill() tests
// ---------------------------------------------------------------------------

program SpinForever {
    int main(move list<string> args) {
        while (true) { }
        return 0;
    }
};

// Loops until its stop token is signalled; returns 42 on clean exit.
program CoopLoop {
    int main(move list<string> args) {
        stop_token tok = _stop_source.get_token();
        while (!tok.stop_requested()) { }
        return 42;
    }
};

bool testRequestStop() {
    bool result = true;
    CoopLoop prog;
    list<string> args;
    prog.run(args);
    prog.RequestStop();
    prog.WaitForExit();
    result &= Test("RequestStop cooperative exit", prog.exitCode, 42);
    return result;
}

bool testWaitForExitTimeoutFast() {
    bool result = true;
    // Fast program: WaitForExit with a generous timeout should return true.
    Minimal prog;
    list<string> args;
    prog.run(args);
    bool done = prog.WaitForExit(5000);
    result &= Test("WaitForExit(ms) fast program", done, true);
    result &= Test("WaitForExit(ms) exitCode", prog.exitCode, 0);
    return result;
}

bool testKillInfiniteLoop() {
    bool result = true;
    SpinForever prog;
    list<string> args;
    prog.run(args);
    // Short timeout — infinite loop won't finish.
    bool done = prog.WaitForExit(100);
    result &= Test("WaitForExit(ms) infinite loop timeout", done, false);
    // Kill the stuck thread so the test process can exit cleanly.
    prog.Kill();
    return result;
}

// ---------------------------------------------------------------------------
// Supervisor tests
// ---------------------------------------------------------------------------

bool testSupervisorSpawnsChildren() {
    bool result = true;
    Supervisor sup;
    list<string> args;
    sup.run(args);
    sup.WaitForExit();
    // 6 + 15 + 55 = 76
    result &= Test("supervisor spawns children", sup.exitCode, 76);
    return result;
}

// ---------------------------------------------------------------------------
// Handle tracker tests
// ---------------------------------------------------------------------------

program TrackHandlesCrash {
    string _path = "";

    int main(move list<string> args) {
        File f;
        f.openWrite(_path);
        // Intentionally crash without closing — tracker must close the handle
        int* p = nullptr;
        return *p;
    }
};

bool testTrackHandles() {
    bool result = true;
    string path = "test_track_tmp.txt";
    File.remove(path);

    TrackHandlesCrash p;
    p._path = path;
    p.trackHandles = true;
    list<string> args;
    p.run(args);
    p.WaitForExit();
    result &= Test("trackHandles crash exitCode", p.exitCode, -1);

    // If the tracker closed the handle, we can delete the file (no sharing violation).
    result &= Test("trackHandles handle closed on crash", File.remove(path), true);
    return result;
}

// ---------------------------------------------------------------------------
// Entry point
// ---------------------------------------------------------------------------

extern int main() {
    int passed = 0;
    int total  = 0;

    total++; passed += testProgramBasicArgsAndField()    ? 1 : 0;
    total++; passed += testProgramMinimalNoFields()      ? 1 : 0;
    total++; passed += testProgramEmptyArgs()            ? 1 : 0;
    total++; passed += testProgramExitCodeZero()         ? 1 : 0;
    total++; passed += testProgramExitCodeNonZero()      ? 1 : 0;
    total++; passed += testProgramMultipleFields()       ? 1 : 0;
    total++; passed += testProgramFieldDefaultValues()   ? 1 : 0;
    total++; passed += testProgramHeapAllocationsFreed() ? 1 : 0;
    total++; passed += testProgramMultipleRuns()         ? 1 : 0;
    total++; passed += testProgramArgsManyItems()        ? 1 : 0;
    total++; passed += testProgramArgsAndFieldCombined() ? 1 : 0;
    total++; passed += testTwoDifferentPrograms()        ? 1 : 0;
    total++; passed += testProgramHeapStressLarge()      ? 1 : 0;
    total++; passed += testListStringNoLeaks()              ? 1 : 0;
    total++; passed += testListOwnershipNoLeaks()           ? 1 : 0;
    total++; passed += testWaitForExitWithToken()          ? 1 : 0;
    total++; passed += testWaitForExitCancelled()          ? 1 : 0;
    total++; passed += testAllocatorNonNullAfterRun()      ? 1 : 0;
    total++; passed += testAllocatorNullBeforeRun()        ? 1 : 0;
    total++; passed += testAllocatorUsedBlocksCleanExit()  ? 1 : 0;
    total++; passed += testAllocatorUsedBlocksLeaked()     ? 1 : 0;
    total++; passed += testOnStdoutNamedCallback()          ? 1 : 0;
    total++; passed += testOnStdoutSecondCallback()          ? 1 : 0;
    total++; passed += testOnStdoutNullByDefault()          ? 1 : 0;
    total++; passed += testOnStdinFgets()                   ? 1 : 0;
    total++; passed += testOnStdinScanf()                   ? 1 : 0;
    total++; passed += testOnStdinNullByDefault()           ? 1 : 0;
    total++; passed += testInboxSingleMessage()              ? 1 : 0;
    total++; passed += testInboxMultipleMessages()           ? 1 : 0;
    total++; passed += testInboxSumMessages()                ? 1 : 0;
    total++; passed += testInboxPolymorphicMessages()        ? 1 : 0;
    total++; passed += testProgramCrashRecovery()           ? 1 : 0;
    total++; passed += testRequestStop()                    ? 1 : 0;
    total++; passed += testWaitForExitTimeoutFast()         ? 1 : 0;
    total++; passed += testKillInfiniteLoop()               ? 1 : 0;
    total++; passed += testSupervisorSpawnsChildren()        ? 1 : 0;
    total++; passed += testTrackHandles()                   ? 1 : 0;

    printf("Program tests: %d/%d passed.\n", passed, total);
    return passed == total ? 0 : 1;
}
