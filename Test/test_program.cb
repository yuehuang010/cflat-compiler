import "list.cb";
import "thread.cb";
import "test_helper.cb";

// ---------------------------------------------------------------------------
// Program definitions
// ---------------------------------------------------------------------------

// Minimal program: no config fields, always returns 0
program Minimal {
    int main(move list<string> args) {
        return 0;
    }
};

// Counter: int field + args.count() (baseline test)
program Counter {
    int startFrom = 0;

    int main(move list<string> args) {
        int* heap = new int;
        *heap = startFrom + args.count();
        int result = *heap;
        // heap is freed by BlockAllocator on run() exit
        return result;
    }
};

// FixedExit: returns whatever code is set in the config field
program FixedExit {
    int code = 0;

    int main(move list<string> args) {
        return code;
    }
};

// MultiField: three independent int fields summed in main
program MultiField {
    int a = 0;
    int b = 0;
    int c = 0;

    int main(move list<string> args) {
        return a + b + c;
    }
};

// HeapStress: allocates `count` ints on the heap, returns their sum;
// BlockAllocator is responsible for cleanup
program HeapStress {
    int count = 0;

    int main(move list<string> args) {
        int sum = 0;
        int i = 0;
        while (i < count) {
            int* p = new int;
            *p = i + 1;
            sum = sum + *p;
            i++;
        }
        return sum;
    }
};

// ArgsSum: returns startFrom + args.count(), testing both sources
program ArgsSum {
    int startFrom = 0;

    int main(move list<string> args) {
        return startFrom + args.count();
    }
};

// ---------------------------------------------------------------------------
// Test functions
// ---------------------------------------------------------------------------

bool testProgramBasicArgsAndField() {
    bool result = true;
    Counter c;
    c.startFrom = 10;
    list<string> args;
    string sa = "" + "a";
    string sb = "" + "b";
    args.add(sa);
    args.add(sb);
    c.run(args);
    c.WaitForExit();
    result &= Test("basic counter", c.exitCode, 12);
    return result;
}

bool testProgramMinimalNoFields() {
    bool result = true;
    Minimal m;
    list<string> args;
    m.run(args);
    m.WaitForExit();
    result &= Test("minimal no fields", m.exitCode, 0);
    return result;
}

bool testProgramEmptyArgs() {
    bool result = true;
    Counter c;
    c.startFrom = 5;
    list<string> args;
    c.run(args);
    c.WaitForExit();
    result &= Test("empty args", c.exitCode, 5);
    return result;
}

bool testProgramExitCodeZero() {
    bool result = true;
    FixedExit f;
    f.code = 0;
    list<string> args;
    f.run(args);
    f.WaitForExit();
    result &= Test("exit code 0", f.exitCode, 0);
    return result;
}

bool testProgramExitCodeNonZero() {
    bool result = true;
    FixedExit f;
    f.code = 42;
    list<string> args;
    f.run(args);
    f.WaitForExit();
    result &= Test("exit code 42", f.exitCode, 42);
    return result;
}

bool testProgramMultipleFields() {
    bool result = true;
    MultiField m;
    m.a = 3;
    m.b = 7;
    m.c = 5;
    list<string> args;
    m.run(args);
    m.WaitForExit();
    result &= Test("multiple fields sum", m.exitCode, 15);
    return result;
}

bool testProgramFieldDefaultValues() {
    bool result = true;
    // No fields set — all default to 0, so a+b+c = 0
    MultiField m;
    list<string> args;
    m.run(args);
    m.WaitForExit();
    result &= Test("field defaults zero", m.exitCode, 0);
    return result;
}

bool testProgramHeapAllocationsFreed() {
    bool result = true;
    HeapStress h;
    h.count = 10;
    list<string> args;
    h.run(args);
    h.WaitForExit();
    // sum of 1+2+...+10 = 55
    result &= Test("heap stress sum 10", h.exitCode, 55);
    return result;
}

bool testProgramMultipleRuns() {
    bool result = true;
    FixedExit f;

    f.code = 7;
    list<string> args1;
    f.run(args1);
    f.WaitForExit();
    result &= Test("multiple runs first", f.exitCode, 7);

    f.code = 13;
    list<string> args2;
    f.run(args2);
    f.WaitForExit();
    result &= Test("multiple runs second", f.exitCode, 13);

    return result;
}

bool testProgramArgsManyItems() {
    bool result = true;
    Counter c;
    c.startFrom = 0;
    list<string> args;
    string s1 = "" + "one";
    string s2 = "" + "two";
    string s3 = "" + "three";
    string s4 = "" + "four";
    string s5 = "" + "five";
    args.add(s1);
    args.add(s2);
    args.add(s3);
    args.add(s4);
    args.add(s5);
    c.run(args);
    c.WaitForExit();
    result &= Test("args count 5", c.exitCode, 5);
    return result;
}

bool testProgramArgsAndFieldCombined() {
    bool result = true;
    ArgsSum p;
    p.startFrom = 100;
    list<string> args;
    string s1 = "" + "x";
    string s2 = "" + "y";
    string s3 = "" + "z";
    args.add(s1);
    args.add(s2);
    args.add(s3);
    p.run(args);
    p.WaitForExit();
    result &= Test("field + args combined", p.exitCode, 103);
    return result;
}

bool testTwoDifferentPrograms() {
    bool result = true;

    Counter c;
    c.startFrom = 20;
    list<string> cargs;
    c.run(cargs);
    c.WaitForExit();
    result &= Test("two programs - counter", c.exitCode, 20);

    FixedExit f;
    f.code = 99;
    list<string> fargs;
    f.run(fargs);
    f.WaitForExit();
    result &= Test("two programs - fixed", f.exitCode, 99);

    return result;
}

bool testProgramHeapStressLarge() {
    bool result = true;
    HeapStress h;
    h.count = 50;
    list<string> args;
    h.run(args);
    h.WaitForExit();
    // sum of 1+2+...+50 = 1275
    result &= Test("heap stress sum 50", h.exitCode, 1275);
    return result;
}

// ---------------------------------------------------------------------------
// Allocator inspection tests
// ---------------------------------------------------------------------------

bool testAllocatorNonNullAfterRun() {
    bool result = true;
    Minimal m;
    list<string> args;
    m.run(args);
    m.WaitForExit();
    result &= Test("_allocator non-null after run", m._allocator != nullptr, true);
    return result;
}

bool testAllocatorNullBeforeRun() {
    bool result = true;
    Minimal m;
    result &= Test("_allocator null before run", m._allocator == nullptr, true);
    return result;
}

bool testAllocatorUsedBlocksCleanExit() {
    bool result = true;
    Minimal m;
    list<string> args;
    m.run(args);
    m.WaitForExit();
    // Minimal.main() makes no allocations — 0 blocks in use
    result &= Test("usedBlocks clean exit", (int)m._allocator.usedBlocks(), 0);
    return result;
}

bool testAllocatorUsedBlocksLeaked() {
    bool result = true;
    HeapStress h;
    h.count = 5;
    list<string> args;
    h.run(args);
    h.WaitForExit();
    // HeapStress allocates count ints via new int, none are freed
    result &= Test("heap stress sum 5", h.exitCode, 15);
    result &= Test("usedBlocks == count leaked", (int)h._allocator.usedBlocks(), 5);
    return result;
}

// ---------------------------------------------------------------------------
// onStdout tests
// ---------------------------------------------------------------------------

int g_stdout_count = 0;

void capture_stdout(char* s) {
    g_stdout_count++;
}

// Program that calls printf three times
program StdoutCapture {
    int main(move list<string> args) {
        printf("line 1\n");
        printf("line 2\n");
        printf("line 3\n");
        return 0;
    }
};

bool testOnStdoutNamedCallback() {
    bool result = true;
    g_stdout_count = 0;
    StdoutCapture p;
    p.onStdout = capture_stdout;
    list<string> args;
    p.run(args);
    p.WaitForExit();
    result &= Test("onStdout named callback count", g_stdout_count, 3);
    result &= Test("onStdout exitCode", p.exitCode, 0);
    return result;
}

void capture_stdout2(char* s) {
    g_stdout_count = g_stdout_count + 10;
}

bool testOnStdoutSecondCallback() {
    bool result = true;
    g_stdout_count = 0;
    StdoutCapture p;
    p.onStdout = capture_stdout2;
    list<string> args;
    p.run(args);
    p.WaitForExit();
    result &= Test("onStdout second callback count", g_stdout_count, 30);
    return result;
}

bool testOnStdoutNullByDefault() {
    bool result = true;
    g_stdout_count = 0;
    StdoutCapture p;
    // onStdout is null by default — output goes to console (we just verify callback not called)
    list<string> args;
    p.run(args);
    p.WaitForExit();
    result &= Test("onStdout default null count", g_stdout_count, 0);
    return result;
}

// ---------------------------------------------------------------------------
// stop_token tests
// ---------------------------------------------------------------------------

bool testWaitForExitWithToken() {
    bool result = true;

    // Thread completes naturally → WaitForExit(token) returns true
    stop_source src;
    src.init();
    stop_token token = src.get_token();

    Minimal prog;
    list<string> args;
    prog.run(args);
    bool done = prog.WaitForExit(token);
    result &= Test("WaitForExit(token) completes", done, true);
    result &= Test("WaitForExit(token) exitCode", prog.exitCode, 0);
    src.dispose();

    return result;
}

bool testWaitForExitCancelled() {
    bool result = true;

    // Pre-cancelled token → WaitForExit returns false immediately
    stop_source src;
    src.init();
    src.request_stop();
    stop_token token = src.get_token();

    Minimal prog;
    list<string> args;
    prog.run(args);
    bool done = prog.WaitForExit(token);
    result &= Test("WaitForExit(cancelled token) returns false", done, false);
    src.dispose();

    return result;
}

// ---------------------------------------------------------------------------
// Entry point
// ---------------------------------------------------------------------------

extern int main() {
    int passed = 0;
    int total  = 0;

    total++; passed += testProgramBasicArgsAndField()    ? 1 : 0;
    total++; passed += testProgramMinimalNoFields()      ? 1 : 0;
    total++; passed += testProgramEmptyArgs()            ? 1 : 0;
    total++; passed += testProgramExitCodeZero()         ? 1 : 0;
    total++; passed += testProgramExitCodeNonZero()      ? 1 : 0;
    total++; passed += testProgramMultipleFields()       ? 1 : 0;
    total++; passed += testProgramFieldDefaultValues()   ? 1 : 0;
    total++; passed += testProgramHeapAllocationsFreed() ? 1 : 0;
    total++; passed += testProgramMultipleRuns()         ? 1 : 0;
    total++; passed += testProgramArgsManyItems()        ? 1 : 0;
    total++; passed += testProgramArgsAndFieldCombined() ? 1 : 0;
    total++; passed += testTwoDifferentPrograms()        ? 1 : 0;
    total++; passed += testProgramHeapStressLarge()      ? 1 : 0;
    total++; passed += testWaitForExitWithToken()          ? 1 : 0;
    total++; passed += testWaitForExitCancelled()          ? 1 : 0;
    total++; passed += testAllocatorNonNullAfterRun()      ? 1 : 0;
    total++; passed += testAllocatorNullBeforeRun()        ? 1 : 0;
    total++; passed += testAllocatorUsedBlocksCleanExit()  ? 1 : 0;
    total++; passed += testAllocatorUsedBlocksLeaked()     ? 1 : 0;
    total++; passed += testOnStdoutNamedCallback()          ? 1 : 0;
    total++; passed += testOnStdoutSecondCallback()          ? 1 : 0;
    total++; passed += testOnStdoutNullByDefault()          ? 1 : 0;

    printf("Program tests: %d/%d passed.\n", passed, total);
    return passed == total ? 0 : 1;
}
