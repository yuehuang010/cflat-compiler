import "test_helper.cb";
import "xml.cb";

annotation JsonName { string value; };
annotation Private { };

// ── Structs ──────────────────────────────────────────────────────────────────

struct Point {
    int x = 0;
    int y = 0;
};

struct AllPrimitives {
    int    i = 0;
    bool   b = false;
    float  f = 0;
    string s = default;
};

struct Address {
    [JsonName("street_name")]
    string street = default;
    int zip = 0;
};

struct Employee {
    [JsonName("full_name")]
    string name = default;
    int id = 0;
    [Private]
    string _token = default;
    Address addr = default;
};

struct Level3 { int val = 0; };
struct Level2 { Level3 deep = default; int mid = 0; };
struct Level1 { Level2 inner = default; string top = default; };

// ── Class ─────────────────────────────────────────────────────────────────────

class Config {
    [JsonName("max_retries")]
    int maxRetries = 0;
    bool enabled = false;
    [Private]
    string secretKey = default;
    float threshold = 0;
};

// ── Helpers ───────────────────────────────────────────────────────────────────

bool floatNear(float a, float b)
{
    float diff = a - b;
    if (diff < 0) diff = -diff;
    return diff < 0.001f;
}

extern int main()
{
    int passed = 0;
    int total  = 0;

    // ── flat struct — toXml ──────────────────────────────────────────────────
    Point p;
    p.x = 3;
    p.y = 7;
    total++; passed += Test("toXml_flat", XmlBuilder.toXml(p, "Point"), "<Point><x>3</x><y>7</y></Point>");

    // ── all primitives — toXml ───────────────────────────────────────────────
    AllPrimitives ap;
    ap.i = 42;
    ap.b = true;
    ap.f = 1.5f;
    ap.s = "hello";
    total++; passed += Test("toXml_primitives", XmlBuilder.toXml(ap, "AllPrimitives"),
        "<AllPrimitives><i>42</i><b>true</b><f>1.5</f><s>hello</s></AllPrimitives>");

    AllPrimitives apFalse;
    apFalse.i = -7;
    apFalse.b = false;
    apFalse.f = 0;
    apFalse.s = "";
    total++; passed += Test("toXml_bool_false", XmlBuilder.toXml(apFalse, "AllPrimitives"),
        "<AllPrimitives><i>-7</i><b>false</b><f>0</f><s></s></AllPrimitives>");

    // ── nested struct with [JsonName] and [Private] — toXml ─────────────────
    Employee e;
    e.name = "Alice";
    e.id = 42;
    e._token = "secret";
    e.addr.street = "Main St";
    e.addr.zip = 12345;
    total++; passed += Test("toXml_nested", XmlBuilder.toXml(e, "Employee"),
        "<Employee><full_name>Alice</full_name><id>42</id><addr><street_name>Main St</street_name><zip>12345</zip></addr></Employee>");

    // ── deeply nested — toXml ────────────────────────────────────────────────
    Level1 l1;
    l1.top = "root";
    l1.inner.mid = 99;
    l1.inner.deep.val = 7;
    total++; passed += Test("toXml_deep", XmlBuilder.toXml(l1, "Level1"),
        "<Level1><inner><deep><val>7</val></deep><mid>99</mid></inner><top>root</top></Level1>");

    // ── class with [JsonName] and [Private] — toXml ──────────────────────────
    Config cfg;
    cfg.maxRetries = 3;
    cfg.enabled = true;
    cfg.secretKey = "hidden";
    cfg.threshold = 0.5f;
    total++; passed += Test("toXml_class", XmlBuilder.toXml(cfg, "Config"),
        "<Config><max_retries>3</max_retries><enabled>true</enabled><threshold>0.5</threshold></Config>");

    // ── XML entity escaping — toXml ──────────────────────────────────────────
    AllPrimitives esc;
    esc.i = 0;
    esc.b = false;
    esc.f = 0;
    esc.s = "a&b<c>d";
    total++; passed += Test("toXml_escape", XmlBuilder.toXml(esc, "AllPrimitives"),
        "<AllPrimitives><i>0</i><b>false</b><f>0</f><s>a&amp;b&lt;c&gt;d</s></AllPrimitives>");

    // ── fromXml — flat struct ────────────────────────────────────────────────
    // Use string variables so the string coercion works for fromXml (same pattern as fromJson).
    string xmlFlat = "<Point><x>3</x><y>7</y></Point>";
    Point p2 = XmlBuilder.fromXml<Point>(xmlFlat);
    total++; passed += Test("fromXml_flat_x", p2.x, 3);
    total++; passed += Test("fromXml_flat_y", p2.y, 7);

    // ── fromXml — all primitives ─────────────────────────────────────────────
    string xmlPrim = "<AllPrimitives><i>42</i><b>true</b><f>1.5</f><s>hello</s></AllPrimitives>";
    AllPrimitives ap2 = XmlBuilder.fromXml<AllPrimitives>(xmlPrim);
    total++; passed += Test("fromXml_int",    ap2.i, 42);
    total++; passed += Test("fromXml_bool",   ap2.b, true);
    total++; passed += Test("fromXml_string", ap2.s, "hello");
    total++;
    if (!floatNear(ap2.f, 1.5f)) { printf("fromXml_float MISMATCH (expected 1.5 got %f)\n", ap2.f); }
    else { passed++; if (printOnPass) printf("fromXml_float passed.\n"); }

    // ── fromXml — negative int ───────────────────────────────────────────────
    string xmlNeg = "<AllPrimitives><i>-7</i><b>false</b><f>0</f><s></s></AllPrimitives>";
    AllPrimitives ap3 = XmlBuilder.fromXml<AllPrimitives>(xmlNeg);
    total++; passed += Test("fromXml_neg_int",   ap3.i, -7);
    total++; passed += Test("fromXml_bool_false", ap3.b, false);
    total++; passed += Test("fromXml_empty_str",  ap3.s, "");

    // ── fromXml — [JsonName] ─────────────────────────────────────────────────
    string xmlEmp = "<Employee><full_name>Alice</full_name><id>42</id><addr><street_name>Main St</street_name><zip>12345</zip></addr></Employee>";
    Employee e2 = XmlBuilder.fromXml<Employee>(xmlEmp);
    total++; passed += Test("fromXml_name",   e2.name,        "Alice");
    total++; passed += Test("fromXml_id",     e2.id,          42);
    total++; passed += Test("fromXml_street", e2.addr.street, "Main St");
    total++; passed += Test("fromXml_zip",    e2.addr.zip,    12345);

    // ── fromXml — [Private] field must stay default ───────────────────────────
    total++; passed += Test("fromXml_private_skipped", e2._token, "");

    // ── fromXml — class with [JsonName] and [Private] ────────────────────────
    string xmlCfg = "<Config><max_retries>5</max_retries><enabled>false</enabled><secretKey>attempt</secretKey><threshold>0.75</threshold></Config>";
    Config cfg2 = XmlBuilder.fromXml<Config>(xmlCfg);
    total++; passed += Test("fromXml_class_retries", cfg2.maxRetries, 5);
    total++; passed += Test("fromXml_class_enabled", cfg2.enabled,    false);
    total++; passed += Test("fromXml_class_private", cfg2.secretKey,  "");
    total++;
    if (!floatNear(cfg2.threshold, 0.75f)) { printf("fromXml_class_threshold MISMATCH (expected 0.75 got %f)\n", cfg2.threshold); }
    else { passed++; if (printOnPass) printf("fromXml_class_threshold passed.\n"); }

    // ── fromXml — deep nesting ───────────────────────────────────────────────
    string xmlDeep = "<Level1><inner><deep><val>7</val></deep><mid>99</mid></inner><top>root</top></Level1>";
    Level1 l2 = XmlBuilder.fromXml<Level1>(xmlDeep);
    total++; passed += Test("fromXml_deep_top",  l2.top,            "root");
    total++; passed += Test("fromXml_deep_mid",  l2.inner.mid,      99);
    total++; passed += Test("fromXml_deep_val",  l2.inner.deep.val, 7);

    // ── fromXml — entity unescaping ──────────────────────────────────────────
    string xmlEsc = "<AllPrimitives><i>0</i><b>false</b><f>0</f><s>a&amp;b&lt;c&gt;d</s></AllPrimitives>";
    AllPrimitives ap4 = XmlBuilder.fromXml<AllPrimitives>(xmlEsc);
    total++; passed += Test("fromXml_unescape", ap4.s, "a&b<c>d");

    // ── round-trip — Employee ────────────────────────────────────────────────
    string xmlE3 = XmlBuilder.toXml(e, "Employee");
    Employee e3 = XmlBuilder.fromXml<Employee>(xmlE3);
    total++; passed += Test("roundtrip_name",   e3.name,        e.name);
    total++; passed += Test("roundtrip_id",     e3.id,          e.id);
    total++; passed += Test("roundtrip_street", e3.addr.street, e.addr.street);
    total++; passed += Test("roundtrip_zip",    e3.addr.zip,    e.addr.zip);

    // ── round-trip — AllPrimitives ───────────────────────────────────────────
    string xmlAp5 = XmlBuilder.toXml(ap, "AllPrimitives");
    AllPrimitives ap5 = XmlBuilder.fromXml<AllPrimitives>(xmlAp5);
    total++; passed += Test("roundtrip_prim_int",    ap5.i, ap.i);
    total++; passed += Test("roundtrip_prim_bool",   ap5.b, ap.b);
    total++; passed += Test("roundtrip_prim_string", ap5.s, ap.s);
    total++;
    if (!floatNear(ap5.f, ap.f)) { printf("roundtrip_prim_float MISMATCH (expected %f got %f)\n", ap.f, ap5.f); }
    else { passed++; if (printOnPass) printf("roundtrip_prim_float passed.\n"); }

    // ── zero / default values ────────────────────────────────────────────────
    Point p0;
    string xmlP0 = XmlBuilder.toXml(p0, "Point");
    Point p0rt = XmlBuilder.fromXml<Point>(xmlP0);
    total++; passed += Test("roundtrip_zero_x", p0rt.x, 0);
    total++; passed += Test("roundtrip_zero_y", p0rt.y, 0);

    printf("%d/%d tests passed.\n", passed, total);
    return passed == total ? 0 : 1;
}
