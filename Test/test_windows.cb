// Win32 C-interop regression test. Importing the system <windows.h> header exercises several
// compiler paths that previously failed:
//   1. Function decls reached via clang's auto-detected SDK toolchain (whose presumed paths
//      carry doubled separators) must pass the in-scope filter - otherwise GetCurrentProcessId
//      and friends resolve as "Undefined variable".
//   2. windows.h registers C unions whose members are records cflat had to abandon (an
//      unsupported field type leaves an opaque, unsized shell). Sizing such a union used to
//      assert ("Cannot getTypeInfo() on a type that is unsized"); it must now be skipped.
//   3. Struct import via the by-value dependency closure: an in-scope struct (MSG, WNDCLASSEXA in
//      um/) embeds a struct from the SDK shared/ dir (POINT/RECT) by value; the dependency must be
//      pulled in or the in-scope struct fails to size. Typedef names (MSG, not just tagMSG) work,
//      function-pointer fields are bare void* (correct ABI size), and object-like #define
//      constants (WM_*, WS_*) are folded from the header bind.
//   4. The inline `lib { ... }` brace clause links several system import libs by bare name. A bare
//      lib name (user32.lib, gdi32.lib) is not found beside this .cb, so it must be passed through
//      to lld-link and resolved against the SDK lib dir cflat discovered for the header - no
//      --c-lib / absolute path. If bare-name resolution regresses, the link fails and this test
//      never builds; calling one function from each lib then proves both were actually linked.
// cflat auto-resolves the Windows SDK include dir, so no --c-include flag is required.
import "test_helper.cb";
import "windows.h" lib { "user32.lib", "gdi32.lib" };

extern int main()
{
    int passed = 0;
    int total = 0;

    u32 pid = GetCurrentProcessId();
    total++; passed += Test("GetCurrentProcessId nonzero", pid != 0, true);

    void* out = GetStdHandle((u32)-11);  // STD_OUTPUT_HANDLE
    total++; passed += Test("GetStdHandle non-null", out != nullptr, true);

    // A folded macro keeps its natural C type: ((DWORD)-11) is u32, not a
    // width-guessed i64, so the call site needs no cast.
    void* out2 = GetStdHandle(STD_OUTPUT_HANDLE);
    total++; passed += Test("GetStdHandle(STD_OUTPUT_HANDLE) uncast", out2 == out, true);

    // A pseudo-handle cast macro ((HKEY)(ULONG_PTR)((LONG)0x80000002)) folds to
    // a void* constant.
    total++; passed += Test("HKEY_LOCAL_MACHINE folds to pointer", HKEY_LOCAL_MACHINE != nullptr, true);

    u32 tick1 = GetTickCount();
    Sleep(1);
    u32 tick2 = GetTickCount();
    total++; passed += Test("GetTickCount monotonic", tick2 >= tick1, true);

    // Struct import: typedef-named Win32 structs resolve with the correct C ABI layout. POINT and
    // RECT live in the SDK shared/ dir (out of the in-scope um/ dir); the by-value dependency
    // closure pulls them in so MSG (embeds POINT) and WNDCLASSEXA size correctly.
    total++; passed += Test("sizeof(POINT)", (int)sizeof(POINT), 8);
    total++; passed += Test("sizeof(RECT)", (int)sizeof(RECT), 16);
    total++; passed += Test("sizeof(MSG)", (int)sizeof(MSG), 48);
    total++; passed += Test("sizeof(WNDCLASSEXA)", (int)sizeof(WNDCLASSEXA), 80);

    // A C function-pointer field (WNDPROC lpfnWndProc) is a bare void*, not a 16-byte closure -
    // otherwise WNDCLASSEXA would be 88 bytes and every following field would be misaligned.
    WNDCLASSEXA wc = default;
    total++; passed += Test("WNDCLASSEXA zero-init", (int)wc.cbSize, 0);
    total++; passed += Test("WNDCLASSEXA wndproc field is null ptr", wc.lpfnWndProc == nullptr, true);

    // Constants from the SDK shared/ sibling dir fold too (the in-scope filter treats
    // um/ and shared/ as one surface): winerror.h ERROR_* codes, minwindef.h MAX_PATH,
    // and HRESULT cast macros like E_FAIL ((HRESULT)0x80004005L).
    total++; passed += Test("ERROR_SUCCESS (shared/winerror.h)", (int)ERROR_SUCCESS, 0);
    total++; passed += Test("ERROR_FILE_NOT_FOUND (shared/winerror.h)", (int)ERROR_FILE_NOT_FOUND, 2);
    total++; passed += Test("MAX_PATH (shared/minwindef.h)", (int)MAX_PATH, 260);
    total++; passed += Test("E_FAIL (HRESULT cast macro)", (u32)E_FAIL == 0x80004005u, true);

    // Object-like #define constants are folded from the header bind (no hand-transcribing needed).
    total++; passed += Test("WM_DESTROY", (int)(u32)WM_DESTROY, 2);
    total++; passed += Test("WM_COMMAND", (int)(u32)WM_COMMAND, 0x0111);
    total++; passed += Test("WS_OVERLAPPEDWINDOW", (u32)WS_OVERLAPPEDWINDOW == 0x00CF0000u, true);
    total++; passed += Test("SW_SHOW", SW_SHOW, 5);

    // Inline `lib { ... }` brace clause: linking the named libs by bare name worked (the exe
    // built), and these calls prove each lib was actually linked, not just name-resolved.
    int cx = GetSystemMetrics(0);  // SM_CXSCREEN - user32.lib
    total++; passed += Test("GetSystemMetrics linked (user32)", cx >= 0, true);
    void* brush = CreateSolidBrush(255u);  // RGB(255,0,0) - gdi32.lib
    total++; passed += Test("CreateSolidBrush non-null (gdi32)", brush != nullptr, true);
    total++; passed += Test("DeleteObject succeeded (gdi32)", DeleteObject(brush) != 0, true);

    printf("\n%d / %d tests passed.\n", passed, total);
    return passed == total ? 0 : 1;
}
