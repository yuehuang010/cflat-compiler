import "filesystem.cb";
import "test_helper.cb";

// ── File static methods: read/write/exists/remove ─────────────────────────────

int testFileReadWrite()
{
    int passed = 0;
    string path = "test_fs_tmp.txt";
    string hw   = "hello world";
    string again = " again";

    File.remove(path);
    passed += Test("file not exists before write", File.exists(path), false);

    passed += Test("writeAllText",            File.writeAllText(path, hw), true);
    passed += Test("file exists after write", File.exists(path),           true);

    string content = File.readAllText(path);
    passed += Test("readAllText content", content.data(), "hello world");
    passed += Test("readAllText length",  content.length(), 11);

    passed += Test("appendAllText", File.appendAllText(path, again), true);
    string content2 = File.readAllText(path);
    passed += Test("after append", content2.data(), "hello world again");

    passed += Test("File.remove",               File.remove(path), true);
    passed += Test("file not exists after del", File.exists(path), false);

    return passed;
}

// ── File class: open / writeLine / readLine / size ────────────────────────────

int testFileClass()
{
    int passed = 0;
    string path  = "test_fs_class.txt";
    string hello = "hello";
    string world = "world";
    File.remove(path);

    File* w = new File;
    passed += Test("openWrite",       w->openWrite(path), true);
    passed += Test("isOpen",          w->isOpen(),        true);
    passed += Test("writeLine hello", w->writeLine(hello), true);
    passed += Test("writeLine world", w->writeLine(world), true);
    w->close();
    passed += Test("isOpen after close", w->isOpen(), false);
    delete w;

    File* r = new File;
    passed += Test("openRead", r->openRead(path), true);
    string line1 = r->readLine();
    string line2 = r->readLine();
    passed += Test("readLine 1", line1.data(), "hello");
    passed += Test("readLine 2", line2.data(), "world");
    string skipped = r->readLine();   // owning return: bind so it is freed, not discarded
    passed += Test("atEnd", r->atEnd(), true);
    delete r;

    // "hello\n" + "world\n" = 12 bytes
    File* s = new File;
    s->openRead(path);
    int sz = s->size();
    passed += Test("file size 12", sz == 12, true);
    delete s;

    File.remove(path);
    return passed;
}

// ── File.move ─────────────────────────────────────────────────────────────────

int testFileMove()
{
    int passed = 0;
    string src     = "test_fs_move_src.txt";
    string dst     = "test_fs_move_dst.txt";
    string moveme  = "move me";
    File.remove(src);
    File.remove(dst);

    File.writeAllText(src, moveme);
    passed += Test("File.move ok",           File.move(src, dst),  true);
    passed += Test("src gone after move",    File.exists(src),     false);
    passed += Test("dst exists after move",  File.exists(dst),     true);

    string content = File.readAllText(dst);
    passed += Test("moved content", content.data(), "move me");

    File.remove(dst);
    return passed;
}

// ── Directory static methods ──────────────────────────────────────────────────

int testDirectoryFunctions()
{
    int passed = 0;
    string testDir = "test_fs_dir";

    Directory.remove(testDir);
    passed += Test("dir not exists before create", Directory.exists(testDir), false);
    passed += Test("Directory.create",             Directory.create(testDir), true);
    passed += Test("dir exists after create",      Directory.exists(testDir), true);
    passed += Test("Directory.remove",             Directory.remove(testDir), true);
    passed += Test("dir not exists after delete",  Directory.exists(testDir), false);

    string cwd = Directory.getCurrent();
    passed += Test("getCurrent not empty", cwd.length() > 0, true);

    return passed;
}

// ── Directory class (instance methods) ───────────────────────────────────────

int testDirectoryClass()
{
    int passed = 0;
    // Build child paths with Path.combine: '\\' is a literal filename character on
    // POSIX, so a hardcoded separator creates one oddly-named top-level entry.
    string testDir = "test_fs_dir2";
    string atxt    = Path.combine(testDir, "a.txt");
    string btxt    = Path.combine(testDir, "b.txt");

    File.remove(atxt);
    File.remove(btxt);
    Directory.remove(testDir);

    Directory* d = new Directory;
    d->init(testDir);

    passed += Test("Directory.exists false",  d->exists(), false);
    passed += Test("Directory.create",        d->create(), true);
    passed += Test("Directory.exists true",   d->exists(), true);

    File.remove(atxt);
    File.remove(btxt);
    passed += Test("Directory.remove", d->remove(), true);
    delete d;

    return passed;
}

// ── File.isFile / isDirectory / copy ─────────────────────────────────────────

int testFileStaticHelpers()
{
    int passed = 0;
    string fpath   = "test_fs_helpers.txt";
    string dpath   = "test_fs_helpers_dir";
    string missing = "test_fs_no_such.txt";

    File.writeAllText(fpath, "hello");
    Directory.create(dpath);

    passed += Test("isFile on file",      File.isFile(fpath),      true);
    passed += Test("isDir on file",       File.isDirectory(fpath), false);
    passed += Test("isDir on directory",  File.isDirectory(dpath), true);
    passed += Test("isFile on directory", File.isFile(dpath),      false);
    passed += Test("isFile on missing",   File.isFile(missing),    false);

    string csrc = "test_fs_copy_src.txt";
    string cdst = "test_fs_copy_dst.txt";
    File.writeAllText(csrc, "copy me");
    passed += Test("File.copy ok",      File.copy(csrc, cdst), true);
    string copied = File.readAllText(cdst);
    passed += Test("File.copy content", copied.data(), "copy me");

    File.remove(fpath);
    File.remove(csrc);
    File.remove(cdst);
    Directory.remove(dpath);
    return passed;
}

// ── File instance: readBytes / writeBytes / seek / tell / flush / readLines ──

int testFileInstanceMethods()
{
    int passed = 0;

    // writeBytes / readBytes / seek / tell
    string bpath = "test_fs_bytes.bin";
    File* f = new File;
    f->openWrite(bpath);
    i8* wbuf = new i8[4];
    wbuf[0] = 10; wbuf[1] = 20; wbuf[2] = 30; wbuf[3] = 40;
    int written = f->writeBytes(wbuf, 4);
    f->flush();
    delete f;
    delete[] wbuf;

    passed += Test("writeBytes count", written, 4);

    f = new File;
    f->openRead(bpath);
    passed += Test("size after writeBytes", f->size(), 4);

    i8* rbuf = new i8[4];
    int nread = f->readBytes(rbuf, 4);
    passed += Test("readBytes count", nread, 4);
    passed += Test("readBytes[0]", rbuf[0], 10);
    passed += Test("readBytes[3]", rbuf[3], 40);

    f->seek(1, 0);
    passed += Test("tell after seek", f->tell(), 1);
    delete f;
    delete[] rbuf;
    File.remove(bpath);

    // readLines
    string lpath = "test_fs_lines.txt";
    File.writeAllText(lpath, "alpha\nbeta\ngamma\n");
    f = new File;
    f->openRead(lpath);
    list<string>* lines = f->readLines();
    passed += Test("readLines count", lines->count(), 3);
    string line0 = lines->get(0);
    string line2 = lines->get(2);
    passed += Test("readLines[0]", line0.data(), "alpha");
    passed += Test("readLines[2]", line2.data(), "gamma");
    delete lines;
    delete f;
    File.remove(lpath);

    return passed;
}

// ── Path class ───────────────────────────────────────────────────────────────

int testPathClass()
{
    int passed = 0;
    string r;

    // combine
    string cfoo    = "C:\\foo";
    string cfoosl  = "C:\\foo\\";
    string bar     = "bar";
    string empty   = "";
    string foo     = "foo";
    // combine INSERTS the platform separator (_fs_sep) but ACCEPTS either when
    // parsing, so only the inserted one differs by platform. The cfoosl case
    // already ends in a separator, so nothing is inserted and it matches everywhere.
    string joined = "C:\\foo/bar";
    if const (__WINDOWS__) { joined = "C:\\foo\\bar"; }
    r = Path.combine(cfoo, bar);
    passed += Test("combine adds sep",      r.data(), joined.data());
    r = Path.combine(cfoosl, bar);
    passed += Test("combine no double sep", r.data(), "C:\\foo\\bar");
    r = Path.combine(empty, bar);
    passed += Test("combine empty a",       r.data(), "bar");
    r = Path.combine(foo, empty);
    passed += Test("combine empty b",       r.data(), "foo");

    // getFileName
    string dirfile = "C:\\dir\\file.txt";
    string filetxt = "file.txt";
    r = Path.getFileName(dirfile);
    passed += Test("getFileName",        r.data(), "file.txt");
    r = Path.getFileName(filetxt);
    passed += Test("getFileName no sep", r.data(), "file.txt");

    // getDirectory
    r = Path.getDirectory(dirfile);
    passed += Test("getDirectory",        r.data(), "C:\\dir");
    r = Path.getDirectory(filetxt);
    passed += Test("getDirectory no sep", r.data(), "");

    // getExtension / hasExtension
    string fileonly = "file";
    r = Path.getExtension(filetxt);
    passed += Test("getExtension",       r.data(), ".txt");
    r = Path.getExtension(fileonly);
    passed += Test("getExtension none",  r.data(), "");
    passed += Test("hasExtension true",  Path.hasExtension(filetxt),   true);
    passed += Test("hasExtension false", Path.hasExtension(fileonly),   false);

    // changeExtension
    string dotmd  = ".md";
    string md     = "md";
    r = Path.changeExtension(filetxt, dotmd);
    passed += Test("changeExtension",        r.data(), "file.md");
    r = Path.changeExtension(filetxt, md);
    passed += Test("changeExtension no dot", r.data(), "file.md");
    r = Path.changeExtension(filetxt, empty);
    passed += Test("changeExtension strip",  r.data(), "file");

    // getAbsolute / getTempPath
    string dot = ".";
    string abs = Path.getAbsolute(dot);
    passed += Test("getAbsolute not empty", abs.length() > 0, true);

    string tmp = Path.getTempPath();
    passed += Test("getTempPath not empty", tmp.length() > 0, true);

    return passed;
}

// ── Directory: listFiles / listDirs / listRecursive / createAll / getTemp ────

int testDirectoryExtended()
{
    int passed = 0;
    string base     = "test_fs_dxt";
    string sub      = Path.combine(base, "sub");
    string afile    = Path.combine(base, "a.txt");
    string bfile    = Path.combine(sub, "b.txt");
    string deepbase = Path.combine(base, "deep");
    string deepdir  = Path.combine(deepbase, "nested");

    // Setup
    Directory.create(base);
    Directory.create(sub);
    File.writeAllText(afile, "a");
    File.writeAllText(bfile, "b");

    // listFiles
    list<string>* files = Directory.listFiles(base);
    passed += Test("listFiles count", files->count(), 1);
    string fname = files->get(0);
    passed += Test("listFiles[0]",    fname.data(), "a.txt");
    delete files;

    // listDirs
    list<string>* dirs = Directory.listDirs(base);
    passed += Test("listDirs count", dirs->count(), 1);
    string dname = dirs->get(0);
    passed += Test("listDirs[0]",    dname.data(), "sub");
    delete dirs;

    // listRecursive: a.txt + sub + sub\b.txt = 3 entries
    list<string>* all = Directory.listRecursive(base);
    passed += Test("listRecursive count", all->count(), 3);
    delete all;

    // createAll
    passed += Test("createAll",        Directory.createAll(deepdir), true);
    passed += Test("createAll exists", Directory.exists(deepdir),    true);

    // getTemp
    string tmp = Directory.getTemp();
    passed += Test("getTemp not empty", tmp.length() > 0, true);

    // Cleanup
    File.remove(afile);
    File.remove(bfile);
    Directory.remove(sub);
    Directory.remove(deepdir);
    Directory.remove(deepbase);
    Directory.remove(base);

    return passed;
}

// ── MappedFile ─────────────────────────────────────────────────────────────

int testMappedFile()
{
    int passed = 0;
    string path = "test_fs_mapped.bin";
    File.remove(path);

    // Round-trip a known buffer through openWrite + flush + openRead.
    MappedFile* w = new MappedFile;
    passed += Test("MappedFile.openWrite", w->openWrite(path, 40), true);   // 5 doubles
    passed += Test("MappedFile write length", w->length(), (i64)40);
    span<double> wsp = w->asSpan<double>();
    passed += Test("write span length", wsp.length(), (i64)5);
    int i = 0;
    while (i < 5) { wsp.set(i, (double)i * 1.5); i = i + 1; }
    passed += Test("flush", w->flush(), true);
    delete w;   // destructor unmaps

    MappedFile* r = new MappedFile;
    passed += Test("MappedFile.openRead", r->openRead(path), true);
    passed += Test("MappedFile read length", r->length(), (i64)40);
    span<double> rsp = r->asSpan<double>();
    passed += Test("read span length", rsp.length(), (i64)5);
    bool valuesOk = true;
    i = 0;
    while (i < 5) { if (rsp.get(i) != (double)i * 1.5) valuesOk = false; i = i + 1; }
    passed += Test("asSpan values round-trip", valuesOk, true);
    delete r;
    File.remove(path);

    // A zero-length file must map cleanly (len 0, null addr, openRead true) -
    // NOT an error - on every platform (Windows cannot map a 0-size section).
    string emptyPath = "test_fs_mapped_empty.bin";
    File.writeAllText(emptyPath, "");
    MappedFile* e = new MappedFile;
    passed += Test("empty file openRead", e->openRead(emptyPath), true);
    passed += Test("empty file length", e->length(), (i64)0);
    passed += Test("empty file data null", e->data() == nullptr, true);
    span<double> esp = e->asSpan<double>();
    passed += Test("empty file span length", esp.length(), (i64)0);
    delete e;
    File.remove(emptyPath);

    // Opening a missing file for read fails cleanly (not an empty mapping).
    MappedFile* missing = new MappedFile;
    passed += Test("missing file openRead fails", missing->openRead("test_fs_mapped_missing.bin"), false);
    delete missing;

    // Map/drop loop: if the destructor failed to unmap, repeatedly mapping a
    // fresh region would eventually exhaust address space / fail to allocate.
    string loopPath = "test_fs_mapped_loop.bin";
    File.remove(loopPath);
    bool loopOk = true;
    i = 0;
    while (i < 2000) {
        MappedFile mf;
        if (!mf.openWrite(loopPath, 65536)) { loopOk = false; break; }
        mf.close();
        i = i + 1;
    }
    passed += Test("map/drop loop does not leak", loopOk, true);
    File.remove(loopPath);

    return passed;
}

// ── main ─────────────────────────────────────────────────────────────────────

extern int main()
{
    int passed = 0;
    int total  = 0;

    int r;

    r = testFileReadWrite();        passed += r; total += 9;
    r = testFileClass();            passed += r; total += 10;
    r = testFileMove();             passed += r; total += 4;
    r = testDirectoryFunctions();   passed += r; total += 6;
    r = testDirectoryClass();       passed += r; total += 4;
    r = testFileStaticHelpers();    passed += r; total += 7;
    r = testFileInstanceMethods();  passed += r; total += 9;
    r = testPathClass();            passed += r; total += 17;
    r = testDirectoryExtended();    passed += r; total += 8;
    r = testMappedFile();           passed += r; total += 14;

    printf("\n%d / %d tests passed.\n", passed, total);
    return passed == total ? 0 : 1;
}
