// End-to-end C-interop coverage. Each section exercises one path of the C-interop
// pipeline; on failure the section's exit code identifies which one regressed.
//
//   Section A (1-9)   : auto-extern of a compiled .c source (clang JSON AST -> auto
//                       extern + struct registration), no hand-written declarations.
//   Section B (10)    : hand-written extern alongside auto-extern (first-writer-wins).
//   Section C (20-25) : `import package` - prebuilt library bound via header + .lib,
//                       including variadic call-site ABI and enum constant registration.
//   Section D (30-42) : struct-by-value ABI - core sizes 1/4/8/12/24, mixed slots,
//                       SRet+ByVal round-trip.
//   Section E (50-59) : struct-by-value ABI - odd sizes 2/3/7 (non-{1,2,4,8} routes).
//   Section F (60-69) : struct-by-value ABI - single-float / single-double / mixed-
//                       type structs (MSVC x64 still routes through GPR, not XMM).
//   Section G (70-79) : struct-by-value ABI - nested struct field, pointer-field
//                       struct (size differs across Win64/Win32), composed calls.
//   Section H (80-89) : struct-by-value ABI - register exhaustion (6 struct params
//                       on Win64 spills past RCX/RDX/R8/R9 onto the stack).
//   Section I (90-99) : object-like #define macro extraction - decimal, hex,
//                       parenthesized negative, expression-folded, i64-promoted,
//                       define-gated, and float/double (routed via __typeof__);
//                       function-like / string macros must be silently skipped
//                       without poisoning their neighbors.
//   Section J (100-115): function-like #define macro translation - each accepted
//                       macro becomes an `auto` generic function callable without
//                       explicit type args; rejected bodies (calls, strings,
//                       member access, floats) must be silently dropped.
//   Section K (120-129): typedef chain resolution - signatures spelled with
//                       `typedef void* HANDLE` (and multi-hop chains like
//                       SCK -> HANDLE -> void*) must auto-register; previously
//                       skipped as "unsupported return/parameter type".

import "library/cinterop.c";
import "library/struct_byval_util.c";
import package "cinterop/mathlib.h" lib "cinterop/mathlib.lib" define "ML_EXTRA";
import "library/c_macro_helpers.h";

// Section B: hand-written extern alongside auto-extern. Same signatures the auto-
// extern path infers; first-writer-wins resolves the duplicate without diagnostic.
extern int c_add(int a, int b);
extern int c_square(int x);

extern void printf(const char* fmt, ...);
extern int  strcmp(const char* a, const char* b);

// CFlat function used as a callback into the C library through the function-pointer
// typedef ML_BinaryOp (declared in mathlib.h as `typedef int (*ML_BinaryOp)(int,int)`).
int my_add_cb(int a, int b) { return a + b; }
int my_sub_cb(int a, int b) { return a - b; }

extern int main()
{
    // ---- Section A: auto-extern of .c source ---------------------------------
    if (c_add(40, 2) != 42)             return 1;
    if (c_square(7) != 49)              return 2;

    // ---- Section B: hand-written extern (same calls, validates coexistence) --
    if (c_add(1, 2) != 3)               return 10;

    // ---- Section C: import package (header + .lib + enum constants) ----------
    if (ml_add(40, 2) != 42)            return 20;       // plain function
    if (ml_mul(6, 7) != 42)             return 21;
    if (ml_sum(4, 10, 20, 30, 40) != 100) return 22;     // variadic call-site ABI
    if (WHITE != 100)                   return 23;       // explicit enum value
    if (GREEN != 2)                     return 24;       // auto-incremented enum value
    if (EXTRA_FLAG != 7)                return 25;       // gated by inline `define "ML_EXTRA"`

    // ---- Section D: struct-by-value ABI --------------------------------------
    // 1-byte struct: CoerceToInt(i8) on Win64; ByVal on Win32.
    Byte1 b1 = make_byte1(42);
    if (b1.b != 42)                     return 30;
    if (sum_byte1(b1) != 42)            return 31;

    // 4-byte struct: CoerceToInt(i32) on both platforms.
    Byte4 b4 = make_byte4(1234567);
    if (b4.x != 1234567)                return 32;
    if (sum_byte4(b4) != 1234567)       return 33;

    // 8-byte struct: CoerceToInt(i64) on both platforms (Win32 returns in EDX:EAX).
    Pair p = make_pair(10, 32);
    if (p.x != 10 || p.y != 32)         return 34;
    if (sum_pair(p) != 42)              return 35;

    // 12-byte struct: ByVal/SRet on both platforms.
    Med m = make_med(100, 200, 300);
    if (m.a != 100 || m.b != 200 || m.c != 300) return 36;
    if (sum_med(m) != 600)              return 37;

    // 24-byte struct: ByVal/SRet on both platforms.
    Big bg = make_big(1.5, 2.5, 3.5);
    double s = sum_big(bg);
    if (s < 7.49 || s > 7.51)           return 38;

    // Mixed slot: struct sandwiched between scalar args - exercises non-first slots.
    int sp = scaled_pair(3, p, 7);  // 3*(10+32) + 7 = 133
    if (sp != 133)                      return 39;

    // Round-trip: ByVal arg + SRet return on the same call. Verifies that:
    //   - The callee's mutation lands in the returned struct.
    //   - The caller's bg is NOT mutated (byval means the callee gets a copy).
    Big bumped = bump_big(bg, 1.0);
    double bs = sum_big(bumped);
    if (bs < 10.49 || bs > 10.51)       return 40;
    double original = sum_big(bg);
    if (original < 7.49 || original > 7.51) return 41;

    // ---- Section E: odd / non-{1,2,4,8} sizes --------------------------------
    // 4-byte struct built from two i16 fields - layout/alignment differ from
    // the all-int Byte4 case but lowering must still be CoerceToInt(i32).
    Two t2 = make_two(1000, 2345);
    if (t2.a != 1000 || t2.b != 2345)   return 50;
    if (sum_two(t2) != 3345)            return 51;

    // 3-byte struct - ByVal/SRet on both platforms (size not in {1,2,4,8}).
    Tri t3 = make_tri(10, 20, 30);
    if (t3.a != 10 || t3.b != 20 || t3.c != 30) return 52;
    if (sum_tri(t3) != 60)              return 53;

    // 7-byte struct - ByVal/SRet on both. Exercises a sret slot smaller than 8.
    Sev t7 = make_sev(1, 2, 3, 4, 5, 6, 7);
    if (sum_sev(t7) != 28)              return 54;

    // ---- Section F: single-float / single-double / mixed-type ----------------
    // Struct-of-float: 4 bytes, MSVC x64 still passes/returns in GPR (no HFA).
    Flt ff = make_flt(2.5f);
    float fv = get_flt(ff);
    if (fv < 2.49 || fv > 2.51)         return 60;

    // Struct-of-double: 8 bytes, GPR on both platforms (EDX:EAX on Win32).
    Dbl dd = make_dbl(3.25);
    double dv = get_dbl(dd);
    if (dv < 3.24 || dv > 3.26)         return 61;

    // Mixed int+double: 16 bytes (4 + 4 padding + 8) -> ByVal/SRet on both.
    // Verifies the recipe respects struct padding, not just naive field-size sum.
    Mix mx = make_mix(7, 1.5);
    if (mx.i != 7)                      return 62;
    if (mx.d < 1.49 || mx.d > 1.51)     return 63;
    double mc = mix_combine(mx);
    if (mc < 8.49 || mc > 8.51)         return 64;

    // ---- Section G: nested struct field, pointer-field struct, composed calls --
    // Nested struct - inner Pair is registered before Nested so the field type
    // resolves correctly during RegisterCRecords' two-pass body fill.
    Nested ns = make_nested(11, 22, 33);
    if (ns.p.x != 11 || ns.p.y != 22 || ns.extra != 33) return 70;
    if (nested_sum(ns) != 66)           return 71;

    // Struct with an int* field. Win64: 16 bytes (ByVal/SRet). Win32: 8 bytes
    // (CoerceToInt(i64)). Same source, different ABI path per platform.
    int payload = 100;
    PtrFld pf = make_ptrfld(&payload, 5);
    if (pf.n != 5)                      return 72;
    if (ptrfld_load(pf) != 105)         return 73;

    // Composed call: struct return fed directly into a struct param, with no
    // intermediate local. Verifies EmitAbiLoweredCall correctly allocates the
    // arg-slot from a value still residing in the previous call's sret/coerce slot.
    if (sum_pair(make_pair(8, 9)) != 17)     return 74;
    if (sum_med(make_med(1, 2, 3)) != 6)     return 75;
    double composed = sum_big(make_big(2.0, 3.0, 4.0));
    if (composed < 8.99 || composed > 9.01)  return 76;

    // ---- Section H: register exhaustion on Win64 (>4 struct args) ------------
    // Six 8-byte structs: first four go in RCX/RDX/R8/R9 (each as i64 coerce),
    // the last two spill onto the stack. A miscompile in the spill path or in
    // the per-slot CoerceToInt would show up as a wrong total here.
    Pair p1 = make_pair(1,  2);
    Pair p2 = make_pair(3,  4);
    Pair p3 = make_pair(5,  6);
    Pair p4 = make_pair(7,  8);
    Pair p5 = make_pair(9,  10);
    Pair p6 = make_pair(11, 12);
    if (sum_six_pairs(p1, p2, p3, p4, p5, p6) != 78) return 80;

    // ---- Section I: object-like #define macro extraction ---------------------
    // Decimal, hex, parenthesized negative, and folded expression all resolve
    // via the enum-stub Pass B in ExtractCHeaderMacros.
    if (ML_PI_X100 != 314)              return 90;
    if (ML_MAX_NODES != 4096)           return 91;   // 0x1000
    if (ML_NEG_OFFSET != -5)            return 92;
    if (ML_COMBINED_MASK != 21)         return 93;   // (1<<0)|(1<<2)|(1<<4)

    // Value > INT32_MAX -> registered as i64 (RegisterCMacros widens automatically).
    i64 big = ML_BIG_CONST;
    if (big != (i64)0x100000000)        return 94;

    // Gated by inline `define "ML_EXTRA"` on the import line. Verifies per-import
    // defines reach the macro extractor, not just the decl/enum dumps.
    if (ML_EXTRA_MACRO != 77)           return 95;

    // Float/double macros - routed through the double-fold probe based on the
    // __typeof__ recovered C type. Registered as CFlat `double` globals.
    if (ML_PI < 3.1415 || ML_PI > 3.1416)               return 96;
    if (ML_HALF < 0.49 || ML_HALF > 0.51)               return 97;
    if (ML_NEG_FLOAT < -1.26 || ML_NEG_FLOAT > -1.24)   return 98;
    if (ML_TWO_PI < 6.28 || ML_TWO_PI > 6.29)           return 99;
    // Float-suffixed source literal: precision lost in float->double round-trip
    // is still well inside our 0.01 tolerance.
    if (ML_FLOAT_F < 2.49 || ML_FLOAT_F > 2.51)         return 119;

    // String-literal macros - routed through Pass B's __typeof__ probe (recovered
    // type is char[N]) and resolved by the string-literal probe. Registered as
    // CFlat `char*` globals interned in the string pool; the C call-site ABI
    // treats them as `const char*`.
    if (strcmp(ML_NAME, "mathlib") != 0)                 return 125;
    if (strcmp(ML_VERSION, "1.2.3") != 0)                return 126;
    if (strcmp(ML_GREETING, "hello\nworld") != 0)        return 127;

    // Anonymous enum: constants are still registered as bare globals (no type
    // name to bind to). The EnumDecl walker is name-agnostic for the constants.
    if (ML_ANON_LOW != 50)                               return 130;
    if (ML_ANON_HIGH != 60)                              return 131;

    // Typedef of anonymous enum: clang reports desugaredQualType as the typedef
    // name itself (self-reference), so CollectCTypedefs falls back to qualType
    // ("enum ML_Mode") to keep the chain resolvable. Without the fallback the
    // signatures below would skip with "unsupported parameter type 'ML_Mode'".
    if (ML_FAST != 1)                                    return 132;
    if (ML_SLOW != 2)                                    return 133;
    if (ml_mode_value(ML_FAST) != 1)                     return 134;
    if (ml_mode_value(ML_AUTO) != 3)                     return 135;
    if (ml_pick_mode(1) != 1)                            return 136;  // ML_FAST
    if (ml_pick_mode(2) != 2)                            return 137;  // ML_SLOW
    if (ml_pick_mode(9) != 3)                            return 138;  // ML_AUTO

    // Typedef of named enum where alias differs from the tag (ML_PriorityAlias
    // -> enum ML_PriorityTag -> int). Constants register as bare globals; the
    // typedef-as-type would resolve to int via the enum-strip path.
    if (ML_LOW_PRI != 10)                                return 139;
    if (ML_HIGH_PRI != 20)                               return 140;

    // Function-pointer typedef: ML_BinaryOp = `int (*)(int,int)`. clang's
    // qualType for the typedef is "int (*)(int, int)"; CollectCTypedefs stores
    // that spelling, MapCTypeToTypeAndValue's ParseCFunctionPointerSpelling
    // turns it into a CFlat IsFunctionPointer TypeAndValue.
    if (ml_apply(my_add_cb, 10, 32) != 42)               return 141;
    if (ml_apply(my_sub_cb, 50,  8) != 42)               return 142;

    // Function-pointer return value: ml_pick_op returns ML_BinaryOp. CFlat
    // receives a fat-struct function<int(int,int)> and calls it through the
    // indirect-call path.
    function<int(int,int)> op_add = ml_pick_op(0);
    function<int(int,int)> op_mul = ml_pick_op(1);
    function<int(int,int)> op_sub = ml_pick_op(2);
    if (op_add(10, 32) != 42)                            return 143;
    if (op_mul(6, 7)  != 42)                             return 144;
    if (op_sub(50, 8) != 42)                             return 145;

    // Function-pointer macro constant: ML_NULL_OP = ((int(*)(int,int))0). Pass B
    // recognizes the (*) shape in __typeof__ output and registers the macro as a
    // function<int(int,int)> global, env=intToPtr(0). The interesting bit is that
    // the assignment compiles - the macro resolves to the constant fat struct
    // and the storage matches function<int(int,int)>. We don't invoke (env=0
    // would AV); we also don't compare (closure fat structs aren't icmp-able).
    function<int(int,int)> sentinel = ML_NULL_OP;
    // Reassign from a live callback to confirm the variable behaves as function<T>.
    sentinel = ml_pick_op(0);
    if (sentinel(10, 32) != 42)                          return 146;

    // ---- Section M: C-interop named union ------------------------------------
    // mathlib.h declares `union ML_IntFloat { int as_int; float as_float; }`.
    // RegisterCRecords routes this through CreateUnionType so both fields share
    // offset 0 (max-size slot, no FieldIndex GEPs). Pass-by-pointer to a C helper
    // exercises that the union resolves end-to-end through the auto-extern path
    // and that field access on a `union ML_IntFloat *` GEPs to offset 0.
    ML_IntFloat u = default;
    ml_pun_write_int(&u, 0x40490FDB);                    // ~ pi as float bits (IEEE-754)
    int ref_bits = ml_pun_int_bits_of(3.14159274f);      // reference bit pattern
    // Field overlap: writing as_int and reading as_float must see the same bytes.
    float f = ml_pun_read_float(&u);
    if (ml_pun_int_bits_of(f) != ref_bits)               return 150;
    // Field overlap from the cflat side: write as_float, read as_int.
    u.as_float = 3.14159274f;
    if (u.as_int != ref_bits)                            return 151;
    // Round-trip the other direction.
    u.as_int = 42;
    if (u.as_int != 42)                                  return 152;

    // ---- Section J: function-like macro translation -------------------------
    // Each accepted macro from c_macro_helpers.h is translated into an `auto`
    // generic function and called without explicit type arguments.
    if (CB_MIN(3, 7) != 3)               return 100;
    if (CB_MIN(9, 2) != 2)               return 101;
    if (CB_MAX(3, 7) != 7)               return 102;
    if (CB_MAX(9, 2) != 9)               return 103;

    if (CB_KB(2) != 2048)                return 104;
    if (CB_KB(0) != 0)                   return 105;

    if (CB_LOWORD(0x12345678) != 0x5678) return 106;
    if (CB_HIWORD(0x12345678) != 0x1234) return 107;

    if (CB_ABS(-9) != 9)                 return 108;
    if (CB_ABS(9)  != 9)                 return 109;

    if (CB_IS_ODD(5) != 1)               return 110;
    if (CB_IS_ODD(4) != 0)               return 111;

    if (CB_CLAMP(5, 0, 10) != 5)         return 112;
    if (CB_CLAMP(-3, 0, 10) != 0)        return 113;
    if (CB_CLAMP(99, 0, 10) != 10)       return 114;

    // Cross-type instantiation: i64 arg forces CB_MIN<int,i64> with widened return.
    if (CB_MIN(3, (i64)7) != (i64)3)     return 115;

    // ---- Section K: typedef chain resolution --------------------------------
    // c_get_handle returns C_HANDLE (typedef void* C_HANDLE). Before this fix
    // the function was skipped with "unsupported return type 'C_HANDLE'".
    void* h = c_get_handle();
    if (c_handle_load(h) != 0x5A5A5A5A) return 120;

    // Multi-hop typedef: SCK -> C_HANDLE -> void*. Mapper must follow >1 hop.
    if (c_sck_load(h) != 0x5A5A5A5A)    return 121;

    // Typedef'd integer chain: C_LONG_PTR -> long long -> i64.
    if (c_lp_double((i64)21) != (i64)42) return 122;

    // Pointer-sentinel macro: CB_INVALID_HANDLE = ((CB_HANDLE)(CB_LONG_PTR)-1).
    // Pass B's __typeof__ probe recovers the type as CB_HANDLE -> void*, so the
    // macro is registered as a void* global and compares equal to the matching
    // pointer returned from C. Before the fix it registered as an i64 constant
    // and the comparison was a type error.
    void* invalid_h = c_get_invalid_handle();
    if (invalid_h != CB_INVALID_HANDLE) return 123;
    if (h == CB_INVALID_HANDLE)         return 124;   // real handle, not sentinel

    // ---- Section N: anonymous union inside struct (C11) ---------------------
    // mathlib.h declares `struct ML_Overlap { int header; union { int as_int;
    // float as_float; }; int trailer; }`. The C-interop extractor synthesizes a
    // tag (`ML_Overlap__anon0`) for the inner union, registers it as a sibling
    // record, and rewrites the materializing unnamed field to a synthetic name
    // `__anon0`. CFlat reaches the inner members via `o.__anon0.as_int`.
    ML_Overlap o = default;
    o.header  = 0x11111111;
    o.trailer = 0x22222222;
    o.__anon0.as_int = 0x40490FDB;                       // pi-as-float bit pattern
    int ref2 = ml_pun_int_bits_of(3.14159274f);
    if (ml_overlap_read_int(&o) != 0x40490FDB)   return 130;
    // Field overlap inside the anon union: writing as_int and reading as_float
    // through the C helper must see the same bytes.
    if (ml_pun_int_bits_of(ml_overlap_read_float(&o)) != ref2) return 131;
    // Surrounding fields are unaffected by the union write.
    if (ml_overlap_header_of(&o)  != 0x11111111) return 132;
    if (ml_overlap_trailer_of(&o) != 0x22222222) return 133;
    // Symmetric write from cflat: write as_float through the anon, read as_int.
    o.__anon0.as_float = 3.14159274f;
    if (o.__anon0.as_int != ref2)                return 134;

    // ---- Section O: _Bool and long double round-trip -----------------------
    // _Bool (C99) maps to CFlat bool; long double on MSVC is an 8-byte alias of
    // double, so it maps to CFlat double. Both pass-by-value and pointer-out
    // shapes must round-trip cleanly.
    if (ml_bool_not(true)  != false)             return 140;
    if (ml_bool_not(false) != true)              return 141;
    if (ml_bool_and(true, false) != false)       return 142;
    if (ml_bool_and(true, true)  != true)        return 143;
    bool bout = false;
    ml_bool_store(&bout, true);
    if (bout != true)                            return 144;

    if (ml_ld_identity(2.5) != 2.5)              return 145;
    if (ml_ld_add(1.25, 2.5) != 3.75)            return 146;
    double dout = 0.0;
    ml_ld_store(&dout, 7.125);
    if (dout != 7.125)                           return 147;

    // ---- Section P: 3+ levels of pointer indirection -----------------------
    // mathlib.h declares helpers taking `int***`. The C-interop mapper collapses
    // ptr > 2 to opaque `void**` (TypeAndValue has only Pointer + ElemPointer);
    // CFlat holds the chain as an opaque handle and threads it back through C.
    // Functions that were previously skipped per the `ptr > 2` guard now bind.
    void** chain = ml_make_ppp(123);
    if (ml_ppp_load(chain) != 123)               return 160;
    ml_ppp_set(chain, 456);
    if (ml_ppp_load(chain) != 456)               return 161;
    ml_ppp_free(chain);

    return 0;
}
