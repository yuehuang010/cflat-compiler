// test_winmd.cb - CONSUME-side WinRT metadata: import "*.winmd", iidof, parameterized
// interfaces, and foreach over a live WinRT collection. (The PRODUCE side - authoring a
// [winrt] COM object - is covered separately by test_com.cb.)
//
// Every assertion here is driven against REAL in-box Windows objects, so the OS itself is the
// oracle: when QueryInterface accepts a compiler-derived parameterized IID (PIID), Windows has
// independently computed the same 16 bytes CFlat did (RFC 4122 v5 SHA-1 over the WinRT type
// signature). Covers milestones M1-M5 of internal/plan/winmd-parameterized.md.
//
// Build:  x64/Debug/cflat.exe Test/test_winmd.cb -i Test/library -o out/test_winmd.exe
// Run:    out\test_winmd.exe

import "Windows.Foundation.winmd";   // PropertyValue, IReference`1, IIterable`1 / IIterator`1
import "Windows.Data.winmd";         // JsonArray, IJsonValue, IJsonArrayStatics

// roapi.h (RoInitialize/RoGetActivationFactory) and winstring.h (WindowsCreateString/...) are
// real WinRT SDK headers - import them so their prototypes are auto-externed; no hand-written
// decls. The .winmd files above resolve by bare name from %SystemRoot%\System32\WinMetadata.
import { "windows.h", "roapi.h", "winstring.h" } lib { "RuntimeObject.lib", "ole32.lib" } cache;
import "test_helper.cb";
import "guid.cb";

// Widen an ASCII cflat string into a UTF-16 HSTRING (every input here is pure ASCII).
void* MakeHString(string s)
{
    u16[128] wbuf = default;
    int i = 0;
    while (i < s.length()) { wbuf[i] = (u16)s.data()[i]; i = i + 1; }
    void* h = nullptr;
    WindowsCreateString(&wbuf[0], (u32)s.length(), &h);
    return h;
}

// === iidof byte-exactness: a stored IID and a DERIVED parameterized IID (no OS needed) ===
//
// iidof(T) yields a REFIID-shaped pointer to a static 16-byte GUID. For a plain imported
// interface it is the IID stored in metadata; for a parameterized instance it is the PIID CFlat
// derives. We compare both against their published, byte-exact reference values.
bool testIidofByteExact()
{
    bool result = true;

    // Plain (non-generic) interface: iidof returns the IID recorded in the winmd verbatim.
    Guid* pStatics = (Guid*)iidof(IPropertyValueStatics);
    Guid statics = *pStatics;
    Guid staticsExpected = Guid.parse("629bdbc8-d932-4ff4-96b9-8d96c5c1e858");
    result &= Test("winmd_iidof_plain", (statics == staticsExpected) ? 1 : 0, 1);

    // Parameterized interface: iidof returns the derived PIID. IReference<int> is NOT in
    // metadata - it is synthesized from the IReference`1 template - yet must equal the value
    // cppwinrt/windows-rs publish for IReference<Int32>.
    Guid* pRefInt = (Guid*)iidof(IReference<int>);
    Guid refInt = *pRefInt;
    Guid refIntExpected = Guid.parse("548cefbd-bc8a-5fa0-8df2-957440fc8bf4");
    result &= Test("winmd_iidof_piid_int", (refInt == refIntExpected) ? 1 : 0, 1);

    // Distinct type args derive distinct PIIDs (proves the signature string varies by arg).
    Guid* pRefBool = (Guid*)iidof(IReference<bool>);
    Guid refBool = *pRefBool;
    result &= Test("winmd_piid_distinct_per_arg", (refInt == refBool) ? 1 : 0, 0);

    return result;
}

// === Live parameterized consume: box values, QI through the derived PIID, read back ===
//
// Activates Windows.Foundation.PropertyValue, boxes an Int32 and a Boolean, then recovers each
// through IReference<T> using iidof. A successful QI means the OS accepted the derived PIID.
bool testLiveParameterizedRoundtrip()
{
    bool result = true;

    void* hClass = MakeHString("Windows.Foundation.PropertyValue");
    IPropertyValueStatics* factory = nullptr;
    i32 hr = RoGetActivationFactory(hClass, iidof(IPropertyValueStatics), (void**)&factory);
    result &= Test("winmd_activation_hr", (hr == 0 && factory != nullptr) ? 1 : 0, 1);
    if (hr != 0 || factory == nullptr) { WindowsDeleteString(hClass); return false; }

    // Box an Int32 -> IInspectable, QI for IReference<int>, read the value back. This path uses the
    // `recv->Method(args)` sugar: a vtable-slot name routes through lpVtbl AND the receiver is passed
    // as the implicit `this`, so `refInt->Release()` means `refInt->lpVtbl->Release(refInt)`. The bool
    // path below keeps the explicit `recv->lpVtbl->Method(recv, ...)` form, so both are regression-
    // covered against a live object. QueryInterface stays explicit because its receiver is a cast
    // rvalue with no addressable storage, which the sugar (storage-based) does not apply to.
    void* boxedInt = nullptr;
    factory->CreateInt32(1234, &boxedInt);
    IReference<int>* refInt = nullptr;
    i32 qiInt = ((IReference<int>*)boxedInt)->lpVtbl->QueryInterface(
        boxedInt, iidof(IReference<int>), (void**)&refInt);
    result &= Test("winmd_qi_int_accepted", (qiInt == 0 && refInt != nullptr) ? 1 : 0, 1);
    if (qiInt == 0 && refInt != nullptr)
    {
        int value = default;
        refInt->get_Value(&value);
        result &= Test("winmd_ref_int_value", value, 1234);
        refInt->Release();
    }
    ((IReference<int>*)boxedInt)->lpVtbl->Release(boxedInt);

    // A SECOND, distinct instantiation proves parameterization is general, not int-special-cased.
    void* boxedBool = nullptr;
    factory->lpVtbl->CreateBoolean(factory, true, &boxedBool);
    IReference<bool>* refBool = nullptr;
    i32 qiBool = ((IReference<bool>*)boxedBool)->lpVtbl->QueryInterface(
        boxedBool, iidof(IReference<bool>), (void**)&refBool);
    result &= Test("winmd_qi_bool_accepted", (qiBool == 0 && refBool != nullptr) ? 1 : 0, 1);
    if (qiBool == 0 && refBool != nullptr)
    {
        bool bval = default;
        refBool->lpVtbl->get_Value(refBool, &bval);
        result &= Test("winmd_ref_bool_value", bval ? 1 : 0, 1);
        refBool->lpVtbl->Release(refBool);
    }
    ((IReference<bool>*)boxedBool)->lpVtbl->Release(boxedBool);

    factory->lpVtbl->Release(factory);
    WindowsDeleteString(hClass);
    return result;
}

// === foreach over a live WinRT collection via IIterable<T>/IIterator<T> ===
//
// JsonArray.Parse("[10,20,30]") yields an IJsonArray, which IS an IVector<IJsonValue> and so
// requires IIterable<IJsonValue>. `for (IJsonValue* x in arr)` synthesizes the iterable/iterator
// vtables on demand, QIs the live object, and drives First/get_HasCurrent/get_Current/MoveNext.
bool testForeachCollection()
{
    bool result = true;

    void* hClass = MakeHString("Windows.Data.Json.JsonArray");
    IJsonArrayStatics* factory = nullptr;
    i32 hr = RoGetActivationFactory(hClass, iidof(IJsonArrayStatics), (void**)&factory);
    result &= Test("winmd_json_activation_hr", (hr == 0 && factory != nullptr) ? 1 : 0, 1);
    if (hr != 0 || factory == nullptr) { WindowsDeleteString(hClass); return false; }

    void* hJson = MakeHString("[10,20,30]");
    IJsonArray* arr = nullptr;
    i32 parseHr = factory->lpVtbl->Parse(factory, hJson, (void**)&arr);
    result &= Test("winmd_json_parse_hr", (parseHr == 0 && arr != nullptr) ? 1 : 0, 1);
    if (parseHr == 0 && arr != nullptr)
    {
        double sum = 0.0;
        int count = 0;
        for (IJsonValue* x in arr)
        {
            double d = default;
            x->lpVtbl->GetNumber(x, &d);
            sum = sum + d;
            count = count + 1;
        }
        result &= Test("winmd_foreach_count", count, 3);
        result &= Test("winmd_foreach_sum", (int)sum, 60);
        arr->lpVtbl->Release(arr);
    }

    factory->lpVtbl->Release(factory);
    WindowsDeleteString(hJson);
    WindowsDeleteString(hClass);
    return result;
}

extern int main()
{
    RoInitialize(1);   // RO_INIT_MULTITHREADED

    int passed = 0;
    int total  = 0;

    total++; passed += testIidofByteExact()            ? 1 : 0;
    total++; passed += testLiveParameterizedRoundtrip() ? 1 : 0;
    total++; passed += testForeachCollection()          ? 1 : 0;

    RoUninitialize();

    printf("WinMD consume-side tests: %d/%d passed.\n", passed, total);
    return passed == total ? 0 : 1;
}
