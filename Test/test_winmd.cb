// test_winmd.cb - CONSUME-side WinRT metadata: import "*.winmd", iidof, parameterized
// interfaces, and foreach over a live WinRT collection. (The PRODUCE side - authoring a
// [winrt] COM object - is covered separately by test_com.cb.)
//
// Every assertion here is driven against REAL in-box Windows objects, so the OS itself is the
// oracle: when QueryInterface accepts a compiler-derived parameterized IID (PIID), Windows has
// independently computed the same 16 bytes CFlat did (RFC 4122 v5 SHA-1 over the WinRT type
// signature). Covers milestones M1-M5 of internal/plan/winmd-parameterized.md.
//
// Build:  x64/Debug/cflat.exe Test/test_winmd.cb -i Test/library -o out/test_winmd.exe
// Run:    out\test_winmd.exe

import "Windows.Data.winmd";         // JsonArray, IJsonValue, IJsonArrayStatics
import "Windows.Storage.winmd";      // IPathIOStatics - async file round-trip (IAsyncOperation`1)

// winrt.cb pulls Windows.Foundation.winmd (PropertyValue, IReference`1, IIterable`1, IAsync*) +
// the WinRT import libs, and supplies hstring/activationFactory/awaitAsync/winrtInit. windows.h
// supplies the kernel32 calls the async test uses (GetTempPathW/CreateFileW/CloseHandle).
import "winrt.cb";
import "windows.h" cache;
import "test_helper.cb";
import "guid.cb";

// === iidof byte-exactness: a stored IID and a DERIVED parameterized IID (no OS needed) ===
//
// iidof(T) yields a REFIID-shaped pointer to a static 16-byte GUID. For a plain imported
// interface it is the IID stored in metadata; for a parameterized instance it is the PIID CFlat
// derives. We compare both against their published, byte-exact reference values.
bool testIidofByteExact()
{
    bool result = true;

    // Plain (non-generic) interface: iidof returns the IID recorded in the winmd verbatim.
    Guid* pStatics = (Guid*)iidof(IPropertyValueStatics);
    Guid statics = *pStatics;
    Guid staticsExpected = Guid.parse("629bdbc8-d932-4ff4-96b9-8d96c5c1e858");
    result &= Test("winmd_iidof_plain", (statics == staticsExpected) ? 1 : 0, 1);

    // Parameterized interface: iidof returns the derived PIID. IReference<int> is NOT in
    // metadata - it is synthesized from the IReference`1 template - yet must equal the value
    // cppwinrt/windows-rs publish for IReference<Int32>.
    Guid* pRefInt = (Guid*)iidof(IReference<int>);
    Guid refInt = *pRefInt;
    Guid refIntExpected = Guid.parse("548cefbd-bc8a-5fa0-8df2-957440fc8bf4");
    result &= Test("winmd_iidof_piid_int", (refInt == refIntExpected) ? 1 : 0, 1);

    // Distinct type args derive distinct PIIDs (proves the signature string varies by arg).
    Guid* pRefBool = (Guid*)iidof(IReference<bool>);
    Guid refBool = *pRefBool;
    result &= Test("winmd_piid_distinct_per_arg", (refInt == refBool) ? 1 : 0, 0);

    return result;
}

// === Live parameterized consume: box values, QI through the derived PIID, read back ===
//
// Activates Windows.Foundation.PropertyValue, boxes an Int32 and a Boolean, then recovers each
// through IReference<T> using iidof. A successful QI means the OS accepted the derived PIID.
bool testLiveParameterizedRoundtrip()
{
    bool result = true;

    IPropertyValueStatics* factory = nullptr;
    i32 hr = activationFactory("Windows.Foundation.PropertyValue", iidof(IPropertyValueStatics), (void**)&factory);
    result &= Test("winmd_activation_hr", (hr == 0 && factory != nullptr) ? 1 : 0, 1);
    if (hr != 0 || factory == nullptr) return false;

    // Box an Int32 -> IInspectable, QI for IReference<int>, read the value back. This path uses the
    // `recv->Method(args)` sugar: a vtable-slot name routes through lpVtbl AND the receiver is passed
    // as the implicit `this`, so `refInt->Release()` means `refInt->lpVtbl->Release(refInt)`. The bool
    // path below keeps the explicit `recv->lpVtbl->Method(recv, ...)` form, so both are regression-
    // covered against a live object. QueryInterface stays explicit because its receiver is a cast
    // rvalue with no addressable storage, which the sugar (storage-based) does not apply to.
    void* boxedInt = nullptr;
    factory->CreateInt32(1234, &boxedInt);
    IReference<int>* refInt = nullptr;
    i32 qiInt = ((IReference<int>*)boxedInt)->lpVtbl->QueryInterface(
        boxedInt, iidof(IReference<int>), (void**)&refInt);
    result &= Test("winmd_qi_int_accepted", (qiInt == 0 && refInt != nullptr) ? 1 : 0, 1);
    if (qiInt == 0 && refInt != nullptr)
    {
        int value = default;
        refInt->get_Value(&value);
        result &= Test("winmd_ref_int_value", value, 1234);
        refInt->Release();
    }
    ((IReference<int>*)boxedInt)->lpVtbl->Release(boxedInt);

    // A SECOND, distinct instantiation proves parameterization is general, not int-special-cased.
    void* boxedBool = nullptr;
    factory->lpVtbl->CreateBoolean(factory, true, &boxedBool);
    IReference<bool>* refBool = nullptr;
    i32 qiBool = ((IReference<bool>*)boxedBool)->lpVtbl->QueryInterface(
        boxedBool, iidof(IReference<bool>), (void**)&refBool);
    result &= Test("winmd_qi_bool_accepted", (qiBool == 0 && refBool != nullptr) ? 1 : 0, 1);
    if (qiBool == 0 && refBool != nullptr)
    {
        bool bval = default;
        refBool->lpVtbl->get_Value(refBool, &bval);
        result &= Test("winmd_ref_bool_value", bval ? 1 : 0, 1);
        refBool->lpVtbl->Release(refBool);
    }
    ((IReference<bool>*)boxedBool)->lpVtbl->Release(boxedBool);

    factory->lpVtbl->Release(factory);
    return result;
}

// === foreach over a live WinRT collection via IIterable<T>/IIterator<T> ===
//
// JsonArray.Parse("[10,20,30]") yields an IJsonArray, which IS an IVector<IJsonValue> and so
// requires IIterable<IJsonValue>. `for (IJsonValue* x in arr)` synthesizes the iterable/iterator
// vtables on demand, QIs the live object, and drives First/get_HasCurrent/get_Current/MoveNext.
bool testForeachCollection()
{
    bool result = true;

    IJsonArrayStatics* factory = nullptr;
    i32 hr = activationFactory("Windows.Data.Json.JsonArray", iidof(IJsonArrayStatics), (void**)&factory);
    result &= Test("winmd_json_activation_hr", (hr == 0 && factory != nullptr) ? 1 : 0, 1);
    if (hr != 0 || factory == nullptr) return false;

    void* hJson = hstring("[10,20,30]");
    IJsonArray* arr = nullptr;
    i32 parseHr = factory->lpVtbl->Parse(factory, hJson, (void**)&arr);
    result &= Test("winmd_json_parse_hr", (parseHr == 0 && arr != nullptr) ? 1 : 0, 1);
    if (parseHr == 0 && arr != nullptr)
    {
        double sum = 0.0;
        int count = 0;
        for (IJsonValue* x in arr)
        {
            double d = default;
            x->lpVtbl->GetNumber(x, &d);
            sum = sum + d;
            count = count + 1;
        }
        result &= Test("winmd_foreach_count", count, 3);
        result &= Test("winmd_foreach_sum", (int)sum, 60);
        arr->lpVtbl->Release(arr);
    }

    factory->lpVtbl->Release(factory);
    freeHString(hJson);
    return result;
}

// === WinRT async via polling: IAsyncAction + IAsyncOperation<String> through PathIO ===
//
// Drives a real WinRT async file round-trip without a completion-handler delegate. Proves the
// generic IAsyncOperation`1 template instantiates on demand (deriving a PIID like IReference<T>)
// and that IAsyncAction / IAsyncInfo project as plain interfaces. PathIO opens an existing file,
// so a Win32 CreateFileW pre-creates the empty target.
bool testAsyncRoundtrip()
{
    bool result = true;

    u16[260] pathBuf = default;
    u32 baseLen = GetTempPathW(260, &pathBuf[0]);
    string fname = "cflat_winmd_async_test.txt";
    int j = 0;
    while (j < fname.length()) { pathBuf[baseLen + (u32)j] = (u16)fname.data()[j]; j = j + 1; }
    u32 pathLen = baseLen + (u32)fname.length();
    void* hPath = nullptr;
    WindowsCreateString(&pathBuf[0], pathLen, &hPath);

    IPathIOStatics* pathIO = nullptr;
    i32 hr = activationFactory("Windows.Storage.PathIO", iidof(IPathIOStatics), (void**)&pathIO);
    result &= Test("winmd_async_activation_hr", (hr == 0 && pathIO != nullptr) ? 1 : 0, 1);
    if (hr != 0 || pathIO == nullptr) { freeHString(hPath); return false; }

    void* hFile = CreateFileW(&pathBuf[0], 0x40000000, 0, nullptr, 2, 0x80, nullptr);
    CloseHandle(hFile);

    string content = "hello from cflat async";
    void* hContent = hstring(content);

    void* writeOp = nullptr;
    hr = pathIO->WriteTextAsync(hPath, hContent, &writeOp);
    i32 wStatus = (hr == 0 && writeOp != nullptr) ? awaitAsync(writeOp) : -1;
    if (writeOp != nullptr)
    {
        ((IAsyncAction*)writeOp)->lpVtbl->GetResults(writeOp);
        ((IAsyncAction*)writeOp)->lpVtbl->Release(writeOp);
    }
    result &= Test("winmd_async_write_completed", wStatus, 1);

    void* readOp = nullptr;
    hr = pathIO->ReadTextAsync(hPath, &readOp);
    i32 rStatus = (hr == 0 && readOp != nullptr) ? awaitAsync(readOp) : -1;
    void* hOut = nullptr;
    if (readOp != nullptr)
    {
        ((IAsyncOperation<string>*)readOp)->lpVtbl->GetResults(readOp, &hOut);
        ((IAsyncOperation<string>*)readOp)->lpVtbl->Release(readOp);
    }
    result &= Test("winmd_async_read_completed", rStatus, 1);

    string readBack = fromHString(hOut);
    result &= Test("winmd_async_roundtrip_text", (readBack == content) ? 1 : 0, 1);

    pathIO->lpVtbl->Release(pathIO);
    freeHString(hOut);
    freeHString(hContent);
    freeHString(hPath);
    return result;
}

// === wstring unit coverage: real UTF-8 <-> UTF-16 transcode + move/copy/equality ===
//
// Proves wstring transcodes (BMP path here) rather than byte-widening: a 3-byte UTF-8 euro sign
// U+20AC must become a SINGLE UTF-16 code unit 0x20AC (a byte-widen would wrongly yield 3 units).
// Non-ASCII inputs are built from raw bytes so this source file stays ASCII.
bool testWString()
{
    bool result = true;

    // ASCII round-trips: code-unit length, and identical bytes back.
    string ascii = "hello wstring";
    wstring wa = ascii.toWString();
    result &= Test("wstring_ascii_len", wa.length(), 13);
    result &= Test("wstring_ascii_roundtrip", (wa.toString() == ascii) ? 1 : 0, 1);

    // U+20AC EURO SIGN: UTF-8 E2 82 AC (3 bytes) -> one UTF-16 unit 0x20AC -> 3 bytes back.
    i8[4] eu = default;
    eu[0] = (i8)0xE2; eu[1] = (i8)0x82; eu[2] = (i8)0xAC; eu[3] = (i8)0;
    string euro = (string)&eu[0];
    wstring we = euro.toWString();
    result &= Test("wstring_utf8_to_one_unit", we.length(), 1);
    result &= Test("wstring_utf8_unit_value", (int)we.data()[0], 0x20AC);
    result &= Test("wstring_utf16_to_utf8_len", we.toString().length(), 3);

    // Empty input -> empty wstring -> empty string.
    string emptyStr = "";
    wstring wem = emptyStr.toWString();
    result &= Test("wstring_empty_len", wem.length(), 0);
    result &= Test("wstring_empty_roundtrip", wem.toString().isEmpty() ? 1 : 0, 1);

    // fromUtf16 copies a borrowed buffer; copy() is independent; equality is code-unit-wise.
    u16[3] units = default;
    units[0] = (u16)65; units[1] = (u16)66; units[2] = (u16)67;   // "ABC"
    wstring wf = wstring.fromUtf16(&units[0], 3);
    result &= Test("wstring_fromUtf16_text", (wf.toString() == "ABC") ? 1 : 0, 1);
    result &= Test("wstring_neq", (wf == wa) ? 1 : 0, 0);
    wstring wc = wa.copy();
    result &= Test("wstring_copy_equal", (wc == wa) ? 1 : 0, 1);

    // Move-by-default: `wstring m = src` transfers the buffer (single free; no leak/double-free).
    wstring src = ascii.toWString();
    wstring m = src;
    result &= Test("wstring_move_len", m.length(), 13);

    return result;
}

// === HSTRING bridge via winrt.cb: string -> HSTRING -> string round-trips (ASCII + non-ASCII) ===
bool testWinrtBridge()
{
    bool result = true;

    void* h = hstring("bridge round-trip");
    string back = fromHString(h);
    freeHString(h);
    result &= Test("winrt_hstring_bridge", (back == "bridge round-trip") ? 1 : 0, 1);

    i8[4] eu = default;
    eu[0] = (i8)0xE2; eu[1] = (i8)0x82; eu[2] = (i8)0xAC; eu[3] = (i8)0;   // U+20AC euro
    string euro = (string)&eu[0];
    void* he = hstring(euro);
    string backe = fromHString(he);
    freeHString(he);
    result &= Test("winrt_hstring_nonascii", (backe == euro) ? 1 : 0, 1);

    return result;
}

// === `using` alias of a deferred winmd generic interface ===
//
// A `using` alias whose RHS is a parameterized WinRT interface must instantiate that interface
// on demand (same path as a cast / iidof use-site), not error "is not a generic type". Regression
// for the alias-RHS instantiation fix. The alias is proven REAL by driving it against a live OS
// object: box an Int32, QI through the aliased type, and read the value back.
using RefInt = IReference<int>;
// Non-generic winmd interface alias - the cast-through-alias path must expand it too.
using PVStatics = IPropertyValueStatics;

bool testUsingAliasOfWinmdGeneric()
{
    bool result = true;

    IPropertyValueStatics* factory = nullptr;
    i32 hr = activationFactory("Windows.Foundation.PropertyValue", iidof(IPropertyValueStatics), (void**)&factory);
    result &= Test("winmd_alias_activation_hr", (hr == 0 && factory != nullptr) ? 1 : 0, 1);
    if (hr != 0 || factory == nullptr) return false;

    void* boxed = nullptr;
    // Cast through the NON-GENERIC alias `PVStatics`: ((PVStatics*)factory)->lpVtbl->... must
    // expand the alias to IPropertyValueStatics, else "Undefined variable lpVtbl". Proven live.
    ((PVStatics*)factory)->lpVtbl->CreateInt32(factory, 4242, &boxed);
    result &= Test("winmd_alias_cast_nongeneric_box", boxed != nullptr ? 1 : 0, 1);

    // The aliased type is a typed local whose vtable dispatch resolves to the instantiated thin
    // interface - the same typed-local-plus-`->` shape the GetStringAsync fix enables. A live
    // get_Value of 4242 proves the alias names the real IReference<int>, not a stub.
    RefInt* ref = nullptr;
    i32 qi = ((IReference<int>*)boxed)->lpVtbl->QueryInterface(boxed, iidof(IReference<int>), (void**)&ref);
    result &= Test("winmd_alias_qi_accepted", (qi == 0 && ref != nullptr) ? 1 : 0, 1);
    if (qi == 0 && ref != nullptr)
    {
        int value = default;
        ref->get_Value(&value);
        result &= Test("winmd_alias_ref_value", value, 4242);
        ref->Release();
    }

    // Cast through the GENERIC alias `RefInt`: ((RefInt*)boxed)->lpVtbl->... must expand to the
    // instantiated IReference<int> thin struct (the remaining cast-in-alias gap this fix closes).
    RefInt* ref2 = nullptr;
    i32 qi2 = ((RefInt*)boxed)->lpVtbl->QueryInterface(boxed, iidof(IReference<int>), (void**)&ref2);
    result &= Test("winmd_alias_cast_generic_qi", (qi2 == 0 && ref2 != nullptr) ? 1 : 0, 1);
    if (qi2 == 0 && ref2 != nullptr)
    {
        int value2 = default;
        ((RefInt*)ref2)->lpVtbl->get_Value(ref2, &value2);
        result &= Test("winmd_alias_cast_generic_value", value2, 4242);
        ((RefInt*)ref2)->lpVtbl->Release(ref2);
    }

    ((IReference<int>*)boxed)->lpVtbl->Release(boxed);
    factory->lpVtbl->Release(factory);
    return result;
}

// === ComPtr<T> RAII: own a real activation factory, borrow via .get(), drop at scope end ===
//
// Acquires IPropertyValueStatics into a ComPtr via put(), boxes an Int32 through a live .get() call,
// QIs the box into a SECOND ComPtr, reads the value back, then lets both ComPtrs fall out of scope.
// The owning-value/move machinery must Release each underlying interface exactly once - no leak, no
// double-free. The value surviving the scope drop (read back == 7777 afterward) is the functional
// proof that release happened cleanly without corrupting state.
bool testComPtrRaii()
{
    bool result = true;

    int boxedValue = 0;
    {
        // put() now returns a typed T**; activationFactory takes void**, so cast at the call site.
        ComPtr<IPropertyValueStatics> factory = default;
        i32 hr = activationFactory("Windows.Foundation.PropertyValue", iidof(IPropertyValueStatics), (void**)factory.put());
        result &= Test("comptr_activation_hr", (hr == 0 && factory.valid()) ? 1 : 0, 1);
        if (hr != 0 || !factory.valid()) return false;

        // .get() borrows the raw pointer for a live vtable call; the ComPtr keeps ownership.
        void* boxed = nullptr;
        factory.get()->CreateInt32(7777, &boxed);
        result &= Test("comptr_box_nonnull", boxed != nullptr ? 1 : 0, 1);

        // tryAs() QIs `boxed` into the holder and keeps the HRESULT - one call replacing the manual
        // QueryInterface(iid, (void**)&out) dance. The IID is named at the call site (iidof needs a
        // concrete type). The OS accepting the derived PIID and the value reading back prove the QI
        // landed a live IReference<int> in the holder.
        ComPtr<IReference<int>> refInt = default;
        i32 qi = refInt.tryAs(boxed, iidof(IReference<int>));
        result &= Test("comptr_qi_accepted", (qi == 0 && refInt.valid()) ? 1 : 0, 1);
        if (qi == 0 && refInt.valid())
        {
            int value = default;
            refInt.get()->get_Value(&value);
            boxedValue = value;
        }

        // reset() releases the held ref early and empties the holder; valid() must be false and the
        // end-of-scope dtor becomes a no-op (one Release total - asan would flag a double-release).
        refInt.reset();
        result &= Test("comptr_reset_clears", refInt.valid() ? 1 : 0, 0);

        ((IReference<int>*)boxed)->lpVtbl->Release(boxed);
    }   // factory releases exactly once here; refInt was already reset.

    result &= Test("comptr_ref_value", boxedValue, 7777);
    return result;
}

extern int main()
{
    winrtInit();   // RO_INIT_MULTITHREADED

    int passed = 0;
    int total  = 0;

    total++; passed += testWString()                    ? 1 : 0;
    total++; passed += testWinrtBridge()                ? 1 : 0;
    total++; passed += testIidofByteExact()            ? 1 : 0;
    total++; passed += testLiveParameterizedRoundtrip() ? 1 : 0;
    total++; passed += testUsingAliasOfWinmdGeneric()    ? 1 : 0;
    total++; passed += testForeachCollection()          ? 1 : 0;
    total++; passed += testAsyncRoundtrip()             ? 1 : 0;
    total++; passed += testComPtrRaii()                 ? 1 : 0;

    winrtUninit();

    printf("WinMD consume-side tests: %d/%d passed.\n", passed, total);
    return passed == total ? 0 : 1;
}
