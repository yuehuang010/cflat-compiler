import "test_helper.cb";
import "list.cb";
import "channel.cb";

// === Interfaces ===

interface IShape
{
    int area();
};

interface IDrawable : IShape
{
    void draw();
};

interface IReader
{
    string read();
};

interface IWriter
{
    void write(string text);
};

// === Concrete classes ===

class Circle : IDrawable
{
    int r = 0;
    int area() { return r * r * 3; }
    void draw() { printf("Circle r=%d\n", r); }
};

class Square : IShape
{
    int s = 0;
    int area() { return s * s; }
};

class Triangle : IDrawable
{
    int b = 0;
    int area() { return b / 2; }
    void draw() { printf("Triangle b=%d\n", b); }
};

// Captures the last by-value string passed through IWriter.write (Bug 1 regression).
int gLastWriteLen = 0;

class FileStream : IReader, IWriter
{
    int id = 0;

    string read()  { return "data"; }
    void write(string text) { gLastWriteLen = text.length(); }
};

// Destructor side-effect counter for delete-through-interface (Test 15).
int gDelIfaceDtorCount = 0;

interface ICounted { int value(); };

class Counted : ICounted
{
    int v = 0;
    int value() { return v; }
    ~Counted() { gDelIfaceDtorCount = gDelIfaceDtorCount + 1; }
};

move ICounted makeCounted()
{
    Counted* c = new Counted();
    c->v = 7;
    return c;
}

// ── Test 1: VTable dispatch ──────────────────────────────────────────────────
// Interface method calls route to the correct concrete implementation.

bool testVTableDispatch()
{
    bool result = true;

    Circle c;
    c.r = 5;
    IShape sc = c;
    result &= Test("vtable_circle_area",   sc.area(), 75);   // 5*5*3

    Square sq;
    sq.s = 4;
    IShape ss = sq;
    result &= Test("vtable_square_area",   ss.area(), 16);   // 4*4

    Triangle t;
    t.b = 10;
    IShape st = t;
    result &= Test("vtable_triangle_area", st.area(), 5);    // 10/2

    // Heap-allocated - interface holds pointer to heap object
    Circle* hc = new Circle();
    hc.r = 6;
    IShape shc = hc;            // boxing moves ownership of hc into shc
    result &= Test("vtable_heap_circle_area", shc.area(), 108);  // 6*6*3
    delete shc;                 // delete through the owning interface (hc is moved-from)

    return result;
}

// ── Test 2: is operator ──────────────────────────────────────────────────────
// Reports the concrete type behind an interface value.

bool testIsOperator()
{
    bool result = true;

    Circle c;
    c.r = 3;
    IShape sc = c;

    Square sq;
    sq.s = 2;
    IShape ss = sq;

    Triangle t;
    t.b = 4;
    IShape st = t;

    result &= Test("is_circle_true",     sc is Circle,   true);
    result &= Test("is_circle_false_sq", ss is Circle,   false);
    result &= Test("is_square_true",     ss is Square,   true);
    result &= Test("is_square_false_c",  sc is Square,   false);
    result &= Test("is_triangle_true",   st is Triangle, true);
    result &= Test("is_triangle_false",  sc is Triangle, false);

    return result;
}

// ── Test 3: as operator - downcast to concrete struct ────────────────────────
// Returns a non-null pointer on match, null on mismatch.

bool testAsToStruct()
{
    bool result = true;

    Circle c;
    c.r = 7;
    IShape sc = c;

    Circle* cp = sc as Circle;
    result &= Test("as_circle_nonnull",      cp != nullptr, true);
    if (cp != nullptr)
        result &= Test("as_circle_area_via_ptr", cp.r * cp.r * 3, 147);  // 7*7*3

    Square* sp = sc as Square;
    result &= Test("as_circle_as_square_null", sp == nullptr, true);

    Square sq;
    sq.s = 6;
    IShape ss = sq;

    Square* sp2 = ss as Square;
    result &= Test("as_square_nonnull",        sp2 != nullptr, true);
    if (sp2 != nullptr)
        result &= Test("as_square_s_via_ptr",  sp2.s * sp2.s, 36);

    Circle* cp2 = ss as Circle;
    result &= Test("as_square_as_circle_null", cp2 == nullptr, true);

    return result;
}

// ── Test 4: as operator - interface-to-interface cast ────────────────────────
// Casting IShape (Circle) to IDrawable should succeed; calling the inherited
// area() and own draw() on the result should dispatch correctly.

bool testAsToInterface()
{
    bool result = true;

    Circle c;
    c.r = 4;
    IShape sc = c;

    // Circle implements IDrawable - cast must succeed
    IDrawable d = sc as IDrawable;
    result &= Test("as_iface_is_circle",     d is Circle, true);
    result &= Test("as_iface_area_inherited", d.area(),   48);   // 4*4*3

    // Direct assignment from Circle to IDrawable (no intermediate IShape)
    Circle c2;
    c2.r = 3;
    IDrawable d2 = c2;
    result &= Test("direct_assign_to_idrawable", d2.area(), 27);  // 3*3*3
    result &= Test("direct_idrawable_is_circle", d2 is Circle, true);

    // Triangle also implements IDrawable
    Triangle t;
    t.b = 8;
    IDrawable dt = t;
    result &= Test("triangle_as_idrawable_area", dt.area(), 4);   // 8/2
    result &= Test("triangle_idrawable_is_triangle", dt is Triangle, true);

    return result;
}

// ── Test 4b: as operator - box a CONCRETE class pointer into an interface ────
// Regression for the bug where `concretePtr as IFace` was lowered as a runtime
// downcast (assumes an already-boxed source) instead of a box, yielding a null
// fat pointer and crashing on first method call. See internal/issue history.

bool testAsBoxConcretePointerIntoInterface()
{
    bool result = true;

    Circle* cp = new Circle();
    cp.r = 4;

    // The crash repro: `as` from a plain class pointer into an interface must box.
    IDrawable d = cp as IDrawable;
    result &= Test("as_box_ptr_area",  d.area(), 48);   // 4*4*3
    result &= Test("as_box_ptr_is_circle", d is Circle, true);
    d.draw();   // access through the boxed value must not fault

    // Round trip: casting the boxed interface value back to the concrete
    // pointer type must still behave exactly as before (interface source).
    Circle* back = d as Circle;
    result &= Test("as_box_roundtrip_nonnull", back != nullptr, true);
    if (back != nullptr)
        result &= Test("as_box_roundtrip_r", back.r, 4);

    // `is` against a concrete pointer source folds to a compile-time constant.
    result &= Test("concrete_ptr_is_idrawable_true", cp is IDrawable, true);

    Square* sp = new Square();
    sp.s = 5;
    result &= Test("concrete_ptr_is_idrawable_false", sp is IDrawable, false);

    // Concrete source with the SAME concrete target is an identity cast. This used to
    // fall into the downcast path and dereference field 0 as if it were a vtable.
    Circle* self = cp as Circle;
    result &= Test("as_same_concrete_nonnull", self != nullptr, true);
    if (self != nullptr)
    {
        result &= Test("as_same_concrete_field", self.r, 4);
        result &= Test("as_same_concrete_method", self.area(), 48);   // 4*4*3
    }
    result &= Test("concrete_ptr_is_circle_true",  cp is Circle, true);
    result &= Test("concrete_ptr_is_square_false", cp is Square, false);

    delete cp;
    delete sp;
    return result;
}

// ── Test 5: switch on concrete type ─────────────────────────────────────────
// Dispatches to the matching case by runtime concrete type.

bool testSwitchConcreteType()
{
    bool result = true;

    Circle c;
    c.r = 2;
    IShape sc = c;

    Square sq;
    sq.s = 3;
    IShape ss = sq;

    Triangle t;
    t.b = 6;
    IShape st = t;

    int kind = 0;

    switch (sc)
    {
        case Circle:   kind = 1; break;
        case Square:   kind = 2; break;
        case Triangle: kind = 3; break;
        default:       kind = 0; break;
    }
    result &= Test("switch_circle",   kind, 1);

    switch (ss)
    {
        case Circle:   kind = 1; break;
        case Square:   kind = 2; break;
        case Triangle: kind = 3; break;
        default:       kind = 0; break;
    }
    result &= Test("switch_square",   kind, 2);

    switch (st)
    {
        case Circle:   kind = 1; break;
        case Square:   kind = 2; break;
        case Triangle: kind = 3; break;
        default:       kind = 0; break;
    }
    result &= Test("switch_triangle", kind, 3);

    return result;
}

// ── Test 6: switch on interface case ────────────────────────────────────────
// A case can name an interface; any concrete type implementing it matches.

bool testSwitchInterfaceCase()
{
    bool result = true;

    Circle c;
    c.r = 1;
    IShape sc = c;       // Circle implements IDrawable

    Square sq;
    sq.s = 1;
    IShape ss = sq;      // Square does NOT implement IDrawable

    Triangle t;
    t.b = 2;
    IShape st = t;       // Triangle implements IDrawable

    int hit = 0;

    switch (sc)
    {
        case IDrawable: hit = 1; break;
        default:        hit = 0; break;
    }
    result &= Test("switch_iface_circle_matches",   hit, 1);

    switch (ss)
    {
        case IDrawable: hit = 1; break;
        default:        hit = 0; break;
    }
    result &= Test("switch_iface_square_no_match",  hit, 0);

    switch (st)
    {
        case IDrawable: hit = 1; break;
        default:        hit = 0; break;
    }
    result &= Test("switch_iface_triangle_matches", hit, 1);

    return result;
}

// ── Test 7: switch default case ─────────────────────────────────────────────
// When no type case matches, execution goes to default.

bool testSwitchDefault()
{
    bool result = true;

    Square sq;
    sq.s = 5;
    IShape ss = sq;

    int hit = 0;
    switch (ss)
    {
        case Circle:   hit = 1; break;
        case Triangle: hit = 2; break;
        default:       hit = 3; break;
    }
    result &= Test("switch_default_hit", hit, 3);

    // No default: execution falls through to resume block
    hit = 0;
    switch (ss)
    {
        case Circle:   hit = 1; break;
        case Triangle: hit = 2; break;
    }
    result &= Test("switch_no_default_no_match", hit, 0);

    return result;
}

// ── Test 8: multiple interface implementations ───────────────────────────────
// FileStream implements both IReader and IWriter; each interface dispatches
// correctly and `is` works through either interface fat pointer.

bool testMultipleInterfaces()
{
    bool result = true;

    FileStream fs;
    fs.id = 42;

    IReader reader = fs;
    IWriter writer = fs;

    string s = reader.read();
    result &= Test("multi_iface_read",                  s, "data");

    // Regression: chaining a method directly on the result of an interface method that
    // returns a by-value type (string) must resolve. The interface call's result needs a
    // populated return type + struct receiver, else the chained call re-dispatched the
    // stale method name and failed overload resolution.
    result &= Test("multi_iface_read_chain_len",        reader.read().length(), 4);
    result &= Test("multi_iface_read_chain_data",       reader.read().data(), "data");

    // Bug 1 regression: a virtual interface method taking a by-value struct (string)
    // arg used to push a bare ptr where the vtable signature expects %string by value,
    // failing module verification. Both a literal and a named owned string must work.
    writer.write("hello");
    result &= Test("multi_iface_write_byval_literal",   gLastWriteLen, 5);
    string greeting = "hi-" + "there";
    writer.write(greeting);
    result &= Test("multi_iface_write_byval_named",     gLastWriteLen, 8);
    result &= Test("multi_iface_write_named_survives",  greeting.length(), 8);

    result &= Test("multi_iface_is_filestream_reader",  reader is FileStream, true);
    result &= Test("multi_iface_is_filestream_writer",  writer is FileStream, true);

    // Downcast via as from each interface view
    FileStream* rfp = reader as FileStream;
    FileStream* wfp = writer as FileStream;
    result &= Test("multi_iface_as_from_reader_nonnull", rfp != nullptr, true);
    result &= Test("multi_iface_as_from_writer_nonnull", wfp != nullptr, true);
    if (rfp != nullptr)
        result &= Test("multi_iface_field_via_reader_ptr", rfp.id, 42);
    if (wfp != nullptr)
        result &= Test("multi_iface_field_via_writer_ptr", wfp.id, 42);

    // Switch via IReader view
    int kind = 0;
    switch (reader)
    {
        case FileStream: kind = 1; break;
        default:         kind = 0; break;
    }
    result &= Test("multi_iface_switch_reader", kind, 1);

    return result;
}

// ── Test 9: returning an interface value ─────────────────────────────────────
// A function whose declared return type is an interface must produce a correct fat
// pointer (vtable + data), so a method call on the returned value dispatches to the
// concrete implementation. Regression for the interface-return miscompile, where a
// returned concrete pointer was emitted as a bare `ret ptr` (verifier failure) and
// the boxing workaround lost the object/vtable (silent 0 result).

move IShape makeCircleShape(int r)
{
    Circle* c = new Circle();
    c.r = r;
    return c;            // concrete implementer POINTER -> interface fat pointer
}

IShape echoShape(IShape s)
{
    return s;            // already-boxed interface value -> passthrough
}

bool testReturnInterface()
{
    bool result = true;

    // Return a concrete implementer pointer as an interface, then dispatch a method.
    IShape c = makeCircleShape(5);
    result &= Test("return_iface_from_ptr_area",      c.area(),    75);   // 5*5*3
    result &= Test("return_iface_from_ptr_is_circle", c is Circle, true);
    Circle* cp = c as Circle;          // reclaim ownership to free the heap object
    if (cp != nullptr)
        delete cp;

    // Return an already-boxed interface value (passthrough of a parameter).
    Square sq;
    sq.s = 6;
    IShape boxed  = sq;
    IShape passed = echoShape(boxed);
    result &= Test("return_iface_passthrough_area",   passed.area(), 36); // 6*6

    return result;
}

// =============================================================
// list<IInterface> tests
// =============================================================

bool testListInterfaceBasic()
{
    bool result = true;

    list<IShape> shapes;

    Circle c;
    c.r = 5;
    shapes.add(c);

    Square sq;
    sq.s = 4;
    shapes.add(sq);

    result &= Test("count", shapes.count(), 2);
    result &= Test("operator[0]_area", shapes[0].area(), 75);
    result &= Test("operator[1]_area", shapes[1].area(), 16);
    result &= Test("get0_area",        shapes.get(0).area(), 75);
    result &= Test("get1_area",        shapes.get(1).area(), 16);

    return result;
}

bool testListInterfaceIsAs()
{
    bool result = true;

    list<IShape> shapes;

    Circle c;
    c.r = 3;
    shapes.add(c);

    Square sq;
    sq.s = 2;
    shapes.add(sq);

    result &= Test("is_circle",  shapes[0] is Circle, true);
    result &= Test("is_square",  shapes[1] is Square, true);
    result &= Test("not_square", shapes[0] is Square, false);

    Circle* cp = shapes[0] as Circle;
    result &= Test("as_circle_nonnull", cp != nullptr, true);
    if (cp != nullptr)
        result &= Test("as_circle_r", cp.r, 3);

    Square* sp = shapes[1] as Square;
    result &= Test("as_square_nonnull", sp != nullptr, true);
    if (sp != nullptr)
        result &= Test("as_square_s", sp.s, 2);

    return result;
}

bool testListInterfaceForeach()
{
    bool result = true;

    list<IShape> shapes;

    Circle c;  c.r = 5;  shapes.add(c);   // area 75
    Square sq; sq.s = 4; shapes.add(sq);  // area 16
    Triangle t; t.b = 6; shapes.add(t);   // area 3

    int sum = 0;
    for (IShape s in shapes)
        sum += s.area();

    result &= Test("foreach_sum", sum, 94);  // 75+16+3

    int count = 0;
    for (IShape s in shapes)
        count++;

    result &= Test("foreach_count", count, 3);

    return result;
}

bool testListInterfaceSort()
{
    bool result = true;

    list<IShape> shapes;

    Square sq1; sq1.s = 3; shapes.add(sq1);  // area 9
    Square sq2; sq2.s = 1; shapes.add(sq2);  // area 1
    Circle c;   c.r  = 2; shapes.add(c);     // area 12

    shapes.sort((IShape a, IShape b) => { return a.area() < b.area(); });

    result &= Test("sort0_area", shapes[0].area(), 1);
    result &= Test("sort1_area", shapes[1].area(), 9);
    result &= Test("sort2_area", shapes[2].area(), 12);

    return result;
}

// =============================================================
// channel<IInterface> tests
// =============================================================

bool testChannelInterface()
{
    channel<IShape> ch;
    ch.init(4);

    Circle c;
    c.r = 5;
    ch.send(c);

    Square sq;
    sq.s = 4;
    ch.send(sq);

    IShape s0 = ch.receive();
    IShape s1 = ch.receive();

    int a0 = s0.area();
    int a1 = s1.area();

    ch.destroy();
    return a0 == 75 && a1 == 16;
}

// ── Test 15: delete through an interface fat pointer ─────────────────────────
// 'delete <interfaceValue>' must virtually destruct the concrete object EXACTLY
// once and free it once - for both a same-scope boxed local (which must transfer
// ownership away from the source so it does not also free) and a factory-returned
// interface. The destructor counter proves single destruction per delete.
bool testDeleteThroughInterface()
{
    gDelIfaceDtorCount = 0;

    // Same-scope boxed local: 'ICounted e = c;' transfers ownership of 'c' into 'e'.
    Counted* c = new Counted();
    c->v = 3;
    ICounted e = c;
    int got1 = e.value();
    delete e;                       // exactly one destruction, one free
    bool boxedOk = (got1 == 3) && (gDelIfaceDtorCount == 1);

    // Factory-returned interface value.
    ICounted f = makeCounted();
    int got2 = f.value();
    delete f;                       // second destruction
    bool factoryOk = (got2 == 7) && (gDelIfaceDtorCount == 2);

    return boxedOk && factoryOk;
}

// Frees a `move` interface param: ownership must transfer into the function so
// 'delete x' is permitted (not rejected as a borrow) and frees exactly once.
void freeMovedInterface(move ICounted x)
{
    delete x;
}

// ── Test 16: move interface parameter takes ownership ────────────────────────
// 'move <Interface> x' must transfer ownership into the callee so 'delete x' in
// the body is allowed and frees the concrete object EXACTLY once - mirroring the
// behaviour of a 'move T*' pointer parameter.
bool testMoveInterfaceParam()
{
    gDelIfaceDtorCount = 0;

    Counted* c = new Counted();
    c->v = 9;
    ICounted a = c;
    freeMovedInterface(a);          // ownership moves in; exactly one destruction, one free

    return gDelIfaceDtorCount == 1;
}

// Closure-owning node for the move-return regression: its destructor counts
// destructions so we can prove the concrete object (and the function<> env it
// owns) is destructed exactly once - no double-free, no leak.
int gNodeDtorCount = 0;

interface INode { int kind(); };

class ClosureNode : INode
{
    Lambda<void()> cb = default;
    int k = 0;
    int kind() { return k; }
    ~ClosureNode() { gNodeDtorCount = gNodeDtorCount + 1; }
};

move INode makeNode(int k)
{
    ClosureNode* n = new ClosureNode();
    n->k = k;
    n->cb = () => { };
    return n;
}

void dropNode(move INode n) { delete n; }

struct NodePatch { int v = 0; };
NodePatch makeNodePatch(int v) { NodePatch p = default; p.v = v; return p; }

// Move-return of a closure-owning interface AFTER an intervening call (list.add).
// Ownership of the concrete node (and its function<> env) must transfer to the
// caller through the move-return; it must not be cloned or freed here.
move INode reconcileReplace(move INode drop, move INode keep, list<NodePatch>* patches)
{
    patches.add(makeNodePatch(keep.kind()));
    dropNode(drop);
    return keep;
}

// ── Test 17: move-return of a closure-owning interface after an intervening call ──
// Regression for the UI reconciler's replace shape: an intervening call before a
// move-return must not perturb ownership of a closure-bearing interface value.
// 'drop' is deleted inside, 'keep' is move-returned and deleted by the caller -
// each concrete node (with its function<> env) destructed exactly once.
bool testMoveReturnClosureInterface()
{
    gNodeDtorCount = 0;
    INode a = makeNode(1);
    INode b = makeNode(2);
    list<NodePatch> patches;
    a = reconcileReplace(a, b, &patches);   // deletes original 'a', returns 'b'
    dropNode(a);                            // caller frees the returned node once
    return gNodeDtorCount == 2;
}

// =============================================================
// String + interface coverage
// Exercises owned strings flowing through: inherited interface chains,
// interface values held in containers, owned string FIELDS dispatched via
// an interface, and an interface-typed FIELD inside a class.
// =============================================================

// A base interface declares a string-returning method; the child interface
// inherits it and adds its own. A concrete class backs both with OWNED string
// fields. The inherited name() must dispatch correctly through BOTH the child
// and the parent fat pointer, and every returned owned string must be correct
// and freed exactly once.

interface INamed
{
    string name();
};

interface IDescribed : INamed
{
    string describe();
};

int gAnimalDtorCount = 0;

class Animal : IDescribed
{
    string nm = default;
    string species = default;
    string name()     { return nm; }                          // owned copy of field
    string describe() { return name() + " the " + species; }  // chains inherited method
    ~Animal() { gAnimalDtorCount = gAnimalDtorCount + 1; }
};

// ── Test 18: owned strings through an inherited interface chain ──────────────
bool testStringInheritedInterfaceChain()
{
    bool result = true;
    gAnimalDtorCount = 0;

    Animal a;
    a.nm = "Rex";
    a.species = "dog";

    // Dispatch through the CHILD interface view.
    IDescribed d = a;
    result &= Test("inh_child_name",      d.name(),     "Rex");
    result &= Test("inh_child_describe",  d.describe(), "Rex the dog");

    // Dispatch the inherited name() through the PARENT interface view.
    INamed n = a;
    result &= Test("inh_parent_name",     n.name(),     "Rex");

    // Cast a child interface value UP to the parent interface, then dispatch
    // the inherited string method through the parent fat pointer.
    IDescribed d2 = a;
    INamed n2 = d2 as INamed;
    result &= Test("inh_cast_up_nonnull", n2 is Animal, true);
    result &= Test("inh_cast_up_name",    n2.name(),    "Rex");

    // Heap object boxed into the interface; delete frees the concrete (and its
    // owned string fields) exactly once.
    Animal* ha = new Animal();
    ha.nm = "Mimi";
    ha.species = "cat";
    IDescribed hd = ha;
    result &= Test("inh_heap_describe",   hd.describe(), "Mimi the cat");
    delete hd;
    result &= Test("inh_heap_dtor_once",  gAnimalDtorCount, 1);

    return result;
}

// ── Test 19: list<Interface> of string-returning interface values ────────────
bool testStringInterfaceList()
{
    bool result = true;

    list<INamed> names;

    Animal a1; a1.nm = "Ann";  a1.species = "x"; names.add(a1);
    Animal a2; a2.nm = "Bob";  a2.species = "y"; names.add(a2);
    Animal a3; a3.nm = "Cara"; a3.species = "z"; names.add(a3);

    result &= Test("list_iface_str_count", names.count(),   3);
    result &= Test("list_iface_str_get0",  names[0].name(), "Ann");
    result &= Test("list_iface_str_get2",  names[2].name(), "Cara");

    // Accumulate every interface-dispatched owned string in a foreach. Each
    // reassignment of 'joined' must free the previous owned buffer (no leak).
    string joined = "";
    for (INamed nm in names)
        joined = joined + nm.name() + ",";
    result &= Test("list_iface_str_joined", joined, "Ann,Bob,Cara,");

    return result;
}

// ── Test 20: channel<Interface> carrying string-returning interface values ───
bool testStringInterfaceChannel()
{
    bool result = true;

    channel<INamed> ch;
    ch.init(4);

    Animal a1; a1.nm = "Sky"; a1.species = "q"; ch.send(a1);
    Animal a2; a2.nm = "Sea"; a2.species = "w"; ch.send(a2);

    INamed r0 = ch.receive();
    INamed r1 = ch.receive();

    result &= Test("chan_iface_str_recv0", r0.name(), "Sky");
    result &= Test("chan_iface_str_recv1", r1.name(), "Sea");

    ch.destroy();
    return result;
}

// An owned string field mutated through an interface: setLabel reassigns the
// owned field (old buffer must be freed), label() returns an owned copy.
interface IBox
{
    string label();
    void setLabel(string s);
};

int gLabelBoxDtorCount = 0;

class LabelBox : IBox
{
    string lbl = default;
    string label()          { return lbl; }
    void setLabel(string s) { lbl = s; }
    ~LabelBox() { gLabelBoxDtorCount = gLabelBoxDtorCount + 1; }
};

// ── Test 21: owned string field read/mutated through an interface ────────────
bool testStringFieldThroughInterface()
{
    bool result = true;
    gLabelBoxDtorCount = 0;

    LabelBox* b = new LabelBox();
    b.lbl = "initial";
    IBox box = b;

    result &= Test("field_iface_initial",    box.label(), "initial");

    // Store an owned interpolated string through the interface; old field freed.
    int count = 7;
    box.setLabel("count={count}");
    result &= Test("field_iface_after_set",  box.label(), "count=7");

    // Reassign again - exercises the owned-field reassignment path via vtable.
    box.setLabel("final");
    result &= Test("field_iface_reassigned", box.label(), "final");

    // label() returns a BORROW of the field, so an independent snapshot needs
    // an explicit `.copy()`. The copy must survive a LATER store to the field
    // (without .copy() the snapshot would alias the field buffer, which is then
    // freed by the next setLabel - the original borrow-into-local dangle).
    string snapshot = box.label().copy();
    box.setLabel("changed");
    result &= Test("field_iface_snapshot_survives", snapshot,    "final");
    result &= Test("field_iface_current",           box.label(), "changed");

    delete box;
    result &= Test("field_iface_dtor_once", gLabelBoxDtorCount, 1);

    return result;
}

int gMovedLabelLen = 0;

// Consumes a moved interface owning a string field: the field is readable in
// the callee, and delete frees the concrete (and its string) exactly once.
void consumeBox(move IBox b)
{
    gMovedLabelLen = b.label().length();
    delete b;
}

// ── Test 22: move an interface owning a string field into a callee ───────────
bool testStringFieldMoveInterface()
{
    bool result = true;
    gLabelBoxDtorCount = 0;

    LabelBox* b = new LabelBox();
    b.lbl = "greetings";
    IBox box = b;
    consumeBox(box);                       // ownership moves in
    result &= Test("field_move_label_len",  gMovedLabelLen, 9);
    result &= Test("field_move_dtor_once",  gLabelBoxDtorCount, 1);

    return result;
}

// An interface-typed FIELD inside a class. The field is a borrow (assigning a
// concrete into it does NOT transfer ownership); the outer class dispatches a
// string method through the stored interface value.
class Container : INamed
{
    IDescribed inner = default;
    string tag = default;
    string name() { return tag + ":" + inner.name(); }
};

// ── Test 23: interface-typed field dispatching owned strings ─────────────────
bool testInterfaceFieldString()
{
    bool result = true;
    gAnimalDtorCount = 0;

    Animal* a = new Animal();
    a.nm = "Leo";
    a.species = "lion";

    Container* c = new Container();
    c.tag = "zoo";
    c.inner = a;                           // borrow: 'a' still owns the Animal

    // Dispatch the inherited / child string methods through the interface field.
    result &= Test("iface_field_inner_name",     c.inner.name(),     "Leo");
    result &= Test("iface_field_inner_describe", c.inner.describe(), "Leo the lion");
    // The outer method combines an owned field string with a field-dispatched one.
    result &= Test("iface_field_outer_name",     c.name(),           "zoo:Leo");

    // Box the outer object into an interface too - dispatch through two layers.
    // Boxing a heap pointer into a local interface transfers ownership of 'c'.
    INamed outer = c;
    result &= Test("iface_field_outer_via_iface", outer.name(),      "zoo:Leo");

    delete outer;                          // frees the Container (and its tag) once
    delete a;                              // frees the borrowed Animal once
    result &= Test("iface_field_inner_dtor_once", gAnimalDtorCount, 1);

    return result;
}

// A class that is an OWNING value type (has a string field) bound to an interface
// slot BY VALUE (stack instance, not `new`). Regression for the interface-bind
// owning-value zeroing bug: binding used to MOVE-zero the aliased source, so reads
// through the interface (and the source) returned default field values. The bind is
// a borrow of the source storage - the source keeps ownership and stays intact.
interface IStackBox
{
    int getV();
    string getName();
};

class StackBox : IStackBox
{
    int v = 40;
    string name = default;
    int getV()       { return this.v; }
    string getName() { return "" + this.name; }
};

IStackBox gStackBox = default;

// ── Test 24: owning-value class bound to an interface slot by value ───────────
bool testStackOwningValueBoxedToInterface()
{
    bool result = true;

    // Assignment form (`_g = c`): global interface slot bound to a stack value.
    StackBox c;
    c.v = 41;
    c.name = "hel" + c.v.toString();           // owned heap buffer, not a literal
    gStackBox = c;                             // bind by value (borrow of c)
    result &= Test("stackbox_assign_v",     gStackBox.getV(),        41);
    result &= Test("stackbox_assign_name",  gStackBox.getName(),     "hel41");
    result &= Test("stackbox_src_v",        c.v,                     41);
    result &= Test("stackbox_src_name",     c.name,                  "hel41");

    // Declaration-init form (`I x = c`): local interface slot bound to a stack value.
    StackBox d;
    d.v = 42;
    d.name = "nm" + d.v.toString();
    IStackBox ix = d;
    result &= Test("stackbox_decl_v",       ix.getV(),               42);
    result &= Test("stackbox_decl_name",    ix.getName(),            "nm42");
    result &= Test("stackbox_decl_src",     d.name,                  "nm42");

    return result;
}

// ── Test 25: downcast of a call result is a BORROW, not an owner ──────────────
// Regression: `T* d = someCall() as U;` where the operand is a function-call
// result (r-value) must yield a BORROW. A stale new/move owning flag left by a
// prior statement (e.g. `list.add(new U())`) used to leak into this declaration,
// so `d` was tracked as owning and auto-deleted at scope exit - double-freeing
// the object the list still owns (and freeing a live object each closure return).
int gDcDtorCount = 0;

interface IPokable { int poke(); };

class Pokable : IPokable
{
    int v = 0;
    int poke() { return v; }
    ~Pokable() { gDcDtorCount = gDcDtorCount + 1; }
};

list<IPokable> _dcZoo = default;

alias IPokable dcActive() { return _dcZoo.get(0); }

bool testDowncastCallResultBorrow()
{
    bool result = true;
    gDcDtorCount = 0;

    _dcZoo.add(new Pokable());   // the list is the sole owner of this heap object

    {
        // Downcast of a CALL RESULT (r-value) - must be a BORROW, not owning.
        Pokable* d = dcActive() as Pokable;
        d.v = 7;
        result &= Test("dc_mutate_via_ptr", d.v, 7);

        // Closure variant: each call downcasts the same call result. Before the fix
        // the inner `p` was owning and freed the live object at the closure's return.
        Lambda<void()> bump = () => { Pokable* p = dcActive() as Pokable; p.v = p.v + 1; };
        bump();
        bump();
        result &= Test("dc_closure_bumped_twice", d.v, 9);
    }
    // `d` (and the closure's inner downcasts) are out of scope. A borrow must NOT
    // have freed the object - the list still owns it. Before the fix, `d`'s scope-exit
    // delete freed it here, so the dtor count would already be 1 and the object dead.
    result &= Test("dc_borrow_did_not_free", gDcDtorCount, 0);
    result &= Test("dc_object_still_live",   dcActive().poke(), 9);

    // The real owner frees the heap object exactly once.
    IPokable owned = _dcZoo.take(0);
    delete owned;
    result &= Test("dc_owner_frees_once", gDcDtorCount, 1);

    return result;
}

// ── Tests 26-28: interface FIELDS (byte-offset vtable slots) ─────────────────
// A 3-level interface chain that introduces a field at EVERY level, so a field
// read through the interface must index the flattened [grandparent, parent, own]
// field list. Two implementors lay their fields out DIFFERENTLY on purpose - a
// fixed offset could not pass these; only the per-implementor offset slot can.
struct WBox
{
    int w = 0;
    int h = 0;
};

interface IWidget
{
    int kind();
    int  tag;
    WBox box;
};

interface ITipped : IWidget
{
    string tip;
};

interface IPress : ITipped
{
    int clicks();
    string label;
};

int gWidgetDtorCount = 0;

class Pressy : IPress
{
    int pad = 7;               // pushes every field off a "natural" offset
    int tag = 0;
    WBox box = default;
    string tip = default;
    string label = default;
    int nclicks = 0;
    int kind()   { return 1; }
    int clicks() { return nclicks; }
    ~Pressy() { gWidgetDtorCount = gWidgetDtorCount + 1; }
};

class Toggly : IPress
{
    string label = default;    // deliberately the reverse layout of Pressy
    i64 pad2 = 0;
    string tip = default;
    WBox box = default;
    int nclicks = 0;
    int tag = 0;
    int kind()   { return 2; }
    int clicks() { return nclicks + 100; }
    ~Toggly() { gWidgetDtorCount = gWidgetDtorCount + 1; }
};

class Plain : IWidget          // implements the ROOT interface only
{
    WBox box = default;
    int tag = 0;
    int kind() { return 3; }
    ~Plain() { gWidgetDtorCount = gWidgetDtorCount + 1; }
};

// A global list keeps this test focused on the upcast itself. The LOCAL-list form
// (take + delete at scope exit) is covered by testLocalListInterfaceTakeDelete.
list<IWidget> _wzoo = default;

// Call-argument upcast: a derived-interface value binds an ancestor-interface param.
int widgetTag(IWidget w)  { return w.tag; }
int widgetKind(IWidget w) { return w.kind(); }

// Return-position upcast: IPress local returned from an IWidget-returning function.
move IWidget makePressy(int t)
{
    Pressy* p = new Pressy();
    p.tag   = t;
    p.tip   = "tip";
    p.label = "Go";
    IPress ip = p;
    return ip;
}

// ── Test 26: read/write interface fields across a 3-level chain ──────────────
bool testInterfaceFieldAccess()
{
    bool result = true;
    gWidgetDtorCount = 0;

    Pressy* p = new Pressy();
    p.tag = 1; p.tip = "pt"; p.label = "Go";   p.nclicks = 3;
    Toggly* t = new Toggly();
    t.tag = 2; t.tip = "tt"; t.label = "Flip"; t.nclicks = 9;

    IPress ip = p;                             // heap pointer moves into the interface
    IPress it = t;

    // Read a field declared at each level of the chain, on both layouts.
    result &= Test("ifld_own_a",     ip.label, "Go");
    result &= Test("ifld_own_b",     it.label, "Flip");
    result &= Test("ifld_parent_a",  ip.tip,   "pt");
    result &= Test("ifld_parent_b",  it.tip,   "tt");
    result &= Test("ifld_grand_a",   ip.tag,   1);
    result &= Test("ifld_grand_b",   it.tag,   2);
    // Methods still dispatch (fields do not disturb the method slots).
    result &= Test("ifld_method_a",  ip.clicks(), 3);
    result &= Test("ifld_method_b",  it.clicks(), 109);

    // Write through the interface: int, owned string, and a NESTED struct field.
    ip.tag = 11;
    it.tip = "z" + "z!";                       // owned buffer; the old one must be freed
    ip.box.w = 5;
    it.box.h = 6;
    result &= Test("ifld_write_int",      ip.tag,   11);
    result &= Test("ifld_write_string",   it.tip,   "zz!");
    result &= Test("ifld_write_nested_a", ip.box.w, 5);
    result &= Test("ifld_write_nested_b", it.box.h, 6);
    // The write landed in the concrete object, at that object's own offset.
    result &= Test("ifld_write_seen_by_iface", it.kind(), 2);

    delete ip;
    delete it;
    result &= Test("ifld_dtor_once", gWidgetDtorCount, 2);

    return result;
}

// --- Test 29: boxing an owning POINTER local into a `move` interface param ---
// Regression (heap corruption): passing an owning `T*` local to a `move IFace`
// parameter (e.g. `list<IFace>.add`) boxes it into a fat pointer and hands
// ownership to the callee. The source local used to keep its owning flag, so its
// scope-exit cleanup freed the object the list still held - then `delete` on the
// taken-out element freed it again (double free -> STATUS_HEAP_CORRUPTION at exit).
// The dtor counters below catch the double free deterministically; the heap
// corruption itself shows up as a non-zero process exit code.
int gBoxDtorCount = 0;

interface IBoxed { int value(); };

class Boxed : IBoxed
{
    int v = 0;
    int value() { return v; }
    ~Boxed() { gBoxDtorCount = gBoxDtorCount + 1; }
};

// The UI-tree shape: the list is a CLASS FIELD, elements are handed in through a
// `move IFace` parameter, then deleted one by one and the list is cleared.
class BoxHolder
{
    list<IBoxed> children = default;

    void addChild(move IBoxed c)
    {
        this.children.add(c);
    }

    int sum()
    {
        int total = 0;
        for (IBoxed c in this.children)
            total += c.value();
        return total;
    }

    void destroyTree()
    {
        for (IBoxed c in this.children)
            delete c;
        this.children.clear();
    }
};

bool testLocalListInterfaceTakeDelete()
{
    bool result = true;
    gBoxDtorCount = 0;

    {
        list<IBoxed> zoo = default;      // LOCAL list - its buffer is freed at scope exit

        Boxed* named = new Boxed();      // owning local, boxed into the list on add
        named->v = 7;
        zoo.add(named);
        zoo.add(new Boxed());            // temporary form

        result &= Test("localbox_count",      zoo.count(),      2);
        result &= Test("localbox_elem0",      zoo[0].value(),   7);
        // The list owns the objects now - the moved-from local must not have freed one.
        result &= Test("localbox_no_early_dtor", gBoxDtorCount, 0);

        IBoxed first = zoo.take(0);
        delete first;
        result &= Test("localbox_dtor_after_first", gBoxDtorCount, 1);

        IBoxed second = zoo.take(0);
        delete second;
        result &= Test("localbox_dtor_after_second", gBoxDtorCount, 2);
        result &= Test("localbox_empty", zoo.count(), 0);
    }
    // The local list's own destructor ran here (buffer freed). A double free of an
    // element would already have corrupted the heap; the count must still be exactly 2.
    result &= Test("localbox_dtor_total", gBoxDtorCount, 2);

    return result;
}

// ── Test 27: `is <Interface>`, null-compare, and derived -> parent upcast ────
bool testInterfaceIsNullUpcast()
{
    bool result = true;
    gWidgetDtorCount = 0;

    Pressy* p = new Pressy();
    p.tag = 4; p.tip = "pt"; p.label = "Go";
    IPress ip = p;
    Plain* pl = new Plain();
    pl.tag = 5;
    IWidget iw = pl;

    // `x is <Interface>`: true for an implementor, false for a non-implementor.
    result &= Test("iface_is_self",    ip is IPress,   true);
    result &= Test("iface_is_ancestor", ip is IWidget, true);   // two levels up
    result &= Test("iface_is_false",   iw is IPress,   false);

    // `as <Interface>` hit/miss, tested with a null-compare on the fat pointer.
    IPress hit  = ip as IPress;
    IPress miss = iw as IPress;
    result &= Test("iface_null_hit",       hit  != nullptr, true);
    result &= Test("iface_null_miss",      miss != nullptr, false);
    result &= Test("iface_null_miss_eq",   miss == nullptr, true);
    result &= Test("iface_null_hit_field", hit.label,       "Go");

    // Upcast (derived -> parent/grandparent) in every position.
    IWidget upAssign = ip;                                    // assignment
    result &= Test("iface_up_assign",  upAssign.tag,  4);
    result &= Test("iface_up_arg",     widgetTag(ip), 4);     // call argument
    result &= Test("iface_up_arg_kind", widgetKind(ip), 1);
    ITipped upMid = ip;                                       // one level, not two
    result &= Test("iface_up_mid",     upMid.tip, "pt");

    IWidget upRet = makePressy(6);                            // return position
    result &= Test("iface_up_return",      upRet.tag,  6);
    result &= Test("iface_up_return_kind", upRet.kind(), 1);

    _wzoo.add(ip);                                            // list<IParent>.add
    _wzoo.add(upRet);
    _wzoo.add(iw);
    int sum = 0;
    for (int i = 0; i < _wzoo.count(); i++)
    {
        IWidget w = _wzoo.get(i);
        sum = sum + w.tag * 10 + w.kind();
    }
    result &= Test("iface_up_list", sum, 155);   // 41 + 61 + 53

    while (_wzoo.count() > 0)
    {
        IWidget w = _wzoo.take(0);
        delete w;                                // dtor runs exactly once each
    }
    result &= Test("iface_up_list_dtor_once", gWidgetDtorCount, 3);

    return result;
}

// --- Test 30: same boxing shape across a list _grow (buffer realloc) ---
bool testLocalListInterfaceGrowTakeDelete()
{
    bool result = true;
    gBoxDtorCount = 0;

    {
        list<IBoxed> zoo = default;
        int i = 0;
        while (i < 6)                    // > 4: forces _grow (buffer realloc)
        {
            Boxed* b = new Boxed();
            b->v = i;
            zoo.add(b);
            i++;
        }
        result &= Test("growbox_count",         zoo.count(),   6);
        result &= Test("growbox_no_early_dtor", gBoxDtorCount, 0);

        int sum = 0;
        while (zoo.count() > 0)
        {
            IBoxed it = zoo.take(0);
            sum += it.value();
            delete it;
        }
        result &= Test("growbox_sum",  sum,           15);   // 0+1+2+3+4+5
        result &= Test("growbox_dtors", gBoxDtorCount, 6);
    }
    result &= Test("growbox_dtor_total", gBoxDtorCount, 6);

    return result;
}

// A GENERIC interface with a field: the field's type is the substituted argument.
interface IHolder<T>
{
    int kind();
    T value;
};

class IntHolder : IHolder<int>
{
    int pad = 3;
    int value = 0;
    int kind() { return 1; }
};

class WideHolder : IHolder<int>
{
    int value = 0;
    i64 pad = 0;
    int kind() { return 2; }
};

// ── Test 28: fields on a GENERIC interface ──────────────────────────────────
bool testGenericInterfaceField()
{
    bool result = true;

    IntHolder* a = new IntHolder();
    a.value = 11;
    WideHolder* b = new WideHolder();
    b.value = 22;

    IHolder<int> ia = a;
    IHolder<int> ib = b;
    result &= Test("gen_ifld_read_a",  ia.value, 11);
    result &= Test("gen_ifld_read_b",  ib.value, 22);
    ia.value = 33;
    result &= Test("gen_ifld_write_a", ia.value, 33);
    result &= Test("gen_ifld_method",  ia.kind() * 10 + ib.kind(), 12);

    delete ia;
    delete ib;

    return result;
}

// --- Test 31: the UI-tree shape - list<IFace> as a CLASS FIELD, filled via `move` ---
bool testFieldListInterfaceTeardown()
{
    bool result = true;
    gBoxDtorCount = 0;

    {
        // Field list on a STACK-allocated holder (the field's list dtor runs at scope exit).
        BoxHolder h;
        Boxed* a = new Boxed();
        a->v = 3;
        h.addChild(a);
        h.addChild(new Boxed());

        result &= Test("fieldbox_sum",           h.sum(),       3);
        result &= Test("fieldbox_no_early_dtor", gBoxDtorCount, 0);

        h.destroyTree();                 // iterate, delete each, clear
        result &= Test("fieldbox_dtors_after_teardown", gBoxDtorCount, 2);
        result &= Test("fieldbox_empty",                h.children.count(), 0);
    }
    result &= Test("fieldbox_dtor_total", gBoxDtorCount, 2);

    // Same shape on a HEAP-allocated holder (the UI tree's actual layout).
    gBoxDtorCount = 0;
    BoxHolder* hp = new BoxHolder();
    Boxed* b = new Boxed();
    b->v = 5;
    hp->addChild(b);
    result &= Test("fieldbox_heap_sum", hp->sum(), 5);
    hp->destroyTree();
    result &= Test("fieldbox_heap_dtors", gBoxDtorCount, 1);
    delete hp;
    result &= Test("fieldbox_heap_dtor_total", gBoxDtorCount, 1);

    return result;
}

// --- Test 32: a `move` parameter on an INTERFACE method (virtual dispatch) ---
// Regression: the virtual-dispatch call path had no move-param source-nulling at all,
// so an owning local boxed into a `move` param kept its owning flag and was freed a
// second time at the caller's scope exit (STATUS_HEAP_CORRUPTION at process exit).
interface IBoxSink
{
    void take(move IBoxed c);
    int  total();
    void drain();
};

class BoxSink : IBoxSink
{
    list<IBoxed> items = default;

    void take(move IBoxed c) { this.items.add(c); }

    int total()
    {
        int t = 0;
        for (IBoxed i in this.items)
            t += i.value();
        return t;
    }

    void drain()
    {
        for (IBoxed i in this.items)
            delete i;
        this.items.clear();
    }
};

bool testMoveParamThroughInterfaceMethod()
{
    bool result = true;
    gBoxDtorCount = 0;

    BoxSink* bs = new BoxSink();
    IBoxSink sink = bs;

    {
        Boxed* p = new Boxed();      // owning local
        p->v = 41;
        sink.take(p);                // virtual dispatch, `move IBoxed` param
        // `p` is moved-from here; reading it is a compile-time error.
    }
    // The caller's source was nulled, so `p`'s scope exit did NOT free the object the
    // sink now owns. Without the nulling this is already 1 (and the heap is corrupt).
    result &= Test("movevirt_source_nulled", gBoxDtorCount, 0);
    result &= Test("movevirt_callee_owns",   sink.total(),  41);

    sink.drain();                    // the real owner frees it - exactly once
    result &= Test("movevirt_dtor_once", gBoxDtorCount, 1);

    delete sink;
    result &= Test("movevirt_dtor_total", gBoxDtorCount, 1);

    return result;
}

// --- Test 33: interface values across the two arg paths the direct path already had ---
// Three regressions, all "the direct-call path did it, the other path did not":
//   a) a function<>/Lambda parameter typed as an INTERFACE got the raw class value (invalid IR).
//   b) a lambda LITERAL passed to an INTERFACE METHOD had no expected signature, so its
//      return type defaulted to void and its `ret i1` failed module verification.
//   c) an owned-string call result passed as a borrow argument of an INTERFACE METHOD was
//      never registered as a temp, so its buffer leaked (proven under --heap-audit).
interface ICase
{
    string label(int n);
    void record(string name, string got);
    bool runUntil(Lambda<bool()> pred);
    int hits();
};

class Case : ICase
{
    int n = 0;
    string label(int i) { return "row" + i.toString(); }
    void record(string name, string got) { if (got.length() > 0) this.n = this.n + 1; }
    bool runUntil(Lambda<bool()> pred) { return pred(); }
    int hits() { return this.n; }
};

class CaseHolder
{
    function<void(ICase)> body = default;   // an INTERFACE-typed function-pointer param
};

bool testInterfaceArgPaths()
{
    bool result = true;

    // (a) the case body is invoked through a function<> field with a CLASS VALUE argument;
    // the indirect-call path must box it into the fat pointer the callee expects.
    CaseHolder* h = new CaseHolder();
    h.body = (ICase c) =>
    {
        // (c) label() hands back an owned string that record() only borrows.
        c.record("first",  c.label(1));
        c.record("second", c.label(2));
        // (b) a lambda literal argument to an interface method - Lambda<bool()>, not void().
        c.record("third",  c.runUntil(() => c.hits() == 2) ? c.label(3) : "");
    };

    Case t = default;
    h.body(t);
    result &= Test("ifacearg_value_boxed", t.hits(), 3);

    // The same body, invoked with a class POINTER argument (the other boxing branch).
    Case* p = new Case();
    h.body(p);
    result &= Test("ifacearg_ptr_boxed", p.hits(), 3);

    delete p;
    delete h;
    return result;
}

// --- Test 34: an AGREEING ownership contract still binds and still transfers ---
// The companion to the err_iface_method_* tests: the implementor matches the interface on
// every ownership qualifier, so the vtable binds and each qualifier keeps its meaning
// through dynamic dispatch. `move` param -> callee owns; `move` return -> caller owns;
// `alias` return -> caller borrows and must not free.
int gOwnDtorCount = 0;

struct Owned
{
    int v = 0;
    ~Owned() { gOwnDtorCount++; }
};

interface IOwnerBox
{
    void put(move Owned* o);      // ownership transferred to the box
    move Owned* release();         // ownership transferred back to the caller
    alias Owned* peek();           // borrow - the box keeps ownership
};

class OwnerBox : IOwnerBox
{
    Owned* held = nullptr;

    void put(move Owned* o)
    {
        if (held != nullptr) delete held;
        held = o;
    }

    move Owned* release()
    {
        Owned* out = move held;   // `move` out of the field: the box stops owning it
        return out;
    }

    alias Owned* peek() { return held; }

    ~OwnerBox() { if (held != nullptr) delete held; }
};

bool testInterfaceMethodOwnershipContract()
{
    bool result = true;
    gOwnDtorCount = 0;

    OwnerBox* obp = new OwnerBox();
    IOwnerBox box = obp;

    {
        Owned* o = new Owned();
        o->v = 21;
        box.put(move o);            // `move` param: the box takes ownership, caller is nulled
    }
    // The caller's scope exit must NOT free what the box now owns.
    result &= Test("contract_move_param_no_free", gOwnDtorCount, 0);

    {
        Owned* borrowed = box.peek();   // `alias` return: a borrow, not freed at scope exit
        result &= Test("contract_alias_return_value", borrowed->v, 21);
    }
    result &= Test("contract_alias_return_no_free", gOwnDtorCount, 0);

    {
        Owned* taken = box.release();   // `move` return: the caller owns it now
        result &= Test("contract_move_return_value", taken->v, 21);
        delete taken;                    // freed exactly once, by the new owner
    }
    result &= Test("contract_move_return_freed_once", gOwnDtorCount, 1);

    delete box;                          // box is empty - nothing double-freed
    result &= Test("contract_dtor_total", gOwnDtorCount, 1);

    return result;
}

extern int main()
{
    int passed = 0;
    int total  = 0;

    total++; passed += testVTableDispatch()      ? 1 : 0;
    total++; passed += testIsOperator()          ? 1 : 0;
    total++; passed += testAsToStruct()          ? 1 : 0;
    total++; passed += testAsToInterface()       ? 1 : 0;
    total++; passed += testAsBoxConcretePointerIntoInterface() ? 1 : 0;
    total++; passed += testSwitchConcreteType()  ? 1 : 0;
    total++; passed += testSwitchInterfaceCase() ? 1 : 0;
    total++; passed += testSwitchDefault()       ? 1 : 0;
    total++; passed += testMultipleInterfaces()  ? 1 : 0;
    total++; passed += testReturnInterface()     ? 1 : 0;
    total++; passed += testListInterfaceBasic()  ? 1 : 0;
    total++; passed += testListInterfaceIsAs()   ? 1 : 0;
    total++; passed += testListInterfaceForeach() ? 1 : 0;
    total++; passed += testListInterfaceSort()   ? 1 : 0;
    total++; passed += testChannelInterface()    ? 1 : 0;
    total++; passed += testDeleteThroughInterface() ? 1 : 0;
    total++; passed += testMoveInterfaceParam()     ? 1 : 0;
    total++; passed += testMoveReturnClosureInterface() ? 1 : 0;
    total++; passed += testStringInheritedInterfaceChain() ? 1 : 0;
    total++; passed += testStringInterfaceList()         ? 1 : 0;
    total++; passed += testStringInterfaceChannel()      ? 1 : 0;
    total++; passed += testStringFieldThroughInterface() ? 1 : 0;
    total++; passed += testStringFieldMoveInterface()    ? 1 : 0;
    total++; passed += testStackOwningValueBoxedToInterface() ? 1 : 0;
    total++; passed += testInterfaceFieldString()        ? 1 : 0;
    total++; passed += testDowncastCallResultBorrow()    ? 1 : 0;
    total++; passed += testInterfaceFieldAccess()        ? 1 : 0;
    total++; passed += testInterfaceIsNullUpcast()       ? 1 : 0;
    total++; passed += testGenericInterfaceField()       ? 1 : 0;
    total++; passed += testLocalListInterfaceTakeDelete()     ? 1 : 0;
    total++; passed += testLocalListInterfaceGrowTakeDelete() ? 1 : 0;
    total++; passed += testFieldListInterfaceTeardown()       ? 1 : 0;
    total++; passed += testMoveParamThroughInterfaceMethod()  ? 1 : 0;
    total++; passed += testInterfaceArgPaths()                ? 1 : 0;
    total++; passed += testInterfaceMethodOwnershipContract()  ? 1 : 0;

    printf("Interface/is/as tests: %d/%d passed.\n", passed, total);
    return passed == total ? 0 : 1;
}
