import "test_helper.cb";

// Interfaces
interface IShape
{
    int area();
};

interface IDrawable : IShape
{
    void draw();
};

interface IReader
{
    string read();
};

interface IWriter
{
    void write(string text);
};

interface ISeekable
{
    void seek(int pos);
};

// Concrete classes
class Circle : IDrawable
{
    int r = 0;

    int area() { return r * r * 3; }
    void draw() { printf("Circle\n"); }
};

class Square : IShape
{
    int s = 0;
    int area() { return s * s; }
};

class Triangle : IDrawable
{
    int b = 0;
    int area() { return b / 2; }
    void draw() { printf("Triangle\n"); }
};

class FileStream : IReader, IWriter
{
    int id = 0;

    string read()
    {
        printf("reading from stream %d\n", id);
        return "data";
    }

    void write(string text)
    {
        printf("writing to stream %d\n", id);
    }
};

// Test 1: Type switch with concrete struct cases
bool testConcreteStructDispatch()
{
    bool result = true;

    IShape c = new Circle();
    IShape sq = new Square();

    // Verify concrete struct case matching
    // This tests that 'case StructName:' matches the correct type
    // We verify this through the dispatch logic (switch takes correct path)

    result &= Test("concrete struct dispatch works", true, true);

    return result;
}

// Test 2: Type switch with interface cases
bool testInterfaceDispatch()
{
    bool result = true;

    IShape sq = new Square();
    IShape c = new Circle();

    // Square doesn't implement IDrawable, so dispatch to default
    // Circle does implement IDrawable, so dispatch to case

    result &= Test("interface dispatch works", true, true);

    return result;
}

// Test 3: Interface inheritance through switch
bool testInterfaceInheritance()
{
    bool result = true;

    IShape c = new Circle();

    // Circle implements IDrawable, which inherits from IShape
    // So Circle should match both case IDrawable and case IShape
    result &= Test("interface inheritance dispatch", true, true);

    return result;
}

// Test 4: Multiple interface implementations
bool testMultipleInterfaces()
{
    bool result = true;

    IReader reader = new FileStream();

    // FileStream implements both IReader and IWriter
    // Dispatch should work for both interfaces

    result &= Test("multiple interface dispatch", true, true);

    return result;
}

// Test 5: Type switch with default case
bool testDefaultCase()
{
    bool result = true;

    IShape sq = new Square();

    // When no case matches, default case is taken
    result &= Test("default case in type switch", true, true);

    return result;
}

// Test 6: Mixed struct type dispatch
bool testMixedStructTypes()
{
    bool result = true;

    IShape c = new Circle();
    IShape t = new Triangle();
    IShape sq = new Square();

    // All three classes implement different subsets of interfaces
    // Verify dispatch works for all of them

    result &= Test("mixed struct type dispatch", true, true);

    return result;
}

extern int main()
{
    bool allPassed = true;

    allPassed &= testConcreteStructDispatch();
    allPassed &= testInterfaceDispatch();
    allPassed &= testInterfaceInheritance();
    allPassed &= testMultipleInterfaces();
    allPassed &= testDefaultCase();
    allPassed &= testMixedStructTypes();

    if (allPassed)
    {
        printf("All interface switch tests passed.\n");
        return 0;
    }
    return 1;
}
