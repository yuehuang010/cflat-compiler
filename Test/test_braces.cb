extern int main()
{
    // \{ and \} escapes
    const char* s1 = "\{hello\}";
    printf("backslash escape: '%s'\n", s1);

    // {{ and }} folding
    const char* s2 = "{{double braces}}";
    printf("double brace: '%s'\n", s2);

    // mixed: format string with {{ for literal { among real interpolation
    int x = 42;
    string s3 = "value is {{x}} = {x}";
    printf("mixed: '%s'\n", s3.data());

    return 0;
}
