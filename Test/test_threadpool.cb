// Comprehensive test suite for core/threadpool.cb.  This file is the single
// consolidated exercise for the pool - the former main.cb demo has been folded
// in here as ordinary tests.  Run via test.bat, or build/run directly:
//
//   x64/Release/cflat.exe Test/test_threadpool.cb -i Test/library \
//       -o out/test_threadpool.exe && out/test_threadpool.exe

import "threadpool.cb";
import "atomic.cb";
import "cruntime.cb";
import "time.cb";
import "list.cb";
import "program.cb";
import "latch.cb";

// Inline test helpers (mirroring Test/test_helper.cb's bool/int Test() API).
int Test(const char* name, bool actual, bool expected) {
    if (actual == expected) { return 1; }
    printf("%s MISMATCH (expected %d got %d).\n", name, (int)expected, (int)actual);
    return 0;
}

int Test(const char* name, int actual, int expected) {
    if (actual == expected) { return 1; }
    printf("%s FAILED (expected %d got %d).\n", name, expected, actual);
    return 0;
}

// ---------------------------------------------------------------------------
// Task functions and contexts shared across tests
// ---------------------------------------------------------------------------

int taskSquare(void* ctx, stop_token tok) {
    int* p = (int*)ctx;
    *p = (*p) * (*p);
    return 0;
}

int taskNoop(void* ctx, stop_token tok) {
    return 0;
}

int taskFail(void* ctx, stop_token tok) {
    return 7;
}

struct AddCtx {
    atomic_counter* counter = nullptr;
};

int taskIncrement(void* raw, stop_token tok) {
    AddCtx* c = (AddCtx*)raw;
    c->counter->increment();
    return 0;
}

struct CancelCtx {
    atomic_counter iterations = default;
    bool           sawCancel  = false;
};

int taskCancellable(void* raw, stop_token tok) {
    CancelCtx* c = (CancelCtx*)raw;
    while (!tok.stop_requested()) {
        c->iterations.increment();
        SwitchToThread();
    }
    c->sawCancel = true;
    return 0;
}

int taskSlow(void* raw, stop_token tok) {
    // Wall-clock sleep instead of a busy loop so -O2 can't eliminate the work
    // (a pure compute loop with a dead result gets dropped by the optimiser).
    sleep(50);
    return 0;
}

struct IntCtx {
    int              input = 0;
    TaskResult<int>* out   = nullptr;
};

int taskSquareResult(void* raw, stop_token tok) {
    IntCtx* c = (IntCtx*)raw;
    c->out->set(c->input * c->input);
    return 0;
}

int taskFailResult(void* raw, stop_token tok) {
    TaskResult<int>* out = (TaskResult<int>*)raw;
    out->fail();
    return 1;
}

int taskDoubleSet(void* raw, stop_token tok) {
    TaskResult<int>* out = (TaskResult<int>*)raw;
    out->set(11);
    out->set(22);   // second set() must be ignored
    out->fail();    // mixed set/fail also ignored
    return 0;
}

struct ChainCtx {
    int value = 0;
};

int chainStep(void* raw, stop_token tok) {
    ChainCtx* c = (ChainCtx*)raw;
    c->value = c->value + 1;
    return 0;
}

struct DrainFromTaskCtx {
    ThreadPool* pool  = nullptr;
    int         value = 0;
};

int drainInnerTask(void* raw, stop_token tok) {
    int* p = (int*)raw;
    *p = 42;
    return 0;
}

int drainOuterTask(void* raw, stop_token tok) {
    DrainFromTaskCtx* c = (DrainFromTaskCtx*)raw;
    c->pool->submit(drainInnerTask, &c->value, nullptr);
    c->pool->drain();   // would deadlock without work-participation
    return 0;
}

struct PriorityCtx {
    int             priority     = 0;
    int             order        = 0;        // completion order (1-based)
    atomic_counter* orderCounter = nullptr;
    latch*          gate         = nullptr;  // if set, wait on it instead of sleeping
};

int taskPriority(void* raw, stop_token tok) {
    PriorityCtx* c = (PriorityCtx*)raw;
    // testPriorityOrdering hands the "keep-busy" task a latch so it blocks
    // deterministically until the main thread has enqueued the priority batch
    // (sleep-based coordination is unreliable under Windows timer granularity).
    // Other callers leave gate==nullptr and fall back to a wall-clock sleep;
    // a dead compute loop would be deleted by the optimiser under -O2.
    if (c->gate != nullptr) { c->gate.wait(); }
    else                    { sleep(10); }
    c->order = (int)c->orderCounter->increment();
    return 0;
}

// ---------------------------------------------------------------------------
// Tests
// ---------------------------------------------------------------------------

bool testBasicSubmitAndDrain() {
    bool result = true;
    ThreadPool pool;
    pool.init(4);

    int[8] inputs;
    int i = 0;
    while (i < 8) { inputs[i] = i + 1; i++; }

    TaskHandle[8] handles {};
    i = 0;
    while (i < 8) {
        bool accepted = pool.submit(taskSquare, &inputs[i], &handles[i]);
        result &= Test("submit accepted", accepted, true);
        i++;
    }
    pool.drain();

    i = 0;
    while (i < 8) {
        int expected = (i + 1) * (i + 1);
        result &= Test("squared value", inputs[i], expected);
        i++;
    }
    pool.shutdown();
    return result;
}

bool testTaskExitCodeAndFailedFlag() {
    bool result = true;
    ThreadPool pool;
    pool.init(2);

    TaskHandle hOk;
    TaskHandle hFail;
    pool.submit(taskNoop, nullptr, &hOk);
    pool.submit(taskFail, nullptr, &hFail);
    pool.drain();

    bool localResult = true;
    hOk.done.acquire((i32 v) => {
        localResult &= Test("noop exitCode",    hOk.exitCode,    0);
        localResult &= Test("noop failed flag", (int)hOk.failed, 0);
    });
    hFail.done.acquire((i32 v) => {
        localResult &= Test("fail exitCode",    hFail.exitCode,   7);
        localResult &= Test("fail failed flag", (int)hFail.failed, 1);
    });
    result &= localResult;

    pool.shutdown();
    return result;
}

bool testSubmitDetached() {
    bool result = true;
    ThreadPool pool;
    pool.init(2);

    atomic_counter counter = default;
    AddCtx[100] ctxs {};
    int i = 0;
    while (i < 100) { ctxs[i].counter = &counter; i++; }

    i = 0;
    while (i < 100) {
        pool.submitDetached(taskIncrement, &ctxs[i]);
        i++;
    }
    pool.drain();

    result &= Test("detached completion count", (int)counter.read(), 100);
    pool.shutdown();
    return result;
}

bool testTaskResultGet() {
    bool result = true;
    ThreadPool pool;
    pool.init(2);

    IntCtx[5] ctxs {};
    TaskResult<int>[5] results {};
    int i = 0;
    while (i < 5) {
        ctxs[i].input = (i + 1) * 3;
        ctxs[i].out   = &results[i];
        pool.submit(taskSquareResult, &ctxs[i], nullptr);
        i++;
    }
    pool.drain();

    i = 0;
    while (i < 5) {
        int expected = ((i + 1) * 3) * ((i + 1) * 3);
        result &= Test("TaskResult.get", results[i].get(), expected);
        i++;
    }
    pool.shutdown();
    return result;
}

bool testTaskResultFail() {
    bool result = true;
    ThreadPool pool;
    pool.init(2);

    TaskResult<int> r;
    pool.submit(taskFailResult, &r, nullptr);
    pool.drain();
    result &= Test("hasFailed after fail()", (int)r.hasFailed(), 1);
    result &= Test("isReady after fail()",   (int)r.isReady(),   1);

    pool.shutdown();
    return result;
}

bool testTaskResultDoubleSet() {
    // Verifies the CAS-once guard in set()/fail(): only the first call wins,
    // even if the task misbehaves and calls set() twice or set() then fail().
    bool result = true;
    ThreadPool pool;
    pool.init(1);

    TaskResult<int> r;
    pool.submit(taskDoubleSet, &r, nullptr);
    pool.drain();

    result &= Test("first set() wins",        r.get(),             11);
    result &= Test("second set/fail ignored", (int)r.hasFailed(),  0);

    pool.shutdown();
    return result;
}

bool testTaskResultIsReadyBeforePublish() {
    bool result = true;
    TaskResult<int> r;
    result &= Test("isReady before publish", (int)r.isReady(), 0);
    return result;
}

bool testCancellation() {
    bool result = true;
    ThreadPool pool;
    pool.init(2);

    CancelCtx ctx;
    TaskHandle h;
    pool.submit(taskCancellable, &ctx, &h);

    // Give the task time to actually start before we cancel it.  Wall-clock
    // sleep so the wait is real under any optimisation level.
    sleep(20);

    h.cancel();
    h.wait();

    result &= Test("task saw cancel",        (int)ctx.sawCancel, 1);
    result &= Test("task ran some iterations", (int)(ctx.iterations.read() > 0), 1);

    pool.shutdown();
    return result;
}

bool testWaitForTimeoutThenComplete() {
    bool result = true;
    ThreadPool pool;
    pool.init(1);

    TaskHandle h;
    pool.submit(taskSlow, nullptr, &h);

    bool timedOut  = !h.wait_for(5);       // very short; task still busy
    bool completed = h.wait_for(30000);    // generous deadline

    result &= Test("wait_for(5ms) timed out",    (int)timedOut,  1);
    result &= Test("wait_for(30s)  completed",   (int)completed, 1);

    pool.shutdown();
    return result;
}

bool testThenChain() {
    bool result = true;
    ThreadPool pool;
    pool.init(2);

    ChainCtx ctx;
    TaskHandle h1; TaskHandle h2; TaskHandle h3;
    pool.submit(chainStep, &ctx, &h1);
    bool t2 = pool.then(&h1, chainStep, &ctx, &h2);
    bool t3 = pool.then(&h2, chainStep, &ctx, &h3);
    result &= Test("then() #1 accepted", (int)t2, 1);
    result &= Test("then() #2 accepted", (int)t3, 1);

    h3.wait();
    result &= Test("chain ran 3 steps", ctx.value, 3);

    pool.shutdown();
    return result;
}

bool testThenDuplicateRegistration() {
    // Registering two continuations on the same dep must fail the second call
    // rather than silently overwriting the first.
    bool result = true;
    ThreadPool pool;
    pool.init(1);

    // Block the single worker with a slow task so depCtx's task stays pending
    // while both then() calls race to register against it.
    TaskHandle hBlocker;
    pool.submit(taskSlow, nullptr, &hBlocker);

    ChainCtx depCtx;
    TaskHandle hChainA; TaskHandle hChainB;
    TaskHandle hUserDep;
    pool.submit(chainStep, &depCtx, &hUserDep);

    bool first  = pool.then(&hUserDep, chainStep, &depCtx, &hChainA);
    bool second = pool.then(&hUserDep, chainStep, &depCtx, &hChainB);

    result &= Test("first then() accepted",       (int)first,  1);
    result &= Test("duplicate then() rejected",   (int)second, 0);

    pool.drain();
    // hUserDep ran (+1) and the first continuation ran (+1).
    result &= Test("chain ran exactly twice", depCtx.value, 2);

    pool.shutdown();
    return result;
}

bool testThenAfterDepCompleted() {
    // then() on a dep that has already finished and has no pending continuation
    // must still enqueue via the submit_now path.  Guards the ordering of the
    // _hasCont / done checks in then(): _hasCont is checked first to close a
    // double-fire race, but a completed dep with _hasCont == false must not be
    // mistaken for a duplicate.
    bool result = true;
    ThreadPool pool;
    pool.init(2);

    ChainCtx ctx;
    TaskHandle hDep;
    pool.submit(chainStep, &ctx, &hDep);
    hDep.wait();   // dep fully completed; no continuation was ever registered

    TaskHandle hCont;
    bool accepted = pool.then(&hDep, chainStep, &ctx, &hCont);
    result &= Test("then() after dep completed accepted", (int)accepted, 1);

    pool.drain();
    result &= Test("continuation ran after completed dep", ctx.value, 2);

    pool.shutdown();
    return result;
}

bool testDrainFromWithinTask() {
    bool result = true;
    ThreadPool pool;
    pool.init(1);   // 1 worker forces work-participation

    DrainFromTaskCtx ctx;
    ctx.pool = &pool;

    TaskHandle h;
    pool.submit(drainOuterTask, &ctx, &h);
    h.wait();

    result &= Test("inner task ran via worker-participation", ctx.value, 42);

    pool.shutdown();
    return result;
}

bool testResizeGrowShrinkGrow() {
    bool result = true;
    ThreadPool pool;
    pool.init(2);
    result &= Test("init worker count", pool.workerCount(), 2);

    // Grow.
    pool.resize(4);
    result &= Test("grow worker count", pool.workerCount(), 4);

    int[4] v;
    v[0] = 2; v[1] = 3; v[2] = 4; v[3] = 5;
    TaskHandle[4] handles {};
    int i = 0;
    while (i < 4) { pool.submit(taskSquare, &v[i], &handles[i]); i++; }
    pool.drain();
    result &= Test("v[0]", v[0], 4);
    result &= Test("v[1]", v[1], 9);
    result &= Test("v[2]", v[2], 16);
    result &= Test("v[3]", v[3], 25);

    // Shrink.
    pool.resize(1);
    result &= Test("shrink worker count", pool.workerCount(), 1);

    int[4] w;
    w[0] = 6; w[1] = 7; w[2] = 8; w[3] = 9;
    TaskHandle[4] wh {};
    i = 0;
    while (i < 4) { pool.submit(taskSquare, &w[i], &wh[i]); i++; }
    pool.drain();
    result &= Test("w[0]", w[0], 36);
    result &= Test("w[3]", w[3], 81);

    // Grow again (slot reuse).
    pool.resize(3);
    result &= Test("regrow worker count", pool.workerCount(), 3);

    int[4] u;
    u[0] = 1; u[1] = 2; u[2] = 3; u[3] = 4;
    TaskHandle[4] uh {};
    i = 0;
    while (i < 4) { pool.submit(taskSquare, &u[i], &uh[i]); i++; }
    pool.drain();
    result &= Test("u[2]", u[2], 9);

    pool.shutdown();
    return result;
}

bool testSubmitAfterShutdown() {
    bool result = true;
    ThreadPool pool;
    pool.init(2);
    pool.shutdown();

    TaskHandle h;
    bool accepted = pool.submit(taskNoop, nullptr, &h);
    result &= Test("submit after shutdown rejected", (int)accepted, 0);
    return result;
}

bool testInitAfterShutdown() {
    // After shutdown() the channel buffers are released, so a second init()
    // must succeed and the pool must run tasks again.
    bool result = true;
    ThreadPool pool;
    pool.init(2);
    pool.shutdown();

    pool.init(2);
    int x = 6;
    TaskHandle h;
    pool.submit(taskSquare, &x, &h);
    pool.drain();
    result &= Test("squared after re-init", x, 36);

    pool.shutdown();
    return result;
}

bool testApproxPendingCount() {
    // pendingCount only counts queued, not running tasks.  After drain it
    // must be zero.  We don't assert a specific positive value because the
    // workers may pop faster than we submit.
    bool result = true;
    ThreadPool pool;
    pool.init(1);

    int[10] vs;
    TaskHandle[10] hs {};
    int i = 0;
    while (i < 10) { vs[i] = i + 1; pool.submit(taskSquare, &vs[i], &hs[i]); i++; }
    pool.drain();

    result &= Test("pending after drain", pool.approxPendingCount(), 0);
    pool.shutdown();
    return result;
}

bool testManyTasksStress() {
    // Throw a large batch at the pool to exercise the channel under contention.
    bool result = true;
    ThreadPool pool;
    pool.init(4);

    int N = 2000;
    atomic_counter counter = default;
    AddCtx ctx;
    ctx.counter = &counter;

    int i = 0;
    while (i < N) {
        pool.submitDetached(taskIncrement, &ctx);
        i++;
    }
    pool.drain();

    result &= Test("stress completion count", (int)counter.read(), N);
    pool.shutdown();
    return result;
}

bool testPriorityOrdering() {
    // Single worker so the queued tasks drain in strict priority order:
    // every HIGH runs before every NORMAL, which runs before every LOW.
    bool result = true;
    ThreadPool pool;
    pool.init(1);

    atomic_counter orderCounter = default;
    PriorityCtx[9] ctxs {};
    int i = 0;
    while (i < 9) { ctxs[i].orderCounter = &orderCounter; i++; }

    // Gate task 0 on a latch so we can deterministically enqueue the priority
    // batch before the worker becomes free.  Without this, the precondition
    // ("all 8 tasks enqueued before the worker drains task 0") would rely on
    // Windows Sleep() granularity (~15 ms) and the test would be flaky.
    latch gate;
    gate.init(1);
    ctxs[0].gate = &gate;

    ctxs[0].priority = THREADPOOL_PRIORITY_LOW;
    ctxs[1].priority = THREADPOOL_PRIORITY_LOW;
    ctxs[2].priority = THREADPOOL_PRIORITY_LOW;
    ctxs[3].priority = THREADPOOL_PRIORITY_NORMAL;
    ctxs[4].priority = THREADPOOL_PRIORITY_NORMAL;
    ctxs[5].priority = THREADPOOL_PRIORITY_NORMAL;
    ctxs[6].priority = THREADPOOL_PRIORITY_HIGH;
    ctxs[7].priority = THREADPOOL_PRIORITY_HIGH;
    ctxs[8].priority = THREADPOOL_PRIORITY_HIGH;

    TaskHandle[9] handles {};

    // Submit task 0 (LOW) first; the worker will pick it up and block on the
    // latch.  Order of the queue-rest submits vs. worker pickup no longer
    // matters: the worker cannot make progress past task 0 until we release.
    pool.submit(taskPriority, &ctxs[0], &handles[0], THREADPOOL_PRIORITY_LOW);

    // Queue the rest in interleaved priority order while task 0 is gated.
    pool.submit(taskPriority, &ctxs[1], &handles[1], THREADPOOL_PRIORITY_LOW);
    pool.submit(taskPriority, &ctxs[2], &handles[2], THREADPOOL_PRIORITY_LOW);
    pool.submit(taskPriority, &ctxs[3], &handles[3], THREADPOOL_PRIORITY_NORMAL);
    pool.submit(taskPriority, &ctxs[4], &handles[4], THREADPOOL_PRIORITY_NORMAL);
    pool.submit(taskPriority, &ctxs[5], &handles[5], THREADPOOL_PRIORITY_NORMAL);
    pool.submit(taskPriority, &ctxs[6], &handles[6], THREADPOOL_PRIORITY_HIGH);
    pool.submit(taskPriority, &ctxs[7], &handles[7], THREADPOOL_PRIORITY_HIGH);
    pool.submit(taskPriority, &ctxs[8], &handles[8], THREADPOOL_PRIORITY_HIGH);

    // All 8 are now enqueued.  Release task 0 so the worker can drain in
    // strict priority order: qHigh then qNormal then qLow.
    gate.count_down();

    pool.drain();

    // Among the 8 queued tasks (indices 1-8): all HIGH < all NORMAL < all LOW.
    int maxHigh   = 0;
    int minNormal = 9999;
    int maxNormal = 0;
    int minLow    = 9999;

    i = 1;
    while (i < 9) {
        int prio  = ctxs[i].priority;
        int order = ctxs[i].order;
        if (prio == THREADPOOL_PRIORITY_HIGH) {
            if (order > maxHigh)   { maxHigh   = order; }
        } else if (prio == THREADPOOL_PRIORITY_NORMAL) {
            if (order < minNormal) { minNormal = order; }
            if (order > maxNormal) { maxNormal = order; }
        } else {
            if (order < minLow)    { minLow    = order; }
        }
        i++;
    }

    result &= Test("HIGH batch drains before NORMAL", (int)(maxHigh < minNormal), 1);
    result &= Test("NORMAL batch drains before LOW",  (int)(maxNormal < minLow), 1);

    pool.shutdown();
    gate.destroy();
    return result;
}

// --- Program-hosted ThreadPool test ---

program ThreadPoolProgram {
    ThreadPool pool = default;

    int main(move list<string> args) {
        // Pool is initialized in outer scope before run() - just use it here.
        // Submit multiple tasks that square numbers.
        int[5] inputs;
        int i = 0;
        while (i < 5) { inputs[i] = i + 2; i++; }

        TaskHandle[5] handles {};
        i = 0;
        while (i < 5) {
            pool.submit(taskSquare, &inputs[i], &handles[i]);
            i++;
        }
        pool.drain();

        // Verify results
        i = 0;
        int failed = 0;
        while (i < 5) {
            int expected = (i + 2) * (i + 2);
            if (inputs[i] != expected) {
                failed = 1;
                break;
            }
            i++;
        }

        return failed;
    }
};

bool testThreadPoolInProgram() {
    bool result = true;

    ThreadPoolProgram prog;
    // Initialize the pool field in outer scope before run()
    // (pattern: complex fields initialized before program execution)
    prog.pool.init(2);

    list<string> emptyArgs;
    prog.run(emptyArgs);
    prog.WaitForExit();

    result &= Test("program threadpool exit code", prog.exitCode, 0);
    return result;
}

extern int main() {
    int total  = 0;
    int passed = 0;

    total++; passed += testBasicSubmitAndDrain()         ? 1 : 0;
    total++; passed += testTaskExitCodeAndFailedFlag()   ? 1 : 0;
    total++; passed += testSubmitDetached()              ? 1 : 0;
    total++; passed += testTaskResultGet()               ? 1 : 0;
    total++; passed += testTaskResultFail()              ? 1 : 0;
    total++; passed += testTaskResultDoubleSet()         ? 1 : 0;
    total++; passed += testTaskResultIsReadyBeforePublish() ? 1 : 0;
    total++; passed += testCancellation()                ? 1 : 0;
    total++; passed += testWaitForTimeoutThenComplete()  ? 1 : 0;
    total++; passed += testThenChain()                   ? 1 : 0;
    total++; passed += testThenDuplicateRegistration()   ? 1 : 0;
    total++; passed += testThenAfterDepCompleted()       ? 1 : 0;
    total++; passed += testDrainFromWithinTask()         ? 1 : 0;
    total++; passed += testResizeGrowShrinkGrow()        ? 1 : 0;
    total++; passed += testSubmitAfterShutdown()         ? 1 : 0;
    total++; passed += testInitAfterShutdown()           ? 1 : 0;
    total++; passed += testApproxPendingCount()          ? 1 : 0;
    total++; passed += testManyTasksStress()             ? 1 : 0;
    total++; passed += testPriorityOrdering()            ? 1 : 0;
    total++; passed += testThreadPoolInProgram()         ? 1 : 0;

    printf("ThreadPool tests: %d/%d passed.\n", passed, total);
    return passed == total ? 0 : 1;
}
