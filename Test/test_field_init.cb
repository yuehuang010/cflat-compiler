struct Point
{
    int x = 0;
    int y = 0;
};

struct Person
{
    int age = 0;
    int score = 0;
};

void printPoint(Point p = { x=1, y=2 })
{
    printf("%d %d\n", p.x, p.y);
}

extern int main()
{
    // Stack allocation with field initializer
    Point p = { x=10, y=20 };
    printf("%d %d\n", p.x, p.y);   // 10 20

    // Partial initializer — unmentioned field keeps default
    Point q = { x=5 };
    printf("%d %d\n", q.x, q.y);   // 5 0

    // Trailing comma
    Person person = { age=30, score=100, };
    printf("%d %d\n", person.age, person.score);   // 30 100

    // Heap allocation with field initializer
    Point* hp = new Point { x=7, y=8 };
    printf("%d %d\n", hp->x, hp->y);   // 7 8
    delete hp;

    // Default parameter with field initializer
    printPoint();   // 1 2

    // Inline field initializer as positional argument
    printPoint({ x=3, y=4 });   // 3 4

    // Inline field initializer as named-parameter argument
    printPoint(p: { x=5, y=6 });   // 5 6

    return 0;
}
