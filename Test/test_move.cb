import "list.cb";
import "test_helper.cb";

int dtorCount = 0;

struct Resource
{
    int id = 0;
    ~Resource()
    {
        dtorCount = dtorCount + 1;
    }
};

struct Container
{
    Resource* item = nullptr;

    void reset()
    {
        if (item != nullptr) { delete item; item = nullptr; }
    }

    ~Container()
    {
        if (item != nullptr)
            delete item;
    }
};

// `unique` field ownership: the compiler-synthesized destructor deletes the pointer,
// so this needs none of ~Container's hand-written free above.
struct UniqueBox
{
    unique Resource* item = nullptr;

    // Bare self-field assign inside a method. This carries no FieldName (it resolves through
    // GetMemberVariable), so the reassignment free is skipped by a runtime old-vs-new compare
    // rather than by name matching; without it this frees and then stores a dangling pointer.
    void selfAssignBare() { item = item; }
};

// `unique` composes with a hand-written destructor. The user dtor runs FIRST, so releasing
// the field early leaves the synthesized delete looking at nullptr - not a double free.
// Stage 2 note: this used to spell the release `delete item; item = nullptr;`. A hand-written
// delete of a `unique` field is now rejected outright (err_unique_delete_field) because the
// un-nulled form of it is a double-free, and it is no longer needed - assigning nullptr frees
// the pointee on its own, which is exactly what this exercises.
struct UniqueFreesItself
{
    unique Resource* item = nullptr;

    ~UniqueFreesItself()
    {
        item = nullptr;
    }
};

// Transitive: deleting the outer `unique` field runs UniqueBox's synthesized
// destructor, which in turn deletes its own `unique` field.
struct UniqueOuter
{
    unique UniqueBox* inner = nullptr;
};

/*
 * `unique` on an INTERFACE field. Ownership has to live in the contract: a store through the
 * interface's byte-offset slot is dispatched dynamically, so the concrete type is unknown and
 * the access site can only learn the slot is owning from the interface itself. Both sides must
 * agree - the two disagreements are rejected (err_unique_iface_field_impl_only /
 * err_unique_iface_field_iface_only). This is the field analogue of `push(move T item)`.
 */
interface IUniqueBox
{
    unique Resource* item;
    int tag();
};

class UniqueIfaceBox : IUniqueBox
{
    unique Resource* item = nullptr;
    int tag() { return 1; }
};

// Reassign through the interface's field slot: the old pointee is freed here, not orphaned.
int storeViaIface(IUniqueBox h)
{
    h.item = new Resource();
    h.item->id = 21;
    return h.tag();
}

// `nullptr` through the interface slot is the same release-early idiom as on a direct field.
void releaseViaIface(IUniqueBox h)
{
    h.item = nullptr;
}

// Composite-ownership shape: 'Bag' owns its 'item' (a Resource*) and an array
// of 'RouteEntry' (each of which owns its own 'name' Resource*). Each layer's
// destructor frees only its own fields; cross-layer cleanup happens by chained
// destructor invocation ('delete[n] entries' calls ~RouteEntry on every slot).
struct RouteEntry
{
    Resource* name = nullptr;
    ~RouteEntry()
    {
        if (name != nullptr) delete name;
    }
};

struct Bag
{
    Resource*    item    = nullptr;
    RouteEntry*  entries = nullptr;

    ~Bag()
    {
        if (item != nullptr) delete item;
        if (entries != nullptr) delete[3] entries;
    }
};

// Worker-style payload: pointer to an external observer slot plus a value.
// Mirrors Test/repro_new_struct.cb but stays single-threaded so the test
// is hermetic. The caller hands the owning pointer to 'workerMove' which
// performs the side effect through ->slot, then ownership ends at the
// callee's scope exit - exactly the pattern repro_new_struct.cb needs.
struct Slot
{
    int* slot  = nullptr;
    int  value = 0;
    ~Slot()
    {
        dtorCount = dtorCount + 1;
    }
};

// Move param: side-effects through the pointer, never calls 'delete'.
// Ownership ends when the function returns (scope-exit cleanup frees it).
int workerMove(move Slot* s)
{
    *s->slot = s->value;
    return s->value;
}

// Move param with an explicit 'delete': proves that an in-body delete
// nulls the parameter's alloca so the scope-exit cleanup does not
// double-free. This is the safe analogue of the unsafe pattern in
// Test/errors/err_delete_borrowed_via_cast.cb.
int workerMoveDelete(move Slot* s)
{
    *s->slot = s->value;
    int v = s->value;
    delete s;
    return v;
}

// move parameter takes ownership - Resource is deleted when consume returns
void consume(move Resource* r)
{
    // use r inside the function
    int x = r->id;
}

// non-move parameter borrows - caller still owns
void borrow(Resource* r)
{
    int x = r->id;
}

// D4: a `unique` parameter is a synthesized move parameter - it takes ownership and
// frees the Resource when the function returns, exactly like `consume(move Resource*)`.
void sinkUnique(unique Resource* r)
{
    int x = r->id;
}

// Move/borrow overload pair: 'move' participates in mangling and overload selection.
// probe(move Resource*) returns 100 + id and takes ownership (deletes r).
// probe(Resource*)      returns 200 + id and borrows.
int probe(move Resource* r)
{
    int id = r->id;
    delete r;
    return 100 + id;
}

int probe(Resource* r)
{
    return 200 + r->id;
}

// Helper: r is a borrowed (non-move) parameter, so probe(r) must pick the borrow overload.
int delegateProbe(Resource* r)
{
    return probe(r);
}

// move T* return type - ownership propagates to caller
move Resource* createResource(int id)
{
    Resource* r = new Resource();
    r->id = id;
    return r;
}

move Resource* forwardResource(move Resource* r)
{
    return r;
}

// ── list<string> helpers ──────────────────────────────────────────────────────
// Passing list<string> value/pointer as a free-function parameter is a known
// limitation; these helpers operate on extracted string values instead.

string echoString(string s)
{
    return s;
}

// Two-hop relay: string passes through two function calls
string relayString(string s)
{
    return echoString(s);
}

// Three-hop relay
string relayStringDeep(string s)
{
    return relayString(s);
}

int testListStringMove()
{
    int passed = 0;

    // Basic list<string> operations: add, count, get
    {
        list<string> words;
        string a = "" + "apple";
        string b = "" + "banana";
        string c = "" + "cherry";
        words.add(a);
        words.add(b);
        words.add(c);
        passed += Test("list_string_count", words.count(), 3);
        passed += Test("list_string_get0",  words.get(0), "apple");
        passed += Test("list_string_get1",  words.get(1), "banana");
        passed += Test("list_string_get2",  words.get(2), "cherry");
    }

    // removeAt: verify element is removed and count updates
    {
        list<string> words;
        string a = "" + "first";
        string b = "" + "second";
        string c = "" + "third";
        words.add(a);
        words.add(b);
        words.add(c);
        words.removeAt(1);
        passed += Test("list_string_remove_count", words.count(), 2);
        passed += Test("list_string_remove_get0",  words.get(0), "first");
        passed += Test("list_string_remove_get1",  words.get(1), "third");
    }

    // Strings extracted from list survive passing through function calls
    // (regression: string values were corrupted when passed across functions)
    {
        list<string> words;
        string w1 = "" + "hello";
        string w2 = "" + "world";
        words.add(w1);
        words.add(w2);

        string r1 = echoString(words.get(0));     // one hop
        string r2 = relayString(words.get(1));    // two hops
        string r3 = relayStringDeep(words.get(0)); // three hops
        passed += Test("list_string_one_hop",   r1, "hello");
        passed += Test("list_string_two_hop",   r2, "world");
        passed += Test("list_string_three_hop", r3, "hello");
    }

    return passed;
}

// ── recursive owning-pointer-tree free (X4 Part 2 regression) ─────────────────
// Passing a FIELD (node->left / node->right) to a 'move' parameter must mark only
// that field as moved, not the whole base 'node' - otherwise the second field
// access is wrongly rejected as "use of moved variable 'node'". This is the
// canonical Huffman/AST shape: a recursive free over an owning pointer tree.
struct TreeNode
{
    TreeNode* left  = nullptr;
    TreeNode* right = nullptr;
    ~TreeNode()
    {
        dtorCount = dtorCount + 1;
    }
};

void freeTree(move TreeNode* node)
{
    if (node == nullptr) return;
    freeTree(node->left);    // moving node->left must NOT poison node ...
    freeTree(node->right);   // ... so this line still compiles.
    delete node;
}

int testRecursiveTreeFree()
{
    int passed = 0;

    // 3-level full binary tree: 1 root + 2 children + 4 grandchildren = 7 nodes.
    dtorCount = 0;
    {
        TreeNode* root = new TreeNode();
        root->left  = new TreeNode();
        root->right = new TreeNode();
        root->left->left   = new TreeNode();
        root->left->right  = new TreeNode();
        root->right->left  = new TreeNode();
        root->right->right = new TreeNode();
        freeTree(root);
        // root is moved into freeTree; scope exit is a no-op. Every node freed once.
    }
    passed += Test("recursive_tree_free_all_freed_once", dtorCount, 7);

    return passed;
}

// A destructor that recursively deletes its own children. Leaf children are null,
// so 'delete left'/'delete right' must treat a null pointer as a no-op rather than
// invoking the destructor on null (which would dereference null and crash).
struct CascadeNode
{
    CascadeNode* left  = nullptr;
    CascadeNode* right = nullptr;
    ~CascadeNode()
    {
        dtorCount = dtorCount + 1;
        delete left;    // null on leaves: delete must be a safe no-op
        delete right;
    }
};

int testDeleteNullCascade()
{
    int passed = 0;

    // root + 2 children; grandchildren are null. 'delete root' cascades through the
    // destructor, hitting 'delete nullptr' on every leaf. All three freed once, no crash.
    dtorCount = 0;
    {
        CascadeNode* root = new CascadeNode();
        root->left  = new CascadeNode();
        root->right = new CascadeNode();
        delete root;
    }
    passed += Test("delete_null_cascade_frees_all", dtorCount, 3);

    return passed;
}

// Recursive container: a node owns its children in a `list<TreeBox*>` field. Because
// TreeBox's own field forces `list<TreeBox*>` to be monomorphized while TreeBox is still
// incomplete, the generic list destructor used to bind its element `delete` to a null
// destructor and leak the entire subtree. The deferred delete-site destructor fix makes
// `~list<TreeBox*>` free each element (recursing through this destructor).
struct TreeBox
{
    int id = 0;
    list<unique TreeBox*> children = default;
    ~TreeBox()
    {
        dtorCount = dtorCount + 1;
    }
};

int testRecursiveContainerFree()
{
    int passed = 0;

    // 3-deep chain held through list<TreeBox*> fields: root -> child -> grandchild.
    // When 'roots' goes out of scope, ~list frees root; ~TreeBox destructs root.children,
    // which frees child; and so on. All three freed exactly once.
    dtorCount = 0;
    {
        list<unique TreeBox*> roots;
        TreeBox* root  = new TreeBox(); root->id  = 1;
        TreeBox* child = new TreeBox(); child->id = 2;
        TreeBox* grand = new TreeBox(); grand->id = 3;
        child->children.add(grand);
        root->children.add(child);
        roots.add(root);
    }
    passed += Test("recursive_container_frees_all", dtorCount, 3);

    return passed;
}

int testUniqueField()
{
    int passed = 0;

    // The synthesized destructor frees the `unique` field - UniqueBox has no user dtor.
    dtorCount = 0;
    {
        UniqueBox b;
        b.item = new Resource();
    }
    passed += Test("unique_field_freed_by_synth_dtor", dtorCount, 1);

    // A `unique` field left null is skipped by the null check, not freed.
    dtorCount = 0;
    {
        UniqueBox b;
    }
    passed += Test("unique_null_field_not_freed", dtorCount, 0);

    // Stage 2 - the user dtor's `item = nullptr` frees it, leaving the synthesized delete
    // a no-op: composition without a double free.
    dtorCount = 0;
    {
        UniqueFreesItself u;
        u.item = new Resource();
    }
    passed += Test("unique_composes_with_user_dtor", dtorCount, 1);

    // Outer deletes inner; inner's synthesized dtor deletes its own `unique` field.
    dtorCount = 0;
    {
        UniqueOuter o;
        o.inner = new UniqueBox();
        o.inner->item = new Resource();
    }
    passed += Test("unique_transitive_chain_freed", dtorCount, 1);

    // Heap-owned struct: `delete` routes through the synthesized full destructor.
    dtorCount = 0;
    {
        UniqueBox* hb = new UniqueBox();
        hb->item = new Resource();
        delete hb;
        passed += Test("unique_field_freed_on_delete", dtorCount, 1);
    }
    passed += Test("unique_no_double_free_after_delete", dtorCount, 1);

    // Brace-init is a second field-store path (EmitOneFieldInit): storing an owning local into a
    // `unique` field must transfer ownership exactly as `=` does, or BOTH the local's scope-exit
    // cleanup and the field's synthesized destructor free the one pointee (a double free).
    dtorCount = 0;
    {
        Resource* r = new Resource();
        UniqueBox b = { item = r };
        passed += Test("unique_brace_init_alive_before_teardown", dtorCount, 0);
    }
    passed += Test("unique_brace_init_owning_local_freed_once", dtorCount, 1);

    // Stage 2 - reassignment destructs first: overwriting a live `unique` field frees the
    // old pointee rather than orphaning it. 3 stores => 2 freed on reassign, 1 at teardown.
    dtorCount = 0;
    {
        UniqueBox b;
        b.item = new Resource();
        b.item = new Resource();
        b.item = new Resource();
        passed += Test("unique_reassign_frees_old", dtorCount, 2);
    }
    passed += Test("unique_reassign_last_freed_at_teardown", dtorCount, 3);

    // Stage 2 - assigning nullptr releases the pointee early (the sanctioned idiom, and the
    // reason a hand-written `delete` on a unique field is both unnecessary and rejected).
    dtorCount = 0;
    {
        UniqueBox b;
        b.item = new Resource();
        b.item = nullptr;
        passed += Test("unique_nullptr_releases_early", dtorCount, 1);
    }
    passed += Test("unique_nullptr_release_no_double_free", dtorCount, 1);

    // Stage 2 - self-assign must not free-then-store a dangling pointer.
    dtorCount = 0;
    {
        UniqueBox b;
        b.item = new Resource();
        b.item = b.item;
        passed += Test("unique_self_assign_does_not_free", dtorCount, 0);
    }
    passed += Test("unique_self_assign_freed_once_at_teardown", dtorCount, 1);

    // Stage 2 - same, spelled bare inside a method (no FieldName to match on).
    dtorCount = 0;
    {
        UniqueBox b;
        b.item = new Resource();
        b.selfAssignBare();
        passed += Test("unique_bare_self_assign_does_not_free", dtorCount, 0);
    }
    passed += Test("unique_bare_self_assign_freed_once_at_teardown", dtorCount, 1);

    // Stage 2 - `move` transfers ownership into a unique field (the accepted spelling of
    // the borrow that err_unique_borrow_into_field rejects). Freed once, by the field.
    dtorCount = 0;
    {
        UniqueBox b;
        Resource* fresh = new Resource();
        b.item = move fresh;
        passed += Test("unique_move_into_field_not_freed_early", dtorCount, 0);
    }
    passed += Test("unique_move_into_field_freed_once", dtorCount, 1);

    // Stage 3 (Trap B) - `move` OUT of a unique field is the sanctioned extraction: it nulls
    // the field, so the local owns the pointee and the synthesized dtor finds nothing to free.
    // This is the counterpart to err_unique_delete_alias, where a plain copy is rejected.
    dtorCount = 0;
    {
        UniqueBox b;
        b.item = new Resource();
        b.item->id = 7;
        Resource* owned = move b.item;
        passed += Test("unique_move_out_field_id_intact", owned->id, 7);
        passed += Test("unique_move_out_field_not_freed_yet", dtorCount, 0);
        delete owned;
        passed += Test("unique_move_out_field_freed_by_local", dtorCount, 1);
        // Scope exit: the field was nulled by the move, so the synthesized delete is a no-op.
    }
    passed += Test("unique_move_out_field_no_double_free", dtorCount, 1);

    // Stage 3 (Trap B) - a local aliasing a `unique` field is a borrow, not an owner: reading
    // and writing THROUGH it stays legal, and it is the field that frees, exactly once. Only
    // `delete alias` is rejected.
    dtorCount = 0;
    {
        UniqueBox b;
        b.item = new Resource();
        Resource* alias = b.item;
        alias->id = 42;
        passed += Test("unique_alias_read_through", b.item->id, 42);
        passed += Test("unique_alias_borrow_does_not_free", dtorCount, 0);
    }
    passed += Test("unique_alias_freed_once_by_field", dtorCount, 1);

    // Stage 3 (Trap B) - the borrow marking must not leak into an ordinary pointer field:
    // `Container.item` is not `unique`, so laundering it through a local and deleting the
    // local stays legal (the ~254 unmarked pointer fields keep today's semantics exactly).
    dtorCount = 0;
    {
        Container c;
        c.item = new Resource();
        Resource* a = c.item;
        delete a;
        c.item = nullptr;   // ~Container would otherwise free the same pointer
        passed += Test("plain_field_alias_delete_still_legal", dtorCount, 1);
    }
    passed += Test("plain_field_alias_delete_freed_once", dtorCount, 1);

    // Brace-init is a second, independent field-store path (EmitOneFieldInit). A fresh
    // allocation through it is owned by the field and freed exactly once at teardown - the
    // borrow spelling is rejected (err_unique_brace_init_borrow).
    dtorCount = 0;
    {
        UniqueBox b = { item = new Resource() };
        b.item->id = 5;
        passed += Test("unique_brace_init_fresh_id", b.item->id, 5);
        passed += Test("unique_brace_init_fresh_not_freed_early", dtorCount, 0);
    }
    passed += Test("unique_brace_init_fresh_freed_once", dtorCount, 1);

    // Brace-init with an explicit `move`: ownership transfers to the field, which frees once.
    dtorCount = 0;
    {
        Resource* fresh = new Resource();
        UniqueBox b = { item = move fresh };
        passed += Test("unique_brace_init_move_not_freed_early", dtorCount, 0);
    }
    passed += Test("unique_brace_init_move_freed_once", dtorCount, 1);

    // The brace-init guards are keyed on `unique`, so an ORDINARY pointer field brace-initialized
    // from a borrow is untouched - it stores the borrow and frees nothing, exactly as before.
    dtorCount = 0;
    {
        Resource* owned = new Resource();
        owned->id = 11;
        {
            Container c = { item = owned };
            passed += Test("plain_brace_init_borrow_reads_through", c.item->id, 11);
            c.item = nullptr;   // ~Container would otherwise free the borrow
        }
        passed += Test("plain_brace_init_borrow_not_freed_by_field", dtorCount, 0);
        delete owned;
        passed += Test("plain_brace_init_borrow_freed_by_owner", dtorCount, 1);
    }

    // `move` between two `unique` fields is the sanctioned transfer: it nulls the source, so
    // only the destination frees. The plain copy `c.item = a.item` is rejected
    // (err_unique_field_to_field) precisely because it would leave both fields owning.
    dtorCount = 0;
    {
        UniqueBox a;
        UniqueBox c;
        a.item = new Resource();
        a.item->id = 13;
        c.item = move a.item;
        passed += Test("unique_field_to_field_move_id_intact", c.item->id, 13);
        passed += Test("unique_field_to_field_move_source_nulled", a.item == nullptr ? 1 : 0, 1);
        passed += Test("unique_field_to_field_move_not_freed_early", dtorCount, 0);
    }
    passed += Test("unique_field_to_field_move_freed_once", dtorCount, 1);

    // A `unique` field reached through an interface's byte-offset slot gets the same store-site
    // guards as a direct field read: the flag rides the interface's field declaration, which the
    // access site binds from. Reassigning through the slot frees the old pointee.
    dtorCount = 0;
    {
        UniqueIfaceBox b;
        b.item = new Resource();
        storeViaIface(b);
        passed += Test("unique_iface_slot_reassign_frees_old", dtorCount, 1);
        passed += Test("unique_iface_slot_reassign_writes_same_slot", b.item->id, 21);
    }
    passed += Test("unique_iface_slot_reassign_freed_at_teardown", dtorCount, 2);

    // Releasing early through the interface slot frees once, and leaves the synthesized
    // destructor looking at nullptr rather than double-freeing.
    dtorCount = 0;
    {
        UniqueIfaceBox b;
        b.item = new Resource();
        releaseViaIface(b);
        passed += Test("unique_iface_slot_nullptr_releases_early", dtorCount, 1);
    }
    passed += Test("unique_iface_slot_release_no_double_free", dtorCount, 1);

    return passed;
}

int testFieldOwnership()
{
    int passed = 0;

    // Destructor frees its own field exactly once.
    dtorCount = 0;
    {
        Container c;
        c.item = new Resource();
    }
    passed += Test("dtor_frees_own_field", dtorCount, 1);

    // Member method frees the field; destructor sees nullptr and does nothing.
    dtorCount = 0;
    {
        Container c;
        c.item = new Resource();
        c.reset();
        passed += Test("method_reset_freed", dtorCount, 1);
        // Scope exit: ~Container runs; c.item == nullptr so no second free.
    }
    passed += Test("no_double_free_after_reset", dtorCount, 1);

    // External code extracts the field via 'move' and frees the local. The
    // owner's field is nulled by the move, so its destructor is a no-op.
    dtorCount = 0;
    {
        Container c;
        c.item = new Resource();
        {
            Resource* taken = move c.item;
            passed += Test("field_nulled_after_move", c.item == nullptr, true);
            delete taken;
        }
        passed += Test("move_then_delete_frees_once", dtorCount, 1);
        // Scope exit: ~Container runs; c.item == nullptr so dtorCount stays 1.
    }
    passed += Test("owner_dtor_skips_moved_field", dtorCount, 1);

    // Move from a heap-owned container pointer works the same way.
    dtorCount = 0;
    {
        Container* hc = new Container();
        hc->item = new Resource();
        Resource* taken = move hc->item;
        delete taken;
        delete hc;
    }
    passed += Test("move_from_heap_container", dtorCount, 1);

    return passed;
}

// ── owning-string by-value param stored into a field (param -> field regression) ──────
// A factory that stores a plain (non-move) by-value `string` parameter into a struct field
// must give the field an INDEPENDENT owned buffer. The argument is typically an owning concat
// temp that the CALLER frees at its end-of-statement cleanup; a shallow store would alias that
// buffer into the field, leaving it dangling - and silently corrupted once a later allocation
// reuses the freed block - after the factory returns. (A true move is impossible from the
// callee, so the param -> field store deep-copies.)
struct Labelled
{
    string label = default;
};

Labelled* makeLabelled(string s)
{
    Labelled* n = new Labelled();
    n.label = s;            // plain by-value param -> field: must deep-copy, not alias
    return n;
}

int testParamStringToField()
{
    int bad = 0;
    for (int i = 0; i < 1000; i++)
    {
        // Owning concat temp as the argument; the caller frees it after makeLabelled returns.
        Labelled* n = makeLabelled("item-" + i.toString());
        // A subsequent string allocation reuses the block freed if ownership leaked.
        string churn = "blah-" + i.toString() + "-padding-padding-padding";
        string want = "item-" + i.toString();
        if (n.label.indexOf(want) != 0) { bad = bad + 1; }
        delete n;           // ~Labelled frees the owned field copy exactly once
    }
    int passed = 0;
    passed += Test("param_string_to_field_survives", bad, 0);
    return passed;
}

// ── borrowed owning-string field read into a local (field -> local regression) ────────
// `string snap = obj.method()` (a plain method returning a field) and `string snap = obj.field`
// (a direct field read) both bind a non-owning BORROW of the field's buffer. A later store to
// the same field frees that buffer, so the local must hold an INDEPENDENT owned copy to survive
// (and so a heap object can be deleted while a snapshot is still live). Regression: before the
// fix the local aliased the field buffer and read garbage after a reassignment, and corrupted
// the heap on delete (a non-heap/pool pointer got freed).
class LabelHolder
{
    string lbl = default;
    string label() { return lbl; }
    void setLabel(string s) { lbl = s; }
};

interface ILabel
{
    string label();
    void setLabel(string s);
};

class HeapLabel : ILabel
{
    string lbl = default;
    string label() { return lbl; }
    void setLabel(string s) { lbl = s; }
    ~HeapLabel() { }
};

int testBorrowStringFieldIntoLocal()
{
    int passed = 0;

    // A method return is a BORROW of the field, so an independent snapshot needs `.copy()`;
    // it then survives a later setter store to the same field.
    {
        LabelHolder p;
        p.setLabel("final");
        string snap = p.label().copy();
        p.setLabel("changed");
        passed += Test("borrow_field_method_read_survives", snap, "final");
    }

    // Snapshot taken via a direct field read survives a later setter store.
    {
        LabelHolder q;
        q.setLabel("final");
        string snapQ = q.lbl;
        q.setLabel("changed");
        passed += Test("borrow_field_direct_read_survives", snapQ, "final");
    }

    // Heap object via an interface: a `.copy()` snapshot survives delete (no crash, no corruption);
    // the field's owned buffer is freed exactly once by the destructor on delete.
    {
        ILabel b = new HeapLabel();
        b.setLabel("final");
        string snap = b.label().copy();
        b.setLabel("changed");
        delete b;
        passed += Test("borrow_field_heap_snapshot_after_delete", snap, "final");
    }

    return passed;
}

// ── value struct with an owning string field, moved into a list<T> via add() ──────────
// `list<T>.add(move T value)` MOVES the struct into `_data[i]`, so the list becomes the
// sole owner of each element's owning string field. Reading elements back - especially via
// `for (Holder h in list)`, which binds a by-value copy of each element to the loop variable
// and destructs it at loop exit - must NOT free the buffer the list still owns. `alias T get`
// returns a borrow whose owning-field OWNED bits are cleared, so a destructed copy is a no-op.
// Regression: before the fix the loop-variable copy freed the field, dangling the list element
// and double-freeing on teardown (process exit 127). Verifies the stored data is intact across
// later allocations and that teardown frees each buffer exactly once (reaching this point at
// all proves no double-free; data integrity proves no premature free).
struct Holder
{
    int id = 0;
    string name = default;
};

int testStructWithStringFieldIntoList()
{
    int bad = 0;
    int sumLen = 0;
    {
        list<Holder> holders;
        for (int i = 0; i < 50; i++)
        {
            Holder h = default;
            h.id = i;
            h.name = "holder-" + i.toString();   // owning string field
            holders.add(h);                       // MOVE struct into the list
        }
        // for-in binds a by-value copy per element and destructs it at loop exit; the
        // borrowed owning-string field must survive (no double-free, no corruption).
        for (Holder h in holders)
            sumLen = sumLen + h.name.length();
        // Churn allocations would reuse any buffer wrongly freed by the loop copies.
        for (int i = 0; i < 50; i++)
        {
            string churn = "padding-padding-padding-" + i.toString();
            if (churn.length() < 1) { bad = bad + 1; }
        }
        // Read back through indexing after the churn: every element must be intact.
        for (int i = 0; i < holders.count(); i++)
        {
            string want = "holder-" + i.toString();
            if (holders.get(i).name.indexOf(want) != 0) { bad = bad + 1; }
            if (holders.get(i).id != i) { bad = bad + 1; }
        }
        // `holders` (and every owned element string) is destructed here - exactly once.
    }
    int passed = 0;
    passed += Test("struct_string_field_into_list_intact", bad, 0);
    passed += Test("struct_string_field_into_list_sumlen", sumLen, 440); // 10*len("holder-N") + 40*len("holder-NN")
    return passed;
}

// D4/D5: `unique` on a local/parameter. A `unique X*` local is an owning location; a
// `unique X*` parameter is a synthesized move parameter. All checks are dtor-count based.
int testUniqueLocalAndParam()
{
    int passed = 0;

    // D5: unique local from new is an owning location - freed exactly once at scope exit.
    dtorCount = 0;
    { unique Resource* a = new Resource(); }
    passed += Test("unique_local_from_new_freed_once", dtorCount, 1);

    // D5: loading from a unique location without move yields a borrow - the borrowed local
    // is not freed, so the owner frees once (no double free).
    dtorCount = 0;
    {
        unique Resource* b = new Resource();
        Resource* borrowed = b;
        int x = borrowed->id;
    }
    passed += Test("unique_borrow_out_no_double_free", dtorCount, 1);

    // D4: passing a named unique value to a unique (synthesized move) parameter transfers
    // ownership - the callee frees it; the caller must not (no double free).
    dtorCount = 0;
    {
        unique Resource* c = new Resource();
        sinkUnique(c);
    }
    passed += Test("unique_synth_move_param_freed_once", dtorCount, 1);

    // D4: passing a unique value to a plain-pointer parameter is a borrow - the caller keeps
    // ownership and frees once at scope exit.
    dtorCount = 0;
    {
        unique Resource* d = new Resource();
        borrow(d);
    }
    passed += Test("unique_to_plain_param_borrows", dtorCount, 1);

    return passed;
}

// Explicit `move` on a VALUE-type call argument (string / owning struct / closure) defers
// the ownership transfer until the callee's parameter move-ness is known. Passing to a
// BORROWING param must leave the source intact (the eager zeroing used to consume it and
// leak the buffer with no diagnostic), and an explicit `move` must select the `move`
// overload rather than the plain one.
int movePlain(string s)      { return (int)s.length(); }
int moveOwns(move string s)  { return (int)s.length(); }

int ovlPick(string s)        { return 1; }
int ovlPick(move string s)   { return 2; }

int testValueMoveArgDeferred()
{
    int passed = 0;

    // Borrowing param: the source keeps its buffer after the call.
    {
        string a = "hel" + "lo";
        int seen = movePlain(a);
        passed += Test("value_move_borrow_callee_sees_len", seen, 5);
        passed += Test("value_move_borrow_source_intact", (int)a.length(), 5);
    }

    // move param: ownership transfers, the source is left empty (moved-from).
    {
        string b = "wor" + "ld";
        int seen = moveOwns(move b);
        passed += Test("value_move_owner_callee_sees_len", seen, 5);
    }

    // Overload selection: a plain argument BORROWS, an explicit `move` picks the move
    // overload. This pair used to resolve exactly backwards.
    {
        string c = "abc" + "de";
        passed += Test("value_move_ovl_plain_arg_borrows", ovlPick(c), 1);
        string d = "fgh" + "ij";
        passed += Test("value_move_ovl_explicit_move_owns", ovlPick(move d), 2);
    }

    return passed;
}

// ---------------------------------------------------------------------------
// Move/borrow overload IDENTITY tests. These deliberately assert WHICH overload
// ran (via a distinct return code / copy counter), never a call count: a counting
// oracle cannot see a fully INVERTED borrow/move pair.
// ---------------------------------------------------------------------------

// Generic-substituted pointer params: Box<T>.put(T) borrows, put(move T) owns.
struct Box<T>
{
    int lastPick = 0;
    int put(T p)      { lastPick = 1; return 1; }
    int put(move T p) { lastPick = 2; delete p; return 2; }
};

int g_rvalCopies = 0;
class Tracked
{
    int id = default;
    Tracked copy() { g_rvalCopies = g_rvalCopies + 1; Tracked t = default; t.id = id; return t; }
};
Tracked makeTracked() { Tracked t = default; t.id = 9; return t; }

// Borrow overload deep-copies (as a copy-by-default container would); move transfers.
int rvalPick(Tracked v)      { Tracked keep = v.copy(); return 1; }
int rvalPick(move Tracked v) { return 2; }

int testPtrMoveOverloadIdentity()
{
    int passed = 0;

    // Plain call on an owning pointer BORROWS: the callee must not free it, and the
    // caller's pointer must NOT be marked moved (it is still readable afterwards).
    dtorCount = 0;
    {
        Resource* a = new Resource();
        a->id = 7;
        passed += Test("ptr_ovl_plain_picks_borrow", probe(a), 207);
        passed += Test("ptr_ovl_plain_not_moved", a->id, 7);   // still usable: not consumed
        passed += Test("ptr_ovl_plain_not_freed_yet", dtorCount, 0);
    }
    passed += Test("ptr_ovl_plain_freed_at_scope_exit", dtorCount, 1);

    // Explicit move picks the MOVE overload, which frees exactly once inside the call.
    dtorCount = 0;
    {
        Resource* b = new Resource();
        b->id = 8;
        passed += Test("ptr_ovl_explicit_move_picks_move", probe(move b), 108);
        passed += Test("ptr_ovl_explicit_move_freed_in_callee", dtorCount, 1);
    }
    passed += Test("ptr_ovl_explicit_move_freed_once", dtorCount, 1);

    // Same rules through a generic substitution (T = Resource*).
    dtorCount = 0;
    {
        Box<Resource*> box;
        Resource* c = new Resource();
        c->id = 3;
        passed += Test("generic_ptr_ovl_plain_picks_borrow", box.put(c), 1);
        passed += Test("generic_ptr_ovl_plain_not_freed", dtorCount, 0);
        delete c;
    }
    passed += Test("generic_ptr_ovl_borrow_freed_by_caller", dtorCount, 1);

    dtorCount = 0;
    {
        Box<Resource*> box;
        Resource* d = new Resource();
        d->id = 4;
        passed += Test("generic_ptr_ovl_explicit_move_picks_move", box.put(move d), 2);
        passed += Test("generic_ptr_ovl_move_freed_in_callee", dtorCount, 1);
    }
    passed += Test("generic_ptr_ovl_move_freed_once", dtorCount, 1);

    return passed;
}

int testRValuePrefersMoveOverload()
{
    int passed = 0;

    // An unnamed temporary prefers the MOVE overload (nothing to preserve), so the
    // borrow overload's deep copy is not paid.
    g_rvalCopies = 0;
    passed += Test("rvalue_arg_picks_move", rvalPick(makeTracked()), 2);
    passed += Test("rvalue_arg_no_copy", g_rvalCopies, 0);

    // A named lvalue still BORROWS - that is the semantics, and it must not regress.
    Tracked t = default;
    t.id = 3;
    g_rvalCopies = 0;
    passed += Test("named_lvalue_arg_picks_borrow", rvalPick(t), 1);
    passed += Test("named_lvalue_arg_copies", g_rvalCopies, 1);

    // Explicit move on a named lvalue picks the move overload, no copy.
    Tracked u = default;
    u.id = 4;
    g_rvalCopies = 0;
    passed += Test("named_lvalue_explicit_move_picks_move", rvalPick(move u), 2);
    passed += Test("named_lvalue_explicit_move_no_copy", g_rvalCopies, 0);

    return passed;
}

extern int main()
{
    int passed = 0;
    int total  = 0;

    // Test 1: move param causes destructor to fire when function returns
    dtorCount = 0;
    {
        Resource* r = new Resource();
        r->id = 42;
        borrow(r);
        consume(r);
    }
    passed += Test("move_borrow_no_dtor", dtorCount, 1);
    total++;

    // Test 2: move param with null - no crash (null check in cleanup)
    dtorCount = 0;
    {
        Resource* r = new Resource();
        consume(r);
    }
    passed += Test("move_null_safe", dtorCount, 1);
    total++;

    // Test 3: new-allocated local auto-freed at scope exit (no escape)
    dtorCount = 0;
    {
        Resource* r = new Resource();
    }
    passed += Test("new_local_auto_free", dtorCount, 1);
    total++;

    // Test 4: new local assigned to struct field - not freed early; freed when owner is destroyed
    dtorCount = 0;
    {
        Container* c = new Container();
        {
            Resource* r = new Resource();
            c->item = r;
            // r exits scope: refcount 2->1, no free
        }
        passed += Test("stack_to_field_no_early_free", dtorCount, 0);
        total++;
        // c exits scope: auto-freed, ~Container() frees c->item -> dtorCount = 1
    }
    passed += Test("stack_to_field_freed_with_owner", dtorCount, 1);
    total++;

    passed += testListStringMove();
    total += 10;

    // Test 5: move T* return - caller receives ownership, pointer freed at scope exit
    dtorCount = 0;
    {
        Resource* r = createResource(7);
    }
    passed += Test("move_return_new_freed", dtorCount, 1);
    total++;

    // Test 6: move T* return - forward through move param, freed once
    dtorCount = 0;
    {
        Resource* r = createResource(8);
        Resource* r2 = forwardResource(r);
    }
    passed += Test("move_return_forward_freed_once", dtorCount, 1);
    total++;

    // Test 6a: move-in-loop with reassign each iteration. The reassignment revives the
    // pointer across the back-edge, so this is NOT a loop-carried use-after-move and must
    // compile clean (guards the move-dataflow pass against a false positive).
    dtorCount = 0;
    {
        Resource* r = new Resource();
        int i = 0;
        while (i < 3)
        {
            consume(r);          // moves + frees r (dtor +1)
            r = new Resource();  // revive: fresh owner for the next iteration
            i = i + 1;
        }
        consume(r);              // free the last one
    }
    passed += Test("move_loop_reassign_revive", dtorCount, 4);
    total++;

    // Test 6b: fresh owning local declared inside the loop each iteration - the binding
    // dominates every use, so no loop-carried move; must compile clean.
    dtorCount = 0;
    {
        int i = 0;
        while (i < 3)
        {
            Resource* q = new Resource();
            consume(q);
            i = i + 1;
        }
    }
    passed += Test("move_loop_fresh_local", dtorCount, 3);
    total++;

    // Worker-style ownership transfer (mirrors repro_new_struct.cb without threads).
    // Caller 'new's a Slot, hands it to a function via 'move'; callee writes through
    // ->slot and returns. Expect exactly one destructor, observed value updated.
    dtorCount = 0;
    {
        int observed = 0;
        Slot* p = new Slot();
        p->slot  = &observed;
        p->value = 42;
        int got = workerMove(p);
        passed += Test("worker_move_return", got, 42);
        total++;
        passed += Test("worker_move_observed", observed, 42);
        total++;
        // p is nulled by 'move'; scope exit is a no-op. Exactly one free inside workerMove.
    }
    passed += Test("worker_move_freed_once", dtorCount, 1);
    total++;

    // Same shape, but the callee calls 'delete' explicitly. ParseDeleteExpression
    // nulls the parameter's alloca so scope-exit cleanup skips - still one free.
    dtorCount = 0;
    {
        int observed = 0;
        Slot* p = new Slot();
        p->slot  = &observed;
        p->value = 7;
        int got = workerMoveDelete(p);
        passed += Test("worker_move_delete_return", got, 7);
        total++;
        passed += Test("worker_move_delete_observed", observed, 7);
        total++;
    }
    passed += Test("worker_move_delete_freed_once", dtorCount, 1);
    total++;

    // Test 7: list<unique T*> OWNS its elements - removeAt frees one in place, the
    // destructor frees the rest. take() went away with the borrow-by-default list:
    // extraction from an owning container is deliberately undesigned (plan item 5).
    dtorCount = 0;
    {
        list<unique Resource*> items;
        Resource* a = new Resource();
        Resource* b = new Resource();
        items.add(a);
        items.add(b);
        items.removeAt(0);
        passed += Test("list_removeAt_owned_freed", dtorCount, 1);
        total++;
        // list goes out of scope; remaining element (b) freed by list destructor
    }
    passed += Test("list_dtor_remaining_freed", dtorCount, 2);
    total++;

    // Test 8: move-vs-borrow overload selection via a second, unrelated function
    // (delegateProbe). probe()'s own plain/move overload pair is covered by
    // testPtrMoveOverloadIdentity() below (ptr_ovl_plain_picks_borrow /
    // ptr_ovl_explicit_move_picks_move), which also asserts the borrowed pointer stays
    // usable after the call - removed the redundant probe() duplicate that used to sit here.
    // Borrowed pointer (non-move param) -> picks 'borrow' overload (returns 200+id, no free).
    dtorCount = 0;
    {
        Resource* b = new Resource();
        b->id = 9;
        int v = delegateProbe(b);
        passed += Test("probe_picks_borrow_for_non_owning", v, 209);
        total++;
        // b still owned here; freed at scope exit.
    }
    passed += Test("probe_borrow_freed_at_scope_exit", dtorCount, 1);
    total++;

    // Test 9: composite-ownership cleanup. Bag owns 'item' (Resource*) and
    // 'entries' (RouteEntry[3]). Each layer's destructor frees only its own
    // fields; ~Bag's 'delete[3] entries' invokes ~RouteEntry on every slot,
    // which frees its own 'name'. No layer reaches into another's fields.
    dtorCount = 0;
    {
        Bag bag;
        bag.item = new Resource();
        bag.item->id = 1;
        bag.entries = new RouteEntry[3];
        int i = 0;
        while (i < 3)
        {
            bag.entries[i].name = new Resource();
            bag.entries[i].name->id = i + 10;
            i = i + 1;
        }
        // 4 Resources alive: bag.item plus three entry names.
        // Scope exit -> ~Bag frees item, delete[3] entries -> ~RouteEntry per slot
        // frees each name. dtorCount should reach 4.
    }
    passed += Test("composite_dtor_chain_frees_all", dtorCount, 4);
    total++;

    passed += testRecursiveTreeFree();
    total += 1;

    passed += testDeleteNullCascade();
    total += 1;

    passed += testRecursiveContainerFree();
    total += 1;

    passed += testFieldOwnership();
    total += 7;

    passed += testUniqueField();
    total += 44;

    passed += testParamStringToField();
    total += 1;

    passed += testStructWithStringFieldIntoList();
    total += 2;

    passed += testBorrowStringFieldIntoLocal();
    total += 3;

    passed += testUniqueLocalAndParam();
    total += 4;

    passed += testValueMoveArgDeferred();
    total += 5;

    passed += testPtrMoveOverloadIdentity();
    total += 13;

    passed += testRValuePrefersMoveOverload();
    total += 6;

    printf("\n%d / %d tests passed.\n", passed, total);
    return passed == total ? 0 : 1;
}
