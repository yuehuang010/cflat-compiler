import "test_helper.cb";

struct Point
{
    int x = 0;
    int y = 0;
};

struct Container
{
    Point* inner = nullptr;
};

// ---------------------------------------------------------------------------
// Nullable pointer (Point?) tests
// ---------------------------------------------------------------------------

bool testNullableDefault() {
    bool result = true;
    Point? p;
    result &= Test("nullable default is nullptr", (int)(p == nullptr), 1);
    return result;
}

bool testNullableAssign() {
    bool result = true;
    Point? p;
    Point pt = Point();
    pt.x = 10;
    pt.y = 20;
    p = &pt;
    result &= Test("nullable after assign not nullptr", (int)(p != nullptr), 1);
    result &= Test("nullable ?.x access", p?.x, 10);
    p = nullptr;
    result &= Test("nullable reset to nullptr", (int)(p == nullptr), 1);
    return result;
}

// ---------------------------------------------------------------------------
// Null-conditional (?.) on raw pointer locals and struct member fields
// ---------------------------------------------------------------------------

bool testLocalPtr() {
    bool result = true;
    Point pt;
    pt.x = 42;
    Point* p = &pt;
    result &= Test("?. on local ptr", p?.x, 42);
    return result;
}

bool testNullLocalPtr() {
    bool result = true;
    Point* p = nullptr;
    result &= Test("?. on null local ptr gives 0", p?.x, 0);
    return result;
}

bool testMemberPtr() {
    bool result = true;
    Point pt;
    pt.x = 99;
    Container c;
    c.inner = &pt;
    result &= Test("?. on member ptr", c.inner?.x, 99);
    return result;
}

bool testNullMemberPtr() {
    bool result = true;
    Container c;
    result &= Test("?. on null member ptr gives 0", c.inner?.x, 0);
    return result;
}

// ---------------------------------------------------------------------------
// Entry point
// ---------------------------------------------------------------------------

extern int main()
{
    int passed = 0;
    int total  = 0;

    total++; passed += testNullableDefault()  ? 1 : 0;
    total++; passed += testNullableAssign()   ? 1 : 0;
    total++; passed += testLocalPtr()         ? 1 : 0;
    total++; passed += testNullLocalPtr()     ? 1 : 0;
    total++; passed += testMemberPtr()        ? 1 : 0;
    total++; passed += testNullMemberPtr()    ? 1 : 0;

    printf("Nullable tests: %d/%d passed.\n", passed, total);
    return passed == total ? 0 : 1;
}
