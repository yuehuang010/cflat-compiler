import "test_helper.cb";
import "thread.cb";
import "mutex.cb";
import "atomic.cb";
import "semaphore.cb";
import "latch.cb";
import "rwlock.cb";
import "channel.cb";
import "spsc_queue.cb";

// ---------------------------------------------------------------------------
// Thread tests
// ---------------------------------------------------------------------------

int writeToPtr(void* ctx) {
    int* p = (int*)ctx;
    *p = 99;
    return 0;
}

int readFromPtr(void* ctx) {
    int* p = (int*)ctx;
    return *p;
}

struct ComputeCtx {
    int input  = 0;
    int output = 0;
};

// Move-overload: ownership of the heap-allocated payload transfers from the
// caller into Thread.start, then via the trampoline into consume_payload, which
// is responsible for freeing it. The caller's pointer is auto-nulled.
struct MoveThreadPayload {
    int* slot  = nullptr;
    int  value = 0;
};

int g_move_thread_payload_dtors = 0;

int consume_thread_payload(move void* ctx) {
    MoveThreadPayload* p = (MoveThreadPayload*)ctx;   // cast transfers ownership ctx -> p
    *p->slot = p->value;
    int v = p->value;
    g_move_thread_payload_dtors = g_move_thread_payload_dtors + 1;
    // p owns the payload; scope-exit cleanup (operator delete) frees it once.
    return v;
}

bool testThreadStartMoveOwnership() {
    bool result = true;
    g_move_thread_payload_dtors = 0;
    int observed = 0;
    MoveThreadPayload* p = new MoveThreadPayload();
    p->slot  = &observed;
    p->value = 1234;
    Thread t;
    t.start(consume_thread_payload, (void*)p);   // ownership transfers into thread
    i32 code = t.join();
    result &= Test("move start observed", observed, 1234);
    result &= Test("move start exit code", code, 1234);
    result &= Test("move start freed once", g_move_thread_payload_dtors, 1);
    return result;
}

int computeSquare(void* ctx) {
    ComputeCtx* c = (ComputeCtx*)ctx;
    c->output = c->input * c->input;
    return 0;
}

bool testThreadWritesThroughPointer() {
    bool result = true;
    int value = 0;
    Thread t;
    t.start(writeToPtr, &value);
    t.join();
    result &= Test("write through ptr", value, 99);
    return result;
}

bool testThreadReadsThroughPointer() {
    bool result = true;
    int value = 42;
    Thread t;
    t.start(readFromPtr, &value);
    i32 code = t.join();
    result &= Test("read through ptr", code, 42);
    return result;
}

bool testThreadExitCode() {
    bool result = true;
    Thread t;
    t.start((void* ctx) => { return 42; }, nullptr);
    i32 code = t.join();
    result &= Test("exit code 42", code, 42);
    return result;
}

bool testMultipleThreadsConcurrent() {
    bool result = true;
    int a = 0;
    int b = 0;
    int c = 0;
    Thread t1;
    Thread t2;
    Thread t3;
    t1.start(writeToPtr, &a);
    t2.start(writeToPtr, &b);
    t3.start(writeToPtr, &c);
    t1.join();
    t2.join();
    t3.join();
    result &= Test("concurrent thread 1", a, 99);
    result &= Test("concurrent thread 2", b, 99);
    result &= Test("concurrent thread 3", c, 99);
    return result;
}

bool testLambdaWritesViaCtx() {
    bool result = true;
    int value = 0;
    Thread t;
    t.start((void* ctx) => {
        int* p = (int*)ctx;
        *p = 123;
        return 0;
    }, &value);
    t.join();
    result &= Test("lambda writes via ctx", value, 123);
    return result;
}

bool testLambdaExitCodeFromCtx() {
    bool result = true;
    int value = 10;
    Thread t;
    t.start((void* ctx) => {
        int* p = (int*)ctx;
        return *p * 3;
    }, &value);
    i32 code = t.join();
    result &= Test("lambda exit code from ctx", code, 30);
    return result;
}

bool testThreadComputationViaStruct() {
    bool result = true;
    ComputeCtx ctx;
    ctx.input  = 7;
    ctx.output = 0;
    Thread t;
    t.start(computeSquare, &ctx);
    t.join();
    result &= Test("named fn computes square", ctx.output, 49);
    return result;
}

bool testLambdaComputationViaStruct() {
    bool result = true;
    ComputeCtx ctx;
    ctx.input  = 5;
    ctx.output = 0;
    Thread t;
    t.start((void* vctx) => {
        ComputeCtx* c = (ComputeCtx*)vctx;
        c->output = c->input * c->input;
        return 0;
    }, &ctx);
    t.join();
    result &= Test("lambda computes square", ctx.output, 25);
    return result;
}

bool testSequentialThreads() {
    bool result = true;
    int a = 0;
    int b = 0;
    Thread t1;
    t1.start(writeToPtr, &a);
    t1.join();
    Thread t2;
    t2.start(writeToPtr, &b);
    t2.join();
    result &= Test("sequential thread 1", a, 99);
    result &= Test("sequential thread 2", b, 99);
    return result;
}

bool testThreadExitCodeZero() {
    bool result = true;
    Thread t;
    t.start((void* ctx) => { return 0; }, nullptr);
    i32 code = t.join();
    result &= Test("exit code 0", code, 0);
    return result;
}

bool testMultipleThreadsCompute() {
    bool result = true;
    ComputeCtx c0; c0.input = 1; c0.output = 0;
    ComputeCtx c1; c1.input = 2; c1.output = 0;
    ComputeCtx c2; c2.input = 3; c2.output = 0;
    ComputeCtx c3; c3.input = 4; c3.output = 0;
    ComputeCtx c4; c4.input = 5; c4.output = 0;
    Thread t0; Thread t1; Thread t2; Thread t3; Thread t4;
    t0.start(computeSquare, &c0);
    t1.start(computeSquare, &c1);
    t2.start(computeSquare, &c2);
    t3.start(computeSquare, &c3);
    t4.start(computeSquare, &c4);
    t0.join(); t1.join(); t2.join(); t3.join(); t4.join();
    result &= Test("parallel compute 1^2", c0.output,  1);
    result &= Test("parallel compute 2^2", c1.output,  4);
    result &= Test("parallel compute 3^2", c2.output,  9);
    result &= Test("parallel compute 4^2", c3.output, 16);
    result &= Test("parallel compute 5^2", c4.output, 25);
    return result;
}

// ---------------------------------------------------------------------------
// mutex + lock statement tests
// ---------------------------------------------------------------------------

struct MutexIntCtx {
    void* m = nullptr;  // mutex*
    int*  v = nullptr;
};

int incrementShared(void* ctx) {
    MutexIntCtx* mi = (MutexIntCtx*)ctx;
    mutex* mp = (mutex*)mi->m;
    lock (*mp) {
        *mi->v = *mi->v + 1;
    }
    return 0;
}

bool testMutexManual() {
    bool result = true;
    mutex m;
    int counter = 0;
    m.acquire();
    counter = counter + 1;
    m.release();
    result &= Test("mutex manual acquire/release", counter, 1);
    m.destroy();
    return result;
}

bool testLockStatement() {
    bool result = true;
    mutex m;
    int counter = 0;
    lock (m) {
        counter = counter + 1;
    }
    result &= Test("lock statement", counter, 1);
    m.destroy();
    return result;
}

bool testLockBreak() {
    bool result = true;
    mutex m;
    int i = 0;
    while (i < 3) {
        lock (m) {
            if (i == 1) break;
        }
        i++;
    }
    // If break didn't release, acquire() would deadlock.
    m.acquire();
    m.release();
    result &= Test("lock break releases mutex", i, 1);
    m.destroy();
    return result;
}

bool testLockContinue() {
    bool result = true;
    mutex m;
    int count = 0;
    int i = 0;
    while (i < 5) {
        i++;
        lock (m) {
            if (i % 2 == 0) continue;
            count++;
        }
    }
    // If continue didn't release, acquire() would deadlock.
    m.acquire();
    m.release();
    result &= Test("lock continue releases mutex", count, 3);
    m.destroy();
    return result;
}

bool testNestedLockBreak() {
    bool result = true;
    mutex m1;
    mutex m2;
    int i = 0;
    while (i < 3) {
        lock (m1) {
            lock (m2) {
                if (i == 1) break;
            }
        }
        i++;
    }
    m1.acquire();
    m1.release();
    m2.acquire();
    m2.release();
    result &= Test("nested lock break releases both mutexes", i, 1);
    m1.destroy();
    m2.destroy();
    return result;
}

bool testMutexWithThreads() {
    bool result = true;
    mutex m;
    int value = 0;
    MutexIntCtx mi;
    mi.m = (void*)&m;
    mi.v = &value;

    Thread t1;
    Thread t2;
    t1.start(incrementShared, &mi);
    t2.start(incrementShared, &mi);
    t1.join();
    t2.join();

    result &= Test("mutex with threads", value, 2);
    m.destroy();
    return result;
}

// ---------------------------------------------------------------------------
// atomic_counter tests
// ---------------------------------------------------------------------------

struct AtomicCtx {
    atomic_counter* counter = nullptr;
    int iterations = 0;
};

int atomicIncrementWorker(void* ctx) {
    AtomicCtx* ac = (AtomicCtx*)ctx;
    int i = 0;
    while (i < ac->iterations) {
        ac->counter->increment();
        i = i + 1;
    }
    return 0;
}

bool testAtomicCounterIncrement() {
    bool result = true;
    atomic_counter c;
    c.increment();
    c.increment();
    c.increment();
    result &= Test("atomic increment x3", (int)c.read(), 3);
    return result;
}

bool testAtomicCounterDecrement() {
    bool result = true;
    atomic_counter c;
    c.increment();
    c.increment();
    c.decrement();
    result &= Test("atomic decrement", (int)c.read(), 1);
    return result;
}

bool testAtomicCounterAdd() {
    bool result = true;
    atomic_counter c;
    c.add(10);
    c.add(5);
    result &= Test("atomic add", (int)c.read(), 15);
    return result;
}

bool testAtomicCounterThreaded() {
    bool result = true;
    atomic_counter counter;

    AtomicCtx ctx1; ctx1.counter = &counter; ctx1.iterations = 100;
    AtomicCtx ctx2; ctx2.counter = &counter; ctx2.iterations = 100;
    AtomicCtx ctx3; ctx3.counter = &counter; ctx3.iterations = 100;
    AtomicCtx ctx4; ctx4.counter = &counter; ctx4.iterations = 100;
    AtomicCtx ctx5; ctx5.counter = &counter; ctx5.iterations = 100;

    Thread t1; Thread t2; Thread t3; Thread t4; Thread t5;
    t1.start(atomicIncrementWorker, &ctx1);
    t2.start(atomicIncrementWorker, &ctx2);
    t3.start(atomicIncrementWorker, &ctx3);
    t4.start(atomicIncrementWorker, &ctx4);
    t5.start(atomicIncrementWorker, &ctx5);
    t1.join(); t2.join(); t3.join(); t4.join(); t5.join();

    result &= Test("atomic counter 5 threads x100", (int)counter.read(), 500);
    return result;
}

bool testAtomicFlag() {
    bool result = true;
    atomic_flag flag;

    bool was_set = flag.test_and_set();
    result &= Test("flag initially clear", (int)was_set, 0);

    bool still_set = flag.test_and_set();
    result &= Test("flag was set", (int)still_set, 1);

    flag.clear();

    bool after_clear = flag.test_and_set();
    result &= Test("flag after clear", (int)after_clear, 0);
    flag.clear();
    return result;
}

bool testAtomicI32() {
    bool result = true;
    atomic__i32 a;
    a.store(42);
    result &= Test("atomic i32 store/load", a.load(), 42);

    bool ok = a.cas(42, 99);
    result &= Test("atomic i32 cas success", (int)ok, 1);
    result &= Test("atomic i32 cas result", a.load(), 99);

    bool fail = a.cas(0, 1);
    result &= Test("atomic i32 cas fail", (int)fail, 0);
    result &= Test("atomic i32 unchanged", a.load(), 99);
    return result;
}

bool testAtomicI64() {
    bool result = true;
    atomic__i64 a;
    a.store(1000000000000);
    result &= Test("atomic i64 store/load", (int)(a.load() == 1000000000000), 1);

    bool ok = a.cas(1000000000000, 2000000000000);
    result &= Test("atomic i64 cas success", (int)ok, 1);
    result &= Test("atomic i64 cas result", (int)(a.load() == 2000000000000), 1);
    return result;
}

// ---------------------------------------------------------------------------
// atomic release/acquire guard tests
// ---------------------------------------------------------------------------

struct FlagGuarded {
    atomic__i32 ready = default;
    lock(ready) {
        int value = 0;
        int value2 = 0;
    }
};

struct I32Guarded {
    atomic__i32 version = default;
    lock(version) {
        int data = 0;
    }
};

int flagReleaseWorker(void* ctx) {
    FlagGuarded* s = (FlagGuarded*)ctx;
    s->ready.release(1, () => {
        s->value  = 42;
        s->value2 = 99;
    });
    return 0;
}

bool testAtomicFlagReleaseAcquire() {
    bool result = true;
    FlagGuarded s;
    Thread t;
    t.start(flagReleaseWorker, &s);
    while (s.ready.load() == 0) { }
    s.ready.acquire((i32 v) => {
        result &= Test("atomic release/acquire value",  s.value,  42);
        result &= Test("atomic release/acquire value2", s.value2, 99);
        result &= Test("atomic release/acquire loaded", (int)v, 1);
    });
    t.join();
    return result;
}

int i32ReleaseWorker(void* ctx) {
    I32Guarded* s = (I32Guarded*)ctx;
    s->version.release(1, () => {
        s->data = 77;
    });
    return 0;
}

bool testAtomicI32ReleaseAcquire() {
    bool result = true;
    I32Guarded s;
    Thread t;
    t.start(i32ReleaseWorker, &s);
    while (s.version.load() == 0) { }
    s.version.acquire((i32 v) => {
        result &= Test("i32 release/acquire data",    s.data, 77);
        result &= Test("i32 release/acquire version", (int)v, 1);
    });
    t.join();
    return result;
}

// ---------------------------------------------------------------------------
// semaphore tests
// ---------------------------------------------------------------------------

struct SemCtx {
    void* sem = nullptr;  // semaphore*
};

int semSignalWorker(void* ctx) {
    SemCtx* sc = (SemCtx*)ctx;
    semaphore* sp = (semaphore*)sc->sem;
    sp->release();
    return 0;
}

bool testSemaphoreBasic() {
    bool result = true;
    semaphore s;
    s.init(3, 10);

    s.acquire();
    s.acquire();
    s.acquire();

    s.release();
    s.release();
    s.release();

    result &= Test("semaphore basic acquire/release", 1, 1);
    s.destroy();
    return result;
}

bool testSemaphoreWithThreads() {
    bool result = true;
    semaphore s;
    s.init(0, 10);

    SemCtx ctx;
    ctx.sem = (void*)&s;

    Thread t1;
    Thread t2;
    t1.start(semSignalWorker, &ctx);
    t2.start(semSignalWorker, &ctx);

    s.acquire();
    s.acquire();

    t1.join();
    t2.join();

    result &= Test("semaphore threaded signal", 1, 1);
    s.destroy();
    return result;
}

bool testSemaphoreLockStatement() {
    bool result = true;
    semaphore s;
    s.init(1, 1);

    int counter = 0;
    lock (s) {
        counter = counter + 1;
    }
    result &= Test("semaphore lock statement", counter, 1);
    s.destroy();
    return result;
}

// ---------------------------------------------------------------------------
// latch tests
// ---------------------------------------------------------------------------

struct LatchCtx {
    void* lch   = nullptr;  // latch*
    int*  steps = nullptr;
};

int latchWorker(void* ctx) {
    LatchCtx* lc = (LatchCtx*)ctx;
    latch* lp = (latch*)lc->lch;
    *lc->steps = *lc->steps + 1;
    lp->count_down();
    return 0;
}

bool testLatchBasic() {
    bool result = true;
    latch l;
    l.init(1);
    l.count_down();
    l.wait();
    result &= Test("latch count_down once then wait", 1, 1);
    l.destroy();
    return result;
}

bool testLatchWithThreads() {
    bool result = true;
    latch l;
    l.init(3);
    int steps = 0;

    LatchCtx ctx;
    ctx.lch   = (void*)&l;
    ctx.steps = &steps;

    Thread t1;
    Thread t2;
    Thread t3;
    t1.start(latchWorker, &ctx);
    t2.start(latchWorker, &ctx);
    t3.start(latchWorker, &ctx);

    l.wait();

    t1.join();
    t2.join();
    t3.join();

    result &= Test("latch 3 threads", steps, 3);
    l.destroy();
    return result;
}

bool testLatchAlreadyZero() {
    bool result = true;
    latch l;
    l.init(1);
    l.count_down();
    l.wait();
    l.wait();
    result &= Test("latch wait idempotent", 1, 1);
    l.destroy();
    return result;
}

// ---------------------------------------------------------------------------
// rwlock tests
// ---------------------------------------------------------------------------

struct RwCtx {
    void* rw  = nullptr;  // rwlock*
    int*  val = nullptr;
    int   add = 0;
};

int rwWriterWorker(void* ctx) {
    RwCtx* rc = (RwCtx*)ctx;
    rwlock* rp = (rwlock*)rc->rw;
    rp->acquire_write();
    *rc->val = *rc->val + rc->add;
    rp->release_write();
    return 0;
}

bool testRwlockExclusive() {
    bool result = true;
    rwlock rw;
    int shared = 0;

    rw.acquire_write();
    shared = 42;
    rw.release_write();

    result &= Test("rwlock exclusive write", shared, 42);
    return result;
}

bool testRwlockShared() {
    bool result = true;
    rwlock rw;
    int shared = 99;

    rw.acquire_read();
    rw.acquire_read();
    int val1 = shared;
    int val2 = shared;
    rw.release_read();
    rw.release_read();

    result &= Test("rwlock shared read", val1, 99);
    result &= Test("rwlock shared read 2", val2, 99);
    return result;
}

bool testRwlockLockStatement() {
    bool result = true;
    rwlock rw;
    int shared = 0;

    lock (rw) {
        shared = 77;
    }
    result &= Test("rwlock lock statement (write)", shared, 77);
    return result;
}

bool testRwlockWithThreads() {
    bool result = true;
    rwlock rw;
    int value = 0;

    RwCtx ctx1; ctx1.rw = (void*)&rw; ctx1.val = &value; ctx1.add = 10;
    RwCtx ctx2; ctx2.rw = (void*)&rw; ctx2.val = &value; ctx2.add = 5;

    Thread t1;
    Thread t2;
    t1.start(rwWriterWorker, &ctx1);
    t2.start(rwWriterWorker, &ctx2);
    t1.join();
    t2.join();

    result &= Test("rwlock two writer threads", value, 15);
    return result;
}

// ---------------------------------------------------------------------------
// channel<int> tests
// ---------------------------------------------------------------------------

struct ChanCtx {
    void* ch    = nullptr;  // channel<int>*
    int   start = 0;
    int   count = 0;
};

int chanProducer(void* ctx) {
    ChanCtx* cc = (ChanCtx*)ctx;
    channel<int>* chp = (channel<int>*)cc->ch;
    int i = 0;
    while (i < cc->count) {
        chp->send(cc->start + i);
        i++;
    }
    return 0;
}

int chanConsumerSum(void* ctx) {
    ChanCtx* cc = (ChanCtx*)ctx;
    channel<int>* chp = (channel<int>*)cc->ch;
    int sum = 0;
    int i = 0;
    while (i < cc->count) {
        sum = sum + chp->receive();
        i++;
    }
    return sum;
}

bool testChannelBasicSendReceive() {
    bool result = true;
    channel<int> ch;
    ch.init(4);

    ch.send(10);
    ch.send(20);
    ch.send(30);

    result &= Test("channel recv 1", ch.receive(), 10);
    result &= Test("channel recv 2", ch.receive(), 20);
    result &= Test("channel recv 3", ch.receive(), 30);
    result &= Test("channel capacity", ch.capacity(), 4);

    ch.destroy();
    return result;
}

bool testChannelCount() {
    bool result = true;
    channel<int> ch;
    ch.init(8);

    ch.send(1);
    ch.send(2);
    result &= Test("channel count after 2 sends", ch.count(), 2);

    ch.receive();
    result &= Test("channel count after 1 recv", ch.count(), 1);

    ch.destroy();
    return result;
}

bool testChannelTryReceive() {
    bool result = true;
    channel<int> ch;
    ch.init(4);

    int out = 0;
    bool ok = ch.try_receive(&out);
    result &= Test("try_receive empty returns false", (int)ok, 0);

    ch.send(99);
    ok = ch.try_receive(&out);
    result &= Test("try_receive gets value", (int)ok, 1);
    result &= Test("try_receive correct value", out, 99);

    ch.destroy();
    return result;
}

bool testChannelWrapAround() {
    bool result = true;
    channel<int> ch;
    ch.init(3);

    ch.send(1); ch.send(2); ch.send(3);
    result &= Test("wrap recv 1", ch.receive(), 1);
    result &= Test("wrap recv 2", ch.receive(), 2);
    ch.send(4); ch.send(5);
    result &= Test("wrap recv 3", ch.receive(), 3);
    result &= Test("wrap recv 4", ch.receive(), 4);
    result &= Test("wrap recv 5", ch.receive(), 5);

    ch.destroy();
    return result;
}

bool testChannelProducerConsumer() {
    bool result = true;
    channel<int> ch;
    ch.init(8);

    ChanCtx pctx; pctx.ch = (void*)&ch; pctx.start = 1; pctx.count = 5;
    ChanCtx cctx; cctx.ch = (void*)&ch; cctx.start = 0; cctx.count = 5;

    Thread producer;
    Thread consumer;
    producer.start(chanProducer,    &pctx);
    consumer.start(chanConsumerSum, &cctx);

    producer.join();
    i32 sum = consumer.join();

    result &= Test("channel producer/consumer sum", (int)sum, 15);
    ch.destroy();
    return result;
}

bool testChannelMultiProducer() {
    bool result = true;
    channel<int> ch;
    ch.init(16);

    ChanCtx p1ctx; p1ctx.ch = (void*)&ch; p1ctx.start = 0;  p1ctx.count = 5;
    ChanCtx p2ctx; p2ctx.ch = (void*)&ch; p2ctx.start = 10; p2ctx.count = 5;
    ChanCtx cctx;  cctx.ch  = (void*)&ch; cctx.start  = 0;  cctx.count  = 10;

    Thread p1; Thread p2; Thread consumer;
    p1.start(chanProducer,    &p1ctx);
    p2.start(chanProducer,    &p2ctx);
    consumer.start(chanConsumerSum, &cctx);

    p1.join(); p2.join();
    i32 sum = consumer.join();

    result &= Test("channel multi-producer sum", (int)sum, 70);
    ch.destroy();
    return result;
}

// channel<T>::operator>> (pipe) + producer-refcount close protocol.
// Borrow semantics: a >> b spawns a forwarder that drains a into b; when a's
// last producer closes, the forwarder drains and closes b.

// Single-stage pipe preserves order and count; closing src closes dst.
bool testChannelPipeSingle() {
    bool result = true;
    channel<int>* src = new channel<int>();
    channel<int>* dst = new channel<int>();
    src.init(64);
    dst.init(64);

    src >> dst;

    src.add_producer();
    int i = 0;
    while (i < 100) { src.push(i); i = i + 1; }
    src.close_producer();

    int expected = 0;
    int v        = 0;
    int count    = 0;
    int ordered  = 1;
    while (dst.receive(&v)) {
        if (v != expected) { ordered = 0; }
        expected = expected + 1;
        count    = count + 1;
    }
    result &= Test("pipe_single_count", count, 100);
    result &= Test("pipe_single_order", ordered, 1);
    return result;
}

// Two-stage pipe src -> mid -> dst: EOF must propagate through both forwarders.
bool testChannelPipeChained() {
    bool result = true;
    channel<int>* src = new channel<int>();
    channel<int>* mid = new channel<int>();
    channel<int>* dst = new channel<int>();
    src.init(64);
    mid.init(64);
    dst.init(64);

    src >> mid;
    mid >> dst;

    src.add_producer();
    int i      = 0;
    int sum_in = 0;
    while (i < 50) { src.push(i); sum_in = sum_in + i; i = i + 1; }
    src.close_producer();

    int v       = 0;
    int sum_out = 0;
    int count   = 0;
    while (dst.receive(&v)) { sum_out = sum_out + v; count = count + 1; }

    result &= Test("pipe_chain_count", count, 50);
    result &= Test("pipe_chain_sum", sum_out, sum_in);
    return result;
}

// An empty source closed with no items must still close the destination.
bool testChannelPipeEmpty() {
    channel<int>* src = new channel<int>();
    channel<int>* dst = new channel<int>();
    src.init(16);
    dst.init(16);

    src >> dst;
    src.add_producer();
    src.close_producer();

    int v     = 0;
    int count = 0;
    while (dst.receive(&v)) { count = count + 1; }
    return Test("pipe_empty_count", count, 0) != 0;
}

// ---------------------------------------------------------------------------
// spsc_queue<int> tests
// ---------------------------------------------------------------------------

struct SpscCtx {
    void* q     = nullptr;  // spsc_queue<int>*
    int   items = 0;
};

int spscProducer(void* ctx) {
    SpscCtx* sc = (SpscCtx*)ctx;
    spsc_queue<int>* qp = (spsc_queue<int>*)sc->q;
    int i = 1;
    while (i <= sc->items) {
        while (!qp->try_push(i)) { }
        i++;
    }
    return 0;
}

int spscConsumer(void* ctx) {
    SpscCtx* sc = (SpscCtx*)ctx;
    spsc_queue<int>* qp = (spsc_queue<int>*)sc->q;
    int sum = 0;
    int i = 0;
    int out = 0;
    while (i < sc->items) {
        while (!qp->try_pop(&out)) { }
        sum = sum + out;
        i++;
    }
    return sum;
}

bool testSpscBasic() {
    bool result = true;
    spsc_queue<int> q;
    q.init(4);

    result &= Test("spsc empty initially", (int)q.is_empty(), 1);

    bool ok = q.try_push(10);
    result &= Test("spsc push 1", (int)ok, 1);
    ok = q.try_push(20);
    result &= Test("spsc push 2", (int)ok, 1);
    ok = q.try_push(30);
    result &= Test("spsc push 3", (int)ok, 1);
    ok = q.try_push(40);
    result &= Test("spsc push 4", (int)ok, 1);
    result &= Test("spsc full", (int)q.is_full(), 1);

    ok = q.try_push(99);
    result &= Test("spsc push when full fails", (int)ok, 0);

    int out = 0;
    q.try_pop(&out); result &= Test("spsc pop 1", out, 10);
    q.try_pop(&out); result &= Test("spsc pop 2", out, 20);
    q.try_pop(&out); result &= Test("spsc pop 3", out, 30);
    q.try_pop(&out); result &= Test("spsc pop 4", out, 40);

    result &= Test("spsc empty after drain", (int)q.is_empty(), 1);

    ok = q.try_pop(&out);
    result &= Test("spsc pop when empty fails", (int)ok, 0);

    result &= Test("spsc capacity", q.capacity(), 4);

    q.destroy();
    return result;
}

bool testSpscWrapAround() {
    bool result = true;
    spsc_queue<int> q;
    q.init(3);

    q.try_push(1); q.try_push(2); q.try_push(3);
    int out = 0;
    q.try_pop(&out);
    q.try_push(4);
    q.try_pop(&out); result &= Test("wrap pop 2", out, 2);
    q.try_pop(&out); result &= Test("wrap pop 3", out, 3);
    q.try_pop(&out); result &= Test("wrap pop 4", out, 4);

    q.destroy();
    return result;
}

bool testSpscThreaded() {
    bool result = true;
    spsc_queue<int> q;
    q.init(64);

    SpscCtx pctx; pctx.q = (void*)&q; pctx.items = 100;
    SpscCtx cctx; cctx.q = (void*)&q; cctx.items = 100;

    Thread producer;
    Thread consumer;
    producer.start(spscProducer, &pctx);
    consumer.start(spscConsumer, &cctx);

    producer.join();
    i32 sum = consumer.join();

    result &= Test("spsc threaded sum 1..100", (int)sum, 5050);
    q.destroy();
    return result;
}

// ---------------------------------------------------------------------------
// Embedded sub-struct initialization tests
// ---------------------------------------------------------------------------

struct WithEmbeddedFlag {
    int    value = 0;
    atomic_flag flag;   // no = default - tests sub-struct auto-init
    int    other = 7;
};

struct WithEmbeddedCounter {
    atomic_counter hits;  // no = default
};

bool testEmbeddedAtomicFlagInitialized() {
    bool result = true;
    WithEmbeddedFlag s;

    // First test_and_set must return false (flag starts clear).
    bool was_set = s.flag.test_and_set();
    result &= Test("embedded flag initially clear", (int)was_set, 0);

    // Second call must see it held.
    bool still_set = s.flag.test_and_set();
    result &= Test("embedded flag now set", (int)still_set, 1);

    s.flag.clear();

    // Surrounding fields must be unaffected.
    result &= Test("embedded flag: value field intact", s.value, 0);
    result &= Test("embedded flag: other field intact", s.other, 7);
    return result;
}

bool testEmbeddedAtomicCounterInitialized() {
    bool result = true;
    WithEmbeddedCounter s;
    result &= Test("embedded counter starts at 0", (int)s.hits.read(), 0);
    s.hits.increment();
    result &= Test("embedded counter after increment", (int)s.hits.read(), 1);
    return result;
}

// ---------------------------------------------------------------------------
// Lock annotation positive tests (field group, lock clause, struct methods)
// ---------------------------------------------------------------------------

struct LockCounter {
    mutex mtx = default;
    lock(mtx) {
        int value = default;
    }
};

struct LockRwData {
    rwlock rw = default;
    lock(rw) {
        int data = default;
    }
};

void lockIncrement(LockCounter* a, int n) lock(a.mtx) {
    a.value = a.value + n;
}

struct LockAccount {
    mutex mtx = default;
    lock(mtx) {
        int balance = default;
        void deposit(int n) { balance = balance + n; }
        int getBalance()    { return balance; }
    }
};

bool testLockAnnotations()
{
    bool result = true;
    LockCounter c;
    lock(c.mtx) { c.value = 42; }
    lock(c.mtx) { lockIncrement(&c, 10); }

    LockCounter c2;
    lock(c.mtx, c2.mtx) { c.value = c.value + c2.value; }
    lock(c.mtx) { result &= Test("lock_counter",  c.value, 52); }

    LockRwData rd;
    lock(rd.rw) { rd.data = 100; }
    lock(rd.rw) { result &= Test("lock_rwdata",   rd.data, 100); }

    LockAccount acct;
    lock(acct.mtx) {
        acct.deposit(100);
        result &= Test("lock_account", acct.getBalance(), 100);
    }
    return result;
}

// ---------------------------------------------------------------------------
// Entry point
// ---------------------------------------------------------------------------

extern int main() {
    int passed = 0;
    int total  = 0;

    // Thread tests
    total++; passed += testThreadWritesThroughPointer()  ? 1 : 0;
    total++; passed += testThreadReadsThroughPointer()   ? 1 : 0;
    total++; passed += testThreadExitCode()              ? 1 : 0;
    total++; passed += testMultipleThreadsConcurrent()   ? 1 : 0;
    total++; passed += testLambdaWritesViaCtx()          ? 1 : 0;
    total++; passed += testLambdaExitCodeFromCtx()       ? 1 : 0;
    total++; passed += testThreadComputationViaStruct()  ? 1 : 0;
    total++; passed += testLambdaComputationViaStruct()  ? 1 : 0;
    total++; passed += testSequentialThreads()           ? 1 : 0;
    total++; passed += testThreadExitCodeZero()          ? 1 : 0;
    total++; passed += testMultipleThreadsCompute()      ? 1 : 0;
    total++; passed += testThreadStartMoveOwnership()    ? 1 : 0;

    // Mutex / atomic tests
    total++; passed += testMutexManual()              ? 1 : 0;
    total++; passed += testLockStatement()            ? 1 : 0;
    total++; passed += testLockBreak()                ? 1 : 0;
    total++; passed += testLockContinue()             ? 1 : 0;
    total++; passed += testNestedLockBreak()          ? 1 : 0;
    total++; passed += testMutexWithThreads()         ? 1 : 0;
    total++; passed += testAtomicCounterIncrement()   ? 1 : 0;
    total++; passed += testAtomicCounterDecrement()   ? 1 : 0;
    total++; passed += testAtomicCounterAdd()         ? 1 : 0;
    total++; passed += testAtomicCounterThreaded()    ? 1 : 0;
    total++; passed += testAtomicFlag()               ? 1 : 0;
    total++; passed += testAtomicI32()                ? 1 : 0;
    total++; passed += testAtomicI64()                ? 1 : 0;

    // Semaphore / latch / rwlock tests
    total++; passed += testSemaphoreBasic()           ? 1 : 0;
    total++; passed += testSemaphoreWithThreads()     ? 1 : 0;
    total++; passed += testSemaphoreLockStatement()   ? 1 : 0;
    total++; passed += testLatchBasic()               ? 1 : 0;
    total++; passed += testLatchWithThreads()         ? 1 : 0;
    total++; passed += testLatchAlreadyZero()         ? 1 : 0;
    total++; passed += testRwlockExclusive()          ? 1 : 0;
    total++; passed += testRwlockShared()             ? 1 : 0;
    total++; passed += testRwlockLockStatement()      ? 1 : 0;
    total++; passed += testRwlockWithThreads()        ? 1 : 0;

    // Embedded sub-struct initialization tests
    total++; passed += testEmbeddedAtomicFlagInitialized()    ? 1 : 0;
    total++; passed += testEmbeddedAtomicCounterInitialized() ? 1 : 0;

    // Channel / spsc_queue tests
    total++; passed += testChannelBasicSendReceive()  ? 1 : 0;
    total++; passed += testChannelCount()             ? 1 : 0;
    total++; passed += testChannelTryReceive()        ? 1 : 0;
    total++; passed += testChannelWrapAround()        ? 1 : 0;
    total++; passed += testChannelProducerConsumer()  ? 1 : 0;
    total++; passed += testChannelMultiProducer()     ? 1 : 0;
    total++; passed += testChannelPipeSingle()        ? 1 : 0;
    total++; passed += testChannelPipeChained()       ? 1 : 0;
    total++; passed += testChannelPipeEmpty()         ? 1 : 0;
    total++; passed += testSpscBasic()                ? 1 : 0;
    total++; passed += testSpscWrapAround()           ? 1 : 0;
    total++; passed += testSpscThreaded()             ? 1 : 0;

    total++; passed += testAtomicFlagReleaseAcquire()     ? 1 : 0;
    total++; passed += testAtomicI32ReleaseAcquire()      ? 1 : 0;
    total++; passed += testLockAnnotations()              ? 1 : 0;

    printf("Thread/Sync tests: %d/%d passed.\n", passed, total);
    return passed == total ? 0 : 1;
}
