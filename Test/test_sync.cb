// ---------------------------------------------------------------------------
// Thread tests
// ---------------------------------------------------------------------------

int writeToPtr(void* ctx) {
    int* p = (int*)ctx;
    *p = 99;
    return 0;
}

int readFromPtr(void* ctx) {
    int* p = (int*)ctx;
    return *p;
}

struct ComputeCtx {
    int input  = 0;
    int output = 0;
};

// Move-overload: ownership of the heap-allocated payload transfers from the
// caller into Thread.start, then via the trampoline into consume_payload, which
// is responsible for freeing it. The caller's pointer is auto-nulled.
struct MoveThreadPayload {
    int* slot  = nullptr;
    int  value = 0;
};

int g_move_thread_payload_dtors = 0;

int consume_thread_payload(move void* ctx) {
    MoveThreadPayload* p = (MoveThreadPayload*)ctx;   // cast transfers ownership ctx -> p
    *p->slot = p->value;
    int v = p->value;
    g_move_thread_payload_dtors = g_move_thread_payload_dtors + 1;
    // p owns the payload; scope-exit cleanup (operator delete) frees it once.
    return v;
}

bool testThreadStartMoveOwnership() {
    bool result = true;
    g_move_thread_payload_dtors = 0;
    int observed = 0;
    MoveThreadPayload* p = new MoveThreadPayload();
    p->slot  = &observed;
    p->value = 1234;
    Thread t;
    t.start(consume_thread_payload, (void*)p);   // ownership transfers into thread
    i32 code = t.join();
    result &= Test("move start observed", observed, 1234);
    result &= Test("move start exit code", code, 1234);
    result &= Test("move start freed once", g_move_thread_payload_dtors, 1);
    return result;
}

int computeSquare(void* ctx) {
    ComputeCtx* c = (ComputeCtx*)ctx;
    c->output = c->input * c->input;
    return 0;
}

bool testThreadWritesThroughPointer() {
    bool result = true;
    int value = 0;
    Thread t;
    t.start(writeToPtr, &value);
    t.join();
    result &= Test("write through ptr", value, 99);
    return result;
}

bool testThreadReadsThroughPointer() {
    bool result = true;
    int value = 42;
    Thread t;
    t.start(readFromPtr, &value);
    i32 code = t.join();
    result &= Test("read through ptr", code, 42);
    return result;
}

bool testThreadExitCode() {
    bool result = true;
    Thread t;
    t.start((void* ctx) => { return 42; }, nullptr);
    i32 code = t.join();
    result &= Test("exit code 42", code, 42);
    return result;
}

bool testMultipleThreadsConcurrent() {
    bool result = true;
    int a = 0;
    int b = 0;
    int c = 0;
    Thread t1;
    Thread t2;
    Thread t3;
    t1.start(writeToPtr, &a);
    t2.start(writeToPtr, &b);
    t3.start(writeToPtr, &c);
    t1.join();
    t2.join();
    t3.join();
    result &= Test("concurrent thread 1", a, 99);
    result &= Test("concurrent thread 2", b, 99);
    result &= Test("concurrent thread 3", c, 99);
    return result;
}

bool testLambdaWritesViaCtx() {
    bool result = true;
    int value = 0;
    Thread t;
    t.start((void* ctx) => {
        int* p = (int*)ctx;
        *p = 123;
        return 0;
    }, &value);
    t.join();
    result &= Test("lambda writes via ctx", value, 123);
    return result;
}

bool testLambdaExitCodeFromCtx() {
    bool result = true;
    int value = 10;
    Thread t;
    t.start((void* ctx) => {
        int* p = (int*)ctx;
        return *p * 3;
    }, &value);
    i32 code = t.join();
    result &= Test("lambda exit code from ctx", code, 30);
    return result;
}

bool testThreadComputationViaStruct() {
    bool result = true;
    ComputeCtx ctx;
    ctx.input  = 7;
    ctx.output = 0;
    Thread t;
    t.start(computeSquare, &ctx);
    t.join();
    result &= Test("named fn computes square", ctx.output, 49);
    return result;
}

bool testLambdaComputationViaStruct() {
    bool result = true;
    ComputeCtx ctx;
    ctx.input  = 5;
    ctx.output = 0;
    Thread t;
    t.start((void* vctx) => {
        ComputeCtx* c = (ComputeCtx*)vctx;
        c->output = c->input * c->input;
        return 0;
    }, &ctx);
    t.join();
    result &= Test("lambda computes square", ctx.output, 25);
    return result;
}

bool testSequentialThreads() {
    bool result = true;
    int a = 0;
    int b = 0;
    Thread t1;
    t1.start(writeToPtr, &a);
    t1.join();
    Thread t2;
    t2.start(writeToPtr, &b);
    t2.join();
    result &= Test("sequential thread 1", a, 99);
    result &= Test("sequential thread 2", b, 99);
    return result;
}

bool testThreadExitCodeZero() {
    bool result = true;
    Thread t;
    t.start((void* ctx) => { return 0; }, nullptr);
    i32 code = t.join();
    result &= Test("exit code 0", code, 0);
    return result;
}

bool testMultipleThreadsCompute() {
    bool result = true;
    ComputeCtx c0; c0.input = 1; c0.output = 0;
    ComputeCtx c1; c1.input = 2; c1.output = 0;
    ComputeCtx c2; c2.input = 3; c2.output = 0;
    ComputeCtx c3; c3.input = 4; c3.output = 0;
    ComputeCtx c4; c4.input = 5; c4.output = 0;
    Thread t0; Thread t1; Thread t2; Thread t3; Thread t4;
    t0.start(computeSquare, &c0);
    t1.start(computeSquare, &c1);
    t2.start(computeSquare, &c2);
    t3.start(computeSquare, &c3);
    t4.start(computeSquare, &c4);
    t0.join(); t1.join(); t2.join(); t3.join(); t4.join();
    result &= Test("parallel compute 1^2", c0.output,  1);
    result &= Test("parallel compute 2^2", c1.output,  4);
    result &= Test("parallel compute 3^2", c2.output,  9);
    result &= Test("parallel compute 4^2", c3.output, 16);
    result &= Test("parallel compute 5^2", c4.output, 25);
    return result;
}

// ---------------------------------------------------------------------------
// mutex + lock statement tests
// ---------------------------------------------------------------------------

struct MutexIntCtx {
    void* m = nullptr;  // mutex*
    int*  v = nullptr;
};

int incrementShared(void* ctx) {
    MutexIntCtx* mi = (MutexIntCtx*)ctx;
    mutex* mp = (mutex*)mi->m;
    lock (*mp) {
        *mi->v = *mi->v + 1;
    }
    return 0;
}

bool testMutexManual() {
    bool result = true;
    mutex m;
    int counter = 0;
    m.acquire();
    counter = counter + 1;
    m.release();
    result &= Test("mutex manual acquire/release", counter, 1);
    m.destroy();
    return result;
}

bool testLockStatement() {
    bool result = true;
    mutex m;
    int counter = 0;
    lock (m) {
        counter = counter + 1;
    }
    result &= Test("lock statement", counter, 1);
    m.destroy();
    return result;
}

bool testLockBreak() {
    bool result = true;
    mutex m;
    int i = 0;
    while (i < 3) {
        lock (m) {
            if (i == 1) break;
        }
        i++;
    }
    // If break didn't release, acquire() would deadlock.
    m.acquire();
    m.release();
    result &= Test("lock break releases mutex", i, 1);
    m.destroy();
    return result;
}

bool testLockContinue() {
    bool result = true;
    mutex m;
    int count = 0;
    int i = 0;
    while (i < 5) {
        i++;
        lock (m) {
            if (i % 2 == 0) continue;
            count++;
        }
    }
    // If continue didn't release, acquire() would deadlock.
    m.acquire();
    m.release();
    result &= Test("lock continue releases mutex", count, 3);
    m.destroy();
    return result;
}

bool testNestedLockBreak() {
    bool result = true;
    mutex m1;
    mutex m2;
    int i = 0;
    while (i < 3) {
        lock (m1) {
            lock (m2) {
                if (i == 1) break;
            }
        }
        i++;
    }
    m1.acquire();
    m1.release();
    m2.acquire();
    m2.release();
    result &= Test("nested lock break releases both mutexes", i, 1);
    m1.destroy();
    m2.destroy();
    return result;
}

bool testMutexWithThreads() {
    bool result = true;
    mutex m;
    int value = 0;
    MutexIntCtx mi;
    mi.m = (void*)&m;
    mi.v = &value;

    Thread t1;
    Thread t2;
    t1.start(incrementShared, &mi);
    t2.start(incrementShared, &mi);
    t1.join();
    t2.join();

    result &= Test("mutex with threads", value, 2);
    m.destroy();
    return result;
}

// ---------------------------------------------------------------------------
// atomic_counter tests
// ---------------------------------------------------------------------------

struct AtomicCtx {
    atomic_counter* counter = nullptr;
    int iterations = 0;
};

int atomicIncrementWorker(void* ctx) {
    AtomicCtx* ac = (AtomicCtx*)ctx;
    int i = 0;
    while (i < ac->iterations) {
        ac->counter->increment();
        i = i + 1;
    }
    return 0;
}

bool testAtomicCounterIncrement() {
    bool result = true;
    atomic_counter c;
    c.increment();
    c.increment();
    c.increment();
    result &= Test("atomic increment x3", (int)c.read(), 3);
    return result;
}

bool testAtomicCounterDecrement() {
    bool result = true;
    atomic_counter c;
    c.increment();
    c.increment();
    c.decrement();
    result &= Test("atomic decrement", (int)c.read(), 1);
    return result;
}

bool testAtomicCounterAdd() {
    bool result = true;
    atomic_counter c;
    c.add(10);
    c.add(5);
    result &= Test("atomic add", (int)c.read(), 15);
    return result;
}

bool testAtomicCounterThreaded() {
    bool result = true;
    atomic_counter counter;

    AtomicCtx ctx1; ctx1.counter = &counter; ctx1.iterations = 100;
    AtomicCtx ctx2; ctx2.counter = &counter; ctx2.iterations = 100;
    AtomicCtx ctx3; ctx3.counter = &counter; ctx3.iterations = 100;
    AtomicCtx ctx4; ctx4.counter = &counter; ctx4.iterations = 100;
    AtomicCtx ctx5; ctx5.counter = &counter; ctx5.iterations = 100;

    Thread t1; Thread t2; Thread t3; Thread t4; Thread t5;
    t1.start(atomicIncrementWorker, &ctx1);
    t2.start(atomicIncrementWorker, &ctx2);
    t3.start(atomicIncrementWorker, &ctx3);
    t4.start(atomicIncrementWorker, &ctx4);
    t5.start(atomicIncrementWorker, &ctx5);
    t1.join(); t2.join(); t3.join(); t4.join(); t5.join();

    result &= Test("atomic counter 5 threads x100", (int)counter.read(), 500);
    return result;
}

bool testAtomicFlag() {
    bool result = true;
    atomic_flag flag;

    bool was_set = flag.test_and_set();
    result &= Test("flag initially clear", (int)was_set, 0);

    bool still_set = flag.test_and_set();
    result &= Test("flag was set", (int)still_set, 1);

    flag.clear();

    bool after_clear = flag.test_and_set();
    result &= Test("flag after clear", (int)after_clear, 0);
    flag.clear();
    return result;
}

bool testAtomicI32() {
    bool result = true;
    atomic__i32 a;
    a.store(42);
    result &= Test("atomic i32 store/load", a.load(), 42);

    bool ok = a.cas(42, 99);
    result &= Test("atomic i32 cas success", (int)ok, 1);
    result &= Test("atomic i32 cas result", a.load(), 99);

    bool fail = a.cas(0, 1);
    result &= Test("atomic i32 cas fail", (int)fail, 0);
    result &= Test("atomic i32 unchanged", a.load(), 99);
    return result;
}

bool testAtomicI64() {
    bool result = true;
    atomic__i64 a;
    a.store(1000000000000);
    result &= Test("atomic i64 store/load", (int)(a.load() == 1000000000000), 1);

    bool ok = a.cas(1000000000000, 2000000000000);
    result &= Test("atomic i64 cas success", (int)ok, 1);
    result &= Test("atomic i64 cas result", (int)(a.load() == 2000000000000), 1);
    return result;
}

// Portable acquire fence (Phase 1 of internal/plan/optimistic-lock-coupling.md): no
// directly observable single-threaded behaviour, so this just proves fence_acquire()
// compiles/lowers/does not crash, and round-trips a value through store_release()/load().
bool testAcquireFenceAndReleaseStore() {
    bool result = true;
    atomic__i64 a;
    a.store_release(7);
    fence_acquire();
    result &= Test("acquire fence + release store round-trip", (int)a.load(), 7);
    return result;
}

// ---------------------------------------------------------------------------
// atomic release/acquire guard tests
// ---------------------------------------------------------------------------

struct FlagGuarded {
    atomic__i32 ready = default;
    lock(ready) {
        int value = 0;
        int value2 = 0;
    }
};

struct I32Guarded {
    atomic__i32 version = default;
    lock(version) {
        int data = 0;
    }
};

// Regression: an unrelated struct with a release() method must NOT disable the
// lock(this) guard-seeding on atomic release(val, body). The guard checker used
// to resolve the callee by bare method name and pick the first overload named
// 'release' (this one), dropping the seeding and rejecting the guarded write.
struct ReleaseDecoy {
    int state = 0;
    void release() { state = 0; }
};

int flagReleaseWorker(void* ctx) {
    FlagGuarded* s = (FlagGuarded*)ctx;
    s->ready.release(1, () => {
        s->value  = 42;
        s->value2 = 99;
    });
    return 0;
}

bool testAtomicFlagReleaseAcquire() {
    bool result = true;
    FlagGuarded s;
    Thread t;
    t.start(flagReleaseWorker, &s);
    while (s.ready.load() == 0) { }
    s.ready.acquire((i32 v) => {
        result &= Test("atomic release/acquire value",  s.value,  42);
        result &= Test("atomic release/acquire value2", s.value2, 99);
        result &= Test("atomic release/acquire loaded", (int)v, 1);
    });
    t.join();
    return result;
}

int i32ReleaseWorker(void* ctx) {
    I32Guarded* s = (I32Guarded*)ctx;
    s->version.release(1, () => {
        s->data = 77;
    });
    return 0;
}

bool testAtomicI32ReleaseAcquire() {
    bool result = true;
    I32Guarded s;
    Thread t;
    t.start(i32ReleaseWorker, &s);
    while (s.version.load() == 0) { }
    s.version.acquire((i32 v) => {
        result &= Test("i32 release/acquire data",    s.data, 77);
        result &= Test("i32 release/acquire version", (int)v, 1);
    });
    t.join();
    return result;
}

// ---------------------------------------------------------------------------
// semaphore tests
// ---------------------------------------------------------------------------

struct SemCtx {
    void* sem = nullptr;  // semaphore*
};

int semSignalWorker(void* ctx) {
    SemCtx* sc = (SemCtx*)ctx;
    semaphore* sp = (semaphore*)sc->sem;
    sp->release();
    return 0;
}

bool testSemaphoreBasic() {
    bool result = true;
    semaphore s;
    s.init(3, 10);

    s.acquire();
    s.acquire();
    s.acquire();

    s.release();
    s.release();
    s.release();

    result &= Test("semaphore basic acquire/release", 1, 1);
    s.destroy();
    return result;
}

bool testSemaphoreWithThreads() {
    bool result = true;
    semaphore s;
    s.init(0, 10);

    SemCtx ctx;
    ctx.sem = (void*)&s;

    Thread t1;
    Thread t2;
    t1.start(semSignalWorker, &ctx);
    t2.start(semSignalWorker, &ctx);

    s.acquire();
    s.acquire();

    t1.join();
    t2.join();

    result &= Test("semaphore threaded signal", 1, 1);
    s.destroy();
    return result;
}

bool testSemaphoreLockStatement() {
    bool result = true;
    semaphore s;
    s.init(1, 1);

    int counter = 0;
    lock (s) {
        counter = counter + 1;
    }
    result &= Test("semaphore lock statement", counter, 1);
    s.destroy();
    return result;
}

// ---------------------------------------------------------------------------
// latch tests
// ---------------------------------------------------------------------------

struct LatchCtx {
    void* lch   = nullptr;  // latch*
    int*  steps = nullptr;
};

int latchWorker(void* ctx) {
    LatchCtx* lc = (LatchCtx*)ctx;
    latch* lp = (latch*)lc->lch;
    *lc->steps = *lc->steps + 1;
    lp->count_down();
    return 0;
}

bool testLatchBasic() {
    bool result = true;
    latch l;
    l.init(1);
    l.count_down();
    l.wait();
    result &= Test("latch count_down once then wait", 1, 1);
    l.destroy();
    return result;
}

bool testLatchWithThreads() {
    bool result = true;
    latch l;
    l.init(3);
    int steps = 0;

    LatchCtx ctx;
    ctx.lch   = (void*)&l;
    ctx.steps = &steps;

    Thread t1;
    Thread t2;
    Thread t3;
    t1.start(latchWorker, &ctx);
    t2.start(latchWorker, &ctx);
    t3.start(latchWorker, &ctx);

    l.wait();

    t1.join();
    t2.join();
    t3.join();

    result &= Test("latch 3 threads", steps, 3);
    l.destroy();
    return result;
}

bool testLatchAlreadyZero() {
    bool result = true;
    latch l;
    l.init(1);
    l.count_down();
    l.wait();
    l.wait();
    result &= Test("latch wait idempotent", 1, 1);
    l.destroy();
    return result;
}

// ---------------------------------------------------------------------------
// rwlock tests
// ---------------------------------------------------------------------------

struct RwCtx {
    void* rw  = nullptr;  // rwlock*
    int*  val = nullptr;
    int   add = 0;
};

int rwWriterWorker(void* ctx) {
    RwCtx* rc = (RwCtx*)ctx;
    rwlock* rp = (rwlock*)rc->rw;
    rp->acquire_write();
    *rc->val = *rc->val + rc->add;
    rp->release_write();
    return 0;
}

bool testRwlockExclusive() {
    bool result = true;
    rwlock rw;
    int shared = 0;

    rw.acquire_write();
    shared = 42;
    rw.release_write();

    result &= Test("rwlock exclusive write", shared, 42);
    return result;
}

bool testRwlockShared() {
    bool result = true;
    rwlock rw;
    int shared = 99;

    rw.acquire_read();
    rw.acquire_read();
    int val1 = shared;
    int val2 = shared;
    rw.release_read();
    rw.release_read();

    result &= Test("rwlock shared read", val1, 99);
    result &= Test("rwlock shared read 2", val2, 99);
    return result;
}

bool testRwlockLockStatement() {
    bool result = true;
    rwlock rw;
    int shared = 0;

    lock (rw) {
        shared = 77;
    }
    result &= Test("rwlock lock statement (write)", shared, 77);

    // Mode suffixes: lock(rw.write) is exclusive, lock(rw.read) is shared. Nesting two
    // read locks must not deadlock - a second shared acquire does not block.
    int val = 0;
    lock (rw.write) {
        shared = 88;
    }
    lock (rw.read) {
        lock (rw.read) {
            val = shared;
        }
    }
    result &= Test("rwlock lock statement (rw.write)", shared, 88);
    result &= Test("rwlock lock statement (rw.read)", val, 88);
    return result;
}

bool testRwlockWithThreads() {
    bool result = true;
    rwlock rw;
    int value = 0;

    RwCtx ctx1; ctx1.rw = (void*)&rw; ctx1.val = &value; ctx1.add = 10;
    RwCtx ctx2; ctx2.rw = (void*)&rw; ctx2.val = &value; ctx2.add = 5;

    Thread t1;
    Thread t2;
    t1.start(rwWriterWorker, &ctx1);
    t2.start(rwWriterWorker, &ctx2);
    t1.join();
    t2.join();

    result &= Test("rwlock two writer threads", value, 15);
    return result;
}

// ---------------------------------------------------------------------------
// RAII teardown for the sync primitives.
//
// mutex/rwlock/condvar/event/semaphore/barrier release their OS state from a
// destructor at scope exit. destroy() stays public and is IDEMPOTENT (it nulls
// the slot/handle), so an explicit destroy() followed by scope exit must not
// double-release. A double release aborts under the macOS allocator, so
// "returns normally" is the assertion here.
// ---------------------------------------------------------------------------

// Explicit destroy() then scope exit - the numa.cb:261 pattern. Must not
// double-release the underlying OS object.
bool testLockDestroyIsIdempotent() {
    bool result = true;

    {
        mutex m;
        lock (m) { }
        m.destroy();
        m.destroy();      // idempotent: slot already nulled
    }                     // ~mutex() must be a no-op

    {
        rwlock rw;
        lock (rw.write) { }
        rw.destroy();
        rw.destroy();
    }                     // ~rwlock() must be a no-op

    result &= Test("lock destroy() is idempotent", true, true);
    return result;
}

// A destroyed lock is re-usable: os.*_lock lazily re-creates the OS state when
// the slot is null, so teardown can never leave a caller with a dead lock.
bool testLockUsableAfterDestroy() {
    bool result = true;
    mutex m;
    int counter = 0;
    lock (m) { counter = counter + 1; }
    m.destroy();
    lock (m) { counter = counter + 1; }   // slot lazily re-created
    result &= Test("lock usable after destroy", counter, 2);
    return result;
}

// Same idempotency contract for the handle-based primitives.
bool testEventSemaphoreBarrierDestroyIdempotent() {
    bool result = true;

    {
        semaphore s;
        s.init(1, 1);
        s.destroy();
        s.destroy();
    }                     // ~semaphore() must be a no-op

    {
        latch l;          // latch embeds an event by value
        l.init(1);
        l.count_down();
        l.wait();
        l.destroy();
        l.destroy();
    }                     // ~event() on l._ev must be a no-op

    {
        barrier b;
        b.init(1);
        b.destroy();
        b.destroy();
    }                     // ~barrier() must be a no-op

    // Never-initialised shells: the destructor must tolerate a null handle.
    {
        semaphore sUnused;
        barrier   bUnused;
        mutex     mUnused;
        rwlock    rwUnused;
    }

    result &= Test("event/semaphore/barrier destroy() idempotent", true, true);
    return result;
}

// Repeated scope-entry must not accumulate OS lock state. This is a smoke test
// for the destructor actually running; the quantitative oracle is an RSS probe
// (a leak here is ~200 bytes per iteration on Darwin).
bool testLockScopeExitReleasesRepeatedly() {
    bool result = true;
    int n = 0;
    for (int i = 0; i < 2000; i++) {
        mutex  m;
        rwlock rw;
        lock (m) { n = n + 1; }
        lock (rw.write) { }
    }
    result &= Test("lock scope exit releases repeatedly", n, 2000);
    return result;
}

// ---------------------------------------------------------------------------
// channel<int> tests
// ---------------------------------------------------------------------------

struct ChanCtx {
    void* ch    = nullptr;  // channel<int>*
    int   start = 0;
    int   count = 0;
};

int chanProducer(void* ctx) {
    ChanCtx* cc = (ChanCtx*)ctx;
    channel<int>* chp = (channel<int>*)cc->ch;
    int i = 0;
    while (i < cc->count) {
        chp->send(cc->start + i);
        i++;
    }
    return 0;
}

int chanConsumerSum(void* ctx) {
    ChanCtx* cc = (ChanCtx*)ctx;
    channel<int>* chp = (channel<int>*)cc->ch;
    int sum = 0;
    int i = 0;
    while (i < cc->count) {
        sum = sum + chp->receive();
        i++;
    }
    return sum;
}

bool testChannelBasicSendReceive() {
    bool result = true;
    channel<int> ch;
    ch.init(4);

    ch.send(10);
    ch.send(20);
    ch.send(30);

    result &= Test("channel recv 1", ch.receive(), 10);
    result &= Test("channel recv 2", ch.receive(), 20);
    result &= Test("channel recv 3", ch.receive(), 30);
    result &= Test("channel capacity", ch.capacity(), 4);

    ch.destroy();
    return result;
}

bool testChannelCount() {
    bool result = true;
    channel<int> ch;
    ch.init(8);

    ch.send(1);
    ch.send(2);
    result &= Test("channel count after 2 sends", ch.count(), 2);

    ch.receive();
    result &= Test("channel count after 1 recv", ch.count(), 1);

    ch.destroy();
    return result;
}

bool testChannelTryReceive() {
    bool result = true;
    channel<int> ch;
    ch.init(4);

    int out = 0;
    bool ok = ch.try_receive(&out);
    result &= Test("try_receive empty returns false", (int)ok, 0);

    ch.send(99);
    ok = ch.try_receive(&out);
    result &= Test("try_receive gets value", (int)ok, 1);
    result &= Test("try_receive correct value", out, 99);

    ch.destroy();
    return result;
}

bool testChannelWrapAround() {
    bool result = true;
    channel<int> ch;
    ch.init(3);

    ch.send(1); ch.send(2); ch.send(3);
    result &= Test("wrap recv 1", ch.receive(), 1);
    result &= Test("wrap recv 2", ch.receive(), 2);
    ch.send(4); ch.send(5);
    result &= Test("wrap recv 3", ch.receive(), 3);
    result &= Test("wrap recv 4", ch.receive(), 4);
    result &= Test("wrap recv 5", ch.receive(), 5);

    ch.destroy();
    return result;
}

bool testChannelProducerConsumer() {
    bool result = true;
    channel<int> ch;
    ch.init(8);

    ChanCtx pctx; pctx.ch = (void*)&ch; pctx.start = 1; pctx.count = 5;
    ChanCtx cctx; cctx.ch = (void*)&ch; cctx.start = 0; cctx.count = 5;

    Thread producer;
    Thread consumer;
    producer.start(chanProducer,    &pctx);
    consumer.start(chanConsumerSum, &cctx);

    producer.join();
    i32 sum = consumer.join();

    result &= Test("channel producer/consumer sum", (int)sum, 15);
    ch.destroy();
    return result;
}

bool testChannelMultiProducer() {
    bool result = true;
    channel<int> ch;
    ch.init(16);

    ChanCtx p1ctx; p1ctx.ch = (void*)&ch; p1ctx.start = 0;  p1ctx.count = 5;
    ChanCtx p2ctx; p2ctx.ch = (void*)&ch; p2ctx.start = 10; p2ctx.count = 5;
    ChanCtx cctx;  cctx.ch  = (void*)&ch; cctx.start  = 0;  cctx.count  = 10;

    Thread p1; Thread p2; Thread consumer;
    p1.start(chanProducer,    &p1ctx);
    p2.start(chanProducer,    &p2ctx);
    consumer.start(chanConsumerSum, &cctx);

    p1.join(); p2.join();
    i32 sum = consumer.join();

    result &= Test("channel multi-producer sum", (int)sum, 70);
    ch.destroy();
    return result;
}

// channel<T>::operator>> (pipe) + producer-refcount close protocol.
// Borrow semantics: a >> b spawns a forwarder that drains a into b; when a's
// last producer closes, the forwarder drains and closes b.

// Single-stage pipe preserves order and count; closing src closes dst.
bool testChannelPipeSingle() {
    bool result = true;
    channel<int>* src = new channel<int>();
    channel<int>* dst = new channel<int>();
    src.init(64);
    dst.init(64);

    src >> dst;

    src.add_producer();
    int i = 0;
    while (i < 100) { src.push(i); i = i + 1; }
    src.close_producer();

    int expected = 0;
    int v        = 0;
    int count    = 0;
    int ordered  = 1;
    while (dst.receive(&v)) {
        if (v != expected) { ordered = 0; }
        expected = expected + 1;
        count    = count + 1;
    }
    result &= Test("pipe_single_count", count, 100);
    result &= Test("pipe_single_order", ordered, 1);
    return result;
}

// Two-stage pipe src -> mid -> dst: EOF must propagate through both forwarders.
bool testChannelPipeChained() {
    bool result = true;
    channel<int>* src = new channel<int>();
    channel<int>* mid = new channel<int>();
    channel<int>* dst = new channel<int>();
    src.init(64);
    mid.init(64);
    dst.init(64);

    src >> mid;
    mid >> dst;

    src.add_producer();
    int i      = 0;
    int sum_in = 0;
    while (i < 50) { src.push(i); sum_in = sum_in + i; i = i + 1; }
    src.close_producer();

    int v       = 0;
    int sum_out = 0;
    int count   = 0;
    while (dst.receive(&v)) { sum_out = sum_out + v; count = count + 1; }

    result &= Test("pipe_chain_count", count, 50);
    result &= Test("pipe_chain_sum", sum_out, sum_in);
    return result;
}

// An empty source closed with no items must still close the destination.
bool testChannelPipeEmpty() {
    channel<int>* src = new channel<int>();
    channel<int>* dst = new channel<int>();
    src.init(16);
    dst.init(16);

    src >> dst;
    src.add_producer();
    src.close_producer();

    int v     = 0;
    int count = 0;
    while (dst.receive(&v)) { count = count + 1; }
    return Test("pipe_empty_count", count, 0) != 0;
}

// ---------------------------------------------------------------------------
// spsc_queue<int> tests
// ---------------------------------------------------------------------------

struct SpscCtx {
    void* q     = nullptr;  // spsc_queue<int>*
    int   items = 0;
};

int spscProducer(void* ctx) {
    SpscCtx* sc = (SpscCtx*)ctx;
    spsc_queue<int>* qp = (spsc_queue<int>*)sc->q;
    int i = 1;
    while (i <= sc->items) {
        while (!qp->try_push(i)) { }
        i++;
    }
    return 0;
}

int spscConsumer(void* ctx) {
    SpscCtx* sc = (SpscCtx*)ctx;
    spsc_queue<int>* qp = (spsc_queue<int>*)sc->q;
    int sum = 0;
    int i = 0;
    int out = 0;
    while (i < sc->items) {
        while (!qp->try_pop(&out)) { }
        sum = sum + out;
        i++;
    }
    return sum;
}

bool testSpscBasic() {
    bool result = true;
    spsc_queue<int> q;
    q.init(4);

    result &= Test("spsc empty initially", (int)q.is_empty(), 1);

    bool ok = q.try_push(10);
    result &= Test("spsc push 1", (int)ok, 1);
    ok = q.try_push(20);
    result &= Test("spsc push 2", (int)ok, 1);
    ok = q.try_push(30);
    result &= Test("spsc push 3", (int)ok, 1);
    ok = q.try_push(40);
    result &= Test("spsc push 4", (int)ok, 1);
    result &= Test("spsc full", (int)q.is_full(), 1);

    ok = q.try_push(99);
    result &= Test("spsc push when full fails", (int)ok, 0);

    int out = 0;
    q.try_pop(&out); result &= Test("spsc pop 1", out, 10);
    q.try_pop(&out); result &= Test("spsc pop 2", out, 20);
    q.try_pop(&out); result &= Test("spsc pop 3", out, 30);
    q.try_pop(&out); result &= Test("spsc pop 4", out, 40);

    result &= Test("spsc empty after drain", (int)q.is_empty(), 1);

    ok = q.try_pop(&out);
    result &= Test("spsc pop when empty fails", (int)ok, 0);

    result &= Test("spsc capacity", q.capacity(), 4);

    q.destroy();
    return result;
}

bool testSpscWrapAround() {
    bool result = true;
    spsc_queue<int> q;
    q.init(3);

    q.try_push(1); q.try_push(2); q.try_push(3);
    int out = 0;
    q.try_pop(&out);
    q.try_push(4);
    q.try_pop(&out); result &= Test("wrap pop 2", out, 2);
    q.try_pop(&out); result &= Test("wrap pop 3", out, 3);
    q.try_pop(&out); result &= Test("wrap pop 4", out, 4);

    q.destroy();
    return result;
}

bool testSpscThreaded() {
    bool result = true;
    spsc_queue<int> q;
    q.init(64);

    SpscCtx pctx; pctx.q = (void*)&q; pctx.items = 100;
    SpscCtx cctx; cctx.q = (void*)&q; cctx.items = 100;

    Thread producer;
    Thread consumer;
    producer.start(spscProducer, &pctx);
    consumer.start(spscConsumer, &cctx);

    producer.join();
    i32 sum = consumer.join();

    result &= Test("spsc threaded sum 1..100", (int)sum, 5050);
    q.destroy();
    return result;
}

// ---------------------------------------------------------------------------
// Embedded sub-struct initialization tests
// ---------------------------------------------------------------------------

struct WithEmbeddedFlag {
    int    value = 0;
    atomic_flag flag;   // no = default - tests sub-struct auto-init
    int    other = 7;
};

struct WithEmbeddedCounter {
    atomic_counter hits;  // no = default
};

bool testEmbeddedAtomicFlagInitialized() {
    bool result = true;
    WithEmbeddedFlag s;

    // First test_and_set must return false (flag starts clear).
    bool was_set = s.flag.test_and_set();
    result &= Test("embedded flag initially clear", (int)was_set, 0);

    // Second call must see it held.
    bool still_set = s.flag.test_and_set();
    result &= Test("embedded flag now set", (int)still_set, 1);

    s.flag.clear();

    // Surrounding fields must be unaffected.
    result &= Test("embedded flag: value field intact", s.value, 0);
    result &= Test("embedded flag: other field intact", s.other, 7);
    return result;
}

bool testEmbeddedAtomicCounterInitialized() {
    bool result = true;
    WithEmbeddedCounter s;
    result &= Test("embedded counter starts at 0", (int)s.hits.read(), 0);
    s.hits.increment();
    result &= Test("embedded counter after increment", (int)s.hits.read(), 1);
    return result;
}

// ---------------------------------------------------------------------------
// Lock annotation positive tests (field group, lock clause, struct methods)
// ---------------------------------------------------------------------------

struct LockCounter {
    mutex mtx = default;
    lock(mtx) {
        int value = default;
    }
};

struct LockRwData {
    rwlock rw = default;
    lock(rw) {
        int data = default;
    }
};

void lockIncrement(LockCounter* a, int n) lock(a.mtx) {
    a.value = a.value + n;
}

struct LockAccount {
    mutex mtx = default;
    lock(mtx) {
        int balance = default;
        void deposit(int n) { balance = balance + n; }
        int getBalance()    { return balance; }
    }
};

bool testLockAnnotations()
{
    bool result = true;
    LockCounter c;
    lock(c.mtx) { c.value = 42; }
    lock(c.mtx) { lockIncrement(&c, 10); }

    LockCounter c2;
    lock(c.mtx, c2.mtx) { c.value = c.value + c2.value; }
    lock(c.mtx) { result &= Test("lock_counter",  c.value, 52); }

    LockRwData rd;
    lock(rd.rw) { rd.data = 100; }
    lock(rd.rw) { result &= Test("lock_rwdata",   rd.data, 100); }

    LockAccount acct;
    lock(acct.mtx) {
        acct.deposit(100);
        result &= Test("lock_account", acct.getBalance(), 100);
    }
    return result;
}

// Guard field is a mutex* (pointer), not a value mutex. Regression: release() used to be
// called on the address of the pointer field, so the real mutex stayed locked forever.
struct LockPtrCounter {
    mutex* mtx = nullptr;
    lock(mtx) {
        int value = default;
    }
};

bool testLockPointerGuard()
{
    bool result = true;
    mutex mm = default;
    LockPtrCounter pc;
    pc.mtx = &mm;

    // Two sequential lock blocks: the second one deadlocks if the first never released.
    lock(pc.mtx) { pc.value = 1; }
    lock(pc.mtx) { pc.value = pc.value + 41; }
    lock(pc.mtx) { result &= Test("lock_ptr_guard", pc.value, 42); }
    return result;
}

// Regression: lock(p->mtx) must canonicalize to the same lock string as lock(p.mtx),
// otherwise accessing a guarded field through the arrow form false-errors.
bool testLockArrowForm()
{
    bool result = true;
    LockCounter dotForm;
    LockCounter arrowForm;
    LockCounter* p = &arrowForm;

    lock(dotForm.mtx) { dotForm.value = 7; }
    lock(p->mtx)      { p->value = 7; }

    lock(arrowForm.mtx) { result &= Test("lock_arrow_form", arrowForm.value, 7); }
    lock(dotForm.mtx, arrowForm.mtx) {
        result &= Test("lock_arrow_matches_dot", arrowForm.value, dotForm.value);
    }
    return result;
}

// ---------------------------------------------------------------------------
// File-scope guard group: a global mutex guarding global state. The globals in the
// group can only be touched while g_regMutex is held; group functions inherit that
// requirement and need no lock statement of their own.
// ---------------------------------------------------------------------------

mutex g_regMutex = default;

lock(g_regMutex) {
    int g_regCount = 0;
    int g_regTotal = 0;

    void regBump(int n) {
        g_regCount = g_regCount + 1;
        g_regTotal = g_regTotal + n;
    }
}

int regWorker(void* ctx) {
    int i = 0;
    while (i < 100) {
        lock(g_regMutex) { regBump(2); }
        i = i + 1;
    }
    return 0;
}

bool testGlobalGuardGroup()
{
    bool result = true;

    lock(g_regMutex) {
        g_regCount = 0;
        g_regTotal = 0;
    }

    Thread t1;
    Thread t2;
    t1.start(regWorker, nullptr);
    t2.start(regWorker, nullptr);
    t1.join();
    t2.join();

    lock(g_regMutex) {
        result &= Test("global_guard_count", g_regCount, 200);
        result &= Test("global_guard_total", g_regTotal, 400);
    }
    return result;
}

// ---------------------------------------------------------------------------
// barrier / spin_barrier tests
// ---------------------------------------------------------------------------

struct BarrierCtx {
    void*           bar         = nullptr;  // barrier* or spin_barrier*
    int*            phaseData   = nullptr;  // one slot per worker
    atomic_counter* leaderCount = nullptr;  // bumped by the elected leader each phase
    atomic_counter* errorCount  = nullptr;  // bumped if a worker hadn't arrived
    int             id          = 0;
    int             phases      = 0;
    int             workers     = 0;
};

// Each phase: write my slot, sync. The elected leader then verifies every slot
// holds this phase's value - which can only be true if all workers arrived
// before the leader was released (the barrier's contract). A second sync keeps
// the leader's read from racing the next phase's overwrite.
int barrierWorker(void* ctx) {
    BarrierCtx* c = (BarrierCtx*)ctx;
    barrier* b = (barrier*)c->bar;
    int p = 0;
    while (p < c->phases) {
        c->phaseData[c->id] = p;
        bool leader = b->arrive_and_wait();
        if (leader) {
            int i = 0;
            while (i < c->workers) {
                if (c->phaseData[i] != p) { c->errorCount->increment(); }
                i = i + 1;
            }
            c->leaderCount->increment();
        }
        b->arrive_and_wait();
        p = p + 1;
    }
    return 0;
}

int spinBarrierWorker(void* ctx) {
    BarrierCtx* c = (BarrierCtx*)ctx;
    spin_barrier* b = (spin_barrier*)c->bar;
    int p = 0;
    while (p < c->phases) {
        c->phaseData[c->id] = p;
        bool leader = b->arrive_and_wait();
        if (leader) {
            int i = 0;
            while (i < c->workers) {
                if (c->phaseData[i] != p) { c->errorCount->increment(); }
                i = i + 1;
            }
            c->leaderCount->increment();
        }
        b->arrive_and_wait();
        p = p + 1;
    }
    return 0;
}

// Shared harness: spawn `workers` threads running `worker`, run `phases`, and
// check (1) exactly one leader per phase and (2) no worker was late.
bool runBarrierThreaded(void* barPtr, function<int(void*)> worker, int workers, int phases,
                        const char* leaderLabel, const char* errLabel) {
    bool result = true;
    int* phaseData = new int[workers];
    int i = 0;
    while (i < workers) { phaseData[i] = -1; i = i + 1; }

    atomic_counter leaderCount;
    atomic_counter errorCount;

    Thread*     threads = new Thread[workers];
    BarrierCtx* ctxs    = new BarrierCtx[workers];
    i = 0;
    while (i < workers) {
        ctxs[i].bar         = barPtr;
        ctxs[i].phaseData   = phaseData;
        ctxs[i].leaderCount = &leaderCount;
        ctxs[i].errorCount  = &errorCount;
        ctxs[i].id          = i;
        ctxs[i].phases      = phases;
        ctxs[i].workers     = workers;
        threads[i].start(worker, &ctxs[i]);
        i = i + 1;
    }
    i = 0;
    while (i < workers) { threads[i].join(); i = i + 1; }

    result &= Test(leaderLabel, (int)leaderCount.read(), phases);
    result &= Test(errLabel,    (int)errorCount.read(),  0);

    delete[_] threads;
    delete[_] ctxs;
    delete[_] phaseData;
    return result;
}

// Single thread, N=1: arrive_and_wait must return immediately AND be reusable -
// if the generation reset were broken the second call would misbehave/hang.
bool testBarrierSingleThreadReuse() {
    bool result = true;
    barrier b;
    b.init(1);
    int i = 0;
    while (i < 5) {
        bool leader = b.arrive_and_wait();   // N=1 -> always the leader
        result &= Test("barrier n=1 reusable leader", (int)leader, 1);
        i = i + 1;
    }
    b.destroy();
    return result;
}

bool testBarrierThreaded() {
    barrier b;
    b.init(4);
    bool r = runBarrierThreaded((void*)&b, barrierWorker, 4, 50,
                                "barrier leader once per phase", "barrier no late arrivals");
    b.destroy();
    return r;
}

bool testSpinBarrierThreaded() {
    spin_barrier b;
    b.init(4);
    bool r = runBarrierThreaded((void*)&b, spinBarrierWorker, 4, 50,
                                "spin_barrier leader once per phase", "spin_barrier no late arrivals");
    b.destroy();
    return r;
}

// ---------------------------------------------------------------------------
// olock (optimistic lock coupling seqlock) tests - Phase 2 of
// internal/plan/optimistic-lock-coupling.md.
// ---------------------------------------------------------------------------

// A validated read with no concurrent writer must succeed.
bool testOlockValidatedReadNoWriter() {
    bool result = true;
    olock o;
    i64 v = o.read_begin();
    bool valid = o.read_validate(v);
    result &= Test("olock read_begin/read_validate with no writer", valid, true);
    return result;
}

// A read that spans a concurrent write must fail validation. Deterministic,
// single-threaded: take and release the lock via lock (o) { } between
// read_begin() and read_validate() so the version has visibly moved.
bool testOlockReadInvalidatedByWrite() {
    bool result = true;
    olock o;
    i64 v = o.read_begin();
    lock (o) { }
    bool valid = o.read_validate(v);
    result &= Test("olock read invalidated by intervening write", valid, false);
    return result;
}

// upgrade() succeeds from a clean snapshot, and fails once another write has
// moved the version out from under the snapshot it was given.
bool testOlockUpgrade() {
    bool result = true;
    olock o;

    i64 v1 = o.read_begin();
    bool ok1 = o.upgrade(v1);
    result &= Test("olock upgrade succeeds from clean snapshot", ok1, true);
    o.release();

    i64 v2 = o.read_begin();
    lock (o) { }   // intervening write moves the version past v2
    bool ok2 = o.upgrade(v2);
    result &= Test("olock upgrade fails after intervening write", ok2, false);
    return result;
}

// lock (o) { } must compile and work on an olock - exercises the
// [Capability(ILockable)] lowering to acquire()/release().
bool testOlockLockStatement() {
    bool result = true;
    olock o;
    int counter = 0;
    lock (o) {
        counter = counter + 1;
    }
    result &= Test("olock lock statement (ILockable)", counter, 1);
    return result;
}

// obsolete() / is_obsolete() round-trip: a freshly retired lock reports
// obsolete on the version snapshotted after retirement.
bool testOlockObsoleteRoundTrip() {
    bool result = true;
    olock o;

    i64 v0 = o.read_begin();
    result &= Test("olock not obsolete before retirement", o.is_obsolete(v0), false);

    o.acquire();
    o.obsolete();

    i64 v1 = o.read_begin();
    result &= Test("olock obsolete after obsolete()", o.is_obsolete(v1), true);
    return result;
}

// ---------------------------------------------------------------------------
// olock.read() - the scoped speculative bracket (Phase 3). The lock(this.optimistic)
// parameter seeds the guard in Optimistic mode, so the body may READ the guarded
// fields; a WRITE to one is a compile error (Test/errors/err_lock_write_under_optimistic.cb).
// ---------------------------------------------------------------------------

// A real guard group over an olock: the fields are unreachable without holding `ver`.
struct OlockGuarded {
    olock ver = default;
    lock(ver) {
        i64 x = 0;
        i64 y = 0;
    }
};

// The body reads both guarded fields under an optimistic snapshot; with no writer the
// read validates and the values are the ones the exclusive writer published.
bool testOlockScopedRead() {
    bool result = true;
    OlockGuarded g;
    lock (g.ver) {
        g.x = 11;
        g.y = 22;
    }

    // The body's reads must escape through a pointer: a primitive local is captured by
    // value, so it cannot carry a snapshot out. This is the closure-escape limitation
    // that keeps a raw read_begin/read_validate descent necessary (plan 4b).
    i64  sx = 0;
    i64  sy = 0;
    i64* px = &sx;
    i64* py = &sy;
    bool valid = g.ver.read(() => {
        *px = g.x;     // guarded field, read-only: legal under the optimistic grant
        *py = g.y;
    });

    result &= Test("olock.read validates with no writer", valid, true);
    result &= Test("olock.read body saw x", (int)sx, 11);
    result &= Test("olock.read body saw y", (int)sy, 22);
    return result;
}

// A writer that intervenes between read_begin() and read_validate() must invalidate the
// read. Deterministic and single-threaded: the body itself takes the exclusive lock, which
// is exactly the version bump a concurrent writer would land.
bool testOlockScopedReadInvalidated() {
    bool result = true;
    OlockGuarded g;

    bool valid = g.ver.read(() => {
        lock (g.ver) {
            g.x = 99;   // exclusive mode inside the optimistic body: a write IS legal here
        }
    });

    result &= Test("olock.read invalidated by an intervening writer", valid, false);
    lock (g.ver) {
        result &= Test("olock.read intervening write took effect", (int)g.x, 99);
    }
    return result;
}

// Struct guarded by an olock. Fields are deliberately left ungrouped (no
// lock(ver) { } field group) - the raw olock API needs no grant, and Phase 4
// (Option A) builds the tree on the raw calls.
struct OlockPair {
    olock ver = default;
    i64   a   = 0;
    i64   b   = 0;
};

struct OlockReaderCtx {
    OlockPair*      pair       = nullptr;
    atomic_counter* validReads = nullptr;
    atomic_counter* consistent = nullptr;  // validated reads where a == b
    atomic_counter* torn       = nullptr;  // validated reads where a != b - must stay 0
    // Reads a writer invalidated. Must stay > 0 or the readers never raced the writer
    // and the whole test is vacuous - a seqlock that never retries proves nothing.
    atomic_counter* invalid    = nullptr;
    // Set by the writer once it is done (either it observed an invalidation or hit its
    // iteration cap). Readers spin until this is set rather than a fixed iteration count,
    // so they cannot stop racing before the writer does.
    atomic_counter* done       = nullptr;
    i64             maxLoops   = 0;  // safety cap so a stuck done flag cannot hang the test
};

struct OlockWriterCtx {
    OlockPair*      pair       = nullptr;
    int             iterations = 0;  // baseline write count
    // Wall-clock cap (ms) once chasing an invalidation, not an iteration cap: under
    // heavy scheduler contention the writer alone can burn through any fixed iteration
    // budget before a starved reader thread ever gets scheduled, which would stop the
    // writer (and unblock readers via `done`) before a race was ever possible.
    i64             capMillis  = 0;
    atomic_counter* invalid    = nullptr;
    atomic_counter* done       = nullptr;
    int             actualIterations = 0;  // out: writes actually applied
};

// Speculative read with no lock: snapshot, read both fields, validate. A
// failed validation is discarded, not counted - it is an expected restart,
// not a bug. Only fields from a validated snapshot are checked for
// consistency, which is the property the seqlock exists to guarantee.
int olockReaderWorker(void* ctx) {
    OlockReaderCtx* rc = (OlockReaderCtx*)ctx;
    i64 loops = 0;
    while (rc->done->read() == 0 && loops < rc->maxLoops) {
        i64 v  = rc->pair->ver.read_begin();
        i64 ra = rc->pair->a;
        i64 rb = rc->pair->b;
        if (rc->pair->ver.read_validate(v)) {
            rc->validReads->increment();
            if (ra == rb) {
                rc->consistent->increment();
            } else {
                rc->torn->increment();
            }
        } else {
            rc->invalid->increment();
        }
        loops = loops + 1;
    }
    return 0;
}

// Writes at least `iterations` times, then - if no reader has reported an
// invalidation yet - keeps writing until one does, bounded by a wall-clock cap.
// This is what makes "the race is real" deterministic instead of hoping a
// fixed iteration count happens to overlap a reader.
int olockWriterWorker(void* ctx) {
    OlockWriterCtx* wc = (OlockWriterCtx*)ctx;
    Timer capTimer;
    capTimer.start(wc->capMillis);
    int i = 0;
    while (i < wc->iterations || (wc->invalid->read() == 0 && !capTimer.isExpired())) {
        lock (wc->pair->ver) {
            wc->pair->a = wc->pair->a + 1;
            wc->pair->b = wc->pair->b + 1;
        }
        i = i + 1;
    }
    wc->actualIterations = i;
    wc->done->store(1);
    return 0;
}

// N reader threads spin optimistic reads over a small struct while one
// writer mutates it under lock (o) { }. This is the test that actually
// proves the seqlock works: every VALIDATED read must observe a == b, since
// the writer only ever changes both fields together while holding the lock.
bool testOlockConcurrentReadersWriter() {
    bool result = true;
    OlockPair pair;

    atomic_counter validReads;
    atomic_counter consistent;
    atomic_counter torn;
    atomic_counter invalid;
    atomic_counter done;

    int numReaders    = 4;
    int writerIters   = 20000;
    // Generous wall-clock cap: bounded by time, not iterations, so a starved writer
    // sharing the box with other parallel test processes still gets a real chance to
    // race a (possibly equally starved) reader before giving up.
    i64 writerCapMillis = 15000;
    i64 readerMaxLoops  = 2000000000;

    Thread*          readerThreads = new Thread[numReaders];
    OlockReaderCtx*  readerCtxs    = new OlockReaderCtx[numReaders];
    int i = 0;
    while (i < numReaders) {
        readerCtxs[i].pair       = &pair;
        readerCtxs[i].validReads = &validReads;
        readerCtxs[i].consistent = &consistent;
        readerCtxs[i].torn       = &torn;
        readerCtxs[i].invalid    = &invalid;
        readerCtxs[i].done       = &done;
        readerCtxs[i].maxLoops   = readerMaxLoops;
        readerThreads[i].start(olockReaderWorker, &readerCtxs[i]);
        i = i + 1;
    }

    OlockWriterCtx writerCtx;
    writerCtx.pair       = &pair;
    writerCtx.iterations = writerIters;
    writerCtx.capMillis  = writerCapMillis;
    writerCtx.invalid    = &invalid;
    writerCtx.done       = &done;
    Thread writerThread;
    writerThread.start(olockWriterWorker, &writerCtx);

    writerThread.join();
    i = 0;
    while (i < numReaders) { readerThreads[i].join(); i = i + 1; }

    result &= Test("olock concurrent: no torn reads observed", (int)torn.read(), 0);
    result &= Test("olock concurrent: some reads were validated",
                    (int)(validReads.read() > 0), 1);
    // The writer keeps writing past its baseline iteration count (bounded by
    // writerCapMillis) until a reader reports an invalidation, so this is no longer
    // a statistical hope: it fails only if the cap above is genuinely exhausted.
    result &= Test("olock concurrent: some reads were invalidated (the race is real)",
                    (int)(invalid.read() > 0), 1);
    result &= Test("olock concurrent: consistent reads == valid reads",
                    (int)(consistent.read() == validReads.read()), 1);
    result &= Test("olock concurrent: writer applied all increments",
                    (int)pair.a, writerCtx.actualIterations);
    result &= Test("olock concurrent: final a == b", (int)(pair.a == pair.b), 1);

    delete[_] readerThreads;
    delete[_] readerCtxs;
    return result;
}

// ---------------------------------------------------------------------------
// Entry point
// ---------------------------------------------------------------------------

extern int main() {
    int passed = 0;
    int total  = 0;

    // Thread tests
    total++; passed += testThreadWritesThroughPointer()  ? 1 : 0;
    total++; passed += testThreadReadsThroughPointer()   ? 1 : 0;
    total++; passed += testThreadExitCode()              ? 1 : 0;
    total++; passed += testMultipleThreadsConcurrent()   ? 1 : 0;
    total++; passed += testLambdaWritesViaCtx()          ? 1 : 0;
    total++; passed += testLambdaExitCodeFromCtx()       ? 1 : 0;
    total++; passed += testThreadComputationViaStruct()  ? 1 : 0;
    total++; passed += testLambdaComputationViaStruct()  ? 1 : 0;
    total++; passed += testSequentialThreads()           ? 1 : 0;
    total++; passed += testThreadExitCodeZero()          ? 1 : 0;
    total++; passed += testMultipleThreadsCompute()      ? 1 : 0;
    total++; passed += testThreadStartMoveOwnership()    ? 1 : 0;

    // Mutex / atomic tests
    total++; passed += testMutexManual()              ? 1 : 0;
    total++; passed += testLockStatement()            ? 1 : 0;
    total++; passed += testLockBreak()                ? 1 : 0;
    total++; passed += testLockContinue()             ? 1 : 0;
    total++; passed += testNestedLockBreak()          ? 1 : 0;
    total++; passed += testMutexWithThreads()         ? 1 : 0;
    total++; passed += testAtomicCounterIncrement()   ? 1 : 0;
    total++; passed += testAtomicCounterDecrement()   ? 1 : 0;
    total++; passed += testAtomicCounterAdd()         ? 1 : 0;
    total++; passed += testAtomicCounterThreaded()    ? 1 : 0;
    total++; passed += testAtomicFlag()               ? 1 : 0;
    total++; passed += testAtomicI32()                ? 1 : 0;
    total++; passed += testAtomicI64()                ? 1 : 0;
    total++; passed += testAcquireFenceAndReleaseStore() ? 1 : 0;

    // Semaphore / latch / rwlock tests
    total++; passed += testSemaphoreBasic()           ? 1 : 0;
    total++; passed += testSemaphoreWithThreads()     ? 1 : 0;
    total++; passed += testSemaphoreLockStatement()   ? 1 : 0;
    total++; passed += testLatchBasic()               ? 1 : 0;
    total++; passed += testLatchWithThreads()         ? 1 : 0;
    total++; passed += testLatchAlreadyZero()         ? 1 : 0;
    total++; passed += testRwlockExclusive()          ? 1 : 0;
    total++; passed += testRwlockShared()             ? 1 : 0;
    total++; passed += testRwlockLockStatement()      ? 1 : 0;
    total++; passed += testRwlockWithThreads()        ? 1 : 0;

    // RAII teardown of the sync primitives
    total++; passed += testLockDestroyIsIdempotent()  ? 1 : 0;
    total++; passed += testLockUsableAfterDestroy()   ? 1 : 0;
    total++; passed += testEventSemaphoreBarrierDestroyIdempotent() ? 1 : 0;
    total++; passed += testLockScopeExitReleasesRepeatedly()        ? 1 : 0;

    // Embedded sub-struct initialization tests
    total++; passed += testEmbeddedAtomicFlagInitialized()    ? 1 : 0;
    total++; passed += testEmbeddedAtomicCounterInitialized() ? 1 : 0;

    // Channel / spsc_queue tests
    total++; passed += testChannelBasicSendReceive()  ? 1 : 0;
    total++; passed += testChannelCount()             ? 1 : 0;
    total++; passed += testChannelTryReceive()        ? 1 : 0;
    total++; passed += testChannelWrapAround()        ? 1 : 0;
    total++; passed += testChannelProducerConsumer()  ? 1 : 0;
    total++; passed += testChannelMultiProducer()     ? 1 : 0;
    total++; passed += testChannelPipeSingle()        ? 1 : 0;
    total++; passed += testChannelPipeChained()       ? 1 : 0;
    total++; passed += testChannelPipeEmpty()         ? 1 : 0;
    total++; passed += testSpscBasic()                ? 1 : 0;
    total++; passed += testSpscWrapAround()           ? 1 : 0;
    total++; passed += testSpscThreaded()             ? 1 : 0;

    total++; passed += testAtomicFlagReleaseAcquire()     ? 1 : 0;
    total++; passed += testAtomicI32ReleaseAcquire()      ? 1 : 0;
    total++; passed += testLockAnnotations()              ? 1 : 0;
    total++; passed += testLockPointerGuard()             ? 1 : 0;
    total++; passed += testLockArrowForm()                ? 1 : 0;
    total++; passed += testGlobalGuardGroup()             ? 1 : 0;

    // barrier / spin_barrier tests
    total++; passed += testBarrierSingleThreadReuse()     ? 1 : 0;
    total++; passed += testBarrierThreaded()              ? 1 : 0;
    total++; passed += testSpinBarrierThreaded()          ? 1 : 0;

    // olock (optimistic lock coupling) tests
    total++; passed += testOlockValidatedReadNoWriter()     ? 1 : 0;
    total++; passed += testOlockReadInvalidatedByWrite()    ? 1 : 0;
    total++; passed += testOlockUpgrade()                   ? 1 : 0;
    total++; passed += testOlockLockStatement()              ? 1 : 0;
    total++; passed += testOlockObsoleteRoundTrip()          ? 1 : 0;
    total++; passed += testOlockScopedRead()                 ? 1 : 0;
    total++; passed += testOlockScopedReadInvalidated()      ? 1 : 0;
    total++; passed += testOlockConcurrentReadersWriter()    ? 1 : 0;

    printf("Thread/Sync tests: %d/%d passed.\n", passed, total);
    return passed == total ? 0 : 1;
}
