// HPC feature tests: the thin `int[]` array-view (noalias) type and the explicit
// `simd<T,N>` vector type. Both are within-core (SIMD) primitives - see doc/HPC.md.
//
// Array-view section: `int[]` parameters, obtaining a view from `new T[n]`, element
// read/write via indexing `a[i]`, two-view BLAS-style kernels (the noalias case),
// `int[] -> int*` decay, and an `int[]` struct field. Compiled by test.bat at -O0 where
// the view is a plain pointer; the noalias attribute it emits is verified at -O2.
//
// simd section: splat construction, element-wise + - * /, mixed scalar/vector operands,
// all power-of-two lane counts, the full numeric element-type set, and lane reads.
// Seeded from argc (= 1 with no args) so the vector ops execute at runtime rather than
// constant-folding away.

import "cruntime.cb";
import "test_helper.cb";
import "span.cb";
import "view.cb";
import "hpc/btree.cb";
import "thread.cb";
import "atomic.cb";

// ---------------------------------------------------------------------------
// int[] array-view kernels
// ---------------------------------------------------------------------------

// Single-view kernel: fill each element. Indexing is the only allowed access.
void fill(int[] a, int n, int base)
{
    int i = 0;
    while (i < n) { a[i] = base + i; i = i + 1; }
}

// Single-view reduction.
int sumv(int[] a, int n)
{
    int s = 0;
    int i = 0;
    while (i < n) { s = s + a[i]; i = i + 1; }
    return s;
}

// Two-view kernel (the BLAS pattern): y and x are provably distinct allocations, so each
// carries noalias and the loop vectorizes without a runtime alias check at -O2.
void axpy(int[] y, int[] x, int n, int k)
{
    int i = 0;
    while (i < n) { y[i] = y[i] + k * x[i]; i = i + 1; }
}

// `int[]` decays implicitly to `int*` when passed to a pointer parameter.
int sumPtr(int* a, int n)
{
    int s = 0;
    int i = 0;
    while (i < n) { s = s + a[i]; i = i + 1; }
    return s;
}

// A container holding a noalias buffer as an `int[]` field. The field is sourced from
// `new T[n]` (a view), read back as a view, indexed, and passed to view kernels - the
// store gate guarantees the field can only ever hold a whole-allocation view.
struct Matrix { int[] data; int n; };

// A class (not just struct) with an `int[]` field AND methods. This is the case the
// grammar fix targets: a field whose type carries empty brackets (`int[]`) must be
// disambiguated from a method definition (both begin with declaration-specifiers). The
// methods read the field back as a view - by index and by passing it to a free kernel.
class Vec
{
    int[] data;
    int n;
    int at(int i) { return data[i]; }       // field read, indexed
    int total() { return sumv(data, n); }   // field read passed to a view kernel
};

// A nested struct that itself carries an `int[]` field, to confirm the grammar fix holds
// for aggregates declared inside another aggregate's body.
struct Outer
{
    struct Buf { int[] cells; int len; };
    Buf buf;
    int tag;
};

// Returns a fresh view: `new T[n]` is a blessed view source, so a `T[]` return is legal.
int[] makeRange(int n, int base)
{
    int[] r = new int[n];
    fill(r, n, base);
    return r;
}

// Returns its view parameter unchanged - view flows out through a `T[]` return.
int[] passthru(int[] a) { return a; }

// ---------------------------------------------------------------------------
// simd<T,N> vector ops
// ---------------------------------------------------------------------------

int testFloatArithmetic(int seed)
{
    int passed = 0;
    float s = (float)seed;            // 1.0

    simd<float, 8> a = s + 1.0;       // 2.0 per lane (splat)
    simd<float, 8> b = 3.0;           // 3.0 per lane
    simd<float, 8> mul = a * b;       // 6.0
    simd<float, 8> add = mul + a;     // 8.0
    simd<float, 8> sub = add - b;     // 5.0
    simd<float, 8> div = sub / a;     // 2.5

    passed += Test("simd float mul", mul[0], 6.0f);
    passed += Test("simd float add lane7", add[7], 8.0f);
    passed += Test("simd float sub lane3", sub[3], 5.0f);
    passed += Test("simd float div", div[0], 2.5f);
    return passed;
}

int testMixedScalarVector(int seed)
{
    int passed = 0;
    simd<float, 4> a = (float)seed;   // 1.0
    simd<float, 4> b = a * 2.0;        // vector * scalar -> 2.0
    simd<float, 4> c = 10.0 - a;       // scalar - vector -> 9.0
    simd<float, 4> d = 12.0 / a;       // scalar / vector -> 12.0
    simd<float, 4> e = a + 4.0;        // vector + scalar -> 5.0

    passed += Test("simd vector*scalar", b[0], 2.0f);
    passed += Test("simd scalar-vector", c[3], 9.0f);
    passed += Test("simd scalar/vector", d[1], 12.0f);
    passed += Test("simd vector+scalar", e[2], 5.0f);
    return passed;
}

int testIntegerSimd(int seed)
{
    int passed = 0;
    simd<i32, 4> p = seed + 4;        // 5
    simd<i32, 4> sq = p * p;          // 25
    simd<i32, 4> df = sq - p;         // 20
    simd<i32, 4> sm = sq + p;         // 30
    simd<i32, 4> dv = sq / p;         // 5 (signed divide)

    passed += Test("simd i32 mul", sq[1], 25);
    passed += Test("simd i32 sub", df[2], 20);
    passed += Test("simd i32 add", sm[0], 30);
    passed += Test("simd i32 sdiv", dv[3], 5);
    return passed;
}

int testUnsignedSimd(int seed)
{
    int passed = 0;
    simd<u32, 4> u = (u32)(seed * 100); // 100
    simd<u32, 4> w = u / 8;             // 12 (unsigned divide)

    passed += Test("simd u32 udiv", (int)w[2], 12);
    return passed;
}

// All four power-of-two lane counts compile, lower, and execute. Read the first,
// a middle, and the last lane of each to confirm the lane indexing spans the width.
int testLaneCounts(int seed)
{
    int passed = 0;
    int v = seed + 6;                  // 7

    simd<i32, 2>  c2  = v;
    simd<i32, 16> c16 = v;
    simd<i32, 32> c32 = v;
    simd<i32, 64> c64 = v;

    simd<i32, 2>  d2  = c2  * c2;       // 49
    simd<i32, 16> d16 = c16 + c16;      // 14
    simd<i32, 32> d32 = c32 - c32;      // 0
    simd<i32, 64> d64 = c64 * c64;      // 49

    passed += Test("simd N=2 lane0",   d2[0],   49);
    passed += Test("simd N=2 lane1",   d2[1],   49);
    passed += Test("simd N=16 lane15", d16[15], 14);
    passed += Test("simd N=32 lane16", d32[16], 0);
    passed += Test("simd N=64 lane63", d64[63], 49);
    return passed;
}

// Every numeric element type: signed/unsigned 8/16/32/64-bit ints plus float/double.
// Small operands keep the narrow integer lanes inside range.
int testElementTypes(int seed)
{
    int passed = 0;

    simd<i8,  8> i8v  = (i8)(seed + 2);   // 3   -> *3 = 9
    simd<i16, 8> i16v = (i16)(seed + 9);  // 10  -> *10 = 100
    simd<i64, 4> i64v = (i64)(seed + 99); // 100 -> *100 = 10000
    simd<u8,  8> u8v  = (u8)(seed + 4);   // 5   -> *5 = 25
    simd<u16, 8> u16v = (u16)(seed + 20); // 21  -> *21 = 441
    simd<u64, 4> u64v = (u64)(seed + 999);// 1000 -> /4 = 250
    simd<double, 4> dv = (double)seed;    // 1.0 -> +0.5 then *3 = 4.5

    simd<i8,  8> i8r  = i8v  * i8v;        // 9
    simd<i16, 8> i16r = i16v * i16v;       // 100
    simd<i64, 4> i64r = i64v * i64v;       // 10000
    simd<u8,  8> u8r  = u8v  * u8v;         // 25
    simd<u16, 8> u16r = u16v * u16v;       // 441
    simd<u64, 4> u64r = u64v / 4;          // 250
    simd<double, 4> dr = (dv + 0.5) * 3.0; // 4.5

    passed += Test("simd i8 mul",    (int)i8r[0],   9);
    passed += Test("simd i16 mul",   (int)i16r[7],  100);
    passed += Test("simd i64 mul",   i64r[2],       (i64)10000);
    passed += Test("simd u8 mul",    (int)u8r[3],   25);
    passed += Test("simd u16 mul",   (int)u16r[4],  441);
    passed += Test("simd u64 udiv",  u64r[1],       (i64)250);
    passed += Test("simd double op", (float)dr[3],  4.5f);
    return passed;
}

// Several vectors of the same shape interacting in one expression, and a chain of
// dependent vector temporaries, to confirm values flow correctly across operations.
int testMultiVar(int seed)
{
    int passed = 0;
    simd<float, 4> a = (float)seed;        // 1.0
    simd<float, 4> b = a + 1.0;            // 2.0
    simd<float, 4> c = b + 1.0;            // 3.0
    simd<float, 4> r = (a + b) * c - a;    // (1+2)*3 - 1 = 8.0

    passed += Test("simd multivar lane0", r[0], 8.0f);
    passed += Test("simd multivar lane3", r[3], 8.0f);
    return passed;
}

// simd <-> memory bridge: simd<T,N>.load reads N contiguous elements of a T[]/T* buffer
// into a vector; simd<T,N>.store writes the lanes back at an element index. The type args
// make the calls self-describing, so they work with `auto` and compose in expressions.
// The only supported way to move real data through a simd value (lanes are not individually
// addressable). See doc/HPC.md.
int testSimdLoadStore()
{
    int passed = 0;

    double[] a = new double[8];
    i64 i = 0;
    while (i < 8) { a[i] = (double)(i + 1); i = i + 1; }   // a = {1,2,...,8}

    // load lanes 0..3, square, store back at index 0
    simd<double, 4> v = simd<double,4>.load(a, 0);
    v = v * v;
    simd<double,4>.store(v, a, 0);                          // a[0..4] = {1,4,9,16}

    // load the second chunk at index 4, double it, store back
    simd<double, 4> w = simd<double,4>.load(a, 4);
    simd<double,4>.store(w + w, a, 4);                      // a[4..8] = {10,12,14,16}

    passed += Test("simd.store squares a[0]", (float)a[0], 1.0f);
    passed += Test("simd.store squares a[2]", (float)a[2], 9.0f);
    passed += Test("simd.store squares a[3]", (float)a[3], 16.0f);
    passed += Test("simd.store double a[4]",  (float)a[4], 10.0f);
    passed += Test("simd.store double a[7]",  (float)a[7], 16.0f);

    // auto: the type args make the result type known without an annotation
    auto r = simd<double,4>.load(a, 0);
    passed += Test("simd.load auto round-trip lane2", (float)r[2], 9.0f);

    // composition: load nested directly inside store's argument (was impossible with the
    // old LHS-inferred form). square a[4..8] in one expression.
    simd<double,4>.store(simd<double,4>.load(a, 4) * simd<double,4>.load(a, 4), a, 4);
    passed += Test("simd compose square a[4]", (float)a[4], 100.0f);  // 10*10
    passed += Test("simd compose square a[7]", (float)a[7], 256.0f);  // 16*16

    // float element type
    float[] f = new float[4];
    f[0] = 2.0; f[1] = 3.0; f[2] = 4.0; f[3] = 5.0;
    simd<float,4>.store(simd<float,4>.load(f, 0) + simd<float,4>.load(f, 0), f, 0);  // {4,6,8,10}
    passed += Test("simd.load float compose lane1", f[1], 6.0f);

    return passed;
}

// load/store across the numeric element-type set and several lane widths. Each: fill an
// array, load the whole vector, store back a modified vector, read an element of the result.
int testSimdLoadStoreTypes()
{
    int passed = 0;

    // float, N=8
    float[] fv = new float[8];
    int i = 0;
    while (i < 8) { fv[i] = (float)(i + 1); i = i + 1; }     // 1..8
    simd<float,8>.store(simd<float,8>.load(fv, 0) + simd<float,8>.load(fv, 0), fv, 0);  // double
    passed += Test("simd ldst float8 lane7", fv[7], 16.0f);  // 8*2

    // double, N=2
    double[] dv = new double[2];
    dv[0] = 3.0; dv[1] = 4.0;
    simd<double,2>.store(simd<double,2>.load(dv, 0) * simd<double,2>.load(dv, 0), dv, 0);
    passed += Test("simd ldst double2 lane1", (float)dv[1], 16.0f);  // 4*4

    // i32, N=4
    i32[] iv = new i32[4];
    i = 0;
    while (i < 4) { iv[i] = i + 1; i = i + 1; }              // 1..4
    simd<i32,4>.store(simd<i32,4>.load(iv, 0) * simd<i32,4>.load(iv, 0), iv, 0);
    passed += Test("simd ldst i32 lane3", iv[3], 16);        // 4*4

    // i64, N=2
    i64[] lv = new i64[2];
    lv[0] = (i64)10; lv[1] = (i64)11;
    simd<i64,2>.store(simd<i64,2>.load(lv, 0) + simd<i64,2>.load(lv, 0), lv, 0);
    passed += Test("simd ldst i64 lane1", lv[1], (i64)22);   // 11*2

    // i16, N=16 (wide lane count)
    i16[] sv = new i16[16];
    i = 0;
    while (i < 16) { sv[i] = (i16)(i + 1); i = i + 1; }      // 1..16
    simd<i16,16>.store(simd<i16,16>.load(sv, 0) + simd<i16,16>.load(sv, 0), sv, 0);
    passed += Test("simd ldst i16 lane15", (int)sv[15], 32); // 16*2

    // u32, N=4 (unsigned)
    u32[] uv = new u32[4];
    i = 0;
    while (i < 4) { uv[i] = (u32)((i + 1) * 10); i = i + 1; } // 10,20,30,40
    simd<u32,4>.store(simd<u32,4>.load(uv, 0) + simd<u32,4>.load(uv, 0), uv, 0);
    passed += Test("simd ldst u32 lane2", (int)uv[2], 60);   // 30*2

    return passed;
}

// Strided kernel over a larger buffer (the real use case), plus a non-zero literal index,
// a raw T* source (not just T[]), and a runtime variable index.
int testSimdLoadStoreStrided()
{
    int passed = 0;

    int n = 16;
    double[] big = new double[n];
    int i = 0;
    while (i < n) { big[i] = (double)(i + 1); i = i + 1; }   // 1..16

    // square every element via N=4 chunks
    i = 0;
    while (i + 4 <= n) {
        auto c = simd<double,4>.load(big, i);
        simd<double,4>.store(c * c, big, i);
        i = i + 4;
    }
    passed += Test("simd strided sq big[0]",  (float)big[0],  1.0f);    // 1*1
    passed += Test("simd strided sq big[7]",  (float)big[7],  64.0f);   // 8*8
    passed += Test("simd strided sq big[15]", (float)big[15], 256.0f);  // 16*16

    // raw double* source (T[] decays to T*) + a runtime variable index
    double* p = big;
    int idx = 4;
    auto pv = simd<double,4>.load(p, idx);   // big[4..8] = {25,36,49,64}
    passed += Test("simd ldst ptr-src lane0", (float)pv[0], 25.0f);  // 5*5
    passed += Test("simd ldst ptr-src lane1", (float)pv[1], 36.0f);  // 6*6

    // store through a raw T* at a variable index, then read it back
    simd<double,4>.store(simd<double,4>.load(p, idx) + simd<double,4>.load(p, idx), p, idx);
    passed += Test("simd ldst ptr-store big[5]", (float)big[5], 72.0f);  // 36*2

    return passed;
}

// Elementwise vector math intrinsics on simd<T,N>: each is a static method that lowers to
// a true SIMD instruction (sqrtps, roundps, vfmadd, minps, ...). Build inputs, apply the
// op, read lanes back. Covers unary (sqrt/abs/floor/ceil/trunc/round/rint), binary
// (min/max/copysign), and ternary (fma).
int testSimdMath()
{
    int passed = 0;

    double[] a = new double[4];
    double[] b = new double[4];
    a[0] = 4.0;  a[1] = 9.0;  a[2] = 16.0; a[3] = 25.0;
    b[0] = -1.5; b[1] = 2.5;  b[2] = -3.5; b[3] = 4.5;
    simd<double,4> va = simd<double,4>.load(a, 0);
    simd<double,4> vb = simd<double,4>.load(b, 0);

    double[] o = new double[4];

    // sqrt: {2,3,4,5}
    simd<double,4>.store(simd<double,4>.sqrt(va), o, 0);
    passed += Test("simd sqrt lane0", (float)o[0], 2.0f);
    passed += Test("simd sqrt lane3", (float)o[3], 5.0f);

    // abs: |b| = {1.5,2.5,3.5,4.5}
    simd<double,4>.store(simd<double,4>.abs(vb), o, 0);
    passed += Test("simd abs lane0", (float)o[0], 1.5f);
    passed += Test("simd abs lane2", (float)o[2], 3.5f);

    // min/max of a and b (elementwise)
    simd<double,4>.store(simd<double,4>.min(va, vb), o, 0);  // {-1.5,2.5,-3.5,4.5}
    passed += Test("simd min lane0", (float)o[0], -1.5f);
    passed += Test("simd min lane3", (float)o[3], 4.5f);
    simd<double,4>.store(simd<double,4>.max(va, vb), o, 0);  // {4,9,16,25}
    passed += Test("simd max lane0", (float)o[0], 4.0f);

    // copysign: magnitude of a, sign of b -> {-4,9,-16,25}
    simd<double,4>.store(simd<double,4>.copysign(va, vb), o, 0);
    passed += Test("simd copysign lane0", (float)o[0], -4.0f);
    passed += Test("simd copysign lane1", (float)o[1], 9.0f);

    // fma: a*b + a
    simd<double,4>.store(simd<double,4>.fma(va, vb, va), o, 0);
    passed += Test("simd fma lane0", (float)o[0], -2.0f);     // 4*-1.5+4
    passed += Test("simd fma lane3", (float)o[3], 137.5f);    // 25*4.5+25

    // rounding family on a fractional buffer
    double[] frac = new double[4];
    frac[0] = 2.3; frac[1] = -2.3; frac[2] = 2.7; frac[3] = -2.7;
    simd<double,4> vf = simd<double,4>.load(frac, 0);
    simd<double,4>.store(simd<double,4>.floor(vf), o, 0);     // {2,-3,2,-3}
    passed += Test("simd floor lane1", (float)o[1], -3.0f);
    simd<double,4>.store(simd<double,4>.ceil(vf), o, 0);      // {3,-2,3,-2}
    passed += Test("simd ceil lane0", (float)o[0], 3.0f);
    simd<double,4>.store(simd<double,4>.trunc(vf), o, 0);     // {2,-2,2,-2}
    passed += Test("simd trunc lane3", (float)o[3], -2.0f);
    simd<double,4>.store(simd<double,4>.round(vf), o, 0);     // {2,-2,3,-3}
    passed += Test("simd round lane2", (float)o[2], 3.0f);

    // clamp(x, lo, hi) elementwise. lo=5, hi=20 over a={4,9,16,25} -> {5,9,16,20}
    simd<double,4> lo = 5.0;
    simd<double,4> hi = 20.0;
    simd<double,4>.store(simd<double,4>.clamp(va, lo, hi), o, 0);
    passed += Test("simd clamp lane0 (below lo)", (float)o[0], 5.0f);   // 4 -> 5
    passed += Test("simd clamp lane1 (in range)", (float)o[1], 9.0f);   // 9 stays
    passed += Test("simd clamp lane3 (above hi)", (float)o[3], 20.0f);  // 25 -> 20

    // sign(x): b={-1.5,2.5,-3.5,4.5} -> {-1,1,-1,1}; plus a zero lane stays 0
    simd<double,4>.store(simd<double,4>.sign(vb), o, 0);
    passed += Test("simd sign neg lane0", (float)o[0], -1.0f);
    passed += Test("simd sign pos lane1", (float)o[1], 1.0f);
    double[] z = new double[4];
    z[0] = 0.0; z[1] = -7.0; z[2] = 0.0; z[3] = 8.0;
    simd<double,4>.store(simd<double,4>.sign(simd<double,4>.load(z, 0)), o, 0); // {0,-1,0,1}
    passed += Test("simd sign zero lane0", (float)o[0], 0.0f);
    passed += Test("simd sign zero lane2", (float)o[2], 0.0f);
    delete[] z;

    // compose: 1/sqrt(a) reciprocal-sqrt without naming an intermediate vector
    simd<double,4> one = 1.0;
    simd<double,4>.store(one / simd<double,4>.sqrt(va), o, 0); // {0.5, 0.333.., 0.25, 0.2}
    passed += Test("simd rsqrt lane0", (float)o[0], 0.5f);
    passed += Test("simd rsqrt lane2", (float)o[2], 0.25f);

    // float element type
    float[] ff = new float[4];
    ff[0] = 9.0; ff[1] = 16.0; ff[2] = 25.0; ff[3] = 36.0;
    simd<float,4>.store(simd<float,4>.sqrt(simd<float,4>.load(ff, 0)), ff, 0);  // {3,4,5,6}
    passed += Test("simd sqrt float lane3", ff[3], 6.0f);

    delete[] a; delete[] b; delete[] o; delete[] frac; delete[] ff;
    return passed;
}

// simd<T,N> comparisons -> simd<bool,N> mask, and simd<T,N>.select(mask, a, b) branchless
// blend. A comparison lowers to a vector compare (<N x i1>); select lowers to a single
// vector select (vblendvps). Together they let a masked kernel - e.g. an LBM bounce-back
// `solid ? wall : value` - stay straight-line and vectorize. See doc/HPC.md.
int testSimdCompareSelect()
{
    int passed = 0;

    // Load from memory so the operands are runtime values (not constant-folded).
    double[] ad = new double[4];
    double[] bd = new double[4];
    ad[0] = 4.0;   ad[1] = 9.0;   ad[2] = 16.0;  ad[3] = 25.0;
    bd[0] = 100.0; bd[1] = 200.0; bd[2] = 300.0; bd[3] = 400.0;
    simd<double,4> a = simd<double,4>.load(ad, 0);
    simd<double,4> b = simd<double,4>.load(bd, 0);
    simd<double,4> thresh = 10.0;
    simd<double,4> nine   = 9.0;

    // Greater: a > 10 -> {F,F,T,T}; select(mask, a, b) = mask ? a : b -> {100,200,16,25}
    simd<bool,4> gt = a > thresh;                       // explicit mask type round-trips
    simd<double,4> rg = simd<double,4>.select(gt, a, b);
    passed += Test("simd select gt lane0 (false->b)", (float)rg[0], 100.0f);
    passed += Test("simd select gt lane2 (true->a)",  (float)rg[2], 16.0f);
    passed += Test("simd select gt lane3 (true->a)",  (float)rg[3], 25.0f);

    // Less, with the comparison written inline as the select argument (no named mask).
    simd<double,4> rl = simd<double,4>.select(a < thresh, a, b);   // {4,9,300,400}
    passed += Test("simd select lt lane1 (true->a)",  (float)rl[1], 9.0f);
    passed += Test("simd select lt lane2 (false->b)", (float)rl[2], 300.0f);

    // Equal / NotEqual.
    simd<double,4> req = simd<double,4>.select(a == nine, b, a);   // {4,200,16,25}
    passed += Test("simd select eq lane1 (true->b)",  (float)req[1], 200.0f);
    passed += Test("simd select eq lane0 (false->a)", (float)req[0], 4.0f);
    simd<double,4> rne = simd<double,4>.select(a != nine, b, a);   // {100,9,300,400}
    passed += Test("simd select ne lane1 (false->a)", (float)rne[1], 9.0f);
    passed += Test("simd select ne lane3 (true->b)",  (float)rne[3], 400.0f);

    // GreaterEqual / LessEqual boundary (lane1 == 9 == thresh-ish boundary at nine).
    simd<double,4> rge = simd<double,4>.select(a >= nine, a, b);   // a>=9 -> {F,T,T,T}
    passed += Test("simd select ge lane0 (false->b)", (float)rge[0], 100.0f);
    passed += Test("simd select ge lane1 (true->a)",  (float)rge[1], 9.0f);
    simd<double,4> rle = simd<double,4>.select(a <= nine, a, b);   // a<=9 -> {T,T,F,F}
    passed += Test("simd select le lane0 (true->a)",  (float)rle[0], 4.0f);
    passed += Test("simd select le lane2 (false->b)", (float)rle[2], 300.0f);

    // Integer compare + select (signed).
    i32[] ai = new i32[4];
    ai[0] = 1; ai[1] = 2; ai[2] = 3; ai[3] = 4;
    simd<i32,4> ia = simd<i32,4>.load(ai, 0);
    simd<i32,4> three = 3;
    simd<i32,4> tens  = 10;
    simd<i32,4> zeros = 0;
    simd<i32,4> ri = simd<i32,4>.select(ia >= three, tens, zeros);  // {0,0,10,10}
    passed += Test("simd select int ge lane1", ri[1], 0);
    passed += Test("simd select int ge lane2", ri[2], 10);

    // Unsigned compare picks the unsigned predicate (large value > small under unsigned).
    u32[] au = new u32[4];
    au[0] = (u32)5; au[1] = (u32)4000000000; au[2] = (u32)7; au[3] = (u32)4000000001;
    simd<u32,4> ua  = simd<u32,4>.load(au, 0);
    simd<u32,4> big = (u32)1000000000;
    simd<u32,4> uOne  = (u32)1;
    simd<u32,4> uZero = (u32)0;
    simd<u32,4> ru = simd<u32,4>.select(ua > big, uOne, uZero);     // {0,1,0,1}
    passed += Test("simd select uns lane0", (int)ru[0], 0);
    passed += Test("simd select uns lane1", (int)ru[1], 1);

    // The motivating kernel shape: bounce-back blend. Where a cell is "solid" replace the
    // value with the wall value, else keep it - exactly `solid ? wall : value`, branchless.
    double[] vald = new double[4];
    double[] solidd = new double[4];   // 1.0 = solid, 0.0 = fluid
    vald[0] = 1.1; vald[1] = 2.2; vald[2] = 3.3; vald[3] = 4.4;
    solidd[0] = 0.0; solidd[1] = 1.0; solidd[2] = 0.0; solidd[3] = 1.0;
    simd<double,4> value = simd<double,4>.load(vald, 0);
    simd<double,4> solid = simd<double,4>.load(solidd, 0);
    simd<double,4> wall  = 0.0;
    simd<double,4> half  = 0.5;
    simd<double,4> blended = simd<double,4>.select(solid > half, wall, value);  // {1.1,0,3.3,0}
    passed += Test("simd bounce-back fluid lane0", (float)blended[0], 1.1f);
    passed += Test("simd bounce-back solid lane1", (float)blended[1], 0.0f);
    passed += Test("simd bounce-back fluid lane2", (float)blended[2], 3.3f);
    passed += Test("simd bounce-back solid lane3", (float)blended[3], 0.0f);

    // `auto` deduces the mask and the blended vector identically to the explicit spelling:
    // the simd type rides the value, so the named-mask form needs no annotation. (typeof on an
    // `auto` reports "auto" - that is universal to auto, not simd-specific - but the value,
    // lane reads, and select behave exactly as the explicit simd<bool,4> / simd<double,4>.)
    auto am = a > thresh;                                // auto mask (same as `gt` above)
    auto ar = simd<double,4>.select(am, a, b);           // auto-typed select result
    passed += Test("simd select auto-mask lane0", (float)ar[0], 100.0f);
    passed += Test("simd select auto-mask lane2", (float)ar[2], 16.0f);
    auto ar2 = simd<double,4>.select(a < thresh, a, b);  // auto result + inline comparison
    passed += Test("simd select auto inline lane1", (float)ar2[1], 9.0f);

    delete[] ad; delete[] bd; delete[] ai; delete[] au; delete[] vald; delete[] solidd;
    return passed;
}

// ---------------------------------------------------------------------------
// simd<T,N> horizontal reductions: reduce_add/min/max collapse all N lanes to a
// scalar T. Checked against the equivalent scalar loop over v[i]. reduce_add on
// float/double is reassociating (see doc/HPC.md); values below are powers of two
// so the sum is exactly representable regardless of summation order.
// ---------------------------------------------------------------------------
int testSimdReduce()
{
    int passed = 0;

    float[] af = new float[4];
    af[0] = 1.0f; af[1] = 2.0f; af[2] = 4.0f; af[3] = 8.0f;   // sum=15, min=1, max=8
    simd<float,4> vf = simd<float,4>.load(af, 0);
    passed += Test("simd reduce_add float",  simd<float,4>.reduce_add(vf), 15.0f);
    passed += Test("simd reduce_min float",  simd<float,4>.reduce_min(vf), 1.0f);
    passed += Test("simd reduce_max float",  simd<float,4>.reduce_max(vf), 8.0f);

    double[] ad = new double[4];
    ad[0] = 1.0; ad[1] = 2.0; ad[2] = 4.0; ad[3] = 8.0;       // sum=15, min=1, max=8
    simd<double,4> vd = simd<double,4>.load(ad, 0);
    passed += Test("simd reduce_add double", (float)simd<double,4>.reduce_add(vd), 15.0f);
    passed += Test("simd reduce_min double", (float)simd<double,4>.reduce_min(vd), 1.0f);
    passed += Test("simd reduce_max double", (float)simd<double,4>.reduce_max(vd), 8.0f);

    i32[] ai = new i32[4];
    ai[0] = -5; ai[1] = 3; ai[2] = -20; ai[3] = 7;            // sum=-15, min=-20, max=7
    simd<i32,4> vi = simd<i32,4>.load(ai, 0);
    passed += Test("simd reduce_add i32", simd<i32,4>.reduce_add(vi), -15);
    passed += Test("simd reduce_min i32", simd<i32,4>.reduce_min(vi), -20);
    passed += Test("simd reduce_max i32", simd<i32,4>.reduce_max(vi), 7);

    // Unsigned: a large top-bit-set lane must reduce as the biggest value, not negative.
    u32[] au = new u32[4];
    au[0] = (u32)5; au[1] = (u32)4000000000; au[2] = (u32)7; au[3] = (u32)9;
    simd<u32,4> vu = simd<u32,4>.load(au, 0);
    passed += Test("simd reduce_add u32", (i64)simd<u32,4>.reduce_add(vu), (i64)4000000021);
    passed += Test("simd reduce_min u32", (int)simd<u32,4>.reduce_min(vu), 5);
    passed += Test("simd reduce_max u32", (i64)simd<u32,4>.reduce_max(vu), (i64)4000000000);

    delete[] af; delete[] ad; delete[] ai; delete[] au;
    return passed;
}

// ---------------------------------------------------------------------------
// simd<T,N> masked load/store: the tail-free replacement for a scalar epilogue.
// simd<T,N>.lanes() builds the {0,1,...,N-1} iota used to compare against the
// remaining count and produce the tail mask.
// ---------------------------------------------------------------------------
int testSimdMasked()
{
    int passed = 0;

    // Partial-tail load: only 2 of 4 lanes are "in range" (remaining = 2).
    double[] src = new double[4];
    src[0] = 10.0; src[1] = 20.0; src[2] = 30.0; src[3] = 40.0;
    simd<double,4> remaining = 2.0;
    simd<bool,4> mask = simd<double,4>.lanes() < remaining;      // {T,T,F,F}
    simd<double,4> passthru = (double)-1.0;
    simd<double,4> loaded = simd<double,4>.load_masked(src, 0, mask, passthru);
    passed += Test("simd load_masked in-range lane0",  (float)loaded[0], 10.0f);
    passed += Test("simd load_masked in-range lane1",  (float)loaded[1], 20.0f);
    passed += Test("simd load_masked passthru lane2",  (float)loaded[2], -1.0f);
    passed += Test("simd load_masked passthru lane3",  (float)loaded[3], -1.0f);

    // Partial-tail store: masked-off lanes must leave destination memory untouched.
    double[] dst = new double[4];
    dst[0] = 0.0; dst[1] = 0.0; dst[2] = 111.0; dst[3] = 222.0;   // 2,3 are sentinel
    simd<double,4> v = simd<double,4>.load(src, 0);               // {10,20,30,40}
    simd<double,4>.store_masked(v, dst, 0, mask);                 // writes lanes 0,1 only
    passed += Test("simd store_masked writes lane0",    (float)dst[0], 10.0f);
    passed += Test("simd store_masked writes lane1",    (float)dst[1], 20.0f);
    passed += Test("simd store_masked untouched lane2", (float)dst[2], 111.0f);
    passed += Test("simd store_masked untouched lane3", (float)dst[3], 222.0f);

    delete[] src; delete[] dst;
    return passed;
}

// ---------------------------------------------------------------------------
// simd<T,N> gather/scatter: unmasked MVP over a simd<i32,N> index vector.
// ---------------------------------------------------------------------------
int testSimdGatherScatter()
{
    int passed = 0;

    // Permutation gather: idx picks lanes out of order, with a repeat (index 0 read twice).
    double[] table = new double[8];
    table[0]=100.0; table[1]=101.0; table[2]=102.0; table[3]=103.0;
    table[4]=104.0; table[5]=105.0; table[6]=106.0; table[7]=107.0;
    i32[] idxa = new i32[4];
    idxa[0] = 7; idxa[1] = 0; idxa[2] = 3; idxa[3] = 0;
    simd<i32,4> idx = simd<i32,4>.load(idxa, 0);
    simd<double,4> gathered = simd<double,4>.load_gather(table, idx);
    passed += Test("simd load_gather lane0", (float)gathered[0], 107.0f);
    passed += Test("simd load_gather lane1", (float)gathered[1], 100.0f);
    passed += Test("simd load_gather lane2", (float)gathered[2], 103.0f);
    passed += Test("simd load_gather lane3", (float)gathered[3], 100.0f);

    // Scatter with a duplicate index: LLVM's masked.scatter stores in lane order, so the
    // last lane targeting a given address wins.
    double[] out = new double[8];
    i32[] outIdxA = new i32[4];
    outIdxA[0] = 2; outIdxA[1] = 5; outIdxA[2] = 2; outIdxA[3] = 1;   // lane0 and lane2 both hit index 2
    simd<i32,4> outIdx = simd<i32,4>.load(outIdxA, 0);
    double[] vals = new double[4];
    vals[0] = 1.0; vals[1] = 2.0; vals[2] = 3.0; vals[3] = 4.0;      // lane2's 3.0 must win at index 2
    simd<double,4> valsv = simd<double,4>.load(vals, 0);
    simd<double,4>.store_scatter(valsv, out, outIdx);
    passed += Test("simd store_scatter dup-index last-lane-wins", (float)out[2], 3.0f);
    passed += Test("simd store_scatter lane1 target",  (float)out[5], 2.0f);
    passed += Test("simd store_scatter lane3 target",  (float)out[1], 4.0f);

    // Gather/scatter round-trip through the same index vector.
    double[] rtSrc = new double[4];
    rtSrc[0] = 11.0; rtSrc[1] = 22.0; rtSrc[2] = 33.0; rtSrc[3] = 44.0;
    i32[] identA = new i32[4];
    identA[0] = 3; identA[1] = 2; identA[2] = 1; identA[3] = 0;
    simd<i32,4> ident = simd<i32,4>.load(identA, 0);
    double[] rtDst = new double[4];
    simd<double,4>.store_scatter(simd<double,4>.load_gather(rtSrc, ident), rtDst, ident);
    passed += Test("simd gather/scatter round-trip lane0", (float)rtDst[0], 11.0f);
    passed += Test("simd gather/scatter round-trip lane3", (float)rtDst[3], 44.0f);

    delete[] table; delete[] idxa; delete[] out; delete[] outIdxA; delete[] vals;
    delete[] rtSrc; delete[] identA; delete[] rtDst;
    return passed;
}

// ---------------------------------------------------------------------------
// span<T> (noalias) and view<T> (may-alias) library types - see doc/HPC.md.
// span rides the T[] array-view noalias metadata; view is the may-alias sibling.
// (Correctness is checked here at -O0; the noalias/no-memcheck IR guarantee for
//  span is verified at -O2 by test_hpc.bat.)
// ---------------------------------------------------------------------------

// span axpy in the documented noalias shape: bind each span's buffer to a local
// T[] and loop over that (the form the optimizer vectorizes without a check).
void span_axpy(double k, span<double> y, span<double> x)
{
    double[] yv = y.data();
    double[] xv = x.data();
    i64 n = y.length();
    i64 i = 0;
    while (i < n) { yv[i] = yv[i] + k * xv[i]; i = i + 1; }
}

int testSpanView()
{
    int passed = 0;

    i64 n = 4;
    double[] da = new double[n];
    double[] db = new double[n];
    i64 i = 0;
    while (i < n) { da[i] = (double)i; db[i] = 1.0; i = i + 1; }   // da={0,1,2,3} db={1,1,1,1}

    span<double> sy; sy.wrap(da, n);
    span<double> sx; sx.wrap(db, n);

    passed += Test("span length", (int)sy.length(), 4);
    passed += Test("span get",    (float)sy.get(2), 2.0f);
    sy.set(0, 7.0);
    passed += Test("span set",    (float)sy.get(0), 7.0f);
    passed += Test("span operator[]", (float)sx[1], 1.0f);
    sy.set(0, 0.0);   // restore da[0]

    span_axpy(2.0, sy, sx);     // da[i] += 2 * db[i]  ->  {2, 3, 4, 5}
    passed += Test("span axpy first", (float)da[0], 2.0f);
    passed += Test("span axpy last",  (float)da[3], 5.0f);

    // span -> view decay (the safe one-way direction; view -> span is rejected, see err_*).
    view<double> vv = sy.as_view();
    passed += Test("span as_view length", (int)vv.length(), 4);
    passed += Test("span as_view elem",   (float)vv[3], 5.0f);

    // view over a buffer, plus a sub-range slice (offset views are sound: view is may-alias).
    view<double> vw; vw.wrap(da, n);     // da = {2, 3, 4, 5}
    view<double> mid = vw.slice(1, 3);   // {3, 4}
    passed += Test("view slice length", (int)mid.length(), 2);
    passed += Test("view slice first",  (float)mid[0], 3.0f);
    passed += Test("view slice last",   (float)mid[1], 4.0f);
    mid.set(0, 99.0);                    // writes through to da[1]
    passed += Test("view slice writes through", (float)da[1], 99.0f);

    // span.chunk: disjoint partition (the data-parallel primitive). 7 elements
    // into 3 balanced tiles -> sizes 3,2,2 at starts 0,3,5.
    double[] dc = new double[7];
    i64 j = 0;
    while (j < 7) { dc[j] = (double)j; j = j + 1; }   // {0,1,2,3,4,5,6}
    span<double> sc; sc.wrap(dc, 7);

    span<double> c0 = sc.chunk(0, 3);    // [0,3) {0,1,2}
    span<double> c1 = sc.chunk(1, 3);    // [3,5) {3,4}
    span<double> c2 = sc.chunk(2, 3);    // [5,7) {5,6}
    passed += Test("chunk0 len", (int)c0.length(), 3);
    passed += Test("chunk1 len", (int)c1.length(), 2);
    passed += Test("chunk2 len", (int)c2.length(), 2);
    passed += Test("chunk lengths cover n",
                   (int)(c0.length() + c1.length() + c2.length()), 7);
    passed += Test("chunk0 first", (float)c0[0], 0.0f);
    passed += Test("chunk1 first", (float)c1[0], 3.0f);
    passed += Test("chunk2 last",  (float)c2[1], 6.0f);
    c1.set(0, 88.0);                     // tile-relative index 0 -> dc[3]
    passed += Test("chunk write-through", (float)dc[3], 88.0f);
    c0.set(2, 77.0);                     // dc[2]; must not disturb c1's region
    passed += Test("chunk neighbor intact", (float)dc[3], 88.0f);

    // span.slice: general sub-range decays to a may-alias view<T> (NOT a span).
    // dc is now {0,1,77,88,4,5,6}.
    view<double> ss = sc.slice(2, 5);    // {77, 88, 4}
    passed += Test("span slice length", (int)ss.length(), 3);
    passed += Test("span slice first",  (float)ss[0], 77.0f);
    ss.set(2, 44.0);                     // writes through to dc[4]
    passed += Test("span slice writes through", (float)dc[4], 44.0f);

    int* dcp = move dc; delete[_] dcp;
    int* dap = move da; delete[_] dap;
    int* dbp = move db; delete[_] dbp;
    return passed;
}

// Explicit (T[]) escape: re-bless a raw T* as a noalias array-view. The sanctioned
// inverse of the implicit T[] -> T* decay (the implicit reverse stays rejected; see
// err_arrayview_bind_declinit.cb).
int testArrayViewCast()
{
    int passed = 0;
    int n = 6;
    int[] a = new int[n];
    int i = 0;
    while (i < n) { a[i] = i * 10; i = i + 1; }   // {0,10,20,30,40,50}

    int* raw = a;              // implicit T[] -> T* decay
    int[] v = (int[])raw;      // explicit T* -> T[] escape
    passed += Test("cast arrayview elem0", v[0], 0);
    passed += Test("cast arrayview elem3", v[3], 30);
    v[2] = 99;                 // writes through to a's buffer
    passed += Test("cast arrayview write-through", a[2], 99);

    int* ap = move a; delete[_] ap;
    return passed;
}

// ---------------------------------------------------------------------------
// btree<K,V> - single-threaded B+tree ordered map (core/hpc/btree.cb).
// ---------------------------------------------------------------------------

// Deterministic pseudo-random source (no rand()).
int btreeLcgNext(int x)
{
    return (int)(((i64)x * 1103515245 + 12345) & 0x7fffffff);
}

// insert 1..1000 ascending, read every key back, count() == 1000.
int testBtreeAscending()
{
    int passed = 0;
    btree<int, int> t;
    int i = 1;
    while (i <= 1000) { t.add(i, i * 3); i = i + 1; }
    passed += Test("btree asc count", t.count(), 1000);

    bool allOk = true;
    i = 1;
    while (i <= 1000) { if (t.get(i) != i * 3) allOk = false; i = i + 1; }
    passed += Test("btree asc get-all", allOk, true);
    return passed;
}

// insert 1000..1 descending, same checks.
int testBtreeDescending()
{
    int passed = 0;
    btree<int, int> t;
    int i = 1000;
    while (i >= 1) { t.add(i, i * 3); i = i - 1; }
    passed += Test("btree desc count", t.count(), 1000);

    bool allOk = true;
    i = 1000;
    while (i >= 1) { if (t.get(i) != i * 3) allOk = false; i = i - 1; }
    passed += Test("btree desc get-all", allOk, true);
    return passed;
}

// insert 1..1000 in a deterministic pseudo-random order (Fisher-Yates shuffle
// driven by an LCG, no rand()), read every key back, count() == 1000.
int testBtreeRandomOrder()
{
    int passed = 0;
    btree<int, int> t;

    int[] order = new int[1000];
    int i = 0;
    while (i < 1000) { order[i] = i + 1; i = i + 1; }

    int x = 424242;
    i = 999;
    while (i > 0)
    {
        x = btreeLcgNext(x);
        int j = x % (i + 1);
        int tmp = order[i]; order[i] = order[j]; order[j] = tmp;
        i = i - 1;
    }

    i = 0;
    while (i < 1000) { t.add(order[i], order[i] * 7); i = i + 1; }
    passed += Test("btree rand count", t.count(), 1000);

    bool allOk = true;
    i = 1;
    while (i <= 1000) { if (t.get(i) != i * 7) allOk = false; i = i + 1; }
    passed += Test("btree rand get-all", allOk, true);

    int* op = move order; delete[_] op;
    return passed;
}

// add() on a duplicate key returns false and leaves the old value untouched;
// set() overwrites.
int testBtreeAddSetDuplicate()
{
    int passed = 0;
    btree<int, int> t;
    passed += Test("btree dup initial add", t.add(5, 50), true);
    passed += Test("btree dup second add returns false", t.add(5, 999), false);
    passed += Test("btree dup value untouched", t.get(5), 50);
    t.set(5, 555);
    passed += Test("btree dup set overwrites", t.get(5), 555);
    return passed;
}

// remove every key in insertion order -> count() == 0, all gets miss.
int testBtreeRemoveAscending()
{
    int passed = 0;
    btree<int, int> t;
    int i = 1;
    while (i <= 500) { t.add(i, i); i = i + 1; }

    bool allRemoved = true;
    i = 1;
    while (i <= 500) { if (!t.remove(i)) allRemoved = false; i = i + 1; }
    passed += Test("btree remove-asc all removed", allRemoved, true);
    passed += Test("btree remove-asc count zero", t.count(), 0);

    bool allMiss = true;
    i = 1;
    while (i <= 500) { if (t.contains(i)) allMiss = false; i = i + 1; }
    passed += Test("btree remove-asc all miss", allMiss, true);
    return passed;
}

// remove every key in reverse (descending) order -> same checks.
int testBtreeRemoveDescending()
{
    int passed = 0;
    btree<int, int> t;
    int i = 1;
    while (i <= 500) { t.add(i, i); i = i + 1; }

    bool allRemoved = true;
    i = 500;
    while (i >= 1) { if (!t.remove(i)) allRemoved = false; i = i - 1; }
    passed += Test("btree remove-desc all removed", allRemoved, true);
    passed += Test("btree remove-desc count zero", t.count(), 0);

    bool allMiss = true;
    i = 1;
    while (i <= 500) { if (t.contains(i)) allMiss = false; i = i + 1; }
    passed += Test("btree remove-desc all miss", allMiss, true);
    return passed;
}

// Deterministic removals against a known 40-key tree (BTREE_FANOUT=16 gives root
// keys=[9,17,25] over four leaves of size 8,8,8,16), each engineered to hit exactly
// one rebalance path. Verified structurally with a debug dump during development;
// here we check behavior (count/contains) rather than internal node shape.
int testBtreeRebalanceScenarios()
{
    int passed = 0;

    // borrow-from-right: leaf0 (no left sibling) underflows; leaf1 has surplus to lend.
    {
        btree<int, int> t;
        int i = 1;
        while (i <= 40) { t.add(i, i); i = i + 1; }
        t.remove(1);
        t.remove(2);
        passed += Test("btree borrow-right count", t.count(), 38);
        bool ok = true;
        i = 3;
        while (i <= 40) { if (!t.contains(i)) ok = false; i = i + 1; }
        passed += Test("btree borrow-right keys intact", ok, true);
        passed += Test("btree borrow-right removed gone", t.contains(1) || t.contains(2), false);
    }

    // borrow-from-left: leaf1 underflows; its left sibling (leaf0) has surplus to lend.
    {
        btree<int, int> t;
        int i = 1;
        while (i <= 40) { t.add(i, i); i = i + 1; }
        t.remove(9);
        t.remove(10);
        passed += Test("btree borrow-left count", t.count(), 38);
        bool ok = true;
        i = 1;
        while (i <= 40)
        {
            bool skip = (i == 9 || i == 10);
            if (!skip && !t.contains(i)) ok = false;
            i = i + 1;
        }
        passed += Test("btree borrow-left keys intact", ok, true);
        passed += Test("btree borrow-left removed gone", t.contains(9) || t.contains(10), false);
    }

    // merge-with-right: leaf0 (no left sibling) underflows; leaf1 is pre-shrunk to
    // exactly the minimum (no surplus), so leaf1 merges into leaf0.
    {
        btree<int, int> t;
        int i = 1;
        while (i <= 40) { t.add(i, i); i = i + 1; }
        t.remove(9);
        t.remove(1);
        t.remove(2);
        passed += Test("btree merge-right count", t.count(), 37);
        bool ok = true;
        i = 3;
        while (i <= 40)
        {
            bool skip = (i == 9);
            if (!skip && !t.contains(i)) ok = false;
            i = i + 1;
        }
        passed += Test("btree merge-right keys intact", ok, true);
        passed += Test("btree merge-right removed gone",
            t.contains(1) || t.contains(2) || t.contains(9), false);
    }

    // merge-with-left: leaf1 underflows with neither sibling offering a surplus (both
    // pre-shrunk to exactly the minimum), so it merges into its LEFT sibling (leaf0) -
    // the algorithm's default merge direction when a left sibling exists.
    {
        btree<int, int> t;
        int i = 1;
        while (i <= 40) { t.add(i, i); i = i + 1; }
        t.remove(1);
        t.remove(17);
        t.remove(9);
        t.remove(10);
        passed += Test("btree merge-left count", t.count(), 36);
        bool ok = true;
        i = 2;
        while (i <= 40)
        {
            bool skip = (i == 9 || i == 10 || i == 17);
            if (!skip && !t.contains(i)) ok = false;
            i = i + 1;
        }
        passed += Test("btree merge-left keys intact", ok, true);
        passed += Test("btree merge-left removed gone",
            t.contains(1) || t.contains(9) || t.contains(10) || t.contains(17), false);
    }

    // root collapse: the tree's only internal level drains to a single child and the
    // root becomes that child directly (height shrinks from 2 to 1).
    {
        btree<int, int> t;
        int i = 1;
        while (i <= 24) { t.add(i, i); i = i + 1; }
        t.remove(1);
        i = 9;
        while (i <= 18) { t.remove(i); i = i + 1; }
        passed += Test("btree root-collapse count", t.count(), 13);
        bool ok = true;
        i = 2;
        while (i <= 24)
        {
            bool skip = (i >= 9 && i <= 18);
            if (!skip && !t.contains(i)) ok = false;
            i = i + 1;
        }
        passed += Test("btree root-collapse keys intact", ok, true);
        // the collapsed (now single-leaf) tree must still behave correctly afterward.
        t.add(100, 100);
        passed += Test("btree root-collapse still mutable", t.get(100), 100);
    }

    return passed;
}

// first()/next() must visit every key exactly once, in strictly ascending order.
int testBtreeOrderedIteration()
{
    int passed = 0;
    btree<int, int> t;
    int i = 1;
    while (i <= 200) { t.add(i, i * 2); i = i + 1; }

    auto c = t.first();
    int prevKey = -1;
    int seenCount = 0;
    bool ascending = true;
    while (c.valid())
    {
        int k = c.key();
        if (k <= prevKey) ascending = false;
        prevKey = k;
        seenCount = seenCount + 1;
        c.next();
    }
    passed += Test("btree iter strictly ascending", ascending, true);
    passed += Test("btree iter count", seenCount, 200);
    return passed;
}

// seek(lo) + walk while valid() and key() < hi returns exactly the keys in [lo, hi).
int testBtreeSeekRange()
{
    int passed = 0;
    btree<int, int> t;
    int i = 1;
    while (i <= 200) { t.add(i, i); i = i + 1; }

    auto c = t.seek(50);
    int count = 0;
    int firstSeen = -1;
    int lastSeen = -1;
    while (c.valid() && c.key() < 80)
    {
        if (firstSeen == -1) firstSeen = c.key();
        lastSeen = c.key();
        count = count + 1;
        c.next();
    }
    passed += Test("btree range [50,80) count", count, 30);
    passed += Test("btree range [50,80) first", firstSeen, 50);
    passed += Test("btree range [50,80) last", lastSeen, 79);

    // seek() below every key lands on the smallest key.
    auto c2 = t.seek(0);
    passed += Test("btree seek before-first key", c2.valid() && c2.key() == 1, true);

    // seek() past every key yields an invalid cursor.
    auto c3 = t.seek(1000);
    passed += Test("btree seek past-end invalid", c3.valid(), false);
    return passed;
}

// string keys: exercises the key.copy() deep-copy path and lexicographic ordering.
int testBtreeStringKeys()
{
    int passed = 0;
    btree<string, int> t;
    t.add("banana", 2);
    t.add("apple", 1);
    t.add("cherry", 3);
    t.add("date", 4);
    t.add("fig", 5);

    passed += Test("btree string count", t.count(), 5);
    passed += Test("btree string get apple", t.get("apple"), 1);
    passed += Test("btree string get cherry", t.get("cherry"), 3);
    passed += Test("btree string contains missing", t.contains("grape"), false);

    auto c = t.first();
    string prev = "";
    bool ascending = true;
    int n = 0;
    while (c.valid())
    {
        string k = c.key();
        if (n > 0 && !(prev < k)) ascending = false;
        prev = k;
        n = n + 1;
        c.next();
    }
    passed += Test("btree string iter ascending", ascending, true);
    passed += Test("btree string iter count", n, 5);

    passed += Test("btree string remove", t.remove("banana"), true);
    passed += Test("btree string removed gone", t.contains("banana"), false);
    passed += Test("btree string count after remove", t.count(), 4);
    return passed;
}

// pointer-valued V: the tree owns the values - add() transfers ownership, set()
// frees the old value on overwrite, and remove()/clear() free the rest.
int testBtreePointerValues()
{
    int passed = 0;
    btree<int, int*> t;
    int i = 1;
    while (i <= 50)
    {
        int* p = new int;
        *p = i * 100;
        t.add(i, p);
        i = i + 1;
    }
    passed += Test("btree ptr count", t.count(), 50);

    bool allOk = true;
    i = 1;
    while (i <= 50)
    {
        int* got = t.get(i);
        if (got == nullptr || *got != i * 100) allOk = false;
        i = i + 1;
    }
    passed += Test("btree ptr get-all", allOk, true);

    // set() must free the old value before storing the new one.
    int* fresh = new int;
    *fresh = 9999;
    t.set(5, fresh);
    int* got5 = t.get(5);
    passed += Test("btree ptr set overwrite", *got5, 9999);

    // remove() frees the value; clear() frees the rest; the tree stays usable.
    i = 1;
    while (i <= 25) { t.remove(i); i = i + 1; }
    passed += Test("btree ptr count after remove", t.count(), 25);
    t.clear();
    passed += Test("btree ptr count after clear", t.count(), 0);
    return passed;
}

// ---------------------------------------------------------------------------
// btree<K,V> concurrent lookup/insert - optimistic lock coupling, Phase 4 of
// internal/plan/optimistic-lock-coupling.md.
//
// lookup() takes no locks at all; insert() takes exactly one (the leaf's, via
// upgrade()) on its fast path. Neither ever frees a node, which is what makes
// them sound with no reclamation. remove() is NOT concurrent and is never
// called from any of these tests.
// ---------------------------------------------------------------------------

struct BtreeWriterCtx
{
    btree<int, int>* tree = nullptr;
    int base     = 0;      // inserts keys base, base+stride, ... (n of them)
    int stride   = 1;
    int n        = 0;
    int inserted = 0;      // written only by this thread; summed after join
};

struct BtreeReaderCtx
{
    btree<int, int>* tree = nullptr;
    atomic_counter*  stop = nullptr;   // set once the writers have joined
    int lo         = 0;    // probes keys lo + step*j, j in [0, span)
    int step       = 1;
    int span       = 0;
    int cap        = 0;    // hard iteration cap, so the test cannot hang
    int seed       = 0;
    int lookups    = 0;    // all three written only by this thread
    int hits       = 0;
    int errors     = 0;    // a pre-populated key must never be missing or wrong
};

int btreeInsertWorker(void* ctx)
{
    BtreeWriterCtx* c = (BtreeWriterCtx*)ctx;
    int i = 0;
    while (i < c->n)
    {
        int k = c->base + c->stride * i;
        if (c->tree->insert(k, k * 3)) c->inserted = c->inserted + 1;
        i = i + 1;
    }
    return 0;
}

// Probes keys that are present from the start and are never removed, so every
// lookup MUST hit with the right value - no matter how badly the writers are
// tearing the tree underneath. That is the property OLC has to deliver.
//
// Runs until the writers are done (stop flag) rather than for a fixed count, so
// the readers cover the WHOLE write window - which is what actually exercises the
// seqlock. The flag is a shared READ, never a write: the read path still issues no
// stores. The cap only bounds the runtime if something goes wrong.
int btreeLookupWorker(void* ctx)
{
    BtreeReaderCtx* c = (BtreeReaderCtx*)ctx;
    int x = c->seed;
    int i = 0;
    while (i < c->cap && c->stop->read() == 0)
    {
        x = btreeLcgNext(x);
        int k = c->lo + c->step * (x % c->span);
        int v = 0;
        if (c->tree->lookup(k, &v))
        {
            if (v == k * 3) c->hits = c->hits + 1;
            else c->errors = c->errors + 1;
        }
        else
        {
            c->errors = c->errors + 1;
        }
        c->lookups = c->lookups + 1;
        i = i + 1;
    }
    return 0;
}

// Depth of the leftmost root-to-leaf path.
int btreeDepthOf(btree_node<int, int>* n)
{
    int d = 0;
    while (n != nullptr && !n->isLeaf) { n = n->children[0]; d = d + 1; }
    return d;
}

// Every leaf sits at exactly `target` depth, and every internal node has count+1
// live children with count in range.
bool btreeCheckLevels(btree_node<int, int>* n, int depth, int target)
{
    if (n == nullptr) return false;
    if (n->isLeaf) return depth == target;
    if (n->count < 1 || n->count > 16) return false;
    int i = 0;
    while (i <= n->count)
    {
        if (n->children[i] == nullptr) return false;
        if (!btreeCheckLevels(n->children[i], depth + 1, target)) return false;
        i = i + 1;
    }
    return true;
}

// Walk the leaf chain: keys strictly ascending across the whole chain, every
// value paired with its key, counts in range. Returns the total entry count.
int btreeLeafChainTotal(btree_node<int, int>* root, bool* okOut)
{
    btree_node<int, int>* n = root;
    while (n != nullptr && !n->isLeaf) n = n->children[0];

    int total = 0;
    int prev  = -1;
    bool ok   = true;
    while (n != nullptr)
    {
        if (n->count < 0 || n->count > 16) { ok = false; n = nullptr; }
        else
        {
            int i = 0;
            while (i < n->count)
            {
                if (n->keys[i] <= prev) ok = false;
                if (n->values[i] != n->keys[i] * 3) ok = false;
                prev = n->keys[i];
                total = total + 1;
                i = i + 1;
            }
            n = n->next;
        }
    }
    *okOut = ok;
    return total;
}

// N readers spin optimistic lookups over the 20000 pre-populated keys (every 5th
// key) while M writers insert the other 80000 keys, INTERLEAVED across the whole
// key space by residue mod 5 - so the writers are splitting and re-locking the
// very leaves, internal nodes and root the readers are descending through. Every
// key a writer reports inserted must be findable afterwards, and every probe of a
// live key must hit with the right value throughout.
int testBtreeConcurrentLookupInsert()
{
    int passed = 0;
    btree<int, int> t;

    int i = 5;
    while (i <= 100000) { t.add(i, i * 3); i = i + 5; }  // 20000 keys, k % 5 == 0

    int numReaders  = 4;
    int numWriters  = 4;
    int perWriter   = 20000;                             // 4 * 20000 = 80000 keys

    atomic_counter stop;
    Thread* readerThreads = new Thread[numReaders];
    Thread* writerThreads = new Thread[numWriters];
    BtreeReaderCtx* rc = new BtreeReaderCtx[numReaders];
    BtreeWriterCtx* wc = new BtreeWriterCtx[numWriters];

    i = 0;
    while (i < numReaders)
    {
        rc[i].tree = &t;
        rc[i].stop = &stop;
        rc[i].lo   = 5;                                  // probes 5, 10, ... 100000
        rc[i].step = 5;
        rc[i].span = 20000;
        rc[i].cap  = 4000000;
        rc[i].seed = 777 + i * 13;
        readerThreads[i].start(btreeLookupWorker, &rc[i]);
        i = i + 1;
    }
    i = 0;
    while (i < numWriters)
    {
        wc[i].tree   = &t;
        wc[i].base   = 1 + i;                            // writer w owns k % 5 == w+1
        wc[i].stride = 5;
        wc[i].n      = perWriter;
        writerThreads[i].start(btreeInsertWorker, &wc[i]);
        i = i + 1;
    }

    i = 0;
    while (i < numWriters) { writerThreads[i].join(); i = i + 1; }
    stop.store(1);                                       // the readers ran the whole window
    i = 0;
    while (i < numReaders) { readerThreads[i].join(); i = i + 1; }

    int totalInserted = 0;
    int totalHits     = 0;
    int totalErrors   = 0;
    int totalLookups  = 0;
    i = 0;
    while (i < numWriters) { totalInserted = totalInserted + wc[i].inserted; i = i + 1; }
    i = 0;
    while (i < numReaders)
    {
        totalLookups = totalLookups + rc[i].lookups;
        totalHits    = totalHits + rc[i].hits;
        totalErrors  = totalErrors + rc[i].errors;
        i = i + 1;
    }

    i64 readRetries  = t.read_restarts();
    i64 writeRetries = t.write_restarts();
    printf("  [btree concurrent] lookups=%d read-restarts=%lld (%.1f%%) write-restarts=%lld\n",
           totalLookups, readRetries,
           100.0 * (double)readRetries / (double)(totalLookups + readRetries),
           writeRetries);

    passed += Test("btree mt: every lookup of a live key hit", totalHits, totalLookups);
    passed += Test("btree mt: no missing/torn lookup", totalErrors, 0);
    passed += Test("btree mt: writers inserted all keys", totalInserted, 80000);
    passed += Test("btree mt: count after concurrent inserts", t.count(), 100000);

    // Without this the concurrency test is vacuous: if no read ever overlapped a
    // writer, validation never failed and the seqlock was never exercised.
    passed += Test("btree mt: reads were invalidated (the race is real)",
                   (int)(readRetries > 0), 1);

    // No lost keys - every key, from both families, is findable single-threaded
    // and through the optimistic path.
    bool allGet = true;
    bool allOpt = true;
    i = 1;
    while (i <= 100000)
    {
        if (t.get(i) != i * 3) allGet = false;
        int v = 0;
        if (!t.lookup(i, &v) || v != i * 3) allOpt = false;
        i = i + 1;
    }
    passed += Test("btree mt: no lost keys (get)", allGet, true);
    passed += Test("btree mt: no lost keys (lookup)", allOpt, true);

    delete[_] readerThreads;
    delete[_] writerThreads;
    delete[_] rc;
    delete[_] wc;
    return passed;
}

// Concurrent inserts into an EMPTY tree, enough to grow it several levels, so
// every writer races through root creation, height growth, and node splits.
// Then check the structural invariants a split must preserve.
int testBtreeConcurrentInsertSplits()
{
    int passed = 0;
    btree<int, int> t;

    int numWriters = 4;
    int perWriter  = 5000;                     // 20000 keys -> several levels at fanout 16

    Thread* writerThreads = new Thread[numWriters];
    BtreeWriterCtx* wc = new BtreeWriterCtx[numWriters];

    int i = 0;
    while (i < numWriters)
    {
        wc[i].tree   = &t;
        wc[i].base   = 1 + i;                  // strided: all writers span all leaves
        wc[i].stride = numWriters;
        wc[i].n      = perWriter;
        writerThreads[i].start(btreeInsertWorker, &wc[i]);
        i = i + 1;
    }
    i = 0;
    while (i < numWriters) { writerThreads[i].join(); i = i + 1; }

    int totalInserted = 0;
    i = 0;
    while (i < numWriters) { totalInserted = totalInserted + wc[i].inserted; i = i + 1; }

    passed += Test("btree mt-split: writers inserted all keys", totalInserted, 20000);
    passed += Test("btree mt-split: count", t.count(), 20000);

    bool allPresent = true;
    i = 1;
    while (i <= 20000) { if (t.get(i) != i * 3) allPresent = false; i = i + 1; }
    passed += Test("btree mt-split: every key present", allPresent, true);

    // Structural invariants: the tree really did grow, all leaves are at the same
    // depth, and the leaf chain is a single ascending run holding every entry.
    int depth = btreeDepthOf(t._root);
    passed += Test("btree mt-split: tree grew several levels", (int)(depth >= 2), 1);
    passed += Test("btree mt-split: all leaves at equal depth",
                   btreeCheckLevels(t._root, 0, depth), true);

    bool chainOk = false;
    int chainTotal = btreeLeafChainTotal(t._root, &chainOk);
    passed += Test("btree mt-split: leaf chain ascending + values intact", chainOk, true);
    passed += Test("btree mt-split: leaf chain holds every entry", chainTotal, 20000);

    delete[_] writerThreads;
    delete[_] wc;
    return passed;
}

extern int main(int argc, char** argv)
{
    int passed = 0;
    int total  = 0;

    // ---- simd<T,N> ----
    int seed = argc;   // 1 with no args

    passed += testFloatArithmetic(seed);   total += 4;
    passed += testMixedScalarVector(seed); total += 4;
    passed += testIntegerSimd(seed);       total += 4;
    passed += testUnsignedSimd(seed);      total += 1;
    passed += testLaneCounts(seed);        total += 5;
    passed += testElementTypes(seed);      total += 7;
    passed += testMultiVar(seed);          total += 2;
    passed += testSimdLoadStore();         total += 9;
    passed += testSimdLoadStoreTypes();    total += 6;
    passed += testSimdLoadStoreStrided();  total += 6;
    passed += testSimdMath();              total += 25;
    passed += testSimdCompareSelect();     total += 24;
    passed += testSimdReduce();            total += 12;
    passed += testSimdMasked();            total += 8;
    passed += testSimdGatherScatter();     total += 9;

    // ---- span<T> / view<T> ----
    passed += testSpanView(); total += 24;

    // ---- explicit (T[]) array-view cast escape ----
    passed += testArrayViewCast(); total += 3;

    // ---- int[] array-view ----
    int n = argc + 7;   // 8 with no args

    int[] a = new int[n];        // blessed: a fresh, whole, distinct allocation
    fill(a, n, 10);              // a = {10, 11, ..., 17}

    passed += Test("arrayview read first", a[0], 10);   total += 1;
    passed += Test("arrayview read last",  a[n - 1], 17); total += 1;
    passed += Test("arrayview sum", sumv(a, n), 108);   total += 1;  // 10+11+...+17

    int[] b = new int[n];
    fill(b, n, 1);               // b = {1, 2, ..., 8}
    axpy(a, b, n, 2);            // a[i] += 2 * b[i]  ->  {12, 15, 18, 21, 24, 27, 30, 33}

    passed += Test("arrayview axpy first", a[0], 12);   total += 1;
    passed += Test("arrayview axpy last",  a[n - 1], 33); total += 1;
    passed += Test("arrayview axpy sum", sumv(a, n), 180); total += 1; // 108 + 2*36

    passed += Test("arrayview decays to int*", sumPtr(b, n), 36); total += 1; // 1+2+...+8

    // Struct `int[]` field: store a view from new[], read it back, index it, and pass the
    // field read to a view kernel (the field-read carries the array-view contract).
    Matrix m;
    m.n = n;
    m.data = new int[n];                       // view -> view field store (allowed)
    fill(m.data, n, 100);                      // field-read view passed to a kernel
    passed += Test("arrayview field index", m.data[2], 102); total += 1;
    passed += Test("arrayview field sum", sumv(m.data, n), 828); total += 1; // 8*100 + (0+..+7)

    int* mp = move m.data; delete[_] mp;       // extract the field's buffer to delete it

    // view -> view binds must NOT be rejected: a copy and a reassignment between views.
    int[] c = a;                 // decl-init copy: aliases a's buffer (never owns)
    passed += Test("arrayview view copy", c[0], 12); total += 1;
    int[] e = a;
    e = b;                       // reassign view <- view: now aliases b (never owned)
    passed += Test("arrayview view reassign", e[0], 1); total += 1;

    // functions may return a view (from new[] or a passed-through view parameter).
    int[] f = makeRange(n, 50);  // owns a fresh buffer {50, 51, ..., 57}
    passed += Test("arrayview returned view", f[0], 50); total += 1;
    int[] g = passthru(f);       // g aliases f
    passed += Test("arrayview passthru view", g[3], 53); total += 1;
    int* fp = move f; delete[_] fp;

    // class with an int[] field AND methods - the grammar disambiguation case.
    Vec vv;
    vv.n = n;
    vv.data = new int[n];
    fill(vv.data, n, 200);       // {200, ..., 207}
    passed += Test("arrayview class field at", vv.at(1), 201); total += 1;
    passed += Test("arrayview class field total", vv.total(), 1628); total += 1; // 200*8 + 28
    int* vp = move vv.data; delete[_] vp;

    // &a[i] yields a raw int* (a borrow of one element) - it is usable as an int*, but it
    // cannot be bound back into a T[] (that would forge an offset view; see err_arrayview_*).
    int[] h = new int[4];
    h[2] = 9;
    int* hp = &h[2];
    passed += Test("arrayview addr-of element as int*", hp[0], 9); total += 1;
    int* hq = move h; delete[_] hq;

    // nested aggregate carrying an int[] field.
    Outer o;
    o.buf.len = n;
    o.buf.cells = new int[n];
    fill(o.buf.cells, n, 300);   // {300, ..., 307}
    passed += Test("arrayview nested field", o.buf.cells[5], 305); total += 1;
    int* op = move o.buf.cells; delete[_] op;

    delete[_] a;
    delete[_] b;

    // ---- btree<K,V> ----
    passed += testBtreeAscending();          total += 2;
    passed += testBtreeDescending();         total += 2;
    passed += testBtreeRandomOrder();        total += 2;
    passed += testBtreeAddSetDuplicate();    total += 4;
    passed += testBtreeRemoveAscending();    total += 3;
    passed += testBtreeRemoveDescending();   total += 3;
    passed += testBtreeRebalanceScenarios(); total += 15;
    passed += testBtreeOrderedIteration();   total += 2;
    passed += testBtreeSeekRange();          total += 5;
    passed += testBtreeStringKeys();         total += 9;
    passed += testBtreePointerValues();      total += 5;

    // ---- btree<K,V> concurrent (optimistic lock coupling) ----
    passed += testBtreeConcurrentLookupInsert();  total += 7;
    passed += testBtreeConcurrentInsertSplits();  total += 7;

    printf("\n%d / %d HPC tests passed.\n", passed, total);
    return passed == total ? 0 : 1;
}
