// simd<T,N> explicit-SIMD vector type: splat construction, element-wise + - * /,
// mixed scalar/vector operands, all power-of-two lane counts, the full numeric
// element-type set, and lane reads at various indices.
// Seeded from argc (= 1 when run with no args) so the vector ops execute at runtime
// rather than constant-folding away.

import "cruntime.cb";
import "test_helper.cb";

int testFloatArithmetic(int seed)
{
    int passed = 0;
    float s = (float)seed;            // 1.0

    simd<float, 8> a = s + 1.0;       // 2.0 per lane (splat)
    simd<float, 8> b = 3.0;           // 3.0 per lane
    simd<float, 8> mul = a * b;       // 6.0
    simd<float, 8> add = mul + a;     // 8.0
    simd<float, 8> sub = add - b;     // 5.0
    simd<float, 8> div = sub / a;     // 2.5

    passed += Test("simd float mul", mul[0], 6.0f);
    passed += Test("simd float add lane7", add[7], 8.0f);
    passed += Test("simd float sub lane3", sub[3], 5.0f);
    passed += Test("simd float div", div[0], 2.5f);
    return passed;
}

int testMixedScalarVector(int seed)
{
    int passed = 0;
    simd<float, 4> a = (float)seed;   // 1.0
    simd<float, 4> b = a * 2.0;        // vector * scalar -> 2.0
    simd<float, 4> c = 10.0 - a;       // scalar - vector -> 9.0
    simd<float, 4> d = 12.0 / a;       // scalar / vector -> 12.0
    simd<float, 4> e = a + 4.0;        // vector + scalar -> 5.0

    passed += Test("simd vector*scalar", b[0], 2.0f);
    passed += Test("simd scalar-vector", c[3], 9.0f);
    passed += Test("simd scalar/vector", d[1], 12.0f);
    passed += Test("simd vector+scalar", e[2], 5.0f);
    return passed;
}

int testIntegerSimd(int seed)
{
    int passed = 0;
    simd<i32, 4> p = seed + 4;        // 5
    simd<i32, 4> sq = p * p;          // 25
    simd<i32, 4> df = sq - p;         // 20
    simd<i32, 4> sm = sq + p;         // 30
    simd<i32, 4> dv = sq / p;         // 5 (signed divide)

    passed += Test("simd i32 mul", sq[1], 25);
    passed += Test("simd i32 sub", df[2], 20);
    passed += Test("simd i32 add", sm[0], 30);
    passed += Test("simd i32 sdiv", dv[3], 5);
    return passed;
}

int testUnsignedSimd(int seed)
{
    int passed = 0;
    simd<u32, 4> u = (u32)(seed * 100); // 100
    simd<u32, 4> w = u / 8;             // 12 (unsigned divide)

    passed += Test("simd u32 udiv", (int)w[2], 12);
    return passed;
}

// All four power-of-two lane counts compile, lower, and execute. Read the first,
// a middle, and the last lane of each to confirm the lane indexing spans the width.
int testLaneCounts(int seed)
{
    int passed = 0;
    int v = seed + 6;                  // 7

    simd<i32, 2>  c2  = v;
    simd<i32, 16> c16 = v;
    simd<i32, 32> c32 = v;
    simd<i32, 64> c64 = v;

    simd<i32, 2>  d2  = c2  * c2;       // 49
    simd<i32, 16> d16 = c16 + c16;      // 14
    simd<i32, 32> d32 = c32 - c32;      // 0
    simd<i32, 64> d64 = c64 * c64;      // 49

    passed += Test("simd N=2 lane0",   d2[0],   49);
    passed += Test("simd N=2 lane1",   d2[1],   49);
    passed += Test("simd N=16 lane15", d16[15], 14);
    passed += Test("simd N=32 lane16", d32[16], 0);
    passed += Test("simd N=64 lane63", d64[63], 49);
    return passed;
}

// Every numeric element type: signed/unsigned 8/16/32/64-bit ints plus float/double.
// Small operands keep the narrow integer lanes inside range.
int testElementTypes(int seed)
{
    int passed = 0;

    simd<i8,  8> i8v  = (i8)(seed + 2);   // 3   -> *3 = 9
    simd<i16, 8> i16v = (i16)(seed + 9);  // 10  -> *10 = 100
    simd<i64, 4> i64v = (i64)(seed + 99); // 100 -> *100 = 10000
    simd<u8,  8> u8v  = (u8)(seed + 4);   // 5   -> *5 = 25
    simd<u16, 8> u16v = (u16)(seed + 20); // 21  -> *21 = 441
    simd<u64, 4> u64v = (u64)(seed + 999);// 1000 -> /4 = 250
    simd<double, 4> dv = (double)seed;    // 1.0 -> +0.5 then *3 = 4.5

    simd<i8,  8> i8r  = i8v  * i8v;        // 9
    simd<i16, 8> i16r = i16v * i16v;       // 100
    simd<i64, 4> i64r = i64v * i64v;       // 10000
    simd<u8,  8> u8r  = u8v  * u8v;         // 25
    simd<u16, 8> u16r = u16v * u16v;       // 441
    simd<u64, 4> u64r = u64v / 4;          // 250
    simd<double, 4> dr = (dv + 0.5) * 3.0; // 4.5

    passed += Test("simd i8 mul",    (int)i8r[0],   9);
    passed += Test("simd i16 mul",   (int)i16r[7],  100);
    passed += Test("simd i64 mul",   i64r[2],       (i64)10000);
    passed += Test("simd u8 mul",    (int)u8r[3],   25);
    passed += Test("simd u16 mul",   (int)u16r[4],  441);
    passed += Test("simd u64 udiv",  u64r[1],       (i64)250);
    passed += Test("simd double op", (float)dr[3],  4.5f);
    return passed;
}

// Several vectors of the same shape interacting in one expression, and a chain of
// dependent vector temporaries, to confirm values flow correctly across operations.
int testMultiVar(int seed)
{
    int passed = 0;
    simd<float, 4> a = (float)seed;        // 1.0
    simd<float, 4> b = a + 1.0;            // 2.0
    simd<float, 4> c = b + 1.0;            // 3.0
    simd<float, 4> r = (a + b) * c - a;    // (1+2)*3 - 1 = 8.0

    passed += Test("simd multivar lane0", r[0], 8.0f);
    passed += Test("simd multivar lane3", r[3], 8.0f);
    return passed;
}

extern int main(int argc, char** argv)
{
    int seed = argc;   // 1 with no args

    int passed = 0;
    int total  = 0;

    passed += testFloatArithmetic(seed);   total += 4;
    passed += testMixedScalarVector(seed); total += 4;
    passed += testIntegerSimd(seed);       total += 4;
    passed += testUnsignedSimd(seed);      total += 1;
    passed += testLaneCounts(seed);        total += 5;
    passed += testElementTypes(seed);      total += 7;
    passed += testMultiVar(seed);          total += 2;

    printf("\n%d / %d simd tests passed.\n", passed, total);
    return passed == total ? 0 : 1;
}
