// Comprehensive coverage of float/double object-like #define macro extraction.
// The fixture (Test/library/float_macros.h) groups macros A..K; each assertion
// below uses a distinct return code so a regression points at the failing case.
//
// Tolerance: 1e-9 around the expected value for ordinary magnitudes. Very small
// (FM_TINY) and very large (FM_HUGE) use proportional bounds. Exact-binary cases
// (sums of powers of two, hex floats, integer-valued casts) use equality.

import "library/float_macros.h";

extern void printf(const char* fmt, ...);

// Approx-equal within an absolute tolerance.
bool near(double actual, double expected, double tol)
{
    double diff = actual - expected;
    if (diff < 0.0) { diff = -diff; }
    return diff <= tol;
}

extern int main()
{
    // ---- A. Plain literals --------------------------------------------------
    if (!near(FM_DOUBLE_PLAIN, 1.5, 1e-12))              return 1;
    if (!near(FM_FLOAT_SUFFIX, 2.5, 1e-6))               return 2;  // float precision
    if (!near(FM_LONG_DOUBLE,  3.5, 1e-12))              return 3;

    // ---- B. Sign / parens --------------------------------------------------
    if (!near(FM_NEG,         -1.25,  1e-12))            return 10;
    if (!near(FM_NEG_PAREN,   -2.75,  1e-12))            return 11;
    if (!near(FM_DOUBLE_NEG,   4.125, 1e-12))            return 12;
    if (!near(FM_UNARY_PLUS,   0.75,  1e-12))            return 13;

    // ---- C. Scientific notation --------------------------------------------
    if (!near(FM_SCI_POS,      1500.0,  1e-9))           return 20;
    if (!near(FM_SCI_NEG_EXP,  0.00025, 1e-12))          return 21;
    if (!near(FM_SCI_LEAD_DOT, 25.0,    1e-12))          return 22;
    if (!near(FM_SCI_TRAIL_DOT, 40.0,   1e-12))          return 23;
    if (!near(FM_SCI_CAP_E,    625.0,   1e-12))          return 24;

    // ---- D. Hex floats - exact binary, so equality is fine -----------------
    if (FM_HEX_FLOAT     != 12.0)                        return 30;
    if (FM_HEX_FLOAT_NEG != -2.5)                        return 31;

    // ---- E. Arithmetic - sums of dyadic rationals -> exact -----------------
    if (FM_ADD        !=  2.0)                           return 40;
    if (FM_SUB        != 10.0)                           return 41;
    if (FM_MUL        != 10.0)                           return 42;
    if (FM_DIV        !=  0.25)                          return 43;
    if (FM_NESTED     != 12.0)                           return 44;
    if (FM_PRECEDENCE != 14.0)                           return 45;  // not 20.0

    // ---- F. Mixed int+float -----------------------------------------------
    if (FM_MIX_INT_FLOAT != 1.5)                         return 50;
    if (FM_MIX_DIV_INT   != 0.5)                         return 51;

    // ---- G. Casts ---------------------------------------------------------
    if (FM_CAST_DOUBLE          != 42.0)                 return 60;
    if (FM_CAST_FLOAT           !=  7.0)                 return 61;
    if (FM_CAST_FROM_INT_MACRO  != 101.0)                return 62;

    // ---- H. Magnitude - proportional tolerance -----------------------------
    if (!near(FM_TINY, 1e-300, 1e-310))                  return 70;
    if (!near(FM_HUGE, 1e300,  1e290))                   return 71;

    // ---- I. Macro chaining ------------------------------------------------
    if (FM_BASE    !=  2.0)                              return 80;
    if (FM_DERIVED != 10.0)                              return 81;

    // ---- J. Zero / negative zero ------------------------------------------
    if (FM_ZERO     != 0.0)                              return 90;
    if (FM_NEG_ZERO != 0.0)                              return 91;  // numerically equal

    // ---- K. Negative tests ------------------------------------------------
    // (int)(3.14) recovers as int via __typeof__, registers as 3 (truncation).
    // Compares equal to the integer 3 because CFlat narrows the literal at
    // comparison-site, confirming the macro did NOT take the double path.
    if (FM_INT_CAST_OF_FLOAT != 3)                       return 100;

    return 0;
}
