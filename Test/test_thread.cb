import "test_helper.cb";
import "thread.cb";

int g_threadResult = 0;

int writeThread(void* ctx) {
    g_threadResult = 99;
    return 0;
}

bool testThreadWritesGlobal() {
    bool result = true;
    g_threadResult = 0;
    Thread t;
    t.start(writeThread, nullptr);
    t.join();
    result &= Test("thread writes global", g_threadResult, 99);
    return result;
}

bool testThreadExitCode() {
    bool result = true;
    Thread t;
    t.start((void* ctx) => { return 42; }, nullptr);
    i32 code = t.join();
    result &= Test("exit code 42", (int)code, 42);
    return result;
}

extern int main() {
    int passed = 0;
    int total  = 0;

    total++; passed += testThreadWritesGlobal() ? 1 : 0;
    total++; passed += testThreadExitCode()     ? 1 : 0;

    printf("Thread tests: %d/%d passed.\n", passed, total);
    return passed == total ? 0 : 1;
}
