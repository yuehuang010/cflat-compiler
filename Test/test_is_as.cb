
import "test_helper.cb";

interface IShape
{
    int Area();
};

class Circle : IShape
{
    int radius = 0;
    int Area() { return radius * radius; }
};

class Square : IShape
{
    int side = 0;
    int Area() { return side * side; }
};

extern int main()
{
    Circle c;
    c.radius = 5;

    Square s;
    s.side = 4;

    IShape shapeC = c;
    IShape shapeS = s;

    bool result = true;
    result &= Test("shapeC is Circle", shapeC is Circle, true);
    result &= Test("shapeC is Square", shapeC is Square, false);
    result &= Test("shapeS is Square", shapeS is Square, true);
    result &= Test("shapeS is Circle", shapeS is Circle, false);

    Circle* cp = shapeC as Circle;
    result &= Test("shapeC as Circle non-null", cp != nullptr, true);

    Square* sp = shapeC as Square;
    result &= Test("shapeC as Square is null", sp == nullptr, true);

    if (result)
    {
        printf("All tests passed.\n");
        return 0;
    }
    return 1;
}
