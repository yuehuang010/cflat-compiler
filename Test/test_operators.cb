
// ── Vec2: 2D vector with full arithmetic ────────────────────────────────────

struct Vec2
{
    float x = 0;
    float y = 0;

    Vec2 operator+(Vec2 other) { Vec2 r; r.x = x + other.x; r.y = y + other.y; return r; }
    Vec2 operator-(Vec2 other) { Vec2 r; r.x = x - other.x; r.y = y - other.y; return r; }
    Vec2 operator*(float s)    { Vec2 r; r.x = x * s;       r.y = y * s;       return r; }
    Vec2 operator/(float s)    { Vec2 r; r.x = x / s;       r.y = y / s;       return r; }
    bool operator==(Vec2 other) { return x == other.x && y == other.y; }
    bool operator!=(Vec2 other) { return x != other.x || y != other.y; }
    Vec2 operator-()  { Vec2 r; r.x = -x;  r.y = -y;  return r; }
};

// ── BoolBox: logical NOT overload ────────────────────────────────────────────

struct BoolBox
{
    bool value = false;
    bool operator!() { return !value; }
};

// ── Bits: bitwise NOT overload ───────────────────────────────────────────────

struct Bits
{
    int value = 0;
    int operator~() { return ~value; }
};

// ── Fraction: rational number with arithmetic ────────────────────────────────

struct Fraction
{
    int num = 0;
    int den = 1;

    Fraction operator+(Fraction other)
    {
        Fraction r;
        r.num = num * other.den + other.num * den;
        r.den = den * other.den;
        return r;
    }

    Fraction operator-(Fraction other)
    {
        Fraction r;
        r.num = num * other.den - other.num * den;
        r.den = den * other.den;
        return r;
    }

    Fraction operator*(Fraction other)
    {
        Fraction r;
        r.num = num * other.num;
        r.den = den * other.den;
        return r;
    }

    bool operator==(Fraction other) { return num * other.den == other.num * den; }
    bool operator!=(Fraction other) { return num * other.den != other.num * den; }
    bool operator<(Fraction other)  { return num * other.den <  other.num * den; }
    bool operator>(Fraction other)  { return num * other.den >  other.num * den; }
};

// ── Counter: integer wrapper demonstrating overloaded +/== ──────────────────

struct Counter
{
    int value = 0;

    Counter operator+(Counter other) { Counter r; r.value = value + other.value; return r; }
    Counter operator-(Counter other) { Counter r; r.value = value - other.value; return r; }
    Counter operator*(int scale)     { Counter r; r.value = value * scale;       return r; }
    bool operator==(Counter other)   { return value == other.value; }
    bool operator<(Counter other)    { return value < other.value; }
};

// ── operator->: forwarding / drill-down member access ────────────────────────

struct Inner
{
    int value = 0;
    int triple() { return value * 3; }
    int who() { return 1; }   // shadowed by Box::who - never reached through a Box
};

// Box forwards member access to the contained Inner* via operator->.
// It also has its OWN members (tag, who) to prove own-member-first resolution:
// `.`/`->` reach these directly and they shadow Inner's same-named members.
struct Box
{
    Inner* p = nullptr;
    int tag = 0;
    Inner* operator->() { return p; }
    int who() { return 2; }   // own member - shadows Inner::who
};

// Plain has no operator->; flexible `.`/`->` both reach its own members directly.
struct Plain { int value = 0; };

// OuterBox holds a Box (a value type that itself defines operator->); `ob->member`
// must chain operator-> until a raw pointer is reached (Box -> Inner*).
struct OuterBox
{
    Box inner;
    Box operator->() { return inner; }
};

// ── Helpers ──────────────────────────────────────────────────────────────────

import "test_helper.cb";

// ── Main ─────────────────────────────────────────────────────────────────────

extern int main()
{
    // Vec2 tests
    Vec2 a; a.x = 1.0f; a.y = 2.0f;
    Vec2 b; b.x = 3.0f; b.y = 4.0f;

    Vec2 sum = a + b;
    Test("Vec2 + x", sum.x, 4.0f);
    Test("Vec2 + y", sum.y, 6.0f);

    Vec2 diff = b - a;
    Test("Vec2 - x", diff.x, 2.0f);
    Test("Vec2 - y", diff.y, 2.0f);

    Vec2 scaled = a * 3.0f;
    Test("Vec2 * x", scaled.x, 3.0f);
    Test("Vec2 * y", scaled.y, 6.0f);

    Vec2 divided = b / 2.0f;
    Test("Vec2 / x", divided.x, 1.5f);
    Test("Vec2 / y", divided.y, 2.0f);

    Vec2 c; c.x = 1.0f; c.y = 2.0f;
    Test("Vec2 == (equal)",     a == c,  true);
    Test("Vec2 == (not equal)", a == b,  false);
    Test("Vec2 != (not equal)", a != b,  true);
    Test("Vec2 != (equal)",     a != c,  false);

    // Fraction tests:  1/2 + 1/3 = 5/6,  1/2 * 2/3 = 2/6 = 1/3
    Fraction half;  half.num  = 1; half.den  = 2;
    Fraction third; third.num = 1; third.den = 3;
    Fraction twothirds; twothirds.num = 2; twothirds.den = 3;

    Fraction fsum = half + third;          // 5/6
    Test("Frac + num", fsum.num, 5);
    Test("Frac + den", fsum.den, 6);

    Fraction fdiff = half - third;         // 1/6
    Test("Frac - num", fdiff.num, 1);
    Test("Frac - den", fdiff.den, 6);

    Fraction fprod = half * twothirds;     // 2/6
    Fraction oneThird; oneThird.num = 1; oneThird.den = 3;
    Test("Frac * ==",  fprod == oneThird, true);

    Test("Frac ==",    half == half,   true);
    Test("Frac !=",    half != third,  true);
    Test("Frac < ",    third < half,   true);
    Test("Frac > ",    half > third,   true);

    // Counter tests
    Counter p; p.value = 10;
    Counter q; q.value = 5;

    Counter csum  = p + q;
    Counter cdiff = p - q;
    Counter cmul  = q * 4;

    Test("Counter + value",  csum.value,  15);
    Test("Counter - value",  cdiff.value,  5);
    Test("Counter * value",  cmul.value,  20);
    Test("Counter == (eq)",  p == p,  true);
    Test("Counter == (ne)",  p == q,  false);
    Test("Counter <  ",      q < p,   true);

    // Chained: (a + b) + c  ==  a + (1,2) + (3,4)+(1,2) = (5,8)+(1,2) but let's just check addition chaining
    Vec2 chain = a + b + c;    // (1+3+1, 2+4+2) = (5, 8)
    Test("Vec2 chain + x", chain.x, 5.0f);
    Test("Vec2 chain + y", chain.y, 8.0f);

    // ── Unary operator overloads ──────────────────────────────────────────────

    // operator-(): unary negation on Vec2
    Vec2 neg = -a;             // -(1,2) = (-1,-2)
    Test("Vec2 unary- x", neg.x, -1.0f);
    Test("Vec2 unary- y", neg.y, -2.0f);

    // Ensure binary operator- still works alongside unary
    Vec2 bsub = b - a;         // (3,4)-(1,2) = (2,2)
    Test("Vec2 binary- after unary- x", bsub.x, 2.0f);
    Test("Vec2 binary- after unary- y", bsub.y, 2.0f);

    // operator!(): logical NOT on BoolBox
    BoolBox bt; bt.value = true;
    BoolBox bf; bf.value = false;
    Test("BoolBox !true",  !bt, false);
    Test("BoolBox !false", !bf, true);

    // operator~(): bitwise NOT on Bits
    Bits bits; bits.value = 0xFF;
    int flipped = ~bits;
    Test("Bits ~ 0xFF", flipped, ~0xFF);

    Bits zero; zero.value = 0;
    Test("Bits ~ 0", ~zero, ~0);

    // ── operator-> forwarding ──────────────────────────────────────────────────

    // Wrapper over a plain struct pointer: w->field reads and w->method() calls
    // forward to the contained Inner.
    Inner item; item.value = 7;
    Box w; w.p = &item;
    Test("Box-> field read",   w->value,    7);
    Test("Box-> method call",  w->triple(), 21);

    // Mutate through the forwarded pointer, then read back.
    w->value = 9;
    Test("Box-> field write",  item.value,  9);
    Test("Box-> method after write", w->triple(), 27);

    // Chaining: OuterBox::operator-> returns a Box, which itself defines
    // operator-> - the chain must continue until the raw Inner* is reached.
    OuterBox ob; ob.inner = w;
    Test("OuterBox-> chained field",  ob->value,    9);
    Test("OuterBox-> chained method", ob->triple(), 27);

    // ── Flexible model: own-member-first, forward only on a miss ──────────────

    // (a) `.` (not just `->`) forwards when the member is NOT on the wrapper.
    Test("Box. forwards field (miss)",  w.value,    9);
    Test("Box. forwards method (miss)", w.triple(), 27);

    // (b) `->` resolves an OWN member of the wrapper directly (no forwarding).
    w.tag = 5;
    Test("Box-> own field",  w->tag,   5);
    Test("Box-> own method", w->who(), 2);

    // (c) Shadowing: `who` exists on BOTH Box and Inner; access resolves to the
    // wrapper's Box::who (2), never the forwarded Inner::who (1) - via both tokens.
    Test("Box. own shadows forwarded", w.who(),  2);
    Test("Box-> own shadows forwarded", w->who(), 2);

    // Flexible `->` on a plain value (no operator->) reaches its own member,
    // exactly like `.` would - `->` on a value is not an error.
    Plain pl; pl.value = 42;
    Test("Plain-> own field",  pl->value, 42);
    Test("Plain. own field",   pl.value,  42);

    // ── ?. (null-conditional) composes with operator-> forwarding ──────────────
    // The `?` is recognized first, then operator-> forwards on a miss and the
    // null guard applies to the forwarded pointer (w.p is &item, non-null here).
    Test("Box?. forwards field (non-null)",  w?.value,    9);
    Test("Box?. forwards method (non-null)", w?.triple(), 27);

    // When the wrapped pointer is null, the forwarded `?.` short-circuits to the
    // default instead of dereferencing.
    Box wn; wn.p = nullptr;
    Test("Box?. null field short-circuits", wn?.value,       0);
    Test("Box?. null with coalesce",        wn?.value ?? -1, -1);

    // Logical '!' is a zero-compare yielding bool, NOT the bitwise '~'. Regression:
    // '!' used to lower to xor -1, so on any type wider than i1 every operand negated
    // to a nonzero (truthy) value - '!1' and '!0' were both true, and '!ptr' was
    // invalid IR that faulted at runtime.
    int notOne  = 1;
    int notZero = 0;
    Test("!int 1",         !notOne,   false);
    Test("!int 0",         !notZero,  true);
    Test("!!int 1",        !!notOne,  true);
    Test("!int truthy 42", !42,    false);

    bool notBt = true;
    Test("!bool true",  !notBt, false);
    Test("!bool false", !!notBt, true);

    float notFz = 0.0f;
    float notFnz = 2.5f;
    Test("!float 0",   !notFz,  true);
    Test("!float 2.5", !notFnz, false);

    int notTarget = 7;
    int* notPv = &notTarget;
    int* notPn = nullptr;
    Test("!ptr null",    !notPn, true);
    Test("!ptr non-null", !notPv, false);

    // '~' stays bitwise - the two operators must not collapse onto each other.
    Test("~int 0", ~notZero, -1);
    Test("~int 1", ~notOne,  -2);

    // Compile-time macros are i32, so `if const (!MACRO)` exercised the same bug:
    // the not-taken arm was compiled anyway. __WINDOWS__ and __MACOS__ are disjoint,
    // so exactly one of these two arms may run.
    int constArm = 0;
    if const (!__WINDOWS__) { constArm = constArm + 1; }
    if const (!__MACOS__)   { constArm = constArm + 10; }
    Test("if const (!macro) picks one arm", constArm == 1 || constArm == 10, true);

    return 0;
}
