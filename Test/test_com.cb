// test_com.cb - produce-side COM object lowering for [winrt] classes.
//
// A [winrt] class lowers to a thin COM object: a struct whose first field is a vtable pointer,
// followed by a refcount and the user fields. The compiler generates QueryInterface / AddRef /
// Release (+ IInspectable stubs) and one thunk per interface method, then wires a static vtable
// instance into every object's lpVtbl. Calls are made through the COM vtable - exactly how a
// foreign WinRT/COM consumer (XAML, C#, cppwinrt) would call a CFlat-authored control.
//
// Interface methods use the real WinRT ABI: each vtable slot returns HRESULT and the logical
// return value comes back through a trailing [out,retval] pointer. So a value-returning method
// is driven as `i32 hr = c->lpVtbl->Method(c, ..., &out);`. The infrastructure methods
// (QueryInterface/AddRef/Release) keep their COM signatures and are reachable by name via the
// member-call sugar (`c->AddRef()`), which hides lpVtbl for them.
// See internal/plan/winmd-projection.md.

import "test_helper.cb";
import "com.cb";

// Order independence: annotationof must resolve a class/interface defined LATER in the file
// (Maker and IMaker appear far below). Forward-scanned annotations make this work regardless
// of source order; without it this query would return "" instead of "1".
bool testAnnotationBeforeDef()
{
    bool result = true;
    result &= Test("com_ann_class_forward", annotationof(Maker, "winrt"), "1");
    result &= Test("com_ann_iface_forward", annotationof(IMaker, "uuid"), "b1b2c3d4-e5f6-4789-8abc-def012345678");
    return result;
}

// === Single-method interface: dispatch + lifecycle ===

int gCatDtorCount = 0;

[uuid("4d57f3c2-8e1a-4b9d-9d3a-1f2e3c4b5a60")]
interface IPurr { i32 Eat(); };

[winrt] class Cat : IPurr
{
    i32 meals = default;
    Cat(i32 start) { this.meals = start; }
    i32 Eat() { this.meals = this.meals + 1; return 0; }
    ~Cat() { gCatDtorCount = gCatDtorCount + 1; }
};

bool testDispatchAndLifecycle()
{
    bool result = true;
    gCatDtorCount = 0;

    Cat* c = new Cat(3);
    result &= Test("com_ctor_field", c->meals, 3);

    // Dispatch Eat through the member-call sugar: it hides lpVtbl AND the [out,retval] pointer,
    // returning an HResult<i32> whose hr is the status and value is the logical return (0).
    HResult<i32> r = c->Eat();
    result &= Test("com_eat_hr", r.hr, S_OK);
    result &= Test("com_eat_return", r.value, 0);
    result &= Test("com_eat_mutated", c->meals, 4);
    c->Eat();
    c->Eat();
    result &= Test("com_eat_thrice", c->meals, 6);

    // Regression: the explicit lpVtbl HRESULT-ABI form still dispatches identically.
    i32 ret = 0;
    i32 hrExplicit = c->lpVtbl->Eat(c, (void*)&ret);
    result &= Test("com_eat_explicit_hr", hrExplicit, S_OK);
    result &= Test("com_eat_explicit_mutated", c->meals, 7);

    // Refcount lifecycle - AddRef/Release keep their COM signatures and are reached by name via
    // the member-call sugar (slots 1/2, unchanged by the HRESULT ABI).
    result &= Test("com_addref", (int)c->AddRef(), 2);
    result &= Test("com_release", (int)c->Release(), 1);

    // Final Release drops to zero, runs the destructor, and frees.
    result &= Test("com_not_freed_yet", gCatDtorCount, 0);
    result &= Test("com_final_release", (int)c->Release(), 0);
    result &= Test("com_freed_once", gCatDtorCount, 1);

    return result;
}

// === QueryInterface identity matching (well-known IIDs from com.cb) ===

bool testQueryInterface()
{
    bool result = true;
    Cat* c = new Cat(0);

    // IUnknown matches: returns S_OK, sets *ppv, and AddRefs (refcount 1 -> 2). QueryInterface
    // is slot 0 (infrastructure), reached by name via the sugar.
    Guid unk = IID_IUnknown();
    void* outUnk = default;
    i32 hrUnk = c->QueryInterface(&unk, &outUnk);
    result &= Test("com_qi_unknown_hr", hrUnk, S_OK);
    result &= Test("com_qi_unknown_out", outUnk != nullptr ? 1 : 0, 1);
    result &= Test("com_qi_unknown_identity", outUnk == (void*)c ? 1 : 0, 1);

    // IInspectable matches too (every WinRT interface derives from it).
    Guid insp = IID_IInspectable();
    void* outInsp = default;
    i32 hrInsp = c->QueryInterface(&insp, &outInsp);
    result &= Test("com_qi_inspectable_hr", hrInsp, S_OK);
    result &= Test("com_qi_inspectable_out", outInsp != nullptr ? 1 : 0, 1);

    // IAgileObject matches: a free-threaded WinRT object answers to it.
    Guid agile = IID_IAgileObject();
    void* outAgile = default;
    i32 hrAgile = c->QueryInterface(&agile, &outAgile);
    result &= Test("com_qi_agile_hr", hrAgile, S_OK);
    result &= Test("com_qi_agile_out", outAgile != nullptr ? 1 : 0, 1);

    // A random IID is rejected with E_NOINTERFACE and a null out-param.
    Guid rnd = Guid.parse("11111111-2222-3333-4444-555566667777");
    void* outRnd = default;
    i32 hrRnd = c->QueryInterface(&rnd, &outRnd);
    result &= Test("com_qi_random_hr", hrRnd, E_NOINTERFACE);
    result &= Test("com_qi_random_failed", FAILED(hrRnd) ? 1 : 0, 1);
    result &= Test("com_qi_random_null", outRnd == nullptr ? 1 : 0, 1);

    // Three successful QIs each AddRef'd; release them, then the original reference (frees).
    c->Release();   // balance IAgileObject QI
    c->Release();   // balance IInspectable QI
    c->Release();   // balance IUnknown QI
    c->Release();   // original -> frees
    return result;
}

// === Multi-method interface: thunk forwards a parameter and a non-zero return ===

[uuid("a1b2c3d4-e5f6-4789-8abc-def012345678")]
interface ICounter
{
    i32 Add(i32 by);   // returns the new total
    i32 Value();
};

[winrt] class Counter : ICounter
{
    i32 total = default;
    Counter(i32 start) { this.total = start; }
    i32 Add(i32 by) { this.total = this.total + by; return this.total; }
    i32 Value() { return this.total; }
};

bool testMultiMethodAndParamForwarding()
{
    bool result = true;
    Counter* k = new Counter(10);

    // Add(by) via the sugar: forwards a real argument and returns the new total in the
    // HResult<i32>'s value (proving param forwarding + a non-zero return through the out-param).
    HResult<i32> a1 = k->Add(5);
    result &= Test("com_add_hr", a1.hr, S_OK);
    result &= Test("com_add_returns_total", a1.value, 15);
    HResult<i32> a2 = k->Add(100);
    result &= Test("com_add_accumulates", a2.value, 115);

    // Value() reads back through a separate slot.
    HResult<i32> v = k->Value();
    result &= Test("com_value_slot", v.value, 115);

    // QueryInterface for ICounter's own IID succeeds.
    Guid iid = Guid.parse("a1b2c3d4-e5f6-4789-8abc-def012345678");
    void* outC = default;
    i32 hrC = k->QueryInterface(&iid, &outC);
    result &= Test("com_qi_own_iid_hr", hrC, S_OK);
    result &= Test("com_qi_own_iid_out", outC != nullptr ? 1 : 0, 1);

    k->Release();   // balance the QI AddRef
    k->Release();   // original -> frees
    return result;
}

// === HResult `?.`/`?->` chaining: short-circuit on the first failure ===

[uuid("b1b2c3d4-e5f6-4789-8abc-def012345678")]
interface IMaker { Counter* Make(bool fail); };

[winrt] class Maker : IMaker
{
    i32 unused = default;
    Maker() { this.unused = 0; }
    // Fallible: returns HResult<Counter*> so it can report failure (vs the logical Counter*).
    HResult<Counter*> Make(bool fail)
    {
        HResult<Counter*> r = default;
        if (fail) { r.fail(E_FAIL); return r; }
        r.succeed(new Counter(7));
        return r;
    }
};

bool testChaining()
{
    bool result = true;
    Maker* m = new Maker();

    // Success chain: Make(false) -> Counter*, then Value() -> 7. The chain stays HResult<i32>;
    // check once at the end. `?.` chains through the HResult (auto-detecting pointer vs value).
    HResult<i32> ok = m->Make(false)?.Value();
    result &= Test("com_chain_ok_hr", ok.hr, S_OK);
    result &= Test("com_chain_ok_value", ok.value, 7);

    // Short-circuit: Make(true) fails, so Value() is never called and the failure HRESULT
    // propagates straight through to the final HResult.
    HResult<i32> bad = m->Make(true)?.Value();
    result &= Test("com_chain_fail_hr", bad.hr, E_FAIL);
    result &= Test("com_chain_fail_value", bad.value, 0);

    m->Release();
    return result;
}

// === Type-level annotation query: annotationof(Type, "Ann") ===
// [winrt] is an ordinary annotation (declared in com.cb), stored on the class and queryable.

bool testTypeLevelAnnotation()
{
    bool result = true;
    result &= Test("com_ann_winrt_present", annotationof(Cat, "winrt"), "1");
    result &= Test("com_ann_winrt_absent",  annotationof(Cat, "Private"), "");
    return result;
}

extern int main()
{
    int passed = 0;
    int total  = 0;

    total++; passed += testDispatchAndLifecycle()         ? 1 : 0;
    total++; passed += testQueryInterface()               ? 1 : 0;
    total++; passed += testMultiMethodAndParamForwarding() ? 1 : 0;
    total++; passed += testChaining()                     ? 1 : 0;
    total++; passed += testTypeLevelAnnotation()          ? 1 : 0;
    total++; passed += testAnnotationBeforeDef()          ? 1 : 0;

    printf("COM produce-side tests: %d/%d passed.\n", passed, total);
    return passed == total ? 0 : 1;
}
