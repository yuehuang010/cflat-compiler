// vectorize keyword: the loop must be vectorized at -O2 or the compile fails.
// Under test.bat (compiled at -O0) this is a no-op and simply runs as a plain
// loop; test_hpc.bat compiles it at -O2 to exercise the enforced contract.
// Either way the results below must be correct.

int sumArrays()
{
    int[1024] a = default;
    int[1024] b = default;
    int[1024] c = default;

    int i = 0;
    while (i < 1024)
    {
        a[i] = i;
        b[i] = 2 * i;
        i = i + 1;
    }

    // Elementwise add over distinct, non-aliasing local arrays: canonical
    // vectorizable kernel (counted trip, no carried dependence).
    vectorize for (int k = 0; k < 1024; k = k + 1)
    {
        c[k] = a[k] + b[k];
    }

    int total = 0;
    int j = 0;
    while (j < 1024)
    {
        total = total + c[j];
        j = j + 1;
    }
    return total; // sum of 3*i for i in [0,1024) = 3 * (1023*1024/2) = 1571328
}

int reduceArray()
{
    int[1000] a = default;
    int i = 0;
    while (i < 1000)
    {
        a[i] = i + 1;
        i = i + 1;
    }

    // Integer reduction: recognized cross-iteration pattern, vectorizes.
    int sum = 0;
    vectorize for (int k = 0; k < 1000; k = k + 1)
    {
        sum = sum + a[k];
    }
    return sum; // 1+2+...+1000 = 500500
}

int vectorizeWhile()
{
    int[512] a = default;
    int n = 512;
    int i = 0;
    while (i < n)
    {
        a[i] = 1;
        i = i + 1;
    }

    int count = 0;
    int k = 0;
    // while form with a countable condition vectorizes the same as the for form.
    vectorize while (k < n)
    {
        count = count + a[k];
        k = k + 1;
    }
    return count; // 512
}

// vectorize(contract): mul-add kernel. contract permits fusing a*b+c into one fma,
// which changes at most the final rounding. Compared against an unfused serial
// reference over the SAME inputs with a small tolerance (fused != unfused by <=1 ulp).
int contractMulAddApprox()
{
    int n = 1024;
    double[1024] a = default;
    double[1024] b = default;
    double[1024] c = default;
    for (int i = 0; i < n; i = i + 1)
    {
        double x = i;
        a[i] = x / 3.0;
        b[i] = (x + 1.0) / 7.0;
        c[i] = (x + 2.0) / 11.0;
    }

    // Serial reference: plain (flagless) ops, separately rounded mul then add.
    double[1024] ref = default;
    for (int i = 0; i < n; i = i + 1)
        ref[i] = a[i] * b[i] + c[i];

    double[1024] out = default;
    vectorize(contract) for (int k = 0; k < n; k = k + 1)
    {
        out[k] = a[k] * b[k] + c[k];
    }

    int fails = 0;
    for (int i = 0; i < n; i = i + 1)
    {
        double d = out[i] - ref[i];
        if (d < 0.0) d = -d;
        if (d > 1.0e-9) fails = fails + 1;
    }
    return fails;
}

// vectorize(contract) exact case: small-integer-valued doubles, where a*b+c is
// computed with no rounding at all, so fused == unfused EXACTLY.
int contractMulAddExact()
{
    int n = 256;
    double[256] a = default;
    double[256] b = default;
    double[256] c = default;
    for (int i = 0; i < n; i = i + 1)
    {
        a[i] = i % 7;   // 0..6
        b[i] = i % 5;   // 0..4
        c[i] = i % 3;   // 0..2
    }

    double[256] out = default;
    vectorize(contract) for (int k = 0; k < n; k = k + 1)
    {
        out[k] = a[k] * b[k] + c[k];
    }

    int fails = 0;
    for (int i = 0; i < n; i = i + 1)
    {
        double expect = a[i] * b[i] + c[i];   // exact for small integers
        if (out[i] != expect) fails = fails + 1;
    }
    return fails;
}

// vectorize(reassoc): sum-of-products reduction. reassoc lets the optimizer regroup
// and split accumulators, so the result drifts from a strict left-to-right serial sum
// by more than the reduction ulp - compared with a looser RELATIVE tolerance.
int reassocSumApprox()
{
    int n = 1024;
    double[1024] a = default;
    double[1024] b = default;
    for (int i = 0; i < n; i = i + 1)
    {
        double x = i;
        a[i] = x / 3.0;
        b[i] = (x + 1.0) / 7.0;
    }

    // Serial reference: strict left-to-right, unfused, un-reassociated.
    double refSum = 0.0;
    for (int i = 0; i < n; i = i + 1)
        refSum = refSum + a[i] * b[i];

    double sum = 0.0;
    vectorize(reassoc) for (int k = 0; k < n; k = k + 1)
    {
        sum = sum + a[k] * b[k];
    }

    double d = sum - refSum;
    if (d < 0.0) d = -d;
    double denom = refSum;
    if (denom < 0.0) denom = -denom;
    if (d > 1.0e-6 * denom) return 1;
    return 0;
}

// vectorize(reassoc) exact case: small integers where every partial sum stays exact
// in double, so any regrouping yields the identical result.
int reassocSumExact()
{
    int n = 512;
    double[512] a = default;
    double[512] b = default;
    for (int i = 0; i < n; i = i + 1)
    {
        a[i] = i % 4;   // 0..3
        b[i] = i % 3;   // 0..2
    }

    double sum = 0.0;
    vectorize(reassoc) for (int k = 0; k < n; k = k + 1)
    {
        sum = sum + a[k] * b[k];
    }

    double refSum = 0.0;
    for (int i = 0; i < n; i = i + 1)
        refSum = refSum + a[i] * b[i];   // <= 512*6 = 3072, exact in any grouping

    if (sum != refSum) return 1;
    return 0;
}

extern int main()
{
    int fails = 0;
    if (sumArrays() != 1571328) fails = fails + 1;
    if (reduceArray() != 500500) fails = fails + 1;
    if (vectorizeWhile() != 512) fails = fails + 1;
    fails = fails + contractMulAddApprox();
    fails = fails + contractMulAddExact();
    fails = fails + reassocSumApprox();
    fails = fails + reassocSumExact();

    if (fails == 0)
        printf("test_vectorize: all passed\n");
    else
        printf("test_vectorize: %d FAILED\n", fails);
    return fails;
}
