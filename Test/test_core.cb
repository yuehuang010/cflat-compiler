import "dictionary.cb";
import "pair.cb";
import "stack.cb";
import "queue.cb";
import "interfaces.cb";
import "array.cb";

// ── array<T> ─────────────────────────────────────────────────────────────────

int g_dtor_count = 0;

struct Tracked
{
    int _val = 0;

    ~Tracked()
    {
        g_dtor_count++;
    }
};

struct FixedBuf
{
    char data[4];
    int length = 0;
};

int testArray()
{
    int passed = 0;

    // delete[n] destructor invocation
    g_dtor_count = 0;
    Tracked* arr = new Tracked[5];
    delete[5] arr;
    passed += Test("delete[5] 5 elements", g_dtor_count, 5);

    g_dtor_count = 0;
    Tracked* one = new Tracked[1];
    delete[1] one;
    passed += Test("delete[1] 1 element", g_dtor_count, 1);

    g_dtor_count = 0;
    Tracked* zero = new Tracked[0];
    delete[_] zero;
    passed += Test("delete[_] 0 elements", g_dtor_count, 0);

    // Primitive array - no cookie, no destructor (must not crash)
    int* ints = new int[10];
    ints[0] = 42;
    delete[] ints;

    // array<int>
    array<int> ai;
    ai.init(4);
    ai.set(0, 10);
    ai.set(1, 20);
    ai.set(2, 30);
    ai.set(3, 40);
    passed += Test("array<int> count",  ai.count(), 4);
    passed += Test("array<int> get(0)", ai.get(0),  10);
    passed += Test("array<int> get(3)", ai.get(3),  40);
    passed += Test("array<int> [1]",    ai[1],      20);
    passed += Test("array<int> [2]",    ai[2],      30);

    // array<Tracked>: destructor fires on scope exit
    g_dtor_count = 0;
    {
        array<Tracked> at;
        at.init(3);
    }
    passed += Test("array<Tracked> dtor count", g_dtor_count, 3);

    // foreach over array<int>
    array<int> af;
    af.init(5);
    af.set(0, 1); af.set(1, 2); af.set(2, 3); af.set(3, 4); af.set(4, 5);

    int sum = 0;
    for (int v in af)
        sum += v;
    passed += Test("array foreach sum",   sum,   15);

    int fcount = 0;
    for (int v in af)
        fcount++;
    passed += Test("array foreach count", fcount, 5);

    // heap-allocated array<int>
    array<int>* ha = new array<int>;
    ha->init(3);
    ha->set(0, 100); ha->set(1, 200); ha->set(2, 300);
    passed += Test("heap array count",    ha->count(),   3);
    passed += Test("heap array get(1)",   ha->get(1),    200);
    delete ha;

    // destructor fires when heap array is deleted
    g_dtor_count = 0;
    {
        array<Tracked>* ht = new array<Tracked>;
        ht->init(4);
        delete ht;
    }
    passed += Test("heap array<Tracked> dtor count", g_dtor_count, 4);

    return passed;
}

// ── list<int> ────────────────────────────────────────────────────────────────

int testList()
{
    int passed = 0;

    list<int> l;

    // add and count
    l.add(10);
    l.add(20);
    l.add(30);
    passed += Test("list count after 3 adds", l.count(), 3);

    // get
    passed += Test("list get 0", l.get(0), 10);
    passed += Test("list get 1", l.get(1), 20);
    passed += Test("list get 2", l.get(2), 30);

    // operator[]
    passed += Test("list op[] 0", l[0], 10);
    passed += Test("list op[] 1", l[1], 20);
    passed += Test("list op[] 2", l[2], 30);

    // set
    l.set(1, 99);
    passed += Test("list set", l.get(1), 99);

    // removeAt middle
    l.set(1, 20);
    l.removeAt(1);
    passed += Test("list count after removeAt", l.count(), 2);
    passed += Test("list after removeAt[0]",   l.get(0), 10);
    passed += Test("list after removeAt[1]",   l.get(1), 30);

    // clear
    l.clear();
    passed += Test("list count after clear", l.count(), 0);

    // growth past initial capacity (forces _grow)
    int i = 0;
    while (i < 20)
    {
        l.add(i);
        i++;
    }
    passed += Test("list count after 20 adds", l.count(), 20);
    passed += Test("list growth get[0]",  l.get(0),  0);
    passed += Test("list growth get[19]", l.get(19), 19);

    return passed;
}

// ── hashset<int> ─────────────────────────────────────────────────────────────

int testHashset()
{
    int passed = 0;

    hashset<int> s;

    // add new elements
    passed += Test("hashset add 1",   s.add(1),   true);
    passed += Test("hashset add 2",   s.add(2),   true);
    passed += Test("hashset add 42",  s.add(42),  true);
    passed += Test ("hashset count 3", s.count(),  3);

    // contains
    passed += Test("hashset contains 1",  s.contains(1),  true);
    passed += Test("hashset contains 42", s.contains(42), true);
    passed += Test("hashset contains 99", s.contains(99), false);

    // duplicate add returns false
    passed += Test("hashset dup add 1",  s.add(1),  false);
    passed += Test ("hashset count unchanged", s.count(), 3);

    // remove
    passed += Test("hashset remove 2",         s.remove(2),      true);
    passed += Test("hashset contains 2 after", s.contains(2),    false);
    passed += Test ("hashset count after remove", s.count(),       2);
    passed += Test("hashset remove missing",   s.remove(999),    false);

    // re-add after remove
    passed += Test("hashset re-add 2", s.add(2), true);
    passed += Test("hashset contains 2 re-added", s.contains(2), true);

    // trigger rehash by adding many elements
    hashset<int> big;
    int i = 0;
    while (i < 50)
    {
        big.add(i);
        i++;
    }
    passed += Test("hashset big count", big.count(), 50);
    passed += Test("hashset big contains 0",  big.contains(0),  true);
    passed += Test("hashset big contains 49", big.contains(49), true);
    passed += Test("hashset big contains 50", big.contains(50), false);

    return passed;
}

// ── dictionary<int,int> ──────────────────────────────────────────────────────

int testDictionary()
{
    int passed = 0;

    dictionary<int, int> d;

    // add new entries
    passed += Test("dict add 1=>100",  d.add(1,  100), true);
    passed += Test("dict add 2=>200",  d.add(2,  200), true);
    passed += Test("dict add 42=>99",  d.add(42, 99),  true);
    passed += Test ("dict count 3",     d.count(),       3);

    // contains / get
    passed += Test("dict contains 1",  d.contains(1),  true);
    passed += Test("dict contains 42", d.contains(42), true);
    passed += Test("dict contains 99", d.contains(99), false);
    passed += Test ("dict get 1",       d.get(1),       100);
    passed += Test ("dict get 2",       d.get(2),       200);
    passed += Test ("dict get 42",      d.get(42),      99);
    passed += Test ("dict get missing", d.get(999),     0);

    // duplicate add leaves existing value alone
    passed += Test("dict dup add 1",   d.add(1, 555),  false);
    passed += Test ("dict get 1 after dup", d.get(1),   100);

    // set overwrites
    d.set(1, 111);
    passed += Test ("dict get 1 after set", d.get(1),   111);
    d.set(5, 500); // set on new key inserts
    passed += Test("dict contains 5",  d.contains(5), true);
    passed += Test ("dict get 5",       d.get(5),       500);
    passed += Test ("dict count 4",     d.count(),       4);

    // remove
    passed += Test("dict remove 2",            d.remove(2),     true);
    passed += Test("dict contains 2 after",    d.contains(2),   false);
    passed += Test ("dict count after remove",  d.count(),        3);
    passed += Test("dict remove missing",      d.remove(999),    false);

    // remaining keys still reachable after swap-remove
    passed += Test ("dict get 1 after remove",  d.get(1),        111);
    passed += Test ("dict get 42 after remove", d.get(42),        99);
    passed += Test ("dict get 5 after remove",  d.get(5),        500);

    // re-add after remove
    passed += Test("dict re-add 2",        d.add(2, 222),   true);
    passed += Test ("dict get 2 re-added",  d.get(2),         222);

    // operator[] - same semantics as get()
    passed += Test ("dict op[] 1",       d[1],            111);
    passed += Test ("dict op[] 42",      d[42],            99);
    passed += Test ("dict op[] missing", d[999],            0);

    // bulk inserts to force hashset rehash underneath
    dictionary<int, int> big;
    int i = 0;
    while (i < 50)
    {
        big.add(i, i * 10);
        i++;
    }
    passed += Test ("dict big count",     big.count(),      50);
    passed += Test ("dict big get 0",     big.get(0),        0);
    passed += Test ("dict big get 49",    big.get(49),     490);
    passed += Test("dict big contains 0",  big.contains(0),  true);
    passed += Test("dict big contains 50", big.contains(50), false);

    return passed;
}

// ── Pair<T,U> ────────────────────────────────────────────────────────────────

int testPair()
{
    int passed = 0;

    // Test Pair<int, int>
    Pair<int, int> p1 = default;
    p1.first = 10;
    p1.second = 20;
    passed += Test("pair int int first", p1.first, 10);
    passed += Test("pair int int second", p1.second, 20);

    // Test Pair<int, int> with different values
    Pair<int, int> p2 = default;
    p2.first = 42;
    p2.second = 99;
    passed += Test("pair int int first 2", p2.first, 42);
    passed += Test("pair int int second 2", p2.second, 99);

    // Test Pair<string, string>
    Pair<string, string> ps = default;
    ps.first = "hello";
    ps.second = "world";
    passed += Test("pair string string first",  ps.first,  "hello");
    passed += Test("pair string string second", ps.second, "world");

    // Reassign fields
    ps.first = "foo";
    ps.second = "bar";
    passed += Test("pair string string reassign first",  ps.first,  "foo");
    passed += Test("pair string string reassign second", ps.second, "bar");

    return passed;
}

// ── stack<i32> ───────────────────────────────────────────────────────────────

int testStack()
{
    int passed = 0;

    stack<i32> s;

    passed += Test("stack empty initially",  s.isEmpty(), true);

    s.push(10);
    s.push(20);
    s.push(30);

    passed += Test("stack count after 3 pushes", s.count(), 3);
    passed += Test("stack not empty",            s.isEmpty(), false);
    passed += Test("stack peek top",             (int)s.peek(), 30);

    passed += Test("stack pop 1 (LIFO)", (int)s.pop(), 30);
    passed += Test("stack pop 2",        (int)s.pop(), 20);
    passed += Test("stack pop 3",        (int)s.pop(), 10);

    passed += Test("stack empty after drain", s.isEmpty(), true);

    return passed;
}

// ── queue<i32> ───────────────────────────────────────────────────────────────

int testQueue()
{
    int passed = 0;

    queue<i32> q;

    passed += Test("queue empty initially",  q.isEmpty(), true);

    q.enqueue(10);
    q.enqueue(20);
    q.enqueue(30);

    passed += Test("queue count after 3 enqueues", q.count(), 3);
    passed += Test("queue not empty",              q.isEmpty(), false);
    passed += Test("queue peek front",             (int)q.peek(), 10);

    passed += Test("queue dequeue 1 (FIFO)", (int)q.dequeue(), 10);
    passed += Test("queue dequeue 2",        (int)q.dequeue(), 20);
    passed += Test("queue dequeue 3",        (int)q.dequeue(), 30);

    passed += Test("queue empty after drain", q.isEmpty(), true);

    return passed;
}

// ── for ──────────────────────────────────────────────────────────────────

int testFor()
{
    int passed = 0;

    // Basic iteration over list<int>
    list<int> l;
    l.add(10);
    l.add(20);
    l.add(30);

    int sum = 0;
    for (int x in l)
        sum += x;
    passed += Test("for sum", sum, 60);

    // Correct element values
    int first = -1;
    int last  = -1;
    for (int x in l)
    {
        if (first == -1) first = x;
        last = x;
    }
    passed += Test("for first", first, 10);
    passed += Test("for last",  last,  30);

    // break exits early
    int count = 0;
    for (int x in l)
    {
        if (x == 20) break;
        count++;
    }
    passed += Test("for break count", count, 1);

    // continue skips element
    int skipSum = 0;
    for (int x in l)
    {
        if (x == 20) continue;
        skipSum += x;
    }
    passed += Test("for continue sum", skipSum, 40);

    // Empty list iterates zero times
    list<int> empty;
    int visits = 0;
    for (int x in empty)
        visits++;
    passed += Test("for empty", visits, 0);

    // Iterate via IEnumerable<int> interface
    IEnumerable<int> ie = l;
    int ieSum = 0;
    for (int x in ie)
        ieSum += x;
    passed += Test("for IEnumerable sum", ieSum, 60);

    // Inline fixed array (local)
    int[5] nums;
    nums[0] = 10; nums[1] = 20; nums[2] = 30; nums[3] = 40; nums[4] = 50;
    int fixedSum = 0;
    for (int x in nums)
        fixedSum += x;
    passed += Test("for int[5] sum", fixedSum, 150);

    char[4] cbuf;
    cbuf[0] = 'a'; cbuf[1] = 'b'; cbuf[2] = 'c'; cbuf[3] = 'd';
    int charCount = 0;
    for (char c in cbuf)
        if (c >= 'a' && c <= 'd') charCount++;
    passed += Test("for char[4] count", charCount, 4);

    // Inline fixed array (struct field)
    FixedBuf fb;
    fb.data[0] = (char)10; fb.data[1] = (char)20;
    fb.data[2] = (char)30; fb.data[3] = (char)40;
    int fieldSum = 0;
    for (char b in fb.data)
        fieldSum += (int)b;
    passed += Test("for struct field char[4] sum", fieldSum, 100);

    return passed;
}

// ── hashset: negative keys ───────────────────────────────────────────────────

int testHashsetNegative()
{
    int passed = 0;

    hashset<int> s;
    passed += Test("hs-neg add -1",   s.add(-1),   true);
    passed += Test("hs-neg add -10",  s.add(-10),  true);
    passed += Test("hs-neg add -100", s.add(-100), true);
    passed += Test("hs-neg count 3",  s.count(),   3);

    passed += Test("hs-neg contains -1",   s.contains(-1),   true);
    passed += Test("hs-neg contains -10",  s.contains(-10),  true);
    passed += Test("hs-neg contains -100", s.contains(-100), true);
    passed += Test("hs-neg missing -5",    s.contains(-5),   false);

    passed += Test("hs-neg remove -10",         s.remove(-10),    true);
    passed += Test("hs-neg -10 gone",           s.contains(-10),  false);
    passed += Test("hs-neg -1 still present",   s.contains(-1),   true);
    passed += Test("hs-neg -100 still present", s.contains(-100), true);

    return passed;
}

// ── hashset: tombstone probing ────────────────────────────────────────────────
// With initial capacity 8: Hash(1)%8=1, Hash(9)%8=1, Hash(17)%8=1.
// Removing 1 leaves a tombstone; contains(9) must probe past it.

int testHashsetTombstone()
{
    int passed = 0;

    hashset<int> s;
    s.add(1);
    s.add(9);    // collides with 1 at slot 1, placed at slot 2
    s.remove(1); // slot 1 becomes tombstone (status=2)

    passed += Test("hs-tomb contains 9 past tombstone", s.contains(9),  true);
    passed += Test("hs-tomb contains 1 gone",           s.contains(1),  false);

    // 17 also hashes to slot 1; should reuse the tombstone
    passed += Test("hs-tomb add 17",      s.add(17),      true);
    passed += Test("hs-tomb contains 17", s.contains(17), true);
    passed += Test("hs-tomb contains 9",  s.contains(9),  true);
    passed += Test("hs-tomb count 2",     s.count(),      2);

    s.remove(9);
    passed += Test("hs-tomb 17 after removing 9", s.contains(17), true);

    return passed;
}

// ── hashset<i64> ─────────────────────────────────────────────────────────────

int testHashsetI64()
{
    int passed = 0;

    hashset<i64> s;
    passed += Test("hs-i64 add 1",    s.add((i64)1),             true);
    passed += Test("hs-i64 add 2",    s.add((i64)2),             true);
    passed += Test("hs-i64 add -1",   s.add((i64)-1),            true);
    passed += Test("hs-i64 add big",  s.add((i64)1000000000000), true);
    passed += Test("hs-i64 count 4",  s.count(), 4);

    passed += Test("hs-i64 contains 1",   s.contains((i64)1),            true);
    passed += Test("hs-i64 contains -1",  s.contains((i64)-1),           true);
    passed += Test("hs-i64 contains big", s.contains((i64)1000000000000), true);
    passed += Test("hs-i64 missing 3",    s.contains((i64)3),            false);

    passed += Test("hs-i64 remove -1", s.remove((i64)-1),   true);
    passed += Test("hs-i64 -1 gone",   s.contains((i64)-1), false);
    passed += Test("hs-i64 1 still",   s.contains((i64)1),  true);

    return passed;
}

// ── hashset<char> ────────────────────────────────────────────────────────────

int testHashsetChar()
{
    int passed = 0;

    hashset<char> s;
    passed += Test("hs-char add 'a'", s.add('a'), true);
    passed += Test("hs-char add 'z'", s.add('z'), true);
    passed += Test("hs-char add '0'", s.add('0'), true);
    passed += Test("hs-char count 3", s.count(),  3);

    passed += Test("hs-char contains 'a'", s.contains('a'), true);
    passed += Test("hs-char contains 'z'", s.contains('z'), true);
    passed += Test("hs-char missing 'x'",  s.contains('x'), false);

    passed += Test("hs-char dup 'a'",    s.add('a'),      false);
    passed += Test("hs-char remove 'z'", s.remove('z'),   true);
    passed += Test("hs-char 'z' gone",   s.contains('z'), false);
    passed += Test("hs-char 'a' still",  s.contains('a'), true);

    return passed;
}

// ── hashset: rehash stress ────────────────────────────────────────────────────

int testHashsetRehash()
{
    int passed = 0;

    hashset<int> s;
    int i = 0;
    while (i < 100) { s.add(i); i++; }
    passed += Test("hs-rehash count 100",   s.count(),       100);
    passed += Test("hs-rehash contains 0",  s.contains(0),   true);
    passed += Test("hs-rehash contains 99", s.contains(99),  true);
    passed += Test("hs-rehash missing 100", s.contains(100), false);

    i = 0;
    while (i < 100) { if (i % 2 == 0) s.remove(i); i++; }
    passed += Test("hs-rehash count after rm", s.count(),       50);
    passed += Test("hs-rehash odd 1 present",  s.contains(1),   true);
    passed += Test("hs-rehash odd 99 present", s.contains(99),  true);
    passed += Test("hs-rehash even 0 gone",    s.contains(0),   false);
    passed += Test("hs-rehash even 98 gone",   s.contains(98),  false);

    return passed;
}

// ── dictionary: negative keys ─────────────────────────────────────────────────

int testDictNegative()
{
    int passed = 0;

    dictionary<int, int> d;
    passed += Test("d-neg add -1=>1",     d.add(-1,   1),   true);
    passed += Test("d-neg add -10=>10",   d.add(-10,  10),  true);
    passed += Test("d-neg add -100=>100", d.add(-100, 100), true);
    passed += Test("d-neg count 3",       d.count(),        3);

    passed += Test("d-neg get -1",    d.get(-1),   1);
    passed += Test("d-neg get -10",   d.get(-10),  10);
    passed += Test("d-neg get -100",  d.get(-100), 100);
    passed += Test("d-neg missing -5",d.get(-5),   0);

    d.set(-1, 999);
    passed += Test("d-neg set -1",     d.get(-1),       999);
    passed += Test("d-neg remove -10", d.remove(-10),   true);
    passed += Test("d-neg -10 gone",   d.contains(-10), false);

    return passed;
}

// ── dictionary: tombstone probing ─────────────────────────────────────────────
// 1 and 9 collide at slot 1 in cap-8 table; remove 1 leaves tombstone.

int testDictTombstone()
{
    int passed = 0;

    dictionary<int, int> d;
    d.add(1, 10);
    d.add(9, 90);   // collides with 1
    d.remove(1);    // slot 1 becomes tombstone

    passed += Test("d-tomb get 9 past tombstone", d.get(9),      90);
    passed += Test("d-tomb contains 9",           d.contains(9), true);
    passed += Test("d-tomb 1 gone",               d.contains(1), false);

    passed += Test("d-tomb add 17=>170",  d.add(17, 170), true);
    passed += Test("d-tomb get 17",       d.get(17),      170);
    passed += Test("d-tomb get 9 still",  d.get(9),       90);
    passed += Test("d-tomb count 2",      d.count(),      2);

    return passed;
}

// ── dictionary<i64,int> ───────────────────────────────────────────────────────

int testDictI64()
{
    int passed = 0;

    dictionary<i64, int> d;
    passed += Test("d-i64 add 1=>1",    d.add((i64)1,             1),  true);
    passed += Test("d-i64 add -1=>-1",  d.add((i64)-1,            -1), true);
    passed += Test("d-i64 add big=>42", d.add((i64)1000000000000, 42), true);
    passed += Test("d-i64 count 3",     d.count(), 3);

    passed += Test("d-i64 get 1",   d.get((i64)1),             1);
    passed += Test("d-i64 get -1",  d.get((i64)-1),            -1);
    passed += Test("d-i64 get big", d.get((i64)1000000000000), 42);
    passed += Test("d-i64 miss 2",  d.get((i64)2),             0);

    d.set((i64)1, 999);
    passed += Test("d-i64 set 1",     d.get((i64)1),       999);
    passed += Test("d-i64 remove -1", d.remove((i64)-1),   true);
    passed += Test("d-i64 -1 gone",   d.contains((i64)-1), false);

    return passed;
}

// ── dictionary<char,int> ──────────────────────────────────────────────────────

int testDictChar()
{
    int passed = 0;

    dictionary<char, int> d;
    passed += Test("d-char add 'a'", d.add('a', 1),  true);
    passed += Test("d-char add 'b'", d.add('b', 2),  true);
    passed += Test("d-char add 'z'", d.add('z', 26), true);
    passed += Test("d-char count 3", d.count(), 3);

    passed += Test("d-char get 'a'",  d.get('a'), 1);
    passed += Test("d-char get 'z'",  d.get('z'), 26);
    passed += Test("d-char miss 'x'", d.get('x'), 0);

    d.set('a', 100);
    passed += Test("d-char set 'a'",    d.get('a'),       100);
    passed += Test("d-char remove 'b'", d.remove('b'),    true);
    passed += Test("d-char 'b' gone",   d.contains('b'),  false);
    passed += Test("d-char 'a' intact", d.get('a'),       100);

    return passed;
}

// ── dictionary: rehash stress ─────────────────────────────────────────────────

int testDictRehash()
{
    int passed = 0;

    dictionary<int, int> d;
    int i = 0;
    while (i < 100) { d.add(i, i * 3); i++; }
    passed += Test("d-rehash count 100",   d.count(),       100);
    passed += Test("d-rehash get 0",       d.get(0),        0);
    passed += Test("d-rehash get 99",      d.get(99),       297);
    passed += Test("d-rehash missing 100", d.contains(100), false);

    i = 0;
    while (i < 100) { if (i % 2 == 0) d.set(i, i * -1); i++; }
    passed += Test("d-rehash updated 0",  d.get(0),   0);
    passed += Test("d-rehash updated 2",  d.get(2),   -2);
    passed += Test("d-rehash updated 98", d.get(98),  -98);
    passed += Test("d-rehash odd 1",      d.get(1),   3);
    passed += Test("d-rehash odd 99",     d.get(99),  297);

    return passed;
}

// ── main ─────────────────────────────────────────────────────────────────────

extern int main()
{
    int passed = 0;
    int total  = 0;

    int r;

    r = testArray();            passed += r; total += 14;
    r = testList();             passed += r; total += 15;
    r = testHashset();          passed += r; total += 19;
    r = testHashsetNegative();  passed += r; total += 12;
    r = testHashsetTombstone(); passed += r; total += 7;
    r = testHashsetI64();       passed += r; total += 12;
    r = testHashsetChar();      passed += r; total += 11;
    r = testHashsetRehash();    passed += r; total += 9;
    r = testDictionary();       passed += r; total += 34;
    r = testDictNegative();     passed += r; total += 11;
    r = testDictTombstone();    passed += r; total += 7;
    r = testDictI64();          passed += r; total += 11;
    r = testDictChar();         passed += r; total += 11;
    r = testDictRehash();       passed += r; total += 9;
    r = testPair();             passed += r; total += 8;
    r = testStack();            passed += r; total += 8;
    r = testQueue();            passed += r; total += 8;
    r = testFor();              passed += r; total += 10;

    printf("\n%d / %d tests passed.\n", passed, total);
    return passed == total ? 0 : 1;
}
