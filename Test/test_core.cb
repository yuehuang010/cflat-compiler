{
    i32 r = 0;
    i32 g = 0;
    i32 b = 0;

    string ToString()
    {
        return "rgb({r},{g},{b})";
    }
};

int testStringInterpolation()
{
    int passed = 0;

    string name = "World";
    passed += Test("interp_simple",    "Hello {name}!",  "Hello World!");

    string a = "foo";
    string b = "bar";
    passed += Test("interp_two_vars",  "{a} and {b}",    "foo and bar");

    string mid = "mid";
    passed += Test("interp_sandwich",  "pre-{mid}-suf",  "pre-mid-suf");

    i32 n = 42;
    passed += Test("interp_int",       "n={n}",          "n=42");

    StringColor c;
    c.r = 255;
    c.g = 128;
    c.b = 0;
    passed += Test("interp_istring",   "color={c}",      "color=rgb(255,128,0)");

    string label = "score";
    i32 value = 99;
    passed += Test("interp_mixed",     "{label}={value}", "score=99");

    return passed;
}

int testStringSwitch()
{
    int passed = 0;

    string fruit = "Apple";
    int result = -1;
    switch (fruit)
    {
        case "Apple":  result = 1; break;
        case "Banana": result = 2; break;
        case "Cherry": result = 3; break;
        default:       result = 0; break;
    }
    passed += Test("switch_match_apple", result, 1);

    fruit = "Banana";
    result = -1;
    switch (fruit)
    {
        case "Apple":  result = 1; break;
        case "Banana": result = 2; break;
        case "Cherry": result = 3; break;
        default:       result = 0; break;
    }
    passed += Test("switch_match_banana", result, 2);

    fruit = "Mango";
    result = -1;
    switch (fruit)
    {
        case "Apple":  result = 1; break;
        case "Banana": result = 2; break;
        case "Cherry": result = 3; break;
        default:       result = 0; break;
    }
    passed += Test("switch_default", result, 0);

    string sa = "hello";
    string sb = "hello";
    string sc = "world";
    passed += Test("str_eq_same",  sa == sb, true);
    passed += Test("str_eq_diff",  sa == sc, false);
    passed += Test("str_neq_diff", sa != sc, true);

    return passed;
}

int testStringBuilder()
{
    int passed = 0;

    stringbuilder sb;
    string s = "hello";
    sb.append(s);
    passed += Test("sb_append_str_len",  sb.length(), 5);
    passed += Test("sb_append_str_data", sb.toString(), "hello");

    sb.append(", world");
    passed += Test("sb_append_cstr_len",  sb.length(), 12);
    passed += Test("sb_append_cstr_data", sb.toString(), "hello, world");

    sb.clear();
    sb.append(42);
    passed += Test("sb_append_int_pos",  sb.toString(), "42");

    sb.clear();
    sb.append(0);
    passed += Test("sb_append_int_zero", sb.toString(), "0");

    sb.clear();
    sb.append(-7);
    passed += Test("sb_append_int_neg",  sb.toString(), "-7");

    sb.clear();
    sb.append(true);
    passed += Test("sb_append_bool_true",  sb.toString(), "true");

    sb.clear();
    sb.append(false);
    passed += Test("sb_append_bool_false", sb.toString(), "false");

    sb.clear();
    sb.appendLine("hello");
    passed += Test("sb_appendLine_cstr_len",  sb.length(), 6);
    passed += Test("sb_appendLine_cstr_data", sb.toString(), "hello\n");

    sb.clear();
    string line = "world";
    sb.appendLine(line);
    passed += Test("sb_appendLine_str_len",  sb.length(), 6);
    passed += Test("sb_appendLine_str_data", sb.toString(), "world\n");

    sb.clear();
    sb.append("abc");
    passed += Test("sb_ToString", sb.ToString(), "abc");

    sb.clear();
    sb.append("score=");
    sb.append(99);
    sb.append(",done=");
    sb.append(true);
    passed += Test("sb_mixed_build", sb.toString(), "score=99,done=true");

    sb.clear();
    sb.appendLine("line1");
    sb.appendLine("line2");
    passed += Test("sb_multi_line_len",  sb.length(), 12);
    passed += Test("sb_multi_line_data", sb.toString(), "line1\nline2\n");

    sb.clear();
    int i = 0;
    while (i < 10)
    {
        sb.append("01234567890123456789");
        i++;
    }
    passed += Test("sb_growth_len", sb.length(), 200);

    sb.clear();
    passed += Test("sb_clear_len",  sb.length(), 0);
    sb.append("reused");
    passed += Test("sb_reuse_data", sb.toString(), "reused");

    return passed;
}

int testStringView()
{
    int passed = 0;

    string source = "hello world";

    string_view* wholeView = source.view();
    passed += Test("view_length", wholeView->length(), 11);
    passed += Test("view_data",   wholeView->data(),   "hello world");
    delete wholeView;

    string_view* wordView = source.span(6, 11);
    passed += Test("span_mid_length", wordView->length(), 5);
    passed += Test("span_mid_get0",   wordView->get(0), 'w');
    passed += Test("span_mid_get4",   wordView->get(4), 'd');
    delete wordView;

    string_view* prefixView = source.span(0, 5);
    passed += Test("span_prefix_length", prefixView->length(), 5);
    passed += Test("span_prefix_get0",   prefixView->get(0), 'h');
    passed += Test("span_prefix_get4",   prefixView->get(4), 'o');
    delete prefixView;

    string_view* emptyView = source.span(3, 3);
    passed += Test("span_empty_length", emptyView->length(), 0);
    delete emptyView;

    string_view* clampedView = source.span(-5, 100);
    passed += Test("span_clamp_length", clampedView->length(), 11);
    delete clampedView;

    string_view* invertedView = source.span(7, 3);
    passed += Test("span_inv_length", invertedView->length(), 0);
    delete invertedView;

    string emptySource = "";
    string_view* emptyStringView = emptySource.view();
    passed += Test("view_empty_length", emptyStringView->length(), 0);
    delete emptyStringView;

    return passed;
}

// ── string API (Phases 1-4) ──────────────────────────────────────────────────

// Consumes an owned string (e.g. a chained-concat result) by value-move and returns
// its length. Exercises the move-string-parameter ownership-transfer path of the
// chained-concat temporary cleanup: the callee frees the buffer, so the caller must
// NOT also free it. Regression for the chained-concat intermediate leak
// (see internal/string-concat-temp-flush.md).
int consumeMoveLen(move string s)
{
    return s.length();
}

// Helper for the if/else owned-string regression below: returns an owned copy
// chosen by branch. The helper-return form was the customer's known-good workaround.
move string pickName(u32 i)
{
    if (i == 0u) { string a = "known"; return a.copy(); }
    else         { string b = "other"; return b.copy(); }
}

// Return-by-value of a struct whose destructor frees owned string fields. The local
// `o`'s destructor must be SKIPPED on the return (ownership moves to the caller) or the
// returned value dangles and the caller's destruction double-frees. g_owned_ret_dtor
// proves the struct is destructed exactly once (the returned `r`, not the local `o`).
// Regression for the return-by-value-of-dtor-bearing-struct fix + the string-field
// assignment ownership-transfer fix (internal/plan/string-ownership-fixes.md).
int g_owned_ret_dtor = 0;
struct OwnedRet {
    string a = default;
    string b = default;
    ~OwnedRet() {
        g_owned_ret_dtor++;
        if (a._ptr != nullptr) { i8* p = move a._ptr; delete p; }
        if (b._ptr != nullptr) { i8* p = move b._ptr; delete p; }
    }
};

OwnedRet makeOwnedRet()
{
    OwnedRet o;
    string s1 = "first-field";
    string s2 = "second-field";
    o.a = s1.copy();      // owned temp -> string field: ownership transfers to the field
    o.b = s2.copy();
    return o;             // by-value move-out: `o`'s dtor must not run here
}

int testStringAPI()
{
    int passed = 0;

    // -- Phase 1: Non-allocating queries --

    string hello = "hello";
    string empty = "";

    passed += Test("isEmpty false",     hello.isEmpty(), false);
    passed += Test("isEmpty true",      empty.isEmpty(), true);

    passed += Test("charAt 0",          hello.charAt(0), (i8)'h');
    passed += Test("charAt 4",          hello.charAt(4), (i8)'o');
    passed += Test("charAt clamp neg",  hello.charAt(-1), (i8)'h');
    passed += Test("charAt clamp over", hello.charAt(99), (i8)'o');
    passed += Test("charAt empty",      empty.charAt(0),  (i8)0);

    string hay = "abcabc";
    passed += Test("indexOf found",     hay.indexOf("bc"), 1);
    passed += Test("indexOf from",      hay.indexOf("bc", 2), 4);
    passed += Test("indexOf absent",    hay.indexOf("xyz"), -1);
    passed += Test("indexOf empty hay", empty.indexOf("x"), -1);
    passed += Test("indexOf char",      hay.indexOf((i8)'c'), 2);

    passed += Test("lastIndexOf found",  hay.lastIndexOf("bc"), 4);
    passed += Test("lastIndexOf absent", hay.lastIndexOf("zz"), -1);
    passed += Test("lastIndexOf char",   hay.lastIndexOf((i8)'a'), 3);

    passed += Test("contains yes",  hay.contains("abc"), true);
    passed += Test("contains no",   hay.contains("xyz"), false);
    passed += Test("contains empty haystack", empty.contains("x"), false);

    string prefix = "hello world";
    passed += Test("startsWith yes",    prefix.startsWith("hello"), true);
    passed += Test("startsWith no",     prefix.startsWith("world"), false);
    passed += Test("startsWith empty",  prefix.startsWith(""), true);
    passed += Test("endsWith yes",      prefix.endsWith("world"), true);
    passed += Test("endsWith no",       prefix.endsWith("hello"), false);
    passed += Test("endsWith empty",    prefix.endsWith(""), true);

    passed += Test("compare equal",  compare("abc", "abc"), 0);
    passed += Test("compare less",   compare("abc", "abd") < 0, true);
    passed += Test("compare greater",compare("abd", "abc") > 0, true);
    passed += Test("compare len",    compare("ab", "abc") < 0, true);

    string sa = "alpha";
    string sb = "beta";
    passed += Test("operator< yes",  sa < sb, true);
    passed += Test("operator< no",   sb < sa, false);
    passed += Test("operator> yes",  sb > sa, true);
    passed += Test("operator> no",   sa > sb, false);

    // sort a list<string> using < to verify ordering
    list<string> words;
    words.add("cherry"); words.add("apple"); words.add("banana");
    // bubble sort
    int n = words.count();
    int ii = 0;
    while (ii < n - 1)
    {
        int jj = 0;
        while (jj < n - 1 - ii)
        {
            if (words.get(jj) > words.get(jj + 1))
            {
                string tmp = words.get(jj).copy();
                words.set(jj, words.get(jj + 1).copy());
                words.set(jj + 1, move tmp);
            }
            jj++;
        }
        ii++;
    }
    passed += Test("sort[0]", words.get(0), "apple");
    passed += Test("sort[1]", words.get(1), "banana");
    passed += Test("sort[2]", words.get(2), "cherry");

    // -- Phase 2: Allocating transforms --

    string src = "Hello World";
    string sub1 = src.substring(6);
    passed += Test("substring from",    sub1, "World");
    string sub2 = src.substring(0, 5);
    passed += Test("substring 0,5",     sub2, "Hello");
    string sub3 = src.substring(0, 0);
    passed += Test("substring len0",    sub3, "");
    string sub4 = src.substring(100);
    passed += Test("substring clamp",   sub4, "");
    string sub5 = empty.substring(0);
    passed += Test("substring empty",   sub5, "");

    string repSrc1 = "aabbcc";
    string rep1 = repSrc1.replace("bb", "XX");
    passed += Test("replace mid",       rep1, "aaXXcc");
    string repSrc2 = "aaaa";
    string rep2 = repSrc2.replace("aa", "b");
    passed += Test("replace overlap",   rep2, "bb");
    string repSrc3 = "hello";
    string rep3 = repSrc3.replace("xyz", "abc");
    passed += Test("replace absent",    rep3, "hello");
    string rep4 = repSrc3.replace("", "x");
    passed += Test("replace empty old", rep4, "hello");

    string upSrc = "Hello World";
    string up1 = upSrc.toUpper();
    passed += Test("toUpper",  up1, "HELLO WORLD");
    string lo1 = upSrc.toLower();
    passed += Test("toLower",  lo1, "hello world");
    string up2 = empty.toUpper();
    passed += Test("toUpper empty", up2, "");

    string trimSrc1 = "  hello  ";
    string trim1 = trimSrc1.trim();
    passed += Test("trim",      trim1, "hello");
    string trimSrc2 = "  hello";
    string trim2 = trimSrc2.trimStart();
    passed += Test("trimStart", trim2, "hello");
    string trimSrc3 = "hello  ";
    string trim3 = trimSrc3.trimEnd();
    passed += Test("trimEnd",   trim3, "hello");
    string trim4 = empty.trim();
    passed += Test("trim empty", trim4, "");
    string trimSrc4 = "   ";
    string trim5 = trimSrc4.trim();
    passed += Test("trim all space", trim5, "");

    string padSrc1 = "hi";
    string pl1 = padSrc1.padLeft(5);
    passed += Test("padLeft",       pl1, "   hi");
    string padSrc2 = "hello";
    string pl2 = padSrc2.padLeft(3);
    passed += Test("padLeft no-op", pl2, "hello");
    string pr1 = padSrc1.padRight(5);
    passed += Test("padRight",      pr1, "hi   ");
    string pr2 = padSrc2.padRight(3);
    passed += Test("padRight no-op",pr2, "hello");

    // reversed concat: "lit" + string
    string revPart = src.substring(6);
    string rev1 = "Hello, " + revPart;
    passed += Test("reverse concat",    rev1, "Hello, World");

    // -- Phase 3: split / join --

    string splitSrc1 = "a,b,c";
    list<string> parts = splitSrc1.split(",");
    passed += Test("split count",   parts.count(), 3);
    passed += Test("split[0]",      parts.get(0),  "a");
    passed += Test("split[1]",      parts.get(1),  "b");
    passed += Test("split[2]",      parts.get(2),  "c");

    string splitSrc2 = "a,b,";
    list<string> trail = splitSrc2.split(",");
    passed += Test("split trailing count", trail.count(), 3);
    passed += Test("split trailing last",  trail.get(2),  "");

    string splitSrc3 = "hello";
    list<string> noSep = splitSrc3.split(",");
    passed += Test("split no match count", noSep.count(), 1);
    passed += Test("split no match[0]",    noSep.get(0),  "hello");

    list<string> emptyParts = empty.split(",");
    passed += Test("split empty input count", emptyParts.count(), 1);
    passed += Test("split empty input[0]",    emptyParts.get(0),  "");

    // split by char
    string splitSrc4 = "x:y:z";
    list<string> byChar = splitSrc4.split((i8)':');
    passed += Test("split char count", byChar.count(), 3);
    passed += Test("split char[0]",    byChar.get(0),  "x");
    passed += Test("split char[2]",    byChar.get(2),  "z");

    // join round-trip
    string joined = join(",", parts);
    passed += Test("join round-trip", joined, "a,b,c");

    list<string> one;
    one.add("only");
    string j1 = join(",", one);
    passed += Test("join single",  j1, "only");

    list<string> none;
    string j2 = join(",", none);
    passed += Test("join empty",   j2, "");

    // -- Phase 4: toString conversions (primitive -> string) --

    i64 n64 = 9876543210;
    string si64 = n64.toString();
    passed += Test("toString i64", si64, "9876543210");

    u64 nu64 = 18446744073709551615;
    string su64 = nu64.toString();
    passed += Test("toString u64", su64, "18446744073709551615");

    double dblVal = 3.14;
    string sdbl = dblVal.toString();
    passed += Test("toString double", sdbl, "3.14");

    bool trueVal = true;
    bool falseVal = false;
    string sbt = trueVal.toString();
    passed += Test("toString bool true",  sbt, "true");
    string sbf = falseVal.toString();
    passed += Test("toString bool false", sbf, "false");

    // toString(base): radix conversion (hex / binary)
    i64 hexVal = 255;
    string shex = hexVal.toString(16);
    passed += Test("toString base16", shex, "ff");

    // interpolation with i64 / double / bool
    i64 bigN = 123456789012345;
    passed += Test("interp i64", "{bigN}", "123456789012345");

    double pi = 3.14159;
    passed += Test("interp double", "{pi}", "3.14159");

    bool flag = true;
    passed += Test("interp bool", "{flag}", "true");

    // stringbuilder: append(i64), append(double)
    stringbuilder sbb;
    sbb.append((i64)1234567890123);
    passed += Test("sb append i64", sbb.toString(), "1234567890123");

    sbb.clear();
    sbb.append(2.718);
    passed += Test("sb append double", sbb.toString(), "2.718");

    // stringbuilder: append(string_view)
    string svsrc = "hello world";
    string_view* sv = svsrc.view();
    sbb.clear();
    sbb.append(*sv);
    passed += Test("sb append string_view", sbb.toString(), "hello world");
    delete sv;

    // ownership: result of allocating fn bound to inner scope, confirmed freed
    // (UFCS on a string literal works for single-arg calls but use a variable to be safe)
    {
        string padSrc = "  padded  ";
        string inner = padSrc.trim();
        passed += Test("ownership inner scope", inner, "padded");
    }

    // chained concat: the unnamed intermediates (e.g. (a+b) of a+b+c) must be freed
    // at end-of-expression while the final result stays correct. Regression for the
    // chained-concat intermediate leak (see internal/string-concat-temp-flush.md;
    // run under --asan / HeapAudit to confirm the intermediates are freed, not just
    // that the result is right).
    {
        string ca = "foo";
        string cb = "bar";
        string cc = "baz";
        string cd = "qux";
        string chain3 = ca + cb + cc;
        passed += Test("concat chain3", chain3, "foobarbaz");
        string chain4 = ca + cb + cc + cd;
        passed += Test("concat chain4", chain4, "foobarbazqux");
        // a chain consumed directly by a move string parameter (ownership transfers
        // to the callee; the caller must drop the temporary from its cleanup list).
        passed += Test("concat chain move-param", consumeMoveLen(ca + cb + cc), 9);
    }

    // Item 1: operator== must honor the tracked byte length (memcmp), not stop at an
    // embedded NUL the way strcmp does. Build the strings by hand via _ptr/_len so the
    // bytes after the NUL differ. The heap buffers are owned i8* locals - freed at block
    // exit; the strings are non-owning wrappers over them (no double free).
    {
        i8* nb1 = new i8[4]; nb1[0] = (i8)'a'; nb1[1] = (i8)0; nb1[2] = (i8)'b'; nb1[3] = (i8)0;
        i8* nb2 = new i8[4]; nb2[0] = (i8)'a'; nb2[1] = (i8)0; nb2[2] = (i8)'c'; nb2[3] = (i8)0;
        i8* nb3 = new i8[4]; nb3[0] = (i8)'a'; nb3[1] = (i8)0; nb3[2] = (i8)'b'; nb3[3] = (i8)0;
        string en1 = default; en1._ptr = nb1; en1._len = 3;
        string en2 = default; en2._ptr = nb2; en2._len = 3;
        string en3 = default; en3._ptr = nb3; en3._len = 3;
        passed += Test("embedded-NUL == differ",       en1 == en2, false);
        passed += Test("embedded-NUL compare nonzero",  en1.compare(en2) != 0, true);
        passed += Test("embedded-NUL == equal",         en1 == en3, true);
        // en1/en2/en3 are non-owning wrappers over the raw buffers - free the buffers explicitly.
        delete[] nb1; delete[] nb2; delete[] nb3;
    }

    // Item 5: a borrowed (non-owning) string wrapped from a char* and moved into a list
    // is heap-copied at the move call site, so the list owns its own copy. Freeing the
    // list on scope exit must not touch the borrowed literal buffer (ASan-clean). Also
    // exercises Item 2: (string)charPtr value-compares a string by content.
    {
        char* rawLit = "borrowed-buf";
        {
            list<string> bl = default;
            string bw = (string)rawLit;
            bl.add(move bw);
            passed += Test("borrowed into list survives", bl.get(0), "borrowed-buf");
            passed += Test("(string)charPtr == string",   (string)rawLit == bl.get(0), true);
            // bl destructor frees its owned element copy here.
        }
        // The borrowed literal buffer must still be valid after the list is destroyed.
        passed += Test("borrowed buffer still alive", (string)rawLit, "borrowed-buf");
    }

    // Item 3: char* + char* concatenates (operator+(const char*, const char*)) instead of
    // erroring with the old toString() advice. char* + literal and chained concat too; the
    // owned intermediates are freed at end-of-expression (ASan-clean).
    {
        char* cp = "foo";
        char* cq = "bar";
        string cc1 = cp + cq;
        passed += Test("charptr + charptr", cc1, "foobar");
        string cc2 = cp + "X";
        passed += Test("charptr + literal", cc2, "fooX");
        string cc3 = cp + cq + cp;
        passed += Test("charptr concat chain", cc3, "foobarfoo");
    }

    // Regression (plan-01): assigning an owned string to the SAME pre-declared local
    // in both branches of an if/else inside a loop. The stale lastCallReturnsOwned
    // flag from the if-branch assignment used to leak into the else-branch's
    // `string b = ...;` declaration, falsely marking that literal-backed local as
    // owning - its scope-exit destructor then freed a string literal -> heap
    // corruption (0xC0000374) on the second iteration. ASan-clean now.
    {
        u32 i = 0u;
        i32 hits = 0;
        string last = default;
        while (i < 4u)
        {
            string name = default;
            if (i == 0u) { string a = "known"; name = a.copy(); }
            else         { string b = "other"; name = b.copy(); }
            if (!name.isEmpty()) hits = hits + 1;
            last = name.copy();
            i = i + 1u;
        }
        passed += Test("if/else owned-string loop iterations", hits, 4);
        passed += Test("if/else owned-string last value", last, "other");
    }
    // Bare-if override form (assign unconditionally, then override in a bare if) -
    // the customer reported this variant ran clean; keep it as a guard.
    {
        u32 i = 0u;
        string name = default;
        while (i < 2u)
        {
            name = "default";
            if (i == 1u) { string c = "override"; name = c.copy(); }
            i = i + 1u;
        }
        passed += Test("bare-if override owned-string", name, "override");
    }
    // Helper-return form (each branch returns an owned string from a helper).
    {
        string n0 = pickName(0u);
        string n1 = pickName(1u);
        passed += Test("helper-return owned-string 0", n0, "known");
        passed += Test("helper-return owned-string 1", n1, "other");
    }
    // Regression (plan-03): a method call on a parenthesized (cast) expression. The
    // receiver is a by-value struct with no addressable storage; it used to fail with
    // "unknown function '((string)buf)'". Materializing it to a temp now lets the method
    // dispatch find the struct receiver.
    {
        char[8] cbuf = default;
        cbuf[0] = (char)'h'; cbuf[1] = (char)'i'; cbuf[2] = (char)0;
        string ms = ((string)cbuf).copy();
        passed += Test("method on cast expr (copy)", ms, "hi");
        passed += Test("method on cast expr (length)", ((string)cbuf).length(), 2);
        string pv = "wrapped";
        passed += Test("method on parenthesized value", (pv).copy(), "wrapped");
    }

    // Return-by-value of a struct whose dtor frees owned string fields.
    {
        g_owned_ret_dtor = 0;
        {
            OwnedRet r = makeOwnedRet();
            passed += Test("ret-struct owned field a", r.a, "first-field");
            passed += Test("ret-struct owned field b", r.b, "second-field");
        } // r destructs here - exactly one destruction, no double-free
        passed += Test("ret-struct single destruction", g_owned_ret_dtor, 1);
    }

    return passed;
}

// ── discard target `_` ───────────────────────────────────────────────────────
// A bare discarded call and `_ = expr` both evaluate the RHS for its side effects
// and destruct an owning-struct rvalue exactly once at end of the full expression
// (regression: the discarded temp used to leak - no field-access site hooked it).
int g_discard_side = 0;
int discardSide(int x) { g_discard_side++; return x; }

int testDiscard()
{
    int passed = 0;

    // Bare-statement owning-struct temp: destructed exactly once (no leak, no double-free).
    g_owned_ret_dtor = 0;
    { makeOwnedRet(); }
    passed += Test("bare discard destructs once", g_owned_ret_dtor, 1);

    // `_ = expr` owning-struct temp: same single destruction.
    g_owned_ret_dtor = 0;
    { _ = makeOwnedRet(); }
    passed += Test("'_ =' discard destructs once", g_owned_ret_dtor, 1);

    // `_ = expr` still evaluates the RHS for its side effects.
    g_discard_side = 0;
    _ = discardSide(7);
    passed += Test("'_ =' runs RHS side effect", g_discard_side, 1);

    return passed;
}

// ── main ─────────────────────────────────────────────────────────────────────

extern int main()
{
    int passed = 0;
    int total  = 0;

    int r;

    r = testArray();            passed += r; total += 22;
    r = testMemberDtor();       passed += r; total += 8;
    r = testList();             passed += r; total += 15;
    r = testListCopy();         passed += r; total += 19;
    r = testHashset();          passed += r; total += 19;
    r = testHashsetNegative();  passed += r; total += 12;
    r = testHashsetTombstone(); passed += r; total += 7;
    r = testHashsetI64();       passed += r; total += 12;
    r = testHashsetChar();      passed += r; total += 11;
    r = testHashsetRehash();    passed += r; total += 9;
    r = testDictionary();       passed += r; total += 34;
    r = testDictNegative();     passed += r; total += 11;
    r = testDictTombstone();    passed += r; total += 7;
    r = testDictI64();          passed += r; total += 11;
    r = testDictChar();         passed += r; total += 11;
    r = testDictRehash();       passed += r; total += 9;
    r = testPair();             passed += r; total += 8;
    r = testStack();            passed += r; total += 8;
    r = testQueue();            passed += r; total += 8;
    r = testFor();              passed += r; total += 10;
    r = testString();           passed += r; total += 22;
    r = testStringConcat();     passed += r; total += 10;
    r = testStringIString();    passed += r; total += 4;
    r = testStringInterpolation(); passed += r; total += 6;
    r = testStringSwitch();     passed += r; total += 6;
    r = testStringBuilder();    passed += r; total += 20;
    r = testStringView();       passed += r; total += 12;
    r = testStringAPI();        passed += r; total += 109;
    r = testDiscard();          passed += r; total += 3;

    printf("\n%d / %d tests passed.\n", passed, total);
    return passed == total ? 0 : 1;
}
