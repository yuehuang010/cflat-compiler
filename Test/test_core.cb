// ── dictionary: tombstone probing ─────────────────────────────────────────────
// 1 and 9 collide at slot 1 in cap-8 table; remove 1 leaves tombstone.

int testDictTombstone()
{
    int passed = 0;

    dictionary<int, int> d;
    d.add(1, 10);
    d.add(9, 90);   // collides with 1
    d.remove(1);    // slot 1 becomes tombstone

    passed += Test("d-tomb get 9 past tombstone", d.get(9),      90);
    passed += Test("d-tomb contains 9",           d.contains(9), true);
    passed += Test("d-tomb 1 gone",               d.contains(1), false);

    passed += Test("d-tomb add 17=>170",  d.add(17, 170), true);
    passed += Test("d-tomb get 17",       d.get(17),      170);
    passed += Test("d-tomb get 9 still",  d.get(9),       90);
    passed += Test("d-tomb count 2",      d.count(),      2);

    return passed;
}

