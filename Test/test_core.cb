import "interfaces.cb";
import "test_helper.cb";
import "list.cb";
import "interfaces.cb";
import "hashset.cb";
import "dictionary.cb";
import "pair.cb";
import "stack.cb";
import "queue.cb";
import "interfaces.cb";
import "array.cb";
import "bucket_allocator.cb";

// ── array<T> ─────────────────────────────────────────────────────────────────

int g_dtor_count = 0;

struct Tracked
{
    int _val = 0;

    ~Tracked()
    {
        g_dtor_count++;
    }
};

struct FixedBuf
{
    char data[4];
    int length = 0;
};

// ── member-field destructor recursion ────────────────────────────────────────
// A containing object must run destructors on its destructor-bearing member fields
// in every destruction path (scope exit, delete, delete[n], nested members).

int g_order_marker = -1;

// No user destructor, but a destructor-bearing value member -> needs a synthesized
// destruction path so the member still gets destructed.
struct MemberHolder
{
    Tracked t = default;
};

// Member-of-member: neither outer level has a user dtor; the leaf Tracked must still fire.
struct NestedHolder
{
    MemberHolder inner = default;
};

// Hand-written dtor must run FIRST, then the member is destructed (no double-free).
struct DtorHolder
{
    Tracked t = default;
    ~DtorHolder()
    {
        g_order_marker = g_dtor_count;  // 0 here proves the member has not been destructed yet
        g_dtor_count += 100;
    }
};

// A value-type container member (array<Tracked>) must have its elements destructed
// when the holder is destroyed.
struct ArrHolder
{
    array<Tracked> at = default;
};

int testMemberDtor()
{
    int passed = 0;

    // 1. Stack object at scope exit, outer has no user dtor.
    g_dtor_count = 0;
    {
        MemberHolder h;
    }
    passed += Test("member dtor on scope exit", g_dtor_count, 1);

    // 2. delete of a heap object, outer has no user dtor.
    g_dtor_count = 0;
    MemberHolder* mp = new MemberHolder;
    delete mp;
    passed += Test("member dtor on delete", g_dtor_count, 1);

    // 3. Nested struct member (member of member).
    g_dtor_count = 0;
    {
        NestedHolder n;
    }
    passed += Test("nested member-of-member dtor", g_dtor_count, 1);

    // 4. User dtor runs first, then member destruction - no double-free, both fire once.
    g_dtor_count = 0;
    g_order_marker = -1;
    {
        DtorHolder d;
    }
    passed += Test("user dtor runs before member dtor", g_order_marker, 0);
    passed += Test("user dtor + member dtor each fire once", g_dtor_count, 101);

    // 5. delete[n] - each element's members are destructed too.
    g_dtor_count = 0;
    MemberHolder* arr = new MemberHolder[3];
    delete[3] arr;
    passed += Test("delete[n] destructs each element's members", g_dtor_count, 3);

    // 6. Value container member at scope exit.
    g_dtor_count = 0;
    {
        ArrHolder h;
        h.at.init(3);
    }
    passed += Test("array<Tracked> member dtor on scope exit", g_dtor_count, 3);

    // 7. Value container member on delete.
    g_dtor_count = 0;
    ArrHolder* hp = new ArrHolder;
    hp->at.init(4);
    delete hp;
    passed += Test("array<Tracked> member dtor on delete", g_dtor_count, 4);

    return passed;
}

int testArray()
{
    int passed = 0;

    // delete[n] destructor invocation
    g_dtor_count = 0;
    Tracked* arr = new Tracked[5];
    delete[5] arr;
    passed += Test("delete[5] 5 elements", g_dtor_count, 5);

    g_dtor_count = 0;
    Tracked* one = new Tracked[1];
    delete[1] one;
    passed += Test("delete[1] 1 element", g_dtor_count, 1);

    g_dtor_count = 0;
    Tracked* zero = new Tracked[0];
    delete[_] zero;
    passed += Test("delete[_] 0 elements", g_dtor_count, 0);

    // Primitive array - no cookie, no destructor (must not crash)
    int* ints = new int[10];
    ints[0] = 42;
    delete[] ints;

    // array<int>
    array<int> ai;
    ai.init(4);
    ai.set(0, 10);
    ai.set(1, 20);
    ai.set(2, 30);
    ai.set(3, 40);
    passed += Test("array<int> count",  ai.count(), 4);
    passed += Test("array<int> get(0)", ai.get(0),  10);
    passed += Test("array<int> get(3)", ai.get(3),  40);
    passed += Test("array<int> [1]",    ai[1],      20);
    passed += Test("array<int> [2]",    ai[2],      30);

    // array<Tracked>: destructor fires on scope exit
    g_dtor_count = 0;
    {
        array<Tracked> at;
        at.init(3);
    }
    passed += Test("array<Tracked> dtor count", g_dtor_count, 3);

    // foreach over array<int>
    array<int> af;
    af.init(5);
    af.set(0, 1); af.set(1, 2); af.set(2, 3); af.set(3, 4); af.set(4, 5);

    int sum = 0;
    for (int v in af)
        sum += v;
    passed += Test("array foreach sum",   sum,   15);

    int fcount = 0;
    for (int v in af)
        fcount++;
    passed += Test("array foreach count", fcount, 5);

    // heap-allocated array<int>
    array<int>* ha = new array<int>;
    ha->init(3);
    ha->set(0, 100); ha->set(1, 200); ha->set(2, 300);
    passed += Test("heap array count",    ha->count(),   3);
    passed += Test("heap array get(1)",   ha->get(1),    200);
    delete ha;

    // destructor fires when heap array is deleted
    g_dtor_count = 0;
    {
        array<Tracked>* ht = new array<Tracked>;
        ht->init(4);
        delete ht;
    }
    passed += Test("heap array<Tracked> dtor count", g_dtor_count, 4);

    // raw 'new string[n]' array: slots are zero-initialized (safe default) and can be
    // read/written; the buffer is freed with 'delete[_]' (no per-element string dtor,
    // which would corrupt the heap since 'string' has no ownership flag - see the
    // err_delete_string_array negative test). Proves the safe-management path works.
    string* codes = new string[4];
    codes[1] = "hello";
    codes[3] = "world";
    passed += Test("new string[n] slot read 1", codes[1], "hello");
    passed += Test("new string[n] slot read 3", codes[3], "world");
    passed += Test("new string[n] unset slot length 0", codes[0].length(), 0);
    delete[_] codes;   // free buffer only; no per-element string dtors (would corrupt)

    // L2 regression: a raw array-free whose target is a CAST expression must compile
    // and free the underlying buffer exactly once. 'delete[_] (string*)expr' used to
    // assert the compiler (the pointer cast wrongly invoked the value conversion
    // 'operator string'); once that was fixed, the cast path still dropped the source
    // alloca, so the owning local was freed here AND again at scope exit -> heap
    // corruption. A cast target must behave exactly like 'delete[_] localPtr'.
    string* castCodes = new string[4];
    castCodes[2] = "cast";
    passed += Test("delete[_] cast-target read", castCodes[2], "cast");
    delete[_] (string*)castCodes;   // frees once: no compiler assert, no double free

    int* castInts = new int[8];
    castInts[0] = 7;
    delete[_] (int*)castInts;       // primitive buffer, cast-target raw free, clean

    // B1: an unsigned narrow cast used as an array index must ZERO-extend. A byte
    // value >= 128 is negative as i8, so without the unsigned widen (u8)b would
    // sign-extend to a negative GEP offset and silently mis-index. Each high byte
    // must land in its own slot (regression for the dogfooding silent-wrong bug).
    int[256] freq;
    for (int i = 0; i < 256; i++) freq[i] = 0;
    i8[4] bytes;
    bytes[0] = (i8)200;   // 0xC8
    bytes[1] = (i8)255;   // 0xFF
    bytes[2] = (i8)127;   // 0x7F (positive - control)
    bytes[3] = (i8)10;
    for (int i = 0; i < 4; i++)
        freq[(u8)bytes[i]] = freq[(u8)bytes[i]] + 1;
    passed += Test("u8 array index slot 200", freq[200], 1);
    passed += Test("u8 array index slot 255", freq[255], 1);
    passed += Test("u8 array index slot 127", freq[127], 1);
    passed += Test("u8 array index slot 10",  freq[10],  1);

    return passed;
}

// ── list<int> ────────────────────────────────────────────────────────────────

int testList()
{
    int passed = 0;

    list<int> l;

    // add and count
    l.add(10);
    l.add(20);
    l.add(30);
    passed += Test("list count after 3 adds", l.count(), 3);

    // get
    passed += Test("list get 0", l.get(0), 10);
    passed += Test("list get 1", l.get(1), 20);
    passed += Test("list get 2", l.get(2), 30);

    // operator[]
    passed += Test("list op[] 0", l[0], 10);
    passed += Test("list op[] 1", l[1], 20);
    passed += Test("list op[] 2", l[2], 30);

    // set
    l.set(1, 99);
    passed += Test("list set", l.get(1), 99);

    // removeAt middle
    l.set(1, 20);
    l.removeAt(1);
    passed += Test("list count after removeAt", l.count(), 2);
    passed += Test("list after removeAt[0]",   l.get(0), 10);
    passed += Test("list after removeAt[1]",   l.get(1), 30);

    // clear
    l.clear();
    passed += Test("list count after clear", l.count(), 0);

    // growth past initial capacity (forces _grow)
    int i = 0;
    while (i < 20)
    {
        l.add(i);
        i++;
    }
    passed += Test("list count after 20 adds", l.count(), 20);
    passed += Test("list growth get[0]",  l.get(0),  0);
    passed += Test("list growth get[19]", l.get(19), 19);

    return passed;
}

// ── list<T> ICopyable (copy / copy(IAllocator)) ──────────────────────────────

// X4 Part 1: the SAFE way to store an owning container into a struct field is '.copy()'
// (an independent buffer). A plain `values = v` shallow-copy is rejected at compile time -
// see Test/errors/err_container_copy_into_field.cb.
class IntListHolder
{
    list<int> values = default;
    void fill(list<int> v) { values = v.copy(); }
};

int testListCopy()
{
    int passed = 0;

    // list<int>: value copy is an independent list.
    list<int> li;
    li.add(1); li.add(2); li.add(3);
    list<int> lic = li.copy();
    passed += Test("list<int> copy count", lic.count(), 3);
    passed += Test("list<int> copy[0]",    lic.get(0), 1);
    passed += Test("list<int> copy[2]",    lic.get(2), 3);
    lic.set(0, 99);                                  // mutate copy
    passed += Test("list<int> copy mutate isolates source", li.get(0), 1);
    li.set(2, 77);                                   // mutate source
    passed += Test("list<int> source mutate isolates copy", lic.get(2), 3);

    // list<string>: copy is a deep copy with its own buffers.
    list<string> ls;
    ls.add("alpha"); ls.add("bravo"); ls.add("charlie");
    list<string> lsc = ls.copy();
    passed += Test("list<string> copy count", lsc.count(), 3);
    passed += Test("list<string> copy[0]",    lsc.get(0), "alpha");
    passed += Test("list<string> copy[1]",    lsc.get(1), "bravo");
    passed += Test("list<string> copy[2]",    lsc.get(2), "charlie");

    // deep: each element owns a distinct buffer (not aliased to the source).
    bool deep0 = ls.get(0).data() != lsc.get(0).data();
    bool deep2 = ls.get(2).data() != lsc.get(2).data();
    passed += Test("list<string> copy deep buf[0]", deep0, true);
    passed += Test("list<string> copy deep buf[2]", deep2, true);

    // mutating the source does not disturb the copy.
    ls.set(0, "ZZZ");
    passed += Test("list<string> source mutate isolates copy", lsc.get(0), "alpha");

    // copy(IAllocator): backing array and string buffers come from the allocator.
    BucketAllocator ba;
    IAllocator alloc = ba;
    {
        list<string> owned = ls.copy(alloc);         // ls == ["ZZZ","bravo","charlie"]
        passed += Test("list<string> copy(alloc) count", owned.count(), 3);
        passed += Test("list<string> copy(alloc)[1]",    owned.get(1), "bravo");
        passed += Test("list<string> copy(alloc) routed to allocator",
                       ba.usedBytes() > (i64)0, true);
    }   // owned freed here, while ba is still alive

    // empty list copies to an empty list.
    list<int> empty;
    list<int> emptyDup = empty.copy();
    passed += Test("list<int> empty copy count", emptyDup.count(), 0);

    // X4 Part 1: storing a list COPY into a struct field is the safe pattern - the field
    // owns an independent buffer, so source and field each free exactly once (no double-free,
    // no STATUS_HEAP_CORRUPTION). Reaching this line (clean teardown) is itself the proof.
    {
        list<int> src;
        src.add(10); src.add(20); src.add(30);
        IntListHolder h;
        h.fill(src);                          // h.values = src.copy()
        passed += Test("list copy-into-field count",  h.values.count(), 3);
        passed += Test("list copy-into-field get[2]", h.values.get(2), 30);
        src.set(0, 999);                      // mutating the source must not disturb the field
        passed += Test("list copy-into-field isolates source", h.values.get(0), 10);
    }   // h and src both destruct here - each frees its own buffer once

    return passed;
}

// ── hashset<int> ─────────────────────────────────────────────────────────────

int testHashset()
{
    int passed = 0;

    hashset<int> s;

    // add new elements
    passed += Test("hashset add 1",   s.add(1),   true);
    passed += Test("hashset add 2",   s.add(2),   true);
    passed += Test("hashset add 42",  s.add(42),  true);
    passed += Test ("hashset count 3", s.count(),  3);

    // contains
    passed += Test("hashset contains 1",  s.contains(1),  true);
    passed += Test("hashset contains 42", s.contains(42), true);
    passed += Test("hashset contains 99", s.contains(99), false);

    // duplicate add returns false
    passed += Test("hashset dup add 1",  s.add(1),  false);
    passed += Test ("hashset count unchanged", s.count(), 3);

    // remove
    passed += Test("hashset remove 2",         s.remove(2),      true);
    passed += Test("hashset contains 2 after", s.contains(2),    false);
    passed += Test ("hashset count after remove", s.count(),       2);
    passed += Test("hashset remove missing",   s.remove(999),    false);

    // re-add after remove
    passed += Test("hashset re-add 2", s.add(2), true);
    passed += Test("hashset contains 2 re-added", s.contains(2), true);

    // trigger rehash by adding many elements
    hashset<int> big;
    int i = 0;
    while (i < 50)
    {
        big.add(i);
        i++;
    }
    passed += Test("hashset big count", big.count(), 50);
    passed += Test("hashset big contains 0",  big.contains(0),  true);
    passed += Test("hashset big contains 49", big.contains(49), true);
    passed += Test("hashset big contains 50", big.contains(50), false);

    return passed;
}

// ── dictionary<int,int> ──────────────────────────────────────────────────────

int testDictionary()
{
    int passed = 0;

    dictionary<int, int> d;

    // add new entries
    passed += Test("dict add 1=>100",  d.add(1,  100), true);
    passed += Test("dict add 2=>200",  d.add(2,  200), true);
    passed += Test("dict add 42=>99",  d.add(42, 99),  true);
    passed += Test ("dict count 3",     d.count(),       3);

    // contains / get
    passed += Test("dict contains 1",  d.contains(1),  true);
    passed += Test("dict contains 42", d.contains(42), true);
    passed += Test("dict contains 99", d.contains(99), false);
    passed += Test ("dict get 1",       d.get(1),       100);
    passed += Test ("dict get 2",       d.get(2),       200);
    passed += Test ("dict get 42",      d.get(42),      99);
    passed += Test ("dict get missing", d.get(999),     0);

    // duplicate add leaves existing value alone
    passed += Test("dict dup add 1",   d.add(1, 555),  false);
    passed += Test ("dict get 1 after dup", d.get(1),   100);

    // set overwrites
    d.set(1, 111);
    passed += Test ("dict get 1 after set", d.get(1),   111);
    d.set(5, 500); // set on new key inserts
    passed += Test("dict contains 5",  d.contains(5), true);
    passed += Test ("dict get 5",       d.get(5),       500);
    passed += Test ("dict count 4",     d.count(),       4);

    // remove
    passed += Test("dict remove 2",            d.remove(2),     true);
    passed += Test("dict contains 2 after",    d.contains(2),   false);
    passed += Test ("dict count after remove",  d.count(),        3);
    passed += Test("dict remove missing",      d.remove(999),    false);

    // remaining keys still reachable after swap-remove
    passed += Test ("dict get 1 after remove",  d.get(1),        111);
    passed += Test ("dict get 42 after remove", d.get(42),        99);
    passed += Test ("dict get 5 after remove",  d.get(5),        500);

    // re-add after remove
    passed += Test("dict re-add 2",        d.add(2, 222),   true);
    passed += Test ("dict get 2 re-added",  d.get(2),         222);

    // operator[] - same semantics as get()
    passed += Test ("dict op[] 1",       d[1],            111);
    passed += Test ("dict op[] 42",      d[42],            99);
    passed += Test ("dict op[] missing", d[999],            0);

    // bulk inserts to force hashset rehash underneath
    dictionary<int, int> big;
    int i = 0;
    while (i < 50)
    {
        big.add(i, i * 10);
        i++;
    }
    passed += Test ("dict big count",     big.count(),      50);
    passed += Test ("dict big get 0",     big.get(0),        0);
    passed += Test ("dict big get 49",    big.get(49),     490);
    passed += Test("dict big contains 0",  big.contains(0),  true);
    passed += Test("dict big contains 50", big.contains(50), false);

    return passed;
}

// ── Pair<T,U> ────────────────────────────────────────────────────────────────

int testPair()
{
    int passed = 0;

    // Test Pair<int, int>
    Pair<int, int> p1 = default;
    p1.first = 10;
    p1.second = 20;
    passed += Test("pair int int first", p1.first, 10);
    passed += Test("pair int int second", p1.second, 20);

    // Test Pair<int, int> with different values
    Pair<int, int> p2 = default;
    p2.first = 42;
    p2.second = 99;
    passed += Test("pair int int first 2", p2.first, 42);
    passed += Test("pair int int second 2", p2.second, 99);

    // Test Pair<string, string>
    Pair<string, string> ps = default;
    ps.first = "hello";
    ps.second = "world";
    passed += Test("pair string string first",  ps.first,  "hello");
    passed += Test("pair string string second", ps.second, "world");

    // Reassign fields
    ps.first = "foo";
    ps.second = "bar";
    passed += Test("pair string string reassign first",  ps.first,  "foo");
    passed += Test("pair string string reassign second", ps.second, "bar");

    return passed;
}

// ── stack<i32> ───────────────────────────────────────────────────────────────

int testStack()
{
    int passed = 0;

    stack<i32> s;

    passed += Test("stack empty initially",  s.isEmpty(), true);

    s.push(10);
    s.push(20);
    s.push(30);

    passed += Test("stack count after 3 pushes", s.count(), 3);
    passed += Test("stack not empty",            s.isEmpty(), false);
    passed += Test("stack peek top",             s.peek(), 30);

    passed += Test("stack pop 1 (LIFO)", s.pop(), 30);
    passed += Test("stack pop 2",        s.pop(), 20);
    passed += Test("stack pop 3",        s.pop(), 10);

    passed += Test("stack empty after drain", s.isEmpty(), true);

    return passed;
}

// ── queue<i32> ───────────────────────────────────────────────────────────────

int testQueue()
{
    int passed = 0;

    queue<i32> q;

    passed += Test("queue empty initially",  q.isEmpty(), true);

    q.enqueue(10);
    q.enqueue(20);
    q.enqueue(30);

    passed += Test("queue count after 3 enqueues", q.count(), 3);
    passed += Test("queue not empty",              q.isEmpty(), false);
    passed += Test("queue peek front",             q.peek(), 10);

    passed += Test("queue dequeue 1 (FIFO)", q.dequeue(), 10);
    passed += Test("queue dequeue 2",        q.dequeue(), 20);
    passed += Test("queue dequeue 3",        q.dequeue(), 30);

    passed += Test("queue empty after drain", q.isEmpty(), true);

    return passed;
}

// ── for ──────────────────────────────────────────────────────────────────

int testFor()
{
    int passed = 0;

    // Basic iteration over list<int>
    list<int> l;
    l.add(10);
    l.add(20);
    l.add(30);

    int sum = 0;
    for (int x in l)
        sum += x;
    passed += Test("for sum", sum, 60);

    // Correct element values
    int first = -1;
    int last  = -1;
    for (int x in l)
    {
        if (first == -1) first = x;
        last = x;
    }
    passed += Test("for first", first, 10);
    passed += Test("for last",  last,  30);

    // break exits early
    int count = 0;
    for (int x in l)
    {
        if (x == 20) break;
        count++;
    }
    passed += Test("for break count", count, 1);

    // continue skips element
    int skipSum = 0;
    for (int x in l)
    {
        if (x == 20) continue;
        skipSum += x;
    }
    passed += Test("for continue sum", skipSum, 40);

    // Empty list iterates zero times
    list<int> empty;
    int visits = 0;
    for (int x in empty)
        visits++;
    passed += Test("for empty", visits, 0);

    // Iterate via IEnumerable<int> interface
    IEnumerable<int> ie = l;
    int ieSum = 0;
    for (int x in ie)
        ieSum += x;
    passed += Test("for IEnumerable sum", ieSum, 60);

    // Inline fixed array (local)
    int[5] nums;
    nums[0] = 10; nums[1] = 20; nums[2] = 30; nums[3] = 40; nums[4] = 50;
    int fixedSum = 0;
    for (int x in nums)
        fixedSum += x;
    passed += Test("for int[5] sum", fixedSum, 150);

    char[4] cbuf;
    cbuf[0] = 'a'; cbuf[1] = 'b'; cbuf[2] = 'c'; cbuf[3] = 'd';
    int charCount = 0;
    for (char c in cbuf)
        if (c >= 'a' && c <= 'd') charCount++;
    passed += Test("for char[4] count", charCount, 4);

    // Inline fixed array (struct field)
    FixedBuf fb;
    fb.data[0] = (char)10; fb.data[1] = (char)20;
    fb.data[2] = (char)30; fb.data[3] = (char)40;
    int fieldSum = 0;
    for (char b in fb.data)
        fieldSum += b;
    passed += Test("for struct field char[4] sum", fieldSum, 100);

    return passed;
}

// ── hashset: negative keys ───────────────────────────────────────────────────

int testHashsetNegative()
{
    int passed = 0;

    hashset<int> s;
    passed += Test("hs-neg add -1",   s.add(-1),   true);
    passed += Test("hs-neg add -10",  s.add(-10),  true);
    passed += Test("hs-neg add -100", s.add(-100), true);
    passed += Test("hs-neg count 3",  s.count(),   3);

    passed += Test("hs-neg contains -1",   s.contains(-1),   true);
    passed += Test("hs-neg contains -10",  s.contains(-10),  true);
    passed += Test("hs-neg contains -100", s.contains(-100), true);
    passed += Test("hs-neg missing -5",    s.contains(-5),   false);

    passed += Test("hs-neg remove -10",         s.remove(-10),    true);
    passed += Test("hs-neg -10 gone",           s.contains(-10),  false);
    passed += Test("hs-neg -1 still present",   s.contains(-1),   true);
    passed += Test("hs-neg -100 still present", s.contains(-100), true);

    return passed;
}

// ── hashset: tombstone probing ────────────────────────────────────────────────
// With initial capacity 8: Hash(1)%8=1, Hash(9)%8=1, Hash(17)%8=1.
// Removing 1 leaves a tombstone; contains(9) must probe past it.

int testHashsetTombstone()
{
    int passed = 0;

    hashset<int> s;
    s.add(1);
    s.add(9);    // collides with 1 at slot 1, placed at slot 2
    s.remove(1); // slot 1 becomes tombstone (status=2)

    passed += Test("hs-tomb contains 9 past tombstone", s.contains(9),  true);
    passed += Test("hs-tomb contains 1 gone",           s.contains(1),  false);

    // 17 also hashes to slot 1; should reuse the tombstone
    passed += Test("hs-tomb add 17",      s.add(17),      true);
    passed += Test("hs-tomb contains 17", s.contains(17), true);
    passed += Test("hs-tomb contains 9",  s.contains(9),  true);
    passed += Test("hs-tomb count 2",     s.count(),      2);

    s.remove(9);
    passed += Test("hs-tomb 17 after removing 9", s.contains(17), true);

    return passed;
}

// ── hashset<i64> ─────────────────────────────────────────────────────────────

int testHashsetI64()
{
    int passed = 0;

    hashset<i64> s;
    passed += Test("hs-i64 add 1",    s.add(1),             true);
    passed += Test("hs-i64 add 2",    s.add(2),             true);
    passed += Test("hs-i64 add -1",   s.add(-1),            true);
    passed += Test("hs-i64 add big",  s.add(1000000000000), true);
    passed += Test("hs-i64 count 4",  s.count(), 4);

    passed += Test("hs-i64 contains 1",   s.contains(1),            true);
    passed += Test("hs-i64 contains -1",  s.contains(-1),           true);
    passed += Test("hs-i64 contains big", s.contains(1000000000000), true);
    passed += Test("hs-i64 missing 3",    s.contains(3),            false);

    passed += Test("hs-i64 remove -1", s.remove(-1),   true);
    passed += Test("hs-i64 -1 gone",   s.contains(-1), false);
    passed += Test("hs-i64 1 still",   s.contains(1),  true);

    return passed;
}

// ── hashset<char> ────────────────────────────────────────────────────────────

int testHashsetChar()
{
