// ── dictionary: rehash stress ─────────────────────────────────────────────────

int testDictRehash()
{
    int passed = 0;

    dictionary<int, int> d;
    int i = 0;
    while (i < 100) { d.add(i, i * 3); i++; }
    passed += Test("d-rehash count 100",   d.count(),       100);
    passed += Test("d-rehash get 0",       d.get(0),        0);
    passed += Test("d-rehash get 99",      d.get(99),       297);
    passed += Test("d-rehash missing 100", d.contains(100), false);

    i = 0;
    while (i < 100) { if (i % 2 == 0) d.set(i, i * -1); i++; }
    passed += Test("d-rehash updated 0",  d.get(0),   0);
    passed += Test("d-rehash updated 2",  d.get(2),   -2);
    passed += Test("d-rehash updated 98", d.get(98),  -98);
    passed += Test("d-rehash odd 1",      d.get(1),   3);
    passed += Test("d-rehash odd 99",     d.get(99),  297);

    return passed;
}

// ── string / stringbuilder / string_view ─────────────────────────────────────

struct StringRow { string name = default; };

int testString()
{
    int passed = 0;

    string s = "hello";
    passed += Test("string literal length", s.length(), 5);
    passed += Test("string literal data",   s.data(),   "hello");

    string empty = "";
    passed += Test("empty string length", empty.length(), 0);

    stringbuilder sb;
    passed += Test("sb initial length", sb.length(), 0);

    sb.appendCStr("foo");
    passed += Test("sb after appendCStr length", sb.length(), 3);
    passed += Test("sb after appendCStr data",   sb.data(),   "foo");

    sb.appendChar('!');
    passed += Test("sb after appendChar length", sb.length(), 4);
    passed += Test("sb after appendChar data",   sb.data(),   "foo!");

    string view = sb.toString();
    passed += Test("sb toString length", view.length(), 4);
    passed += Test("sb toString data",   view.data(),   "foo!");

    sb.clear();
    passed += Test("sb after clear length", sb.length(), 0);

    // char* -> string coercion must apply on ASSIGNMENT to an existing string, not just
    // on initialization: `s = buf;` and `r.name = buf;` must route through operator
    // string(const char*) so _len = strlen(buf), not stay 0 (raw-pointer store bug).
    char[16] cbuf = {'a', 'b', 'c', '\0'};

    string assignInit = cbuf;
    passed += Test("char* init length", assignInit.length(), 3);

    string assignLocal = default;
    assignLocal = cbuf;
    passed += Test("char* assign local length", assignLocal.length(), 3);
    passed += Test("char* assign local data",   assignLocal.data(),   "abc");

    StringRow row;
    row.name = cbuf;
    passed += Test("char* assign field length", row.name.length(), 3);
    passed += Test("char* assign field data",   row.name.data(),   "abc");

    // Method-call syntax on a char* / char[N] receiver dispatches to
    // toString(const char* self), yielding an OWNED string copy of the C bytes.
    char* litPtr = "abc";
    string fromPtr = litPtr.toString();
    passed += Test("char* toString length", fromPtr.length(), 3);
    passed += Test("char* toString data",   fromPtr.data(),   "abc");

    char[16] mbuf = {'a', 'b', 'c', '\0'};
    string fromArr = mbuf.toString();
    passed += Test("char[N] toString length", fromArr.length(), 3);
    passed += Test("char[N] toString data",   fromArr.data(),   "abc");

    // The call copies the bytes and leaves the source buffer untouched.
    passed += Test("char[N] toString source intact", (int)mbuf[0], (int)'a');

    // The result is owned: mutating the source after the call must not change it
    // (a non-owning wrap would alias the buffer and change with it).
    mbuf[0] = 'Z';
    passed += Test("char[N] toString owned", fromArr.data(), "abc");

    return passed;
}

int testStringConcat()
{
    int passed = 0;

    string a = "hello";
    string b = " world";

    string c = a + b;
    passed += Test("concat length",  c.length(), 11);
    passed += Test("concat data",    c.data(),   "hello world");

    string d = a + " there";
    passed += Test("concat char* length", d.length(), 11);
    passed += Test("concat char* data",   d.data(),   "hello there");

    string e = c + b;
    passed += Test("chained concat length", e.length(), 17);
    passed += Test("chained concat data",   e.data(),   "hello world world");

    string empty = "";
    string f = empty + a;
    passed += Test("empty + s length", f.length(), 5);
    passed += Test("empty + s data",   f.data(),   "hello");

    string g = a + empty;
    passed += Test("s + empty length", g.length(), 5);
    passed += Test("s + empty data",   g.data(),   "hello");

    return passed;
}

