
extern bool printOnPass;

import "list.cb";
import "dictionary.cb";

int Test(const char* testName, i64 actual, i64 expected)
{
    if (expected == actual)
    {
        if (printOnPass) printf("%s passed.\n", testName);
        return 1;
    }

    printf("%s mismatch: expected '%d' but got '%d'.\n", testName, expected, actual);
    return 0;
}

int Test(const char* testName, int actual, int expected)
{
    if (expected == actual)
    {
        if (printOnPass) printf("%s passed.\n", testName);
        return 1;
    }

    printf("%s mismatch: expected '%d' but got '%d'.\n", testName, expected, actual);
    return 0;
}

// =============================================================
// Generic struct tests (compile-time only monomorphization)
// =============================================================

struct Box<T>
{
    T value = default;
};

struct Pair<K, V>
{
    K first = default;
    V second = default;
};

struct Container<T>
{
    T data = default;
    int count = 0;
};

struct Stack<T>
{
    T elements = default;
    int size = 0;
};

bool testGenericBox()
{
    bool result = true;

    // Test Box<int>
    Box<int> intBox = default;
    intBox.value = 42;
    result &= Test("generic_box_int", intBox.value, 42);

    // Test Box<float> - compare as int representation
    Box<float> floatBox = default;
    floatBox.value = 3.14f;
    // Note: floating point comparison would need special handling

    // Test Box<i32>
    Box<i32> i32Box = default;
    i32Box.value = 100;
    result &= Test("generic_box_i32", i32Box.value, 100);

    return result;
}

bool testGenericPair()
{
    bool result = true;

    // Test Pair<int, int>
    Pair<int, int> intIntPair = default;
    intIntPair.first = 10;
    intIntPair.second = 20;
    result &= Test("generic_pair_int_int_first", intIntPair.first, 10);
    result &= Test("generic_pair_int_int_second", intIntPair.second, 20);

    // Test Pair<int, float>
    Pair<int, float> intFloatPair = default;
    intFloatPair.first = 5;
    intFloatPair.second = 2.5f;
    result &= Test("generic_pair_int_float_first", intFloatPair.first, 5);

    // Test Pair<i32, i32>
    Pair<i32, i32> i32Pair = default;
    i32Pair.first = 1000;
    i32Pair.second = 2000;
    result &= Test("generic_pair_i32_first", i32Pair.first, 1000);
    result &= Test("generic_pair_i32_second", i32Pair.second, 2000);

    return result;
}

bool testGenericMultipleInstantiations()
{
    bool result = true;

    // Multiple instantiations of Box with different types
    Box<int> boxInt = default;
    Box<i32> boxI32 = default;
    Box<u32> boxU32 = default;
    Box<i8> boxI8 = default;

    boxInt.value = 42;
    boxI32.value = 100;
    boxU32.value = 200;
    boxI8.value = 10;

    result &= Test("generic_multi_int", boxInt.value, 42);
    result &= Test("generic_multi_i32", boxI32.value, 100);
    result &= Test("generic_multi_u32", boxU32.value, 200);
    result &= Test("generic_multi_i8", boxI8.value, 10);

    return result;
}

bool testGenericContainer()
{
    bool result = true;

    // Test Container<int>
    Container<int> intContainer = default;
    intContainer.data = 99;
    intContainer.count = 1;
    result &= Test("generic_container_int_data", intContainer.data, 99);
    result &= Test("generic_container_int_count", intContainer.count, 1);

    // Test Container<i64>
    Container<i64> i64Container = default;
    i64Container.data = 200000;
    i64Container.count = 5;
    result &= Test("generic_container_i64_data", i64Container.data, 200000);
    result &= Test("generic_container_i64_count", i64Container.count, 5);

    return result;
}

bool testGenericStack()
{
    bool result = true;

    // Test Stack<int>
    Stack<int> intStack = default;
    intStack.elements = 42;
    intStack.size = 1;
    result &= Test("generic_stack_int_elements", intStack.elements, 42);
    result &= Test("generic_stack_int_size", intStack.size, 1);

    // Test Stack<i32>
    Stack<i32> i32Stack = default;
    i32Stack.elements = 999;
    i32Stack.size = 10;
    result &= Test("generic_stack_i32_elements", i32Stack.elements, 999);
    result &= Test("generic_stack_i32_size", i32Stack.size, 10);

    return result;
}

int testGenericStructs()
{
    bool result = true;
    result &= testGenericBox();
    result &= testGenericPair();
    result &= testGenericMultipleInstantiations();
    result &= testGenericContainer();
    result &= testGenericStack();
    return result;
}

// Interface tests

interface IReadable
{
    int Read();
};

interface IScalable
{
    int Scale(int factor);
};

class Counter : IReadable
{
    int count = 10;
    int Read() { return count; }
};

class ScaledValue : IReadable, IScalable
{
    int value = 3;
    int Read() { return value; }
    int Scale(int factor) { return value * factor; }
};

int extensionIRead(IReadable scaledValue)
{
    return scaledValue.Read();
}

bool testInterface()
{
    bool result = true;
    Counter c = Counter();
    ScaledValue s = ScaledValue();

    result &= Test("counter.Read", c.Read(), 10);   // 10
    result &= Test("scaledValue.Read", s.Read(), 3);   // 3
    result &= Test("scaledValue.Read", s.extensionIRead(), 3);   // 3
    result &= Test("scaledValue.Scale2", s.Scale(2), 6);   // 3*2=6
    result &= Test("scaledValue.Scale5", s.Scale(5), 15);   // 3*5=15
    return result;
}


// Generic interface for storing and retrieving a value
interface Container<T>
{
    T Get();
    void Set(T value);
};

struct MyInt
{
    int x = 5;
};

// Generic struct template with type parameter T implementing Container<T>
class Storage<T> : Container<T>
{
    T data = default;

    T Get()
    {
        return data;
    }

    void Set(T value)
    {
        data = value;
    }
};

T ExtGet<T>(Container<T> container)
{
    T value = container.Get();
    return value;
}

bool testGenericInterface()
{
    bool result = true;

    // Test Storage<int> implementing Container<int>
    Storage<int> intStorage = default;
    intStorage.Set(42);
    result &= Test("generic_interface_int_get", intStorage.Get(), 42);
    result &= Test("generic_interface_int_getExt", intStorage.ExtGet(), 42);

    // Test Storage<MyInt> implementing Container<MyInt>
    Storage<MyInt> structStorage = default;
    MyInt mi = default;
    mi.x = 99;
    structStorage.Set(mi);
    result &= Test("generic_interface_mystruct_get", structStorage.Get().x, 99);

    // Test another Storage<int> with different value
    Storage<int> anotherIntStorage = default;
    anotherIntStorage.Set(100);
    result &= Test("generic_interface_int_get_100", anotherIntStorage.Get(), 100);

    return result;
}

// =============================================================
// Returning list<T>* from functions
// =============================================================

list<int>* makeIntList()
{
    list<int>* l = new list<int>;
    l->add(10);
    l->add(20);
    l->add(30);
    return l;
}

class ListFactory
{
    list<int>* create()
    {
        list<int>* l = new list<int>;
        l->add(1);
        l->add(2);
        return l;
    }
};

bool testReturnListFreeFunc()
{
    bool result = true;
    list<int>* l = makeIntList();
    result &= Test("return_list_count",  l->count(), 3);
    result &= Test("return_list_get_0",  l->get(0),  10);
    result &= Test("return_list_get_1",  l->get(1),  20);
    result &= Test("return_list_get_2",  l->get(2),  30);
    delete l;
    return result;
}

bool testReturnListMethod()
{
    bool result = true;
    ListFactory f;
    list<int>* l = f.create();
    result &= Test("return_list_method_count", l->count(), 2);
    result &= Test("return_list_method_get_0", l->get(0),  1);
    result &= Test("return_list_method_get_1", l->get(1),  2);
    delete l;
    return result;
}

// =============================================================
// Nested generic struct default initialization
// =============================================================

struct NestedBox<T>
{
    Box<T> inner = default;
};

bool testNestedGenericDefault()
{
    bool result = true;
    NestedBox<int> nb = default;
    nb.inner.value = 77;
    result &= Test("nested_generic_default", nb.inner.value, 77);
    NestedBox<i32> nb2 = default;
    nb2.inner.value = 55;
    result &= Test("nested_generic_default_i32", nb2.inner.value, 55);
    return result;
}

// =============================================================
// Generic local variable with = default (via method)
// =============================================================

struct LocalDefaultBox<T>
{
    T stored = default;

    // Uses a local variable of generic type T initialized to default
    T GetWithLocal()
    {
        T local = default;
        local = stored;
        return local;
    }
};

bool testGenericLocalDefault()
{
    bool result = true;

    LocalDefaultBox<int> b = default;
    b.stored = 99;
    result &= Test("generic_local_default_int", b.GetWithLocal(), 99);

    LocalDefaultBox<i32> b2 = default;
    b2.stored = 77;
    result &= Test("generic_local_default_i32", b2.GetWithLocal(), 77);

    return result;
}

// =============================================================
// Overloaded constructors
// =============================================================

struct Point
{
    int x = 0;
    int y = 0;

    Point(int px, int py)
    {
        this->x = px;
        this->y = py;
    }
};

struct Rect
{
    int left = 0;
    int top = 0;
    int width = 10;
    int height = 10;

    Rect(int l, int t, int w, int h)
    {
        this->left   = l;
        this->top    = t;
        this->width  = w;
        this->height = h;
    }

    Rect(int w, int h)
    {
        this->width  = w;
        this->height = h;
    }
};

bool testOverloadedConstructors()
{
    bool result = true;

    Point p = Point(3, 4);
    result &= Test("ctor_point_x", p.x, 3);
    result &= Test("ctor_point_y", p.y, 4);

    Point q = Point();
    result &= Test("ctor_point_default_x", q.x, 0);
    result &= Test("ctor_point_default_y", q.y, 0);

    Rect r = Rect(5, 10, 200, 100);
    result &= Test("ctor_rect_left",   r.left,   5);
    result &= Test("ctor_rect_top",    r.top,    10);
    result &= Test("ctor_rect_width",  r.width,  200);
    result &= Test("ctor_rect_height", r.height, 100);

    Rect r2 = Rect(320, 240);
    result &= Test("ctor_rect2_left",   r2.left,   0);
    result &= Test("ctor_rect2_top",    r2.top,    0);
    result &= Test("ctor_rect2_width",  r2.width,  320);
    result &= Test("ctor_rect2_height", r2.height, 240);

    return result;
}

// =============================================================
// Constructor default arguments
// =============================================================

struct Vec3
{
    int x = 0;
    int y = 0;
    int z = 0;

    Vec3(int px, int py = 0, int pz = 0)
    {
        this->x = px;
        this->y = py;
        this->z = pz;
    }
};

bool testConstructorDefaultArgs()
{
    bool result = true;

    // All args explicit
    Vec3 a = Vec3(1, 2, 3);
    result &= Test("ctor_default_args_all_x", a.x, 1);
    result &= Test("ctor_default_args_all_y", a.y, 2);
    result &= Test("ctor_default_args_all_z", a.z, 3);

    // One default (pz = 0)
    Vec3 b = Vec3(4, 5);
    result &= Test("ctor_default_args_two_x", b.x, 4);
    result &= Test("ctor_default_args_two_y", b.y, 5);
    result &= Test("ctor_default_args_two_z", b.z, 0);

    // Two defaults (py = 0, pz = 0)
    Vec3 c = Vec3(7);
    result &= Test("ctor_default_args_one_x", c.x, 7);
    result &= Test("ctor_default_args_one_y", c.y, 0);
    result &= Test("ctor_default_args_one_z", c.z, 0);

    return result;
}

// =============================================================
// Collections with struct and class types
// =============================================================

struct Person
{
    int age = 0;
    int id = 0;
};

bool testListStruct()
{
    bool result = true;

    list<Person> people;

    Person p1 = default;
    p1.age = 25;
    p1.id = 101;

    Person p2 = default;
    p2.age = 30;
    p2.id = 102;

    Person p3 = default;
    p3.age = 35;
    p3.id = 103;

    people.add(p1);
    people.add(p2);
    people.add(p3);

    result &= Test("list<struct> count", people.count(), 3);
    result &= Test("list<struct> get[0].age", people.get(0).age, 25);
    result &= Test("list<struct> get[0].id",  people.get(0).id,  101);
    result &= Test("list<struct> get[1].age", people.get(1).age, 30);
    result &= Test("list<struct> get[2].id",  people.get(2).id,  103);

    // operator[]
    result &= Test("list<struct> op[] get", people[1].age, 30);

    // set
    Person p4 = default;
    p4.age = 40;
    p4.id = 104;
    people.set(1, p4);
    result &= Test("list<struct> after set", people.get(1).age, 40);

    // removeAt
    people.removeAt(1);
    result &= Test("list<struct> count after remove", people.count(), 2);
    result &= Test("list<struct> after remove[1]", people.get(1).id, 103);

    // clear
    people.clear();
    result &= Test("list<struct> after clear", people.count(), 0);

    return result;
}


bool testDictionaryStruct()
{
    bool result = true;

    dictionary<int, Person> personMap;

    Person p1 = default;
    p1.age = 25;
    p1.id = 101;

    Person p2 = default;
    p2.age = 30;
    p2.id = 102;

    Person p3 = default;
    p3.age = 35;
    p3.id = 103;

    // Add entries
    result &= Test("dict<int,struct> add 1", personMap.add(1, p1), true);
    result &= Test("dict<int,struct> add 2", personMap.add(2, p2), true);
    result &= Test("dict<int,struct> add 3", personMap.add(3, p3), true);

    result &= Test("dict<int,struct> count", personMap.count(), 3);

    // Get and check fields
    result &= Test("dict<int,struct> get 1 age",  personMap.get(1).age, 25);
    result &= Test("dict<int,struct> get 1 id",   personMap.get(1).id,  101);
    result &= Test("dict<int,struct> get 2 age",  personMap.get(2).age, 30);
    result &= Test("dict<int,struct> op[] get",   personMap[3].id,      103);

    // set
    Person p4 = default;
    p4.age = 40;
    p4.id = 104;
    personMap.set(2, p4);
    result &= Test("dict<int,struct> after set", personMap.get(2).age, 40);

    // remove
    result &= Test("dict<int,struct> remove", personMap.remove(2), true);
    result &= Test("dict<int,struct> count after remove", personMap.count(), 2);
    result &= Test("dict<int,struct> get after remove", personMap.get(3).age, 35);

    return result;
}


bool testForeachStruct()
{
    bool result = true;

    list<Person> people;

    Person p1 = default;
    p1.age = 20;

    Person p2 = default;
    p2.age = 30;

    Person p3 = default;
    p3.age = 40;

    people.add(p1);
    people.add(p2);
    people.add(p3);

    int sumAge = 0;
    foreach (Person p in people)
        sumAge += p.age;

    result &= Test("foreach struct sum", sumAge, 90);

    return result;
}

// =============================================================
// Pointer types inside generic parameters (list<Employee*>)
// =============================================================

struct Employee
{
    int id = 0;
    int salary = 0;
};

bool testListPointer()
{
    bool result = true;

    list<Employee*> employees;

    Employee* e1 = new Employee;
    e1->id = 1;
    e1->salary = 50000;

    Employee* e2 = new Employee;
    e2->id = 2;
    e2->salary = 60000;

    Employee* e3 = new Employee;
    e3->id = 3;
    e3->salary = 70000;

    employees.add(e1);
    employees.add(e2);
    employees.add(e3);

    result &= Test("list<ptr> count",        employees.count(),          3);
    result &= Test("list<ptr> get[0].id",    employees.get(0)->id,       1);
    result &= Test("list<ptr> get[0].salary",employees.get(0)->salary,   50000);
    result &= Test("list<ptr> get[1].id",    employees.get(1)->id,       2);
    result &= Test("list<ptr> get[2].salary",employees.get(2)->salary,   70000);

    // operator[]
    result &= Test("list<ptr> op[]",         employees[1]->id,           2);

    // removeAt (caller must free)
    Employee* removed = employees.get(1);
    employees.removeAt(1);
    delete removed;
    result &= Test("list<ptr> count after remove", employees.count(),    2);
    result &= Test("list<ptr> after remove[1].id", employees.get(1)->id, 3);

    // cleanup
    delete employees.get(0);
    delete employees.get(1);

    return result;
}

extern int main()
{
    bool result = true;
    result &= testGenericStructs();
    result &= testInterface();
    result &= testGenericInterface();
    result &= testReturnListFreeFunc();
    result &= testReturnListMethod();
    result &= testNestedGenericDefault();
    result &= testGenericLocalDefault();
    result &= testOverloadedConstructors();
    result &= testConstructorDefaultArgs();
    result &= testListStruct();
    result &= testDictionaryStruct();
    result &= testForeachStruct();
    result &= testListPointer();
    if (result)
    {
        printf("All Test Passed.\n");
        return 0;
    }

    return 1;
}
