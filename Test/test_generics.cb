import "test_helper.cb";
import "list.cb";
import "dictionary.cb";
import "tuple.cb";

// =============================================================
// Generic struct tests (compile-time only monomorphization)
// =============================================================

struct Box<T>
{
    T value = default;
};

struct Pair<K, V>
{
    K first = default;
    V second = default;
};

struct Container<T>
{
    T data = default;
    int count = 0;
};

struct Stack<T>
{
    T elements = default;
    int size = 0;
};

bool testGenericBox()
{
    bool result = true;

    // Test Box<int>
    Box<int> intBox = default;
    intBox.value = 42;
    result &= Test("generic_box_int", intBox.value, 42);

    // Test Box<float> - compare as int representation
    Box<float> floatBox = default;
    floatBox.value = 3.14f;
    // Note: floating point comparison would need special handling

    // Test Box<i32>
    Box<i32> i32Box = default;
    i32Box.value = 100;
    result &= Test("generic_box_i32", i32Box.value, 100);

    return result;
}

bool testGenericPair()
{
    bool result = true;

    // Test Pair<int, int>
    Pair<int, int> intIntPair = default;
    intIntPair.first = 10;
    intIntPair.second = 20;
    result &= Test("generic_pair_int_int_first", intIntPair.first, 10);
    result &= Test("generic_pair_int_int_second", intIntPair.second, 20);

    // Test Pair<int, float>
    Pair<int, float> intFloatPair = default;
    intFloatPair.first = 5;
    intFloatPair.second = 2.5f;
    result &= Test("generic_pair_int_float_first", intFloatPair.first, 5);

    // Test Pair<i32, i32>
    Pair<i32, i32> i32Pair = default;
    i32Pair.first = 1000;
    i32Pair.second = 2000;
    result &= Test("generic_pair_i32_first", i32Pair.first, 1000);
    result &= Test("generic_pair_i32_second", i32Pair.second, 2000);

    return result;
}

bool testGenericMultipleInstantiations()
{
    bool result = true;

    // Multiple instantiations of Box with different types
    Box<int> boxInt = default;
    Box<i32> boxI32 = default;
    Box<u32> boxU32 = default;
    Box<i8> boxI8 = default;

    boxInt.value = 42;
    boxI32.value = 100;
    boxU32.value = 200;
    boxI8.value = 10;

    result &= Test("generic_multi_int", boxInt.value, 42);
    result &= Test("generic_multi_i32", boxI32.value, 100);
    result &= Test("generic_multi_u32", boxU32.value, 200);
    result &= Test("generic_multi_i8", boxI8.value, 10);

    return result;
}

bool testGenericContainer()
{
    bool result = true;

    // Test Container<int>
    Container<int> intContainer = default;
    intContainer.data = 99;
    intContainer.count = 1;
    result &= Test("generic_container_int_data", intContainer.data, 99);
    result &= Test("generic_container_int_count", intContainer.count, 1);

    // Test Container<i64>
    Container<i64> i64Container = default;
    i64Container.data = 200000;
    i64Container.count = 5;
    result &= Test("generic_container_i64_data", i64Container.data, 200000);
    result &= Test("generic_container_i64_count", i64Container.count, 5);

    return result;
}

bool testGenericStack()
{
    bool result = true;

    // Test Stack<int>
    Stack<int> intStack = default;
    intStack.elements = 42;
    intStack.size = 1;
    result &= Test("generic_stack_int_elements", intStack.elements, 42);
    result &= Test("generic_stack_int_size", intStack.size, 1);

    // Test Stack<i32>
    Stack<i32> i32Stack = default;
    i32Stack.elements = 999;
    i32Stack.size = 10;
    result &= Test("generic_stack_i32_elements", i32Stack.elements, 999);
    result &= Test("generic_stack_i32_size", i32Stack.size, 10);

    return result;
}

int testGenericStructs()
{
    bool result = true;
    result &= testGenericBox();
    result &= testGenericPair();
    result &= testGenericMultipleInstantiations();
    result &= testGenericContainer();
    result &= testGenericStack();
    return result;
}

// Interface tests

interface IReadable
{
    int Read();
};

interface IScalable
{
    int Scale(int factor);
};

class Counter : IReadable
{
    int count = 10;
    int Read() { return count; }
};

class ScaledValue : IReadable, IScalable
{
    int value = 3;
    int Read() { return value; }
    int Scale(int factor) { return value * factor; }
};

int extensionIRead(IReadable scaledValue)
{
    return scaledValue.Read();
}

bool testInterface()
{
    bool result = true;
    Counter c = Counter();
    ScaledValue s = ScaledValue();

    result &= Test("counter.Read", c.Read(), 10);   // 10
    result &= Test("scaledValue.Read", s.Read(), 3);   // 3
    result &= Test("scaledValue.Read", s.extensionIRead(), 3);   // 3
    result &= Test("scaledValue.Scale2", s.Scale(2), 6);   // 3*2=6
    result &= Test("scaledValue.Scale5", s.Scale(5), 15);   // 3*5=15
    return result;
}


// Generic interface for storing and retrieving a value
interface Container<T>
{
    T Get();
    void Set(T value);
};

struct MyInt
{
    int x = 5;
};

// Generic struct template with type parameter T implementing Container<T>
class Storage<T> : Container<T>
{
    T data = default;

    T Get()
    {
        return data;
    }

    void Set(T value)
    {
        data = value;
    }
};

T ExtGet<T>(Container<T> container)
{
    T value = container.Get();
    return value;
}

bool testGenericInterface()
{
    bool result = true;

    // Test Storage<int> implementing Container<int>
    Storage<int> intStorage = default;
    intStorage.Set(42);
    result &= Test("generic_interface_int_get", intStorage.Get(), 42);
    result &= Test("generic_interface_int_getExt", intStorage.ExtGet(), 42);

    // Test Storage<MyInt> implementing Container<MyInt>
    Storage<MyInt> structStorage = default;
    MyInt mi = default;
    mi.x = 99;
    structStorage.Set(mi);
    result &= Test("generic_interface_mystruct_get", structStorage.Get().x, 99);

    // Test another Storage<int> with different value
    Storage<int> anotherIntStorage = default;
    anotherIntStorage.Set(100);
    result &= Test("generic_interface_int_get_100", anotherIntStorage.Get(), 100);

    return result;
}

// =============================================================
// Returning list<T>* from functions
// =============================================================

list<int>* makeIntList()
{
    list<int>* l = new list<int>;
    l->add(10);
    l->add(20);
    l->add(30);
    return l;
}

class ListFactory
{
    list<int>* create()
    {
        list<int>* l = new list<int>;
        l->add(1);
        l->add(2);
        return l;
    }
};

bool testReturnListFreeFunc()
{
    bool result = true;
    list<int>* l = makeIntList();
    result &= Test("return_list_count",  l->count(), 3);
    result &= Test("return_list_get_0",  l->get(0),  10);
    result &= Test("return_list_get_1",  l->get(1),  20);
    result &= Test("return_list_get_2",  l->get(2),  30);
    delete l;
    return result;
}

bool testReturnListMethod()
{
    bool result = true;
    ListFactory f;
    list<int>* l = f.create();
    result &= Test("return_list_method_count", l->count(), 2);
    result &= Test("return_list_method_get_0", l->get(0),  1);
    result &= Test("return_list_method_get_1", l->get(1),  2);
    delete l;
    return result;
}

// =============================================================
// Nested generic struct default initialization
// =============================================================

struct NestedBox<T>
{
    Box<T> inner = default;
};

bool testNestedGenericDefault()
{
    bool result = true;
    NestedBox<int> nb = default;
    nb.inner.value = 77;
    result &= Test("nested_generic_default", nb.inner.value, 77);
    NestedBox<i32> nb2 = default;
    nb2.inner.value = 55;
    result &= Test("nested_generic_default_i32", nb2.inner.value, 55);
    return result;
}

// =============================================================
// Generic local variable with = default (via method)
// =============================================================

struct LocalDefaultBox<T>
{
    T stored = default;

    // Uses a local variable of generic type T initialized to default
    T GetWithLocal()
    {
        T local = default;
        local = stored;
        return local;
    }
};

bool testGenericLocalDefault()
{
    bool result = true;

    LocalDefaultBox<int> b = default;
    b.stored = 99;
    result &= Test("generic_local_default_int", b.GetWithLocal(), 99);

    LocalDefaultBox<i32> b2 = default;
    b2.stored = 77;
    result &= Test("generic_local_default_i32", b2.GetWithLocal(), 77);

    return result;
}

// =============================================================
// Overloaded constructors
// =============================================================

struct Point
{
    int x = 0;
    int y = 0;

    Point(int px, int py)
    {
        this->x = px;
        this->y = py;
    }
};

struct Rect
{
    int left = 0;
    int top = 0;
    int width = 10;
    int height = 10;

    Rect(int l, int t, int w, int h)
    {
        this->left   = l;
        this->top    = t;
        this->width  = w;
        this->height = h;
    }

    Rect(int w, int h)
    {
        this->width  = w;
        this->height = h;
    }
};

bool testOverloadedConstructors()
{
    bool result = true;

    Point p = Point(3, 4);
    result &= Test("ctor_point_x", p.x, 3);
    result &= Test("ctor_point_y", p.y, 4);

    Point q = Point();
    result &= Test("ctor_point_default_x", q.x, 0);
    result &= Test("ctor_point_default_y", q.y, 0);

    Rect r = Rect(5, 10, 200, 100);
    result &= Test("ctor_rect_left",   r.left,   5);
    result &= Test("ctor_rect_top",    r.top,    10);
    result &= Test("ctor_rect_width",  r.width,  200);
    result &= Test("ctor_rect_height", r.height, 100);

    Rect r2 = Rect(320, 240);
    result &= Test("ctor_rect2_left",   r2.left,   0);
    result &= Test("ctor_rect2_top",    r2.top,    0);
    result &= Test("ctor_rect2_width",  r2.width,  320);
    result &= Test("ctor_rect2_height", r2.height, 240);

    return result;
}

// =============================================================
// Constructor default arguments
// =============================================================

struct Vec3
{
    int x = 0;
    int y = 0;
    int z = 0;

    Vec3(int px, int py = 0, int pz = 0)
    {
        this->x = px;
        this->y = py;
        this->z = pz;
    }
};

bool testConstructorDefaultArgs()
{
    bool result = true;

    // All args explicit
    Vec3 a = Vec3(1, 2, 3);
    result &= Test("ctor_default_args_all_x", a.x, 1);
    result &= Test("ctor_default_args_all_y", a.y, 2);
    result &= Test("ctor_default_args_all_z", a.z, 3);

    // One default (pz = 0)
    Vec3 b = Vec3(4, 5);
    result &= Test("ctor_default_args_two_x", b.x, 4);
    result &= Test("ctor_default_args_two_y", b.y, 5);
    result &= Test("ctor_default_args_two_z", b.z, 0);

    // Two defaults (py = 0, pz = 0)
    Vec3 c = Vec3(7);
    result &= Test("ctor_default_args_one_x", c.x, 7);
    result &= Test("ctor_default_args_one_y", c.y, 0);
    result &= Test("ctor_default_args_one_z", c.z, 0);

    return result;
}

// =============================================================
// Collections with struct and class types
// =============================================================

struct Person
{
    int age = 0;
    int id = 0;
};

bool testListStruct()
{
    bool result = true;

    list<Person> people;

    Person p1 = default;
    p1.age = 25;
    p1.id = 101;

    Person p2 = default;
    p2.age = 30;
    p2.id = 102;

    Person p3 = default;
    p3.age = 35;
    p3.id = 103;

    people.add(p1);
    people.add(p2);
    people.add(p3);

    result &= Test("list<struct> count", people.count(), 3);
    result &= Test("list<struct> get[0].age", people.get(0).age, 25);
    result &= Test("list<struct> get[0].id",  people.get(0).id,  101);
    result &= Test("list<struct> get[1].age", people.get(1).age, 30);
    result &= Test("list<struct> get[2].id",  people.get(2).id,  103);

    // operator[]
    result &= Test("list<struct> op[] get", people[1].age, 30);

    // set
    Person p4 = default;
    p4.age = 40;
    p4.id = 104;
    people.set(1, p4);
    result &= Test("list<struct> after set", people.get(1).age, 40);

    // removeAt
    people.removeAt(1);
    result &= Test("list<struct> count after remove", people.count(), 2);
    result &= Test("list<struct> after remove[1]", people.get(1).id, 103);

    // clear
    people.clear();
    result &= Test("list<struct> after clear", people.count(), 0);

    return result;
}


bool testDictionaryStruct()
{
    bool result = true;

    dictionary<int, Person> personMap;

    Person p1 = default;
    p1.age = 25;
    p1.id = 101;

    Person p2 = default;
    p2.age = 30;
    p2.id = 102;

    Person p3 = default;
    p3.age = 35;
    p3.id = 103;

    // Add entries
    result &= Test("dict<int,struct> add 1", personMap.add(1, p1), true);
    result &= Test("dict<int,struct> add 2", personMap.add(2, p2), true);
    result &= Test("dict<int,struct> add 3", personMap.add(3, p3), true);

    result &= Test("dict<int,struct> count", personMap.count(), 3);

    // Get and check fields
    result &= Test("dict<int,struct> get 1 age",  personMap.get(1).age, 25);
    result &= Test("dict<int,struct> get 1 id",   personMap.get(1).id,  101);
    result &= Test("dict<int,struct> get 2 age",  personMap.get(2).age, 30);
    result &= Test("dict<int,struct> op[] get",   personMap[3].id,      103);

    // set
    Person p4 = default;
    p4.age = 40;
    p4.id = 104;
    personMap.set(2, p4);
    result &= Test("dict<int,struct> after set", personMap.get(2).age, 40);

    // remove
    result &= Test("dict<int,struct> remove", personMap.remove(2), true);
    result &= Test("dict<int,struct> count after remove", personMap.count(), 2);
    result &= Test("dict<int,struct> get after remove", personMap.get(3).age, 35);

    return result;
}


bool testForStruct()
{
    bool result = true;

    list<Person> people;

    Person p1 = default;
    p1.age = 20;

    Person p2 = default;
    p2.age = 30;

    Person p3 = default;
    p3.age = 40;

    people.add(p1);
    people.add(p2);
    people.add(p3);

    int sumAge = 0;
    for (Person p in people)
        sumAge += p.age;

    result &= Test("for struct sum", sumAge, 90);

    return result;
}

// =============================================================
// Pointer types inside generic parameters (list<Employee*>)
// =============================================================

int empDtorCount = 0;

struct Employee
{
    int id = 0;
    int salary = 0;
    ~Employee() { empDtorCount = empDtorCount + 1; }
};

bool testListPointer()
{
    bool result = true;

    {
        list<Employee*> employees;

        Employee* e1 = new Employee;
        e1->id = 1;
        e1->salary = 50000;

        Employee* e2 = new Employee;
        e2->id = 2;
        e2->salary = 60000;

        Employee* e3 = new Employee;
        e3->id = 3;
        e3->salary = 70000;

        employees.add(e1);
        employees.add(e2);
        employees.add(e3);

        result &= Test("list<ptr> count",        employees.count(),          3);
        result &= Test("list<ptr> get[0].id",    employees.get(0)->id,       1);
        result &= Test("list<ptr> get[0].salary",employees.get(0)->salary,   50000);
        result &= Test("list<ptr> get[1].id",    employees.get(1)->id,       2);
        result &= Test("list<ptr> get[2].salary",employees.get(2)->salary,   70000);

        // operator[]
        result &= Test("list<ptr> op[]",         employees[1]->id,           2);

        // removeAt auto-frees the element (destructor called + memory released)
        empDtorCount = 0;
        employees.removeAt(1);
        result &= Test("list<ptr> removeAt dtor fired",    empDtorCount,              1);
        result &= Test("list<ptr> count after remove",     employees.count(),         2);
        result &= Test("list<ptr> after remove[1].id",     employees.get(1)->id,      3);
        // employees destructor frees remaining elements (e1, e3) here
    }
    // ~list() freed the 2 remaining elements; total dtor fires = 1 (removeAt) + 2 (dtor) = 3
    result &= Test("list<ptr> cleanup dtor count",     empDtorCount,              3);

    return result;
}

bool testListPointerClear()
{
    bool result = true;

    empDtorCount = 0;
    {
        list<Employee*> employees;
        Employee* e1 = new Employee; e1->id = 1;
        Employee* e2 = new Employee; e2->id = 2;
        Employee* e3 = new Employee; e3->id = 3;
        employees.add(e1);
        employees.add(e2);
        employees.add(e3);

        // clear() must free all 3 elements
        employees.clear();
        result &= Test("list<ptr> clear count",      employees.count(), 0);
        result &= Test("list<ptr> clear dtor fires", empDtorCount,      3);

        // add after clear - destructor must not double-free
        Employee* e4 = new Employee; e4->id = 4;
        employees.add(e4);
        result &= Test("list<ptr> add after clear count", employees.count(), 1);
        result &= Test("list<ptr> add after clear id",    employees.get(0)->id, 4);
        // ~list() frees e4 here
    }
    result &= Test("list<ptr> dtor after clear", empDtorCount, 4);

    return result;
}

bool testHashsetPointer()
{
    bool result = true;

    hashset<Employee*> s;
    Employee* e1 = new Employee; e1->id = 10;
    Employee* e2 = new Employee; e2->id = 20;
    Employee* e3 = new Employee; e3->id = 30;

    s.add(e1);
    s.add(e2);
    s.add(e3);
    result &= Test("hashset<ptr> count",          s.count(),      3);
    result &= Test("hashset<ptr> contains e1",    s.contains(e1), true);
    result &= Test("hashset<ptr> contains e2",    s.contains(e2), true);
    result &= Test("hashset<ptr> dup add",        s.add(e1),      false);

    s.remove(e2);
    delete e2;
    result &= Test("hashset<ptr> count after remove", s.count(),      2);
    result &= Test("hashset<ptr> contains after remove", s.contains(e2), false);

    s.clear();
    result &= Test("hashset<ptr> count after clear", s.count(), 0);

    // caller owns e1 and e3 - delete them manually
    delete e1;
    delete e3;

    Employee* e4 = new Employee; e4->id = 40;
    s.add(e4);
    result &= Test("hashset<ptr> add after clear", s.count(), 1);
    delete e4;

    return result;
}

bool testDictionaryPointer()
{
    bool result = true;

    empDtorCount = 0;
    {
        dictionary<int, Employee*> d;
        Employee* e1 = new Employee; e1->id = 1; e1->salary = 100;
        Employee* e2 = new Employee; e2->id = 2; e2->salary = 200;
        Employee* e3 = new Employee; e3->id = 3; e3->salary = 300;
        d.add(1, e1);
        d.add(2, e2);
        d.add(3, e3);
        result &= Test("dict<ptr> count",    d.count(), 3);
        result &= Test("dict<ptr> get id",   d.get(1)->id, 1);

        // remove() must free the value
        d.remove(2);
        result &= Test("dict<ptr> remove dtor",        empDtorCount, 1);
        result &= Test("dict<ptr> count after remove", d.count(),    2);

        // set() on existing key must free old value before storing new
        Employee* e2b = new Employee; e2b->id = 99; e2b->salary = 999;
        d.add(2, e2b);
        Employee* e2c = new Employee; e2c->id = 77;
        d.set(2, e2c);
        result &= Test("dict<ptr> set overwrites and frees", empDtorCount, 2);
        result &= Test("dict<ptr> get after set",            d.get(2)->id, 77);

        // clear() must free remaining elements (e1, e2c, e3)
        d.clear();
        result &= Test("dict<ptr> clear dtor",  empDtorCount, 5);
        result &= Test("dict<ptr> clear count", d.count(),    0);

        // add after clear - destructor must not double-free
        Employee* e4 = new Employee; e4->id = 4;
        d.add(4, e4);
        result &= Test("dict<ptr> add after clear count", d.count(), 1);
        // ~dictionary() frees e4 here
    }
    result &= Test("dict<ptr> dtor after clear", empDtorCount, 6);

    return result;
}

// =============================================================
// Nested generic structures (generic fields with generic types)
// =============================================================

struct DoubleNested<T>
{
    Box<Box<T>> innerBox = default;
};

struct TripleNested<T>
{
    Box<Box<Box<T>>> tripleBox = default;
};

struct PairOfBoxes<K, V>
{
    Box<K> left = default;
    Box<V> right = default;
};

struct ContainerOfPairs<A, B>
{
    Pair<A, B> data = default;
    int dataCount = 0;
};

bool testDoubleNestedGeneric()
{
    bool result = true;

    // Test DoubleNested<int>
    DoubleNested<int> dn = default;
    dn.innerBox.value.value = 123;
    result &= Test("double_nested_int", dn.innerBox.value.value, 123);

    // Test DoubleNested<i32>
    DoubleNested<i32> dn2 = default;
    dn2.innerBox.value.value = 456;
    result &= Test("double_nested_i32", dn2.innerBox.value.value, 456);

    return result;
}

bool testTripleNestedGeneric()
{
    bool result = true;

    // Test TripleNested<int>
    TripleNested<int> tn = default;
    tn.tripleBox.value.value.value = 789;
    result &= Test("triple_nested_int", tn.tripleBox.value.value.value, 789);

    // Test TripleNested<i32>
    TripleNested<i32> tn2 = default;
    tn2.tripleBox.value.value.value = 999;
    result &= Test("triple_nested_i32", tn2.tripleBox.value.value.value, 999);

    return result;
}

bool testPairOfBoxes()
{
    bool result = true;

    // Test PairOfBoxes<int, int>
    PairOfBoxes<int, int> pob = default;
    pob.left.value = 10;
    pob.right.value = 20;
    result &= Test("pair_of_boxes_int_int_left", pob.left.value, 10);
    result &= Test("pair_of_boxes_int_int_right", pob.right.value, 20);

    // Test PairOfBoxes<i32, i64>
    PairOfBoxes<i32, i64> pob2 = default;
    pob2.left.value = 100;
    pob2.right.value = 1000;
    result &= Test("pair_of_boxes_i32_i64_left", pob2.left.value, 100);
    result &= Test("pair_of_boxes_i32_i64_right", pob2.right.value, 1000);

    // Test PairOfBoxes<u32, u16>
    PairOfBoxes<u32, u16> pob3 = default;
    pob3.left.value = 50000;
    pob3.right.value = 5000;
    result &= Test("pair_of_boxes_u32_u16_left", pob3.left.value, 50000);
    result &= Test("pair_of_boxes_u32_u16_right", pob3.right.value, 5000);

    return result;
}

bool testContainerOfPairs()
{
    bool result = true;

    // Test ContainerOfPairs<int, int>
    ContainerOfPairs<int, int> cop = default;
    cop.data.first = 5;
    cop.data.second = 10;
    cop.dataCount = 1;
    result &= Test("container_of_pairs_int_int_first", cop.data.first, 5);
    result &= Test("container_of_pairs_int_int_second", cop.data.second, 10);
    result &= Test("container_of_pairs_int_int_count", cop.dataCount, 1);

    // Test ContainerOfPairs<i32, i64>
    ContainerOfPairs<i32, i64> cop2 = default;
    cop2.data.first = 777;
    cop2.data.second = 888;
    cop2.dataCount = 2;
    result &= Test("container_of_pairs_i32_i64_first", cop2.data.first, 777);
    result &= Test("container_of_pairs_i32_i64_second", cop2.data.second, 888);
    result &= Test("container_of_pairs_i32_i64_count", cop2.dataCount, 2);

    return result;
}

// Generic struct with generic method returning nested generic
struct GenericWrapper<T>
{
    Box<T> wrapped = default;

    Box<T> GetWrapped()
    {
        return wrapped;
    }

    T GetValue()
    {
        return wrapped.value;
    }
};

bool testGenericWrapperMethods()
{
    bool result = true;

    // Test GenericWrapper<int> GetValue
    GenericWrapper<int> gw = default;
    gw.wrapped.value = 42;
    result &= Test("generic_wrapper_int_get_value", gw.GetValue(), 42);

    // Test GenericWrapper<i32> GetValue
    GenericWrapper<i32> gw2 = default;
    gw2.wrapped.value = 100;
    result &= Test("generic_wrapper_i32_get_value", gw2.GetValue(), 100);

    // Test GenericWrapper<int> GetWrapped
    Box<int> b = gw.GetWrapped();
    result &= Test("generic_wrapper_int_get_wrapped", b.value, 42);

    return result;
}

// Multiple levels of generic composition
struct Layer1<T>
{
    T data = default;
};

struct Layer2<T>
{
    Layer1<T> inner = default;
};

struct Layer3<T>
{
    Layer2<T> inner = default;
};

bool testMultiLayerGeneric()
{
    bool result = true;

    // Test Layer3<int>
    Layer3<int> l3 = default;
    l3.inner.inner.data = 111;
    result &= Test("multi_layer_int", l3.inner.inner.data, 111);

    // Test Layer3<i32>
    Layer3<i32> l3_i32 = default;
    l3_i32.inner.inner.data = 222;
    result &= Test("multi_layer_i32", l3_i32.inner.inner.data, 222);

    return result;
}

// Generic struct with mixed generic and non-generic fields
struct MixedGeneric<T>
{
    Box<T> genericBox = default;
    int regularInt = 0;
    T genericValue = default;
    i64 regularLong = 0;
};

bool testMixedGenericFields()
{
    bool result = true;

    // Test MixedGeneric<int>
    MixedGeneric<int> mg = default;
    mg.genericBox.value = 50;
    mg.regularInt = 100;
    mg.genericValue = 25;
    mg.regularLong = 9999;
    result &= Test("mixed_generic_int_box", mg.genericBox.value, 50);
    result &= Test("mixed_generic_int_regular", mg.regularInt, 100);
    result &= Test("mixed_generic_int_value", mg.genericValue, 25);
    result &= Test("mixed_generic_int_long", mg.regularLong, 9999);

    // Test MixedGeneric<i32>
    MixedGeneric<i32> mg2 = default;
    mg2.genericBox.value = 200;
    mg2.regularInt = 300;
    mg2.genericValue = 400;
    mg2.regularLong = 5555;
    result &= Test("mixed_generic_i32_box", mg2.genericBox.value, 200);
    result &= Test("mixed_generic_i32_regular", mg2.regularInt, 300);
    result &= Test("mixed_generic_i32_value", mg2.genericValue, 400);
    result &= Test("mixed_generic_i32_long", mg2.regularLong, 5555);

    return result;
}

// =============================================================
// Sort with lambda tests
// =============================================================

interface IPriority {
    int priority();
};

class RankedEmployee {
    int id   = 0;
    int rank = 0;
    int getRank() { return rank; }
};

class PrioItem : IPriority {
    int score = 0;
    int priority() { return score; }
};

bool testSortInt()
{
    bool ok = true;

    list<int> asc;
    asc.add(5); asc.add(2); asc.add(8); asc.add(1); asc.add(9); asc.add(3);
    asc.sort((int a, int b) => { return a < b; });
    ok &= asc.get(0) == 1;
    ok &= asc.get(1) == 2;
    ok &= asc.get(2) == 3;
    ok &= asc.get(3) == 5;
    ok &= asc.get(4) == 8;
    ok &= asc.get(5) == 9;

    list<int> desc;
    desc.add(5); desc.add(2); desc.add(8); desc.add(1); desc.add(9); desc.add(3);
    desc.sort((int a, int b) => { return a > b; });
    ok &= desc.get(0) == 9;
    ok &= desc.get(1) == 8;
    ok &= desc.get(2) == 5;
    ok &= desc.get(3) == 3;
    ok &= desc.get(4) == 2;
    ok &= desc.get(5) == 1;

    if (!ok) printf("FAIL: testSortInt\n");
    return ok;
}

bool testSortFloat()
{
    bool ok = true;

    list<float> nums;
    nums.add(3.5f); nums.add(1.0f); nums.add(4.0f); nums.add(1.5f); nums.add(2.5f);
    nums.sort((float a, float b) => { return a < b; });

    ok &= nums.get(0) == 1.0f;
    ok &= nums.get(1) == 1.5f;
    ok &= nums.get(2) == 2.5f;
    ok &= nums.get(3) == 3.5f;
    ok &= nums.get(4) == 4.0f;

    if (!ok) printf("FAIL: testSortFloat\n");
    return ok;
}

bool testSortStruct()
{
    bool ok = true;

    list<Point> byX;
    Point p1; p1.x = 5; p1.y = 1;
    Point p2; p2.x = 2; p2.y = 4;
    Point p3; p3.x = 8; p3.y = 2;
    Point p4; p4.x = 1; p4.y = 7;
    byX.add(p1); byX.add(p2); byX.add(p3); byX.add(p4);
    byX.sort((Point a, Point b) => { return a.x < b.x; });
    ok &= byX.get(0).x == 1;
    ok &= byX.get(1).x == 2;
    ok &= byX.get(2).x == 5;
    ok &= byX.get(3).x == 8;

    list<Point> byY;
    Point q1; q1.x = 0; q1.y = 3;
    Point q2; q2.x = 0; q2.y = 7;
    Point q3; q3.x = 0; q3.y = 1;
    Point q4; q4.x = 0; q4.y = 5;
    byY.add(q1); byY.add(q2); byY.add(q3); byY.add(q4);
    byY.sort((Point a, Point b) => { return a.y > b.y; });
    ok &= byY.get(0).y == 7;
    ok &= byY.get(1).y == 5;
    ok &= byY.get(2).y == 3;
    ok &= byY.get(3).y == 1;

    if (!ok) printf("FAIL: testSortStruct\n");
    return ok;
}

bool testSortPointer()
{
    bool ok = true;

    list<Point*> pts;
    Point* sp1 = new Point; sp1->x = 30;
    Point* sp2 = new Point; sp2->x = 10;
    Point* sp3 = new Point; sp3->x = 50;
    Point* sp4 = new Point; sp4->x = 20;
    pts.add(sp1); pts.add(sp2); pts.add(sp3); pts.add(sp4);

    pts.sort((Point* a, Point* b) => { return a->x < b->x; });

    ok &= pts.get(0)->x == 10;
    ok &= pts.get(1)->x == 20;
    ok &= pts.get(2)->x == 30;
    ok &= pts.get(3)->x == 50;

    if (!ok) printf("FAIL: testSortPointer\n");
    return ok;
}

bool testSortClass()
{
    bool ok = true;

    list<RankedEmployee> emps;
    RankedEmployee e1; e1.id = 1; e1.rank = 40;
    RankedEmployee e2; e2.id = 2; e2.rank = 10;
    RankedEmployee e3; e3.id = 3; e3.rank = 70;
    RankedEmployee e4; e4.id = 4; e4.rank = 25;
    emps.add(e1); emps.add(e2); emps.add(e3); emps.add(e4);

    emps.sort((RankedEmployee a, RankedEmployee b) => { return a.getRank() < b.getRank(); });

    ok &= emps.get(0).getRank() == 10;
    ok &= emps.get(1).getRank() == 25;
    ok &= emps.get(2).getRank() == 40;
    ok &= emps.get(3).getRank() == 70;

    if (!ok) printf("FAIL: testSortClass\n");
    return ok;
}

bool testSortInterface()
{
    bool ok = true;

    list<PrioItem> items;
    PrioItem si1; si1.score = 30;
    PrioItem si2; si2.score = 10;
    PrioItem si3; si3.score = 50;
    PrioItem si4; si4.score = 20;
    items.add(si1); items.add(si2); items.add(si3); items.add(si4);

    items.sort((PrioItem a, PrioItem b) => {
        IPriority ia = a;
        IPriority ib = b;
        return ia.priority() < ib.priority();
    });

    ok &= items.get(0).score == 10;
    ok &= items.get(1).score == 20;
    ok &= items.get(2).score == 30;
    ok &= items.get(3).score == 50;

    if (!ok) printf("FAIL: testSortInterface\n");
    return ok;
}

bool testSortCapturedKey()
{
    bool ok = true;

    bool flipSort = false;

    list<int> nums;
    nums.add(5); nums.add(2); nums.add(8);

    function<bool(int,int)> cmpAsc = (int a, int b) => {
        if (flipSort) return a > b;
        return a < b;
    };
    nums.sort(cmpAsc);
    ok &= nums.get(0) == 2;
    ok &= nums.get(2) == 8;

    flipSort = true;
    nums.sort(cmpAsc);
    ok &= nums.get(0) == 2;
    ok &= nums.get(2) == 8;

    function<bool(int,int)> cmpDesc = (int a, int b) => {
        if (flipSort) return a > b;
        return a < b;
    };
    nums.sort(cmpDesc);
    ok &= nums.get(0) == 8;
    ok &= nums.get(2) == 2;

    if (!ok) printf("FAIL: testSortCapturedKey\n");
    return ok;
}

bool testSortEdgeCases()
{
    bool ok = true;

    list<int> empty;
    empty.sort((int a, int b) => { return a < b; });
    ok &= empty.count() == 0;

    list<int> one;
    one.add(42);
    one.sort((int a, int b) => { return a < b; });
    ok &= one.get(0) == 42;

    list<int> same;
    same.add(7); same.add(7); same.add(7); same.add(7);
    same.sort((int a, int b) => { return a < b; });
    ok &= same.get(0) == 7;
    ok &= same.get(3) == 7;

    list<int> sorted;
    sorted.add(1); sorted.add(2); sorted.add(3); sorted.add(4);
    sorted.sort((int a, int b) => { return a < b; });
    ok &= sorted.get(0) == 1;
    ok &= sorted.get(3) == 4;

    list<int> rev;
    rev.add(4); rev.add(3); rev.add(2); rev.add(1);
    rev.sort((int a, int b) => { return a < b; });
    ok &= rev.get(0) == 1;
    ok &= rev.get(3) == 4;

    if (!ok) printf("FAIL: testSortEdgeCases\n");
    return ok;
}

// =============================================================
// is_pointer(T) compile-time intrinsic
// =============================================================

struct PointerChecker<T>
{
    int check()
    {
        return is_pointer(T);
    }
};

bool testIsPointerIntrinsic()
{
    bool result = true;
    PointerChecker<int>       ci = default;
    PointerChecker<bool>      cb = default;
    PointerChecker<Employee*> cp = default;
    result &= Test("is_pointer int",       ci.check(), 0);
    result &= Test("is_pointer bool",      cb.check(), 0);
    result &= Test("is_pointer Employee*", cp.check(), 1);
    return result;
}

// --- Templated global function (explicit type args) ---
T ShadowPick<T>(T a, T b) { return a > b ? a : b; }

T PickFirst<T>(T a, T b)
{
    return a;
}

// --- Templated static member function ---
struct MathOps
{
    static T Max<T>(T a, T b)
    {
        if (a > b) return a;
        return b;
    }

    static T Clamp<T>(T val, T lo, T hi)
    {
        if (val < lo) return lo;
        if (val > hi) return hi;
        return val;
    }
};

// --- Template with struct type ---
struct TemplatePoint
{
    int x = 0;
    int y = 0;
};

struct PointOps
{
    static TemplatePoint CombinePoints(TemplatePoint p1, TemplatePoint p2)
    {
        TemplatePoint result = default;
        result.x = p1.x + p2.x;
        result.y = p1.y + p2.y;
        return result;
    }
};

// --- Template with pointer type ---
struct PointerOps
{
    static T* MakeCopy<T>(T* source)
    {
        T* copy = new T;
        *copy = *source;
        return copy;
    }

    static T Dereference<T>(T* ptr)
    {
        return *ptr;
    }
};

// --- Template with interface type ---
interface IComparable
{
    int CompareTo(IComparable other);
};

class IntComparable : IComparable
{
    int value = 0;

    int CompareTo(IComparable other)
    {
        return 0;
    }
};

struct InterfaceOps
{
    static T* WrapInterface<T>(T value)
    {
        T* ptr = new T;
        *ptr = value;
        return ptr;
    }
};

bool testTemplateFunctions()
{
    bool result = true;

    // Test 1: Global generic function with explicit type args - primitives
    result &= Test("global_template_int", PickFirst<int>(7, 3), 7);
    result &= Test("global_template_i64", PickFirst<i64>(10, 20), 10);
    result &= Test("global_template_i32", PickFirst<i32>(99, 1), 99);
    result &= Test("global_template_u32", PickFirst<u32>(50, 25), 50);

    // Test 2: Static member generic function - primitives
    result &= Test("static_template_max_int", MathOps.Max<int>(3, 7), 7);
    result &= Test("static_template_max_neg", MathOps.Max<int>(-5, -1), -1);
    result &= Test("static_template_clamp_lo", MathOps.Clamp<int>(15, 0, 10), 10);
    result &= Test("static_template_clamp_mid", MathOps.Clamp<int>(5, 0, 10), 5);
    result &= Test("static_template_clamp_hi", MathOps.Clamp<i64>(5, 0, 10), 5);

    // Test 3: Static method with struct type
    TemplatePoint p1 = default;
    p1.x = 3;
    p1.y = 4;
    TemplatePoint p2 = default;
    p2.x = 1;
    p2.y = 2;
    TemplatePoint p3 = PointOps.CombinePoints(p1, p2);
    result &= Test("struct_static_combine_x", p3.x, 4);
    result &= Test("struct_static_combine_y", p3.y, 6);

    // Test 4: Generic pointer type parameter
    int* intPtr = new int;
    *intPtr = 42;
    int* intCopy = PointerOps.MakeCopy<int>(intPtr);
    int derefValue = PointerOps.Dereference<int>(intCopy);
    result &= Test("pointer_template_deref_int", derefValue, 42);
    delete intCopy;

    TemplatePoint* pointPtr = new TemplatePoint;
    pointPtr->x = 10;
    pointPtr->y = 20;
    TemplatePoint* pointCopy = PointerOps.MakeCopy<TemplatePoint>(pointPtr);
    int copiedX = PointerOps.Dereference<TemplatePoint>(pointCopy).x;
    int copiedY = PointerOps.Dereference<TemplatePoint>(pointCopy).y;
    result &= Test("pointer_template_copy_struct_x", copiedX, 10);
    result &= Test("pointer_template_copy_struct_y", copiedY, 20);
    delete pointCopy;
    delete pointPtr;

    // Test 5: Generic interface type parameter
    IntComparable ic = default;
    ic.value = 100;
    IntComparable* icPtr = InterfaceOps.WrapInterface<IntComparable>(ic);
    result &= Test("interface_template_wrap", icPtr->value, 100);
    delete icPtr;

    // Regression: when a generic function is instantiated mid-emission of the
    // outer caller, the generic body must not bind parameter names to the
    // outer's locals. Here the outer declares `int a`, which collides with
    // ShadowPick<T>'s parameter `a`. Pre-fix: the generic body's lookup walked
    // past its own frame, loaded from the outer's alloca, and produced
    // "Instruction does not dominate all uses" at LLVM verify time. Uses a
    // fresh generic so the instantiation happens here, mid-emit of this body.
    int a = 5;
    result &= Test("generic_local_shadow_outer_a", a, 5);
    result &= Test("generic_local_shadow_pick",   ShadowPick<int>(3, 7), 7);

    return result;
}

// =============================================================
// Generic type constraint tests (where T : IInterface)
// =============================================================

interface IScorer
{
    int Score();
};

interface ILabeled
{
    int Label();
};

class Player : IScorer
{
    int points = 0;
    int Score() { return points; }
};

class Robot : IScorer
{
    int power = 0;
    int Score() { return power * 2; }
};

class Medal : IScorer, ILabeled
{
    int value = 0;
    int rank  = 0;
    int Score() { return value; }
    int Label() { return rank;  }
};

struct BestOf<T> where T : IScorer
{
    T first  = default;
    T second = default;

    int best()
    {
        int a = first.Score();
        int b = second.Score();
        return a > b ? a : b;
    }
};

struct Duel<T, U> where T : IScorer, U : IScorer
{
    T challenger = default;
    U defender   = default;

    bool challengerWins()
    {
        return challenger.Score() > defender.Score();
    }
};

struct TaggedBest<T> where T : IScorer, T : ILabeled
{
    T first  = default;
    T second = default;

    int bestScore()
    {
        int a = first.Score();
        int b = second.Score();
        return a > b ? a : b;
    }

    int bestLabel()
    {
        int la = first.Label();
        int lb = second.Label();
        return la > lb ? la : lb;
    }
};

class ScoreAccumulator<T> where T : IScorer
{
    T item  = default;
    int bonus = 0;

    int total()
    {
        return item.Score() + bonus;
    }
};

int MaxScore<T>(T* a, T* b) where T : IScorer
{
    int sa = a.Score();
    int sb = b.Score();
    return sa > sb ? sa : sb;
}

int SumScores<T>(T* a, T* b) where T : IScorer
{
    return a.Score() + b.Score();
}

bool testBasicStructConstraint()
{
    bool result = true;
    BestOf<Player> bo;
    bo.first.points  = 10;
    bo.second.points = 20;
    result &= Test("constraint_best_of_20", bo.best(), 20);
    BestOf<Player> bo2;
    bo2.first.points  = 99;
    bo2.second.points = 7;
    result &= Test("constraint_best_of_99", bo2.best(), 99);
    return result;
}

bool testAlternativeConcreteType()
{
    bool result = true;
    BestOf<Robot> br;
    br.first.power  = 5;
    br.second.power = 8;
    result &= Test("constraint_robot_best_16", br.best(), 16);
    BestOf<Robot> br2;
    br2.first.power  = 9;
    br2.second.power = 3;
    result &= Test("constraint_robot_best_18", br2.best(), 18);
    return result;
}

bool testTwoConstrainedParams()
{
    bool result = true;
    Duel<Player, Robot> d;
    d.challenger.points = 25;
    d.defender.power    = 10;
    result &= Test("constraint_duel_challenger_wins", d.challengerWins(), true);
    Duel<Robot, Player> d2;
    d2.challenger.power  = 3;
    d2.defender.points   = 50;
    result &= Test("constraint_duel_defender_wins", d2.challengerWins(), false);
    return result;
}

bool testMultipleConstraintsSameParam()
{
    bool result = true;
    TaggedBest<Medal> tb;
    tb.first.value  = 10;
    tb.first.rank   = 3;
    tb.second.value = 7;
    tb.second.rank  = 5;
    result &= Test("constraint_tagged_best_score", tb.bestScore(), 10);
    result &= Test("constraint_tagged_best_label", tb.bestLabel(), 5);
    return result;
}

bool testConstrainedClass()
{
    bool result = true;
    ScoreAccumulator<Player> sa;
    sa.item.points = 30;
    sa.bonus       = 5;
    result &= Test("constraint_class_player_total", sa.total(), 35);
    ScoreAccumulator<Robot> sar;
    sar.item.power = 4;
    sar.bonus      = 2;
    result &= Test("constraint_class_robot_total", sar.total(), 10);
    return result;
}

bool testConstrainedFunction()
{
    bool result = true;
    Player p1;
    p1.points = 15;
    Player p2;
    p2.points = 30;
    result &= Test("constraint_func_max_player", MaxScore<Player>(&p1, &p2), 30);
    result &= Test("constraint_func_sum_player", SumScores<Player>(&p1, &p2), 45);
    Robot r1;
    r1.power = 6;
    Robot r2;
    r2.power = 4;
    result &= Test("constraint_func_max_robot", MaxScore<Robot>(&r1, &r2), 12);
    result &= Test("constraint_func_sum_robot", SumScores<Robot>(&r1, &r2), 20);
    return result;
}

// ---- Variadic template tests ----

struct PackTuple<T...>
{
    T item = default;
};

bool testVariadicStruct()
{
    PackTuple<int> t1 = default;
    t1.item_0 = 42;
    bool result = Test("variadic_1elem", t1.item_0, 42);

    PackTuple<int, float> t2 = default;
    t2.item_0 = 7;
    t2.item_1 = 3.0f;
    result &= Test("variadic_2elem_0", t2.item_0, 7);

    PackTuple<int, int, int> t3 = default;
    t3.item_0 = 1;
    t3.item_1 = 2;
    t3.item_2 = 3;
    result &= Test("variadic_3elem_2", t3.item_2, 3);

    return result;
}

struct PackWithFixed<K, V...>
{
    K key = default;
    V value = default;
};

bool testVariadicFixedPlusPack()
{
    PackWithFixed<int, float> p1 = default;
    p1.key = 99;
    p1.value_0 = 1.5f;
    bool result = Test("varfixed_key", p1.key, 99);

    PackWithFixed<int, int, int> p2 = default;
    p2.key = 5;
    p2.value_0 = 10;
    p2.value_1 = 20;
    result &= Test("varfixed_val1", p2.value_1, 20);

    return result;
}

struct SizeChecker<T...>
{
    int count()
    {
        return sizeof(T);
    }
};

bool testVariadicSizeof()
{
    SizeChecker<int> s1 = default;
    SizeChecker<int, float, bool> s3 = default;
    bool result = Test("sizeof_pack_1", s1.count(), 1);
    result &= Test("sizeof_pack_3", s3.count(), 3);
    return result;
}

// =============================================================
// tuple<T...> comprehensive tests
// =============================================================

bool testTuplePrimitives()
{
    bool result = true;

    tuple<int> ti = default;
    ti.item_0 = 42;
    result &= Test("tuple_int_val",  ti.item_0, 42);
    result &= Test("tuple_int_size", ti.size(),  1);

    tuple<float> tf = default;
    tf.item_0 = 2.5f;
    result &= Test("tuple_float_val",  tf.item_0, 2.5f);
    result &= Test("tuple_float_size", tf.size(),  1);

    tuple<bool> tb = default;
    tb.item_0 = true;
    result &= Test("tuple_bool_val",  tb.item_0, true);
    result &= Test("tuple_bool_size", tb.size(),  1);

    tuple<i64> tl = default;
    tl.item_0 = 9000000000;
    result &= Test("tuple_i64_val",  tl.item_0, 9000000000);
    result &= Test("tuple_i64_size", tl.size(),  1);

    // four-element mixed: int, float, bool, i64
    tuple<int, float, bool, i64> tmix = default;
    tmix.item_0 = 7;
    tmix.item_1 = 1.5f;
    tmix.item_2 = true;
    tmix.item_3 = 8000000000;
    result &= Test("tuple_mix_int",   tmix.item_0, 7);
    result &= Test("tuple_mix_float", tmix.item_1, 1.5f);
    result &= Test("tuple_mix_bool",  tmix.item_2, true);
    result &= Test("tuple_mix_i64",   tmix.item_3, 8000000000);
    result &= Test("tuple_mix_size",  tmix.size(),  4);

    return result;
}

bool testTupleSizedIntegers()
{
    bool result = true;

    // signed: i8, i16, i32, i64
    tuple<i8, i16, i32, i64> ts = default;
    ts.item_0 = 100;
    ts.item_1 = 30000;
    ts.item_2 = 2000000;
    ts.item_3 = 5000000000;
    result &= Test("tuple_i8",          ts.item_0,      100);
    result &= Test("tuple_i16",         ts.item_1,      30000);
    result &= Test("tuple_i32",         ts.item_2,      2000000);
    result &= Test("tuple_i64_sized",   ts.item_3,      5000000000);
    result &= Test("tuple_signed_size", ts.size(),      4);

    // unsigned: u8, u16, u32, u64
    tuple<u8, u16, u32, u64> tu = default;
    tu.item_0 = 200;
    tu.item_1 = 50000;
    tu.item_2 = 2000000;
    tu.item_3 = 5000000000;
    result &= Test("tuple_u8",            tu.item_0,      200);
    result &= Test("tuple_u16",           tu.item_1,      50000);
    result &= Test("tuple_u32",           tu.item_2,      2000000);
    result &= Test("tuple_u64_sized",     tu.item_3,      5000000000);
    result &= Test("tuple_unsigned_size", tu.size(),      4);

    return result;
}

bool testTupleStructs()
{
    bool result = true;

    // single struct
    tuple<Person> tp1 = default;
    tp1.item_0.age = 25;
    tp1.item_0.id  = 101;
    result &= Test("tuple_struct_age",  tp1.item_0.age, 25);
    result &= Test("tuple_struct_id",   tp1.item_0.id,  101);
    result &= Test("tuple_struct_size", tp1.size(), 1);

    // two structs of same type
    tuple<Person, Person> tp2 = default;
    tp2.item_0.age = 30;
    tp2.item_0.id  = 102;
    tp2.item_1.age = 40;
    tp2.item_1.id  = 103;
    result &= Test("tuple_struct2_age0", tp2.item_0.age, 30);
    result &= Test("tuple_struct2_id0",  tp2.item_0.id,  102);
    result &= Test("tuple_struct2_age1", tp2.item_1.age, 40);
    result &= Test("tuple_struct2_id1",  tp2.item_1.id,  103);
    result &= Test("tuple_struct2_size", tp2.size(), 2);

    // mixed: struct + int + struct
    tuple<TemplatePoint, int, Person> tms = default;
    tms.item_0.x   = 3;
    tms.item_0.y   = 4;
    tms.item_1     = 77;
    tms.item_2.age = 50;
    result &= Test("tuple_mix_struct_x",   tms.item_0.x,   3);
    result &= Test("tuple_mix_struct_y",   tms.item_0.y,   4);
    result &= Test("tuple_mix_struct_int", tms.item_1,     77);
    result &= Test("tuple_mix_struct_age", tms.item_2.age, 50);
    result &= Test("tuple_mix_struct_sz",  tms.size(),     3);

    return result;
}

bool testTupleClasses()
{
    bool result = true;

    // single class
    tuple<Player> tc1 = default;
    tc1.item_0.points = 15;
    result &= Test("tuple_class1_pts",  tc1.item_0.points,  15);
    result &= Test("tuple_class1_scr",  tc1.item_0.Score(), 15);
    result &= Test("tuple_class1_size", tc1.size(), 1);

    // two different classes
    tuple<Player, Robot> tc2 = default;
    tc2.item_0.points = 20;
    tc2.item_1.power  = 8;
    result &= Test("tuple_class2_player", tc2.item_0.Score(), 20);
    result &= Test("tuple_class2_robot",  tc2.item_1.Score(), 16);
    result &= Test("tuple_class2_size",   tc2.size(), 2);

    // three classes: Player, Robot, Medal (Medal implements IScorer + ILabeled)
    tuple<Player, Robot, Medal> tc3 = default;
    tc3.item_0.points = 10;
    tc3.item_1.power  = 5;
    tc3.item_2.value  = 7;
    tc3.item_2.rank   = 2;
    result &= Test("tuple_class3_player", tc3.item_0.Score(), 10);
    result &= Test("tuple_class3_robot",  tc3.item_1.Score(), 10);
    result &= Test("tuple_class3_medal",  tc3.item_2.Score(),  7);
    result &= Test("tuple_class3_label",  tc3.item_2.Label(),  2);
    result &= Test("tuple_class3_size",   tc3.size(), 3);

    return result;
}

bool testTuplePointers()
{
    bool result = true;

    // single struct pointer
    Employee* e1 = new Employee;
    e1->id     = 1;
    e1->salary = 50000;
    tuple<Employee*> tp1 = default;
    tp1.item_0 = e1;
    result &= Test("tuple_ptr1_id",     tp1.item_0->id,     1);
    result &= Test("tuple_ptr1_salary", tp1.item_0->salary, 50000);
    result &= Test("tuple_ptr1_size",   tp1.size(), 1);
    Employee* tp1_e1 = move tp1.item_0; delete tp1_e1;

    // two struct pointers
    Employee* e2 = new Employee;
    e2->id     = 2;
    e2->salary = 60000;
    Employee* e3 = new Employee;
    e3->id     = 3;
    e3->salary = 70000;
    tuple<Employee*, Employee*> tp2 = default;
    tp2.item_0 = e2;
    tp2.item_1 = e3;
    result &= Test("tuple_ptr2_id0",  tp2.item_0->id,     2);
    result &= Test("tuple_ptr2_sal0", tp2.item_0->salary, 60000);
    result &= Test("tuple_ptr2_id1",  tp2.item_1->id,     3);
    result &= Test("tuple_ptr2_sal1", tp2.item_1->salary, 70000);
    result &= Test("tuple_ptr2_size", tp2.size(), 2);
    Employee* tp2_e2 = move tp2.item_0; delete tp2_e2;
    Employee* tp2_e3 = move tp2.item_1; delete tp2_e3;

    // mixed: int* + Employee* + bool*
    int* ip = new int;
    *ip = 777;
    Employee* e4 = new Employee;
    e4->id = 4;
    bool* bp = new bool;
    *bp = true;
    tuple<int*, Employee*, bool*> tpm = default;
    tpm.item_0 = ip;
    tpm.item_1 = e4;
    tpm.item_2 = bp;
    result &= Test("tuple_ptr_mix_int",  *tpm.item_0,      777);
    result &= Test("tuple_ptr_mix_emp",  tpm.item_1->id,   4);
    result &= Test("tuple_ptr_mix_bool", *tpm.item_2,      true);
    result &= Test("tuple_ptr_mix_size", tpm.size(),       3);
    int*      tpm_ip = move tpm.item_0; delete tpm_ip;
    Employee* tpm_e4 = move tpm.item_1; delete tpm_e4;
    bool*     tpm_bp = move tpm.item_2; delete tpm_bp;

    return result;
}

bool testTupleInterfaces()
{
    bool result = true;

    // Counter implements IReadable
    Counter c1 = Counter();
    tuple<IReadable> ti1 = default;
    ti1.item_0 = c1;
    result &= Test("tuple_iface1_read", ti1.item_0.Read(), 10);
    result &= Test("tuple_iface1_size", ti1.size(), 1);

    // ScaledValue implements both IReadable and IScalable
    ScaledValue sv = ScaledValue();
    tuple<IReadable, IScalable> ti2 = default;
    ti2.item_0 = sv;
    ti2.item_1 = sv;
    result &= Test("tuple_iface2_read",  ti2.item_0.Read(),    3);
    result &= Test("tuple_iface2_scale", ti2.item_1.Scale(4), 12);
    result &= Test("tuple_iface2_size",  ti2.size(), 2);

    // mixed: IReadable + int
    Counter c2 = Counter();
    tuple<IReadable, int> tim = default;
    tim.item_0 = c2;
    tim.item_1 = 99;
    result &= Test("tuple_iface_mix_read", tim.item_0.Read(), 10);
    result &= Test("tuple_iface_mix_int",  tim.item_1,        99);
    result &= Test("tuple_iface_mix_size", tim.size(), 2);

    return result;
}

// Returns a (int, float) tuple via tuple construction expression
(int, float) makePoint()
{
    return (3, 1.5f);
}

// Returns a (int, float, bool) tuple
(int, float, bool) makeTriple()
{
    return (42, 2.7f, true);
}

bool testTupleTypeSyntax()
{
    bool result = true;

    // Phase 1: (int, float) as a type
    (int, float) t = default;
    t.item_0 = 10;
    t.item_1 = 0.5f;
    result &= Test("tuple_type_int",   t.item_0, 10);
    result &= Test("tuple_type_float", t.item_1, 0.5f);
    result &= Test("tuple_type_size",  t.size(), 2);

    return result;
}

bool testTupleConstruct()
{
    bool result = true;

    // Phase 2: (expr, expr) construction expression
    (int, float) p = (7, 3.14f);
    result &= Test("tuple_ctor_int",   p.item_0, 7);
    result &= Test("tuple_ctor_float", p.item_1, 3.14f);

    // Three-element construction
    (int, float, bool) tri = (99, 1.1f, true);
    result &= Test("tuple_ctor3_int",   tri.item_0, 99);
    result &= Test("tuple_ctor3_float", tri.item_1, 1.1f);
    result &= Test("tuple_ctor3_bool",  tri.item_2, true);

    return result;
}

bool testTupleReturnAndDestructure()
{
    bool result = true;

    // Phase 2+3: return a tuple and destructure it
    (int x, float y) = makePoint();
    result &= Test("destr_int",   x, 3);
    result &= Test("destr_float", y, 1.5f);

    // Three-element destructure
    (int a, float b, bool c) = makeTriple();
    result &= Test("destr3_int",   a, 42);
    result &= Test("destr3_float", b, 2.7f);
    result &= Test("destr3_bool",  c, true);

    // Inferred entry: omit the type and infer it from the tuple field. At least one entry must
    // carry a type so the parse is unambiguous (a fully type-less '(a, b) = expr;' parses as an
    // assignment expression, not a destructure - see ParseDestructuringDeclaration).
    (int ix, iy) = makePoint();
    result &= Test("destr_infer_int",   ix, 3);
    result &= Test("destr_infer_float", iy, 1.5f);

    // `_` wildcard: skip a slot. The value stays in the tuple (no extra binding), and the wildcard
    // can sit anywhere - first, last, or middle - mixed with typed/inferred entries.
    (_, float wy) = makePoint();
    result &= Test("destr_wild_first", wy, 1.5f);
    (int wx, _) = makePoint();
    result &= Test("destr_wild_second", wx, 3);
    (int wa, _, bool wc) = makeTriple();
    result &= Test("destr_wild_mid_int",  wa, 42);
    result &= Test("destr_wild_mid_bool", wc, true);

    // Leading `auto` disambiguates from an assignment expression, so a FULLY type-less form is
    // allowed - every entry is inferred or `_`, no type token required anywhere.
    auto (aa, ab) = makePoint();
    result &= Test("destr_auto_int",   aa, 3);
    result &= Test("destr_auto_float", ab, 1.5f);
    auto (am, _, ac) = makeTriple();
    result &= Test("destr_auto_wild_int",  am, 42);
    result &= Test("destr_auto_wild_bool", ac, true);

    // Regression: a tuple shape (long, char) that is NEVER value-constructed anywhere and is
    // reached ONLY as a return type + destructure target. makeFreshPair is also defined AFTER
    // this function, so its fields are not yet emitted when this destructure runs - the
    // destructure must lazily instantiate them (was "arity mismatch: 2 variables for 0 fields").
    (long fa, char fb) = makeFreshPair();
    result &= Test("destr_fresh_long", fa, 9L);
    result &= Test("destr_fresh_char", (int)fb, 65);

    return result;
}

// Builds a (long, char) tuple via field assignment - no '(a, b)' construction expression of
// this shape exists in the file. Deliberately defined after testTupleReturnAndDestructure.
(long, char) makeFreshPair()
{
    tuple<long, char> t = default;
    t.item_0 = 9L;
    t.item_1 = (char)65;
    return t;
}

// Returns two array-views as a tuple. A tuple element may be a `T[]` array-view; each
// element keeps the noalias contract, so the destructured locals are distinct views (the
// !alias.scope metadata is checked by the HPC IR tests; here we verify the values).
(int[], int[]) twoViews(int[] a)
{
    int[] first = a;
    int[] second = a;
    return (first, second);
}

bool testTupleArrayView()
{
    bool result = true;

    int[5] backing = {10, 20, 30, 40, 50};
    int[] v = backing;

    // Sugar form (int[], int[]) destructured into array-view locals.
    (int[] x, int[] y) = twoViews(v);
    x[0] = 99;                       // mutate through one view
    result &= Test("tuple_view_destr_write", y[0], 99);

    int sum = 0;
    vectorize for (i64 i = 0; i < (i64)5; i = i + 1) { sum = sum + y[i]; }
    result &= Test("tuple_view_destr_sum", sum, 99 + 20 + 30 + 40 + 50);

    // Explicit generic form tuple<int[], int[]> built from a tuple literal.
    tuple<int[], int[]> t = (v, v);
    t.item_0[1] = 7;
    result &= Test("tuple_view_field_alias", t.item_1[1], 7);

    return result;
}

// Phase 4: ITuple<T...> - a third-party type that implements the interface
class MyRange : ITuple<int, int>
{
    int lo = 0;
    int hi = 0;

    (int, int) get()
    {
        return (lo, hi);
    }
};

bool testITuple()
{
    bool result = true;

    MyRange r;
    r.lo = 5;
    r.hi = 10;
    (int a, int b) = r.get();
    result &= Test("ituple_lo", a, 5);
    result &= Test("ituple_hi", b, 10);

    return result;
}

bool testImplicitStringLiteral()
{
    bool result = true;

    // string s = "literal" - implicit char* -> string coercion in variable declaration
    string s1 = "hello";
    result &= Test("implicit_decl", s1, "hello");

    // list<string>.add("literal") - implicit char* -> string coercion in function argument
    list<string> words = default;
    words.add("foo");
    words.add("bar");
    result &= Test("implicit_add_0", words.get(0), "foo");
    result &= Test("implicit_add_1", words.get(1), "bar");

    return result;
}

// =============================================================
// Generic function references and nested generic locals
// =============================================================

int dbl<T>(T x) { return (int)x + (int)x; }

// Nested generic-type local inside a generic function body (regression for the
// QueueInstantiateGenericType substitution fix - a literal "T" used to be queued
// and failed with "unknown type 'T'").
int sumPair<T>(T seed)
{
    list<T> xs = default;
    xs.add(seed);
    xs.add(seed);
    int total = 0;
    int i = 0;
    while (i < xs.count()) { total = total + (int)xs.get(i); i = i + 1; }
    return total;
}

bool testGenericFnAsValue()
{
    bool result = true;
    function<int(int)> fp = dbl<int>;   // generic fn instantiated as a value
    result &= Test("genfn_value_call",  fp(21), 42);
    result &= Test("genfn_value_call2", fp(0), 0);
    return result;
}

bool testNestedGenericLocal()
{
    bool result = true;
    result &= Test("genfn_nested_local_int", sumPair<int>(5), 10);
    result &= Test("genfn_nested_local_i64", (int)sumPair<i64>(7), 14);
    return result;
}

// =============================================================
// `this` pointer in member-function bodies (plain and generic)
// =============================================================

struct SelfProbe
{
    int n = 0;
    SelfProbe* self() { return this; }
    void*      raw()  { return (void*)this; }
    int        read() { return this.n; }
    void       bump() { this.n = this.n + 1; }
};

class SelfBox<T>
{
    T val = default;
    SelfBox<T>* me()  { return this; }
    T           get() { return this.val; }
};

bool testThisReturnsSelf()
{
    SelfProbe p;
    p.n = 7;
    bool result = true;
    result &= Test("this_self_eq", (int)(p.self() == &p), 1);
    result &= Test("this_raw_eq",  (int)(p.raw() == (void*)&p), 1);
    return result;
}

bool testThisMemberAccess()
{
    SelfProbe p;
    p.n = 41;
    p.bump();
    return Test("this_member_rw", p.read(), 42) != 0;
}

bool testThisInGenericMethod()
{
    SelfBox<int> b;
    b.val = 9;
    bool result = true;
    result &= Test("this_generic_eq",  (int)(b.me() == &b), 1);
    result &= Test("this_generic_get", b.get(), 9);
    return result;
}

// =============================================================
// auto return-type inference on generic functions
// =============================================================

auto square<T>(T v)         { return v * v; }
auto identity<T>(T v)       { return v; }
auto pick_max<T>(T lhs, T rhs) { return lhs > rhs ? lhs : rhs; }
auto is_positive<T>(T v)    { return v > (T)0; }
auto abs_val<T>(T v)
{
    if (v < (T)0) return -v;
    return v;
}

bool testAutoReturn()
{
    bool result = true;
    result &= Test("auto_square_int",     square<int>(5),         25);
    result &= Test("auto_square_i64",     square<i64>(7),         (i64)49);
    double d = square<double>(2.5);
    result &= Test("auto_square_double",  (int)(d > 6.24 && d < 6.26), 1);
    result &= Test("auto_identity_int",   identity<int>(42),      42);
    result &= Test("auto_pick_max_7",     pick_max<int>(3, 7),    7);
    result &= Test("auto_pick_max_9",     pick_max<int>(9, 2),    9);
    result &= Test("auto_is_pos_false",   is_positive<int>(-3),   false);
    result &= Test("auto_is_pos_true",    is_positive<int>(5),    true);
    result &= Test("auto_abs_neg",        abs_val<int>(-4),       4);
    result &= Test("auto_abs_pos",        abs_val<int>(4),        4);
    return result;
}

// -- generic argument inference --

auto pick<T>(T a, T b) { return a > b ? a : b; }

bool testGenericArgInference()
{
    bool result = true;
    result &= Test("pick_int_max",  pick(3, 7),                  7);
    result &= Test("pick_int_min",  pick(9, 2),                  9);
    result &= Test("pick_i64_max",  pick((i64)10, (i64)20), (i64)20);
    return result;
}

// Regression: an outer generic's method calls a method on an INNER generic type
// instantiated with the same type arg. When the inner is instantiated standalone
// (queued first) before any top-level call to its methods, its member bodies must
// still be reachable from the outer's body (forward-declared before the dependency
// flush). Previously failed with "Unknown identifier" on the inner method.
class GInner<T> where T : IMessage
{
    i64 _v = default;
    void bump() { _v = _v + (i64)1; }
};

class GOuter<T> where T : IMessage
{
    GInner<T>* make()
    {
        GInner<T>* a = new GInner<T>[1];
        a.bump();
        a.bump();
        return a;
    }
};

bool testNestedGenericInnerMethod()
{
    bool result = true;
    GOuter<IMessage> o = default;
    GInner<IMessage>* a = o.make();
    result &= Test("nested generic inner-method call", (int)a._v, 2);
    delete[1] a;
    return result;
}

// =============================================================
// Recursive generic instantiation: a generic container used as the type
// argument to another generic (e.g. list<list<int>>). Before the fix the inner
// type argument was kept as the literal string "list<int>" and never
// instantiated, so the outer declaration failed with "unknown type 'list<int>'".
// =============================================================

// list<list<int>> - by-value nested generic. Add inner lists, read back via
// get(i).get(j). add() moves the inner list into the slot (ownership transfer),
// so teardown frees each buffer exactly once.
bool testListOfListByValue()
{
    bool result = true;
    list<list<int>> ll;

    list<int> a = {1, 2, 3};
    list<int> b = {4, 5};
    ll.add(a);
    ll.add(b);

    result &= Test("nested count",   ll.count(),         2);
    result &= Test("nested a.count", ll.get(0).count(),  3);
    result &= Test("nested b.count", ll.get(1).count(),  2);
    result &= Test("nested a[0]",    ll.get(0).get(0),   1);
    result &= Test("nested a[2]",    ll.get(0).get(2),   3);
    result &= Test("nested b[1]",    ll.get(1).get(1),   5);
    return result;
}

// Three levels deep: list<list<list<int>>>.
bool testListOfListOfListByValue()
{
    bool result = true;
    list<list<list<int>>> lll;

    list<list<int>> inner;
    list<int> a = {7, 8};
    inner.add(a);
    lll.add(inner);

    result &= Test("deep count",       lll.count(),                1);
    result &= Test("deep inner count", lll.get(0).count(),         1);
    result &= Test("deep value",       lll.get(0).get(0).get(1),   8);
    return result;
}

// list<list<int>*> - the idiomatic owning-pointer nesting. The outer list owns
// the inner list pointers and frees them in its destructor.
bool testListOfListPtr()
{
    bool result = true;
    list<list<int>*> ll;

    list<int>* a = new list<int>();
    a.add(10); a.add(20); a.add(30);
    list<int>* b = new list<int>();
    b.add(40); b.add(50);
    ll.add(a);
    ll.add(b);

    result &= Test("ptr count", ll.count(),         2);
    result &= Test("ptr a[0]",  ll.get(0).get(0),  10);
    result &= Test("ptr a[2]",  ll.get(0).get(2),  30);
    result &= Test("ptr b[1]",  ll.get(1).get(1),  50);
    return result;
}

// dictionary<int, list<int>*> - a generic used as the value type argument of
// another generic.
bool testDictOfListPtr()
{
    bool result = true;
    dictionary<int, list<int>*> d;

    list<int>* a = new list<int>();
    a.add(100); a.add(200);
    d.add(1, a);

    list<int>* got = d.get(1);
    result &= Test("dict value count", got.count(),  2);
    result &= Test("dict value[0]",    got.get(0), 100);
    result &= Test("dict value[1]",    got.get(1), 200);
    return result;
}

// =============================================================
// Generic type aliases (using IntList = list<int>) - Tier 1
// The alias value is just the mangled name (list__int), a plain string; the
// instantiation is enqueued by the using itself (see ParseUsingDeclaration).
// =============================================================

using IntList   = list<int>;
using FloatList = list<float>;        // list<float> is mentioned ONLY via this using
using IntToInt  = dictionary<int, int>;

// Alias used in a function signature (parameter + return).
int aliasSum(IntList* xs)
{
    int sum = 0;
    for (int v in *xs) sum += v;
    return sum;
}

bool testGenericAlias()
{
    bool result = true;

    IntList xs;
    xs.add(10);
    xs.add(20);
    xs.add(12);
    result &= Test("generic_alias_count", xs.count(), 3);
    result &= Test("generic_alias_get1",  xs.get(1),  20);
    result &= Test("generic_alias_in_fn", aliasSum(&xs), 42);

    // list<float> instantiates purely from the `using FloatList = list<float>` above.
    FloatList fs;
    fs.add(1.5f);
    fs.add(2.5f);
    result &= Test("generic_alias_float_count", fs.count(), 2);
    result &= Test("generic_alias_float_get0",  fs.get(0) == 1.5f, true);

    // dictionary alias
    IntToInt m;
    m.add(1, 100);
    m.add(2, 200);
    result &= Test("generic_alias_dict_count", m.count(), 2);
    result &= Test("generic_alias_dict_get",   m.get(2),  200);

    return result;
}

extern int main()
{
    int passed = 0;
    int total  = 0;
    total++; passed += testGenericAlias()                ? 1 : 0;
    total++; passed += testGenericStructs();
    total++; passed += testInterface()                   ? 1 : 0;
    total++; passed += testGenericInterface()            ? 1 : 0;
    total++; passed += testReturnListFreeFunc()          ? 1 : 0;
    total++; passed += testReturnListMethod()            ? 1 : 0;
