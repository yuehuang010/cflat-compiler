// Regression tests for the "Fix string/list/dictionary ownership leaks + double-free"
// change. Each fixed path is exercised over mixed/nested data structures and asserted
// for both correct behavior AND leak-freedom via the HeapAudit oracle (every operator
// new is recorded, every operator delete checked; reportLeaks() must return 0 and a
// double free aborts deterministically). HeapAudit needs an -o build, which test.bat
// uses. The bugs this guards against:
//
//   1. string.split() built each part inline as `string p = default; p._ptr = buf;`,
//      which the static ownership tracker does NOT mark owning - so parts added to the
//      returned list<string> leaked on the list's destruction. Fix routes every part
//      through the `move`-returning _str_owned_range() helper.
//   2. list<T>.set / removeAt / clear did not destruct an overwritten/removed/cleared
//      VALUE-TYPE element that owns buffers (string, or a nested container) - it leaked.
//      (Only pointer elements were freed before.)
//   3. dictionary<K,V>.add / set stored the incoming `move V` with a plain copy-assign,
//      so `value`'s scope-exit destructor freed a buffer the slot now aliased - a double
//      free for a value-type V with a real destructor (e.g. a nested list<string>).
import "string.cb";
import "list.cb";
import "dictionary.cb";
import "hashset.cb";
import "diagnostic/heap_audit.cb";
import "test_helper.cb";

// Owning aggregates with managed fields and NO user copy() - exercise the synthesized
// memberwise copy() and the field-reassignment destruct-old (Bugs 5 and 6 below).
struct LeakRow { string name = default; };
struct LeakBox { list<int> nums = default; };
struct LeakPair { string name = default; list<int> nums = default; };
// Owning fixed-array FIELD (`ArrSBox items[3]`): the synthesized destructor must free EVERY element
// (was a leak - the whole array field was skipped), and the memberwise copy() must deep-copy each
// element so a .copy() is independent (not a shared-buffer double-free). (Multi-dimensional array
// FIELDS are not expressible in the grammar; the flattened walk is exercised by array LOCALS.)
// See internal/issue/fixed-array-elements-not-destructed.md.
struct ArrSBox   { string s = default; };
struct ArrHolder { ArrSBox items[3] = default; };
// Owning Lambda<> field (lambda Option A): a closure stored in a struct field owns its heap
// env and is freed by the struct's destructor, like a string/list field.
struct LeakHandler { Lambda<int(int)> fn = default; };
// Same, but the closure RETURNS an owned string - the shape that exposed the field-callee leak.
struct LeakLabeler { Lambda<string(int)> label = default; };

// Regression for "container copy moves-or-shares elements": copy() deep-copies value-type
// elements (source intact), transfers owned POINTER elements to the copy (single owner - a
// shared pointee would double-free), and bitwise-copies enum elements. LeakName needs hash()
// and == to be a hashset element.
enum LeakColor : int { LC_Red, LC_Green, LC_Blue };
struct LeakName { string n = default; int hash() { return (int)n.length(); } };
bool operator==(LeakName a, LeakName b) { return a.n == b.n; }

// `unique T*` field: the struct owns the raw pointer and the SYNTHESIZED destructor frees it.
// Without the keyword these leak - an unmarked pointer field is never auto-freed.
struct LeakPayload { list<int> nums = default; };
struct LeakUnique  { unique LeakPayload* slot = nullptr; };
// Nested: freeing the outer field runs LeakUnique's synthesized dtor, which frees its own field.
struct LeakUniqueOuter { unique LeakUnique* inner = nullptr; };

// `unique` on an INTERFACE field: ownership rides the contract, because a store through the
// interface's byte-offset slot is dispatched dynamically and cannot see the concrete type.
// Both sides must declare it (err_unique_iface_field_impl_only / _iface_only).
interface ILeakSlot
{
    unique LeakPayload* slot;
};

class LeakIfaceBox : ILeakSlot
{
    unique LeakPayload* slot = nullptr;
};

// Reassign through the interface slot. The old pointee - and its list<int> buffer - must be
// freed here; a store that only overwrote the slot would orphan them silently.
void leakStoreViaIface(ILeakSlot h, int v)
{
    h.slot = new LeakPayload();
    h.slot->nums.add(v);
}

// Function-type alias: ownership/clone/free flow through the alias exactly as through the
// underlying Lambda<int(int)>, so clone-by-default reassignment must not leak.
using EVENT = Lambda<int(int)>;

// Returns a CAPTURING closure - its env must be heap-owned so the value can escape the frame
// (Bug 8). Built in a local and returned by variable (the escape pattern real code uses).
Lambda<int(int)> makeLeakAdder(int base)
{
    Lambda<int(int)> f = (int x) => x + base;
    return f;
}

// Same, but returns the capturing lambda LITERAL directly (no intermediate variable). This is a
// distinct codegen path from makeLeakAdder; the returned env must still transfer to the caller's
// local and free exactly once (no leak, no double-free) when that local goes out of scope.
Lambda<int(int)> makeLeakAdderLiteral(int base)
{
    return (int x) => x + base;
}

// Borrow a closure by value and invoke it (exercises the by-value argument copy site - the
// caller's temporary env is freed at end of the call statement by FlushOwnedClosureTemps).
int applyLeak(Lambda<int(int)> fn, int v) { return fn(v); }

// === String-RETURN ownership (runtime-bit model) regression helpers ===
// Before the fix, the string destructor was gated on a COMPILE-TIME `IsOwningString` flag
// instead of the runtime OWNED bit (_len high bit), so a genuinely-owned string returned
// from a PLAIN (non-`move`) `string` function was never freed by the caller's local -> LEAK.
// The helpers below exercise the return shapes the fix made leak- and double-free-clean:
//   - returnOwnedConcat: returns a fresh owned temp (operator+ result)
//   - returnOwnedLocal:  returns a whole owned LOCAL (moved out - source zeroed on return)
//   - Greeter.greet:     owned string returned from a MEMBER function
// while a list element read confirms a BORROW return is handed back with the owned bit
// cleared, so the caller does not double-free a buffer the container still owns.
string returnOwnedConcat(string who)
{
    string g = "hello ";
    return g + who;            // owned concat temp, plain `string` return type
}

string returnOwnedLocal()
{
    string s = "x" + "yz";     // owned local
    return s;                  // moved to caller: source zeroed so it is not double-freed
}

struct Greeter
{
    string prefix = default;
    string greet(string who) { return prefix + who; }   // owned result from a member fn
};

// By-value owning-struct temp field-extract: a `move` return OWNS its fields, so a temp whose
// field is read transiently is fully destructed at end-of-statement (no leak). A plain accessor
// (`list.get`) returns a shallow ALIAS, so its temp must NOT be destructed (a double-free aborts).
struct TempTok { string text = default; string extra = default; };
move TempTok makeTempTok(int n) { TempTok t = default; t.text = "tok" + n.toString(); t.extra = "ex" + n.toString(); return t; }
// PLAIN (non-move) owning return: builds a fresh owned local and transfers it out by value. An
// unbound transient field read (`makePlainTok(3).text.length()`) used to LEAK - the temp owned
// the buffer but, unbound, was never destructed. It is now dropped at end-of-statement (no leak).
TempTok makePlainTok(int n) { TempTok t = default; t.text = "tok" + n.toString(); t.extra = "ex" + n.toString(); return t; }
// Destination for the implied-move cases: a `move`-temp's owning field transfers into this slot.
struct TokHolder { string slot = default; };
// Phase B: returning a `move`-temp's owning field moves it out (ownership escapes to the caller).
// String field and struct field both move; the temp's other field still frees at end-of-statement.
string returnMovedText(int n) { return makeTempTok(n).text; }
struct InnerTok { string s = default; };
struct OuterTok { InnerTok inner = default; };
move OuterTok makeOuterTok(int n) { OuterTok o = default; o.inner.s = "in" + n.toString(); return o; }
InnerTok returnMovedInner(int n) { return makeOuterTok(n).inner; }

// Interface with a PLAIN (non-`move`) string method: the implementer returns a freshly owned
// concat, so a virtual call physically carries the owned bit. Exercises the interface-dispatch
// (CallInterfaceMethod) leg of the ternary-branch cleanup - a distinct codegen path from a
// direct free-function/member call, but the same runtime-owned-bit contract.
interface ILabel { string label(); };
class Labeler : ILabel { string tag = default; string label() { return tag + "!"; } };

// Interface-element ownership: `list<unique IShapeLeak>` owns its boxed elements and frees them
// through the vtable dtor slot; bare `list<IShapeLeak>` borrows and frees nothing.
int g_shapeDtor = 0;
interface IShapeLeak { int area(); };
class CircleLeak : IShapeLeak { int r = 0; int area() { return r * r; } ~CircleLeak() { g_shapeDtor = g_shapeDtor + 1; } };

// A `unique` interface PARAM takes ownership: the callee frees the boxed object at scope exit.
void sinkShape(unique IShapeLeak s) {}

// Regression (mirrors ui_native.cb reconcilePath): mutually-exclusive branches that each consume
// a `move` interface param exactly once and immediately return must COMPILE - a move inside a
// branch that unconditionally returns must not leak its moved state to the fall-through path. At
// runtime each owned object is freed exactly once.
move IShapeLeak pickShape(move IShapeLeak a, move IShapeLeak b, int sel)
{
    if (sel == 0) { sinkShape(a); return b; }
    if (sel == 1) { sinkShape(a); return b; }
    sinkShape(b);
    return a;
}

// Pointer flavor of the same exclusive-return pattern: must compile and free each object once.
struct PtrLeak { int v = 0; ~PtrLeak() { g_shapeDtor = g_shapeDtor + 1; } };
void delPtr(move PtrLeak* p) {}
move PtrLeak* pickPtr(move PtrLeak* a, move PtrLeak* b, int sel)
{
    if (sel == 0) { delPtr(a); return b; }
    if (sel == 1) { delPtr(a); return b; }
    delPtr(b);
    return a;
}

// A `move` consumed in a branch that returns, with a DEAD statement after the return: the branch
// must still read as returned (the dead statement reopens a live block that would otherwise hide
// the return), so its move does not spuriously poison the fall-through use of the same param.
move IShapeLeak deadCodePick(move IShapeLeak a, move IShapeLeak b, int sel)
{
    if (sel == 0) { sinkShape(a); return b; int dead = 5; }
    sinkShape(a);
    return b;
}

// Return-block functions inline an early CALLER-EXIT (their `return` returns from the caller). The
// move analysis must model that exit: an UNCONDITIONAL return-block makes the enclosing branch
// return (a following move is dead), while a CONDITIONAL one may fall through (a following move
// stays live). Both must compile and free each object exactly once.
void rbExitLeak() { return { return; }; }
void rbMaybeLeak(int x) { return { if (x < 0) { return; } }; }
void rbUncondFree(move PtrLeak* a, int c)
{
    if (c > 0) { rbExitLeak(); delPtr(a); }   // rbExitLeak returns from here; delPtr(a) is dead
    delPtr(a);
}
void rbCondFree(move PtrLeak* a, int c)
{
    rbMaybeLeak(c);                            // may return here (c < 0) or fall through (c >= 0)
    delPtr(a);
}

// PLAIN (non-`move`) string return that hands back a freshly owned concat. Passing its result -
// or an owned local bound from it - bare into list<string>.add(move)/set(move) used to LEAK: the
// move-arg lowering heap-copied a fresh buffer for the slot (the static owned flag is unset for a
// plain return / bare local read) and orphaned the runtime-owned original. The lowering now
// branches on the runtime owned bit: transfer when already owned, copy only literals/views.
string plainOwnedStr(int n) { return "owned" + n.toString(); }

// Returns an owning container BY VALUE - the caller owns the result. Used as an rvalue-temp
// method receiver below (Bug 9).
list<int> makeIntList(int n)
{
    list<int> v = default;
    int i = 0;
    while (i < n) { v.add(i); i++; }
    return v;
}

// === Bug 10: global owning values were never destructed ===
// Globals are destructed on main's normal return, in REVERSE definition order. `_gLeakGate` is
// defined FIRST, so it is destructed LAST - its destructor observes the container globals below
// already torn down, and fails the process if any of their buffers survived. The containers are
// populated only at the END of main (after the in-main leak oracle), so that oracle still sees
// zero live allocations.
struct GlobalLeakGate
{
    int _pad = 0;
    ~GlobalLeakGate()
    {
        if (HeapAudit.reportLeaks() != 0u)
        {
            printf("FAIL: global owning values were not destructed at exit.\n");
            exit(1);
        }
    }
};
GlobalLeakGate            _gLeakGate = default;
list<int>                 _gNums     = default;
dictionary<string, string> _gMap     = default;

extern int main()
{
    HeapAudit.enable();

    int passed = 0;
    int total = 0;

    // === Bug 1: string.split() parts are owned by the returned list ===
    // The list and all of its split-produced string elements must free on scope exit.
    {
        string csv = "alpha,beta,gamma,delta";
        list<string> parts = csv.split(",");
        total++; passed += Test("split count", parts.count(), 4);
        total++; passed += Test("split[0]", parts.get(0), "alpha");
        total++; passed += Test("split[3]", parts.get(3), "delta");

        // char separator overload + trailing-empty element path
        string path = "a/b/c/";
        list<string> segs = path.split('/');
        total++; passed += Test("split(char) trailing-empty count", segs.count(), 4);
        total++; passed += Test("split(char)[2]", segs.get(2), "c");
        total++; passed += Test("split(char) trailing empty", segs.get(3), "");
    }

    // === Bug 2a: list<string>.set overwrites and frees the old owning element ===
    {
        list<string> ls = {"aaa", "bbb", "ccc"};
        ls.set(1, "OVERWRITTEN");          // old "bbb" must be destructed, new value moved in
        total++; passed += Test("list set value", ls.get(1), "OVERWRITTEN");
        total++; passed += Test("list set keeps count", ls.count(), 3);
    }

    // === Bug 2d: bare owned string moved into list<string>.add / .set adopts (no leak) ===
    // A call result and a named local (both runtime-owned but NOT statically flagged) moved into
    // a `move string` param must transfer their buffer into the slot, not orphan it via a copy.
    {
        list<string> ls = default;
        string s = plainOwnedStr(0);
        ls.add(s);                         // bare named local -> add(move)
        ls.add(plainOwnedStr(1));          // bare call result  -> add(move)
        ls.add("lit2");                    // literal still heap-copied (owns an independent buffer)
        total++; passed += Test("bare-move add count", ls.count(), 3);
        total++; passed += Test("bare-move add[0]", ls.get(0), "owned0");
        total++; passed += Test("bare-move add[1]", ls.get(1), "owned1");

        ls.set(0, plainOwnedStr(2));       // bare call result  -> set(move), old freed
        string s2 = plainOwnedStr(3);
        ls.set(1, s2);                     // bare named local  -> set(move), old freed
        total++; passed += Test("bare-move set[0]", ls.get(0), "owned2");
        total++; passed += Test("bare-move set[1]", ls.get(1), "owned3");
    }

    // === Bug 2b: list<string>.removeAt frees the removed owning element ===
    {
        list<string> ls = {"a", "b", "c", "d"};
        ls.removeAt(1);                    // "b" destructed in place, tail shifts left
        total++; passed += Test("removeAt count", ls.count(), 3);
        total++; passed += Test("removeAt shift", ls.get(1), "c");
    }

    // === Bug 2c: list<string>.clear frees every owning element, buffer reusable ===
    {
        list<string> ls = {"x", "y", "z"};
        ls.clear();                        // all three destructed
        total++; passed += Test("clear count", ls.count(), 0);
        ls.add("reused");                  // reuse the kept backing buffer after clear
        total++; passed += Test("reuse after clear", ls.get(0), "reused");
    }

    // === Fixed-array LOCAL elements are destructed (all N, not just element [0]) ===
    // `SBox[3] a;` default-constructs every element, so every element's owning string must be
    // freed at scope exit. The scope-exit destructor used to fire once on the array BASE pointer,
    // freeing element [0] only and leaking the rest. Concatenations force genuinely owned buffers
    // (a literal is borrowed and would free as a no-op, hiding the leak).
    {
        LeakRow[3] a;
        a[0].name = "aa" + "bb";
        a[1].name = "cc" + "dd";
        a[2].name = "ee" + "ff";
        total++; passed += Test("fixed-array elem [1] live", a[1].name, "ccdd");
        total++; passed += Test("fixed-array elem [2] live", a[2].name, "eeff");
    }

    // Multi-dimensional arrays are contiguous, so all N*M owning elements must be freed too.
    {
        LeakRow[2][3] m;
        m[0][0].name = "gg" + "hh";
        m[1][2].name = "ii" + "jj";
        total++; passed += Test("fixed-array multidim first", m[0][0].name, "gghh");
        total++; passed += Test("fixed-array multidim last", m[1][2].name, "iijj");
    }

    // === Bug 3a: dictionary<string,string> overwrite/add move the value (no double free) ===
    // string V has a real destructor, so a copy-assign of the move param would double free.
    {
        dictionary<string, string> d = {"k1": "v1"};
        d.set("k1", "v2");                 // overwrite same key: old "v1" freed, "v2" moved in
        total++; passed += Test("dict<str,str> overwrite", d.get("k1"), "v2");
        d.add("k2", "x");                  // add new (move)
        total++; passed += Test("dict<str,str> add", d.get("k2"), "x");
        total++; passed += Test("dict<str,str> count", d.count(), 2);
    }

    // === Bug 3b: dictionary with a NESTED container value (list<string>) ===
    // The headline double-free case: V owns buffers transitively. add()/set() must move.
    {
        dictionary<int, list<string>> d = default;
        list<string> v1 = {"p", "q"};
        d.add(1, move v1);                 // value moved into slot; v1 zeroed
        total++; passed += Test("dict nested add count", d.get(1).count(), 2);

        list<string> v2 = {"r", "s", "t"};
        d.set(1, move v2);                 // overwrite: old list<string> destructed, new moved in
        total++; passed += Test("dict nested overwrite count", d.get(1).count(), 3);
        total++; passed += Test("dict nested overwrite elem", d.get(1).get(2), "t");

        d.remove(1);                       // value-type V destructed on remove
        total++; passed += Test("dict nested remove", d.count(), 0);
    }

    // === Bug 9a: list<string>.add(move <owned-string-local>) TRANSFERS the buffer ===
    // A named owned string passed via `move` to a `move string` parameter must transfer its
    // buffer into the callee, not be defensively heap-copied - the copy would be handed to the
    // slot while the (already-emptied) source frees nothing, orphaning the original buffer: a
    // leak of one heap buffer per inserted element. Fix: ParseMoveExpression flags the moved
    // string value owning, so CreateOverloadedFunctionCall skips the defensive clone.
    {
        list<string> ls = default;
        int i = 0;
        while (i < 6) { string item = "item_" + i.toString(); ls.add(move item); i++; }
        total++; passed += Test("list<str> move-local add count", ls.count(), 6);
        total++; passed += Test("list<str> move-local add elem",  ls.get(5), "item_5");
    }

    // === Bug 9b: dictionary<string,K> deep-copies owning string KEYS and frees them ===
    // String keys built from owned temps ("k"+i) are deep-copied into the slot (a plain store
    // would alias the soon-freed argument and dangle); the slot's owned copy is freed on
    // remove() and on destruction. set()/remove() locate the key via that owned copy.
    {
        dictionary<string, int> d = default;
        int i = 0;
        while (i < 6) { d.add("k" + i.toString(), i); i++; }
        total++; passed += Test("dict<str,int> concat-key count",  d.count(), 6);
        total++; passed += Test("dict<str,int> concat-key lookup", d.get("k3"), 3);
        d.set("k3", 99);                       // overwrite existing key (found via the owned copy)
        total++; passed += Test("dict<str,int> set existing count", d.count(), 6);
        total++; passed += Test("dict<str,int> set value",          d.get("k3"), 99);
        d.remove("k2");                        // removed key's owned copy freed
        total++; passed += Test("dict<str,int> remove count",       d.count(), 5);
    }

    // === Bug 9c: hashset<string> owns its string ELEMENTS (deep-copied), frees them ===
    // Owned-temp elements are deep-copied into the slot; growth past initial capacity relocates
    // them with a raw slot-to-slot store (no per-element clone); remove()/clear()/the destructor
    // free the owned copies. (Pointer elements stay borrowed - see test_generics hashset<ptr>.)
    {
        hashset<string> hs = default;
        int i = 0;
        while (i < 10) { hs.add("e" + i.toString()); i++; }   // grows past initial capacity (rehash)
        total++; passed += Test("hashset<str> count",        hs.count(), 10);
        total++; passed += Test("hashset<str> contains",     hs.contains("e7"), true);
        total++; passed += Test("hashset<str> dup add",      hs.add("e3"), false);
        hs.remove("e7");                       // removed element's owned copy freed
        total++; passed += Test("hashset<str> after remove", hs.contains("e7"), false);
        hs.clear();                            // every owned element freed, buffer reusable
        total++; passed += Test("hashset<str> after clear",  hs.count(), 0);
    }

    // === Bug 4: owned-string temp operand of +, ==/!=/relational, and switch scrutinee ===
    // A move-returning string operand (e.g. `i.toString()`) is an owned temp that operator+,
    // the comparison operators, and a switch dispatch only borrow. Each must be freed at the end
    // of the full expression. Operands are registered in ParseAdditive/Equality/Relational; a
    // control-flow CONDITION flushes its temps in the condition block (the post-branch merge block
    // would drop them via the dominance guard and leak); a switch scrutinee's temps are re-homed to
    // resumeBlock (the dispatch reads the buffer, so they cannot be flushed before it).
    {
        int i = 0;
        int hits = 0;
        while (i < 8)
        {
            if (i.toString() == "3") hits++;            // equality operand temp
            if (i.toString() != "5") hits++;            // inequality operand temp
            if (i.toString() < "9") hits++;             // relational operand temp
            string r = "v" + i.toString();              // additive operand temp (r owns the result)
            if (r != i.toString()) hits++;              // both a named string and an operand temp
            i++;
        }
        for (int k = 0; k.toString() != "4"; k++) hits++;  // for-condition operand temp
        int m = 0;
        do { hits++; m++; } while (m.toString() != "3");   // do-while-condition operand temp

        // switch scrutinees: bare owned-call, concat (operand + result), and named (scope-freed).
        i = 0;
        while (i < 6)
        {
            switch (i.toString())            { case "2": hits = hits + 10;  break; default: hits++; break; }
            switch ("v" + i.toString())      { case "v3": hits = hits + 100; break; default: hits++; break; }
            string s = i.toString();
            switch (s)                       { case "1": hits = hits + 5;   break; default: hits++; break; }
            i++;
        }
        total++; passed += Test("owned-string temp expression hits", hits > 0, true);
    }

    // === Bug 5: reassigning an owning-value struct FIELD destructs the OLD value ===
    // `obj.field = newValue` previously overwrote the field's owned buffer without freeing
    // it (the field-store leak / copy-point #3). The destruct-old fix frees the prior value
    // first; the destructor is owned-bit/state-gated so a default or borrowed prior value is
    // a safe no-op (no double-free), and a self-assign must not free-then-dangle.
    {
        string base = "reassigned";
        LeakRow r = default;
        r.name = base.toUpper();          // owned "REASSIGNED"
        r.name = base.toLower();          // reassign: old owned buffer must be freed
        r.name = r.name;                  // self-assign: must NOT free-then-use
        r.name = "borrowed-literal";      // owned -> borrowed: old owned buffer freed
        total++; passed += Test("field reassign final value", r.name, "borrowed-literal");

        // move into a list<int> field (bypasses the X4 guard via `move`): old field freed
        LeakBox bx = default;
        list<int> v1 = default; v1.add(1);
        bx.nums = move v1;
        list<int> v2 = default; v2.add(2); v2.add(3);
        bx.nums = move v2;                // old bx.nums (v1's buffer) must be freed
        total++; passed += Test("field move-reassign count", bx.nums.count(), 2);
    }

    // === Bug 6: synthesized memberwise copy() deep-copies managed fields ===
    // A value type with managed fields and no explicit copy() gets an implicit memberwise
    // one: each managed field (string, list<int>) is deep-copied so the copy is independent,
    // and both the original and the copy free exactly once (no alias double-free, no leak).
    {
        string base = "src";
        LeakPair a = default;
        a.name = base.toUpper();          // "SRC"
        a.nums.add(10); a.nums.add(20);

        LeakPair b = a.copy();            // synthesized deep copy
        b.nums.add(30);                   // mutate the copy only
        total++; passed += Test("memberwise copy independent list (orig)", a.nums.count(), 2);
        total++; passed += Test("memberwise copy independent list (copy)", b.nums.count(), 3);
        total++; passed += Test("memberwise copy string value", b.name, "SRC");
    }

    // === Bug 7: closure (Lambda<...>) ownership - lambda Option A ===
    // A capturing closure owns a heap env. As an owning value type it must: be freed at scope
    // exit / struct teardown, clone-on-copy (.copy() and clone-by-default `b = a`), be stored
    // into a struct field cleanly, and have an unbound by-value-argument temporary freed at the
    // end of the call statement. Every path here must leave HeapAudit at zero.
    {
        // (a) capturing closure stored in a struct field, invoked after the defining frame is gone
        LeakHandler h = default;
        h.fn = makeLeakAdder(100);
        total++; passed += Test("closure field store invoke", h.fn(5), 105);

        // (b) returned capturing closure held in a local (escape via return)
        Lambda<int(int)> r = makeLeakAdder(1000);
        total++; passed += Test("closure return->var invoke", r(1), 1001);

        // (c) explicit .copy() -> two independent envs, both valid
        Lambda<int(int)> a = makeLeakAdder(10);
        Lambda<int(int)> b = a.copy();
        total++; passed += Test("closure copy independent (orig)", a(2), 12);
        total++; passed += Test("closure copy independent (copy)", b(3), 13);

        // (d) clone-by-default: `c = a` deep-copies the env, a stays valid (no use-after-move)
        Lambda<int(int)> c = a;
        total++; passed += Test("closure clone-by-default (clone)", c(7), 17);
        total++; passed += Test("closure clone-by-default (source live)", a(8), 18);

        // (e) lambda literal passed by value (unbound temp freed at statement end)
        int cap = 50;
        total++; passed += Test("closure literal by-value arg", applyLeak((int x) => x + cap, 4), 54);

        // (f) named closure passed by value (caller retains ownership; callee borrows)
        Lambda<int(int)> g = (int x) => x + 1;
        total++; passed += Test("closure named by-value arg", applyLeak(g, 9), 10);

        // (g) reassigning a closure LOCAL frees the previous heap env (no leak of the old env).
        // Each store overwrites a known-initialized alloca slot, so the old env is destructed
        // before the new value lands. Covers a lambda-literal RHS, a named-source clone, and a
        // self-assign (which must not double-free the slot it just cloned from).
        int rk = 3;
        Lambda<int(int)> rf = (int x) => x + rk;   // env #1
        rf = (int x) => x * rk;                       // frees env #1, stores env #2
        rf = rf;                                       // clone-then-free-old: no double-free
        Lambda<int(int)> rsrc = (int x) => x - rk;
        rf = rsrc;                                     // named-source clone; frees prior env
        total++; passed += Test("closure reassign result", rf(10), 7);
        total++; passed += Test("closure reassign source live", rsrc(10), 7);

        // (h) assigning a NAMED closure into a tmp, repeatedly: each `tmp = name` clones the
        // source env (clone-by-default) AND frees the tmp's PREVIOUS clone first, so reassigning
        // a tmp via a name does not leak the prior cloned env. The named sources stay live (a
        // clone, never a move), so they remain callable after being assigned into the tmp.
        Lambda<int(int)> src1 = makeLeakAdder(20);
        Lambda<int(int)> src2 = makeLeakAdder(30);
        Lambda<int(int)> tmp = src1;   // clone src1 -> tmp env #1
        tmp = src2;                       // free tmp env #1, clone src2 -> tmp env #2
        tmp = src1;                       // free tmp env #2, clone src1 -> tmp env #3
        total++; passed += Test("closure tmp via name (result)", tmp(1), 21);
        total++; passed += Test("closure tmp via name (src1 live)", src1(2), 22);
        total++; passed += Test("closure tmp via name (src2 live)", src2(3), 33);

        // (i) function-type alias `using EVENT = Lambda<int(int)>`: two alias-typed locals,
        // then clone-by-default reassignment `v2 = v1` through the alias. The store frees v2's
        // previous env and clones v1's into v2 (no leak), and v1 stays live (clone, not move).
        EVENT v1 = makeLeakAdder(40);
        EVENT v2 = makeLeakAdder(50);
        v2 = v1;                          // free v2's old env, clone v1's env into v2
        total++; passed += Test("alias EVENT clone (v2)", v2(1), 41);
        total++; passed += Test("alias EVENT source live (v1)", v1(2), 42);

        // (j) reassigning a closure struct FIELD frees the previous env (no leak of the old env).
        // The field's enclosing struct is a stack value type (default-initialized), so the field
        // destruct-old fires; a field reached through a heap pointer (raw packet) is left alone.
        // A self-assign clones the source env before freeing the old one, so it never double-frees.
        LeakHandler rh = default;
        rh.fn = makeLeakAdder(7);         // env #1 -> field
        rh.fn = makeLeakAdder(8);         // reassign: old env #1 freed, env #2 in field
        rh.fn = rh.fn;                    // self-assign: clone-then-free-old, no double-free
        total++; passed += Test("closure field reassign frees old env", rh.fn(1), 9);

        // (k) returning a capturing lambda LITERAL directly (no intermediate variable): the env
        // transfers to the caller's local and frees on scope exit. Exercised once and in a loop
        // (each iteration's local frees independently - the envs must not accumulate).
        Lambda<int(int)> lit = makeLeakAdderLiteral(60);
        total++; passed += Test("returned lambda literal invoke", lit(5), 65);
        int li = 0;
        int lsum = 0;
        while (li < 16) { Lambda<int(int)> lg = makeLeakAdderLiteral(li); lsum = lsum + lg(1); li = li + 1; }
        total++; passed += Test("returned lambda literal loop sum", lsum, 136);   // sum of (1 + li), li=0..15

        // (l) UNBOUND closure call result used INLINE: a closure-returning call whose result is
        // never bound to a variable (invoked directly, or passed by value as an argument) is freed
        // at end-of-full-expression by FlushOwnedClosureTemps - the call result is registered as an
        // owned closure temp exactly like a lambda literal. Both the literal- and variable-return
        // forms are covered, and the inline-arg form must not double-free the borrowed callee copy.
        total++; passed += Test("inline-invoke literal-return call result", makeLeakAdderLiteral(1000)(7), 1007);
        total++; passed += Test("inline-invoke variable-return call result", makeLeakAdder(2000)(3), 2003);
        total++; passed += Test("inline-arg call result (by-value borrow)", applyLeak(makeLeakAdder(10), 5), 15);
    }

    // === String RETURNS: owned transfer + borrow (runtime-bit ownership model) ===
    // A plain `string` return of an owned value transfers ownership to the caller's local
    // (freed on scope exit); a borrow return (a container element) is handed back non-owning
    // so it is not double-freed. The caller never sees the function's `move`-ness - the
    // runtime owned bit alone decides whether the local frees - so this works for free
    // functions, member functions, AND lambdas. All of it must be leak/double-free clean.
    {
        string greeting = returnOwnedConcat("world");      // owned temp: "hello world"
        total++; passed += Test("owned concat return", greeting.length(), 11);

        string moved = returnOwnedLocal();                  // owned local moved out: "xyz"
        total++; passed += Test("owned local move-return", moved.length(), 3);

        Greeter gr = default;
        gr.prefix = "hi-";
        string built = gr.greet("bob");                     // owned member-fn result: "hi-bob"
        total++; passed += Test("owned member-fn return", built.length(), 6);

        // Lambda returning a string: the lambda invoker shares the same return-ownership path,
        // so an owned temp (concat) and an owned local moved out of the body both transfer to
        // the caller's local and free on scope exit - no leak, no double-free.
        Lambda<string()> tempFn = () => { return "lam" + "bda"; };   // owned concat in a lambda
        string fromLambdaTemp = tempFn();
        total++; passed += Test("lambda owned temp return", fromLambdaTemp.length(), 6);

        Lambda<string()> localFn = () => { string t = "x" + "y"; return t; };  // owned local
        string fromLambdaLocal = localFn();
        total++; passed += Test("lambda owned local return", fromLambdaLocal.length(), 2);

        // Invoking the SAME closure through a struct FIELD must behave identically. The call
        // RESULT is a fresh value, not a read of the field, so the receiving local takes the
        // returned buffer directly. (Regression: the result inherited the callee field's
        // provenance and was classified as a borrow of an owning string FIELD - the local got a
        // deep copy while the returned buffer was orphaned, leaking it.) Covered for a heap
        // object, a stack value, and reassignment of an existing local.
        LeakLabeler* heapLbl = new LeakLabeler();
        heapLbl.label = (int n) => { return "n=" + n.toString(); };
        string fromFieldHeap = heapLbl.label(7);
        total++; passed += Test("lambda field owned return (heap)", fromFieldHeap, "n=7");
        delete heapLbl;

        LeakLabeler valLbl = default;
        valLbl.label = (int n) => { return "v" + n.toString(); };
        string fromFieldValue = valLbl.label(9);
        total++; passed += Test("lambda field owned return (value)", fromFieldValue, "v9");
        fromFieldValue = valLbl.label(10);                  // reassign from another field call
        total++; passed += Test("lambda field owned return (reassign)", fromFieldValue, "v10");

        // Borrow return: list.get hands the element back as a non-owning borrow (owned bit
        // cleared). The list still owns and frees it on teardown; the local `picked` must NOT
        // free it (a double-free would abort), and the element must survive for the list.
        list<string> fruits = default;
        fruits.add("a" + "pple");                           // owned element ("apple")
        fruits.add("ber" + "ry");                           // owned element ("berry")
        string picked = fruits.get(0);                      // borrow of an owned element
        total++; passed += Test("list element borrow return", picked.length(), 5);
        total++; passed += Test("list element still owned", fruits.get(1).length(), 5);

        // A `move`-return temp read transiently is fully destructed at end of statement: both
        // text and extra are freed (no leak). The reject guards against persisting the field.
        total++; passed += Test("move-temp field read", makeTempTok(7).text.length(), 4);   // "tok7"

        // A PLAIN (non-move) owning return read transiently is also fully destructed at end of
        // statement (regression: this unbound temp used to leak its text+extra buffers).
        total++; passed += Test("plain-temp field read", makePlainTok(8).text.length(), 4);   // "tok8"

        // A bare discarded owning-struct call (no bind, no field read) is destructed at the end of
        // the full expression (regression: this used to leak the whole temp - no field-access site
        // hooked it). Covered by the HeapAudit oracle below; both move and plain returns apply.
        makeTempTok(80);
        makePlainTok(81);

        // `_ = expr` is an explicit discard: same end-of-full-expression destruction as the bare
        // form, but works for any result (scalar/string/struct). Covered by the oracle below.
        _ = makeTempTok(82);
        _ = makePlainTok(83);

        // list.get(i) returns a shallow ALIAS of the element, so the temp is NOT destructed - the
        // element survives (frees once with the list, no double-free). Read it, and copy it out.
        list<TempTok> toks = default;
        TempTok one = default; one.text = "li" + "st"; one.extra = "ex" + "tra";
        toks.add(one);
        total++; passed += Test("get() alias field read", toks.get(0).text.length(), 4);   // "list"
        string ownedCopy = toks.get(0).text.copy();         // copy from an alias -> independent owner
        total++; passed += Test("get() alias field copy", ownedCopy.length(), 4);

        // Implied move: a `move`-temp OWNS its field, so persisting it transfers ownership (no .copy
        // needed). The destination frees the buffer once; the temp's other field frees at end of
        // statement; the moved-out field is zeroed so the temp's dtor does not double-free it.
        TokHolder h = default;
        h.slot = makeTempTok(11).text;                      // implied move into a struct field
        total++; passed += Test("implied-move into field", h.slot.length(), 5);   // "tok11"
        string movedTok = makeTempTok(123).text;            // implied move into a local
        total++; passed += Test("implied-move into local", movedTok.length(), 6); // "tok123"

        // Phase B: returning a `move`-temp's owning field moves it out to the caller (no leak,
        // no double-free - the temp's sibling field frees, the moved field rides out owned).
        string retText = returnMovedText(55);               // string field moved out via return
        total++; passed += Test("implied-move via return (string)", retText.length(), 5); // "tok55"
        InnerTok retInner = returnMovedInner(9);            // struct field moved out via return
        total++; passed += Test("implied-move via return (struct)", retInner.s.length(), 3); // "in9"

        // Comparison-operand temps from PLAIN (non-`move`) string returns. The compiler does not
        // flag a plain `string`-returning function as owned, so a result used DIRECTLY as a
        // comparison operand was never registered for cleanup and leaked (regression: the temp is
        // now freed at end-of-statement). The comparison only borrows the operands, so freeing the
        // (single) temp each is correct. Covered for free functions AND member functions, for
        // ==, !=, and relational <.
        bool cmpNe = returnOwnedConcat("a") != returnOwnedConcat("b");   // two plain-fn temps
        total++; passed += Test("plain-fn temp '!=' operands", cmpNe, true);
        bool cmpEq = returnOwnedConcat("x") == returnOwnedConcat("x");   // == operands
        total++; passed += Test("plain-fn temp '==' operands", cmpEq, true);
        bool cmpLt = gr.greet("a") < gr.greet("b");                      // plain member-fn temps
        total++; passed += Test("plain member-fn temp '<' operands", cmpLt, true);

        // Named owned-string locals as comparison operands must NOT be double-freed: the locals
        // own the buffers and free once on scope exit; the comparison borrows them and frees
        // nothing. A double-free here would abort the HeapAudit oracle.
        string cmpA = returnOwnedConcat("p");
        string cmpB = returnOwnedConcat("q");
        bool cmpLocals = cmpA != cmpB;
        total++; passed += Test("named owned-string locals compared (no double-free)", cmpLocals, true);

        // Additive-operand temps from PLAIN (non-`move`) string returns. Same gap as the
        // comparison operands above but on the `+` (concat) path: a plain string-returning call
        // used DIRECTLY as a `+` operand was never registered and leaked (the result `r` is freed,
        // the two operand temps were not). operator+ only borrows its operands, so freeing each
        // temp once is correct. Chained `+` mixes operand temps with an intermediate result temp.
        {
            string addCall = returnOwnedConcat("a") + returnOwnedConcat("b");   // two plain-fn temps
            total++; passed += Test("plain-fn temp '+' operands", addCall.length(), 14); // "hello ahello b"
            string addChain = returnOwnedConcat("a") + returnOwnedConcat("b") + returnOwnedConcat("c");
            total++; passed += Test("plain-fn temp chained '+' operands", addChain.length() > 0, true);
        }

        // Named owned-string locals as `+` operands must NOT be double-freed: the locals own the
        // buffers and free once on scope exit; operator+ borrows them and frees nothing.
        {
            string addA = returnOwnedConcat("p");
            string addB = returnOwnedConcat("q");
            string addLocals = addA + addB;
            total++; passed += Test("named owned-string locals added (no double-free)", addLocals.length() > 0, true);
        }

        // Ternary over a PLAIN (non-`move`) owned-string return. The ternary deep-copies the
        // selected branch into an independent owned buffer for the local; the branch's own fresh
        // temp (a plain string-returning CALL) was not registered by the call path, so before the
        // fix it leaked after the copy. Both branches of a select are evaluated, so a temp on the
        // NON-selected branch must be freed too. Covered for a free function, a member function,
        // and interface dispatch. `cond` is derived from a runtime value so the select is real.
        {
            bool cond = total > 0;   // always true, but not a compile-time constant

            string tsel = cond ? returnOwnedConcat("t1") : "lit";       // free-fn owned branch
            total++; passed += Test("ternary plain-fn owned branch", tsel.length(), 8); // "hello t1"

            string tboth = cond ? returnOwnedConcat("a") : returnOwnedConcat("b"); // both branches call
            total++; passed += Test("ternary both-branch owned calls", tboth.length(), 7); // "hello a"

            string tmem = cond ? gr.greet("z") : "lit";                 // member-fn owned branch
            total++; passed += Test("ternary plain member-fn owned branch", tmem.length(), 4); // "hi-z"

            Labeler lb = default;
            lb.tag = "ta" + "g";                                        // owned field
            ILabel il = lb;
            string tvirt = cond ? il.label() : "lit";                   // interface-dispatch owned branch
            total++; passed += Test("ternary interface-dispatch owned branch", tvirt.length(), 4); // "tag!"

            // A named owning local as a branch must NOT be double-freed (the deep-copy keeps the
            // local's buffer intact); a borrow branch (list element) likewise stays owned by the list.
            string loc = returnOwnedConcat("k");
            string tloc = cond ? loc : "lit";
            total++; passed += Test("ternary named-local branch (no double-free)", tloc.length(), 7); // "hello k"
            total++; passed += Test("ternary named-local branch source live", loc.length(), 7);
        }
    }

    // === Bug 9: a method call on an owning-value RVALUE temp receiver frees the temp ===
    // `makeIntList(3).count()` consumed the temp as `this` and then dropped it - its buffer leaked.
    // An `alias` (borrow) receiver must still NOT be destructed here, or the owner double-frees.
    {
        total++; passed += Test("temp receiver count", makeIntList(3).count(), 3);
        total++; passed += Test("temp receiver chained", makeIntList(2).copy().count(), 2);

        dictionary<int, list<string>> holder = default;
        list<string> hv = {"p", "q"};
        holder.add(1, move hv);
        // holder.get(1) is an `alias` borrow of the slot: counting through it must not free it.
        total++; passed += Test("alias temp receiver borrowed", holder.get(1).count(), 2);
        total++; passed += Test("alias temp receiver source live", holder.get(1).get(0), "p");
    }

    // === `unique` field ownership: the synthesized destructor frees the pointee ===
    // Both the pointer BLOCK and the pointee's own owning fields must go; the oracle below
    // is what proves it (dropping `unique` from LeakUnique.slot makes it fail).
    {
        LeakUnique u = default;
        u.slot = new LeakPayload();
        u.slot->nums.add(7);
        total++; passed += Test("unique field live", u.slot->nums.count(), 1);

        LeakUniqueOuter o = default;
        o.inner = new LeakUnique();
        o.inner->slot = new LeakPayload();
        o.inner->slot->nums.add(8);
        total++; passed += Test("unique nested field live", o.inner->slot->nums.get(0), 8);
    }

    // === Stage 2: reassigning a `unique` field frees the old pointee ===
    // The leak oracle below is the only thing that proves this - a reassignment that merely
    // overwrote the slot would orphan 32 payloads (and their list<int> buffers) silently.
    {
        LeakUnique u = default;
        for (int i = 0; i < 32; i++)
        {
            u.slot = new LeakPayload();
            u.slot->nums.add(i);
        }
        total++; passed += Test("unique reassign live", u.slot->nums.get(0), 31);

        // Releasing via nullptr frees the last pointee early; teardown then finds null.
        u.slot = nullptr;
        total++; passed += Test("unique nullptr release", u.slot == nullptr, true);
    }

    // === Stage 3: `move` out of a `unique` field transfers ownership to the local ===
    // The sanctioned extraction (a plain copy is rejected - err_unique_delete_alias). The move
    // nulls the field, so exactly one owner frees: `delete owned` here, and teardown finds null.
    // The oracle proves both halves - a lost `move` would leak, a double-free would abort.
    {
        LeakUnique u = default;
        u.slot = new LeakPayload();
        u.slot->nums.add(9);

        LeakPayload* owned = move u.slot;
        total++; passed += Test("unique move-out field nulled", u.slot == nullptr, true);
        total++; passed += Test("unique move-out payload intact", owned->nums.get(0), 9);
        delete owned;
    }

    // === Brace-init of a `unique` field: the second field-store path owns identically ===
    // EmitOneFieldInit constructs a fresh slot, so it takes no reassign-free - the oracle proves
    // the field still ends up the sole owner and frees at teardown (a lost store would leak).
    {
        LeakUnique u = { slot = new LeakPayload() };
        u.slot->nums.add(4);
        total++; passed += Test("unique brace-init live", u.slot->nums.get(0), 4);
    }

    // === Brace-init `move` of an owning STRING into a field: transfer, not deep-copy ===
    // Regression for the brace-init/`=` parity class (instance #8): the second field-store path
    // deep-copied a `move`d string while the move had already suppressed the source's destructor,
    // orphaning the original buffer. The oracle (reportLeaks == 0) is what catches it; the plain
    // `s = b` case below still deep-copies (source stays usable), so both spellings are exercised.
    {
        string a = "hel" + "lo";
        ArrSBox mv = { s = move a };
        total++; passed += Test("brace-init move-string value intact", mv.s == "hello", true);

        string b = "wor" + "ld";
        ArrSBox cp = { s = b };
        total++; passed += Test("brace-init copy-string field intact", cp.s == "world", true);
        total++; passed += Test("brace-init copy-string source intact", b == "world", true);
    }

    // === `move` between two `unique` fields: one owner throughout ===
    // The plain copy is rejected (err_unique_field_to_field); this pins that the sanctioned
    // spelling still transfers - a double-free would abort, a lost move would leak.
    {
        LeakUnique a = default;
        LeakUnique c = default;
        a.slot = new LeakPayload();
        a.slot->nums.add(6);
        c.slot = move a.slot;
        total++; passed += Test("unique field-to-field move source nulled", a.slot == nullptr, true);
        total++; passed += Test("unique field-to-field move payload intact", c.slot->nums.get(0), 6);
    }

    // === `unique` field reached through an INTERFACE's byte-offset slot ===
    // The store site binds the flag from the interface's field declaration, so the reassign-free
    // fires there too. The oracle is what proves it: before the contract carried `unique`, these
    // 32 payloads (and their list<int> buffers) were orphaned one store at a time.
    {
        LeakIfaceBox b;
        for (int i = 0; i < 32; i++)
            leakStoreViaIface(b, i);
        total++; passed += Test("unique iface-slot reassign live", b.slot->nums.get(0), 31);

        // Release early through the interface slot; teardown then finds null (no double-free).
        b.slot = nullptr;
        total++; passed += Test("unique iface-slot nullptr release", b.slot == nullptr, true);
    }

    // === Container copy() element semantics (moves-or-shares-elements fix) ===
    // Each container's copy() must leave a value-type source intact (deep copy), transfer an
    // OWNED pointer element to the copy (source slot nulled - a shared pointee would double-free
    // at teardown), and copy an enum element bitwise. The leak oracle below proves no leak /
    // no double-free across all of it.
    {
        // list<owning-struct>: source survives, copy independent (was: source EMPTIED by a move).
        list<LeakRow> ls = default;
        LeakRow lr = default; lr.name = "aa" + "bb"; ls.add(move lr);
        list<LeakRow> lsCopy = ls.copy();
        total++; passed += Test("list<struct> copy source intact", ls.get(0).name, "aabb");
        total++; passed += Test("list<struct> copy independent",   lsCopy.get(0).name, "aabb");

        // list<int*> is a BORROWED view now: copy() shallow-copies the pointers (no move, no
        // ownership transfer) - the source keeps its slot and both lists alias the same pointee,
        // which the caller owns and frees once. (Owning lists use list<unique int*>, whose copy()
        // is a compile error - see err_unique_list_copy.cb.)
        list<int*> lp = default;
        int* p0 = new int; *p0 = 7; lp.add(p0);
        list<int*> lpCopy = lp.copy();
        int* lpElem = lpCopy.get(0);
        total++; passed += Test("list<ptr> borrow copy keeps source", lp.get(0) != nullptr, true);
        total++; passed += Test("list<ptr> borrow copy aliases same", lp.get(0) == lpElem, true);
        total++; passed += Test("list<ptr> borrow copy sees pointee", *lpElem, 7);
        int* lpOwner = lpCopy.take(0); delete lpOwner;   // free the shared int exactly once

        // list<enum>: element copy is bitwise; source and copy both hold the value (was: build failed).
        list<LeakColor> lc = default; lc.add(LeakColor.LC_Green); lc.add(LeakColor.LC_Blue);
        list<LeakColor> lcCopy = lc.copy();
        total++; passed += Test("list<enum> copy source intact", (i64)lc.get(1), (i64)LeakColor.LC_Blue);
        total++; passed += Test("list<enum> copy value",         (i64)lcCopy.get(0), (i64)LeakColor.LC_Green);

        // dictionary<int, owning-struct>: the STATUS_HEAP_CORRUPTION case - now deep-copies (independent).
        dictionary<int, LeakRow> dm = default;
        LeakRow dv = default; dv.name = "cc" + "dd"; dm.set(1, move dv);
        dictionary<int, LeakRow> dmCopy = dm.copy();
        total++; passed += Test("dict<struct> copy source intact", dm.get(1).name, "ccdd");
        total++; passed += Test("dict<struct> copy independent",   dmCopy.get(1).name, "ccdd");

        // dictionary<int, int*>: the dict OWNS value pointers, so copy() MOVES them (source value nulled).
        dictionary<int, int*> dp = default;
        int* dpp = new int; *dpp = 9; dp.set(2, dpp);
        dictionary<int, int*> dpCopy = dp.copy();
        int* dpElem = dpCopy.get(2);
        total++; passed += Test("dict<ptr-value> copy transfers ownership", dp.get(2) == nullptr, true);
        total++; passed += Test("dict<ptr-value> copy owns pointee",        *dpElem, 9);

        // hashset<owning-struct>: deep-copied into the slot and freed at teardown (no leak, source intact).
        hashset<LeakName> hn = default;
        LeakName nm = default; nm.n = "ee" + "ff"; hn.add(nm);
        total++; passed += Test("hashset<struct> source intact",  nm.n, "eeff");
        total++; passed += Test("hashset<struct> contains copy",  hn.contains(nm), true);
    }

    // === Whole-struct assignment through a pointer deref (`*pc = *pa`) auto-moves ===
    // A shallow bitwise store used to alias owned buffers (both dtors free -> double-free) and
    // orphan the destination's old value (leak). The deref lvalue is now recognized as an owning
    // destination: the old destination is destructed, the source moved in, and the source zeroed
    // so its dtor is a no-op. The leak oracle below proves single-owner freedom for both a `unique`
    // pointer field and a plain owning `string` field (the hole was general, not `unique`-specific).
    {
        LeakUnique a = default;
        LeakUnique c = default;
        a.slot = new LeakPayload(); a.slot->nums.add(41);
        c.slot = new LeakPayload(); c.slot->nums.add(99);   // c's old payload must be freed on the store
        LeakUnique* pa = &a;
        LeakUnique* pc = &c;
        *pc = *pa;                                          // move a's payload into c; a.slot zeroed
        total++; passed += Test("deref-assign unique source zeroed", a.slot == nullptr, true);
        total++; passed += Test("deref-assign unique dest owns moved", c.slot->nums.get(0), 41);

        LeakRow sa = default;
        LeakRow sc = default;
        sa.name = "de" + "ref";                             // owned "deref"
        sc.name = "ol" + "d";                               // owned "old" - freed on the store
        LeakRow* spa = &sa;
        LeakRow* spc = &sc;
        *spc = *spa;                                        // move sa.name into sc; sa.name zeroed
        total++; passed += Test("deref-assign string dest owns moved", sc.name, "deref");
        total++; passed += Test("deref-assign string source zeroed", sa.name.length(), 0);
    }

    // === Owning fixed-array FIELD: full destruction + independent deep copy ===
    // The synthesized destructor walks all N elements; the memberwise copy deep-copies each, so a
    // .copy() is independent and both structs free every element exactly once. Multi-dim exercises
    // the flattened walk. Before the fix the whole array field was skipped (leak); a naive walk
    // without the deep copy turned it into a .copy() double-free (the leak oracle catches both).
    {
        ArrHolder h = default;
        h.items[0].s = "aa" + "bb";
        h.items[1].s = "cc" + "dd";
        h.items[2].s = "ee" + "ff";
        ArrHolder h2 = h.copy();
        h2.items[0].s = "zz" + "yy";                        // mutate copy; original must be intact
        total++; passed += Test("arr-field copy independent (src)", h.items[0].s, "aabb");
        total++; passed += Test("arr-field copy independent (dst)", h2.items[0].s, "zzyy");
        total++; passed += Test("arr-field copy element 2",         h2.items[2].s, "eeff");
        // h and h2 destruct here - every owned element must free exactly once (oracle below).
    }

    // === Interface-element list ownership (the plan's Evidence leak, finally fixed) ===
    // list<unique IShapeLeak> OWNS boxed elements (freed via the vtable dtor slot); a bare
    // list<IShapeLeak> BORROWS and frees nothing - scope-owned objects survive.
    {
        g_shapeDtor = 0;
        {
            list<unique IShapeLeak> shapes;
            shapes.add(new CircleLeak());
            shapes.add(new CircleLeak());
            shapes.add(new CircleLeak());
            IShapeLeak taken = shapes.take(0);
            delete taken;
            total++; passed += Test("list<unique iface> take+delete dtor", g_shapeDtor, 1);
        }
        total++; passed += Test("list<unique iface> dtor frees rest", g_shapeDtor, 3);

        g_shapeDtor = 0;
        {
            list<unique IShapeLeak> owner;
            owner.add(new CircleLeak());
            owner.add(new CircleLeak());
            {
                list<IShapeLeak> view;
                view.add(owner.get(0));
                view.add(owner.get(1));
                total++; passed += Test("bare list<iface> view count", view.count(), 2);
            }
            total++; passed += Test("bare list<iface> view frees nothing", g_shapeDtor, 0);
        }
        total++; passed += Test("bare list<iface> owner frees all", g_shapeDtor, 2);
    }

    // === Scalar `unique` interface local/param teardown (the stage-5 leak, finally fixed) ===
    // A scalar `unique IShapeLeak` local owns its heap-boxed object and frees it at scope exit
    // through the vtable dtor slot - mirroring the container leg above and the `unique Circle*`
    // scalar. A `unique IShapeLeak` PARAM (a synthesized move param) frees it in the callee.
    {
        g_shapeDtor = 0;
        { unique IShapeLeak s = new CircleLeak(); }
        total++; passed += Test("scalar unique iface local teardown", g_shapeDtor, 1);

        g_shapeDtor = 0;
        sinkShape(new CircleLeak());
        total++; passed += Test("unique iface move-param teardown", g_shapeDtor, 1);

        // nullptr owns nothing: scope exit is a null-guarded no-op, no dtor runs.
        g_shapeDtor = 0;
        { unique IShapeLeak s = nullptr; }
        total++; passed += Test("scalar unique iface null no-op", g_shapeDtor, 0);

        // Consuming an owning local by move/pass transfers ownership to the callee; the source is
        // disowned so it frees exactly ONCE (double-free before the fix).
        g_shapeDtor = 0;
        { unique IShapeLeak s = new CircleLeak(); sinkShape(move s); }
        total++; passed += Test("consume unique iface local by move frees once", g_shapeDtor, 1);

        g_shapeDtor = 0;
        { unique IShapeLeak s = new CircleLeak(); sinkShape(s); }
        total++; passed += Test("consume unique iface local by pass frees once", g_shapeDtor, 1);

        // Moving an owning local into an owning container: the container owns it, the source is
        // disowned - freed exactly once at the container's teardown.
        g_shapeDtor = 0;
        {
            list<unique IShapeLeak> xs;
            unique IShapeLeak s = new CircleLeak();
            xs.add(move s);
        }
        total++; passed += Test("move unique iface local into container frees once", g_shapeDtor, 1);

        // Reassigning an owning `unique` interface local frees the OLD object first, then the new
        // one at scope exit: two objects created, two freed, none leaked.
        g_shapeDtor = 0;
        { unique IShapeLeak s = new CircleLeak(); s = new CircleLeak(); }
        total++; passed += Test("reassign unique iface local frees old and new", g_shapeDtor, 2);

        // Exclusive branches each consuming a move interface param once and returning: the
        // returning branch's move must not poison the fall-through path (compile regression), and
        // every object frees exactly once. Each sel exercises one path; sel=2 is the fall-through.
        g_shapeDtor = 0;
        { unique IShapeLeak r = pickShape(new CircleLeak(), new CircleLeak(), 0); }
        total++; passed += Test("exclusive-branch consume path 0 frees both", g_shapeDtor, 2);
        g_shapeDtor = 0;
        { unique IShapeLeak r = pickShape(new CircleLeak(), new CircleLeak(), 1); }
        total++; passed += Test("exclusive-branch consume path 1 frees both", g_shapeDtor, 2);
        g_shapeDtor = 0;
        { unique IShapeLeak r = pickShape(new CircleLeak(), new CircleLeak(), 2); }
        total++; passed += Test("exclusive-branch consume fall-through frees both", g_shapeDtor, 2);

        // Pointer flavor of the exclusive-return pattern: compiles and frees each object once.
        g_shapeDtor = 0;
        { unique PtrLeak* r = pickPtr(new PtrLeak(), new PtrLeak(), 0); }
        total++; passed += Test("exclusive-branch ptr consume path 0 frees both", g_shapeDtor, 2);
        g_shapeDtor = 0;
        { unique PtrLeak* r = pickPtr(new PtrLeak(), new PtrLeak(), 2); }
        total++; passed += Test("exclusive-branch ptr consume fall-through frees both", g_shapeDtor, 2);

        // Dead code after a return in a consuming branch must not spuriously flag the fall-through
        // use of the same param (compile regression); each object still frees exactly once.
        g_shapeDtor = 0;
        { unique IShapeLeak r = deadCodePick(new CircleLeak(), new CircleLeak(), 0); }
        total++; passed += Test("dead-code-after-return returning path frees both", g_shapeDtor, 2);
        g_shapeDtor = 0;
        { unique IShapeLeak r = deadCodePick(new CircleLeak(), new CircleLeak(), 1); }
        total++; passed += Test("dead-code-after-return fall-through frees both", g_shapeDtor, 2);

        // Return-block early-exit: an unconditional return-block makes the branch return (the move
        // after it is dead); a conditional one may fall through. Both compile and free exactly once.
        g_shapeDtor = 0; rbUncondFree(new PtrLeak(), 1);
        total++; passed += Test("return-block unconditional exit frees once", g_shapeDtor, 1);
        g_shapeDtor = 0; rbUncondFree(new PtrLeak(), 0);
        total++; passed += Test("return-block unconditional skip frees once", g_shapeDtor, 1);
        g_shapeDtor = 0; rbCondFree(new PtrLeak(), 5);
        total++; passed += Test("return-block conditional fall-through frees once", g_shapeDtor, 1);
        g_shapeDtor = 0; rbCondFree(new PtrLeak(), -1);
        total++; passed += Test("return-block conditional exit frees once", g_shapeDtor, 1);
    }

    // === Leak oracle: everything above must have freed on scope exit ===
    u64 leaks = HeapAudit.reportLeaks();
    total++; passed += Test("HeapAudit live allocations", (i64)leaks, (i64)0);

    // === Bug 10: globals are destructed on main's normal return (see _gLeakGate above) ===
    // Populated after the oracle above so it still sees zero; _gLeakGate's destructor re-audits
    // once these have been torn down and fails the process if a buffer survived.
    _gNums.add(1);
    _gNums.add(2);
    _gMap.set("k", "v");
    total++; passed += Test("global list live", _gNums.count(), 2);
    total++; passed += Test("global dict live", _gMap.get("k"), "v");

    if (passed == total)
    {
        printf("ALL %d collection-leak regression tests passed.\n", total);
        return 0;
    }
    printf("%d of %d collection-leak regression tests FAILED.\n", total - passed, total);
    return 1;
}
