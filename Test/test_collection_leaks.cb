// Regression tests for the "Fix string/list/dictionary ownership leaks + double-free"
// change. Each fixed path is exercised over mixed/nested data structures and asserted
// for both correct behavior AND leak-freedom via the HeapAudit oracle (every operator
// new is recorded, every operator delete checked; reportLeaks() must return 0 and a
// double free aborts deterministically). HeapAudit needs an -o build, which test.bat
// uses. The bugs this guards against:
//
//   1. string.split() built each part inline as `string p = default; p._ptr = buf;`,
//      which the static ownership tracker does NOT mark owning - so parts added to the
//      returned list<string> leaked on the list's destruction. Fix routes every part
//      through the `move`-returning _str_owned_range() helper.
//   2. list<T>.set / removeAt / clear did not destruct an overwritten/removed/cleared
//      VALUE-TYPE element that owns buffers (string, or a nested container) - it leaked.
//      (Only pointer elements were freed before.)
//   3. dictionary<K,V>.add / set stored the incoming `move V` with a plain copy-assign,
//      so `value`'s scope-exit destructor freed a buffer the slot now aliased - a double
//      free for a value-type V with a real destructor (e.g. a nested list<string>).
import "string.cb";
import "list.cb";
import "dictionary.cb";
import "hashset.cb";
import "hpc/btree.cb";
import "array.cb";
import "queue.cb";
import "stack.cb";
import "diagnostic/heap_audit.cb";
import "test_helper.cb";

// Owning aggregates with managed fields and NO user copy() - exercise the synthesized
// memberwise copy() and the field-reassignment destruct-old (Bugs 5 and 6 below).
struct LeakRow { string name = default; };
struct LeakBox { list<int> nums = default; };
struct LeakPair { string name = default; list<int> nums = default; };
// Owning fixed-array FIELD (`ArrSBox items[3]`): the synthesized destructor must free EVERY element
// (was a leak - the whole array field was skipped), and the memberwise copy() must deep-copy each
// element so a .copy() is independent (not a shared-buffer double-free). (Multi-dimensional array
// FIELDS are not expressible in the grammar; the flattened walk is exercised by array LOCALS.)
// See internal/issue/fixed-array-elements-not-destructed.md.
struct ArrSBox   { string s = default; };
struct ArrHolder { ArrSBox items[3] = default; };

// `return move <named struct local>` was classified as a BORROW return, so the compiler
// emitted `and i32 %x, 0x7FFFFFFF` to strip the owned bits off the returned aggregate. The
// caller got a non-owning struct, its destructor found nothing to free, and the owning
// `string` field leaked. Both a plain return type and a `move` return type were affected.
struct MvRow { string name = default; MvRow copy() { MvRow v; v.name = name.copy(); return move v; } };
MvRow      mvPlainType() { MvRow r = default; r.name = "mv" + "a"; return move r; }
move MvRow mvMoveType()  { MvRow r = default; r.name = "mv" + "b"; return move r; }
// Owning Lambda<> field (lambda Option A): a closure stored in a struct field owns its heap
// env and is freed by the struct's destructor, like a string/list field.
struct LeakHandler { Lambda<int(int)> fn = default; };
// Same, but the closure RETURNS an owned string - the shape that exposed the field-callee leak.
struct LeakLabeler { Lambda<string(int)> label = default; };

// Regression for "container copy moves-or-shares elements": copy() deep-copies value-type
// elements (source intact), transfers owned POINTER elements to the copy (single owner - a
// shared pointee would double-free), and bitwise-copies enum elements. LeakName needs hash()
// and == to be a hashset element.
enum LeakColor : int { LC_Red, LC_Green, LC_Blue };
struct LeakName { string n = default; int hash() { return (int)n.length(); } };
bool operator==(LeakName a, LeakName b) { return a.n == b.n; }

// `unique T*` field: the struct owns the raw pointer and the SYNTHESIZED destructor frees it.
// Without the keyword these leak - an unmarked pointer field is never auto-freed.
struct LeakPayload { list<int> nums = default; };
struct LeakUnique  { unique LeakPayload* slot = nullptr; };
// Nested: freeing the outer field runs LeakUnique's synthesized dtor, which frees its own field.
struct LeakUniqueOuter { unique LeakUnique* inner = nullptr; };

// Generic struct with a bare SCALAR field `T v`: instantiated with `unique PtrLeak*`, the field
// is made unique by SUBSTITUTION - there is no `unique` token on the field declaration itself.
// The synthesized destructor's scalar-free arm must widen from IsUnique to
// (IsUnique || IsUniqueTypeArg) (LLVMBackend.h ~line 3079) or this pointee silently leaks.
// Instantiated with a plain `PtrLeak*` instead, the field is a BORROW and must free nothing.
struct LeakGenSlot<T> { T v = default; };

// `unique` on an INTERFACE field: ownership rides the contract, because a store through the
// interface's byte-offset slot is dispatched dynamically and cannot see the concrete type.
// Both sides must declare it (err_unique_iface_field_impl_only / _iface_only).
interface ILeakSlot
{
    unique LeakPayload* slot;
};

class LeakIfaceBox : ILeakSlot
{
    unique LeakPayload* slot = nullptr;
};

// Reassign through the interface slot. The old pointee - and its list<int> buffer - must be
// freed here; a store that only overwrote the slot would orphan them silently.
void leakStoreViaIface(ILeakSlot h, int v)
{
    h.slot = new LeakPayload();
    h.slot->nums.add(v);
}

// Function-type alias: ownership/clone/free flow through the alias exactly as through the
// underlying Lambda<int(int)>, so clone-by-default reassignment must not leak.
using EVENT = Lambda<int(int)>;

// Returns a CAPTURING closure - its env must be heap-owned so the value can escape the frame
// (Bug 8). Built in a local and returned by variable (the escape pattern real code uses).
Lambda<int(int)> makeLeakAdder(int base)
{
    Lambda<int(int)> f = (int x) => x + base;
    return f;
}

// Same, but returns the capturing lambda LITERAL directly (no intermediate variable). This is a
// distinct codegen path from makeLeakAdder; the returned env must still transfer to the caller's
// local and free exactly once (no leak, no double-free) when that local goes out of scope.
Lambda<int(int)> makeLeakAdderLiteral(int base)
{
    return (int x) => x + base;
}

// Borrow a closure by value and invoke it (exercises the by-value argument copy site - the
// caller's temporary env is freed at end of the call statement by FlushOwnedClosureTemps).
int applyLeak(Lambda<int(int)> fn, int v) { return fn(v); }

// === String-RETURN ownership (runtime-bit model) regression helpers ===
// Before the fix, the string destructor was gated on a COMPILE-TIME `IsOwningString` flag
// instead of the runtime OWNED bit (_len high bit), so a genuinely-owned string returned
// from a PLAIN (non-`move`) `string` function was never freed by the caller's local -> LEAK.
// The helpers below exercise the return shapes the fix made leak- and double-free-clean:
//   - returnOwnedConcat: returns a fresh owned temp (operator+ result)
//   - returnOwnedLocal:  returns a whole owned LOCAL (moved out - source zeroed on return)
//   - Greeter.greet:     owned string returned from a MEMBER function
// while a list element read confirms a BORROW return is handed back with the owned bit
// cleared, so the caller does not double-free a buffer the container still owns.
string returnOwnedConcat(string who)
{
    string g = "hello ";
    return g + who;            // owned concat temp, plain `string` return type
}

string returnOwnedLocal()
{
    string s = "x" + "yz";     // owned local
    return s;                  // moved to caller: source zeroed so it is not double-freed
}

struct Greeter
{
    string prefix = default;
    string greet(string who) { return prefix + who; }   // owned result from a member fn
};

// By-value owning-struct temp field-extract: a `move` return OWNS its fields, so a temp whose
// field is read transiently is fully destructed at end-of-statement (no leak). A plain accessor
// (`list.get`) returns a shallow ALIAS, so its temp must NOT be destructed (a double-free aborts).
struct TempTok { string text = default; string extra = default; };
move TempTok makeTempTok(int n) { TempTok t = default; t.text = "tok" + n.toString(); t.extra = "ex" + n.toString(); return t; }
// PLAIN (non-move) owning return: builds a fresh owned local and transfers it out by value. An
// unbound transient field read (`makePlainTok(3).text.length()`) used to LEAK - the temp owned
// the buffer but, unbound, was never destructed. It is now dropped at end-of-statement (no leak).
TempTok makePlainTok(int n) { TempTok t = default; t.text = "tok" + n.toString(); t.extra = "ex" + n.toString(); return t; }
// Destination for the implied-move cases: a `move`-temp's owning field transfers into this slot.
struct TokHolder { string slot = default; };
// Phase B: returning a `move`-temp's owning field moves it out (ownership escapes to the caller).
// String field and struct field both move; the temp's other field still frees at end-of-statement.
string returnMovedText(int n) { return makeTempTok(n).text; }
struct InnerTok { string s = default; };
struct OuterTok { InnerTok inner = default; };
move OuterTok makeOuterTok(int n) { OuterTok o = default; o.inner.s = "in" + n.toString(); return o; }
InnerTok returnMovedInner(int n) { return makeOuterTok(n).inner; }

// Interface with a PLAIN (non-`move`) string method: the implementer returns a freshly owned
// concat, so a virtual call physically carries the owned bit. Exercises the interface-dispatch
// (CallInterfaceMethod) leg of the ternary-branch cleanup - a distinct codegen path from a
// direct free-function/member call, but the same runtime-owned-bit contract.
interface ILabel { string label(); };
class Labeler : ILabel { string tag = default; string label() { return tag + "!"; } };

// Interface-element ownership: `list<unique IShapeLeak>` owns its boxed elements and frees them
// through the vtable dtor slot; bare `list<IShapeLeak>` borrows and frees nothing.
int g_shapeDtor = 0;
interface IShapeLeak { int area(); };
class CircleLeak : IShapeLeak { int r = 0; int area() { return r * r; } ~CircleLeak() { g_shapeDtor = g_shapeDtor + 1; } };

// A `unique` interface PARAM takes ownership: the callee frees the boxed object at scope exit.
void sinkShape(unique IShapeLeak s) {}

// Regression (mirrors ui_native.cb reconcilePath): mutually-exclusive branches that each consume
// a `move` interface param exactly once and immediately return must COMPILE - a move inside a
// branch that unconditionally returns must not leak its moved state to the fall-through path. At
// runtime each owned object is freed exactly once.
move IShapeLeak pickShape(move IShapeLeak a, move IShapeLeak b, int sel)
{
    if (sel == 0) { sinkShape(a); return b; }
    if (sel == 1) { sinkShape(a); return b; }
    sinkShape(b);
    return a;
}

// Pointer flavor of the same exclusive-return pattern: must compile and free each object once.
struct PtrLeak { int v = 0; ~PtrLeak() { g_shapeDtor = g_shapeDtor + 1; } };

// Regression: a value struct with a USER destructor over a RAW pointer field (not `unique`) and NO
// copy() is NON-copyable - the memberwise synth would shallow-share the pointer while the dtor frees
// it on both copies (double-free). IsCopyableType now rejects that shape, so `RawResLeak b = a;`
// MOVES (single owner). A sibling with a hand-written copy() stays copyable (deep, independent).
int g_rawNodeFreed = 0;
struct RawResNodeLeak { int v = 0; };
struct RawResLeak
{
    RawResNodeLeak* node = default;
    ~RawResLeak() { if (node != nullptr) { g_rawNodeFreed = g_rawNodeFreed + 1; delete node; } }
};
RawResLeak mkRawRes(int n) { RawResLeak r = default; r.node = new RawResNodeLeak(); r.node.v = n; return move r; }
struct RawResCopyable
{
    RawResNodeLeak* node = default;
    RawResCopyable copy()
    {
        RawResCopyable c = default;
        if (node != nullptr) { c.node = new RawResNodeLeak(); c.node.v = node.v; }
        return move c;
    }
    ~RawResCopyable() { if (node != nullptr) { g_rawNodeFreed = g_rawNodeFreed + 1; delete node; } }
};

// Trivial POD value struct (no owning fields, no destructor): the "copies, exit 0" row of the
// container double-free matrix - a multi-field aggregate is a distinct copy/store path from a
// scalar `int`, and its teardown must free nothing (a spurious free would abort HeapAudit).
struct QPoint { int x = 0; int y = 0; };

// `unique T* f[N]` as a struct FIELD: the synthesized destructor walks the array and releases
// every slot. UniqSlotBag is the hand-written spelling; UniqSlotBox<V> is the same shape reached
// through generic substitution (btree_node's), which used to be accepted and silently leak.
struct UniqSlotBag { unique PtrLeak* slots[4] = default; };
struct UniqSlotBox<V> { V slots[4] = default; };
// Scalar `unique IFace` field: a boxed interface value is a fat pointer, released via vtable dtor.
struct UniqIfaceSlot { unique IShapeLeak v = default; };
// Non-copyable value element: owns a `unique` pointer and has no copy(), so the COPYING
// dictionary/hashset insert is poisoned and only the `move` transfer overload is usable.
struct LeakHolder { unique PtrLeak* slot = nullptr; int k = 0; int hash() { return k; } };
bool operator==(LeakHolder a, LeakHolder b) { return a.k == b.k; }

// Regression for internal/issue/discard-move-vs-decl-move-element-ownership-disparity.md:
// `_ = move _data[i]` (the DISCARD form) must release an owning container element exactly like
// `T tmp = move _data[i]` (the DECL form) - an owning `unique T*`/`unique IFace` element frees
// exactly ONCE, a bare borrow element frees NOTHING. DiscardBag exercises the discard spelling
// directly (in `discardAll` AND in the destructor's teardown loop) so the two forms are proven
// equivalent for every element kind. Ownership DEFERS to T, so there is no `if const` here: the
// slot-move re-derives the element's true ownership at the move site (ElementOwningUnique).
struct DiscardBag<T>
{
    T*  _data  = nullptr;
    int _count = 0;

    void _ensure()
    {
        // Fixed capacity keeps the helper minimal; every test bag holds well under 16 elements.
        if (_data == nullptr) _data = new T[16];
    }

    void add(T value)
    {
        _ensure();
        _data[_count] = move value;   // move-sink for `unique`; copy/move for a value type
        _count++;
    }

    // Release EVERY element to nowhere via the discard-move form, leaving zeroed dead slots.
    void discardAll()
    {
        for (int i = 0; i < _count; i++) _ = move _data[i];
        _count = 0;
    }

    int count() { return _count; }

    ~DiscardBag()
    {
        // Teardown ALSO uses the discard form: any element still held frees exactly once; a slot
        // already emptied by discardAll is zeroed, so a second move over it is a safe no-op.
        for (int i = 0; i < _count; i++) _ = move _data[i];
        if (_data != nullptr) delete[_] _data;
    }
};

// Stage 3 (owning-value move-sink): a free function whose plain by-value owning param is
// UNCONDITIONALLY moved becomes a synthesized sink - a caller's owning local is consumed with
// NO `move` keyword and its source nulled, so exactly one owner frees. Direct (non-container)
// regression for internal/plan/container-ownership-transparency.md gap 1.
string     g_sinkStr    = default;
LeakHolder g_sinkHolder = default;
LeakRow    g_sinkRow    = default;
void strSink(string s)     { g_sinkStr = move s; }
void holderSink(LeakHolder v) { g_sinkHolder = move v; }
// Copyable owning-value struct sink: the arg below is a `.copy()` RVALUE TEMP - it must move
// into the slot and NOT also be freed at end-of-full-expression (else slot + temp double-free).
void rowSink(LeakRow v)    { g_sinkRow = move v; }
// Owning-value CLOSURE sink (Increment 1): a fat Lambda is an owning value like string, so a plain
// by-value param the body moves is a synthesized sink - the caller's closure (named local OR rvalue
// temp) is consumed with NO `move` keyword, its env transferred into the slot (single owner).
Lambda<int(int)> g_sinkFn = default;
void fnSink(Lambda<int(int)> f) { g_sinkFn = move f; }
// If-const laundering residual (internal/issue/borrow-launder-residual-if-const-body-move.md):
// a generic method whose ONLY move of its by-value param sits inside a LIVE `if const` branch
// must classify the param a move-sink for that instantiation (caller nulled, single owner), not a
// borrow. For non-copyable LeakHolder the `!is_copyable` arm is live, so `v` is consumed and the
// local `s` frees the held PtrLeak exactly once - no leak, and the nulled source is no double-free.
struct IfConstProbe<T> {
    void take(T v) {
        if const (!is_copyable(T)) { T s = move v; }
    }
};
void delPtr(move PtrLeak* p) {}
move PtrLeak* pickPtr(move PtrLeak* a, move PtrLeak* b, int sel)
{
    if (sel == 0) { delPtr(a); return b; }
    if (sel == 1) { delPtr(a); return b; }
    delPtr(b);
    return a;
}

// A `move` consumed in a branch that returns, with a DEAD statement after the return: the branch
// must still read as returned (the dead statement reopens a live block that would otherwise hide
// the return), so its move does not spuriously poison the fall-through use of the same param.
move IShapeLeak deadCodePick(move IShapeLeak a, move IShapeLeak b, int sel)
{
    if (sel == 0) { sinkShape(a); return b; int dead = 5; }
    sinkShape(a);
    return b;
}

// Return-block functions inline an early CALLER-EXIT (their `return` returns from the caller). The
// move analysis must model that exit: an UNCONDITIONAL return-block makes the enclosing branch
// return (a following move is dead), while a CONDITIONAL one may fall through (a following move
// stays live). Both must compile and free each object exactly once.
void rbExitLeak() { return { return; }; }
void rbMaybeLeak(int x) { return { if (x < 0) { return; } }; }
void rbUncondFree(move PtrLeak* a, int c)
{
    if (c > 0) { rbExitLeak(); delPtr(a); }   // rbExitLeak returns from here; delPtr(a) is dead
    delPtr(a);
}
void rbCondFree(move PtrLeak* a, int c)
{
    rbMaybeLeak(c);                            // may return here (c < 0) or fall through (c >= 0)
    delPtr(a);
}

// PLAIN (non-`move`) string return that hands back a freshly owned concat. Passing its result -
// or an owned local bound from it - bare into list<string>.add(move)/set(move) used to LEAK: the
// move-arg lowering heap-copied a fresh buffer for the slot (the static owned flag is unset for a
// plain return / bare local read) and orphaned the runtime-owned original. The lowering now
// branches on the runtime owned bit: transfer when already owned, copy only literals/views.
string plainOwnedStr(int n) { return "owned" + n.toString(); }

// Returns an owning container BY VALUE - the caller owns the result. Used as an rvalue-temp
// method receiver below (Bug 9).
list<int> makeIntList(int n)
{
    list<int> v = default;
    int i = 0;
    while (i < n) { v.add(i); i++; }
    return v;
}

// === Bug 10: global owning values were never destructed ===
// Globals are destructed on main's normal return, in REVERSE definition order. `_gLeakGate` is
// defined FIRST, so it is destructed LAST - its destructor observes the container globals below
// already torn down, and fails the process if any of their buffers survived. The containers are
// populated only at the END of main (after the in-main leak oracle), so that oracle still sees
// zero live allocations.
struct GlobalLeakGate
{
    int _pad = 0;
    ~GlobalLeakGate()
    {
        if (HeapAudit.reportLeaks() != 0u)
        {
            printf("FAIL: global owning values were not destructed at exit.\n");
            exit(1);
        }
    }
};
GlobalLeakGate            _gLeakGate = default;
list<int>                 _gNums     = default;
dictionary<string, string> _gMap     = default;

extern int main()
{
    HeapAudit.enable();

    int passed = 0;
    int total = 0;

    // === Bug 1: string.split() parts are owned by the returned list ===
    // The list and all of its split-produced string elements must free on scope exit.
    {
        string csv = "alpha,beta,gamma,delta";
        list<string> parts = csv.split(",");
        total++; passed += Test("split count", parts.count(), 4);
        total++; passed += Test("split[0]", parts.get(0), "alpha");
        total++; passed += Test("split[3]", parts.get(3), "delta");

        // char separator overload + trailing-empty element path
        string path = "a/b/c/";
        list<string> segs = path.split('/');
        total++; passed += Test("split(char) trailing-empty count", segs.count(), 4);
        total++; passed += Test("split(char)[2]", segs.get(2), "c");
        total++; passed += Test("split(char) trailing empty", segs.get(3), "");
    }

    // === `_ = move <local>;` explicitly releases an owning local; scope-exit must not double-free ===
    // Releasing a string / unique pointer / owning container frees its buffer NOW; the slot is nulled
    // so the scope-exit destructor is a no-op. HeapAudit (reportLeaks below) proves no leak and no
    // double-free. A borrow/primitive release is a harmless no-op, so the value stays usable.
    {
        string s = "a long enough string to force a heap buffer allocation here";
        total++; passed += Test("release precheck len", (int)s.length(), 59);
        _ = move s;                        // frees the buffer now; scope exit sees a nulled slot

        list<string> ls = {"one", "two", "three"};
        total++; passed += Test("release list precheck", ls.count(), 3);
        _ = move ls;                       // frees the list and its owned elements now

        int keep = 41;
        _ = move keep;                     // primitive: no-op, still usable
        total++; passed += Test("release primitive is no-op", keep, 41);
    }

    // === Bug 2a: list<string>.set overwrites and frees the old owning element ===
    {
        list<string> ls = {"aaa", "bbb", "ccc"};
        ls.set(1, "OVERWRITTEN");          // old "bbb" must be destructed, new value moved in
        total++; passed += Test("list set value", ls.get(1), "OVERWRITTEN");
        total++; passed += Test("list set keeps count", ls.count(), 3);
    }

    // === Bug 2d: bare owned string moved into list<string>.add / .set adopts (no leak) ===
    // A call result and a named local (both runtime-owned but NOT statically flagged) moved into
    // a `move string` param must transfer their buffer into the slot, not orphan it via a copy.
    {
        list<string> ls = default;
        string s = plainOwnedStr(0);
        ls.add(s);                         // bare named local -> add(move)
        ls.add(plainOwnedStr(1));          // bare call result  -> add(move)
        ls.add("lit2");                    // literal still heap-copied (owns an independent buffer)
        total++; passed += Test("bare-move add count", ls.count(), 3);
        total++; passed += Test("bare-move add[0]", ls.get(0), "owned0");
        total++; passed += Test("bare-move add[1]", ls.get(1), "owned1");

        ls.set(0, plainOwnedStr(2));       // bare call result  -> set(move), old freed
        string s2 = plainOwnedStr(3);
        ls.set(1, s2);                     // bare named local  -> set(move), old freed
        total++; passed += Test("bare-move set[0]", ls.get(0), "owned2");
        total++; passed += Test("bare-move set[1]", ls.get(1), "owned3");
    }

    // === Bug 2b: list<string>.removeAt frees the removed owning element ===
    {
        list<string> ls = {"a", "b", "c", "d"};
        ls.removeAt(1);                    // "b" destructed in place, tail shifts left
        total++; passed += Test("removeAt count", ls.count(), 3);
        total++; passed += Test("removeAt shift", ls.get(1), "c");
    }

    // === Bug 2c: list<string>.clear frees every owning element, buffer reusable ===
    {
        list<string> ls = {"x", "y", "z"};
        ls.clear();                        // all three destructed
        total++; passed += Test("clear count", ls.count(), 0);
        ls.add("reused");                  // reuse the kept backing buffer after clear
        total++; passed += Test("reuse after clear", ls.get(0), "reused");
    }

    // === Fixed-array LOCAL elements are destructed (all N, not just element [0]) ===
    // `SBox[3] a;` default-constructs every element, so every element's owning string must be
    // freed at scope exit. The scope-exit destructor used to fire once on the array BASE pointer,
    // freeing element [0] only and leaking the rest. Concatenations force genuinely owned buffers
    // (a literal is borrowed and would free as a no-op, hiding the leak).
    {
        LeakRow[3] a;
        a[0].name = "aa" + "bb";
        a[1].name = "cc" + "dd";
        a[2].name = "ee" + "ff";
        total++; passed += Test("fixed-array elem [1] live", a[1].name, "ccdd");
        total++; passed += Test("fixed-array elem [2] live", a[2].name, "eeff");
    }

    // Multi-dimensional arrays are contiguous, so all N*M owning elements must be freed too.
    {
        LeakRow[2][3] m;
        m[0][0].name = "gg" + "hh";
        m[1][2].name = "ii" + "jj";
        total++; passed += Test("fixed-array multidim first", m[0][0].name, "gghh");
        total++; passed += Test("fixed-array multidim last", m[1][2].name, "iijj");
    }

    // === Bug 3a: dictionary<string,string> overwrite/add move the value (no double free) ===
    // string V has a real destructor, so a copy-assign of the move param would double free.
    {
        dictionary<string, string> d = {"k1": "v1"};
        d.set("k1", "v2");                 // overwrite same key: old "v1" freed, "v2" moved in
        total++; passed += Test("dict<str,str> overwrite", d.get("k1"), "v2");
        d.add("k2", "x");                  // add new (move)
        total++; passed += Test("dict<str,str> add", d.get("k2"), "x");
        total++; passed += Test("dict<str,str> count", d.count(), 2);
    }

    // === Bug 3b: dictionary with a NESTED container value (list<string>) ===
    // The headline double-free case: V owns buffers transitively. add()/set() must move.
    {
        dictionary<int, list<string>> d = default;
        list<string> v1 = {"p", "q"};
        d.add(1, move v1);                 // value moved into slot; v1 zeroed
        total++; passed += Test("dict nested add count", d.get(1).count(), 2);

        list<string> v2 = {"r", "s", "t"};
        d.set(1, move v2);                 // overwrite: old list<string> destructed, new moved in
        total++; passed += Test("dict nested overwrite count", d.get(1).count(), 3);
        total++; passed += Test("dict nested overwrite elem", d.get(1).get(2), "t");

        d.remove(1);                       // value-type V destructed on remove
        total++; passed += Test("dict nested remove", d.count(), 0);
    }

    // === Bug 9a: list<string>.add(move <owned-string-local>) TRANSFERS the buffer ===
    // A named owned string passed via `move` to a `move string` parameter must transfer its
    // buffer into the callee, not be defensively heap-copied - the copy would be handed to the
    // slot while the (already-emptied) source frees nothing, orphaning the original buffer: a
    // leak of one heap buffer per inserted element. Fix: ParseMoveExpression flags the moved
    // string value owning, so CreateOverloadedFunctionCall skips the defensive clone.
    {
        list<string> ls = default;
        int i = 0;
        while (i < 6) { string item = "item_" + i.toString(); ls.add(move item); i++; }
        total++; passed += Test("list<str> move-local add count", ls.count(), 6);
        total++; passed += Test("list<str> move-local add elem",  ls.get(5), "item_5");
    }

    // === Bug 9b: dictionary<string,K> deep-copies owning string KEYS and frees them ===
    // String keys built from owned temps ("k"+i) are deep-copied into the slot (a plain store
    // would alias the soon-freed argument and dangle); the slot's owned copy is freed on
    // remove() and on destruction. set()/remove() locate the key via that owned copy.
    {
        dictionary<string, int> d = default;
        int i = 0;
        while (i < 6) { d.add("k" + i.toString(), i); i++; }
        total++; passed += Test("dict<str,int> concat-key count",  d.count(), 6);
        total++; passed += Test("dict<str,int> concat-key lookup", d.get("k3"), 3);
        d.set("k3", 99);                       // overwrite existing key (found via the owned copy)
        total++; passed += Test("dict<str,int> set existing count", d.count(), 6);
        total++; passed += Test("dict<str,int> set value",          d.get("k3"), 99);
        d.remove("k2");                        // removed key's owned copy freed
        total++; passed += Test("dict<str,int> remove count",       d.count(), 5);
    }

    // === Bug 9c: hashset<string> owns its string ELEMENTS (deep-copied), frees them ===
    // Owned-temp elements are deep-copied into the slot; growth past initial capacity relocates
    // them with a raw slot-to-slot store (no per-element clone); remove()/clear()/the destructor
    // free the owned copies. (Pointer elements stay borrowed - see test_generics hashset<ptr>.)
    {
        hashset<string> hs = default;
        int i = 0;
        while (i < 10) { hs.add("e" + i.toString()); i++; }   // grows past initial capacity (rehash)
        total++; passed += Test("hashset<str> count",        hs.count(), 10);
        total++; passed += Test("hashset<str> contains",     hs.contains("e7"), true);
        total++; passed += Test("hashset<str> dup add",      hs.add("e3"), false);
        hs.remove("e7");                       // removed element's owned copy freed
        total++; passed += Test("hashset<str> after remove", hs.contains("e7"), false);
        hs.clear();                            // every owned element freed, buffer reusable
        total++; passed += Test("hashset<str> after clear",  hs.count(), 0);
    }

    // === Bug 4: owned-string temp operand of +, ==/!=/relational, and switch scrutinee ===
    // A move-returning string operand (e.g. `i.toString()`) is an owned temp that operator+,
    // the comparison operators, and a switch dispatch only borrow. Each must be freed at the end
    // of the full expression. Operands are registered in ParseAdditive/Equality/Relational; a
    // control-flow CONDITION flushes its temps in the condition block (the post-branch merge block
    // would drop them via the dominance guard and leak); a switch scrutinee's temps are re-homed to
    // resumeBlock (the dispatch reads the buffer, so they cannot be flushed before it).
    {
        int i = 0;
        int hits = 0;
        while (i < 8)
        {
            if (i.toString() == "3") hits++;            // equality operand temp
            if (i.toString() != "5") hits++;            // inequality operand temp
            if (i.toString() < "9") hits++;             // relational operand temp
            string r = "v" + i.toString();              // additive operand temp (r owns the result)
            if (r != i.toString()) hits++;              // both a named string and an operand temp
            i++;
        }
        for (int k = 0; k.toString() != "4"; k++) hits++;  // for-condition operand temp
        int m = 0;
        do { hits++; m++; } while (m.toString() != "3");   // do-while-condition operand temp

        // switch scrutinees: bare owned-call, concat (operand + result), and named (scope-freed).
        i = 0;
        while (i < 6)
        {
            switch (i.toString())            { case "2": hits = hits + 10;  break; default: hits++; break; }
            switch ("v" + i.toString())      { case "v3": hits = hits + 100; break; default: hits++; break; }
            string s = i.toString();
            switch (s)                       { case "1": hits = hits + 5;   break; default: hits++; break; }
            i++;
        }
        total++; passed += Test("owned-string temp expression hits", hits > 0, true);
    }

    // === Bug 5: reassigning an owning-value struct FIELD destructs the OLD value ===
    // `obj.field = newValue` previously overwrote the field's owned buffer without freeing
    // it (the field-store leak / copy-point #3). The destruct-old fix frees the prior value
    // first; the destructor is owned-bit/state-gated so a default or borrowed prior value is
    // a safe no-op (no double-free), and a self-assign must not free-then-dangle.
    {
        string base = "reassigned";
        LeakRow r = default;
        r.name = base.toUpper();          // owned "REASSIGNED"
        r.name = base.toLower();          // reassign: old owned buffer must be freed
        r.name = r.name;                  // self-assign: must NOT free-then-use
        r.name = "borrowed-literal";      // owned -> borrowed: old owned buffer freed
        total++; passed += Test("field reassign final value", r.name, "borrowed-literal");

        // move into a list<int> field (bypasses the X4 guard via `move`): old field freed
        LeakBox bx = default;
        list<int> v1 = default; v1.add(1);
        bx.nums = move v1;
        list<int> v2 = default; v2.add(2); v2.add(3);
        bx.nums = move v2;                // old bx.nums (v1's buffer) must be freed
        total++; passed += Test("field move-reassign count", bx.nums.count(), 2);
    }

    // === Bug 6: synthesized memberwise copy() deep-copies managed fields ===
    // A value type with managed fields and no explicit copy() gets an implicit memberwise
    // one: each managed field (string, list<int>) is deep-copied so the copy is independent,
    // and both the original and the copy free exactly once (no alias double-free, no leak).
    {
        string base = "src";
        LeakPair a = default;
        a.name = base.toUpper();          // "SRC"
        a.nums.add(10); a.nums.add(20);

        LeakPair b = a.copy();            // synthesized deep copy
        b.nums.add(30);                   // mutate the copy only
        total++; passed += Test("memberwise copy independent list (orig)", a.nums.count(), 2);
        total++; passed += Test("memberwise copy independent list (copy)", b.nums.count(), 3);
        total++; passed += Test("memberwise copy string value", b.name, "SRC");
    }

    // === Bug 7: closure (Lambda<...>) ownership - lambda Option A ===
    // A capturing closure owns a heap env. As an owning value type it must: be freed at scope
    // exit / struct teardown, clone-on-copy (.copy() and clone-by-default `b = a`), be stored
    // into a struct field cleanly, and have an unbound by-value-argument temporary freed at the
    // end of the call statement. Every path here must leave HeapAudit at zero.
    {
        // (a) capturing closure stored in a struct field, invoked after the defining frame is gone
        LeakHandler h = default;
        h.fn = makeLeakAdder(100);
        total++; passed += Test("closure field store invoke", h.fn(5), 105);

        // (b) returned capturing closure held in a local (escape via return)
        Lambda<int(int)> r = makeLeakAdder(1000);
        total++; passed += Test("closure return->var invoke", r(1), 1001);

        // (c) explicit .copy() -> two independent envs, both valid
        Lambda<int(int)> a = makeLeakAdder(10);
        Lambda<int(int)> b = a.copy();
        total++; passed += Test("closure copy independent (orig)", a(2), 12);
        total++; passed += Test("closure copy independent (copy)", b(3), 13);

        // (d) clone-by-default: `c = a` deep-copies the env, a stays valid (no use-after-move)
        Lambda<int(int)> c = a;
        total++; passed += Test("closure clone-by-default (clone)", c(7), 17);
        total++; passed += Test("closure clone-by-default (source live)", a(8), 18);

        // (e) lambda literal passed by value (unbound temp freed at statement end)
        int cap = 50;
        total++; passed += Test("closure literal by-value arg", applyLeak((int x) => x + cap, 4), 54);

        // (f) named closure passed by value (caller retains ownership; callee borrows)
        Lambda<int(int)> g = (int x) => x + 1;
        total++; passed += Test("closure named by-value arg", applyLeak(g, 9), 10);

        // (g) reassigning a closure LOCAL frees the previous heap env (no leak of the old env).
        // Each store overwrites a known-initialized alloca slot, so the old env is destructed
        // before the new value lands. Covers a lambda-literal RHS, a named-source clone, and a
        // self-assign (which must not double-free the slot it just cloned from).
        int rk = 3;
        Lambda<int(int)> rf = (int x) => x + rk;   // env #1
        rf = (int x) => x * rk;                       // frees env #1, stores env #2
        rf = rf;                                       // clone-then-free-old: no double-free
        Lambda<int(int)> rsrc = (int x) => x - rk;
        rf = rsrc;                                     // named-source clone; frees prior env
        total++; passed += Test("closure reassign result", rf(10), 7);
        total++; passed += Test("closure reassign source live", rsrc(10), 7);

        // (h) assigning a NAMED closure into a tmp, repeatedly: each `tmp = name` clones the
        // source env (clone-by-default) AND frees the tmp's PREVIOUS clone first, so reassigning
        // a tmp via a name does not leak the prior cloned env. The named sources stay live (a
        // clone, never a move), so they remain callable after being assigned into the tmp.
        Lambda<int(int)> src1 = makeLeakAdder(20);
        Lambda<int(int)> src2 = makeLeakAdder(30);
        Lambda<int(int)> tmp = src1;   // clone src1 -> tmp env #1
        tmp = src2;                       // free tmp env #1, clone src2 -> tmp env #2
        tmp = src1;                       // free tmp env #2, clone src1 -> tmp env #3
        total++; passed += Test("closure tmp via name (result)", tmp(1), 21);
        total++; passed += Test("closure tmp via name (src1 live)", src1(2), 22);
        total++; passed += Test("closure tmp via name (src2 live)", src2(3), 33);

        // (i) function-type alias `using EVENT = Lambda<int(int)>`: two alias-typed locals,
        // then clone-by-default reassignment `v2 = v1` through the alias. The store frees v2's
        // previous env and clones v1's into v2 (no leak), and v1 stays live (clone, not move).
        EVENT v1 = makeLeakAdder(40);
        EVENT v2 = makeLeakAdder(50);
        v2 = v1;                          // free v2's old env, clone v1's env into v2
        total++; passed += Test("alias EVENT clone (v2)", v2(1), 41);
        total++; passed += Test("alias EVENT source live (v1)", v1(2), 42);

        // (j) reassigning a closure struct FIELD frees the previous env (no leak of the old env).
        // The field's enclosing struct is a stack value type (default-initialized), so the field
        // destruct-old fires; a field reached through a heap pointer (raw packet) is left alone.
        // A self-assign clones the source env before freeing the old one, so it never double-frees.
        LeakHandler rh = default;
        rh.fn = makeLeakAdder(7);         // env #1 -> field
        rh.fn = makeLeakAdder(8);         // reassign: old env #1 freed, env #2 in field
        rh.fn = rh.fn;                    // self-assign: clone-then-free-old, no double-free
        total++; passed += Test("closure field reassign frees old env", rh.fn(1), 9);

        // (k) returning a capturing lambda LITERAL directly (no intermediate variable): the env
        // transfers to the caller's local and frees on scope exit. Exercised once and in a loop
        // (each iteration's local frees independently - the envs must not accumulate).
        Lambda<int(int)> lit = makeLeakAdderLiteral(60);
        total++; passed += Test("returned lambda literal invoke", lit(5), 65);
        int li = 0;
        int lsum = 0;
        while (li < 16) { Lambda<int(int)> lg = makeLeakAdderLiteral(li); lsum = lsum + lg(1); li = li + 1; }
        total++; passed += Test("returned lambda literal loop sum", lsum, 136);   // sum of (1 + li), li=0..15

        // (l) UNBOUND closure call result used INLINE: a closure-returning call whose result is
        // never bound to a variable (invoked directly, or passed by value as an argument) is freed
        // at end-of-full-expression by FlushOwnedClosureTemps - the call result is registered as an
        // owned closure temp exactly like a lambda literal. Both the literal- and variable-return
        // forms are covered, and the inline-arg form must not double-free the borrowed callee copy.
        total++; passed += Test("inline-invoke literal-return call result", makeLeakAdderLiteral(1000)(7), 1007);
        total++; passed += Test("inline-invoke variable-return call result", makeLeakAdder(2000)(3), 2003);
        total++; passed += Test("inline-arg call result (by-value borrow)", applyLeak(makeLeakAdder(10), 5), 15);
    }

    // === String RETURNS: owned transfer + borrow (runtime-bit ownership model) ===
    // A plain `string` return of an owned value transfers ownership to the caller's local
    // (freed on scope exit); a borrow return (a container element) is handed back non-owning
    // so it is not double-freed. The caller never sees the function's `move`-ness - the
    // runtime owned bit alone decides whether the local frees - so this works for free
    // functions, member functions, AND lambdas. All of it must be leak/double-free clean.
    {
        string greeting = returnOwnedConcat("world");      // owned temp: "hello world"
        total++; passed += Test("owned concat return", greeting.length(), 11);

        string moved = returnOwnedLocal();                  // owned local moved out: "xyz"
        total++; passed += Test("owned local move-return", moved.length(), 3);

        Greeter gr = default;
        gr.prefix = "hi-";
        string built = gr.greet("bob");                     // owned member-fn result: "hi-bob"
        total++; passed += Test("owned member-fn return", built.length(), 6);

        // Lambda returning a string: the lambda invoker shares the same return-ownership path,
        // so an owned temp (concat) and an owned local moved out of the body both transfer to
        // the caller's local and free on scope exit - no leak, no double-free.
        Lambda<string()> tempFn = () => { return "lam" + "bda"; };   // owned concat in a lambda
        string fromLambdaTemp = tempFn();
        total++; passed += Test("lambda owned temp return", fromLambdaTemp.length(), 6);

        Lambda<string()> localFn = () => { string t = "x" + "y"; return t; };  // owned local
        string fromLambdaLocal = localFn();
        total++; passed += Test("lambda owned local return", fromLambdaLocal.length(), 2);

        // Invoking the SAME closure through a struct FIELD must behave identically. The call
        // RESULT is a fresh value, not a read of the field, so the receiving local takes the
        // returned buffer directly. (Regression: the result inherited the callee field's
        // provenance and was classified as a borrow of an owning string FIELD - the local got a
        // deep copy while the returned buffer was orphaned, leaking it.) Covered for a heap
        // object, a stack value, and reassignment of an existing local.
        LeakLabeler* heapLbl = new LeakLabeler();
        heapLbl.label = (int n) => { return "n=" + n.toString(); };
        string fromFieldHeap = heapLbl.label(7);
        total++; passed += Test("lambda field owned return (heap)", fromFieldHeap, "n=7");
        delete heapLbl;

        LeakLabeler valLbl = default;
        valLbl.label = (int n) => { return "v" + n.toString(); };
        string fromFieldValue = valLbl.label(9);
        total++; passed += Test("lambda field owned return (value)", fromFieldValue, "v9");
        fromFieldValue = valLbl.label(10);                  // reassign from another field call
        total++; passed += Test("lambda field owned return (reassign)", fromFieldValue, "v10");

        // Borrow return: list.get hands the element back as a non-owning borrow (owned bit
        // cleared). The list still owns and frees it on teardown; the local `picked` must NOT
        // free it (a double-free would abort), and the element must survive for the list.
        list<string> fruits = default;
        fruits.add("a" + "pple");                           // owned element ("apple")
        fruits.add("ber" + "ry");                           // owned element ("berry")
        string picked = fruits.get(0);                      // borrow of an owned element
        total++; passed += Test("list element borrow return", picked.length(), 5);
        total++; passed += Test("list element still owned", fruits.get(1).length(), 5);

        // A `move`-return temp read transiently is fully destructed at end of statement: both
        // text and extra are freed (no leak). The reject guards against persisting the field.
        total++; passed += Test("move-temp field read", makeTempTok(7).text.length(), 4);   // "tok7"

        // A PLAIN (non-move) owning return read transiently is also fully destructed at end of
        // statement (regression: this unbound temp used to leak its text+extra buffers).
        total++; passed += Test("plain-temp field read", makePlainTok(8).text.length(), 4);   // "tok8"

        // A discarded owning-struct call must be an explicit `_ =` discard (a bare `makeTempTok(80);`
        // statement is now a compile error - mandatory nodiscard). The explicit discard is destructed
        // at the end of the full expression (regression: the temp was formerly dropped undestructed -
        // no field-access site hooked it). Covered by the HeapAudit oracle below; move and plain apply.
        _ = makeTempTok(80);
        _ = makePlainTok(81);
        _ = makeTempTok(82);
        _ = makePlainTok(83);

        // list.get(i) returns a shallow ALIAS of the element, so the temp is NOT destructed - the
        // element survives (frees once with the list, no double-free). Read it, and copy it out.
        list<TempTok> toks = default;
        TempTok one = default; one.text = "li" + "st"; one.extra = "ex" + "tra";
        toks.add(one);
        total++; passed += Test("get() alias field read", toks.get(0).text.length(), 4);   // "list"
        string ownedCopy = toks.get(0).text.copy();         // copy from an alias -> independent owner
        total++; passed += Test("get() alias field copy", ownedCopy.length(), 4);

        // Implied move: a `move`-temp OWNS its field, so persisting it transfers ownership (no .copy
        // needed). The destination frees the buffer once; the temp's other field frees at end of
        // statement; the moved-out field is zeroed so the temp's dtor does not double-free it.
        TokHolder h = default;
        h.slot = makeTempTok(11).text;                      // implied move into a struct field
        total++; passed += Test("implied-move into field", h.slot.length(), 5);   // "tok11"
        string movedTok = makeTempTok(123).text;            // implied move into a local
        total++; passed += Test("implied-move into local", movedTok.length(), 6); // "tok123"

        // Phase B: returning a `move`-temp's owning field moves it out to the caller (no leak,
        // no double-free - the temp's sibling field frees, the moved field rides out owned).
        string retText = returnMovedText(55);               // string field moved out via return
        total++; passed += Test("implied-move via return (string)", retText.length(), 5); // "tok55"
        InnerTok retInner = returnMovedInner(9);            // struct field moved out via return
        total++; passed += Test("implied-move via return (struct)", retInner.s.length(), 3); // "in9"

        // Comparison-operand temps from PLAIN (non-`move`) string returns. The compiler does not
        // flag a plain `string`-returning function as owned, so a result used DIRECTLY as a
        // comparison operand was never registered for cleanup and leaked (regression: the temp is
        // now freed at end-of-statement). The comparison only borrows the operands, so freeing the
        // (single) temp each is correct. Covered for free functions AND member functions, for
        // ==, !=, and relational <.
        bool cmpNe = returnOwnedConcat("a") != returnOwnedConcat("b");   // two plain-fn temps
        total++; passed += Test("plain-fn temp '!=' operands", cmpNe, true);
        bool cmpEq = returnOwnedConcat("x") == returnOwnedConcat("x");   // == operands
        total++; passed += Test("plain-fn temp '==' operands", cmpEq, true);
        bool cmpLt = gr.greet("a") < gr.greet("b");                      // plain member-fn temps
        total++; passed += Test("plain member-fn temp '<' operands", cmpLt, true);

        // Named owned-string locals as comparison operands must NOT be double-freed: the locals
        // own the buffers and free once on scope exit; the comparison borrows them and frees
        // nothing. A double-free here would abort the HeapAudit oracle.
        string cmpA = returnOwnedConcat("p");
        string cmpB = returnOwnedConcat("q");
        bool cmpLocals = cmpA != cmpB;
        total++; passed += Test("named owned-string locals compared (no double-free)", cmpLocals, true);

        // Additive-operand temps from PLAIN (non-`move`) string returns. Same gap as the
        // comparison operands above but on the `+` (concat) path: a plain string-returning call
        // used DIRECTLY as a `+` operand was never registered and leaked (the result `r` is freed,
        // the two operand temps were not). operator+ only borrows its operands, so freeing each
        // temp once is correct. Chained `+` mixes operand temps with an intermediate result temp.
        {
            string addCall = returnOwnedConcat("a") + returnOwnedConcat("b");   // two plain-fn temps
            total++; passed += Test("plain-fn temp '+' operands", addCall.length(), 14); // "hello ahello b"
            string addChain = returnOwnedConcat("a") + returnOwnedConcat("b") + returnOwnedConcat("c");
            total++; passed += Test("plain-fn temp chained '+' operands", addChain.length() > 0, true);
        }

        // Named owned-string locals as `+` operands must NOT be double-freed: the locals own the
        // buffers and free once on scope exit; operator+ borrows them and frees nothing.
        {
            string addA = returnOwnedConcat("p");
            string addB = returnOwnedConcat("q");
            string addLocals = addA + addB;
            total++; passed += Test("named owned-string locals added (no double-free)", addLocals.length() > 0, true);
        }

        // Ternary over a PLAIN (non-`move`) owned-string return. The ternary deep-copies the
        // selected branch into an independent owned buffer for the local; the branch's own fresh
        // temp (a plain string-returning CALL) was not registered by the call path, so before the
        // fix it leaked after the copy. Both branches of a select are evaluated, so a temp on the
        // NON-selected branch must be freed too. Covered for a free function, a member function,
        // and interface dispatch. `cond` is derived from a runtime value so the select is real.
        {
            bool cond = total > 0;   // always true, but not a compile-time constant

            string tsel = cond ? returnOwnedConcat("t1") : "lit";       // free-fn owned branch
            total++; passed += Test("ternary plain-fn owned branch", tsel.length(), 8); // "hello t1"

            string tboth = cond ? returnOwnedConcat("a") : returnOwnedConcat("b"); // both branches call
            total++; passed += Test("ternary both-branch owned calls", tboth.length(), 7); // "hello a"

            string tmem = cond ? gr.greet("z") : "lit";                 // member-fn owned branch
            total++; passed += Test("ternary plain member-fn owned branch", tmem.length(), 4); // "hi-z"

            Labeler lb = default;
            lb.tag = "ta" + "g";                                        // owned field
            ILabel il = lb;
            string tvirt = cond ? il.label() : "lit";                   // interface-dispatch owned branch
            total++; passed += Test("ternary interface-dispatch owned branch", tvirt.length(), 4); // "tag!"

            // A named owning local as a branch must NOT be double-freed (the deep-copy keeps the
            // local's buffer intact); a borrow branch (list element) likewise stays owned by the list.
            string loc = returnOwnedConcat("k");
            string tloc = cond ? loc : "lit";
            total++; passed += Test("ternary named-local branch (no double-free)", tloc.length(), 7); // "hello k"
            total++; passed += Test("ternary named-local branch source live", loc.length(), 7);
        }
    }

    // === Bug 9: a method call on an owning-value RVALUE temp receiver frees the temp ===
    // `makeIntList(3).count()` consumed the temp as `this` and then dropped it - its buffer leaked.
    // An `alias` (borrow) receiver must still NOT be destructed here, or the owner double-frees.
    {
        total++; passed += Test("temp receiver count", makeIntList(3).count(), 3);
        total++; passed += Test("temp receiver chained", makeIntList(2).copy().count(), 2);

        dictionary<int, list<string>> holder = default;
        list<string> hv = {"p", "q"};
        holder.add(1, move hv);
        // holder.get(1) is an `alias` borrow of the slot: counting through it must not free it.
        total++; passed += Test("alias temp receiver borrowed", holder.get(1).count(), 2);
        total++; passed += Test("alias temp receiver source live", holder.get(1).get(0), "p");
    }

    // === `unique` field ownership: the synthesized destructor frees the pointee ===
    // Both the pointer BLOCK and the pointee's own owning fields must go; the oracle below
    // is what proves it (dropping `unique` from LeakUnique.slot makes it fail).
    {
        LeakUnique u = default;
        u.slot = new LeakPayload();
        u.slot->nums.add(7);
        total++; passed += Test("unique field live", u.slot->nums.count(), 1);

        LeakUniqueOuter o = default;
        o.inner = new LeakUnique();
        o.inner->slot = new LeakPayload();
        o.inner->slot->nums.add(8);
        total++; passed += Test("unique nested field live", o.inner->slot->nums.get(0), 8);
    }

    // === Stage 1.5: generic struct field made `unique` by SUBSTITUTION (no `unique` token on the
    // field declaration - it arrives via the type argument) ===
    // LeakGenSlot<unique PtrLeak*> must free its pointee exactly once on scope exit (the leak this
    // pins: before the LLVMBackend.h fix, the synthesized destructor's scalar arm only checked
    // IsUnique, so a field that is unique purely by substitution was never freed).
    {
        g_shapeDtor = 0;
        {
            LeakGenSlot<unique PtrLeak*> h = default;
            h.v = new PtrLeak();
            total++; passed += Test("generic unique-substitution field live", g_shapeDtor, 0);
        }
        total++; passed += Test("generic unique-substitution field dtor runs once", g_shapeDtor, 1);

        // LeakGenSlot<PtrLeak*> (NON-unique type argument): the field is a BORROW, so the struct's
        // synthesized destructor must free NOTHING - the pointee only dies when the test deletes it.
        // This pins that the widened predicate did not start freeing borrows too.
        g_shapeDtor = 0;
        {
            LeakGenSlot<PtrLeak*> h2 = default;
            h2.v = new PtrLeak();
            total++; passed += Test("generic borrow-substitution field live", g_shapeDtor, 0);
            PtrLeak* extracted = h2.v;          // borrow read; not an ownership transfer
            delete extracted;                  // caller frees the borrowed pointee manually
            total++; passed += Test("generic borrow-substitution caller frees", g_shapeDtor, 1);
        }
        total++; passed += Test("generic borrow-substitution field frees nothing itself", g_shapeDtor, 1);

        // Item 2 (delete-borrow reassignment): a local that borrows a unique-list element and is
        // then REASSIGNED to a fresh allocation must be deletable - the borrow tag clears on
        // reassign. Without the fix this whole file fails to COMPILE (the delete is wrongly rejected).
        g_shapeDtor = 0;
        {
            list<unique PtrLeak*> lu = default;
            lu.add(new PtrLeak());
            PtrLeak* g = lu.get(0);         // borrows the list-owned element
            g = new PtrLeak();              // now owns a fresh alloc; borrow tag cleared
            delete g;                       // frees the fresh alloc only (allowed)
            total++; passed += Test("reassigned borrow delete frees fresh once", g_shapeDtor, 1);
        }                                    // list frees its original element at teardown
        total++; passed += Test("reassigned borrow list frees original at teardown", g_shapeDtor, 2);
    }

    // === Stage 2: reassigning a `unique` field frees the old pointee ===
    // The leak oracle below is the only thing that proves this - a reassignment that merely
    // overwrote the slot would orphan 32 payloads (and their list<int> buffers) silently.
    {
        LeakUnique u = default;
        for (int i = 0; i < 32; i++)
        {
            u.slot = new LeakPayload();
            u.slot->nums.add(i);
        }
        total++; passed += Test("unique reassign live", u.slot->nums.get(0), 31);

        // Releasing via nullptr frees the last pointee early; teardown then finds null.
        u.slot = nullptr;
        total++; passed += Test("unique nullptr release", u.slot == nullptr, true);
    }

    // === Stage 3: `move` out of a `unique` field transfers ownership to the local ===
    // The sanctioned extraction (a plain copy is rejected - err_unique_delete_alias). The move
    // nulls the field, so exactly one owner frees: `delete owned` here, and teardown finds null.
    // The oracle proves both halves - a lost `move` would leak, a double-free would abort.
    {
        LeakUnique u = default;
        u.slot = new LeakPayload();
        u.slot->nums.add(9);

        LeakPayload* owned = move u.slot;
        total++; passed += Test("unique move-out field nulled", u.slot == nullptr, true);
        total++; passed += Test("unique move-out payload intact", owned->nums.get(0), 9);
        delete owned;
    }

    // === Brace-init of a `unique` field: the second field-store path owns identically ===
    // EmitOneFieldInit constructs a fresh slot, so it takes no reassign-free - the oracle proves
    // the field still ends up the sole owner and frees at teardown (a lost store would leak).
    {
        LeakUnique u = { slot = new LeakPayload() };
        u.slot->nums.add(4);
        total++; passed += Test("unique brace-init live", u.slot->nums.get(0), 4);
    }

    // === Brace-init `move` of an owning STRING into a field: transfer, not deep-copy ===
    // Regression for the brace-init/`=` parity class (instance #8): the second field-store path
    // deep-copied a `move`d string while the move had already suppressed the source's destructor,
    // orphaning the original buffer. The oracle (reportLeaks == 0) is what catches it; the plain
    // `s = b` case below still deep-copies (source stays usable), so both spellings are exercised.
    {
        string a = "hel" + "lo";
        ArrSBox mv = { s = move a };
        total++; passed += Test("brace-init move-string value intact", mv.s == "hello", true);

        string b = "wor" + "ld";
        ArrSBox cp = { s = b };
        total++; passed += Test("brace-init copy-string field intact", cp.s == "world", true);
        total++; passed += Test("brace-init copy-string source intact", b == "world", true);
    }

    // === `move` between two `unique` fields: one owner throughout ===
    // The plain copy is rejected (err_unique_field_to_field); this pins that the sanctioned
    // spelling still transfers - a double-free would abort, a lost move would leak.
    {
        LeakUnique a = default;
        LeakUnique c = default;
        a.slot = new LeakPayload();
        a.slot->nums.add(6);
        c.slot = move a.slot;
        total++; passed += Test("unique field-to-field move source nulled", a.slot == nullptr, true);
        total++; passed += Test("unique field-to-field move payload intact", c.slot->nums.get(0), 6);
    }

    // === `unique` field reached through an INTERFACE's byte-offset slot ===
    // The store site binds the flag from the interface's field declaration, so the reassign-free
    // fires there too. The oracle is what proves it: before the contract carried `unique`, these
    // 32 payloads (and their list<int> buffers) were orphaned one store at a time.
    {
        LeakIfaceBox b;
        for (int i = 0; i < 32; i++)
            leakStoreViaIface(b, i);
        total++; passed += Test("unique iface-slot reassign live", b.slot->nums.get(0), 31);

        // Release early through the interface slot; teardown then finds null (no double-free).
        b.slot = nullptr;
        total++; passed += Test("unique iface-slot nullptr release", b.slot == nullptr, true);
    }

    // === Container copy() element semantics (moves-or-shares-elements fix) ===
    // Each container's copy() must leave a value-type source intact (deep copy), transfer an
    // OWNED pointer element to the copy (source slot nulled - a shared pointee would double-free
    // at teardown), and copy an enum element bitwise. The leak oracle below proves no leak /
    // no double-free across all of it.
    {
        // list<owning-struct>: source survives, copy independent (was: source EMPTIED by a move).
        list<LeakRow> ls = default;
        LeakRow lr = default; lr.name = "aa" + "bb"; ls.add(move lr);
        list<LeakRow> lsCopy = ls.copy();
        total++; passed += Test("list<struct> copy source intact", ls.get(0).name, "aabb");
        total++; passed += Test("list<struct> copy independent",   lsCopy.get(0).name, "aabb");

        // list<int*> is the BORROWED view: copy() shallow-copies the pointers (no move, no
        // ownership transfer) - the source keeps its slot and both lists alias the same pointee,
        // which the caller owns and frees once. (An OWNING list<unique int*> has a copy() that is
        // a compile error - see err_unique_list_copy.cb.)
        list<int*> lp = default;
        int* p0 = new int; *p0 = 7; lp.add(p0);
        list<int*> lpCopy = lp.copy();
        int* lpElem = lpCopy.get(0);
        total++; passed += Test("list<ptr> borrow copy keeps source", lp.get(0) != nullptr, true);
        total++; passed += Test("list<ptr> borrow copy aliases same", lp.get(0) == lpElem, true);
        total++; passed += Test("list<ptr> borrow copy sees pointee", *lpElem, 7);
        // A bare pointer element borrows, so p0 stays usable and frees the shared int once.
        // (Not via lpCopy.take(0): see internal/issue/delete-borrow-via-named-local.md.)
        delete p0;

        // list<enum>: element copy is bitwise; source and copy both hold the value (was: build failed).
        list<LeakColor> lc = default; lc.add(LeakColor.LC_Green); lc.add(LeakColor.LC_Blue);
        list<LeakColor> lcCopy = lc.copy();
        total++; passed += Test("list<enum> copy source intact", (i64)lc.get(1), (i64)LeakColor.LC_Blue);
        total++; passed += Test("list<enum> copy value",         (i64)lcCopy.get(0), (i64)LeakColor.LC_Green);

        // dictionary<int, owning-struct>: the STATUS_HEAP_CORRUPTION case - now deep-copies (independent).
        dictionary<int, LeakRow> dm = default;
        LeakRow dv = default; dv.name = "cc" + "dd"; dm.set(1, move dv);
        dictionary<int, LeakRow> dmCopy = dm.copy();
        total++; passed += Test("dict<struct> copy source intact", dm.get(1).name, "ccdd");
        total++; passed += Test("dict<struct> copy independent",   dmCopy.get(1).name, "ccdd");

        // dictionary<int, int*> is a BORROWED view now: copy() shallow-copies the value pointers
        // (no move, no ownership transfer) - the source keeps its slot and both dicts alias the same
        // pointee, which the caller owns and frees once. (Owning dicts use dictionary<int, unique
        // int*>, whose copy() is a compile error - see err_unique_dict_copy.cb.)
        dictionary<int, int*> dp = default;
        int* dpp = new int; *dpp = 9; dp.set(2, dpp);       // borrowed: dpp stays usable and owning
        dictionary<int, int*> dpCopy = dp.copy();
        int* dpElem = dpCopy.get(2);
        int* dpSrc  = dp.get(2);
        total++; passed += Test("dict<ptr-value> borrow copy keeps source", dpSrc != nullptr, true);
        total++; passed += Test("dict<ptr-value> borrow copy aliases same", dpSrc == dpElem, true);
        total++; passed += Test("dict<ptr-value> borrow copy sees pointee", *dpElem, 9);
        // Free through the still-owning SOURCE pointer, not through the borrowed slot value:
        // deleting a named borrow leaves the owner to free again at scope exit (double free).
        delete dpp;     // free the shared int exactly once (both dicts borrow it)

        // hashset<owning-struct>: deep-copied into the slot and freed at teardown (no leak, source intact).
        hashset<LeakName> hn = default;
        LeakName nm = default; nm.n = "ee" + "ff"; hn.add(nm);
        total++; passed += Test("hashset<struct> source intact",  nm.n, "eeff");
        total++; passed += Test("hashset<struct> contains copy",  hn.contains(nm), true);
    }

    // === Part 9b: TOTAL .copy() over T - the per-element copy() defers to the element kind ===
    // Each element's `.copy()` is identity for a primitive/enum/borrow and a deep copy for a
    // copyable owner. The legs below exercise the kinds the collapsed list/dictionary copy() relies
    // on; the HeapAudit oracle proves the borrow legs alias (no double-free) and the deep legs are
    // independent (no leak, source intact).
    {
        // list<int>: primitive elements copy by identity (value copy).
        list<int> li = default; li.add(10); li.add(20);
        list<int> liCopy = li.copy();
        total++; passed += Test("list<int> copy value", liCopy.get(1), 20);
        li.set(0, 99);                                  // mutate source
        total++; passed += Test("list<int> copy independent of source", liCopy.get(0), 10);

        // list<string>: DEEP copy - mutating the source leaves the copy unchanged, both freed once.
        list<string> lstr = default;
        lstr.add("aa" + "bb");                          // genuinely owned buffer
        list<string> lstrCopy = lstr.copy();
        total++; passed += Test("list<string> deep copy value", lstrCopy.get(0), "aabb");
        lstr.set(0, "cc" + "dd");                       // reassign source element (old owned buffer freed)
        total++; passed += Test("list<string> source mutated", lstr.get(0), "ccdd");
        total++; passed += Test("list<string> deep copy unchanged", lstrCopy.get(0), "aabb");

        // list<struct-ptr> BORROW: copy() shallow-copies the pointers - both lists alias the same
        // pointee (caller owns it and frees once). This exercises the pointer-to-STRUCT identity arm.
        g_shapeDtor = 0;
        PtrLeak* sp = new PtrLeak();
        {
            list<PtrLeak*> lsp = default; lsp.add(sp);
            list<PtrLeak*> lspCopy = lsp.copy();
            total++; passed += Test("list<struct-ptr> borrow copy aliases same", lsp.get(0) == lspCopy.get(0), true);
        }
        total++; passed += Test("list<struct-ptr> two borrow copies free nothing", g_shapeDtor, 0);
        delete sp;                                      // caller owns the pointee, frees it once
        total++; passed += Test("list<struct-ptr> owner frees exactly once", g_shapeDtor, 1);

        // dictionary<string, string>: DEEP copy of both key and value; both dicts freed once.
        dictionary<string, string> ds = default;
        ds.set("k" + "1", "v" + "1");
        dictionary<string, string> dsCopy = ds.copy();
        total++; passed += Test("dict<string,string> deep copy value", dsCopy.get("k1"), "v1");
        ds.set("k1", "v" + "2");                         // overwrite source value (old freed)
        total++; passed += Test("dict<string,string> source mutated", ds.get("k1"), "v2");
        total++; passed += Test("dict<string,string> deep copy unchanged", dsCopy.get("k1"), "v1");

        // Plain primitive local .copy() is identity - a value copy, independent of the source.
        int a = 7;
        int b = a.copy();
        a = 42;
        total++; passed += Test("primitive local .copy() identity", b, 7);
    }

    // === Stage 6: unique dictionary VALUE ownership (dtor + leak oracle) ===
    // dictionary<K, unique V*> OWNS its values: freed on remove()/set()-overwrite/clear()/teardown.
    // A bare dictionary<K, V*> BORROWS and frees nothing. Interface values ride the vtable dtor slot.
    // hashset<T*> borrows its (key-like) elements. The HeapAudit oracle proves no leak / no double-free.
    {
        // unique pointer values: free on remove, overwrite, clear, and dtor (PtrLeak bumps g_shapeDtor).
        g_shapeDtor = 0;
        {
            dictionary<int, unique PtrLeak*> d;
            d.add(1, new PtrLeak());
            d.add(2, new PtrLeak());
            d.add(3, new PtrLeak());
            d.remove(2);                               // frees the value at key 2
            total++; passed += Test("dict<unique ptr> remove frees value", g_shapeDtor, 1);
            d.set(3, new PtrLeak());                   // overwrite key 3: old value freed first
            total++; passed += Test("dict<unique ptr> overwrite frees old", g_shapeDtor, 2);
            d.clear();                                 // frees the values at keys 1 and 3
            total++; passed += Test("dict<unique ptr> clear frees rest", g_shapeDtor, 4);
            d.add(4, new PtrLeak());                   // repopulate; the dtor must free it
        }
        total++; passed += Test("dict<unique ptr> dtor frees remaining", g_shapeDtor, 5);

        // Regression: a refused duplicate-key add() must free the rejected unique value, not drop
        // it - see internal/issue/duplicate-add-leaks-unique-value.md.
        g_shapeDtor = 0;
        {
            dictionary<int, unique PtrLeak*> d;
            d.add(1, new PtrLeak());
            bool dup = d.add(1, new PtrLeak());        // duplicate: refused value must be freed here
            total++; passed += Test("dict<unique ptr> dup add rejected", dup, false);
            total++; passed += Test("dict<unique ptr> dup add frees refused value", g_shapeDtor, 1);
        }
        total++; passed += Test("dict<unique ptr> dup add dtor frees remaining", g_shapeDtor, 2);

        // bare pointer values: the dict frees NOTHING (add()'s move-param nulls the caller local, so
        // the pointee is reached back through get()). remove() and teardown must leave it alive.
        g_shapeDtor = 0;
        PtrLeak* survivor = nullptr;
        {
            dictionary<int, PtrLeak*> view;
            view.add(1, new PtrLeak());
            PtrLeak* held = view.get(1);               // borrow the stored pointer
            view.remove(1);                            // borrowed: must NOT free
            total++; passed += Test("dict<bare ptr> remove frees nothing", g_shapeDtor, 0);
            delete held;                               // caller frees the removed pointee once
            total++; passed += Test("dict<bare ptr> caller frees removed", g_shapeDtor, 1);
            view.add(2, new PtrLeak());
            survivor = view.get(2);                    // stays in the dict; teardown must not free it
        }
        total++; passed += Test("dict<bare ptr> dtor frees nothing", g_shapeDtor, 1);
        delete survivor;                               // caller frees the survivor once
        total++; passed += Test("dict<bare ptr> caller frees survivor", g_shapeDtor, 2);

        // unique interface values: owned, freed through the vtable dtor slot (CircleLeak bumps g_shapeDtor).
        g_shapeDtor = 0;
        {
            dictionary<int, unique IShapeLeak> d;
            d.add(1, new CircleLeak());
            d.add(2, new CircleLeak());
            d.remove(1);                               // frees the value at key 1 via the vtable dtor
            total++; passed += Test("dict<unique iface> remove frees", g_shapeDtor, 1);
        }
        total++; passed += Test("dict<unique iface> dtor frees rest", g_shapeDtor, 2);

        // hashset<ptr> BORROWS its elements (add() takes a plain param - no move/null): remove(),
        // clear(), and the destructor free nothing; the caller owns and frees the pointees.
        g_shapeDtor = 0;
        {
            PtrLeak* h1 = new PtrLeak();
            PtrLeak* h2 = new PtrLeak();
            {
                hashset<PtrLeak*> hs;
                hs.add(h1);
                hs.add(h2);
                hs.remove(h1);                         // borrowed: frees nothing
                total++; passed += Test("hashset<ptr> remove frees nothing", g_shapeDtor, 0);
            }                                          // dtor frees nothing
            total++; passed += Test("hashset<ptr> dtor frees nothing", g_shapeDtor, 0);
            delete h1; delete h2;                      // caller frees both pointees once
            total++; passed += Test("hashset<ptr> caller frees", g_shapeDtor, 2);
        }
    }

    // === Borrow-by-default migration of dictionary / hashset: VALUE elements are COPIED ===
    // add()/set() take a plain `V value` and deep-copy it, so the caller's source stays intact
    // and independent; the `move` transfer overload is the opt-in that hands the buffer over.
    // A dictionary<K, V*> / <K, IFace> BORROWS (covered above); this covers the value legs.
    {
        // dictionary value COPIED: mutating the source after insert must not touch the slot.
        dictionary<int, LeakRow> dv = default;
        LeakRow src = default; src.name = "or" + "ig";
        dv.add(1, src);
        src.name = "MUT" + "ATED";
        total++; passed += Test("dict<val> add copies (slot)",   dv.get(1).name, "orig");
        total++; passed += Test("dict<val> add copies (source)", src.name, "MUTATED");

        // set() copies too, and releases the old owned element (no leak, no double free).
        LeakRow src2 = default; src2.name = "se" + "cond";
        dv.set(1, src2);
        src2.name = "AGA" + "IN";
        total++; passed += Test("dict<val> set copies (slot)",   dv.get(1).name, "second");
        total++; passed += Test("dict<val> set copies (source)", src2.name, "AGAIN");

        // The move overloads still transfer: no copy, the slot adopts the caller's buffer.
        LeakRow mv = default; mv.name = "mo" + "ved";
        dv.add(2, move mv);
        total++; passed += Test("dict<val> add(move) transfers", dv.get(2).name, "moved");
        LeakRow mv2 = default; mv2.name = "mov" + "ed2";
        dv.set(2, move mv2);
        total++; passed += Test("dict<val> set(move) transfers", dv.get(2).name, "moved2");
        dv.remove(1);
        total++; passed += Test("dict<val> remove count", dv.count(), 1);

        // hashset elements are deep-copied on add(); the source stays usable and independent.
        hashset<LeakName> hv = default;
        LeakName hs1 = default; hs1.n = "el" + "em";
        hv.add(hs1);
        total++; passed += Test("hashset<val> add copies (contains)", hv.contains(hs1), true);
        total++; passed += Test("hashset<val> add copies (source)",   hs1.n, "elem");

        // hashset's transfer counterpart - value elements only, same guard as dictionary's.
        LeakName hs2 = default; hs2.n = "gon" + "e";
        hv.add(move hs2);
        LeakName probe = default; probe.n = "gon" + "e";
        total++; passed += Test("hashset<val> add(move) transfers", hv.contains(probe), true);
        total++; passed += Test("hashset<val> count after move add", hv.count(), 2);
    }

    // === Non-copyable value element stays USABLE through the transfer overload ===
    // A struct owning a `unique` pointer has no copy(), so the copying add()/set() are poisoned
    // (see err_dict_noncopyable_value.cb / err_hashset_noncopyable_elem.cb). The container must
    // still instantiate and work via `move`, and must free the owned pointee exactly once.
    {
        g_shapeDtor = 0;
        {
            dictionary<int, LeakHolder> d = default;
            LeakHolder h1 = default; h1.slot = new PtrLeak(); h1.k = 1;
            d.add(1, move h1);
            total++; passed += Test("dict<noncopy> move add count", d.count(), 1);
            LeakHolder h2 = default; h2.slot = new PtrLeak(); h2.k = 2;
            d.set(1, move h2);                     // overwrite releases the old holder's pointee
            total++; passed += Test("dict<noncopy> move set frees old", g_shapeDtor, 1);

            hashset<LeakHolder> s = default;
            LeakHolder h3 = default; h3.slot = new PtrLeak(); h3.k = 3;
            s.add(move h3);
            LeakHolder sProbe = default; sProbe.k = 3;
            total++; passed += Test("hashset<noncopy> move add", s.contains(sProbe), true);
        }
        total++; passed += Test("noncopy containers free on teardown", g_shapeDtor, 3);
    }

    // === array<T> borrow-by-default migration (mirrors list<T>/hashset<T>/dictionary<K,V>) ===
    // array<T> value elements are COPIED (plain set) / TRANSFERRED (set(move)); array<T*> and
    // array<IShapeLeak> BORROW (never freed by the array, heap- or stack-boxed alike);
    // array<unique T*> OWNS (frees on overwrite and teardown); a non-copyable value element is
    // poisoned on the plain overload but usable via set(move) (see err_array_noncopyable_elem.cb).
    {
        // array<int> primitive - trivial.
        array<int> ai; ai.init(3);
        ai.set(0, 10); ai.set(1, 20); ai.set(2, 30);
        total++; passed += Test("array<int> get(1)", ai.get(1), 20);
        total++; passed += Test("array<int> count", ai.count(), 3);

        // array<string> value: plain set COPIES (source survives, independently mutable);
        // set(move) transfers.
        array<string> asv; asv.init(2);
        string src = "or" + "ig";
        asv.set(0, src);
        src = "MUT" + "ATED";
        total++; passed += Test("array<val> set copies (slot)",   asv.get(0), "orig");
        total++; passed += Test("array<val> set copies (source)", src, "MUTATED");
        string mvs = "mo" + "ved";
        asv.set(1, move mvs);
        total++; passed += Test("array<val> set(move) transfers", asv.get(1), "moved");

        // array<T*> bare pointer: BORROWS. Elements are passed as fresh `new` expressions (never
        // named owning locals - a named `PtrLeak* p = new PtrLeak();` local is itself an owning
        // local freed at ITS OWN scope exit, which would confound this oracle); get() hands back
        // an alias (borrow) that the caller frees explicitly.
        g_shapeDtor = 0;
        {
            array<PtrLeak*> ap; ap.init(2);
            ap.set(0, new PtrLeak());
            ap.set(1, new PtrLeak());
            PtrLeak* bp0 = ap.get(0);
            PtrLeak* bp1 = ap.get(1);
            total++; passed += Test("array<ptr> dtor frees nothing before death", g_shapeDtor, 0);
            delete bp0; delete bp1;
        }
        total++; passed += Test("array<ptr> caller frees both", g_shapeDtor, 2);

        // array<IShapeLeak> heap-boxed interface: BORROWS.
        g_shapeDtor = 0;
        {
            array<IShapeLeak> ash; ash.init(2);
            ash.set(0, new CircleLeak());
            ash.set(1, new CircleLeak());
            IShapeLeak bs0 = ash.get(0);
            IShapeLeak bs1 = ash.get(1);
            total++; passed += Test("array<iface> heap dtor frees nothing before death", g_shapeDtor, 0);
            delete bs0; delete bs1;
        }
        total++; passed += Test("array<iface> heap caller frees both", g_shapeDtor, 2);

        // array<IShapeLeak> STACK-boxed interface: BORROWS - the array must not delete a
        // stack-boxed object (that would run the dtor and then abort/corrupt on the real
        // scope-exit destruction below).
        g_shapeDtor = 0;
        {
            CircleLeak stc0; stc0.r = 1;
            CircleLeak stc1; stc1.r = 2;
            {
                array<IShapeLeak> ash2; ash2.init(2);
                ash2.set(0, stc0);
                ash2.set(1, stc1);
            }
            total++; passed += Test("array<iface> stack-boxed array dtor frees nothing", g_shapeDtor, 0);
        }
        // stc0/stc1 destruct on scope exit above -> +2, proving they were never double-freed.
        total++; passed += Test("array<iface> stack-boxed source destructs once", g_shapeDtor, 2);

        // array<unique T*>: OWNS - overwrite frees the old element, teardown frees the rest.
        g_shapeDtor = 0;
        {
            array<unique PtrLeak*> au; au.init(2);
            au.set(0, new PtrLeak());
            au.set(1, new PtrLeak());
            au.set(1, new PtrLeak());   // overwrite: old element at index 1 freed first
            total++; passed += Test("array<unique ptr> overwrite frees old", g_shapeDtor, 1);
        }
        total++; passed += Test("array<unique ptr> teardown frees remaining", g_shapeDtor, 3);

        // array<LeakHolder>: non-copyable value element (owns a `unique` field, no copy()).
        // The plain set() is poisoned at compile time (err_array_noncopyable_elem.cb); set(move)
        // works and the array frees both owned pointees on teardown - LEAKS=0.
        g_shapeDtor = 0;
        {
            array<LeakHolder> ah; ah.init(2);
            LeakHolder ah0 = default; ah0.slot = new PtrLeak(); ah0.k = 1;
            ah.set(0, move ah0);
            LeakHolder ah1 = default; ah1.slot = new PtrLeak(); ah1.k = 2;
            ah.set(1, move ah1);
            total++; passed += Test("array<noncopy> move set ks", ah.get(0).k * 10 + ah.get(1).k, 12);
        }
        total++; passed += Test("array<noncopy> teardown frees both slots", g_shapeDtor, 2);
    }

    // === queue<T> / stack<T> borrow-by-default migration (mirrors list<T>/array<T>) ===
    // Before this change both were self-inconsistent: enqueue/push took `move T` (claiming
    // ownership of a pointer element) while the destructor guarded with `if const
    // (!is_pointer(T))` and freed nothing, so a pointer queue/stack drained by nobody leaked
    // every element. Now bare BORROWS, `unique` OWNS, and dequeue()/pop() return `alias` for a
    // borrowed element and `move` for an owned or value one.
    {
        // Primitives - trivial. Enough inserts to force several _grow()s, and for queue the
        // _front offset path: drain half, refill, and confirm FIFO order survives the repack.
        queue<int> qi;
        int qn = 0;
        while (qn < 40) { qi.enqueue(qn); qn++; }
        total++; passed += Test("queue<int> count after grows", qi.count(), 40);
        int qbad = 0; int qd = 0;
        while (qd < 20) { if (qi.dequeue() != qd) qbad++; qd++; }
        total++; passed += Test("queue<int> FIFO across grows", qbad, 0);
        int qr = 0;
        while (qr < 30) { qi.enqueue(100 + qr); qr++; }   // _front > 0: forces the repack path
        total++; passed += Test("queue<int> count after _front repack", qi.count(), 50);
        total++; passed += Test("queue<int> front after repack", qi.dequeue(), 20);

        stack<int> si;
        int sn = 0;
        while (sn < 40) { si.push(sn); sn++; }
        total++; passed += Test("stack<int> count after grows", si.count(), 40);
        total++; passed += Test("stack<int> pop LIFO", si.pop(), 39);

        // Trivial POD value struct (QPoint{int x,y}): a multi-field aggregate is a distinct
        // copy/store path from a scalar. The plain insert COPIES (source stays independently
        // mutable); dequeue/pop hands the value back; teardown frees nothing (no owning field).
        {
            queue<QPoint> qpt;
            QPoint qp0 = default; qp0.x = 1; qp0.y = 2;
            qpt.enqueue(qp0);
            qp0.x = 99;                        // mutate source: the copied slot must be unaffected
            total++; passed += Test("queue<pod> enqueue copies (slot x)", qpt.peek().x, 1);
            total++; passed += Test("queue<pod> enqueue copies (source x)", qp0.x, 99);
            QPoint qp1 = default; qp1.x = 3; qp1.y = 4;
            qpt.enqueue(qp1);
            QPoint qout = qpt.dequeue();
            total++; passed += Test("queue<pod> dequeue value", qout.y, 2);
            total++; passed += Test("queue<pod> count after dequeue", qpt.count(), 1);

            stack<QPoint> spt;
            QPoint sp0 = default; sp0.x = 5; sp0.y = 6;
            spt.push(sp0);
            QPoint sp1 = default; sp1.x = 7; sp1.y = 8;
            spt.push(sp1);
            total++; passed += Test("stack<pod> peek top", spt.peek().x, 7);
            total++; passed += Test("stack<pod> pop LIFO value", spt.pop().y, 8);
        }

        // Value elements: the plain insert COPIES (source survives and is independently
        // mutable); the guarded `move` overload transfers.
        queue<string> qs;
        string qsrc = "or" + "ig";
        qs.enqueue(qsrc);
        qsrc = "MUT" + "ATED";
        total++; passed += Test("queue<val> enqueue copies (slot)",   qs.peek(), "orig");
        total++; passed += Test("queue<val> enqueue copies (source)", qsrc, "MUTATED");
        string qmv = "mo" + "ved";
        qs.enqueue(move qmv);
        total++; passed += Test("queue<val> dequeue 1", qs.dequeue(), "orig");
        total++; passed += Test("queue<val> enqueue(move) transfers", qs.dequeue(), "moved");

        // Leave LIVE owning-string elements at scope exit: many COPY-inserts (forcing several
        // _grow()s), a partial dequeue, then more inserts, and NO final drain. Each insert stores
        // into a fresh/grown slot, so the total-assignment drop-old must be a no-op there; the
        // queue destructor then releases every live slot exactly once. The named source stays
        // independently owned and frees once at its own scope exit (COPY, not alias/move).
        {
            queue<string> ql;
            int qi2 = 0;
            while (qi2 < 12) { ql.enqueue("q" + qi2.toString()); qi2++; }   // grows repeatedly (copy-in)
            total++; passed += Test("queue<val> live-teardown count", ql.count(), 12);
            total++; passed += Test("queue<val> live-teardown front", ql.dequeue(), "q0");   // one out
            string qkeep = "ke" + "ep";
            ql.enqueue(qkeep);                                              // COPY a named local in
            total++; passed += Test("queue<val> live-teardown source live", qkeep, "keep");
            total++; passed += Test("queue<val> live-teardown mid", ql.peek(), "q1");
            // ql leaves scope here holding 12 live owning strings -> all freed exactly once
        }

        stack<string> ss;
        string ssrc = "or" + "ig";
        ss.push(ssrc);
        ssrc = "MUT" + "ATED";
        total++; passed += Test("stack<val> push copies (slot)",   ss.peek(), "orig");
        total++; passed += Test("stack<val> push copies (source)", ssrc, "MUTATED");
        string smv = "mo" + "ved";
        ss.push(move smv);
        total++; passed += Test("stack<val> push(move) transfers", ss.pop(), "moved");

        // Bare pointer BORROWS: dequeue()/pop() hand back an alias, the container frees
        // nothing, and the caller frees each element exactly once. Elements are fresh `new`
        // expressions, never named owning locals (those are freed at their own scope exit).
        g_shapeDtor = 0;
        {
            queue<PtrLeak*> qp;
            qp.enqueue(new PtrLeak());
            qp.enqueue(new PtrLeak());
            PtrLeak* qb0 = qp.dequeue();
            PtrLeak* qb1 = qp.peek();
            total++; passed += Test("queue<ptr> dequeue frees nothing", g_shapeDtor, 0);
            delete qb0; delete qb1;
        }
        total++; passed += Test("queue<ptr> caller frees both", g_shapeDtor, 2);

        g_shapeDtor = 0;
        {
            stack<PtrLeak*> sp;
            sp.push(new PtrLeak());
            sp.push(new PtrLeak());
            PtrLeak* sb0 = sp.pop();
            PtrLeak* sb1 = sp.peek();
            total++; passed += Test("stack<ptr> pop frees nothing", g_shapeDtor, 0);
            delete sb0; delete sb1;
        }
        total++; passed += Test("stack<ptr> caller frees both", g_shapeDtor, 2);

        // Heap-boxed interface elements BORROW, exactly like bare pointers.
        g_shapeDtor = 0;
        {
            queue<IShapeLeak> qf;
            qf.enqueue(new CircleLeak());
            qf.enqueue(new CircleLeak());
            IShapeLeak qf0 = qf.dequeue();
            IShapeLeak qf1 = qf.peek();
            total++; passed += Test("queue<iface> heap frees nothing", g_shapeDtor, 0);
            delete qf0; delete qf1;
        }
        total++; passed += Test("queue<iface> heap caller frees both", g_shapeDtor, 2);

        // STACK-boxed interface elements BORROW - deleting one would run the dtor and then
        // abort/corrupt on the real scope-exit destruction below.
        g_shapeDtor = 0;
        {
            CircleLeak sbc0; sbc0.r = 1;
            CircleLeak sbc1; sbc1.r = 2;
            {
                stack<IShapeLeak> sf;
                sf.push(sbc0);
                sf.push(sbc1);
            }
            total++; passed += Test("stack<iface> stack-boxed dtor frees nothing", g_shapeDtor, 0);
        }
        total++; passed += Test("stack<iface> stack-boxed sources destruct once", g_shapeDtor, 2);

        // `unique T*` OWNS: dequeue()/pop() transfer out (the caller then frees), and teardown
        // frees everything still held.
        g_shapeDtor = 0;
        {
            queue<unique PtrLeak*> qu;
            qu.enqueue(new PtrLeak());
            qu.enqueue(new PtrLeak());
            qu.enqueue(new PtrLeak());
            PtrLeak* qtaken = qu.dequeue();
            total++; passed += Test("queue<unique ptr> dequeue frees nothing", g_shapeDtor, 0);
            delete qtaken;
            total++; passed += Test("queue<unique ptr> caller frees taken", g_shapeDtor, 1);
        }
        total++; passed += Test("queue<unique ptr> teardown frees rest", g_shapeDtor, 3);

        g_shapeDtor = 0;
        {
            stack<unique PtrLeak*> su;
            su.push(new PtrLeak());
            su.push(new PtrLeak());
            su.push(new PtrLeak());
            PtrLeak* staken = su.pop();
            total++; passed += Test("stack<unique ptr> pop frees nothing", g_shapeDtor, 0);
            delete staken;
            total++; passed += Test("stack<unique ptr> caller frees taken", g_shapeDtor, 1);
        }
        total++; passed += Test("stack<unique ptr> teardown frees rest", g_shapeDtor, 3);

        // `unique IFace` OWNS - freed through the vtable dtor slot.
        g_shapeDtor = 0;
        {
            queue<unique IShapeLeak> qui;
            qui.enqueue(new CircleLeak());
            qui.enqueue(new CircleLeak());
            IShapeLeak quitaken = qui.dequeue();
            delete quitaken;
            total++; passed += Test("queue<unique iface> caller frees taken", g_shapeDtor, 1);
        }
        total++; passed += Test("queue<unique iface> teardown frees rest", g_shapeDtor, 2);

        g_shapeDtor = 0;
        {
            stack<unique IShapeLeak> sui;
            sui.push(new CircleLeak());
            sui.push(new CircleLeak());
            IShapeLeak suitaken = sui.pop();
            delete suitaken;
            total++; passed += Test("stack<unique iface> caller frees taken", g_shapeDtor, 1);
        }
        total++; passed += Test("stack<unique iface> teardown frees rest", g_shapeDtor, 2);

        // Non-copyable value element (owns a `unique` field, no copy()): the plain insert is
        // poisoned at compile time (err_queue/err_stack_noncopyable_elem.cb) but the `move`
        // overload works and teardown frees both owned pointees.
        g_shapeDtor = 0;
        {
            queue<LeakHolder> qh;
            LeakHolder qh0 = default; qh0.slot = new PtrLeak(); qh0.k = 1;
            qh.enqueue(move qh0);
            LeakHolder qh1 = default; qh1.slot = new PtrLeak(); qh1.k = 2;
            qh.enqueue(move qh1);
            total++; passed += Test("queue<noncopy> move enqueue front k", qh.peek().k, 1);
        }
        total++; passed += Test("queue<noncopy> teardown frees both slots", g_shapeDtor, 2);

        g_shapeDtor = 0;
        {
            stack<LeakHolder> sh;
            LeakHolder sh0 = default; sh0.slot = new PtrLeak(); sh0.k = 1;
            sh.push(move sh0);
            LeakHolder sh1 = default; sh1.slot = new PtrLeak(); sh1.k = 2;
            sh.push(move sh1);
            total++; passed += Test("stack<noncopy> move push top k", sh.peek().k, 2);
        }
        total++; passed += Test("stack<noncopy> teardown frees both slots", g_shapeDtor, 2);
    }

    // === `_ = move _data[i]` DISCARD-FORM element release parity (every element kind) ===
    // Guards internal/issue/discard-move-vs-decl-move-element-ownership-disparity.md: the discard
    // spelling must release an owning container element exactly like `T tmp = move _data[i]`. Each
    // owning kind must free EXACTLY once (no leak via a stripped owner, no double-free via the
    // zeroed slot); each borrow kind must free NOTHING. discardAll uses the discard form; the
    // DiscardBag destructor uses it too, so both discard sites are covered.
    {
        // int + POD value elements: no dtor, so the discard/teardown must free NOTHING (a spurious
        // free would abort the HeapAudit oracle). Just prove it compiles and stays clean.
        {
            DiscardBag<int> bi = default;
            bi.add(10); bi.add(20); bi.add(30);
            bi.discardAll();
            total++; passed += Test("discard<int> count after discardAll", bi.count(), 0);

            DiscardBag<QPoint> bp = default;
            QPoint p0 = default; p0.x = 1; bp.add(p0);
            QPoint p1 = default; p1.x = 2; bp.add(p1);
            bp.discardAll();
            total++; passed += Test("discard<pod> count after discardAll", bp.count(), 0);
        }

        // string element (owning value): the buffer frees exactly once via RegisterDiscardedOwningStructTemp.
        {
            DiscardBag<string> bs = default;
            bs.add("dsc" + "0");        // owned concat -> forced heap buffer
            bs.add("dsc" + "1");
            bs.discardAll();            // both string buffers freed here
            total++; passed += Test("discard<string> count after discardAll", bs.count(), 0);
        }

        // owning-value struct element (owns a string): freed once through its full destructor.
        {
            DiscardBag<LeakRow> br = default;
            LeakRow r0 = default; r0.name = "row" + "A"; br.add(r0);
            LeakRow r1 = default; r1.name = "row" + "B"; br.add(r1);
            br.discardAll();
            total++; passed += Test("discard<owning-value> count after discardAll", br.count(), 0);
        }

        // LeakHolder{unique PtrLeak*} value element (non-copyable): the full dtor frees the unique field.
        g_shapeDtor = 0;
        {
            DiscardBag<LeakHolder> bh = default;
            LeakHolder h0 = default; h0.slot = new PtrLeak(); h0.k = 1; bh.add(move h0);
            LeakHolder h1 = default; h1.slot = new PtrLeak(); h1.k = 2; bh.add(move h1);
            bh.discardAll();
            total++; passed += Test("discard holder-unique-ptr discardAll frees both", g_shapeDtor, 2);
        }
        total++; passed += Test("discard holder-unique-ptr teardown noop", g_shapeDtor, 2);

        // bare `PtrLeak*` BORROW element: discard frees NOTHING; the caller owns and frees each.
        g_shapeDtor = 0;
        {
            PtrLeak* k0 = new PtrLeak();
            PtrLeak* k1 = new PtrLeak();
            {
                DiscardBag<PtrLeak*> bb = default;
                bb.add(k0); bb.add(k1);
                bb.discardAll();
                total++; passed += Test("discard<borrow-ptr> frees nothing", g_shapeDtor, 0);
            }                                       // teardown of a borrow bag also frees nothing
            total++; passed += Test("discard<borrow-ptr> teardown frees nothing", g_shapeDtor, 0);
            delete k0; delete k1;
        }
        total++; passed += Test("discard<borrow-ptr> caller frees both", g_shapeDtor, 2);

        // `unique PtrLeak*` OWNING element: discardAll frees each once; nothing left for teardown.
        g_shapeDtor = 0;
        {
            DiscardBag<unique PtrLeak*> bu = default;
            bu.add(new PtrLeak()); bu.add(new PtrLeak()); bu.add(new PtrLeak());
            bu.discardAll();
            total++; passed += Test("discard<unique-ptr> discardAll frees all", g_shapeDtor, 3);
        }
        total++; passed += Test("discard<unique-ptr> teardown noop", g_shapeDtor, 3);

        // `unique PtrLeak*` OWNING element released by the DESTRUCTOR's discard form (no discardAll):
        // teardown's `_ = move _data[i]` must free every still-held element exactly once.
        g_shapeDtor = 0;
        {
            DiscardBag<unique PtrLeak*> bt = default;
            bt.add(new PtrLeak()); bt.add(new PtrLeak());
            total++; passed += Test("discard<unique-ptr> pre-teardown live", g_shapeDtor, 0);
        }                                           // destructor discard-move frees both here
        total++; passed += Test("discard<unique-ptr> teardown discard frees both", g_shapeDtor, 2);

        // bare `IShapeLeak` interface BORROW element: discard frees NOTHING; caller frees each.
        g_shapeDtor = 0;
        {
            IShapeLeak f0 = new CircleLeak();
            IShapeLeak f1 = new CircleLeak();
            {
                DiscardBag<IShapeLeak> bf = default;
                bf.add(f0); bf.add(f1);
                bf.discardAll();
                total++; passed += Test("discard<borrow-iface> frees nothing", g_shapeDtor, 0);
            }
            delete f0; delete f1;
        }
        total++; passed += Test("discard<borrow-iface> caller frees both", g_shapeDtor, 2);

        // `unique IShapeLeak` OWNING interface element: freed once via the vtable dtor slot.
        g_shapeDtor = 0;
        {
            DiscardBag<unique IShapeLeak> bui = default;
            bui.add(new CircleLeak()); bui.add(new CircleLeak());
            bui.discardAll();
            total++; passed += Test("discard<unique-iface> discardAll frees both", g_shapeDtor, 2);
        }
        total++; passed += Test("discard<unique-iface> teardown noop", g_shapeDtor, 2);
    }

    // === Whole-struct assignment through a pointer deref (`*pc = *pa`) ===
    // A shallow bitwise store used to alias owned buffers (both dtors free -> double-free) and
    // orphan the destination's old value (leak). The deref lvalue is now an owning destination:
    // the old destination is destructed first, then the source is transferred in. Per THE FLIP,
    // a NON-copyable owner (`unique` payload) MOVES - the source is zeroed; a COPYABLE owner
    // (a plain owning `string` field) COPIES - the source stays LIVE and gets an independent
    // buffer. The leak oracle below proves single-owner freedom for both.
    {
        LeakUnique a = default;
        LeakUnique c = default;
        a.slot = new LeakPayload(); a.slot->nums.add(41);
        c.slot = new LeakPayload(); c.slot->nums.add(99);   // c's old payload must be freed on the store
        LeakUnique* pa = &a;
        LeakUnique* pc = &c;
        *pc = *pa;                                          // non-copyable: move a's payload into c; a.slot zeroed
        total++; passed += Test("deref-assign unique source zeroed", a.slot == nullptr, true);
        total++; passed += Test("deref-assign unique dest owns moved", c.slot->nums.get(0), 41);

        LeakRow sa = default;
        LeakRow sc = default;
        sa.name = "de" + "ref";                             // owned "deref"
        sc.name = "ol" + "d";                               // owned "old" - freed on the store
        LeakRow* spa = &sa;
        LeakRow* spc = &sc;
        *spc = *spa;                                        // copyable: COPY sa.name into sc; sa stays live
        total++; passed += Test("deref-assign string dest owns copy", sc.name, "deref");
        total++; passed += Test("deref-assign string source stays live", sa.name, "deref");
    }

    // === Field-to-field copy of a copyable owning VALUE STRUCT (`b.f = a.f`) ===
    // THE FLIP copies a copyable owner field-to-field, leaving the source field live. The copy runs
    // through RejectOwningValueCopyIntoField; the dedicated field-to-field block must NOT copy a
    // second time (that orphaned the first copy - a leak the oracle below catches). The old
    // destination field is destructed before the copy is stored.
    {
        LeakBox a = default; a.nums.add(1); a.nums.add(2);
        LeakBox b = default; b.nums.add(9);                 // b's old list freed on the store
        b.nums = a.nums;                                    // copyable value struct: single copy
        b.nums.add(3);
        total++; passed += Test("field-to-field src list stays independent", a.nums.count(), 2);
        total++; passed += Test("field-to-field dest list is an independent copy", b.nums.count(), 3);
    }

    // === Owning fixed-array FIELD: full destruction + independent deep copy ===
    // The synthesized destructor walks all N elements; the memberwise copy deep-copies each, so a
    // .copy() is independent and both structs free every element exactly once. Multi-dim exercises
    // the flattened walk. Before the fix the whole array field was skipped (leak); a naive walk
    // without the deep copy turned it into a .copy() double-free (the leak oracle catches both).
    {
        ArrHolder h = default;
        h.items[0].s = "aa" + "bb";
        h.items[1].s = "cc" + "dd";
        h.items[2].s = "ee" + "ff";
        ArrHolder h2 = h.copy();
        h2.items[0].s = "zz" + "yy";                        // mutate copy; original must be intact
        total++; passed += Test("arr-field copy independent (src)", h.items[0].s, "aabb");
        total++; passed += Test("arr-field copy independent (dst)", h2.items[0].s, "zzyy");
        total++; passed += Test("arr-field copy element 2",         h2.items[2].s, "eeff");
        // h and h2 destruct here - every owned element must free exactly once (oracle below).
    }

    // === Interface-element list ownership (the plan's Evidence leak, finally fixed) ===
    // list<unique IShapeLeak> OWNS boxed elements (freed via the vtable dtor slot); a bare
    // list<IShapeLeak> BORROWS and frees nothing - scope-owned objects survive.
    {
        g_shapeDtor = 0;
        {
            list<unique IShapeLeak> shapes;
            shapes.add(new CircleLeak());
            shapes.add(new CircleLeak());
            shapes.add(new CircleLeak());
            shapes.removeAt(0);
            total++; passed += Test("list<unique iface> removeAt frees box", g_shapeDtor, 1);
        }
        total++; passed += Test("list<unique iface> dtor frees rest", g_shapeDtor, 3);

        g_shapeDtor = 0;
        {
            list<unique IShapeLeak> owner;
            owner.add(new CircleLeak());
            owner.add(new CircleLeak());
            {
                list<IShapeLeak> view;
                view.add(owner.get(0));
                view.add(owner.get(1));
                total++; passed += Test("bare list<iface> view count", view.count(), 2);
            }
            total++; passed += Test("bare list<iface> view frees nothing", g_shapeDtor, 0);
        }
        total++; passed += Test("bare list<iface> owner frees all", g_shapeDtor, 2);
    }

    // === STEP D: `_releaseAt` collapse - in-body drop of a moved-out element over EVERY kind ===
    // list.set()/list.removeAt() release the old/removed element by `T tmp = move _data[i]` and let
    // tmp DROP in-body (not returned) - the exact path the container-teardown collapse relies on.
    // Ownership must defer to T: a bare-pointer / interface BORROW frees nothing (a spurious free
    // double-frees), `unique` (thin ptr AND fat interface) and owning values free exactly once.
    {
        // int: primitive, drop is a no-op.
        {
            list<int> li = {10, 20, 30};
            li.removeAt(1);
            total++; passed += Test("releaseAt int removeAt count", li.count(), 2);
            li.set(0, 99);
            total++; passed += Test("releaseAt int set", li.get(0), 99);
        }
        // POD struct: no owning fields, drop frees nothing.
        {
            list<QPoint> lq = default;
            QPoint a = default; a.x = 1; a.y = 2; lq.add(a);
            QPoint b = default; b.x = 3; b.y = 4; lq.add(b);
            lq.removeAt(0);
            total++; passed += Test("releaseAt POD removeAt count", lq.count(), 1);
            QPoint c = default; c.x = 5; c.y = 6; lq.set(0, c);
            total++; passed += Test("releaseAt POD set", lq.get(0).x, 5);
        }
        // string: owning value, drop destructs the buffer (leak / double-free caught by the oracle).
        {
            list<string> ls = {"aaa", "bbb", "ccc"};
            ls.removeAt(1);                    // "bbb" destructed in-body via the moved-out local
            total++; passed += Test("releaseAt string removeAt", ls.get(1), "ccc");
            ls.set(0, plainOwnedStr(7));       // old "aaa" destructed in-body
            total++; passed += Test("releaseAt string set", ls.get(0), "owned7");
        }
        // owning value struct with a `unique` member: drop runs the synthesized destructor (frees
        // the held PtrLeak once). Non-copyable, so add/set use the move overload.
        {
            g_shapeDtor = 0;
            list<LeakHolder> lh = default;
            LeakHolder h0 = default; h0.slot = new PtrLeak(); h0.k = 1; lh.add(move h0);
            LeakHolder h1 = default; h1.slot = new PtrLeak(); h1.k = 2; lh.add(move h1);
            lh.removeAt(0);                    // frees h0's PtrLeak in-body
            total++; passed += Test("releaseAt owning-val removeAt frees member", g_shapeDtor, 1);
            LeakHolder h2 = default; h2.slot = new PtrLeak(); h2.k = 3; lh.set(0, move h2);
            total++; passed += Test("releaseAt owning-val set frees old member", g_shapeDtor, 2);
        }
        // bare P* BORROW: the list never owned the pointee - the in-body drop must free NOTHING (a
        // spurious delete here is the double-free the fix removed). The caller frees them.
        {
            g_shapeDtor = 0;
            PtrLeak* p0 = new PtrLeak();
            PtrLeak* p1 = new PtrLeak();
            list<PtrLeak*> lp = default;
            lp.add(p0);
            lp.add(p1);
            lp.removeAt(0);                    // borrow: frees nothing
            total++; passed += Test("releaseAt bare-ptr removeAt frees nothing", g_shapeDtor, 0);
            lp.set(0, p0);                     // overwrite with a borrow: frees nothing
            total++; passed += Test("releaseAt bare-ptr set frees nothing", g_shapeDtor, 0);
            delete p0; delete p1;              // caller owns both
            total++; passed += Test("releaseAt bare-ptr caller frees both", g_shapeDtor, 2);
        }
        // `unique P*` thin pointer: the list OWNS - the in-body drop frees the removed / overwritten
        // pointee exactly once.
        {
            g_shapeDtor = 0;
            list<unique PtrLeak*> lu = default;
            lu.add(new PtrLeak());
            lu.add(new PtrLeak());
            lu.removeAt(0);                    // frees the removed pointee
            total++; passed += Test("releaseAt unique-ptr removeAt frees one", g_shapeDtor, 1);
            lu.set(0, new PtrLeak());          // frees the overwritten pointee
            total++; passed += Test("releaseAt unique-ptr set frees old", g_shapeDtor, 2);
        }
        // IShapeLeak BORROW: bare interface value, the list frees nothing on the in-body drop.
        {
            g_shapeDtor = 0;
            {
                list<unique IShapeLeak> owner;
                owner.add(new CircleLeak());
                owner.add(new CircleLeak());
                {
                    list<IShapeLeak> view;
                    view.add(owner.get(0));
                    view.add(owner.get(1));
                    view.removeAt(0);          // borrow: frees nothing
                    total++; passed += Test("releaseAt iface-borrow removeAt frees nothing", g_shapeDtor, 0);
                    view.set(0, owner.get(1)); // overwrite borrow: frees nothing
                    total++; passed += Test("releaseAt iface-borrow set frees nothing", g_shapeDtor, 0);
                }
                total++; passed += Test("releaseAt iface-borrow view no free", g_shapeDtor, 0);
            }                                  // owner frees both boxes here
            total++; passed += Test("releaseAt iface-borrow owner frees all", g_shapeDtor, 2);
        }
        // `unique IShapeLeak` fat pointer: the list OWNS - the in-body drop frees the boxed object
        // via the vtable dtor slot exactly once (the leak the fix closed).
        {
            g_shapeDtor = 0;
            list<unique IShapeLeak> lui = default;
            lui.add(new CircleLeak());
            lui.add(new CircleLeak());
            lui.removeAt(0);                   // frees the removed box via the vtable dtor
            total++; passed += Test("releaseAt unique-iface removeAt frees box", g_shapeDtor, 1);
            lui.set(0, new CircleLeak());      // frees the overwritten box
            total++; passed += Test("releaseAt unique-iface set frees old box", g_shapeDtor, 2);
        }
    }

    // === Scalar `unique` interface local/param teardown (the stage-5 leak, finally fixed) ===
    // A scalar `unique IShapeLeak` local owns its heap-boxed object and frees it at scope exit
    // through the vtable dtor slot - mirroring the container leg above and the `unique Circle*`
    // scalar. A `unique IShapeLeak` PARAM (a synthesized move param) frees it in the callee.
    {
        g_shapeDtor = 0;
        { unique IShapeLeak s = new CircleLeak(); }
        total++; passed += Test("scalar unique iface local teardown", g_shapeDtor, 1);

        g_shapeDtor = 0;
        sinkShape(new CircleLeak());
        total++; passed += Test("unique iface move-param teardown", g_shapeDtor, 1);

        // nullptr owns nothing: scope exit is a null-guarded no-op, no dtor runs.
        g_shapeDtor = 0;
        { unique IShapeLeak s = nullptr; }
        total++; passed += Test("scalar unique iface null no-op", g_shapeDtor, 0);

        // Consuming an owning local by move/pass transfers ownership to the callee; the source is
        // disowned so it frees exactly ONCE (double-free before the fix).
        g_shapeDtor = 0;
        { unique IShapeLeak s = new CircleLeak(); sinkShape(move s); }
        total++; passed += Test("consume unique iface local by move frees once", g_shapeDtor, 1);

        g_shapeDtor = 0;
        { unique IShapeLeak s = new CircleLeak(); sinkShape(s); }
        total++; passed += Test("consume unique iface local by pass frees once", g_shapeDtor, 1);

        // Moving an owning local into an owning container: the container owns it, the source is
        // disowned - freed exactly once at the container's teardown.
        g_shapeDtor = 0;
        {
            list<unique IShapeLeak> xs;
            unique IShapeLeak s = new CircleLeak();
            xs.add(move s);
        }
        total++; passed += Test("move unique iface local into container frees once", g_shapeDtor, 1);

        // Reassigning an owning `unique` interface local frees the OLD object first, then the new
        // one at scope exit: two objects created, two freed, none leaked.
        g_shapeDtor = 0;
        { unique IShapeLeak s = new CircleLeak(); s = new CircleLeak(); }
        total++; passed += Test("reassign unique iface local frees old and new", g_shapeDtor, 2);

        // Exclusive branches each consuming a move interface param once and returning: the
        // returning branch's move must not poison the fall-through path (compile regression), and
        // every object frees exactly once. Each sel exercises one path; sel=2 is the fall-through.
        g_shapeDtor = 0;
        { unique IShapeLeak r = pickShape(new CircleLeak(), new CircleLeak(), 0); }
        total++; passed += Test("exclusive-branch consume path 0 frees both", g_shapeDtor, 2);
        g_shapeDtor = 0;
        { unique IShapeLeak r = pickShape(new CircleLeak(), new CircleLeak(), 1); }
        total++; passed += Test("exclusive-branch consume path 1 frees both", g_shapeDtor, 2);
        g_shapeDtor = 0;
        { unique IShapeLeak r = pickShape(new CircleLeak(), new CircleLeak(), 2); }
        total++; passed += Test("exclusive-branch consume fall-through frees both", g_shapeDtor, 2);

        // Pointer flavor of the exclusive-return pattern: compiles and frees each object once.
        g_shapeDtor = 0;
        { unique PtrLeak* r = pickPtr(new PtrLeak(), new PtrLeak(), 0); }
        total++; passed += Test("exclusive-branch ptr consume path 0 frees both", g_shapeDtor, 2);
        g_shapeDtor = 0;
        { unique PtrLeak* r = pickPtr(new PtrLeak(), new PtrLeak(), 2); }
        total++; passed += Test("exclusive-branch ptr consume fall-through frees both", g_shapeDtor, 2);

        // Dead code after a return in a consuming branch must not spuriously flag the fall-through
        // use of the same param (compile regression); each object still frees exactly once.
        g_shapeDtor = 0;
        { unique IShapeLeak r = deadCodePick(new CircleLeak(), new CircleLeak(), 0); }
        total++; passed += Test("dead-code-after-return returning path frees both", g_shapeDtor, 2);
        g_shapeDtor = 0;
        { unique IShapeLeak r = deadCodePick(new CircleLeak(), new CircleLeak(), 1); }
        total++; passed += Test("dead-code-after-return fall-through frees both", g_shapeDtor, 2);

        // Return-block early-exit: an unconditional return-block makes the branch return (the move
        // after it is dead); a conditional one may fall through. Both compile and free exactly once.
        g_shapeDtor = 0; rbUncondFree(new PtrLeak(), 1);
        total++; passed += Test("return-block unconditional exit frees once", g_shapeDtor, 1);
        g_shapeDtor = 0; rbUncondFree(new PtrLeak(), 0);
        total++; passed += Test("return-block unconditional skip frees once", g_shapeDtor, 1);
        g_shapeDtor = 0; rbCondFree(new PtrLeak(), 5);
        total++; passed += Test("return-block conditional fall-through frees once", g_shapeDtor, 1);
        g_shapeDtor = 0; rbCondFree(new PtrLeak(), -1);
        total++; passed += Test("return-block conditional exit frees once", g_shapeDtor, 1);
    }

    // A fixed-array LOCAL of `unique` elements owns every slot and releases each one at scope
    // exit - an interface array through the vtable dtor slot, a pointer array through delete.
    // An element moved out is nulled, so it is freed exactly once, by the sink.
    {
        g_shapeDtor = 0;
        {
            unique IShapeLeak[4] arr = default;
            int i = 0;
            while (i < 4) { arr[i] = new CircleLeak(); i = i + 1; }
        }
        total++; passed += Test("unique iface array frees all elements", g_shapeDtor, 4);

        g_shapeDtor = 0;
        {
            unique IShapeLeak[4] arr = default;
            int i = 0;
            while (i < 4) { arr[i] = new CircleLeak(); i = i + 1; }
            sinkShape(move arr[0]);
            total++; passed += Test("unique iface array move-out frees one", g_shapeDtor, 1);
        }
        total++; passed += Test("unique iface array frees the remaining three", g_shapeDtor, 4);

        g_shapeDtor = 0;
        {
            unique PtrLeak*[4] arr = default;
            int i = 0;
            while (i < 4) { arr[i] = new PtrLeak(); i = i + 1; }
            delPtr(move arr[0]);
            total++; passed += Test("unique ptr array move-out frees one", g_shapeDtor, 1);
        }
        total++; passed += Test("unique ptr array frees the remaining three", g_shapeDtor, 4);
    }

    // === hpc/btree<K,V> borrow-by-default migration (the last container converted) ===
    // Bare btree<K, V*> BORROWS; btree<K, unique V*> OWNS (frees on overwrite, remove, clear
    // and teardown); a VALUE element is COPIED on insert and TRANSFERRED via the move overload;
    // KEYS are always borrowed. Exercised at a scale that forces multi-level splits AND enough
    // erases to force merges/rebalances, since a mishandled split is a fill-factor-specific
    // double free. btree<K, unique IFace> owns its fat-pointer values the same way.
    {
        // unique values: freed on remove / overwrite / clear / teardown, exactly once each.
        g_shapeDtor = 0;
        {
            btree<int, unique PtrLeak*> t;
            t.add(1, new PtrLeak());
            t.add(2, new PtrLeak());
            t.add(3, new PtrLeak());
            t.remove(2);
            total++; passed += Test("btree<unique ptr> remove frees value", g_shapeDtor, 1);
            t.set(3, new PtrLeak());
            total++; passed += Test("btree<unique ptr> overwrite frees old", g_shapeDtor, 2);
            t.add(1, new PtrLeak());               // duplicate: refused, must free not leak
            total++; passed += Test("btree<unique ptr> refused duplicate frees", g_shapeDtor, 3);
            t.clear();
            total++; passed += Test("btree<unique ptr> clear frees rest", g_shapeDtor, 5);
            // Scale past a single leaf so splits and merges are on the tested path.
            int i = 0;
            while (i < 300) { t.add(i * 37 % 300, new PtrLeak()); i = i + 1; }
            int r = 0;
            while (r < 150) { t.remove(r * 37 % 300); r = r + 1; }
            total++; passed += Test("btree<unique ptr> scaled removes free", g_shapeDtor, 155);
            total++; passed += Test("btree<unique ptr> count after removes", t.count(), 150);
        }
        total++; passed += Test("btree<unique ptr> dtor frees remaining", g_shapeDtor, 305);

        // bare pointer values BORROW: nothing is freed by the tree, on any path.
        g_shapeDtor = 0;
        {
            PtrLeak*[120] owned = default;
            {
                btree<int, PtrLeak*> view;
                int i = 0;
                while (i < 120) { owned[i] = new PtrLeak(); view.add(i * 7 % 120, owned[i]); i = i + 1; }
                int r = 0;
                while (r < 60) { view.remove(r * 7 % 120); r = r + 1; }
                total++; passed += Test("btree<bare ptr> remove frees nothing", g_shapeDtor, 0);
            }
            total++; passed += Test("btree<bare ptr> dtor frees nothing", g_shapeDtor, 0);
            int k = 0;
            while (k < 120) { delete owned[k]; k = k + 1; }
            total++; passed += Test("btree<bare ptr> caller frees exactly once", g_shapeDtor, 120);
        }

        // Bare INTERFACE values BORROW, exactly like bare pointers: the tree stores fat pointers
        // to objects a list owns, frees none of them, and every element must survive the inline
        // node array intact (this is the regression for the interface-array-field mis-sizing that
        // used to clobber children[] and segfault past ~128 inserts). 400 keys forces multi-level
        // splits; 150 removes force merges/rebalances.
        g_shapeDtor = 0;
        {
            list<unique IShapeLeak> ifaceOwner;
            int i = 0;
            while (i < 400) { CircleLeak* c = new CircleLeak(); c->r = i; ifaceOwner.add(c); i = i + 1; }
            {
                btree<int, IShapeLeak> iview;
                int j = 0;
                while (j < 400) { int k = j * 37 % 400; iview.add(k, ifaceOwner.get(k)); j = j + 1; }
                total++; passed += Test("btree<bare iface> count", (i64)iview.count(), (i64)400);
                // Per-element round trip: every slot must hold the object stored under that key,
                // and dispatch through it must reach that object's own area().
                int bad = 0;
                int k2 = 0;
                while (k2 < 400)
                {
                    IShapeLeak s = default;
                    if (!iview.lookup(k2, &s) || s.area() != k2 * k2) bad = bad + 1;
                    k2 = k2 + 1;
                }
                total++; passed += Test("btree<bare iface> per-element round trip", bad, 0);
                int r = 0;
                while (r < 150) { iview.remove(r); r = r + 1; }
                total++; passed += Test("btree<bare iface> count after removes", (i64)iview.count(), (i64)250);
                int bad2 = 0;
                int k3 = 150;
                while (k3 < 400)
                {
                    IShapeLeak s = default;
                    if (!iview.lookup(k3, &s) || s.area() != k3 * k3) bad2 = bad2 + 1;
                    k3 = k3 + 1;
                }
                total++; passed += Test("btree<bare iface> round trip after merges", bad2, 0);
                iview.clear();
                total++; passed += Test("btree<bare iface> clear frees nothing", g_shapeDtor, 0);
            }
            total++; passed += Test("btree<bare iface> dtor frees nothing", g_shapeDtor, 0);
        }
        total++; passed += Test("btree<bare iface> owner frees all", g_shapeDtor, 400);

        // `unique` INTERFACE values OWN, exactly like `unique` pointers: the tree frees each boxed
        // object through the vtable dtor slot on remove, overwrite, clear and teardown, exactly
        // once. 400 keys force multi-level splits and 150 removes force merges/rebalances, so a
        // fill-factor-specific double free would abort here rather than leak quietly.
        g_shapeDtor = 0;
        {
            btree<int, unique IShapeLeak> t = default;
            t.add(1, new CircleLeak());
            t.add(2, new CircleLeak());
            t.add(3, new CircleLeak());
            t.remove(2);
            total++; passed += Test("btree<unique iface> remove frees value", g_shapeDtor, 1);
            t.set(3, new CircleLeak());
            total++; passed += Test("btree<unique iface> overwrite frees old", g_shapeDtor, 2);
            t.add(1, new CircleLeak());            // duplicate: refused, must free not leak
            total++; passed += Test("btree<unique iface> refused duplicate frees", g_shapeDtor, 3);
            t.clear();
            total++; passed += Test("btree<unique iface> clear frees rest", g_shapeDtor, 5);
            int i = 0;
            while (i < 400)
            {
                CircleLeak* c = new CircleLeak(); c->r = i * 37 % 400;
                t.add(i * 37 % 400, c);
                i = i + 1;
            }
            total++; passed += Test("btree<unique iface> count after inserts", (i64)t.count(), (i64)400);
            // Dispatch through an owned slot must still reach the object stored under that key.
            int bad = 0;
            int k2 = 0;
            while (k2 < 400)
            {
                IShapeLeak s = default;
                if (!t.lookup(k2, &s) || s.area() != k2 * k2) bad = bad + 1;
                k2 = k2 + 1;
            }
            total++; passed += Test("btree<unique iface> per-element round trip", bad, 0);
            int r = 0;
            while (r < 150) { t.remove(r); r = r + 1; }
            total++; passed += Test("btree<unique iface> scaled removes free", g_shapeDtor, 155);
            total++; passed += Test("btree<unique iface> count after removes", (i64)t.count(), (i64)250);
        }
        total++; passed += Test("btree<unique iface> dtor frees remaining", g_shapeDtor, 405);

        // A `unique` fixed-array FIELD is released slot by slot by the synthesized destructor -
        // written by hand, and reached through generic substitution. A null slot is skipped, so
        // moving one element out leaves exactly N-1 for teardown.
        {
            g_shapeDtor = 0;
            { UniqSlotBag b = default; int i = 0; while (i < 4) { b.slots[i] = new PtrLeak(); i = i + 1; } }
            total++; passed += Test("unique ptr array field frees all N", g_shapeDtor, 4);

            g_shapeDtor = 0;
            { UniqSlotBox<unique IShapeLeak> b = default; int i = 0; while (i < 4) { b.slots[i] = new CircleLeak(); i = i + 1; } }
            total++; passed += Test("substituted unique iface array field frees all N", g_shapeDtor, 4);

            g_shapeDtor = 0;
            {
                UniqSlotBag b = default; int i = 0; while (i < 4) { b.slots[i] = new PtrLeak(); i = i + 1; }
                { unique PtrLeak* taken = move b.slots[2]; }
                total++; passed += Test("moved-out element freed by its local", g_shapeDtor, 1);
            }
            total++; passed += Test("unique ptr array field frees N-1 after move-out", g_shapeDtor, 4);
        }

        // A SCALAR `unique IShapeLeak` field is a {i8*,i8*} fat pointer, so it is released through
        // the vtable dtor slot - written by hand, and reached through generic substitution.
        {
            g_shapeDtor = 0;
            { UniqIfaceSlot s = default; s.v = new CircleLeak(); }
            total++; passed += Test("written unique iface scalar field frees once", g_shapeDtor, 1);

            g_shapeDtor = 0;
            { LeakGenSlot<unique IShapeLeak> h = default; h.v = new CircleLeak(); }
            total++; passed += Test("substituted unique iface scalar field frees once", g_shapeDtor, 1);

            // Null slot: teardown must no-op, not dispatch through a null vtable.
            g_shapeDtor = 0;
            { UniqIfaceSlot s = default; }
            total++; passed += Test("null unique iface scalar field frees nothing", g_shapeDtor, 0);

            // NON-unique type argument: the field is a BORROW and must be freed by nobody but us.
            g_shapeDtor = 0;
            {
                CircleLeak* owned = new CircleLeak();
                { LeakGenSlot<IShapeLeak> h2 = default; h2.v = owned; }
                total++; passed += Test("borrowed iface scalar field frees nothing", g_shapeDtor, 0);
                delete owned;
            }
            total++; passed += Test("borrowed iface scalar field caller frees", g_shapeDtor, 1);
        }

        // Value elements are COPIED; the caller's source stays intact and independently mutable.
        {
            btree<int, LeakRow> t = default;
            LeakRow src = default; src.name = "or" + "ig";
            t.add(1, src);
            src.name = "MUT" + "ATED";
            total++; passed += Test("btree<val> add copies (slot)",   t.get(1).name, "orig");
            total++; passed += Test("btree<val> add copies (source)", src.name, "MUTATED");
            LeakRow mv = default; mv.name = "mo" + "ved";
            t.add(2, move mv);
            total++; passed += Test("btree<val> add(move) transfers", t.get(2).name, "moved");
            LeakRow mv2 = default; mv2.name = "mv" + "2";
            t.set(2, move mv2);
            total++; passed += Test("btree<val> set(move) frees old", t.get(2).name, "mv2");
            // Scale the value leg too: splits move owning buffers between nodes.
            int i = 0;
            while (i < 300) { LeakRow r = default; r.name = "n" + toString(i); t.set(10 + i * 41 % 300, move r); i = i + 1; }
            int d = 0;
            while (d < 200) { t.remove(10 + d * 41 % 300); d = d + 1; }
            total++; passed += Test("btree<val> survives split+merge", (i64)(t.count() > 0), (i64)1);
        }

        // A non-copyable value element (owns a `unique`, no copy()) is poisoned on the copying
        // add()/set() (see err_btree_noncopyable_value.cb) but stays usable through `move`.
        g_shapeDtor = 0;
        {
            btree<int, LeakHolder> t = default;
            LeakHolder h1 = default; h1.slot = new PtrLeak(); h1.k = 1;
            t.add(1, move h1);
            LeakHolder h2 = default; h2.slot = new PtrLeak(); h2.k = 2;
            t.set(1, move h2);                     // overwrite releases the old holder's pointee
            total++; passed += Test("btree<noncopy> move set frees old", g_shapeDtor, 1);
        }
        total++; passed += Test("btree<noncopy> teardown frees rest", g_shapeDtor, 2);
    }

    // === `return move <named struct local>` must transfer ownership, not strip it ===
    // Each leg leaked one string buffer before the fix; the oracle below is what fails.
    {
        MvRow a = mvPlainType();
        total++; passed += Test("move-return, plain return type", a.name, "mva");
        MvRow b = mvMoveType();
        total++; passed += Test("move-return, move return type", b.name, "mvb");
        MvRow s = default; s.name = "mv" + "c";
        MvRow c = s.copy();                    // hand-written copy() that move-returns
        total++; passed += Test("move-return, user copy()", c.name, "mvc");
        list<MvRow> l = default;
        l.add(s.copy());                       // copy() result stored in a container
        total++; passed += Test("move-return copy into list", l.get(0).name, "mvc");
        _ = mvPlainType();                     // explicit discard: owned return still freed
    }

    // === Stage 3: owning-value by-value param is a move-sink (move-by-default, no keyword) ===
    // A free sink(string)/sink(Holder) that UNCONDITIONALLY moves its param consumes an owning
    // local passed WITHOUT `move`; the caller's source is nulled so exactly one owner frees. A
    // double-free would abort HeapAudit (exit 134); a leak would trip the oracle below.
    {
        g_shapeDtor = 0;
        {
            string sv = "sink" + "str";
            strSink(sv);                       // move-by-default: sv consumed, no keyword
        }
        total++; passed += Test("owning-value string sink consumes source", g_sinkStr, "sinkstr");
        string emptyS = default;
        g_sinkStr = move emptyS;               // release the buffer strSink now owns

        {
            LeakHolder hv = default; hv.slot = new PtrLeak(); hv.k = 9;
            holderSink(hv);                    // move-by-default: hv consumed
        }
        total++; passed += Test("owning-value struct sink consumes source", g_sinkHolder.k, 9);
        total++; passed += Test("owning-value struct sink single owner (no premature free)", g_shapeDtor, 0);
        LeakHolder emptyH = default;
        g_sinkHolder = move emptyH;            // assignment frees the held PtrLeak exactly once
        total++; passed += Test("owning-value struct sink frees once on release", g_shapeDtor, 1);

        // Owning-value struct RVALUE TEMP into a sink (the rvalue-temp move-sink enabler, case A):
        // `rowSink(lr.copy())` moves the COPY temp into g_sinkRow; the temp must not ALSO be freed
        // at end-of-full-expression, or slot + temp double-free (rc 134). The source lr survives.
        {
            LeakRow lr = default; lr.name = "row" + "src";
            rowSink(lr.copy());
            total++; passed += Test("struct-temp sink source survives", lr.name, "rowsrc");
        }
        total++; passed += Test("struct-temp sink slot value", g_sinkRow.name, "rowsrc");
        LeakRow emptyR = default;
        g_sinkRow = move emptyR;               // release the slot's buffer exactly once

        // Owning-value CLOSURE local + RVALUE TEMP into a sink (Increment 1 closure enabler). A fat
        // Lambda flows through the SAME owning-value move-sink as string: passed WITHOUT `move` the
        // closure is consumed (source nulled), env transferred, single owner - no leak/double-free.
        {
            int cbase = 40;
            Lambda<int(int)> cf = (int x) => x + cbase;
            fnSink(cf);                        // move-by-default: cf consumed
        }
        total++; passed += Test("closure sink consumes named local", g_sinkFn(2), 42);
        {
            int cbase = 100;
            fnSink((int x) => x + cbase);      // rvalue-temp closure into sink: no double-free
        }
        total++; passed += Test("closure sink consumes rvalue temp", g_sinkFn(1), 101);
        Lambda<int(int)> emptyF = default;
        g_sinkFn = move emptyF;                // release the env the sink now owns

        // If-const live-branch sink: a generic method that moves its by-value owning param into a
        // local inside a LIVE `if const (!is_copyable(T))` branch consumes the caller's value (nulls
        // it, single owner). Previously the param read as a borrow -> caller + local double-freed.
        g_shapeDtor = 0;
        {
            IfConstProbe<LeakHolder> p;
            LeakHolder hv = default; hv.slot = new PtrLeak(); hv.k = 7;
            p.take(hv);                        // move-by-default via live if-const branch: hv consumed
        }
        total++; passed += Test("if-const live-branch sink frees once", g_shapeDtor, 1);
    }

    // === Increment 1: container<Lambda> dequeue-and-invoke-inline frees the returned env (bug d) ===
    // Insert stays copy-on-insert (Increment 2 collapses it); the concern is the dequeue/pop RESULT
    // - a monomorphized generic-T closure temp invoked inline must free at end-of-full-expression,
    // not leak (the registration gate previously required a static IsFunctionPointer return type).
    {
        queue<Lambda<int(int)>> q = default;
        int a = 100; int b = 200; int c = 300;
        q.enqueue((int x) => x + a);
        q.enqueue((int x) => x + b);
        q.enqueue((int x) => x + c);
        total++; passed += Test("queue<Lambda> peek invoke", q.peek()(1), 101);
        int qr0 = q.dequeue()(1);              // dequeue-and-invoke-inline: returned env must free
        int qr1 = q.dequeue()(1);
        int qr2 = q.dequeue()(1);
        total++; passed += Test("queue<Lambda> dequeue-inline slot0", qr0, 101);
        total++; passed += Test("queue<Lambda> dequeue-inline slot1", qr1, 201);
        total++; passed += Test("queue<Lambda> dequeue-inline slot2", qr2, 301);
    }
    {
        stack<Lambda<int(int)>> s = default;
        int a = 10; int b = 20;
        s.push((int x) => x + a);
        s.push((int x) => x + b);
        total++; passed += Test("stack<Lambda> peek invoke", s.peek()(1), 21);
        int sr0 = s.pop()(1);                  // pop-and-invoke-inline: returned env must free
        int sr1 = s.pop()(1);
        total++; passed += Test("stack<Lambda> pop-inline top", sr0, 21);
        total++; passed += Test("stack<Lambda> pop-inline next", sr1, 11);
    }

    // === Regression: copy of a user-dtor raw-pointer struct MOVES (no shallow-copy double-free) ===
    // `RawResLeak b = a;` has no copy() and owns a raw `node` its dtor deletes, so IsCopyableType
    // makes it non-copyable: the init MOVES (a is consumed, its node nulled) and exactly ONE delete
    // runs. A shallow copy would delete the shared node twice -> HeapAudit abort (exit 134). The
    // sibling WITH a copy() deep-copies (source stays live, two independent nodes freed once each).
    {
        g_rawNodeFreed = 0;
        {
            RawResLeak a = mkRawRes(7);
            RawResLeak b = a;                  // non-copyable -> MOVE: single owner
            total++; passed += Test("raw-ptr struct copy is move (value)", b.node.v, 7);
        }
        total++; passed += Test("raw-ptr struct move frees node once", g_rawNodeFreed, 1);

        g_rawNodeFreed = 0;
        {
            RawResCopyable a = default; a.node = new RawResNodeLeak(); a.node.v = 5;
            RawResCopyable b = a;              // has copy() -> deep COPY: source a stays live
            total++; passed += Test("raw-ptr copy() source live", a.node.v, 5);
            total++; passed += Test("raw-ptr copy() independent value", b.node.v, 5);
        }
        total++; passed += Test("raw-ptr copy() frees two independent nodes", g_rawNodeFreed, 2);
    }

    // === Regression: list<T>.sort() relocates elements via a raw bit-copy swap in _qsort /
    // _partition / _medianPivot (`T tmp = _data[i]; _data[i] = _data[j]; _data[j] = tmp;`). That
    // shuffle bypasses the ownership machinery, so it must be exercised over OWNING element types
    // too, not just int / bare pointers - a copy/move miscount here would show up as a leak or a
    // double free at scope exit below.
    {
        // list<string>: sort must reorder without leaking or double-freeing any owned buffer.
        {
            list<string> ls = {"pear", "apple", "mango", "banana", "kiwi", "grape"};
            ls.sort((string a, string b) => { return a < b; });
            total++; passed += Test("list<string> sort count", ls.count(), 6);
            total++; passed += Test("list<string> sort first", ls.get(0), "apple");
            total++; passed += Test("list<string> sort last",  ls.get(5), "pear");
        }

        // list<LeakRow>: an OWNING value struct (string field) sorted by that field.
        {
            list<LeakRow> rows = default;
            LeakRow r1 = default; r1.name = "delta";   rows.add(r1);
            LeakRow r2 = default; r2.name = "alpha";   rows.add(r2);
            LeakRow r3 = default; r3.name = "charlie"; rows.add(r3);
            LeakRow r4 = default; r4.name = "bravo";   rows.add(r4);
            rows.sort((LeakRow a, LeakRow b) => { return a.name < b.name; });
            total++; passed += Test("list<LeakRow> sort count", rows.count(), 4);
            total++; passed += Test("list<LeakRow> sort first", rows.get(0).name, "alpha");
            total++; passed += Test("list<LeakRow> sort last",  rows.get(3).name, "delta");
        }

        // list<unique PtrLeak*>: sort by a field; every element must be freed exactly once at
        // scope exit (the swap only relocates the pointer bits, ownership count is unaffected).
        g_shapeDtor = 0;
        {
            list<unique PtrLeak*> lu = default;
            PtrLeak* p0 = new PtrLeak(); p0.v = 40; lu.add(move p0);
            PtrLeak* p1 = new PtrLeak(); p1.v = 10; lu.add(move p1);
            PtrLeak* p2 = new PtrLeak(); p2.v = 30; lu.add(move p2);
            PtrLeak* p3 = new PtrLeak(); p3.v = 20; lu.add(move p3);
            lu.sort((PtrLeak* a, PtrLeak* b) => { return a.v < b.v; });
            total++; passed += Test("list<unique ptr> sort count",  lu.count(), 4);
            total++; passed += Test("list<unique ptr> sort first",  lu.get(0).v, 10);
            total++; passed += Test("list<unique ptr> sort last",   lu.get(3).v, 40);
            total++; passed += Test("list<unique ptr> sort live before teardown", g_shapeDtor, 0);
        }
        total++; passed += Test("list<unique ptr> sort teardown frees each once", g_shapeDtor, 4);
    }

    // === Regression: dictionary<K,V>._maybeRehash relocates every live entry into a fresh, larger
    // buffer via a raw bit-copy (`_keys[slot] = oldKeys[i]; _values[slot] = oldValues[i];`) plus a
    // buffer-only `delete[_]` of the old arrays. Force MULTIPLE rehashes (initial capacity is 8,
    // doubling on load factor) over OWNING keys and OWNING values to prove the relocation neither
    // leaks nor double-frees.
    {
        // dictionary<string, string>: owning keys AND owning values, well past several rehashes.
        {
            dictionary<string, string> d = default;
            int i = 0;
            while (i < 120) { d.add("k" + i.toString(), "v" + i.toString()); i++; }
            total++; passed += Test("dict<str,str> rehash count",        d.count(), 120);
            total++; passed += Test("dict<str,str> rehash lookup early", d.get("k0"),   "v0");
            total++; passed += Test("dict<str,str> rehash lookup mid",   d.get("k60"),  "v60");
            total++; passed += Test("dict<str,str> rehash lookup last",  d.get("k119"), "v119");
        }

        // dictionary<string, unique PtrLeak*>: owning keys AND owning unique-pointer values,
        // rehashed several times (8 -> 16 -> 32 -> 64); every value must free exactly once.
        g_shapeDtor = 0;
        {
            dictionary<string, unique PtrLeak*> d2 = default;
            int i = 0;
            while (i < 40)
            {
                PtrLeak* p = new PtrLeak();
                p.v = i;
                d2.add("k" + i.toString(), move p);
                i++;
            }
            total++; passed += Test("dict<str,unique ptr> rehash count",  d2.count(), 40);
            total++; passed += Test("dict<str,unique ptr> rehash lookup", d2.get("k20").v, 20);
            total++; passed += Test("dict<str,unique ptr> rehash live before teardown", g_shapeDtor, 0);
        }
        total++; passed += Test("dict<str,unique ptr> rehash teardown frees each once", g_shapeDtor, 40);
    }

    // === Leak oracle: everything above must have freed on scope exit ===
    u64 leaks = HeapAudit.reportLeaks();
    total++; passed += Test("HeapAudit live allocations", (i64)leaks, (i64)0);

    // === Bug 10: globals are destructed on main's normal return (see _gLeakGate above) ===
    // Populated after the oracle above so it still sees zero; _gLeakGate's destructor re-audits
    // once these have been torn down and fails the process if a buffer survived.
    _gNums.add(1);
    _gNums.add(2);
    _gMap.set("k", "v");
    total++; passed += Test("global list live", _gNums.count(), 2);
    total++; passed += Test("global dict live", _gMap.get("k"), "v");

    if (passed == total)
    {
        printf("ALL %d collection-leak regression tests passed.\n", total);
        return 0;
    }
    printf("%d of %d collection-leak regression tests FAILED.\n", total - passed, total);
    return 1;
}
