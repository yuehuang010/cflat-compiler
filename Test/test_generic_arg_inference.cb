// Verify free-function generic argument inference works:
// calling pick(3, 7) without explicit <int> should instantiate pick<int>.

extern int printf(const char* fmt, ...);

auto pick<T>(T a, T b) { return a > b ? a : b; }

extern int main()
{
    if (pick(3, 7) != 7)            return 1;
    if (pick(9, 2) != 9)            return 2;
    if (pick((i64)10, (i64)20) != (i64)20) return 3;
    printf("test_generic_arg_inference: ok\n");
    return 0;
}
