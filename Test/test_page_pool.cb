// Smoke test for page_pool.cb — exercise acquire/release/cleanup correctness
// and the soft-cap behavior in single-threaded form.

import "page_pool.cb";

// Acquire returns a fully-zeroed 64KB page.
bool testAcquireZeroed()
{
    void* p = g_page_pool.acquire();
    if (p == nullptr) return false;

    i8* bytes = (i8*)p;
    int i = 0;
    while (i < 65536)
    {
        if (bytes[i] != (i8)0) { g_page_pool.release(p); return false; }
        i = i + 1;
    }
    g_page_pool.release(p);
    return true;
}

// Release a page, acquire again — should reuse the same address (LIFO),
// fully zeroed including the byte we marked before release.
bool testRecycle()
{
    g_page_pool.cleanup();

    void* a = g_page_pool.acquire();
    if (a == nullptr) return false;

    i8* bytes = (i8*)a;
    bytes[100] = (i8)42;

    g_page_pool.release(a);

    void* b = g_page_pool.acquire();
    if (b != a) return false;

    i8* bytesB = (i8*)b;
    if (bytesB[100] != (i8)0) return false;

    g_page_pool.release(b);
    return true;
}

// Push cap+10 pages — depth must not exceed cap (excess goes to vmem_free).
bool testSoftCap()
{
    g_page_pool.cleanup();

    int total = 270;
    list<i64> arr;   // store page addresses as i64 (list<void*> not yet supported)

    int i = 0;
    while (i < total)
    {
        void* p = g_page_pool.acquire();
        if (p == nullptr) return false;
        arr.add((i64)p);
        i = i + 1;
    }

    i = 0;
    while (i < total)
    {
        g_page_pool.release((void*)arr.get(i));
        i = i + 1;
    }

    if (g_page_pool.cachedPages() > (i64)256) return false;

    g_page_pool.cleanup();
    if (g_page_pool.cachedPages() != (i64)0) return false;

    return true;
}

extern int main()
{
    if (!testAcquireZeroed()) { printf("FAIL: testAcquireZeroed\n"); return 1; }
    if (!testRecycle())       { printf("FAIL: testRecycle\n");       return 2; }
    if (!testSoftCap())       { printf("FAIL: testSoftCap\n");       return 3; }
    printf("PASS: page_pool test\n");
    return 0;
}
