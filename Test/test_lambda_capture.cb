// Comprehensive test for lambda capture:
// value capture (primitives, pointers, string, function<T>)
// reference capture (struct, class)

import "string.cb";

// ── Supporting types ─────────────────────────────────────────────────────────

struct Counter {
    int value = 0;
};

struct Stats {
    float min   = 0.0f;
    float max   = 0.0f;
    int   count = 0;
};

interface ITransform {
    int apply(int x);
};

class Multiplier : ITransform {
    int factor = 1;
    int apply(int x) { return x * factor; }
};

class Adder : ITransform {
    int offset = 0;
    int apply(int x) { return x + offset; }
};

// Helper: calls fn(arg) and returns result
int ApplyFn(function<int(int)> fn, int arg) {
    return fn(arg);
}

// ── Tests ────────────────────────────────────────────────────────────────────

extern int main() {

    // 1. int — value capture; outer mutation does not affect captured copy
    {
        int x = 10;
        function<int()> getX = () => { return x; };
        if (getX() != 10) return 1;
        x = 99;
        if (getX() != 10) return 1;
    }

    // 2. float — value capture; lambda sees snapshot at capture time
    {
        float factor = 2.5f;
        function<float(float)> scale = (float v) => { return v * factor; };
        if (scale(4.0f) != 10.0f) return 2;
        factor = 999.0f;
        if (scale(4.0f) != 10.0f) return 2;
    }

    // 3. double — value capture
    {
        double multiplier = 3.0;
        function<double(double)> triple = (double v) => { return v * multiplier; };
        double result = triple(7.0);
        if (result < 20.9 || result > 21.1) return 3;
        multiplier = 0.0;
        result = triple(7.0);
        if (result < 20.9 || result > 21.1) return 3;
    }

    // 4. bool — value capture; lambda holds copy
    {
        bool enabled = true;
        function<bool()> isEnabled = () => { return enabled; };
        if (!isEnabled()) return 4;
        enabled = false;
        if (!isEnabled()) return 4;
    }

    // 5. i64 — value capture
    {
        i64 big = 4000000000;
        function<i64()> getBig = () => { return big; };
        if (getBig() != 4000000000) return 5;
        big = 0;
        if (getBig() != 4000000000) return 5;
    }

    // 6. char* — value capture (pointer copy; both sides read same bytes)
    {
        char* msg = "hello";
        function<int()> getLen = () => { return strlen(msg); };
        if (getLen() != 5) return 6;
    }

    // 7. int* — value capture; writes through the shared pointer are visible
    {
        int* p = new int;
        *p = 42;
        function<int()> read = () => { return *p; };
        if (read() != 42) return 7;
        *p = 77;
        if (read() != 77) return 7;
    }

    // 8. struct pointer (Counter*) — value capture of pointer; mutations visible
    {
        Counter* cp = new Counter;
        cp->value = 5;
        function<void()> incHeap = () => { cp->value = cp->value + 1; };
        incHeap();
        incHeap();
        if (cp->value != 7) return 8;
    }

    // 9. string — value capture (string is a value type {i8*,i32}; copy taken at capture time)
    {
        string label = "world";
        function<int()> getLen = () => { return label.length(); };
        if (getLen() != 5) return 9;
        // Lambda holds a copy — outer reassignment does NOT change captured value
        label = "hi";
        if (getLen() != 5) return 9;
    }

    // 10. string — equality check inside lambda
    {
        string greeting = "hello";
        function<bool(string)> matches = (string s) => { return greeting == s; };
        if (!matches("hello")) return 10;
        if (matches("world")) return 10;
    }

    // 11. string — data() access inside lambda
    {
        string word = "abc";
        function<char*()> getPtr = () => { return word.data(); };
        char* ptr = getPtr();
        if (ptr == nullptr) return 11;
        if (strlen(ptr) != 3) return 11;
    }

    // 12. struct (Counter) — reference capture; lambda mutations visible to caller
    {
        Counter c;
        function<void()> inc = () => { c.value = c.value + 1; };
        inc(); inc(); inc();
        if (c.value != 3) return 12;
    }

    // 13. struct (Stats) — reference capture of multi-field struct
    {
        Stats s;
        function<void(float)> observe = (float v) => {
            if (s.count == 0 || v < s.min) s.min = v;
            if (s.count == 0 || v > s.max) s.max = v;
            s.count = s.count + 1;
        };
        observe(3.0f);
        observe(1.0f);
        observe(5.0f);
        if (s.count != 3) return 13;
        if (s.min != 1.0f) return 13;
        if (s.max != 5.0f) return 13;
    }

    // 14. class (Multiplier) — reference capture; caller mutations visible in lambda
    {
        Multiplier m;
        m.factor = 3;
        function<int(int)> tripleIt = (int x) => { return m.apply(x); };
        if (tripleIt(7) != 21) return 14;
        m.factor = 5;
        if (tripleIt(7) != 35) return 14;
    }

    // 15. class (Adder) — reference capture with method call
    {
        Adder a;
        a.offset = 100;
        function<int(int)> add100 = (int x) => { return a.apply(x); };
        if (add100(5) != 105) return 15;
        if (add100(-3) != 97) return 15;
    }

    // 16. interface — value capture (fat ptr {vtable,data} copied)
    {
        Multiplier m;
        m.factor = 4;
        ITransform t = m;
        function<int(int)> callT = (int x) => { return t.apply(x); };
        if (callT(6) != 24) return 16;
        if (callT(3) != 12) return 16;
    }

    // 17. multiple captures: int + float + struct
    {
        int base = 10;
        float rate = 1.5f;
        Counter total;
        function<void(int)> accumulate = (int n) => {
            total.value = total.value + (int)(n * rate) + base;
        };
        accumulate(2);   // total = 0 + (int)(2*1.5) + 10 = 3 + 10 = 13
        accumulate(4);   // total = 13 + (int)(4*1.5) + 10 = 13 + 6 + 10 = 29
        if (total.value != 29) return 17;
    }

    // 18. multiple captures: string (value) + Counter (reference)
    {
        string prefix = "item_";   // len=5, value-captured
        Counter counter;
        function<int()> nextId = () => {
            counter.value = counter.value + 1;
            return prefix.length() + counter.value;
        };
        if (nextId() != 6) return 18;   // len=5, counter=1 → 6
        if (nextId() != 7) return 18;   // counter=2 → 7
        if (counter.value != 2) return 18;
    }

    // 19. lambda passed as argument, captures struct
    {
        Counter c;
        function<int(int)> addToC = (int n) => { c.value = c.value + n; return c.value; };
        int r = ApplyFn(addToC, 5);
        if (r != 5) return 19;
        r = ApplyFn(addToC, 3);
        if (r != 8) return 19;
        if (c.value != 8) return 19;
    }

    // 20. function<T> variable — value capture of fat struct
    {
        int base = 100;
        function<int(int)> addBase = (int x) => { return x + base; };
        function<int(int)> doubleAndAdd = (int x) => { return addBase(x * 2); };
        if (doubleAndAdd(5) != 110) return 20;
        if (doubleAndAdd(0) != 100) return 20;
    }

    // 21. non-capturing lambda still works
    {
        function<int(int, int)> add = (int a, int b) => { return a + b; };
        if (add(3, 4) != 7) return 21;
        if (add(-1, 1) != 0) return 21;
    }

    // 22. bool — captured flag used as branch inside lambda
    {
        bool negate = false;
        function<int(int)> maybeNeg = (int x) => {
            if (negate) return -x;
            return x;
        };
        if (maybeNeg(5) != 5) return 22;
        negate = true;
        if (maybeNeg(5) != 5) return 22;  // captured copy is still false
    }

    // 23. i64 arithmetic inside lambda
    {
        i64 multiplier = 1000000;
        function<i64(int)> scale = (int n) => { return (i64)n * multiplier; };
        if (scale(3) != 3000000) return 23;
    }

    return 0;
}
