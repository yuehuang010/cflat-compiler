import "fit_allocator.cb";

// =============================================================
// Basic alloc/dealloc
// =============================================================

bool testBasic()
{
    FitAllocator fa;

    void* p1 = fa.alloc(64);
    if (p1 == nullptr) return false;

    void* p2 = fa.alloc(64);
    if (p2 == nullptr) return false;
    if (p1 == p2)      return false;

    if (fa.usedBytes() != 128) return false;

    fa.dealloc(p1);
    if (fa.usedBytes() != 64) return false;

    fa.dealloc(p2);
    if (fa.usedBytes() != 0) return false;

    return true;
}

// =============================================================
// Write-and-read-back
// =============================================================

bool testWriteRead()
{
    FitAllocator fa;

    i32* arr = (i32*)fa.alloc(32);
    if (arr == nullptr) return false;
    arr[0] = 10; arr[1] = 20; arr[2] = 30; arr[3] = 40;
    if (arr[0] != 10) return false;
    if (arr[1] != 20) return false;
    if (arr[2] != 30) return false;
    if (arr[3] != 40) return false;

    fa.dealloc((void*)arr);
    return true;
}

// =============================================================
// Mixed sizes — fragmentation and reuse
// =============================================================

bool testMixedSizes()
{
    FitAllocator fa;

    void* a = fa.alloc(16);
    void* b = fa.alloc(64);
    void* c = fa.alloc(128);
    void* d = fa.alloc(32);
    if (a == nullptr) return false;
    if (b == nullptr) return false;
    if (c == nullptr) return false;
    if (d == nullptr) return false;

    fa.dealloc(b);
    fa.dealloc(d);

    // Two gaps exist. A 64-byte request should fit in the former b slot.
    void* e = fa.alloc(64);
    if (e == nullptr) return false;

    if (fa.usedBytes() != 16 + 128 + 64) return false;

    fa.dealloc(a);
    fa.dealloc(c);
    fa.dealloc(e);
    if (fa.usedBytes() != 0) return false;

    return true;
}

// =============================================================
// Coalescing — adjacent free blocks merge
// =============================================================

bool testCoalescing()
{
    FitAllocator fa;

    void* a = fa.alloc(128);
    void* b = fa.alloc(128);
    void* c = fa.alloc(128);
    if (a == nullptr) return false;
    if (b == nullptr) return false;
    if (c == nullptr) return false;

    i64 freeBefore = fa.freeBytes();

    fa.dealloc(a);
    fa.dealloc(c);
    fa.dealloc(b);  // b is between a and c — should coalesce all three

    i64 freeAfter = fa.freeBytes();

    // After coalescing, free space should be freeBefore + 3*128 + 2 headers.
    // We just verify free space grew and usedBytes is zero.
    if (fa.usedBytes() != 0)         return false;
    if (freeAfter <= freeBefore)     return false;

    // The coalesced block should be large enough for a 384-byte alloc.
    void* big = fa.alloc(128 * 3);
    if (big == nullptr) return false;
    fa.dealloc(big);

    return true;
}

// =============================================================
// Segment growth — alloc more than one segment
// =============================================================

bool testSegmentGrowth()
{
    FitAllocator fa;

    // Allocate ~600K in 4K chunks to exhaust the default 1MB segment.
    int N = 160;
    int i = 0;
    while (i < N)
    {
        void* p = fa.alloc(4096);
        if (p == nullptr) return false;
        i = i + 1;
    }
    // Should have grown into a second segment.
    if (fa.usedBytes() != (i64)N * 4096) return false;

    return true;
}

// =============================================================
// Large allocation (> half segment size)
// =============================================================

bool testLargeAlloc()
{
    FitAllocator fa;

    void* p = fa.alloc(1048576);  // 1 MB — goes to large path
    if (p == nullptr) return false;
    if (fa.usedBytes() != 1048576) return false;

    i32* arr = (i32*)p;
    arr[0] = 777;
    if (arr[0] != 777) return false;

    fa.dealloc(p);
    if (fa.usedBytes() != 0) return false;

    return true;
}

// =============================================================
// Zero-size and nullptr dealloc are no-ops
// =============================================================

bool testEdgeCases()
{
    FitAllocator fa;

    void* p = fa.alloc(0);
    if (p != nullptr) return false;

    fa.dealloc(nullptr);  // must not crash

    return true;
}

// =============================================================
// printUsage doesn't crash
// =============================================================

bool testPrintUsage()
{
    FitAllocator fa;
    fa.alloc(64);
    fa.alloc(2097152);
    fa.printUsage();
    return true;
}

extern int main()
{
    int passed = 0;
    int total  = 0;
    total++; passed += testBasic()          ? 1 : 0;
    total++; passed += testWriteRead()      ? 1 : 0;
    total++; passed += testMixedSizes()     ? 1 : 0;
    total++; passed += testCoalescing()     ? 1 : 0;
    total++; passed += testSegmentGrowth()  ? 1 : 0;
    total++; passed += testLargeAlloc()     ? 1 : 0;
    total++; passed += testEdgeCases()      ? 1 : 0;
    total++; passed += testPrintUsage()     ? 1 : 0;
    printf("%d/%d tests passed.\n", passed, total);
    return passed == total ? 0 : 1;
}
