// Named enum - enumerators should be registered as globals.
enum MyEnum : u8 { E_ONE = 1, E_TWO, E_THREE = 5 };

bool testEnum()
{
    bool result = true;
    result &= Test("enum_E_ONE", MyEnum.E_ONE, 1);
    result &= Test("enum_E_TWO", MyEnum.E_TWO, 2);
    result &= Test("enum_E_THREE", MyEnum.E_THREE, 5);
    return result;
}

struct MyStruct
{
    int num1 = 1;
    int num2 = 2;
    int num3 = 3;
};

int TotalByValue(MyStruct mystruct)
{
    return mystruct.num1 + mystruct.num2 + mystruct.num2;
}

int TotalByPointer(MyStruct* mystruct)
{
    return mystruct->num1 + mystruct->num2 + mystruct->num2;
}

struct MyStruct1
{
    int num = 1;
    int Read() { return num; }
};

struct MyStruct2
{
    int num = 2;
    int Read() { return num; }
};

// Overloaded Extension function
int ReadExt(MyStruct1 my) { return my.num; }
int ReadExt(MyStruct2 my) { return my.num; }

// Destructor tests

int destructorCallCount = 0;

struct Tracked
{
    int id = 0;
    ~Tracked()
    {
        destructorCallCount = destructorCallCount + 1;
    }
};

bool testDestructor()
{
    bool result = true;
    destructorCallCount = 0;

    {
        Tracked t = Tracked();
    }
    result &= Test("destructor_called_once", destructorCallCount, 1);

    {
        Tracked a = Tracked();
        Tracked b = Tracked();
    }
    result &= Test("destructor_called_twice", destructorCallCount, 3);

    return result;
}


// Default parameter tests

int addWithDefault(int x, int y = 5)
{
    return x + y;
}

bool testDefaultSingleParam()
{
    bool result = true;
    result &= Test("add_both_args", addWithDefault(3, 4), 7);  // 3+4=7
    result &= Test("add_default_y", addWithDefault(3), 8);  // 3+5=8
    return result;
}

int sumWithDefaults(int x, int y = 10, int z = 20)
{
    return x + y + z;
}

bool testDefaultMultipleParams()
{
    bool result = true;
    result &= Test("sum_all_args", sumWithDefaults(1, 2, 3), 6);   // 1+2+3=6
    result &= Test("sum_default_z", sumWithDefaults(1, 2), 23);  // 1+2+20=23
    result &= Test("sum_defaults_yz", sumWithDefaults(1), 31);  // 1+10+20=31
    return result;
}

int multiplyWithDefault(int x, int factor = 2)
{
    return x * factor;
}

bool testDefaultExpression()
{
    bool result = true;
    result &= Test("multiply_explicit", multiplyWithDefault(5, 3), 15);  // 5*3=15
    result &= Test("multiply_default", multiplyWithDefault(5), 10);  // 5*2=10
    return result;
}

// Regression: a method default parameter whose bare name collides with a
// same-named method on an UNRELATED type used to abort the compile with
// "named argument '<Type>__' does not match any parameter". The default-param
// forwarding wrapper leaked the leading `this` (named "<Type>__") as a NAMED
// argument; when that forwarding call was resolved against the sibling type's
// method it hard-errored instead of rejecting the candidate. The wrapper now
// forwards positionally. (Repro: two types both with a method `mix`, one with a
// default param.)
struct DefaultParamOther {
    int mix(int a, int b) { return a + b; }
};
struct DefaultParamSelf {
    int mix(int a, int scale = 10) { return a * scale; }
};

bool testDefaultParamNameCollision()
{
    bool result = true;
    DefaultParamOther o;
    DefaultParamSelf s;
    result &= Test("collide_other_type", o.mix(3, 4), 7);    // 3+4
    result &= Test("collide_explicit",   s.mix(3, 2), 6);    // 3*2
    result &= Test("collide_default",    s.mix(3), 30);      // 3*10
    return result;
}

extern int strcmp(const char* a, const char* b);

bool Test(const char* testName, const char* actual, const char* expected)
{
    if (strcmp(actual, expected) == 0)
    {
        printf("%s passed.\n", testName);
        return true;
    }
    printf("%s failed: expected '%s' but got '%s'.\n", testName, expected, actual);
    return false;
}

struct NamedThing
{
    int value = 42;
};


struct TypedThing
{
    int count = 0;
    bool flag = false;
};

bool testTypeof()
{
    bool result = true;
    int i = 0;
    bool b = false;
    TypedThing t = TypedThing();

    result &= Test("typeof_int", typeof(i), "int");
    result &= Test("typeof_bool", typeof(b), "bool");
    result &= Test("typeof_struct", typeof(t), "TypedThing");
    result &= Test("typeof_field_int", typeof(t.count), "int");
    result &= Test("typeof_field_bool", typeof(t.flag), "bool");
    result &= Test("typeof_type_int", typeof(int), "int");
    result &= Test("typeof_type_name", typeof(TypedThing), "TypedThing");
    return result;
}

bool testNameof()
{
    bool result = true;
    int myVar = 0;
    NamedThing thing = NamedThing();

    result &= Test("nameof_var", nameof(myVar), "myVar");
    result &= Test("nameof_struct", nameof(thing), "thing");
    result &= Test("nameof_field", nameof(thing.value), "value");
    result &= Test("nameof_type", nameof(NamedThing), "NamedThing");
    return result;
}

// Namespace tests

int add(int a, int b) { return a + b + 100; }  // global add returns a different value

namespace MathUtils
{
    // Namespace globals register under their qualified name (MathUtils.nsCounter),
    // like namespace functions: qualified access works from outside, bare sibling
    // access works from inside, and the bare name does NOT leak outside.
    int nsCounter = 7;
    const int BASE = 120;

    int readCounter() { return nsCounter; }
    void bumpCounter() { nsCounter++; }

    int add(int a, int b) { return a + b; }
    int multiply(int a, int b) { return a * b; }

    // Unqualified sibling call: `add` must resolve to MathUtils.add (NOT the global
    // `add` that returns a+b+100), so addThenDouble(3,4) == (3+4)*2 == 14.
    int addThenDouble(int a, int b) { return multiply(add(a, b), 2); }

    // `global::add` escapes the namespace and reaches the GLOBAL add (a+b+100),
    // even though the sibling MathUtils.add (a+b) would shadow a bare `add`.
    int addViaGlobal(int a, int b) { return global::add(a, b); }

    // Bare `add` still resolves to the sibling MathUtils.add (a+b).
    int addViaSibling(int a, int b) { return add(a, b); }

    namespace Advanced
    {
        int square(int x) { return x * x; }
        int cube(int x) { return x * x * x; }

        // Unqualified sibling call inside a nested namespace resolves to
        // Advanced.square; sumOfSquares(3,4) == 9 + 16 == 25.
        int sumOfSquares(int a, int b) { return square(a) + square(b); }

        // `global::` with a dotted path resolves at the root: global::MathUtils.add
        // is the sibling-free root MathUtils.add (a+b), reached from this nested scope.
        int addViaGlobalDotted(int a, int b) { return global::MathUtils.add(a, b); }

        // A bare global reference inside a nested namespace walks outward through
        // parent namespaces: BASE resolves to MathUtils.BASE.
        int readOuterBase() { return BASE; }
    }
}

// Dotted namespace declaration: `namespace a.b { }` declares the nested chain in
// one line. An extern inside a namespace registers under the qualified lookup
// name (sysapi.win.GetCurrentProcessId) but keeps its bare linkage symbol, so it
// binds to the same imported C function. A namespace function signature may
// reference a sibling struct unqualified.
namespace sysapi.win
{
    extern stdcall u32 GetCurrentProcessId();

    struct Box2 {
        int w = default;
        int h = default;
    };

    int area(Box2* b) { return b->w * b->h; }
}

using Math = MathUtils;          // global alias for top-level namespace
using MathAdv = MathUtils.Advanced;  // global alias for nested namespace

bool testNamespace()
{
    bool result = true;
    result &= Test("namespace_add", MathUtils.add(3, 4), 7);            // 3+4=7
    result &= Test("namespace_multiply", MathUtils.multiply(3, 4), 12); // 3*4=12
    result &= Test("global_add", add(3, 4), 107);                       // 3+4+100=107
    result &= Test("no_collision", MathUtils.add(3, 4) != add(3, 4), 1);
    result &= Test("global_using_add", Math.add(3, 4), 7);              // global alias resolves to MathUtils.add
    result &= Test("global_using_multiply", Math.multiply(3, 4), 12);   // global alias resolves to MathUtils.multiply
    // Unqualified sibling call inside the namespace must resolve to the namespace
    // member (more-local wins over the global `add`): (3+4)*2 = 14, not (3+4+100)*2.
    result &= Test("sibling_call", MathUtils.addThenDouble(3, 4), 14);
    result &= Test("nested_sibling_call", MathUtils.Advanced.sumOfSquares(3, 4), 25); // 9+16=25
    // global:: escapes the sibling shadow: addViaGlobal reaches the global add (a+b+100),
    // while addViaSibling still resolves to the namespace member (a+b).
    result &= Test("global_scope_escape", MathUtils.addViaGlobal(3, 4), 107);          // 3+4+100
    result &= Test("global_scope_sibling_still_local", MathUtils.addViaSibling(3, 4), 7); // 3+4
    // global:: with a dotted path resolves at the root namespace.
    result &= Test("global_scope_dotted", MathUtils.Advanced.addViaGlobalDotted(3, 4), 7); // 3+4
    // Namespace globals: qualified read/write from outside, bare sibling access inside.
    result &= Test("namespace_global_const", MathUtils.BASE, 120);
    result &= Test("namespace_global_read", MathUtils.nsCounter, 7);
    result &= Test("namespace_global_sibling_read", MathUtils.readCounter(), 7);
    MathUtils.bumpCounter();                       // bare sibling write inside
    result &= Test("namespace_global_sibling_write", MathUtils.nsCounter, 8);
    MathUtils.nsCounter = 42;                      // qualified write from outside
    result &= Test("namespace_global_qualified_write", MathUtils.readCounter(), 42);
    result &= Test("namespace_global_alias", Math.BASE, 120);  // via `using Math = MathUtils`
    result &= Test("namespace_global_outer_from_nested", MathUtils.Advanced.readOuterBase(), 120);
    // Dotted namespace declaration + extern with bare linkage inside a namespace.
    result &= Test("dotted_ns_extern", sysapi.win.GetCurrentProcessId() != 0, true);
    sysapi.win.Box2 bx;
    bx.w = 3; bx.h = 5;
    result &= Test("dotted_ns_struct_sibling_sig", sysapi.win.area(&bx), 15);
    return result;
}

bool testLocalUsing()
{
    using M = MathUtils;  // local alias, only visible in this function
    bool result = true;
    result &= Test("local_using_add", M.add(2, 3), 5);
    result &= Test("local_using_multiply", M.multiply(2, 3), 6);
    return result;
}

bool testNestedNamespace()
{
    bool result = true;
    result &= Test("nested_square", MathUtils.Advanced.square(4), 16);    // 4*4=16
    result &= Test("nested_cube", MathUtils.Advanced.cube(3), 27);        // 3*3*3=27

    using Adv = MathUtils.Advanced;  // local alias for nested namespace
    result &= Test("nested_using_square", Adv.square(5), 25);             // 5*5=25
    result &= Test("nested_using_cube", Adv.cube(2), 8);                  // 2*2*2=8
    return result;
}

bool testNestedUsing()
{
    bool result = true;

    // Global alias for nested namespace
    result &= Test("global_nested_using_square", MathAdv.square(4), 16);  // 4*4=16
    result &= Test("global_nested_using_cube", MathAdv.cube(3), 27);      // 3*3*3=27

    // Local alias for nested namespace shadows nothing; verify it works
    using Adv2 = MathUtils.Advanced;
    result &= Test("local_nested_using_square", Adv2.square(6), 36);      // 6*6=36
    result &= Test("local_nested_using_cube", Adv2.cube(4), 64);          // 4*4*4=64
    return result;
}

bool testLocalUsingScoped()
{
    // 'M' from testLocalUsing is not visible here; only 'Math' global alias is.
    bool result = true;
    result &= Test("local_alias_not_leaked", Math.add(1, 2), 3);
    return result;
}

// =============================================================
// Forward reference tests
// =============================================================

// Test 1: bar() calls foo() which is defined after bar().
int bar()
{
    return foo();
}

int foo()
{
    return 42;
}

bool testForwardFunction()
{
    bool result = true;
    result &= Test("bar calls foo (fwd ref)", bar(), 42);
    return result;
}

// Test 2: Mutual recursion - no explicit forward declaration needed.
bool isEven(int n)
{
    if (n == 0) return true;
    return isOdd(n - 1);
}

bool isOdd(int n)
{
    if (n == 0) return false;
    return isEven(n - 1);
}

bool testMutualRecursion()
{
    bool result = true;
    result &= Test("isEven(0)", isEven(0), 1);
    result &= Test("isEven(4)", isEven(4), 1);
    result &= Test("isOdd(1)",  isOdd(1),  1);
    result &= Test("isOdd(5)",  isOdd(5),  1);
    result &= Test("isEven(3) is false", isEven(3), 0);
    result &= Test("isOdd(4) is false",  isOdd(4),  0);
    return result;
}

// Test 3: runAccumulator() calls getTotal() which is defined after the struct.
int runAccumulator()
{
    return getTotal();
}

struct Accumulator
{
    int x = 10;
    int y = 20;
    int z = 30;

    int Total()
    {
        return x + y + z;
    }
};

int getTotal()
{
    Accumulator a = Accumulator();
    return a.Total();
}

bool testForwardFunctionWithStruct()
{
    bool result = true;
    result &= Test("runAccumulator (fwd ref to getTotal)", runAccumulator(), 60);
    return result;
}

// Test 4: Member function calls a member function defined later in the struct.
struct Calculator
{
    int value = 10;

    int ComputeDouble()
    {
        return doubleIt();
    }

    int ComputeSum()
    {
        return addThree(5, 3);
    }

    int doubleIt()
    {
        return value * 2;
    }

    int addThree(int b, int c)
    {
        return value + b + c;
    }
};

bool testForwardInStruct()
{
    bool result = true;
    Calculator c = Calculator();
    result &= Test("member calls fwd func (doubleIt)", c.ComputeDouble(), 20);
    result &= Test("member calls fwd func (addThree)", c.ComputeSum(), 18);
    return result;
}

// Return block: the function body is inlined at every call site.
// 'return' inside the block returns from the caller.
inline int doubleValue(int x)
{
    return { return x * 2; };
}

inline int addValues(int a, int b)
{
    return { return a + b; };
}

// Wrappers: the return-block is inlined here; its 'return' returns from these functions.
int getDoubled(int x)
{
    doubleValue(x);
}

int getSum(int a, int b)
{
    addValues(a, b);
}

bool testReturnBlock()
{
    bool result = true;
    result &= Test("returnBlock doubleValue(5)", getDoubled(5), 10);
    result &= Test("returnBlock addValues(3,4)", getSum(3, 4), 7);
    return result;
}

// Assert uses a return block: if the assertion fails, it returns false from the caller.
inline bool Assert(const char* testName, int actual, int expected)
{
    return {
        if (actual != expected)
        {
            printf("%s negative: expected '%d' but got '%d'.\n", testName, expected, actual);
            return false;
        }
    };
}

// When the failing Assert is hit, it exits this function early with false.
// The 'return true' at the end is only reached if all asserts pass.
bool testAssertPass()
{
    Assert("assert 42==42", 42, 42);
    Assert("assert 7==7", 7, 7);
    return true;
}

bool testAssertFail()
{
    Assert("assert 10==10", 10, 10);
    Assert("assert 10==99", 10, 99);  // fails - exits testAssertFail with false
    return true;
}

bool testAssertReturnBlock()
{
    bool result = true;
    result &= Test("assert_all_pass", testAssertPass(), true);
    result &= Test("assert_early_exit", testAssertFail(), false);
    return result;
}

// =============================================================
// Explicit-width integer type tests
// C equivalents: i8=int8_t, i16=int16_t, i32=int32_t, i64=int64_t
//                u8=uint8_t, u16=uint16_t, u32=uint32_t, u64=uint64_t
// =============================================================

int sumI32(i32 a, i32 b) { return a + b; }
int sumU32(u32 a, u32 b) { return a + b; }

bool testExplicitIntTypes()
{
    bool result = true;

    // Signed types: declaration and basic value
    i8  s8  = 100;
    i16 s16 = 1000;
    i32 s32 = 100000;
    i64 s64 = 200000;

    result &= Test("i8_value",  s8,  100);
    result &= Test("i16_value", s16, 1000);
    result &= Test("i32_value", s32, 100000);
    result &= Test("i64_value", s64, 200000);

    // Unsigned types: declaration and basic value
    u8  u8v  = 200;
    u16 u16v = 2000;
    u32 u32v = 300000;
    u64 u64v = 400000;

    result &= Test("u8_value",  u8v,  200);
    result &= Test("u16_value", u16v, 2000);
    result &= Test("u32_value", u32v, 300000);
    result &= Test("u64_value", u64v, 400000);

    // Arithmetic - values chosen to stay within each type's range
    i8  s8a  = 50;   // 50+50=100, within i8  (-128..127)
    u8  u8a  = 100;  // 100+100=200, within u8 (0..255)
    result &= Test("i8_add",  s8a  + s8a,   100);  // 50+50=100
    result &= Test("i16_add", s16  + s16,   2000); // 1000+1000=2000, within i16
    result &= Test("i32_add", s32  + s32,   200000); // 100000+100000=200000
    result &= Test("u8_add",  u8a  + u8a,   200);  // 100+100=200
    result &= Test("u16_add", u16v + u16v,  4000); // 2000+2000=4000, within u16

    // C-equivalent compatibility: int <-> i32 are the same type
    int ci = s32;
    result &= Test("i32_to_int", ci, 100000);

    i32 ia = ci;
    result &= Test("int_to_i32", ia, 100000);

    // Passing i32/u32 to functions expecting i32/u32
    result &= Test("func_i32", sumI32(40, 2), 42);
    result &= Test("func_u32", sumU32(40, 2), 42);

    // Passing int to function expecting i32 (compatible types)
    int x = 10;
    result &= Test("int_to_i32_param", sumI32(x, 5), 15);

    // Hex literals with high bit set (contain hex digit 'E' - must not be parsed as float)
    // C++ rule: hex literals that exceed i32 positive range type as unsigned int (same 32-bit pattern).
    u32 magic = 0xBA63E001;             // contains 'E' - previously mistaken as float exponent
    u32 magic2 = (u32)0xBA63E001;
    result &= Test("hex_high_bit_direct", magic,  (u32)0xBA63E001);
    result &= Test("hex_high_bit_cast",   magic2, (u32)0xBA63E001);
    result &= Test("hex_with_E_digit",    (u32)0xDEADBEEF, (u32)0xDEADBEEF);
    result &= Test("hex_all_ones",        (u32)0xFFFFFFFF, (u32)0xFFFFFFFF);
    result &= Test("hex_int_min",         (u32)0x80000000, (u32)0x80000000);

    return result;
}

// =============================================================
// Null-conditional (?.) and null-coalescing (??) tests
// =============================================================

struct NullableNode
{
    int value = 99;
    int Read() { return value; }
};

// Helper: returns the node's value if non-null, -1 otherwise
int readNodeValueNC(NullableNode* node)
{
    return node?.value ?? -1;
}

// Helper: calls Read() if non-null, returns -1 otherwise
int callNodeRead(NullableNode* node)
{
    return node?.Read() ?? -1;
}

bool testNullConditional()
{
    bool result = true;

    NullableNode n = NullableNode();
    NullableNode* p = &n;
    NullableNode* np = nullptr;

    // null-conditional field access + coalescing via helper
    result &= Test("nc_coalesce_nonnull", readNodeValueNC(p),  99);
    result &= Test("nc_coalesce_null",    readNodeValueNC(np), -1);

    // null-conditional method call via helper
    result &= Test("nc_method_nonnull",   callNodeRead(p),  99);
    result &= Test("nc_method_null",      callNodeRead(np), -1);

    // null-conditional method call directly on a local pointer (no helper)
    result &= Test("nc_direct_nonnull", p?.Read()  ?? -1, 99);
    result &= Test("nc_direct_null",    np?.Read() ?? -1, -1);

    // null-conditional field access directly on a local pointer (no helper)
    result &= Test("nc_direct_field_nonnull", p?.value  ?? -1, 99);
    result &= Test("nc_direct_field_null",    np?.value ?? -1, -1);

    return result;
}

const char* tryGetName(bool found)
{
    if (found) return "Alice";
    return nullptr;
}

bool testNullCoalescing()
{
    bool result = true;

    // pointer coalescing: null -> fallback string
    const char* name1 = tryGetName(true)  ?? "Unknown";
    const char* name2 = tryGetName(false) ?? "Unknown";
    result &= Test("nullcoal_nonnull_ptr", name1, "Alice");
    result &= Test("nullcoal_null_ptr",    name2, "Unknown");

    // integer coalescing: 0 -> default, nonzero -> self
    int zero = 0;
    int five = 5;
    result &= Test("nullcoal_zero",    zero ?? 42, 42);
    result &= Test("nullcoal_nonzero", five ?? 42, 5);

    return result;
}

// =============================================================
// Null-coalescing assignment (??=) tests
// =============================================================

bool testNullCoalescingAssignment()
{
    bool result = true;

    // zero int: should be assigned the rhs value
    int x = 0;
    x ??= 42;
    result &= Test("nullcoalasgn_zero_becomes_rhs", x, 42);

    // nonzero int: should keep its original value
    int y = 7;
    y ??= 99;
    result &= Test("nullcoalasgn_nonzero_unchanged", y, 7);

    // repeated application: once set, a second ??= should not overwrite
    int z = 0;
    z ??= 10;
    z ??= 20;
    result &= Test("nullcoalasgn_already_set", z, 10);

    // null pointer: should be assigned the rhs
    const char* p = nullptr;
    p ??= "hello";
    result &= Test("nullcoalasgn_null_ptr", p, "hello");

    // non-null pointer: should keep its original value
    const char* q = "world";
    q ??= "other";
    result &= Test("nullcoalasgn_nonnull_ptr", q, "world");

    // null struct pointer: should be assigned the rhs
    NullableNode* node = nullptr;
    node ??= new NullableNode();
    result &= Test("nullcoalasgn_null_struct_ptr", node?.Read() ?? -1, 99);
    delete node;

    // non-null struct pointer: should keep its original value and not be replaced
    NullableNode* nonNullNode = new NullableNode();
    NullableNode* replacementNode = new NullableNode();
    NullableNode* before = nonNullNode;
    nonNullNode ??= replacementNode;
    result &= Test("nullcoalasgn_nonnull_struct_ptr", nonNullNode == before, true);
    delete nonNullNode;
    delete replacementNode;

    return result;
}

// =============================================================
// Default keyword tests
// =============================================================

bool testDefault()
{
    bool result = true;

    // Primitive types: default -> zero value
    int  di = default;
    bool db = default;
    i32  di32 = default;
    i64  di64 = default;

    result &= Test("default_int",  di,   0);
    result &= Test("default_bool", db,   0);
    result &= Test("default_i32",  di32, 0);
    result &= Test("default_i64",  di64, 0);

    // Struct type: default -> calls default constructor, fields get their declared defaults
    MyStruct ds = default;
    result &= Test("default_struct_num1", ds.num1, 1);
    result &= Test("default_struct_num2", ds.num2, 2);
    result &= Test("default_struct_num3", ds.num3, 3);

    return result;
}

// =============================================================
// return default; tests
// =============================================================

struct RdPoint
{
    int x = 10;
    int y = 20;
};

class RdNode
{
    int val = 99;
};

int rdInt()       { return default; }
float rdFloat()   { return default; }
bool rdBool()     { return default; }
i64 rdI64()       { return default; }
int* rdIntPtr()   { return default; }
RdNode* rdClassPtr() { return default; }
RdPoint rdStruct() { return default; }
string rdString() { return default; }

int rdCondInt(bool flag)
{
    if (flag)
        return 99;
    return default;
}

RdPoint rdCondStruct(bool flag)
{
    if (flag)
    {
        RdPoint p;
        p.x = 7;
        p.y = 8;
        return p;
    }
    return default;
}

bool testReturnDefaultPrimitives()
{
    bool result = true;
    result &= Test("rd_int",   rdInt(),   0);
    result &= Test("rd_float", rdFloat(), 0.0f);
    result &= Test("rd_bool",  rdBool(),  false);
    result &= Test("rd_i64",   rdI64(),   0);
    return result;
}

bool testReturnDefaultPointers()
{
    bool result = true;
    result &= Test("rd_int_ptr",   rdIntPtr()   == nullptr ? 1 : 0, 1);
    result &= Test("rd_class_ptr", rdClassPtr() == nullptr ? 1 : 0, 1);
    return result;
}

bool testReturnDefaultStruct()
{
    bool result = true;
    RdPoint pt = rdStruct();
    // return default; zero-initializes - fields are 0, not declared defaults (10, 20)
    result &= Test("rd_struct_x", pt.x, 0);
    result &= Test("rd_struct_y", pt.y, 0);
    return result;
}

bool testReturnDefaultString()
{
    bool result = true;
    string s = rdString();
    result &= Test("rd_string_len", s.length(), 0);
    return result;
}

bool testReturnDefaultConditional()
{
    bool result = true;
    result &= Test("rd_cond_taken",   rdCondInt(true),  99);
    result &= Test("rd_cond_default", rdCondInt(false), 0);

    RdPoint p1 = rdCondStruct(true);
    result &= Test("rd_cond_struct_x", p1.x, 7);
    result &= Test("rd_cond_struct_y", p1.y, 8);

    RdPoint p2 = rdCondStruct(false);
    result &= Test("rd_cond_struct_zero_x", p2.x, 0);
    result &= Test("rd_cond_struct_zero_y", p2.y, 0);
    return result;
}

// =============================================================
// string type tests
// string is a built-in value type: { i8* _ptr, i32 _len }
// with data() -> i8* and length() -> i32 member functions.
// =============================================================

// operator string(char*) and operator string(i32) are now provided by core/string.cb.

bool testStringType()
{
    bool result = true;

    string s = "hello";

    result &= Test("string_length", s.length(), 5);
    result &= Test("string_data", s.data(), "hello");

    string s2 = "world!!";
    result &= Test("string2_length", s2.length(), 7);
    result &= Test("string2_data", s2.data(), "world!!");

    return result;
}

// Regression: a chained access `structValue.field.method()` where `field` is a primitive
// must bind the FIELD VALUE as the method receiver, not the parent struct. Covers a struct
// local base and a `this` base inside a member method.
struct ChainPoint
{
    int x = 0;
    int y = 0;
    string xStr() { return this.x.toString(); }
};

bool testChainedFieldUFCS()
{
    bool result = true;

    ChainPoint p = default;
    p.x = 5;
    p.y = 42;

    // Local struct base: p.x.toString() must operate on x (int), not p (ChainPoint).
    string sx = p.x.toString();
    result &= Test("chain_field_local_x", sx.data(), "5");
    string sy = p.y.toString();
    result &= Test("chain_field_local_y", sy.data(), "42");

    // `this` base inside a method: this.x.toString().
    string sthis = p.xStr();
    result &= Test("chain_field_this", sthis.data(), "5");

    return result;
}

// Tests the built-in string literal syntax: string s = "...";
// A string literal is automatically wrapped in a string struct { _ptr, _len }.
bool testStringLiteral()
{
    bool result = true;

    // Basic assignment from a string literal
    string s = "hello";
    result &= Test("str_lit_length",      s.length(), 5);
    result &= Test("str_lit_data",     s.data(),  "hello");

    // Longer literal - the canonical use case: string s = "My test string";
    string s2 = "My test string";
    result &= Test("str_lit_long_length", s2.length(), 14);
    result &= Test("str_lit_long_data", s2.data(), "My test string");

    // Empty string literal
    string s3 = "";
    result &= Test("str_lit_empty_length", s3.length(), 0);
    result &= Test("str_lit_empty_data", s3.data(), "");

    // String with escape sequences - \n counts as one character
    string s4 = "line1\nline2";
    result &= Test("str_lit_escape_length", s4.length(), 11);

    // Multiple string variables can coexist with independent values
    string sa = "alpha";
    string sb = "beta!";
    result &= Test("str_lit_multi_a_length",  sa.length(), 5);
    result &= Test("str_lit_multi_b_length",  sb.length(), 5);
    result &= Test("str_lit_multi_a_data", sa.data(), "alpha");
    result &= Test("str_lit_multi_b_data", sb.data(), "beta!");

    // X6: a ternary whose branches are a `string` value and a char* literal must
    // coerce the literal to `string` (instead of asserting in LLVM's select on
    // mismatched operands). Verify both branch orders and the selected value.
    string base = "abc";
    string t1 = base.length() == 0 ? "lit" : base;       // selects the string branch
    result &= Test("ternary_str_pick_value",   t1.data(), "abc");
    string t2 = base.length() == 3 ? "lit" : base;       // selects the char* literal
    result &= Test("ternary_str_pick_literal", t2.data(), "lit");
    string t3 = base.length() == 0 ? base : "fallback";  // reversed: string then char*
    result &= Test("ternary_str_reversed",     t3.data(), "fallback");

    return result;
}

class Node
{
    int value = 0;
};

int testNewDelete()
{
    Node* n = new Node();
    delete n;
    return 42;
}

int testNewArray()
{
    int* arr = new int[5];
    for (int i = 0; i < 5; i++)
    {
        arr[i] = i;
	}

    for (int i = 0; i < 5; i++)
    {
        if (arr[i] != i)
        {
            printf("testNewArray failed: arr[%d] expected %d but got %d.\n", i, i, arr[i]);
            delete[] arr;
            return 1;
        }
	}

    delete[] arr;
    return 99;
}

class Counter
{
    int count = 0;
};

int testNewWithConstructor()
{
    Counter* c = new Counter();
    delete c;
    return 123;
}

bool testNewArrayConstructor()
{
    bool result = true;

    // new T[n] must call the default constructor for each element
    MyStruct* arr = new MyStruct[3];
    result &= Test("new_arr_ctor_0_num1", arr[0].num1, 1);
    result &= Test("new_arr_ctor_0_num2", arr[0].num2, 2);
    result &= Test("new_arr_ctor_1_num1", arr[1].num1, 1);
    result &= Test("new_arr_ctor_2_num3", arr[2].num3, 3);
    delete[3] arr;

    return result;
}

// Regression: when 'p = new T' is an assignment statement (not a declaration),
// lastOwningResult must not leak into the next declaration in scope.
// Previously the next declared pointer variable was incorrectly marked owning
// and freed at scope exit, causing a double-free with the allocator.
bool testNewAssignNoOwnershipLeak()
{
    bool result = true;

    // p declared before loop (assignment, not declaration, inside loop)
    int* p = nullptr;
    int sum = 0;
    int i = 0;
    while (i < 3)
    {
        p = new int;   // assignment - must NOT set lastOwningResult for next decl
        *p = i + 1;
        sum += *p;
        delete p;
        p = nullptr;
        i++;
    }
    result &= Test("new_assign_sum", sum, 6);

    // q declared AFTER the loop that used 'p = new int'.
    // If lastOwningResult leaked, q would be marked owning and freed at scope
    // exit even though it holds a stack address - causing heap corruption.
    int local = 99;
    int* q = &local;   // NOT a heap allocation; must not be freed at scope exit
    result &= Test("new_assign_no_leak", *q, 99);

    return result;
}

class Point : IString
{
    i32 x = 0;
    i32 y = 0;

    string ToString()
    {
        return "{x}, {y}";
    }
};

bool testFormatString()
{
    bool result = true;

    string name = "World";
    string greeting = "Hello {name}!";
    result &= Test("fmt_simple", greeting.data(), "Hello World!");

    string a = "foo";
    string b = "bar";
    string combined = "{a} and {b}";
    result &= Test("fmt_two", combined.data(), "foo and bar");

    string prefix = "pre";
    string suffix = "suf";
    string three = "{prefix}-mid-{suffix}";
    result &= Test("fmt_three", three.data(), "pre-mid-suf");

    Point p = Point();
	p.x = 10;
	p.y = 20;
	string pointStr = "Point is {p}.";
	result &= Test("fmt_object", pointStr.data(), "Point is 10, 20.");

    // Numeric interpolation: int goes through operator string(i32); float must
    // promote to operator string(double) (regression for float -> double overload
    // resolution). The owned conversion temp is freed at end of statement (no leak).
    int n = 7;
    string intStr = "n={n}";
    result &= Test("fmt_int", intStr.data(), "n=7");

    float f = 1.5;
    string floatStr = "f={f}";
    result &= Test("fmt_float", floatStr.data(), "f=1.5");

    return result;
}

// =============================================================
// if const compile-time conditional tests
// =============================================================

bool testIfConst()
{
    bool result = true;

    // Test 1: if const with true literal - should enter true branch
    if const (true)
    {
        result &= Test("if_const_true", 1, 1);
    }
    else
    {
        result &= Test("if_const_true", 0, 1);  // should not execute
    }

    // Test 2: if const with false literal - should skip body entirely
    if const (false)
    {
        result &= Test("if_const_false", 0, 1);  // should not execute
    }

    // Test 3: if const with comparison (1 == 1) - should enter true branch
    if const (1 == 1)
    {
        result &= Test("if_const_eq_true", 1, 1);
    }
    else
    {
        result &= Test("if_const_eq_true", 0, 1);  // should not execute
    }

    // Test 4: if const with false comparison (1 == 2) - should enter else branch
    if const (1 == 2)
    {
        result &= Test("if_const_eq_false", 0, 1);  // should not execute
    }
    else
    {
        result &= Test("if_const_eq_false", 1, 1);
    }

    // Test 5: if const with inequality (5 != 3) - should enter true branch
    if const (5 != 3)
    {
        result &= Test("if_const_neq_true", 1, 1);
    }
    else
    {
        result &= Test("if_const_neq_true", 0, 1);  // should not execute
    }

    return result;
}

// =============================================================
// Platform constant tests (__PLATFORM__)
// =============================================================

bool testPlatformConstant()
{
    bool result = true;

    // The __PLATFORM__ constant is set at compile-time based on -p flag:
    // 64 for win64 (default), 32 for win32
    // This test verifies that if const works with __PLATFORM__

    if const (__PLATFORM__ == 64)
    {
        result &= Test("__PLATFORM__==64", 1, 1);
    }
    else if const (__PLATFORM__ == 32)
    {
        result &= Test("__PLATFORM__==32", 1, 1);
    }

    // Verify that exactly one of the above branches executed
    // (the other branch should be completely eliminated from IR)
    return result;
}

// =============================================================
// Global-scope if const tests (compile-time conditional declarations)
// =============================================================

// Test 1: Simple true/false branches at global scope
if const (true)
{
    class GlobalTrueClass
    {
        int value = 42;
    };
}
else
{
    class GlobalFalseClass
    {
        int value = 0;
    };
}

// Test 2: Platform-specific declarations
if const (__PLATFORM__ >= 32)
{
    class PlatformSpecificClass
    {
        int platformValue = 64;
    };

    void platformSpecificFunc()
    {
        printf("Compiled for win64\n");
    }
}
else
{
    class PlatformSpecificClass
    {
        int platformValue = 32;
    };

    void platformSpecificFunc()
    {
        printf("Compiled for other platform\n");
    }
}

// Test 3: Nested if const at global scope
if const (false)
{
    class NeverDeclared
    {
        int x = 99;
    };
}

if const (true)
{
    class AlwaysDeclared
    {
        int y = 123;
    };
}

bool testGlobalIfConst()
{
    bool result = true;

    // Test that GlobalTrueClass from true branch is available
    GlobalTrueClass gtc = GlobalTrueClass();
    result &= Test("global_if_const_true_branch", gtc.value, 42);

    // Test that PlatformSpecificClass is declared correctly
    PlatformSpecificClass psc = PlatformSpecificClass();
    if const (__PLATFORM__ >= 32)
    {
        result &= Test("global_if_const_platform_win64", psc.platformValue, 64);
    }
    else
    {
        result &= Test("global_if_const_platform_other", psc.platformValue, 32);
    }

    // Test that AlwaysDeclared from always-true branch is available
    AlwaysDeclared ad = AlwaysDeclared();
    result &= Test("global_if_const_always_declared", ad.y, 123);

    // Call platform-specific function
    platformSpecificFunc();

    return result;
}

// =============================================================
// Struct with string field
// =============================================================

struct Employee
{
    string name = default;
    int id = 0;
};

bool testStructWithString()
{
    bool result = true;
    Employee e;
    e.name = "Alice";
    e.id = 42;
    result &= Test("employee_name", e.name.data(), "Alice");
    result &= Test("employee_id",   e.id, 42);
    return result;
}

// =============================================================
// Brace escape sequences in string literals
// \{ \} produce literal braces; {{ }} fold to single braces
// =============================================================

bool testBraceEscapes()
{
    bool result = true;

    // Both \{ and {{ should produce a literal '{' - compare the two forms against each other
    const char* slash = "\{hello\}";
    const char* dbl   = "{{hello}}";
    result &= Test("brace_forms_equal", strcmp(slash, dbl), 0);

    // In a format string, {{ folds to literal '{' and {x} interpolates - check resulting length
    // "value is {x} = 42" => 18 chars
    int x = 42;
    string s = "value is {{x}} = {x}";
    result &= Test("mixed_brace_length", s.length(), 17);

    return result;
}

// =============================================================
// Global struct pointer method dispatch
// Verifies that TypeAndValue is preserved for global variables so
// direct method calls on globals resolve correctly.
// =============================================================

struct GlobalCounter
{
    int count = 0;
    int increment() { count = count + 1; return count; }
    int get() { return count; }
};

GlobalCounter* g_counter = nullptr;

bool testGlobalStructPtrMethod()
{
    bool result = true;

    GlobalCounter c = GlobalCounter();
    g_counter = &c;

    result &= Test("global_ptr_method_get",      g_counter.get(),       0);
    result &= Test("global_ptr_method_increment", g_counter.increment(), 1);
    result &= Test("global_ptr_method_after_inc", g_counter.get(),       1);

    g_counter = nullptr;
    return result;
}

// =============================================================
// Overload resolution tests (float, string types)
// =============================================================

// Regression: a struct method must not win overload resolution for a free call
// whose argument is a primitive pointer. With opaque pointers, readBack(&boolVar)
// once resolved to ReadBackBox.readBack() with the bool* bound as 'this' (the
// fsh shell's readLine(&eof) silently called File.readLine on a stack bool).
struct ReadBackBox
{
    void* _handle = nullptr;
    int readBack() { return -1; }
};

int readBack(bool* flag)
{
    *flag = true;
    return 7;
}

bool testOverloadResolution()
{
    bool result = true;

    bool flag = false;
    result &= Test("free fn beats method this", readBack(&flag), 7);
    result &= Test("free fn wrote through ptr", flag, true);
    result &= Test("int overload",        42,    42);
    result &= Test("bool overload",       true,  true);
    result &= Test("char* overload",      "hello", "hello");

    float f = 1.5f;
    result &= Test("float overload exact",   f,      1.5f);
    result &= Test("float overload literal", 3.14f,  3.14f);
    // Verify a known mismatch is caught (Test returns 0 on mismatch)
    result &= Test("float mismatch detected",   Test("_float_mm",  1.0f,   2.0f)  == 0, true);

    string s1 = "hello";
    string s2 = "hello";
    string s3 = "world";
    result &= Test("string overload equal",      s1, s2);
    result &= Test("string mismatch detected",   Test("_str_mm",   s1, s3)        == 0, true);
    result &= Test("string vs literal",          s1, "hello");
    result &= Test("str/literal mismatch detect",Test("_str_lit_mm", s1, "world") == 0, true);

    return result;
}

// =============================================================
// Static method tests
// =============================================================

struct StaticMathUtils
{
    static int add(int a, int b) { return a + b; }
    static int mul(int a, int b) { return a * b; }
    static int square(int x)     { return x * x; }
};

class StaticCounter
{
    int _count = 0;
    static int zero()       { return 0; }
    static int maxValue()   { return 2147483647; }
    void increment()        { _count = _count + 1; }
    int  value()            { return _count; }
};

struct StaticPoint
{
    int x = 0;
    int y = 0;
    static int origin_x() { return 0; }
    static int origin_y() { return 0; }
};

bool testStatic()
{
    bool result = true;
    result &= Test("StaticMath.add",    StaticMathUtils.add(3, 4),    7);
    result &= Test("StaticMath.mul",    StaticMathUtils.mul(3, 4),    12);
    result &= Test("StaticMath.square", StaticMathUtils.square(5),    25);
    result &= Test("Counter.zero",      StaticCounter.zero(),         0);
    result &= Test("Counter.maxValue",  StaticCounter.maxValue(),     2147483647);
    StaticCounter sc = StaticCounter();
    sc.increment();
    sc.increment();
    result &= Test("Counter.value",     sc.value(),                   2);
    result &= Test("Point.origin_x",    StaticPoint.origin_x(),       0);
    result &= Test("Point.origin_y",    StaticPoint.origin_y(),       0);
    return result;
}

// =============================================================
// Cast tests (C-style casts, float UFCS, integer conversions)
// =============================================================

bool testCast()
{
    bool result = true;

    i32 five = 5;
    i32 neg3 = -3;
    float fpos = 3.9f;
    float fneg = -3.9f;

    result &= Test("(float)5",    (float)five,   5.0f);
    result &= Test("(float)-3",   (float)neg3,  -3.0f);
    result &= Test("(int)3.9f",   (int)fpos,     3);
    result &= Test("(int)-3.9f",  (int)fneg,    -3);
    result &= Test("(int)3.0f",   (int)3.0f,     3);

    i64 big64 = 0x200000000;
    big64 = big64 + 5;
    i32 neg32 = -1;
    result &= Test("(i32)(i64) truncate", (i32)big64,   5);
    result &= Test("(i64)(i32) sign-ext", (i64)neg32,   -1);

    result &= Test("(0.5f).round()",    (0.5f).round(),    1.0f);
    result &= Test("(-0.5f).round()",   (-0.5f).round(),  -1.0f);
    result &= Test("(0.4f).round()",    (0.4f).round(),    0.0f);
    result &= Test("(-0.4f).round()",   (-0.4f).round(),   0.0f);
    result &= Test("(-3.7f).floor()",   (-3.7f).floor(),  -4.0f);
    result &= Test("(-3.7f).ceil()",    (-3.7f).ceil(),   -3.0f);
    result &= Test("(-3.0f).floor()",   (-3.0f).floor(),  -3.0f);
    result &= Test("(-3.0f).ceil()",    (-3.0f).ceil(),   -3.0f);
    result &= Test("(0.0f).abs()",      (0.0f).abs(),      0.0f);
    result &= Test("(3.5f).abs()",      (3.5f).abs(),      3.5f);
    result &= Test("(9.0f).sqrt()",     (9.0f).sqrt(),     3.0f);
    result &= Test("(1.0f).sqrt()",     (1.0f).sqrt(),     1.0f);
    result &= Test("(0.0f).sqrt()",     (0.0f).sqrt(),     0.0f);

    float v = -5.5f;
    result &= Test("var(-5.5f).floor()", v.floor(), -6.0f);
    result &= Test("var(-5.5f).ceil()",  v.ceil(),  -5.0f);
    result &= Test("var(-5.5f).round()", v.round(), -6.0f);
    result &= Test("var(-5.5f).abs()",   v.abs(),    5.5f);

    i32 v127   = 127;
    i32 v128   = 128;
    i32 v32767 = 32767;
    i32 v32768 = 32768;
    result &= Test("127.to_i8()",          v127.to_i8(),    127);
    result &= Test("128.to_i8() wrap",     v128.to_i8(),   -128);
    result &= Test("32767.to_i16()",       v32767.to_i16(), 32767);
    result &= Test("32768.to_i16() wrap",  v32768.to_i16(),-32768);

    i32 neg_src  = -100;
    i8  byte_neg = neg_src.to_i8();
    result &= Test("i8(-100).to_i16()", byte_neg.to_i16(), -100);
    result &= Test("i8(-100).to_i32()", byte_neg.to_i32(), -100);
    result &= Test("i8(-100).to_i64()",  byte_neg.to_i64(),      -100);

    i16 short_neg = neg_src.to_i16();
    result &= Test("i16(-100).to_i32()", short_neg.to_i32(), -100);
    result &= Test("i16(-100).to_i64()",  short_neg.to_i64(),     -100);

    i32 xi = 42;
    result &= Test("i32(42).to_i32()",  xi.to_i32(),  42);
    i64 yi = 999;
    result &= Test("i64(999).to_i64()", yi.to_i64(),  999);

    return result;
}

// =============================================================
// Nullable pointer (?.) tests
// =============================================================

struct NullablePoint
{
    int x = 0;
    int y = 0;
};

struct NullableContainer
{
    NullablePoint* inner = nullptr;
};

bool testNullableTypes()
{
    bool result = true;

    NullablePoint? p;
    result &= Test("nullable default is nullptr", (int)(p == nullptr), 1);

    NullablePoint pt = NullablePoint();
    pt.x = 10;
    pt.y = 20;
    p = &pt;
    result &= Test("nullable after assign not nullptr", (int)(p != nullptr), 1);
    result &= Test("nullable ?.x access",               p?.x, 10);
    p = nullptr;
    result &= Test("nullable reset to nullptr", (int)(p == nullptr), 1);

    NullablePoint pt2;
    pt2.x = 42;
    NullablePoint* rp = &pt2;
    result &= Test("?. on local ptr",           rp?.x,  42);
    NullablePoint* np = nullptr;
    result &= Test("?. on null local ptr",       np?.x,  0);

    NullablePoint pt3;
    pt3.x = 99;
    NullableContainer nc;
    nc.inner = &pt3;
    result &= Test("?. on member ptr",           nc.inner?.x, 99);
    NullableContainer nc2;
    result &= Test("?. on null member ptr",      nc2.inner?.x, 0);

    return result;
}

// =============================================================
// Nested struct / class tests
// =============================================================

struct OuterStruct {
    struct InnerStruct {
        int x = 0;
        int y = 0;
    };
    InnerStruct inner;
    int value = 0;

    int sum()
    {
        return inner.x + inner.y + value;
    }
};

class OuterClass {
    class InnerClass {
        int a = 0;
        int b = 0;

        int product()
        {
            return a * b;
        }
    };
    InnerClass data;
};

class ClassWithInnerStruct {
    struct Point {
        int x = 0;
        int y = 0;
    };
    Point origin;
    Point corner;
};

struct StructWithInnerClass {
    class Color {
        int r = 0;
        int g = 0;
        int b = 0;

        int brightness()
        {
            return r + g + b;
        }
    };
    Color tint;
};

bool testNestedStructClass()
{
    bool result = true;

    OuterStruct o;
    o.inner.x = 3;
    o.inner.y = 7;
    o.value = 10;
    result &= Test("nested struct field access", o.inner.x, 3);
    result &= Test("nested struct method", o.sum(), 20);

    OuterStruct.InnerStruct standalone;
    standalone.x = 100;
    standalone.y = 200;
    result &= Test("nested type qualified x", standalone.x, 100);
    result &= Test("nested type qualified y", standalone.y, 200);

    OuterClass oc;
    oc.data.a = 4;
    oc.data.b = 5;
    result &= Test("nested class field a", oc.data.a, 4);
    result &= Test("nested class method product", oc.data.product(), 20);

    ClassWithInnerStruct cws;
    cws.origin.x = 0;
    cws.origin.y = 0;
    cws.corner.x = 10;
    cws.corner.y = 20;
    result &= Test("class with inner struct origin x", cws.origin.x, 0);
    result &= Test("class with inner struct corner x", cws.corner.x, 10);
    result &= Test("class with inner struct corner y", cws.corner.y, 20);

    StructWithInnerClass swc;
    swc.tint.r = 100;
    swc.tint.g = 150;
    swc.tint.b = 200;
    result &= Test("struct with inner class field r", swc.tint.r, 100);
    result &= Test("struct with inner class brightness", swc.tint.brightness(), 450);

    return result;
}

// =============================================================
// Variadic function tests
// =============================================================

bool testVariadic()
{
    bool result = true;
    char* buf = (char*)malloc(64);

    // Positional: all args by position - regression for the original call path.
    snprintf(buf, 64, "%d + %d = %d", 3, 4, 7);
    result &= Test("variadic_positional", (const char*)buf, "3 + 4 = 7");

    // Named fixed parameter with variadic tail: fmt: names the third param of snprintf
    // while buf and 64 remain positional and 6, 7, 42 are variadic.
    snprintf(buf, 64, fmt: "%d * %d = %d", 6, 7, 42);
    result &= Test("variadic_named_fmt", (const char*)buf, "6 * 7 = 42");

    free(buf);
    return result;
}

// =============================================================
// Primitive type alias tests (using Alias = primitiveType)
// =============================================================

using MyInt  = int;
using MyU32  = u32;
using MyI64  = i64;
using MyBool = bool;
using MyF32  = float;

MyInt  primitiveAliasAdd(MyInt a, MyInt b) { return a + b; }
MyU32  primitiveAliasU32(MyU32 a, MyU32 b) { return a + b; }
MyI64  primitiveAliasI64(MyI64 a, MyI64 b) { return a + b; }

bool testPrimitiveTypeAlias()
{
    bool result = true;

    MyInt  i = 10;
    result &= Test("alias_int_decl",      i,                      10);
    result &= Test("alias_int_func",      primitiveAliasAdd(3, 4), 7);

    MyU32  u = 300000;
    result &= Test("alias_u32_decl",      u,                       300000);
    result &= Test("alias_u32_func",      primitiveAliasU32(10, 5), 15);

    MyI64  l = 1000000000;
    result &= Test("alias_i64_decl",      l,                       1000000000);
    result &= Test("alias_i64_func",      primitiveAliasI64(100, 200), 300);

    MyBool b = true;
    result &= Test("alias_bool_decl",     b,                       true);

    MyF32  f = 1.5f;
    result &= Test("alias_float_decl",    f,                       1.5f);

    // Local alias inside a function
    using LocalU8 = u8;
    LocalU8 byte = 255;
    result &= Test("local_alias_u8",      byte,                    255);

    return result;
}

// =============================================================
// Pointer type alias tests (using Handle = void*) - Tier 2
// The trailing '*' is stored in the alias string and peeled back onto the
// Pointer / ElemPointer flags at the resolution site.
// =============================================================

struct AliasNode { int v = 0; };

using IntPtrAlias = int*;
using VoidPtrAlias = void*;
using NodePtrAlias = AliasNode*;

int derefIntPtrAlias(IntPtrAlias p) { return *p; }   // alias used in a parameter

bool testPointerTypeAlias()
{
    bool result = true;

    int x = 7;
    IntPtrAlias p = &x;
    result &= Test("ptr_alias_deref",  *p,                   7);
    result &= Test("ptr_alias_in_fn",  derefIntPtrAlias(p),  7);

    // void* alias holds any pointer and round-trips through a cast
    VoidPtrAlias h = (void*)p;
    result &= Test("ptr_alias_void_nonnull", h != nullptr,   true);
    IntPtrAlias back = (int*)h;
    result &= Test("ptr_alias_void_roundtrip", *back,        7);

    // alias star + use-site star => int**
    IntPtrAlias* pp = &p;
    result &= Test("ptr_alias_double", **pp,                 7);

    // struct pointer alias
    AliasNode n = default;
    n.v = 99;
    NodePtrAlias np = &n;
    result &= Test("ptr_alias_struct", np->v,                99);

    return result;
}

// =============================================================
// Array type alias tests (using Vec3 = float[3]) - Tier 3
// The folded sizes are baked into the alias string ("float[3]") and re-parsed
// onto ConstArraySize / ConstInnerDimensions at the resolution site.
// =============================================================

using Vec3Alias = i32[3];
using Mat2Alias = i32[2][3];

bool testArrayTypeAlias()
{
    bool result = true;

    // Single-dimension array alias, zero-initialized then written
    Vec3Alias v = default;
    v[0] = 10; v[1] = 20; v[2] = 12;
    result &= Test("arr_alias_elem0",  v[0],            10);
    result &= Test("arr_alias_elem2",  v[2],            12);
    result &= Test("arr_alias_sum",    v[0] + v[1] + v[2], 42);
    result &= Test("arr_alias_sizeof", sizeof(Vec3Alias), 12);  // 3 * 4 bytes

    // Two declarators share the aliased size (the size lives on the type)
    Vec3Alias a = default;
    Vec3Alias b = default;
    a[2] = 7;
    b[2] = 9;
    result &= Test("arr_alias_two_decls", a[2] + b[2], 16);

    // Multi-dimensional array alias
    Mat2Alias m = default;
    m[0][0] = 5; m[1][2] = 8;
    result &= Test("arr_alias_md_00",    m[0][0],          5);
    result &= Test("arr_alias_md_12",    m[1][2],          8);
    result &= Test("arr_alias_md_sizeof", sizeof(Mat2Alias), 24);  // 2 * 3 * 4 bytes

    return result;
}

// =============================================================
// Fixed-size inline array tests (local variables and struct fields)
// =============================================================

struct ArrayHolder
{
    i8 label[8] = default;
    i32 count = 0;
    i8 data[16] = default;
};

int sumFixedBuf(i8* buf, int len)
{
    int sum = 0;
    int i = 0;
    while (i < len) { sum = sum + buf[i]; i++; }
    return sum;
}

// Global (file-scope) fixed-size arrays. Regression: indexing a global array
// folded the all-zero element GEP (e.g. gFixedArr[0]) back onto the GlobalVariable
// symbol, so the read loaded the whole [N x T] aggregate and module verification
// failed ("return type does not match operand type" / "Invalid bitcast"). Globals
// must index to the element exactly like locals do.
int[81] gFixedArr = default;
int*[3] gPtrArr = default;
// Global brace/positional initializer: lowered to an LLVM constant array.
int[4] gInitArr = {10, 20, 30, 40};
// Partial positional init: trailing slots zero-fill (matches local semantics).
int[4] gPartialArr = {7, 8};
// Empty brace on a primitive element: zero-init, equivalent to = default.
int[3] gEmptyArr = {};
// Global array sized by a named const / const-expr: the size must be folded at
// compile time (a non-literal size used to leave the global malformed and crash).
const int kGRows = 9;
const int kGCols = 9;
int[kGRows * kGCols] gConstExprArr = default;
int[kGRows] gConstNameArr = default;

bool testFixedArrays()
{
    bool result = true;

    // Local fixed-size array: write, read back
    i8[8] buf = default;
    buf[0] = (i8)10; buf[1] = (i8)20; buf[2] = (i8)30;
    result &= Test("fixed_local_elem0", buf[0], 10);
    result &= Test("fixed_local_elem1", buf[1], 20);
    result &= Test("fixed_local_elem2", buf[2], 30);

    // Array decays to pointer when passed to a function
    result &= Test("fixed_local_decay", sumFixedBuf(buf, 3), 60);

    // No ConstArraySize carryover to the next declarator
    int plain = 42;
    result &= Test("fixed_no_carryover", plain, 42);

    // Struct with multiple inline array fields
    ArrayHolder h = default;
    h.label[0] = (i8)'O'; h.label[1] = (i8)'K'; h.label[2] = (i8)0;
    h.count = 7;
    h.data[0] = (i8)1; h.data[1] = (i8)2; h.data[2] = (i8)3;
    result &= Test("fixed_struct_label0", h.label[0], 'O');
    result &= Test("fixed_struct_label1", h.label[1], 'K');
    result &= Test("fixed_struct_count",  h.count, 7);
    result &= Test("fixed_struct_data_sum", sumFixedBuf(h.data, 3), 6);

    // Struct pointer access
    ArrayHolder* ph = &h;
    result &= Test("fixed_struct_ptr_label0", ph->label[0], 'O');
    result &= Test("fixed_struct_ptr_count",  ph->count, 7);

    // Explicit cast of a fixed array decays to a pointer to its first element
    // (regression: the cast path loaded the whole [N x T] aggregate and emitted
    // an aggregate-to-pointer bitcast that failed module verification).
    u8* up = (u8*)buf;
    result &= Test("fixed_cast_decay_elem0", (int)up[0], 10);
    result &= Test("fixed_cast_decay_elem2", (int)up[2], 30);

    // Same decay from a struct's inline array field.
    u8* dp = (u8*)h.data;
    result &= Test("fixed_cast_decay_field", (int)dp[1], 2);

    // Decay also feeds non-pointer casts: the array's address as an integer.
    i64 addr = (i64)buf;
    result &= Test("fixed_cast_decay_to_int", addr != (i64)0, true);

    // sizeof(variable): a fixed array measures its full byte capacity, a scalar
    // measures its declared type (regression: any variable operand used to fail
    // with "unknown type").
    result &= Test("sizeof_fixed_array", (int)sizeof(buf), 8);
    result &= Test("sizeof_scalar_var", (int)sizeof(plain), 4);
    result &= Test("sizeof_struct_var", (int)sizeof(h), (int)sizeof(ArrayHolder));

    // Global (file-scope) fixed array: write then read back a constant index
    // (the all-zero GEP that used to fold onto the GlobalVariable symbol).
    gFixedArr[0] = 11;
    gFixedArr[80] = 22;
    result &= Test("fixed_global_elem0", gFixedArr[0], 11);
    result &= Test("fixed_global_elemN", gFixedArr[80], 22);

    // Global brace/positional initializer: read back the constant elements.
    result &= Test("fixed_global_init0", gInitArr[0], 10);
    result &= Test("fixed_global_init3", gInitArr[3], 40);
    result &= Test("fixed_global_partial_set", gPartialArr[1], 8);
    result &= Test("fixed_global_partial_zerofill", gPartialArr[3], 0);
    result &= Test("fixed_global_empty_zero", gEmptyArr[0], 0);

    // Global array sized by a named const / const-expr: full extent is usable.
    gConstExprArr[80] = 5;   // index 80 only valid if size folded to 9*9 = 81
    gConstNameArr[8]  = 6;   // index 8 only valid if size folded to 9
    result &= Test("fixed_global_constexpr_size", gConstExprArr[80], 5);
    result &= Test("fixed_global_constname_size", gConstNameArr[8], 6);

    // Global fixed array: variable-index write and a loop sum.
    int gi = 0;
    while (gi < 81) { gFixedArr[gi] = gi; gi++; }
    int gsum = 0;
    gi = 0;
    while (gi < 81) { gsum += gFixedArr[gi]; gi++; }
    result &= Test("fixed_global_loop_sum", gsum, 3240);  // 0+1+...+80

    // Global fixed array decays to a pointer (its first element's address).
    // After the loop above, gFixedArr[i] == i.
    int* gp = (int*)gFixedArr;
    result &= Test("fixed_global_decay_elem0", gp[0], 0);
    result &= Test("fixed_global_decay_elem5", gp[5], 5);

    // Global array of pointers (int*[3]): store an address, read through it.
    int gpval = 99;
    gPtrArr[0] = &gpval;
    result &= Test("fixed_global_ptrarr", *gPtrArr[0], 99);

    return result;
}

// =============================================================
// Multi-dimensional arrays: T[N][M] - covers char, int, float, struct
// =============================================================

struct Cell { int x = 0; int y = 0; };

bool testMultiDimArrays()
{
    bool result = true;

    // --- char[3][5]: 3 rows x 5 cols ---
    char[3][5] cg = default;
    int r = 0;
    while (r < 3)
    {
        int c = 0;
        while (c < 5)
        {
            cg[r][c] = (char)(r * 5 + c);
            c++;
        }
        r++;
    }
    result &= Test("char2d[0][0]", cg[0][0], 0);
    result &= Test("char2d[1][2]", cg[1][2], 7);
    result &= Test("char2d[2][4]", cg[2][4], 14);

    // --- int[4][3]: 4 rows x 3 cols ---
    int[4][3] ig = default;
    r = 0;
    while (r < 4)
    {
        int c = 0;
        while (c < 3)
        {
            ig[r][c] = r * 10 + c;
            c++;
        }
        r++;
    }
    result &= Test("int2d[0][0]",  ig[0][0], 0);
    result &= Test("int2d[3][2]",  ig[3][2], 32);
    // Sum all elements: sum = 0+1+2 + 10+11+12 + 20+21+22 + 30+31+32 = 192
    int sum = 0;
    r = 0;
    while (r < 4)
    {
        int c = 0;
        while (c < 3) { sum += ig[r][c]; c++; }
        r++;
    }
    result &= Test("int2d_sum", sum, 192);

    // --- float[2][2] ---
    float[2][2] fg = default;
    r = 0;
    while (r < 2)
    {
        int c = 0;
        while (c < 2)
        {
            fg[r][c] = (float)(r * 2 + c) + 0.5f;
            c++;
        }
        r++;
    }
    // fg[0][0]=0.5  fg[0][1]=1.5  fg[1][0]=2.5  fg[1][1]=3.5
    result &= Test("float2d[1][1]", (int)(fg[1][1] * 2.0f), 7);  // 3.5 * 2 = 7

    // --- Cell[2][3]: struct element type ---
    Cell[2][3] sg = default;
    r = 0;
    while (r < 2)
    {
        int c = 0;
        while (c < 3)
        {
            sg[r][c].x = r * 3 + c;
            sg[r][c].y = (r * 3 + c) * 2;
            c++;
        }
        r++;
    }
    result &= Test("struct2d[0][0].x", sg[0][0].x, 0);
    result &= Test("struct2d[1][2].x", sg[1][2].x, 5);
    result &= Test("struct2d[1][2].y", sg[1][2].y, 10);

    return result;
}

// =============================================================
// Regression: Bug 1 - cast result chained with -> member access
// CFlat previously required a named variable to hold the cast
// result before accessing a field (e.g. ((Struct*)ptr)->field).
// =============================================================

struct CastMemberPoint { int x = 0; int y = 0; };

bool testCastMemberAccess()
{
    bool result = true;

    CastMemberPoint pt = CastMemberPoint();
    pt.x = 7;
    pt.y = 13;

    void* vp = (void*)&pt;

    // Direct cast-then-arrow without a named intermediate
    int x = ((CastMemberPoint*)vp)->x;
    result &= Test("cast->field x", x, 7);

    // Outer cast applied to a cast->arrow expression
    int y = (int)((CastMemberPoint*)vp)->y;
    result &= Test("(int)(cast->field y)", y, 13);

    return result;
}

// =============================================================
// Regression: Bug 2 - returning int from a bool function
// The compiler previously emitted ret i32 inside an i1 function,
// which fails LLVM module verification. The fix emits ICmpNE to
// convert any nonzero int to true (matching bool assignment semantics).
// =============================================================

int intTwo() { return 2; }

bool boolFromIntReturn()
{
    return intTwo() != 0;
}

bool testReturnBoolFromInt()
{
    bool result = true;

    // intTwo() returns 2; value 2 truncated to i1 is 0 (wrong), ICmpNE gives 1 (right).
    result &= Test("bool from int=2", (int)boolFromIntReturn(), 1);

    return result;
}

// bool is i1 and converts to an integer as exactly 0/1 (zext i1), both
// implicitly in arithmetic and via an explicit cast - and the comparison
// operators yield a normalized 0/1. Branchless code (e.g. counting how many
// sorted keys are <= a probe) relies on this, so lock it down. See the
// "bool in arithmetic" section of doc/LANGUAGE.md.
bool testBoolArithmetic()
{
    bool result = true;

    int a = 5;
    int b = 3;

    // Comparison result used directly in arithmetic - no cast.
    int j = 0;
    j = j + (a >= b);          // true  -> +1
    j = j + (a <  b);          // false -> +0
    result &= Test("bool implicit add 0/1", j, 1);

    // Explicit (int) cast must produce the same 0/1.
    result &= Test("bool cast true ==1",  (int)(a >= b), 1);
    result &= Test("bool cast false==0",  (int)(a <  b), 0);

    // Assigning a bool to an int widens to 0/1.
    bool flag = (a >= b);
    int x = flag;
    result &= Test("int = bool true",  x, 1);
    flag = (a < b);
    x = flag;
    result &= Test("int = bool false", x, 0);

    // Logical operators also yield a normalized 0/1.
    result &= Test("logical && ->1", (int)(true && true),   1);
    result &= Test("logical || ->0", (int)(false || false), 0);
    result &= Test("logical !  ->1", (int)(!false),         1);

    // The branchless-rank idiom: count keys <= probe over a sorted run.
    i64[5] keys = default;
    keys[0] = 10; keys[1] = 20; keys[2] = 30; keys[3] = 40; keys[4] = 50;
    i64 probe = 35;
    int rank = 0;
    int k = 0;
    while (k < 5)
    {
        rank = rank + (probe >= keys[k]);   // +1 for 10,20,30; +0 for 40,50
        k = k + 1;
    }
    result &= Test("branchless rank of 35", rank, 3);

    return result;
}

// `= default`, `= {}`, a bare declaration, and the `new` (heap) forms must all run the default
// constructor, which zero-fills any field that has no declared initializer (no stack/heap garbage)
// while preserving fields that do. Regression for the default-ctor undef-seed bug.
struct DefInitMixed  { int a = 7; int b; int c = 9; int d; };
struct DefInitAllBare { int x; int y; i64 z; void* p; };

bool testStructDefaultZeroFill()
{
    bool result = true;

    DefInitMixed m = default;
    result &= Test("default mixed a", m.a, 7);
    result &= Test("default mixed b", m.b, 0);   // bare field zeroed
    result &= Test("default mixed c", m.c, 9);
    result &= Test("default mixed d", m.d, 0);   // bare field zeroed

    DefInitMixed m2 = {};                         // empty-brace value-init
    result &= Test("brace mixed a", m2.a, 7);
    result &= Test("brace mixed b", m2.b, 0);
    result &= Test("brace mixed c", m2.c, 9);
    result &= Test("brace mixed d", m2.d, 0);

    DefInitAllBare z = default;                   // all fields bare -> fully zeroed
    result &= Test("default allbare x", z.x, 0);
    result &= Test("default allbare y", z.y, 0);
    result &= Test("default allbare z", z.z, (i64)0);
    result &= Test("default allbare p null", z.p == nullptr, true);

    DefInitAllBare bare;                          // bare declaration runs the same ctor
    result &= Test("bare-decl allbare x", bare.x, 0);
    result &= Test("bare-decl allbare p null", bare.p == nullptr, true);

    // `new` (heap): malloc does not zero, so this proves the constructor initializes the fields.
    DefInitAllBare* hz = new DefInitAllBare;
    result &= Test("new allbare x", hz.x, 0);
    result &= Test("new allbare z", hz.z, (i64)0);
    result &= Test("new allbare p null", hz.p == nullptr, true);
    delete hz;

    DefInitMixed* hm = new DefInitMixed();
    result &= Test("new mixed a", hm.a, 7);
    result &= Test("new mixed b", hm.b, 0);
    delete hm;

    DefInitMixed* ha = new DefInitMixed[3];
    bool arrOk = true;
    int i = 0;
    while (i < 3)
    {
        if (ha[i].a != 7 || ha[i].b != 0 || ha[i].c != 9 || ha[i].d != 0) arrOk = false;
        i = i + 1;
    }
    result &= Test("new mixed[3] value-init", arrOk, true);
    delete ha;

    return result;
}

extern int main()
{
    MyStruct my = MyStruct();
    MyStruct1 struct1 = MyStruct1();
    MyStruct2 struct2 = MyStruct2();

    int passed = 0;
    int total  = 0;
    total++; passed += Test("testArray", testArray(), 435);
    total++; passed += testNamedParameters()             ? 1 : 0;
    total++; passed += Test("testTotalByValue", my.TotalByValue(), 5);
    total++; passed += Test("testTotalByPointer", my.TotalByPointer(), 5);
    total++; passed += Test("struct1.Read", struct1.Read(), 1);
    total++; passed += Test("struct2.Read", struct2.Read(), 2);
    total++; passed += Test("struct1.ReadExt", struct1.ReadExt(), 1);
    total++; passed += Test("struct2.ReadExt", struct2.ReadExt(), 2);
    total++; passed += testDefaultSingleParam()          ? 1 : 0;
    total++; passed += testDefaultMultipleParams()       ? 1 : 0;
    total++; passed += testDefaultExpression()           ? 1 : 0;
    total++; passed += testDefaultParamNameCollision()   ? 1 : 0;
    total++; passed += testDestructor()                  ? 1 : 0;
    total++; passed += testBuiltinIdentifiers()          ? 1 : 0;
    total++; passed += testTypeof()                      ? 1 : 0;
    total++; passed += testNameof()                      ? 1 : 0;
    total++; passed += testNamespace()                   ? 1 : 0;
    total++; passed += testNestedNamespace()             ? 1 : 0;
    total++; passed += testNestedUsing()                 ? 1 : 0;
    total++; passed += testLocalUsing()                  ? 1 : 0;
    total++; passed += testLocalUsingScoped()            ? 1 : 0;
    total++; passed += testForwardFunction()             ? 1 : 0;
    total++; passed += testMutualRecursion()             ? 1 : 0;
    total++; passed += testForwardFunctionWithStruct()   ? 1 : 0;
    total++; passed += testForwardInStruct()             ? 1 : 0;
    total++; passed += testReturnBlock()                 ? 1 : 0;
    total++; passed += testAssertReturnBlock()           ? 1 : 0;
    total++; passed += testExplicitIntTypes()            ? 1 : 0;
    total++; passed += testNullConditional()             ? 1 : 0;
    total++; passed += testNullCoalescing()              ? 1 : 0;
    total++; passed += testNullCoalescingAssignment()    ? 1 : 0;
    total++; passed += testDefault()                     ? 1 : 0;
    total++; passed += testReturnDefaultPrimitives()     ? 1 : 0;
    total++; passed += testReturnDefaultPointers()       ? 1 : 0;
    total++; passed += testReturnDefaultStruct()         ? 1 : 0;
    total++; passed += testStructDefaultZeroFill()       ? 1 : 0;
    total++; passed += testReturnDefaultString()         ? 1 : 0;
    total++; passed += testReturnDefaultConditional()    ? 1 : 0;
    total++; passed += Test("testNewDelete", testNewDelete(), 42);
    total++; passed += Test("testNewArray", testNewArray(), 99);
    total++; passed += Test("testNewWithConstructor", testNewWithConstructor(), 123);
    total++; passed += testNewArrayConstructor()            ? 1 : 0;
    total++; passed += testNewAssignNoOwnershipLeak()       ? 1 : 0;
    total++; passed += testStringType()                  ? 1 : 0;
    total++; passed += testChainedFieldUFCS()            ? 1 : 0;
    total++; passed += testStringLiteral()               ? 1 : 0;
    total++; passed += testFormatString()                ? 1 : 0;
    total++; passed += testIfConst()                     ? 1 : 0;
    total++; passed += testPlatformConstant()            ? 1 : 0;
    total++; passed += testGlobalIfConst()               ? 1 : 0;
    total++; passed += testGlobalStructPtrMethod()       ? 1 : 0;
    total++; passed += testStructWithString()            ? 1 : 0;
    total++; passed += testBraceEscapes()                ? 1 : 0;
    total++; passed += testOverloadResolution()          ? 1 : 0;
    total++; passed += testStatic()                      ? 1 : 0;
    total++; passed += testCast()                        ? 1 : 0;
    total++; passed += testNullableTypes()               ? 1 : 0;
    total++; passed += testPointerArithmetic()           ? 1 : 0;
    total++; passed += testPrimitiveTypeAlias()          ? 1 : 0;
    total++; passed += testPointerTypeAlias()            ? 1 : 0;
    total++; passed += testArrayTypeAlias()              ? 1 : 0;
    total++; passed += testNestedStructClass()           ? 1 : 0;
    total++; passed += testInPlaceDtor()                 ? 1 : 0;
    total++; passed += testVariadic()                    ? 1 : 0;
    total++; passed += testFixedArrays()                 ? 1 : 0;
    total++; passed += testMultiDimArrays()              ? 1 : 0;
    total++; passed += testCastMemberAccess()            ? 1 : 0;
    total++; passed += testReturnBoolFromInt()           ? 1 : 0;
    total++; passed += testBoolArithmetic()              ? 1 : 0;
    total++; passed += testUnion()                       ? 1 : 0;
    total++; passed += testBreakContinue()               ? 1 : 0;
    total++; passed += testDoWhile()                     ? 1 : 0;
    total++; passed += testWhileTrueReturn()             ? 1 : 0;
    total++; passed += testAndShortCircuit()             ? 1 : 0;
    total++; passed += testInterfaceNullCheck()          ? 1 : 0;
    total++; passed += testSizeof()                      ? 1 : 0;
    total++; passed += testFieldInit()                   ? 1 : 0;
    total++; passed += testStructInlineArrays()          ? 1 : 0;
    total++; passed += testPointerArrays()               ? 1 : 0;
    total++; passed += testArrayDefaultInit()            ? 1 : 0;
    total++; passed += testArrayFieldInit()              ? 1 : 0;
    total++; passed += testAlignas()                     ? 1 : 0;
    total++; passed += testConstFold()                   ? 1 : 0;
    total++; passed += testFloatLiteralWidth()            ? 1 : 0;
    total++; passed += testFloatDoubleWiden()             ? 1 : 0;
    printf("%d/%d tests passed.\n", passed, total);
    return passed == total ? 0 : 1;
}

// =============================================================
// Pointer arithmetic tests
// =============================================================

void incThroughPtr(int* p) { (*p)++; }

bool testPointerArithmetic()
{
    bool result = true;

    // Basic ptr + int
    int* arr = new int[4];
    arr[0] = 10; arr[1] = 20; arr[2] = 30; arr[3] = 40;

    int* p1 = arr + 1;
    result &= Test("ptr+1 elem", p1[0], 20);

    int* p2 = arr + 2;
    result &= Test("ptr+2 elem", p2[0], 30);

    // ptr - int
    int* p3 = p2 - 1;
    result &= Test("ptr-1 elem", p3[0], 20);

    // Chained arithmetic
    int* p4 = arr + 1 + 1;
    result &= Test("ptr+1+1 elem", p4[0], 30);

    // p++ increments by sizeof(int)
    int* p = arr;
    p++;
    result &= Test("int* p++ elem", *p, 20);
    p++;
    result &= Test("int* p++ again", *p, 30);

    // p-- decrements by sizeof(int)
    p--;
    result &= Test("int* p-- elem", *p, 20);

    // (*p)++ / (*p)-- increment the POINTEE, not the pointer. Regression: the
    // parenthesized deref lost its storage, so the increment silently no-op'd
    // (fsh's edInsert (*len)++ never advanced and the line editor dropped keys).
    (*p)++;
    result &= Test("(*p)++ pointee", arr[1], 21);
    result &= Test("(*p)++ ptr unmoved", *p, 21);
    (*p)--;
    result &= Test("(*p)-- pointee", arr[1], 20);
    incThroughPtr(&arr[2]);
    result &= Test("(*param)++ writes back", arr[2], 31);

    // p += n
    int* q = arr;
    q += 3;
    result &= Test("int* p+=3 elem", *q, 40);

    // p -= n
    q -= 2;
    result &= Test("int* p-=2 elem", *q, 20);

    // ptr - ptr -> element count
    int* start = arr;
    int* end = arr + 4;
    int diff = (int)(end - start);
    result &= Test("ptr-ptr elem count", diff, 4);

    // i8* arithmetic (byte-sized: p++ still correct)
    i8* buf = (i8*)new i8[4];
    buf[0] = 65; buf[1] = 66; buf[2] = 67; buf[3] = 0;

    i8* b1 = buf + 1;
    result &= Test("i8*+1", b1[0], 66);

    i8* b2 = b1 + 1;
    result &= Test("i8*+1+1", b2[0], 67);

    i8* b3 = b2 - 2;
    result &= Test("i8*-2", b3[0], 65);

    // i8* cursor walk with ++
    i8* cursor = buf;
    cursor++;
    result &= Test("i8* cursor++", *cursor, 66);
    cursor++;
    result &= Test("i8* cursor++ again", *cursor, 67);

    // i8* ptr - ptr -> byte count
    i8* bstart = buf;
    i8* bend = buf + 4;
    int bdiff = (int)(bend - bstart);
    result &= Test("i8* ptr-ptr byte count", bdiff, 4);

    delete[] arr;
    delete[] buf;
    return result;
}

// =============================================================
// In-place destructor (.~()) tests
// =============================================================

int g_inplace_dtor_count = 0;

struct Destructible
{
    int value = 0;

    ~Destructible()
    {
        g_inplace_dtor_count++;
    }
};

bool testInPlaceDtor()
{
    bool result = true;

    // Allocate a raw buffer large enough for 3 Destructible elements.
    // Use .~() to destroy individual elements without freeing the buffer.
    Destructible* buf = new Destructible[3];
    buf[0].value = 10;
    buf[1].value = 20;
    buf[2].value = 30;

    g_inplace_dtor_count = 0;

    // Destroy element 1 in place - buffer must remain usable.
    buf[1].~();
    result &= Test(".~() dtor called once",  g_inplace_dtor_count, 1);
    result &= Test(".~() buf[0] intact",     buf[0].value, 10);
    result &= Test(".~() buf[2] intact",     buf[2].value, 30);

    // Destroy the remaining two elements in place before freeing.
    buf[0].~();
    buf[2].~();
    result &= Test(".~() all three called", g_inplace_dtor_count, 3);

    // Free only the backing buffer - destructors already ran.
    delete[_] buf;

    return result;
}

// =============================================================
// Union tests
// =============================================================

bool testUnion()
{
    bool result = true;

    UnionIntFloat u;
    u.i = 42;
    result &= Test("union write/read int", u.i, 42);

    u.i = 0;
    result &= Test("union zero int", u.i, 0);

    u.f = 1.5f;
    result &= Test("union write/read float", u.f, 1.5f);

    result &= Test("sizeof union == sizeof largest", (int)sizeof(UnionIntFloat), 4);

    ContainerWithUnion c;
    c.data.i = 99;
    c.tag = 1;
    result &= Test("union as struct field", c.data.i, 99);
    result &= Test("struct field tag intact", c.tag, 1);

    UnionByteView bv;
    bv.value = 0x000000FF;
    result &= Test("union aliasing low byte", bv.byte0, -1);

    // Union with struct members: write and read sub-fields
    UnionWithStructs s;
    s.pt.x = 10;
    s.pt.y = 20;
    result &= Test("union struct member write/read x", s.pt.x, 10);
    result &= Test("union struct member write/read y", s.pt.y, 20);

    s.col.r = 255;
    s.col.g = 128;
    result &= Test("union struct member aliasing", s.col.r, 255);

    // Write via pointer
    UnionWithStructs s2;
    writeUnionStructViaPtr(&s2, 42, 99);
    result &= Test("union struct member write via ptr x", s2.pt.x, 42);
    result &= Test("union struct member write via ptr y", s2.pt.y, 99);

    return result;
}

// =============================================================
// break / continue tests
// =============================================================

bool testBreakContinue()
{
    bool result = true;

    // --- while: break exits on sentinel ---
    int i = 0;
    while (i < 100)
    {
        if (i == 5) break;
        i++;
    }
    result &= Test("while break at 5", i, 5);

    // --- while: continue skips iterations ---
    int sum = 0;
    int k = 0;
    while (k < 6)
    {
        k++;
        if (k % 2 == 0) continue;
        sum += k;   // sum odd numbers 1+3+5 = 9
    }
    result &= Test("while continue odd sum", sum, 9);

    // --- for: break exits early ---
    int found = -1;
    for (int j = 0; j < 10; j++)
    {
        if (j == 7) { found = j; break; }
    }
    result &= Test("for break at 7", found, 7);

    // --- for: continue skips body ---
    int evenSum = 0;
    for (int n = 0; n < 10; n++)
    {
        if (n % 2 != 0) continue;
        evenSum += n;   // 0+2+4+6+8 = 20
    }
    result &= Test("for continue even sum", evenSum, 20);

    // --- for-in (range-based): break and continue ---
    // IntRange is a minimal collection supporting for (int v in r) syntax.
    IntRange r;
    r.lo = 0; r.hi = 10;   // values 0..9

    int firstOver5 = -1;
    for (int v in r)
    {
        if (v > 5) { firstOver5 = v; break; }
    }
    result &= Test("for-in break first>5", firstOver5, 6);

    int oddSum = 0;
    for (int v in r)
    {
        if (v % 2 == 0) continue;
        oddSum += v;    // 1+3+5+7+9 = 25
    }
    result &= Test("for-in continue odd sum", oddSum, 25);

    return result;
}

// =============================================================
// do-while loop tests
// Regression: do-while was compiled as while (condition first),
// so the body never executed when the condition was initially false.
// =============================================================

bool testDoWhile()
{
    bool result = true;

    // Body must execute once even when condition is false from the start.
    int counter = 0;
    do {
        counter++;
    } while (false);
    result &= Test("dowhile_runs_once_cond_false", counter, 1);

    // Body must execute once when condition is true, then exit.
    int count2 = 0;
    do {
        count2++;
    } while (count2 < 1);
    result &= Test("dowhile_exits_after_first_true", count2, 1);

    // Standard multi-iteration pattern: count to 5.
    int n = 0;
    do {
        n++;
    } while (n < 5);
    result &= Test("dowhile_multi_iter", n, 5);

    // Body executes at least once even when counter starts at limit.
    int m = 10;
    do {
        m++;
    } while (m < 10);
    result &= Test("dowhile_body_before_cond", m, 11);

    // Accumulate inside the body; condition references accumulated value.
    int sum = 0;
    int idx = 1;
    do {
        sum += idx;
        idx++;
    } while (idx <= 5);
    result &= Test("dowhile_sum_1_to_5", sum, 15);

    return result;
}

// =============================================================
// while(true) fall-through tests
// Regression: a `while (true)` loop with no `break` can only be left
// via a `return` inside the body, so the function never falls through.
// Control-flow analysis used to only check whether the final insert
// block was terminated; the loop's (dead) resume block was the insert
// point with no terminator, so the compiler wrongly reported a missing
// return and the code only compiled with a dead trailing `return`.
// These functions intentionally have NO return after the loop - if they
// compile and run, the fix holds.
// =============================================================

// No trailing return - the body always returns once i reaches n.
int wtrPick(int n)
{
    int i = 0;
    while (true)
    {
        if (i >= n)
            return i;
        i = i + 1;
    }
}

// while(1) (constant non-zero, not just the literal `true`) behaves the same.
int wtrFirstHit(int start)
{
    int x = start;
    while (1)
    {
        if (x % 7 == 0)
            return x;
        x = x + 1;
    }
}

// A `break` keeps the exit reachable, so a real return after the loop is
// still required (and used) - this must compile and run normally.
int wtrCountUpTo(int n)
{
    int i = 0;
    while (true)
    {
        if (i >= n)
            break;
        i = i + 1;
    }
    return i;
}

bool testWhileTrueReturn()
{
    bool result = true;
    result &= Test("wtr_pick_returns_from_body", wtrPick(3), 3);
    result &= Test("wtr_while1_first_multiple_of_7", wtrFirstHit(10), 14);  // 10..14 -> 14
    result &= Test("wtr_break_then_return", wtrCountUpTo(5), 5);
    return result;
}

// =============================================================
// && short-circuit in loop body tests
// Regression: when the left operand of && was false inside a while
// loop body, the IR branched to the loop-exit block instead of
// continuing the current iteration.
// =============================================================

bool testAndShortCircuit()
{
    bool result = true;

    // Loop must run all 5 iterations; match_count accumulates only when
    // both operands of && are true (n == 2 and n == 4).
    int n = 0;
    int iters = 0;
    int matches = 0;
    while (n < 5)
    {
        bool a = (n == 2 || n == 4);
        bool match = a && true;
        if (match) matches++;
        iters++;
        n++;
    }
    result &= Test("and_loop_all_iters",    iters,   5);
    result &= Test("and_loop_match_count",  matches, 2);

    // && with a false constant: short-circuit must not exit the loop.
    int count = 0;
    int i = 0;
    while (i < 4)
    {
        bool always_false = false && true;
        if (always_false) count = -1;  // must never execute
        i++;
    }
    result &= Test("and_false_const_iters",    i,     4);
    result &= Test("and_false_const_no_match", count, 0);

    // && result used in an if: false branch continues normally.
    int trueBranches = 0;
    int totalIters = 0;
    int j = 0;
    while (j < 6)
    {
        bool flag = (j % 2 == 0) && (j > 0);  // true only for 2, 4
        if (flag) trueBranches++;
        totalIters++;
        j++;
    }
    result &= Test("and_if_result_total_iters", totalIters,   6);
    result &= Test("and_if_result_true_count",  trueBranches, 2);

    // Chained &&: a && b && c - false on first two operands must not exit loop.
    int hits = 0;
    int k = 0;
    while (k < 5)
    {
        bool val = (k == 3) && true && true;
        if (val) hits++;
        k++;
    }
    result &= Test("and_chain_iters",  k,    5);
    result &= Test("and_chain_hits",   hits, 1);

    return result;
}

// =============================================================
// sizeof / alignof intrinsics
// =============================================================

struct SizeofPoint      { int x = default; int y = default; };
struct SizeofComplex    { char a = default; int b = default; double c = default; SizeofPoint p = default; };
struct SizeofEmpty      { };
struct SizeofSingle     { i64 value = default; };
struct SizeofPtrFields  { int* ptr = nullptr; char* str_ptr = nullptr; };
struct SizeofNested     { SizeofPoint outer = default; SizeofComplex inner = default; };
struct SizeofUnder      { int x = default; int y = default; };
struct SizeofDunder     { void* a = nullptr; void* b = nullptr; };
struct SizeofFuncField  { function<int(void*)> fn = nullptr; void* ctx = nullptr; };

bool testSizeof()
{
    bool r = true;

    // Primitive sizes
    if (sizeof(int)    != 4) r = false;
    if (sizeof(char)   != 1) r = false;
    if (sizeof(double) != 8) r = false;
    if (sizeof(bool)   != 1) r = false;
    if (sizeof(i8)     != 1) r = false;
    if (sizeof(i16)    != 2) r = false;
    if (sizeof(i32)    != 4) r = false;
    if (sizeof(i64)    != 8) r = false;
    if (sizeof(u8)     != 1) r = false;
    if (sizeof(u16)    != 2) r = false;
    if (sizeof(u32)    != 4) r = false;
    if (sizeof(u64)    != 8) r = false;
    if (sizeof(float)  != 4) r = false;

    // Pointer sizes
    if const (__PLATFORM__ == 64) {
        if (sizeof(int*)    != 8) r = false;
        if (sizeof(char*)   != 8) r = false;
        if (sizeof(double*) != 8) r = false;
    } else {
        if (sizeof(int*)    != 4) r = false;
        if (sizeof(char*)   != 4) r = false;
        if (sizeof(double*) != 4) r = false;
    }

    // Struct sizes
    if (sizeof(SizeofPoint)  != 8) r = false;
    if (sizeof(SizeofSingle) != 8) r = false;
    if const (__PLATFORM__ == 64) {
        if (sizeof(SizeofPtrFields) != 16) r = false;
    } else {
        if (sizeof(SizeofPtrFields) != 8)  r = false;
    }

    // alignof must return positive
    if (alignof(int)    <= 0) r = false;
    if (alignof(char)   <= 0) r = false;
    if (alignof(double) <= 0) r = false;
    if (alignof(i64)    <= 0) r = false;
    if (alignof(SizeofPoint) <= 0) r = false;

    // Pointer type sizeof/alignof
    if const (__PLATFORM__ == 64) {
        if (sizeof(SizeofPoint*)  != 8) r = false;
        if (alignof(SizeofPoint*) != 8) r = false;
    } else {
        if (sizeof(SizeofPoint*)  != 4) r = false;
        if (alignof(SizeofPoint*) != 4) r = false;
    }

    // Arithmetic on results
    i64 total3 = sizeof(int) + sizeof(char) + sizeof(double);
    if (total3 != (4 + 1 + 8)) r = false;
    if (sizeof(i64) < sizeof(int)) r = false;

    // Underscore struct names
    if (sizeof(SizeofUnder) != 8) r = false;
    if const (__PLATFORM__ == 64) {
        if (sizeof(SizeofDunder) != 16) r = false;
    } else {
        if (sizeof(SizeofDunder) != 8)  r = false;
    }

    // Struct with thin function<T> field: bare C fn ptr + void* = 16 on x64, 8 on x86
    if const (__PLATFORM__ == 64) {
        if (sizeof(SizeofFuncField) != 16) r = false;
    } else {
        if (sizeof(SizeofFuncField) != 8) r = false;
    }

    return r;
}

// =============================================================
// Field initializer syntax and struct-inline fixed arrays
// =============================================================

struct FieldInitPoint  { int x = 0; int y = 0; };
struct FieldInitPerson { int age = 0; int score = 0; };

int sumFieldInitPoint(FieldInitPoint p = { x=1, y=2 }) { return p.x + p.y; }

bool testFieldInit()
{
    bool result = true;

    FieldInitPoint p = { x=10, y=20 };
    result &= Test("field_init_xy",   p.x + p.y, 30);

    FieldInitPoint q = { x=5 };
    result &= Test("field_init_partial", q.x, 5);
    result &= Test("field_init_default", q.y, 0);

    FieldInitPerson person = { age=30, score=100, };
    result &= Test("field_init_person_age",   person.age,   30);
    result &= Test("field_init_person_score", person.score, 100);

    FieldInitPoint* hp = new FieldInitPoint { x=7, y=8 };
    result &= Test("field_init_heap_x", hp->x, 7);
    result &= Test("field_init_heap_y", hp->y, 8);
    delete hp;

    result &= Test("field_init_default_param",  sumFieldInitPoint(), 3);
    result &= Test("field_init_positional_arg",  sumFieldInitPoint({ x=3, y=4 }), 7);
    result &= Test("field_init_named_arg",       sumFieldInitPoint(p: { x=5, y=6 }), 11);

    return result;
}

struct FieldInitPacket { char data[64]; int length = 0; };

// Type-first inline array field (u8[8]) - distinct from the C-style suffix form
// above. The size lives on the declaration specifier, not the declarator; the
// field-decl path used to drop it, collapsing the array and undersizing the
// struct (sizeof was 8 instead of 16, element writes past [0] hit garbage).
struct InlineArrField { u32 a = 0; u8[8] b = default; };
struct InlineArr2D     { int[2][3] grid = default; };

bool testStructInlineArrays()
{
    bool result = true;

    char[8] buf;
    buf[0] = (char)10; buf[1] = (char)20; buf[2] = (char)30;
    result &= Test("inline_arr_sum", buf[0] + buf[1] + buf[2], 60);

    FieldInitPacket pkt;
    pkt.data[0] = (char)'H';
    pkt.data[1] = (char)'i';
    pkt.data[2] = (char)0;
    pkt.length = 2;
    result &= Test("struct_arr_elem0", pkt.data[0], 'H');
    result &= Test("struct_arr_elem1", pkt.data[1], 'i');

    FieldInitPoint[3] pts;
    pts[0].x = 1; pts[1].x = 2; pts[2].x = 3;
    result &= Test("struct_arr_sum", pts[0].x + pts[1].x + pts[2].x, 6);

    // Type-first array field: full 8 bytes inline (u32 + 8*u8 = 12, align 4).
    result &= Test("typefirst_arr_sizeof", (int)sizeof(InlineArrField), 12);
    InlineArrField iaf = default;
    iaf.b[0] = (u8)11; iaf.b[7] = (u8)77;
    result &= Test("typefirst_arr_elem0", (int)iaf.b[0], 11);
    result &= Test("typefirst_arr_elem7", (int)iaf.b[7], 77);
    result &= Test("typefirst_arr_default_mid", (int)iaf.b[3], 0);

    // Multi-dimensional type-first array field.
    result &= Test("typefirst_2d_sizeof", (int)sizeof(InlineArr2D), 24);
    InlineArr2D g2 = default;
    g2.grid[0][0] = 5; g2.grid[1][2] = 9;
    result &= Test("typefirst_2d_elem00", g2.grid[0][0], 5);
    result &= Test("typefirst_2d_elem12", g2.grid[1][2], 9);

    return result;
}

bool testPointerArrays()
{
    bool result = true;

    char*[3] words;
    words[0] = "alpha";
    words[1] = "beta";
    words[2] = "gamma";

    result &= Test("ptr_arr_strlen0", strlen(words[0]), 5);
    result &= Test("ptr_arr_strlen1", strlen(words[1]), 4);
    result &= Test("ptr_arr_strlen2", strlen(words[2]), 5);

    int i = 0;
    int total_len = 0;
    while (i < 3) { total_len = total_len + strlen(words[i]); i++; }
    result &= Test("ptr_arr_total", total_len, 14);

    return result;
}

// =============================================================
// Array value-init: T[N] name {} and T[N] name {field=v,...}
// =============================================================

struct ArrayInitCounter {
    int count = 0;
    int step  = 1;

    ArrayInitCounter() {
        count = 100;
        step  = 5;
    }
};

bool testArrayDefaultInit()
{
    bool result = true;

    ArrayInitCounter[3] ctrs {};
    result &= Test("arr_init_0_count", ctrs[0].count, 100);
    result &= Test("arr_init_0_step",  ctrs[0].step,  5);
    result &= Test("arr_init_1_count", ctrs[1].count, 100);
    result &= Test("arr_init_2_count", ctrs[2].count, 100);

    return result;
}

bool testArrayFieldInit()
{
    bool result = true;

    ArrayInitCounter[2] seeded {count=42, step=7};
    result &= Test("arr_seed_0_count", seeded[0].count, 42);
    result &= Test("arr_seed_0_step",  seeded[0].step,  7);
    result &= Test("arr_seed_1_count", seeded[1].count, 42);
    result &= Test("arr_seed_1_step",  seeded[1].step,  7);

    return result;
}

// =============================================================
// Interface nullptr comparison tests
// =============================================================

interface ICounter
{
    int count();
};

class SimpleCounter : ICounter
{
    int n = default;
    int count() { return n; }
};

bool checkIfaceNull(ICounter c)
{
    return c == nullptr;
}

bool checkIfaceNotNull(ICounter c)
{
    return c != nullptr;
}

bool testInterfaceNullCheck()
{
    bool result = true;

    // Null fat-ptr compares equal to nullptr
    ICounter empty = nullptr;
    result &= Test("iface_null_eq",    empty == nullptr, true);
    result &= Test("iface_null_ne",    empty != nullptr, false);

    // Non-null fat-ptr compares not-equal to nullptr
    SimpleCounter* sc = new SimpleCounter();
    sc.n = 5;
    ICounter live = sc;
    result &= Test("iface_nonnull_ne", live != nullptr,  true);
    result &= Test("iface_nonnull_eq", live == nullptr,  false);

    // Reassign to nullptr clears the fat-ptr. 'live' now owns the boxed object (boxing a heap
    // pointer into an interface moves ownership; interface locals are not auto-destructed), so
    // delete through 'live' before clearing it - 'delete sc' after the move is a no-op and leaks.
    delete live;
    live = nullptr;
    result &= Test("iface_reassign_null", live == nullptr, true);

    // Pass interface variable as interface parameter
    ICounter nullIface = nullptr;
    result &= Test("iface_param_null",    checkIfaceNull(nullIface),    true);
    result &= Test("iface_param_nonnull", checkIfaceNotNull(nullIface), false);

    return result;
}

// =============================================================
// alignas tests
// =============================================================

struct alignas(64) AlignCL { int x = 0; };
class alignas(32) AlignPaddedPair { int a = 0; int b = 0; };
struct AlignPlain { int v = 0; };

alignas(64) i64 g_align_counter = 0;
alignas(64) AlignCL g_align_cl = default;

bool testAlignas()
{
    bool result = true;

    result &= Test("sizeof(AlignCL)==64",         (int)sizeof(AlignCL),         64);
    result &= Test("alignof(AlignCL)==64",        (int)alignof(AlignCL),        64);
    result &= Test("sizeof(AlignPaddedPair)==32",  (int)sizeof(AlignPaddedPair), 32);
    result &= Test("alignof(AlignPaddedPair)==32", (int)alignof(AlignPaddedPair),32);
    result &= Test("sizeof(AlignPlain)==4",        (int)sizeof(AlignPlain),      4);
    result &= Test("alignof(AlignPlain)==4",       (int)alignof(AlignPlain),     4);

    AlignCL local_cl;
    AlignPaddedPair local_pp;
    alignas(32) int local_int = 0;
    result &= Test("local AlignCL addr%64",    (int)(((i64)&local_cl)  & 63), 0);
    result &= Test("local AlignPaddedPair%32", (int)(((i64)&local_pp)  & 31), 0);
    result &= Test("local alignas(32) int%32", (int)(((i64)&local_int) & 31), 0);

    result &= Test("global alignas(64) i64%64", (int)(((i64)&g_align_counter) & 63), 0);
    result &= Test("global AlignCL%64",         (int)(((i64)&g_align_cl)      & 63), 0);

    AlignCL[4] arr;
    result &= Test("AlignCL[4] stride==64",   (int)(((i64)&arr[1]) - ((i64)&arr[0])), 64);
    result &= Test("AlignCL[4] base%64",      (int)(((i64)&arr[0]) & 63), 0);
    result &= Test("AlignCL[4] arr[2]%64",    (int)(((i64)&arr[2]) & 63), 0);

    AlignCL* p = new AlignCL;
    result &= Test("new AlignCL%64", (int)(((i64)p) & 63), 0);
    delete p;

    return result;
}

// =============================================================
// Compile-time constant folding (C integer promotion)
// =============================================================
// Regression: small integer literals are stored at their minimal width (1 is i8),
// so binary folding used to overflow in that width - (i8)1 << 20 folded to 0 and
// (i8)100 << 1 to -56. C integer promotion now widens sub-int operands to i32
// before the fold. Runtime forms were always correct; only compile-time literal
// folding was affected.
bool testConstFold()
{
    bool result = true;

    // Shifts that overflow the i8 source width.
    result &= Test("1 << 8",    1 << 8,    256);
    result &= Test("1 << 20",   1 << 20,   1048576);
    result &= Test("100 << 1",  100 << 1,  200);

    // Chained multiply that overflows i16 (4*1024 fits i16, *1024 overflows it).
    result &= Test("4*1024*1024", 4 * 1024 * 1024, 4194304);
    result &= Test("2*1000*1000", 2 * 1000 * 1000, 2000000);

    // Add/subtract that exceed the narrow width.
    result &= Test("100 + 100",  100 + 100,  200);
    result &= Test("200 + 100",  200 + 100,  300);

    // Folded literal must match the runtime form computed from int variables.
    int one = 1;
    int sh  = 20;
    result &= Test("fold==runtime shift", 1 << 20, one << sh);

    int a = 4;
    int k = 1024;
    result &= Test("fold==runtime mul", 4 * 1024 * 1024, a * k * k);

    return result;
}

// =============================================================
// Floating-point literal default width
// =============================================================
// Like small integer literals (1 is i8), a no-suffix decimal literal is typed as
// the smallest float type that holds it exactly: float (f32) when it round-trips
// through float without loss, otherwise double (f64). An explicit 'f' suffix always
// forces float. These overloads let the literal pick the matching parameter type.
int whichFp(float x)  { return 1; }   // float  selected
int whichFp(double x) { return 2; }   // double selected

bool testFloatLiteralWidth()
{
    bool result = true;

    // Exact in float -> f32.
    result &= Test("1.5 is float",    whichFp(1.5),   1);
    result &= Test("100.0 is float",  whichFp(100.0), 1);
    result &= Test("0.5 is float",    whichFp(0.5),   1);

    // 'f' suffix forces float.
    result &= Test("1.5f is float",   whichFp(1.5f),  1);

    // Not representable exactly in float -> f64.
    result &= Test("0.1 is double",   whichFp(0.1),                 2);
    result &= Test("pi is double",    whichFp(3.141592653589793),   2);

    return result;
}

// =============================================================
// float -> double implicit widening at the literal site
// =============================================================
// A bare literal like 1.0 is typed `float` (smallest-type rule above), but
// float -> double is an implicit widening conversion, so it must widen when the
// destination is `double`. Two sites previously emitted invalid LLVM IR:
//   1. Ternary unification: `cond ? <double> : 1.0` produced a select with one
//      double and one float operand (verifier: "Invalid operands for select").
//   2. A `double` global seeded from a bare float literal mismatched its type
//      (verifier: "Global variable initializer type does not match").

// Case 2: double global seeded from a bare float literal.
double g_widenGlobal = 1.0;

bool testFloatDoubleWiden()
{
    bool result = true;

    // Global initialized from a bare float literal widened to double.
    result &= Test("widen_global_literal", g_widenGlobal == 1.0, true);

    // `c` is a loaded local, so the ternary lowers to a real `select` whose
    // operands must unify to a common type (double).
    bool c = true;

    // Case 1: ternary mixing a double expression with a bare float literal,
    // on each branch.
    double x = c ? (g_widenGlobal * 2.0) : 1.0;   // double expr on taken branch
    double y = c ? 0.0 : (g_widenGlobal * 2.0);   // bare literal on taken branch
    result &= Test("widen_ternary_double_branch", x == 2.0, true);
    result &= Test("widen_ternary_literal_branch", y == 0.0, true);

    return result;
}
