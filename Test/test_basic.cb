import "test_helper.cb";

// =============================================================
// Union types
// =============================================================

union UnionIntFloat
{
    int i = default;
    float f = default;
};

union UnionByteView
{
    int value = default;
    i8 byte0 = default;
};

struct ContainerWithUnion
{
    UnionIntFloat data = default;
    int tag = default;
};

// Minimal integer range collection for range-based for tests.
struct IntRange
{
    int lo = default;
    int hi = default;

    int count() { return hi - lo; }
    int get(int i) { return lo + i; }
};

bool testBuiltinIdentifiers()
{
    bool result = true;
    result &= Test("__FILE__", __FILE__, "test_basic.cb");
    result &= Test("__FUNCTION__", __FUNCTION__, "testBuiltinIdentifiers");
    result &= Test("__LINE__", __LINE__, 40); // Remember to adjust if shifted.
    return result;
}

struct UnionPoint { int x = default; int y = default; };
struct UnionColor { int r = default; int g = default; int b = default; };

union UnionWithStructs
{
    UnionPoint pt = default;
    UnionColor col = default;
};

void writeUnionStructViaPtr(UnionWithStructs* s, int x, int y)
{
    s->pt.x = x;
    s->pt.y = y;
}

int testArray()
{
    int arraySize = 30;
    int[arraySize] array;

    int i = 0;
    while (i < arraySize)
    {
        array[i] = i;
        i++;
    }

    int sum = 0;
    i = 0;
    while (i < arraySize)
    {
        sum += array[i];
        i++;
    }

    return sum;
}

int myFunction(int x, int y, int z)
{
    // printf("x=%d,y=%d,z=%d: ", x, y, z);
    int pair_xy = (x + y) * (x + y + 1) / 2 + y;
    return (pair_xy + z) * (pair_xy + z + 1) / 2 + z;
}

bool testNamedParameters()
{
    bool result = true;
    int expected = myFunction(1, 2, 3);
    result &= Test("InOrder", myFunction(x:1, y : 2, z : 3), expected);
    result &= Test("OutOfOrderName", myFunction(y:2, z : 3, x : 1), expected);
    result &= Test("MixedInOrder", myFunction(x:1, y : 2, 3), expected);
    result &= Test("MixedOutOfOrder", myFunction(z:3, 1, 2), expected);

    return result;
}

