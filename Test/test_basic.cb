// Named enum — enumerators should be registered as globals.
enum MyEnum : u8 { E_ONE = 1, E_TWO, E_THREE = 5 };

bool testEnum()
{
    bool result = true;
    result &= Test("enum_E_ONE", MyEnum.E_ONE, 1);
    result &= Test("enum_E_TWO", MyEnum.E_TWO, 2);
    result &= Test("enum_E_THREE", MyEnum.E_THREE, 5);
    return result;
}

struct MyStruct
{
    int num1 = 1;
    int num2 = 2;
    int num3 = 3;
};

int TotalByValue(MyStruct mystruct)
{
    return mystruct.num1 + mystruct.num2 + mystruct.num2;
}

int TotalByPointer(MyStruct* mystruct)
{
    return mystruct->num1 + mystruct->num2 + mystruct->num2;
}

struct MyStruct1
{
    int num = 1;
    int Read() { return num; }
};

struct MyStruct2
{
    int num = 2;
    int Read() { return num; }
};

// Overloaded Extension function
int ReadExt(MyStruct1 my) { return my.num; }
int ReadExt(MyStruct2 my) { return my.num; }

// Destructor tests

int destructorCallCount = 0;

struct Tracked
{
    int id = 0;
    ~Tracked()
    {
        destructorCallCount = destructorCallCount + 1;
    }
};

bool testDestructor()
{
    bool result = true;
    destructorCallCount = 0;

    {
        Tracked t = Tracked();
    }
    result &= Test("destructor_called_once", destructorCallCount, 1);

    {
        Tracked a = Tracked();
        Tracked b = Tracked();
    }
    result &= Test("destructor_called_twice", destructorCallCount, 3);

    return result;
}


// Default parameter tests

int addWithDefault(int x, int y = 5)
{
    return x + y;
}

bool testDefaultSingleParam()
{
    bool result = true;
    result &= Test("add_both_args", addWithDefault(3, 4), 7);  // 3+4=7
    result &= Test("add_default_y", addWithDefault(3), 8);  // 3+5=8
    return result;
}

int sumWithDefaults(int x, int y = 10, int z = 20)
{
    return x + y + z;
}

bool testDefaultMultipleParams()
{
    bool result = true;
    result &= Test("sum_all_args", sumWithDefaults(1, 2, 3), 6);   // 1+2+3=6
    result &= Test("sum_default_z", sumWithDefaults(1, 2), 23);  // 1+2+20=23
    result &= Test("sum_defaults_yz", sumWithDefaults(1), 31);  // 1+10+20=31
    return result;
}

int multiplyWithDefault(int x, int factor = 2)
{
    return x * factor;
}

bool testDefaultExpression()
{
    bool result = true;
    result &= Test("multiply_explicit", multiplyWithDefault(5, 3), 15);  // 5*3=15
    result &= Test("multiply_default", multiplyWithDefault(5), 10);  // 5*2=10
    return result;
}

extern int strcmp(const char* a, const char* b);

bool Test(const char* testName, const char* actual, const char* expected)
{
    if (strcmp(actual, expected) == 0)
    {
        printf("%s passed.\n", testName);
        return true;
    }
    printf("%s failed: expected '%s' but got '%s'.\n", testName, expected, actual);
    return false;
}

struct NamedThing
{
    int value = 42;
};


struct TypedThing
{
    int count = 0;
    bool flag = false;
};

bool testTypeof()
{
    bool result = true;
    int i = 0;
    bool b = false;
    TypedThing t = TypedThing();

    result &= Test("typeof_int", typeof(i), "int");
    result &= Test("typeof_bool", typeof(b), "bool");
    result &= Test("typeof_struct", typeof(t), "TypedThing");
    result &= Test("typeof_field_int", typeof(t.count), "int");
    result &= Test("typeof_field_bool", typeof(t.flag), "bool");
    result &= Test("typeof_type_int", typeof(int), "int");
    result &= Test("typeof_type_name", typeof(TypedThing), "TypedThing");
    return result;
}

bool testNameof()
{
    bool result = true;
    int myVar = 0;
    NamedThing thing = NamedThing();

    result &= Test("nameof_var", nameof(myVar), "myVar");
    result &= Test("nameof_struct", nameof(thing), "thing");
    result &= Test("nameof_field", nameof(thing.value), "value");
    result &= Test("nameof_type", nameof(NamedThing), "NamedThing");
    return result;
}

// Namespace tests

int add(int a, int b) { return a + b + 100; }  // global add returns a different value

namespace MathUtils
{
    int add(int a, int b) { return a + b; }
    int multiply(int a, int b) { return a * b; }

    namespace Advanced
    {
        int square(int x) { return x * x; }
        int cube(int x) { return x * x * x; }
    }
}

using Math = MathUtils;          // global alias for top-level namespace
using MathAdv = MathUtils.Advanced;  // global alias for nested namespace

bool testNamespace()
{
    bool result = true;
    result &= Test("namespace_add", MathUtils.add(3, 4), 7);            // 3+4=7
    result &= Test("namespace_multiply", MathUtils.multiply(3, 4), 12); // 3*4=12
    result &= Test("global_add", add(3, 4), 107);                       // 3+4+100=107
    result &= Test("no_collision", MathUtils.add(3, 4) != add(3, 4), 1);
    result &= Test("global_using_add", Math.add(3, 4), 7);              // global alias resolves to MathUtils.add
    result &= Test("global_using_multiply", Math.multiply(3, 4), 12);   // global alias resolves to MathUtils.multiply
    return result;
}

bool testLocalUsing()
{
    using M = MathUtils;  // local alias, only visible in this function
    bool result = true;
    result &= Test("local_using_add", M.add(2, 3), 5);
    result &= Test("local_using_multiply", M.multiply(2, 3), 6);
    return result;
}

bool testNestedNamespace()
{
    bool result = true;
    result &= Test("nested_square", MathUtils.Advanced.square(4), 16);    // 4*4=16
    result &= Test("nested_cube", MathUtils.Advanced.cube(3), 27);        // 3*3*3=27

    using Adv = MathUtils.Advanced;  // local alias for nested namespace
    result &= Test("nested_using_square", Adv.square(5), 25);             // 5*5=25
    result &= Test("nested_using_cube", Adv.cube(2), 8);                  // 2*2*2=8
    return result;
}

bool testNestedUsing()
{
    bool result = true;

    // Global alias for nested namespace
    result &= Test("global_nested_using_square", MathAdv.square(4), 16);  // 4*4=16
    result &= Test("global_nested_using_cube", MathAdv.cube(3), 27);      // 3*3*3=27

    // Local alias for nested namespace shadows nothing; verify it works
    using Adv2 = MathUtils.Advanced;
    result &= Test("local_nested_using_square", Adv2.square(6), 36);      // 6*6=36
    result &= Test("local_nested_using_cube", Adv2.cube(4), 64);          // 4*4*4=64
    return result;
}

bool testLocalUsingScoped()
{
    // 'M' from testLocalUsing is not visible here; only 'Math' global alias is.
    bool result = true;
    result &= Test("local_alias_not_leaked", Math.add(1, 2), 3);
    return result;
}

// =============================================================
// Forward reference tests
// =============================================================

// Test 1: bar() calls foo() which is defined after bar().
int bar()
{
    return foo();
}

int foo()
{
    return 42;
}

bool testForwardFunction()
{
    bool result = true;
    result &= Test("bar calls foo (fwd ref)", bar(), 42);
    return result;
}

// Test 2: Mutual recursion — no explicit forward declaration needed.
bool isEven(int n)
{
    if (n == 0) return true;
    return isOdd(n - 1);
}

bool isOdd(int n)
{
    if (n == 0) return false;
    return isEven(n - 1);
}

bool testMutualRecursion()
{
    bool result = true;
    result &= Test("isEven(0)", isEven(0), 1);
    result &= Test("isEven(4)", isEven(4), 1);
    result &= Test("isOdd(1)",  isOdd(1),  1);
    result &= Test("isOdd(5)",  isOdd(5),  1);
    result &= Test("isEven(3) is false", isEven(3), 0);
    result &= Test("isOdd(4) is false",  isOdd(4),  0);
    return result;
}

// Test 3: runAccumulator() calls getTotal() which is defined after the struct.
int runAccumulator()
{
    return getTotal();
}

struct Accumulator
{
    int x = 10;
    int y = 20;
    int z = 30;

    int Total()
    {
        return x + y + z;
    }
};

int getTotal()
{
    Accumulator a = Accumulator();
    return a.Total();
}

bool testForwardFunctionWithStruct()
{
    bool result = true;
    result &= Test("runAccumulator (fwd ref to getTotal)", runAccumulator(), 60);
    return result;
}

// Test 4: Member function calls a member function defined later in the struct.
struct Calculator
{
    int value = 10;

    int ComputeDouble()
    {
        return doubleIt();
    }

    int ComputeSum()
    {
        return addThree(5, 3);
    }

    int doubleIt()
    {
        return value * 2;
    }

    int addThree(int b, int c)
    {
        return value + b + c;
    }
};

bool testForwardInStruct()
{
    bool result = true;
    Calculator c = Calculator();
    result &= Test("member calls fwd func (doubleIt)", c.ComputeDouble(), 20);
    result &= Test("member calls fwd func (addThree)", c.ComputeSum(), 18);
    return result;
}

// Return block: the function body is inlined at every call site.
// 'return' inside the block returns from the caller.
inline int doubleValue(int x)
{
    return { return x * 2; };
}

inline int addValues(int a, int b)
{
    return { return a + b; };
}

// Wrappers: the return-block is inlined here; its 'return' returns from these functions.
int getDoubled(int x)
{
    doubleValue(x);
}

int getSum(int a, int b)
{
    addValues(a, b);
}

bool testReturnBlock()
{
    bool result = true;
    result &= Test("returnBlock doubleValue(5)", getDoubled(5), 10);
    result &= Test("returnBlock addValues(3,4)", getSum(3, 4), 7);
    return result;
}

// Assert uses a return block: if the assertion fails, it returns false from the caller.
inline bool Assert(const char* testName, int actual, int expected)
{
    return {
        if (actual != expected)
        {
            printf("%s negative: expected '%d' but got '%d'.\n", testName, expected, actual);
            return false;
        }
    };
}

// When the failing Assert is hit, it exits this function early with false.
// The 'return true' at the end is only reached if all asserts pass.
bool testAssertPass()
{
    Assert("assert 42==42", 42, 42);
    Assert("assert 7==7", 7, 7);
    return true;
}

bool testAssertFail()
{
    Assert("assert 10==10", 10, 10);
    Assert("assert 10==99", 10, 99);  // fails — exits testAssertFail with false
    return true;
}

bool testAssertReturnBlock()
{
    bool result = true;
    result &= Test("assert_all_pass", testAssertPass(), true);
    result &= Test("assert_early_exit", testAssertFail(), false);
    return result;
}

// =============================================================
// Explicit-width integer type tests
// C equivalents: i8=int8_t, i16=int16_t, i32=int32_t, i64=int64_t
//                u8=uint8_t, u16=uint16_t, u32=uint32_t, u64=uint64_t
// =============================================================

int sumI32(i32 a, i32 b) { return a + b; }
int sumU32(u32 a, u32 b) { return a + b; }

bool testExplicitIntTypes()
{
    bool result = true;

    // Signed types: declaration and basic value
    i8  s8  = 100;
    i16 s16 = 1000;
    i32 s32 = 100000;
    i64 s64 = 200000;

    result &= Test("i8_value",  s8,  100);
    result &= Test("i16_value", s16, 1000);
    result &= Test("i32_value", s32, 100000);
    result &= Test("i64_value", s64, 200000);

    // Unsigned types: declaration and basic value
    u8  u8v  = 200;
    u16 u16v = 2000;
    u32 u32v = 300000;
    u64 u64v = 400000;

    result &= Test("u8_value",  u8v,  200);
    result &= Test("u16_value", u16v, 2000);
    result &= Test("u32_value", u32v, 300000);
    result &= Test("u64_value", u64v, 400000);

    // Arithmetic - values chosen to stay within each type's range
    i8  s8a  = 50;   // 50+50=100, within i8  (-128..127)
    u8  u8a  = 100;  // 100+100=200, within u8 (0..255)
    result &= Test("i8_add",  s8a  + s8a,   100);  // 50+50=100
    result &= Test("i16_add", s16  + s16,   2000); // 1000+1000=2000, within i16
    result &= Test("i32_add", s32  + s32,   200000); // 100000+100000=200000
    result &= Test("u8_add",  u8a  + u8a,   200);  // 100+100=200
    result &= Test("u16_add", u16v + u16v,  4000); // 2000+2000=4000, within u16

    // C-equivalent compatibility: int <-> i32 are the same type
    int ci = s32;
    result &= Test("i32_to_int", ci, 100000);

    i32 ia = ci;
    result &= Test("int_to_i32", ia, 100000);

    // Passing i32/u32 to functions expecting i32/u32
    result &= Test("func_i32", sumI32(40, 2), 42);
    result &= Test("func_u32", sumU32(40, 2), 42);

    // Passing int to function expecting i32 (compatible types)
    int x = 10;
    result &= Test("int_to_i32_param", sumI32(x, 5), 15);

    // Hex literals with high bit set (contain hex digit 'E' — must not be parsed as float)
    // C++ rule: hex literals that exceed i32 positive range type as unsigned int (same 32-bit pattern).
    u32 magic = 0xBA63E001;             // contains 'E' — previously mistaken as float exponent
    u32 magic2 = (u32)0xBA63E001;
    result &= Test("hex_high_bit_direct", magic,  (u32)0xBA63E001);
    result &= Test("hex_high_bit_cast",   magic2, (u32)0xBA63E001);
    result &= Test("hex_with_E_digit",    (u32)0xDEADBEEF, (u32)0xDEADBEEF);
    result &= Test("hex_all_ones",        (u32)0xFFFFFFFF, (u32)0xFFFFFFFF);
    result &= Test("hex_int_min",         (u32)0x80000000, (u32)0x80000000);

    return result;
}

// =============================================================
// Null-conditional (?.) and null-coalescing (??) tests
// =============================================================

struct NullableNode
{
    int value = 99;
    int Read() { return value; }
};

// Helper: returns the node's value if non-null, -1 otherwise
int readNodeValueNC(NullableNode* node)
{
    return node?.value ?? -1;
}

// Helper: calls Read() if non-null, returns -1 otherwise
int callNodeRead(NullableNode* node)
{
    return node?.Read() ?? -1;
}

bool testNullConditional()
{
    bool result = true;

    NullableNode n = NullableNode();
    NullableNode* p = &n;
    NullableNode* np = nullptr;

    // null-conditional field access + coalescing via helper
    result &= Test("nc_coalesce_nonnull", readNodeValueNC(p),  99);
    result &= Test("nc_coalesce_null",    readNodeValueNC(np), -1);

    // null-conditional method call via helper
    result &= Test("nc_method_nonnull",   callNodeRead(p),  99);
    result &= Test("nc_method_null",      callNodeRead(np), -1);

    // null-conditional method call directly on a local pointer (no helper)
    result &= Test("nc_direct_nonnull", p?.Read()  ?? -1, 99);
    result &= Test("nc_direct_null",    np?.Read() ?? -1, -1);

    // null-conditional field access directly on a local pointer (no helper)
    result &= Test("nc_direct_field_nonnull", p?.value  ?? -1, 99);
    result &= Test("nc_direct_field_null",    np?.value ?? -1, -1);

    return result;
}

const char* tryGetName(bool found)
{
    if (found) return "Alice";
    return nullptr;
}

bool testNullCoalescing()
{
    bool result = true;

    // pointer coalescing: null -> fallback string
    const char* name1 = tryGetName(true)  ?? "Unknown";
    const char* name2 = tryGetName(false) ?? "Unknown";
    result &= Test("nullcoal_nonnull_ptr", name1, "Alice");
    result &= Test("nullcoal_null_ptr",    name2, "Unknown");

    // integer coalescing: 0 -> default, nonzero -> self
    int zero = 0;
    int five = 5;
    result &= Test("nullcoal_zero",    zero ?? 42, 42);
    result &= Test("nullcoal_nonzero", five ?? 42, 5);

    return result;
}

// =============================================================
// Null-coalescing assignment (??=) tests
// =============================================================

bool testNullCoalescingAssignment()
{
    bool result = true;

    // zero int: should be assigned the rhs value
    int x = 0;
    x ??= 42;
    result &= Test("nullcoalasgn_zero_becomes_rhs", x, 42);

    // nonzero int: should keep its original value
    int y = 7;
    y ??= 99;
    result &= Test("nullcoalasgn_nonzero_unchanged", y, 7);

    // repeated application: once set, a second ??= should not overwrite
    int z = 0;
    z ??= 10;
    z ??= 20;
    result &= Test("nullcoalasgn_already_set", z, 10);

    // null pointer: should be assigned the rhs
    const char* p = nullptr;
    p ??= "hello";
    result &= Test("nullcoalasgn_null_ptr", p, "hello");

    // non-null pointer: should keep its original value
    const char* q = "world";
    q ??= "other";
    result &= Test("nullcoalasgn_nonnull_ptr", q, "world");

    // null struct pointer: should be assigned the rhs
    NullableNode* node = nullptr;
    node ??= new NullableNode();
    result &= Test("nullcoalasgn_null_struct_ptr", node?.Read() ?? -1, 99);
    delete node;

    // non-null struct pointer: should keep its original value and not be replaced
    NullableNode* nonNullNode = new NullableNode();
    NullableNode* replacementNode = new NullableNode();
    NullableNode* before = nonNullNode;
    nonNullNode ??= replacementNode;
    result &= Test("nullcoalasgn_nonnull_struct_ptr", nonNullNode == before, true);
    delete nonNullNode;
    delete replacementNode;

    return result;
}

// =============================================================
// Default keyword tests
// =============================================================

bool testDefault()
{
    bool result = true;

    // Primitive types: default -> zero value
    int  di = default;
    bool db = default;
    i32  di32 = default;
    i64  di64 = default;

    result &= Test("default_int",  di,   0);
    result &= Test("default_bool", db,   0);
    result &= Test("default_i32",  di32, 0);
    result &= Test("default_i64",  di64, 0);

    // Struct type: default -> calls default constructor, fields get their declared defaults
    MyStruct ds = default;
    result &= Test("default_struct_num1", ds.num1, 1);
    result &= Test("default_struct_num2", ds.num2, 2);
    result &= Test("default_struct_num3", ds.num3, 3);

    return result;
}

// =============================================================
// return default; tests
// =============================================================

struct RdPoint
{
    int x = 10;
    int y = 20;
};

class RdNode
{
    int val = 99;
};

int rdInt()       { return default; }
float rdFloat()   { return default; }
bool rdBool()     { return default; }
i64 rdI64()       { return default; }
int* rdIntPtr()   { return default; }
RdNode* rdClassPtr() { return default; }
RdPoint rdStruct() { return default; }
string rdString() { return default; }

int rdCondInt(bool flag)
{
    if (flag)
        return 99;
    return default;
}

RdPoint rdCondStruct(bool flag)
{
    if (flag)
    {
        RdPoint p;
        p.x = 7;
        p.y = 8;
        return p;
    }
    return default;
}

bool testReturnDefaultPrimitives()
{
    bool result = true;
    result &= Test("rd_int",   rdInt(),   0);
    result &= Test("rd_float", rdFloat(), 0.0f);
    result &= Test("rd_bool",  rdBool(),  false);
    result &= Test("rd_i64",   rdI64(),   (i64)0);
    return result;
}

bool testReturnDefaultPointers()
{
    bool result = true;
    result &= Test("rd_int_ptr",   rdIntPtr()   == nullptr ? 1 : 0, 1);
    result &= Test("rd_class_ptr", rdClassPtr() == nullptr ? 1 : 0, 1);
    return result;
}

bool testReturnDefaultStruct()
{
    bool result = true;
    RdPoint pt = rdStruct();
    // return default; zero-initializes — fields are 0, not declared defaults (10, 20)
    result &= Test("rd_struct_x", pt.x, 0);
    result &= Test("rd_struct_y", pt.y, 0);
    return result;
}

bool testReturnDefaultString()
{
    bool result = true;
    string s = rdString();
    result &= Test("rd_string_len", s.length(), 0);
    return result;
}

bool testReturnDefaultConditional()
{
    bool result = true;
    result &= Test("rd_cond_taken",   rdCondInt(true),  99);
    result &= Test("rd_cond_default", rdCondInt(false), 0);

    RdPoint p1 = rdCondStruct(true);
    result &= Test("rd_cond_struct_x", p1.x, 7);
    result &= Test("rd_cond_struct_y", p1.y, 8);

    RdPoint p2 = rdCondStruct(false);
    result &= Test("rd_cond_struct_zero_x", p2.x, 0);
    result &= Test("rd_cond_struct_zero_y", p2.y, 0);
    return result;
}

// =============================================================
// string type tests
// string is a built-in value type: { i8* _ptr, i32 _len }
// with data() -> i8* and length() -> i32 member functions.
// =============================================================

// operator string(char*) and operator string(i32) are now provided by core/string.cb.

bool testStringType()
{
    bool result = true;

    string s = "hello";

    result &= Test("string_length", s.length(), 5);
    result &= Test("string_data", s.data(), "hello");

    string s2 = "world!!";
    result &= Test("string2_length", s2.length(), 7);
    result &= Test("string2_data", s2.data(), "world!!");

    return result;
}

// Tests the built-in string literal syntax: string s = "...";
// A string literal is automatically wrapped in a string struct { _ptr, _len }.
bool testStringLiteral()
{
    bool result = true;

    // Basic assignment from a string literal
    string s = "hello";
    result &= Test("str_lit_length",      s.length(), 5);
    result &= Test("str_lit_data",     s.data(),  "hello");

    // Longer literal — the canonical use case: string s = "My test string";
    string s2 = "My test string";
    result &= Test("str_lit_long_length", s2.length(), 14);
    result &= Test("str_lit_long_data", s2.data(), "My test string");

    // Empty string literal
    string s3 = "";
    result &= Test("str_lit_empty_length", s3.length(), 0);
    result &= Test("str_lit_empty_data", s3.data(), "");

    // String with escape sequences — \n counts as one character
    string s4 = "line1\nline2";
    result &= Test("str_lit_escape_length", s4.length(), 11);

    // Multiple string variables can coexist with independent values
    string sa = "alpha";
    string sb = "beta!";
    result &= Test("str_lit_multi_a_length",  sa.length(), 5);
    result &= Test("str_lit_multi_b_length",  sb.length(), 5);
    result &= Test("str_lit_multi_a_data", sa.data(), "alpha");
    result &= Test("str_lit_multi_b_data", sb.data(), "beta!");

    return result;
}

class Node
{
    int value = 0;
};

int testNewDelete()
{
    Node* n = new Node();
    delete n;
    return 42;
}

int testNewArray()
{
    int* arr = new int[5];
    for (int i = 0; i < 5; i++)
    {
        arr[i] = i;
	}

    for (int i = 0; i < 5; i++)
    {
        if (arr[i] != i)
        {
            printf("testNewArray failed: arr[%d] expected %d but got %d.\n", i, i, arr[i]);
            delete[] arr;
            return 1;
        }
	}

    delete[] arr;
    return 99;
}

class Counter
{
    int count = 0;
};

int testNewWithConstructor()
{
    Counter* c = new Counter();
    delete c;
    return 123;
}

bool testNewArrayConstructor()
{
    bool result = true;

    // new T[n] must call the default constructor for each element
    MyStruct* arr = new MyStruct[3];
    result &= Test("new_arr_ctor_0_num1", arr[0].num1, 1);
    result &= Test("new_arr_ctor_0_num2", arr[0].num2, 2);
    result &= Test("new_arr_ctor_1_num1", arr[1].num1, 1);
    result &= Test("new_arr_ctor_2_num3", arr[2].num3, 3);
    delete[3] arr;

    return result;
}

// Regression: when 'p = new T' is an assignment statement (not a declaration),
// lastOwningResult must not leak into the next declaration in scope.
// Previously the next declared pointer variable was incorrectly marked owning
// and freed at scope exit, causing a double-free with the allocator.
bool testNewAssignNoOwnershipLeak()
{
    bool result = true;

    // p declared before loop (assignment, not declaration, inside loop)
    int* p = nullptr;
    int sum = 0;
    int i = 0;
    while (i < 3)
    {
        p = new int;   // assignment — must NOT set lastOwningResult for next decl
        *p = i + 1;
        sum += *p;
        delete p;
        p = nullptr;
        i++;
    }
    result &= Test("new_assign_sum", sum, 6);

    // q declared AFTER the loop that used 'p = new int'.
    // If lastOwningResult leaked, q would be marked owning and freed at scope
    // exit even though it holds a stack address — causing heap corruption.
    int local = 99;
    int* q = &local;   // NOT a heap allocation; must not be freed at scope exit
    result &= Test("new_assign_no_leak", *q, 99);

    return result;
}

class Point : IString
{
    i32 x = 0;
    i32 y = 0;

    string ToString()
    {
        return "{x}, {y}";
    }
};

bool testFormatString()
{
    bool result = true;

    string name = "World";
    string greeting = "Hello {name}!";
    result &= Test("fmt_simple", greeting.data(), "Hello World!");

    string a = "foo";
    string b = "bar";
    string combined = "{a} and {b}";
    result &= Test("fmt_two", combined.data(), "foo and bar");

    string prefix = "pre";
    string suffix = "suf";
    string three = "{prefix}-mid-{suffix}";
    result &= Test("fmt_three", three.data(), "pre-mid-suf");

    Point p = Point();
	p.x = 10;
	p.y = 20;
	string pointStr = "Point is {p}.";
	result &= Test("fmt_object", pointStr.data(), "Point is 10, 20.");

    return result;
}

// =============================================================
// if const compile-time conditional tests
// =============================================================

bool testIfConst()
{
    bool result = true;

    // Test 1: if const with true literal — should enter true branch
    if const (true)
    {
        result &= Test("if_const_true", 1, 1);
    }
    else
    {
        result &= Test("if_const_true", 0, 1);  // should not execute
    }

    // Test 2: if const with false literal — should skip body entirely
    if const (false)
    {
        result &= Test("if_const_false", 0, 1);  // should not execute
    }

    // Test 3: if const with comparison (1 == 1) — should enter true branch
    if const (1 == 1)
    {
        result &= Test("if_const_eq_true", 1, 1);
    }
    else
    {
        result &= Test("if_const_eq_true", 0, 1);  // should not execute
    }

    // Test 4: if const with false comparison (1 == 2) — should enter else branch
    if const (1 == 2)
    {
        result &= Test("if_const_eq_false", 0, 1);  // should not execute
    }
    else
    {
        result &= Test("if_const_eq_false", 1, 1);
    }

    // Test 5: if const with inequality (5 != 3) — should enter true branch
    if const (5 != 3)
    {
        result &= Test("if_const_neq_true", 1, 1);
    }
    else
    {
        result &= Test("if_const_neq_true", 0, 1);  // should not execute
    }

    return result;
}

// =============================================================
// Platform constant tests (__PLATFORM__)
// =============================================================

bool testPlatformConstant()
{
    bool result = true;

    // The __PLATFORM__ constant is set at compile-time based on -p flag:
    // 64 for win64 (default), 32 for win32
    // This test verifies that if const works with __PLATFORM__

    if const (__PLATFORM__ == 64)
    {
        result &= Test("__PLATFORM__==64", 1, 1);
    }
    else if const (__PLATFORM__ == 32)
    {
        result &= Test("__PLATFORM__==32", 1, 1);
    }

    // Verify that exactly one of the above branches executed
    // (the other branch should be completely eliminated from IR)
    return result;
}

// =============================================================
// Global-scope if const tests (compile-time conditional declarations)
// =============================================================

// Test 1: Simple true/false branches at global scope
if const (true)
{
    class GlobalTrueClass
    {
        int value = 42;
    };
}
else
{
    class GlobalFalseClass
    {
        int value = 0;
    };
}

// Test 2: Platform-specific declarations
if const (__PLATFORM__ >= 32)
{
    class PlatformSpecificClass
    {
        int platformValue = 64;
    };

    void platformSpecificFunc()
    {
        printf("Compiled for win64\n");
    }
}
else
{
    class PlatformSpecificClass
    {
        int platformValue = 32;
    };

    void platformSpecificFunc()
    {
        printf("Compiled for other platform\n");
    }
}

// Test 3: Nested if const at global scope
if const (false)
{
    class NeverDeclared
    {
        int x = 99;
    };
}

if const (true)
{
    class AlwaysDeclared
    {
        int y = 123;
    };
}

bool testGlobalIfConst()
{
    bool result = true;

    // Test that GlobalTrueClass from true branch is available
    GlobalTrueClass gtc = GlobalTrueClass();
    result &= Test("global_if_const_true_branch", gtc.value, 42);

    // Test that PlatformSpecificClass is declared correctly
    PlatformSpecificClass psc = PlatformSpecificClass();
    if const (__PLATFORM__ >= 32)
    {
        result &= Test("global_if_const_platform_win64", psc.platformValue, 64);
    }
    else
    {
        result &= Test("global_if_const_platform_other", psc.platformValue, 32);
    }

    // Test that AlwaysDeclared from always-true branch is available
    AlwaysDeclared ad = AlwaysDeclared();
    result &= Test("global_if_const_always_declared", ad.y, 123);

    // Call platform-specific function
    platformSpecificFunc();

    return result;
}

// =============================================================
// Struct with string field
// =============================================================

struct Employee
{
    string name = default;
    int id = 0;
};

bool testStructWithString()
{
    bool result = true;
    Employee e;
    e.name = "Alice";
    e.id = 42;
    result &= Test("employee_name", e.name.data(), "Alice");
    result &= Test("employee_id",   e.id, 42);
    return result;
}

// =============================================================
// Brace escape sequences in string literals
// \{ \} produce literal braces; {{ }} fold to single braces
// =============================================================

bool testBraceEscapes()
{
    bool result = true;

    // Both \{ and {{ should produce a literal '{' — compare the two forms against each other
    const char* slash = "\{hello\}";
    const char* dbl   = "{{hello}}";
    result &= Test("brace_forms_equal", strcmp(slash, dbl), 0);

    // In a format string, {{ folds to literal '{' and {x} interpolates — check resulting length
    // "value is {x} = 42" => 18 chars
    int x = 42;
    string s = "value is {{x}} = {x}";
    result &= Test("mixed_brace_length", s.length(), 17);

    return result;
}

// =============================================================
// Global struct pointer method dispatch
// Verifies that TypeAndValue is preserved for global variables so
// direct method calls on globals resolve correctly.
// =============================================================

struct GlobalCounter
{
    int count = 0;
    int increment() { count = count + 1; return count; }
    int get() { return count; }
};

GlobalCounter* g_counter = nullptr;

bool testGlobalStructPtrMethod()
{
    bool result = true;

    GlobalCounter c = GlobalCounter();
    g_counter = &c;

    result &= Test("global_ptr_method_get",      g_counter.get(),       0);
    result &= Test("global_ptr_method_increment", g_counter.increment(), 1);
    result &= Test("global_ptr_method_after_inc", g_counter.get(),       1);

    g_counter = nullptr;
    return result;
}

// =============================================================
// Overload resolution tests (float, string types)
// =============================================================

bool testOverloadResolution()
{
    bool result = true;
    result &= Test("int overload",        42,    42);
    result &= Test("bool overload",       true,  true);
    result &= Test("char* overload",      "hello", "hello");

    float f = 1.5f;
    result &= Test("float overload exact",   f,      1.5f);
    result &= Test("float overload literal", 3.14f,  3.14f);
    // Verify a known mismatch is caught (Test returns 0 on mismatch)
    result &= Test("float mismatch detected",   Test("_float_mm",  1.0f,   2.0f)  == 0, true);

    string s1 = "hello";
    string s2 = "hello";
    string s3 = "world";
    result &= Test("string overload equal",      s1, s2);
    result &= Test("string mismatch detected",   Test("_str_mm",   s1, s3)        == 0, true);
    result &= Test("string vs literal",          s1, "hello");
    result &= Test("str/literal mismatch detect",Test("_str_lit_mm", s1, "world") == 0, true);

    return result;
}

// =============================================================
// Static method tests
// =============================================================

struct StaticMathUtils
{
    static int add(int a, int b) { return a + b; }
    static int mul(int a, int b) { return a * b; }
    static int square(int x)     { return x * x; }
};

class StaticCounter
{
    int _count = 0;
    static int zero()       { return 0; }
    static int maxValue()   { return 2147483647; }
    void increment()        { _count = _count + 1; }
    int  value()            { return _count; }
};

struct StaticPoint
{
    int x = 0;
    int y = 0;
    static int origin_x() { return 0; }
    static int origin_y() { return 0; }
};

bool testStatic()
{
    bool result = true;
    result &= Test("StaticMath.add",    StaticMathUtils.add(3, 4),    7);
    result &= Test("StaticMath.mul",    StaticMathUtils.mul(3, 4),    12);
    result &= Test("StaticMath.square", StaticMathUtils.square(5),    25);
    result &= Test("Counter.zero",      StaticCounter.zero(),         0);
    result &= Test("Counter.maxValue",  StaticCounter.maxValue(),     2147483647);
    StaticCounter sc = StaticCounter();
    sc.increment();
    sc.increment();
    result &= Test("Counter.value",     sc.value(),                   2);
    result &= Test("Point.origin_x",    StaticPoint.origin_x(),       0);
    result &= Test("Point.origin_y",    StaticPoint.origin_y(),       0);
    return result;
}

// =============================================================
// Cast tests (C-style casts, float UFCS, integer conversions)
// =============================================================

bool testCast()
{
    bool result = true;

    i32 five = 5;
    i32 neg3 = -3;
    float fpos = 3.9f;
    float fneg = -3.9f;

    result &= Test("(float)5",    (float)five,   5.0f);
    result &= Test("(float)-3",   (float)neg3,  -3.0f);
    result &= Test("(int)3.9f",   (int)fpos,     3);
    result &= Test("(int)-3.9f",  (int)fneg,    -3);
    result &= Test("(int)3.0f",   (int)3.0f,     3);

    i64 big64 = 0x200000000;
    big64 = big64 + 5;
    i32 neg32 = -1;
    result &= Test("(i32)(i64) truncate", (i32)big64,   5);
    result &= Test("(i64)(i32) sign-ext", (i64)neg32,   (i64)-1);

    result &= Test("(0.5f).round()",    (0.5f).round(),    1.0f);
    result &= Test("(-0.5f).round()",   (-0.5f).round(),  -1.0f);
    result &= Test("(0.4f).round()",    (0.4f).round(),    0.0f);
    result &= Test("(-0.4f).round()",   (-0.4f).round(),   0.0f);
    result &= Test("(-3.7f).floor()",   (-3.7f).floor(),  -4.0f);
    result &= Test("(-3.7f).ceil()",    (-3.7f).ceil(),   -3.0f);
    result &= Test("(-3.0f).floor()",   (-3.0f).floor(),  -3.0f);
    result &= Test("(-3.0f).ceil()",    (-3.0f).ceil(),   -3.0f);
    result &= Test("(0.0f).abs()",      (0.0f).abs(),      0.0f);
    result &= Test("(3.5f).abs()",      (3.5f).abs(),      3.5f);
    result &= Test("(9.0f).sqrt()",     (9.0f).sqrt(),     3.0f);
    result &= Test("(1.0f).sqrt()",     (1.0f).sqrt(),     1.0f);
    result &= Test("(0.0f).sqrt()",     (0.0f).sqrt(),     0.0f);

    float v = -5.5f;
    result &= Test("var(-5.5f).floor()", v.floor(), -6.0f);
    result &= Test("var(-5.5f).ceil()",  v.ceil(),  -5.0f);
    result &= Test("var(-5.5f).round()", v.round(), -6.0f);
    result &= Test("var(-5.5f).abs()",   v.abs(),    5.5f);

    i32 v127   = 127;
    i32 v128   = 128;
    i32 v32767 = 32767;
    i32 v32768 = 32768;
    result &= Test("127.to_i8()",          (int)v127.to_i8(),    127);
    result &= Test("128.to_i8() wrap",     (int)v128.to_i8(),   -128);
    result &= Test("32767.to_i16()",       (int)v32767.to_i16(), 32767);
    result &= Test("32768.to_i16() wrap",  (int)v32768.to_i16(),-32768);

    i32 neg_src  = -100;
    i8  byte_neg = neg_src.to_i8();
    result &= Test("i8(-100).to_i16()", (int)byte_neg.to_i16(), -100);
    result &= Test("i8(-100).to_i32()", (int)byte_neg.to_i32(), -100);
    result &= Test("i8(-100).to_i64()",  byte_neg.to_i64(),      (i64)-100);

    i16 short_neg = neg_src.to_i16();
    result &= Test("i16(-100).to_i32()", (int)short_neg.to_i32(), -100);
    result &= Test("i16(-100).to_i64()",  short_neg.to_i64(),     (i64)-100);

    i32 xi = 42;
    result &= Test("i32(42).to_i32()",  xi.to_i32(),  (i32)42);
    i64 yi = 999;
    result &= Test("i64(999).to_i64()", yi.to_i64(),  (i64)999);

    return result;
}

// =============================================================
// Nullable pointer (?.) tests
// =============================================================

struct NullablePoint
{
    int x = 0;
    int y = 0;
};

struct NullableContainer
{
    NullablePoint* inner = nullptr;
};

bool testNullableTypes()
{
    bool result = true;

    NullablePoint? p;
    result &= Test("nullable default is nullptr", (int)(p == nullptr), 1);

    NullablePoint pt = NullablePoint();
    pt.x = 10;
    pt.y = 20;
    p = &pt;
    result &= Test("nullable after assign not nullptr", (int)(p != nullptr), 1);
    result &= Test("nullable ?.x access",               p?.x, 10);
    p = nullptr;
    result &= Test("nullable reset to nullptr", (int)(p == nullptr), 1);

    NullablePoint pt2;
    pt2.x = 42;
    NullablePoint* rp = &pt2;
    result &= Test("?. on local ptr",           rp?.x,  42);
    NullablePoint* np = nullptr;
    result &= Test("?. on null local ptr",       np?.x,  0);

    NullablePoint pt3;
    pt3.x = 99;
    NullableContainer nc;
    nc.inner = &pt3;
    result &= Test("?. on member ptr",           nc.inner?.x, 99);
    NullableContainer nc2;
    result &= Test("?. on null member ptr",      nc2.inner?.x, 0);

    return result;
}

// =============================================================
// Nested struct / class tests
// =============================================================

struct OuterStruct {
    struct InnerStruct {
        int x = 0;
        int y = 0;
    };
    InnerStruct inner;
    int value = 0;

    int sum()
    {
        return inner.x + inner.y + value;
    }
};

class OuterClass {
    class InnerClass {
        int a = 0;
        int b = 0;

        int product()
        {
            return a * b;
        }
    };
    InnerClass data;
};

class ClassWithInnerStruct {
    struct Point {
        int x = 0;
        int y = 0;
    };
    Point origin;
    Point corner;
};

struct StructWithInnerClass {
    class Color {
        int r = 0;
        int g = 0;
        int b = 0;

        int brightness()
        {
            return r + g + b;
        }
    };
    Color tint;
};

bool testNestedStructClass()
{
    bool result = true;

    OuterStruct o;
    o.inner.x = 3;
    o.inner.y = 7;
    o.value = 10;
    result &= Test("nested struct field access", o.inner.x, 3);
    result &= Test("nested struct method", o.sum(), 20);

    OuterStruct.InnerStruct standalone;
    standalone.x = 100;
    standalone.y = 200;
    result &= Test("nested type qualified x", standalone.x, 100);
    result &= Test("nested type qualified y", standalone.y, 200);

    OuterClass oc;
    oc.data.a = 4;
    oc.data.b = 5;
    result &= Test("nested class field a", oc.data.a, 4);
    result &= Test("nested class method product", oc.data.product(), 20);

    ClassWithInnerStruct cws;
    cws.origin.x = 0;
    cws.origin.y = 0;
    cws.corner.x = 10;
    cws.corner.y = 20;
    result &= Test("class with inner struct origin x", cws.origin.x, 0);
    result &= Test("class with inner struct corner x", cws.corner.x, 10);
    result &= Test("class with inner struct corner y", cws.corner.y, 20);

    StructWithInnerClass swc;
    swc.tint.r = 100;
    swc.tint.g = 150;
    swc.tint.b = 200;
    result &= Test("struct with inner class field r", swc.tint.r, 100);
    result &= Test("struct with inner class brightness", swc.tint.brightness(), 450);

    return result;
}

// =============================================================
// Variadic function tests
// =============================================================

bool testVariadic()
{
    bool result = true;
    char* buf = (char*)malloc(64);

    // Positional: all args by position — regression for the original call path.
    snprintf(buf, 64, "%d + %d = %d", 3, 4, 7);
    result &= Test("variadic_positional", (const char*)buf, "3 + 4 = 7");

    // Named fixed parameter with variadic tail: fmt: names the third param of snprintf
    // while buf and 64 remain positional and 6, 7, 42 are variadic.
    snprintf(buf, 64, fmt: "%d * %d = %d", 6, 7, 42);
    result &= Test("variadic_named_fmt", (const char*)buf, "6 * 7 = 42");

    free(buf);
    return result;
}

// =============================================================
// Primitive type alias tests (using Alias = primitiveType)
// =============================================================

using MyInt  = int;
using MyU32  = u32;
using MyI64  = i64;
using MyBool = bool;
using MyF32  = float;

MyInt  primitiveAliasAdd(MyInt a, MyInt b) { return a + b; }
MyU32  primitiveAliasU32(MyU32 a, MyU32 b) { return a + b; }
MyI64  primitiveAliasI64(MyI64 a, MyI64 b) { return a + b; }

bool testPrimitiveTypeAlias()
{
    bool result = true;

    MyInt  i = 10;
    result &= Test("alias_int_decl",      i,                      10);
    result &= Test("alias_int_func",      primitiveAliasAdd(3, 4), 7);

    MyU32  u = 300000;
    result &= Test("alias_u32_decl",      u,                       300000);
    result &= Test("alias_u32_func",      primitiveAliasU32(10, 5), 15);

    MyI64  l = 1000000000;
    result &= Test("alias_i64_decl",      l,                       (i64)1000000000);
    result &= Test("alias_i64_func",      primitiveAliasI64(100, 200), (i64)300);

    MyBool b = true;
    result &= Test("alias_bool_decl",     b,                       true);

    MyF32  f = 1.5f;
    result &= Test("alias_float_decl",    f,                       1.5f);

    // Local alias inside a function
    using LocalU8 = u8;
    LocalU8 byte = 255;
    result &= Test("local_alias_u8",      (int)byte,               255);

    return result;
}

// =============================================================
// Fixed-size inline array tests (local variables and struct fields)
// =============================================================

struct ArrayHolder
{
    i8 label[8] = default;
    i32 count = 0;
    i8 data[16] = default;
};

int sumFixedBuf(i8* buf, int len)
{
    int sum = 0;
    int i = 0;
    while (i < len) { sum = sum + (int)buf[i]; i++; }
    return sum;
}

bool testFixedArrays()
{
    bool result = true;

    // Local fixed-size array: write, read back
    i8 buf[8] = default;
    buf[0] = (i8)10; buf[1] = (i8)20; buf[2] = (i8)30;
    result &= Test("fixed_local_elem0", (int)buf[0], 10);
    result &= Test("fixed_local_elem1", (int)buf[1], 20);
    result &= Test("fixed_local_elem2", (int)buf[2], 30);

    // Array decays to pointer when passed to a function
    result &= Test("fixed_local_decay", sumFixedBuf(buf, 3), 60);

    // No ConstArraySize carryover to the next declarator
    int plain = 42;
    result &= Test("fixed_no_carryover", plain, 42);

    // Struct with multiple inline array fields
    ArrayHolder h = default;
    h.label[0] = (i8)'O'; h.label[1] = (i8)'K'; h.label[2] = (i8)0;
    h.count = 7;
    h.data[0] = (i8)1; h.data[1] = (i8)2; h.data[2] = (i8)3;
    result &= Test("fixed_struct_label0", (int)h.label[0], (int)'O');
    result &= Test("fixed_struct_label1", (int)h.label[1], (int)'K');
    result &= Test("fixed_struct_count",  h.count, 7);
    result &= Test("fixed_struct_data_sum", sumFixedBuf(h.data, 3), 6);

    // Struct pointer access
    ArrayHolder* ph = &h;
    result &= Test("fixed_struct_ptr_label0", (int)ph->label[0], (int)'O');
    result &= Test("fixed_struct_ptr_count",  ph->count, 7);

    return result;
}

// =============================================================
// Regression: Bug 1 — cast result chained with -> member access
// CFlat previously required a named variable to hold the cast
// result before accessing a field (e.g. ((Struct*)ptr)->field).
// =============================================================

struct CastMemberPoint { int x = 0; int y = 0; };

bool testCastMemberAccess()
{
    bool result = true;

    CastMemberPoint pt = CastMemberPoint();
    pt.x = 7;
    pt.y = 13;

    void* vp = (void*)&pt;

    // Direct cast-then-arrow without a named intermediate
    int x = ((CastMemberPoint*)vp)->x;
    result &= Test("cast->field x", x, 7);

    // Outer cast applied to a cast->arrow expression
    int y = (int)((CastMemberPoint*)vp)->y;
    result &= Test("(int)(cast->field y)", y, 13);

    return result;
}

// =============================================================
// Regression: Bug 2 — returning int from a bool function
// The compiler previously emitted ret i32 inside an i1 function,
// which fails LLVM module verification. The fix emits ICmpNE to
// convert any nonzero int to true (matching bool assignment semantics).
// =============================================================

int intTwo() { return 2; }

bool boolFromIntReturn()
{
    return intTwo();
}

bool testReturnBoolFromInt()
{
    bool result = true;

    // intTwo() returns 2; value 2 truncated to i1 is 0 (wrong), ICmpNE gives 1 (right).
    result &= Test("bool from int=2", (int)boolFromIntReturn(), 1);

    return result;
}

