// 'auto' return-type inference on generic functions. The return type is
// determined per-instantiation from the body's 'return' expressions: each
// captured value type is unified (widening only) and the function is rebuilt
// with the inferred signature.

extern int printf(const char* fmt, ...);

// Single-param: returns T from a binary op on T.
auto square<T>(T v) { return v * v; }

// Identity: returns the same T it received.
auto identity<T>(T v) { return v; }

// Two-params: returns one of them via ternary - both branches have type T.
auto pick_max<T>(T lhs, T rhs) { return lhs > rhs ? lhs : rhs; }

// Returns a different type than the parameter (bool, not T).
auto is_positive<T>(T v) { return v > (T)0; }

// Body has the same expression in two return paths - exercises unification
// with identical types (trivially accepted).
auto abs_val<T>(T v)
{
    if (v < (T)0) return -v;
    return v;
}

extern int main()
{
    if (square<int>(5) != 25)       return 1;
    if (square<i64>(7) != (i64)49)  return 2;

    double d = square<double>(2.5);
    if (d < 6.24 || d > 6.26)       return 3;

    if (identity<int>(42) != 42)    return 4;

    if (pick_max<int>(3, 7) != 7)   return 5;
    if (pick_max<int>(9, 2) != 9)   return 6;

    if (is_positive<int>(-3) != false) return 7;
    if (is_positive<int>(5)  != true)  return 8;

    if (abs_val<int>(-4) != 4) return 9;
    if (abs_val<int>(4)  != 4) return 10;

    printf("test_auto_return: all checks passed\n");
    return 0;
}
