// Binds a PREBUILT C library via header extraction + lib link (the `import
// package` path), as opposed to test_c_autoextern.cb which compiles C *source*.
//
// The fixture library lives in Test/cinterop/. test.bat pre-builds mathlib.lib
// (via Test/cinterop/build_mathlib.bat) before launching the test workers.
//
// Both paths below are relative to THIS file's directory (Test/):
//   - "cinterop/mathlib.h"   -> Test/cinterop/mathlib.h   (header, AST-dumped)
//   - lib "cinterop/mathlib.lib" -> Test/cinterop/mathlib.lib (linked)
//
// cflat AST-dumps the header to auto-extern ml_add/ml_mul/ml_sum and register
// the Color enum constants, then links mathlib.lib. No hand-written extern.
//
// The inline `define "ML_EXTRA"` is scoped to THIS import's AST dump (appended
// on top of any process-wide --c-define), exposing the gated EXTRA_FLAG enum.
import package "cinterop/mathlib.h" lib "cinterop/mathlib.lib" define "ML_EXTRA";

extern int main()
{
    if (ml_add(40, 2) != 42) return 1;          // plain function
    if (ml_mul(6, 7) != 42) return 2;
    if (ml_sum(4, 10, 20, 30, 40) != 100) return 3;  // variadic call-site ABI
    if (WHITE != 100) return 4;                  // explicit enum value
    if (GREEN != 2) return 5;                    // auto-incremented enum value
    if (EXTRA_FLAG != 7) return 6;               // gated by the inline define clause
    return 0;
}
