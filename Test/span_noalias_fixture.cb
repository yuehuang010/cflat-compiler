// Fixture for test_hpc.bat: the span<T> noalias guarantee, verified at -O2.
//
// span_axpy passes two span<double> BY VALUE and indexes each span's buffer through a local
// `double[]`. The span's `T[] _ptr` field rides the compiler's scoped alias-scope metadata, so at
// -O2 the loop must vectorize with NO runtime overlap check (no `vector.memcheck`) - the headline
// span guarantee. The `vectorize` keyword additionally hard-errors if the loop fails to vectorize
// at all, and test_hpc.bat greps the emitted IR to assert the memcheck is absent.
//
// Named without a `test_` prefix so test.bat's `test_*.cb` wildcard skips it (it needs -O2, which
// test.bat does not use).
import "span.cb";
import "cruntime.cb";

void span_axpy(double k, span<double> y, span<double> x)
{
    double[] yv = y.data();
    double[] xv = x.data();
    i64 n = y.length();
    vectorize for (i64 i = 0; i < n; i = i + 1) { yv[i] = yv[i] + k * xv[i]; }
}

// Indexing the spans DIRECTLY through operator[] (no `double[] yv = y.data()` local) must also
// vectorize with NO vector.memcheck. The compiler lowers `y[i]` on a span to the `_ptr` field
// subscript, keying each access's alias scope to the receiver (y vs x) instead of collapsing
// provenance to the operator[] method's `this` - so two distinct spans still prove disjoint at -O2.
void span_idx_axpy(double k, span<double> y, span<double> x)
{
    i64 n = y.length();
    vectorize for (i64 i = 0; i < n; i = i + 1) { y[i] = y[i] + k * x[i]; }
}

// chunk() must preserve the noalias contract: take tile `c` of `nc` from each
// whole span and axpy over the tiles. At -O2 this must vectorize with NO
// vector.memcheck, exactly like the whole-span case - the headline guarantee for
// the partition primitive (the offset T[] is re-blessed through the union pun).
void chunk_axpy(double k, span<double> y, span<double> x, i64 c, i64 nc)
{
    span<double> yc = y.chunk(c, nc);
    span<double> xc = x.chunk(c, nc);
    double[] yv = yc.data();
    double[] xv = xc.data();
    i64 n = yc.length();
    vectorize for (i64 i = 0; i < n; i = i + 1) { yv[i] = yv[i] + k * xv[i]; }
}

extern int main()
{
    i64 n = 1024;
    double[] a = new double[n];
    double[] b = new double[n];
    i64 i = 0;
    while (i < n) { a[i] = (double)i; b[i] = 2.0; i = i + 1; }

    span<double> y; y.wrap(a, n);
    span<double> x; x.wrap(b, n);
    span_axpy(3.0, y, x);     // a[i] += 3 * 2  ->  a[i] + 6

    // Partition both buffers into 4 tiles and axpy over each tile; the tiles
    // cover [0,n) disjointly, so the whole array gets a[i] += 10 * 2 = +20.
    i64 nc = 4;
    i64 c = 0;
    while (c < nc) { chunk_axpy(10.0, y, x, c, nc); c = c + 1; }   // a[i] -> a[i] + 26

    int ok = 1;
    if (a[0]    != 26.0)   ok = 0;
    if (a[100]  != 126.0)  ok = 0;
    if (a[1023] != 1049.0) ok = 0;

    // operator[] form on its own buffers: c[i] += 5 * 2 = +10.
    double[] c = new double[n];
    double[] d = new double[n];
    i64 j = 0;
    while (j < n) { c[j] = (double)j; d[j] = 2.0; j = j + 1; }
    span<double> yc2; yc2.wrap(c, n);
    span<double> xd2; xd2.wrap(d, n);
    span_idx_axpy(5.0, yc2, xd2);
    if (c[0]    != 10.0)   ok = 0;
    if (c[100]  != 110.0)  ok = 0;
    if (c[1023] != 1033.0) ok = 0;

    int* cp = move c; delete[_] cp;
    int* dp = move d; delete[_] dp;
    int* ap = move a; delete[_] ap;
    int* bp = move b; delete[_] bp;

    printf("span_axpy ok=%d\n", ok);
    return ok == 1 ? 0 : 1;
}
