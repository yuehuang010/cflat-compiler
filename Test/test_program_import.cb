// Regression test: program defined in an imported library file.
// Previously failed with "unknown type 'list__string'" because
// CompileImportedFile did not run ScanGenericTypeUses before
// ScanExternalDeclaration, so the opaque shell for list__string
// was absent when ScanProgramDefinition pre-declared run().
import "list.cb";
import "thread.cb";
import "test_helper.cb";
import "prog_lib.cb";

extern int main()
{
    list<string> args;
    LibProgram p;
    p.run(args);
    p.WaitForExit();

    bool ok = Test("program in imported file: result", p.result, 42);
    if (ok) printf("test_program_import: all passed.\n");
    else    printf("test_program_import: FAILED.\n");
    return ok ? 0 : 1;
}
