import "test_helper.cb";

extern int main()
{
    int passed = 0;
    int total = 0;

    // ── C-style casts: integer ↔ float ───────────────────────────────────────

    i32 five = 5;
    i32 neg3 = -3;
    float fpos = 3.9f;
    float fneg = -3.9f;

    total++; passed += Test("(float)5",       (float)five,  5.0f);
    total++; passed += Test("(float)-3",      (float)neg3, -3.0f);
    total++; passed += Test("(int)3.9f",      (int)fpos,    3);    // truncates toward zero
    total++; passed += Test("(int)-3.9f",     (int)fneg,   -3);    // truncates toward zero
    total++; passed += Test("(int)3.0f",      (int)3.0f,    3);

    // ── C-style casts: integer widening / narrowing ──────────────────────────

    i64 big64 = 0x200000000;
    big64 = big64 + 5;
    i32 neg32 = -1;

    total++; passed += Test("(i32)(i64) truncate",  (i32)big64,  5);
    total++; passed += Test("(i64)(i32) sign-ext",  (i64)neg32, (i64)-1);

    // ── Float UFCS methods — negative values and boundary ────────────────────

    // round: ties go away from zero
    total++; passed += Test("(0.5f).round()",   (0.5f).round(),   1.0f);
    total++; passed += Test("(-0.5f).round()",  (-0.5f).round(), -1.0f);
    total++; passed += Test("(0.4f).round()",   (0.4f).round(),   0.0f);
    total++; passed += Test("(-0.4f).round()",  (-0.4f).round(),  0.0f);

    // floor and ceil on negative values
    total++; passed += Test("(-3.7f).floor()", (-3.7f).floor(), -4.0f);
    total++; passed += Test("(-3.7f).ceil()",  (-3.7f).ceil(),  -3.0f);
    total++; passed += Test("(-3.0f).floor()", (-3.0f).floor(), -3.0f);
    total++; passed += Test("(-3.0f).ceil()",  (-3.0f).ceil(),  -3.0f);

    // abs on zero and positive
    total++; passed += Test("(0.0f).abs()",    (0.0f).abs(),    0.0f);
    total++; passed += Test("(3.5f).abs()",    (3.5f).abs(),    3.5f);

    // sqrt
    total++; passed += Test("(9.0f).sqrt()",   (9.0f).sqrt(),   3.0f);
    total++; passed += Test("(1.0f).sqrt()",   (1.0f).sqrt(),   1.0f);
    total++; passed += Test("(0.0f).sqrt()",   (0.0f).sqrt(),   0.0f);

    // methods on named variable
    float v = -5.5f;
    total++; passed += Test("var(-5.5f).floor()", v.floor(), -6.0f);
    total++; passed += Test("var(-5.5f).ceil()",  v.ceil(),  -5.0f);
    total++; passed += Test("var(-5.5f).round()", v.round(), -6.0f);
    total++; passed += Test("var(-5.5f).abs()",   v.abs(),    5.5f);

    // ── Integer conversion methods — narrowing ────────────────────────────────

    i32 v127  = 127;
    i32 v128  = 128;     // 0x80 overflows signed i8 → -128
    i32 v32767 = 32767;
    i32 v32768 = 32768;  // 0x8000 overflows signed i16 → -32768

    total++; passed += Test("127.to_i8()",       (int)v127.to_i8(),    127);
    total++; passed += Test("128.to_i8() wrap",  (int)v128.to_i8(),   -128);
    total++; passed += Test("32767.to_i16()",    (int)v32767.to_i16(), 32767);
    total++; passed += Test("32768.to_i16() wrap",(int)v32768.to_i16(),-32768);

    // ── Integer conversion methods — widening ─────────────────────────────────

    i32 neg_src = -100;
    i8  byte_neg = neg_src.to_i8();   // -100 in 8 bits

    total++; passed += Test("i8(-100).to_i16()", (int)byte_neg.to_i16(), -100);
    total++; passed += Test("i8(-100).to_i32()", (int)byte_neg.to_i32(), -100);
    total++; passed += Test("i8(-100).to_i64()",  byte_neg.to_i64(),      (i64)-100);

    i16 short_neg = neg_src.to_i16(); // -100 in 16 bits
    total++; passed += Test("i16(-100).to_i32()", (int)short_neg.to_i32(), -100);
    total++; passed += Test("i16(-100).to_i64()",  short_neg.to_i64(),     (i64)-100);

    // ── Integer conversion methods — same-size (no-op) ────────────────────────

    i32 x = 42;
    total++; passed += Test("i32(42).to_i32()", x.to_i32(), (i32)42);

    i64 y = 999;
    total++; passed += Test("i64(999).to_i64()", y.to_i64(), (i64)999);

    printf("\n%d / %d tests passed.\n", passed, total);
    return passed == total ? 0 : 1;
}
