import "stream.cb";
import "list.cb";
import "thread.cb";
import "test_helper.cb";

// Producer: prints 3 numbered lines to stdout.
program StreamProducer {
    int main(move list<string> args) {
        printf("alpha\n");
        printf("beta\n");
        printf("gamma\n");
        return 0;
    }
};

// Consumer: reads up to lineCount lines via fgets and accumulates their lengths.
program StreamConsumer {
    int lineCount = 3;
    int totalLen  = 0;

    int main(move list<string> args) {
        char* buf = (char*)malloc(256);
        int i = 0;
        while (i < lineCount) {
            // __std_iob(0)/fgets are the portable runtime shims (cruntime.cb); on Windows
            // they resolve to __acrt_iob_func(0) and the same fgets linkage symbol.
            void* stdinStream = __std_iob(0);
            if (fgets(buf, 256, stdinStream) == nullptr) break;
            totalLen += strlen(buf);
            i++;
        }
        free(buf);
        return totalLen;
    }
};

// ---------------------------------------------------------------------------
// Basic pipe tests
// ---------------------------------------------------------------------------

// "alpha\n"(6) + "beta\n"(5) + "gamma\n"(6) = 17
bool testStreamBasicPipe() {
    bool result = true;

    stream s;
    s.bufferSize = 8;
    s.init();

    StreamProducer  p1;
    StreamConsumer  p2;
    p2.lineCount = 3;

    p1 >> s;
    s >> p2;

    list<string> args1;
    list<string> args2;
    p1.run(args1);
    p2.run(args2);

    p1.WaitForExit();
    s.close();
    p2.WaitForExit();

    result &= Test("stream pipe totalLen", p2.totalLen, 17);
    result &= Test("stream pipe producer exit", p1.exitCode, 0);
    return result;
}

// Small buffer: bufferSize = 1 means each printf output exceeds the 1-byte text
// buffer and is sent directly (bypass path). Producer blocks per-message until
// the consumer returns the buffer. Should still deliver all lines correctly.
bool testStreamSmallBuffer() {
    bool result = true;

    stream s;
    s.bufferSize = 1;
    s.init();

    StreamProducer p1;
    StreamConsumer p2;
    p2.lineCount = 3;

    p1 >> s;
    s >> p2;

    list<string> args1;
    list<string> args2;
    p1.run(args1);
    p2.run(args2);

    p1.WaitForExit();
    s.close();
    p2.WaitForExit();

    result &= Test("stream small buffer totalLen", p2.totalLen, 17);
    return result;
}

// Direct `producer >> consumer` with no explicit stream in the middle. The compiler
// synthesizes the stream, wires stdout->stdin, and the producer's run() trampoline
// auto-closes it after main() returns - so there is no hand-written s.init()/s.close().
bool testStreamDirectPipe() {
    bool result = true;

    StreamProducer p1;
    StreamConsumer p2;
    p2.lineCount = 3;

    p1 >> p2;   // auto-synthesized + auto-closed stream

    list<string> args1;
    list<string> args2;
    p1.run(args1);
    p2.run(args2);

    p1.WaitForExit();
    p2.WaitForExit();

    result &= Test("stream direct pipe totalLen", p2.totalLen, 17);
    result &= Test("stream direct pipe producer exit", p1.exitCode, 0);
    return result;
}

// ---------------------------------------------------------------------------
// Primitive type tests - int, negative int, large int, float
// ---------------------------------------------------------------------------

// Sends 4 integers (positive, negative, zero, large) as "%d\n" lines.
program PrimitiveSender {
    int main(move list<string> args) {
        printf("%d\n", 42);
        printf("%d\n", -7);
        printf("%d\n", 0);
        printf("%d\n", 1000000);
        return 0;
    }
};

// Reads 4 integers via scanf and stores them in fields.
program PrimitiveReceiver {
    int a = 0;
    int b = 0;
    int c = 0;
    int d = 0;

    int main(move list<string> args) {
        scanf("%d", &a);
        scanf("%d", &b);
        scanf("%d", &c);
        scanf("%d", &d);
        return a + b + c + d;
    }
};

bool testStreamPrimitives() {
    bool result = true;

    stream s;
    s.bufferSize = 8;
    s.init();

    PrimitiveSender   p1;
    PrimitiveReceiver p2;

    p1 >> s;
    s >> p2;

    list<string> args1;
    list<string> args2;
    p1.run(args1);
    p2.run(args2);

    p1.WaitForExit();
    s.close();
    p2.WaitForExit();

    // 42 + (-7) + 0 + 1000000 = 1000035
    result &= Test("stream primitives a",    p2.a, 42);
    result &= Test("stream primitives b",    p2.b, -7);
    result &= Test("stream primitives c",    p2.c, 0);
    result &= Test("stream primitives d",    p2.d, 1000000);
    result &= Test("stream primitives sum",  p2.exitCode, 1000035);
    return result;
}

// ---------------------------------------------------------------------------
// CFlat string type test
// ---------------------------------------------------------------------------

// Sends 3 CFlat string values via printf("%s\n", s.data()).
program StringSender {
    int main(move list<string> args) {
        string hello = "hello";
        string world = "world";
        string bang  = "CFlat!";
        printf("%s\n", hello.data());
        printf("%s\n", world.data());
        printf("%s\n", bang.data());
        return 0;
    }
};

// Reads 3 lines via fgets and checks exact content (including trailing newline).
program StringReceiver {
    int match1 = 0;
    int match2 = 0;
    int match3 = 0;

    int main(move list<string> args) {
        char* buf = (char*)malloc(256);
        void* stdinStream = __std_iob(0);
        if (fgets(buf, 256, stdinStream) != nullptr) {
            match1 = strcmp(buf, "hello\n") == 0 ? 1 : 0;
        }
        if (fgets(buf, 256, stdinStream) != nullptr) {
            match2 = strcmp(buf, "world\n") == 0 ? 1 : 0;
        }
        if (fgets(buf, 256, stdinStream) != nullptr) {
            match3 = strcmp(buf, "CFlat!\n") == 0 ? 1 : 0;
        }
        free(buf);
        return match1 + match2 + match3;
    }
};

bool testStreamStringType() {
    bool result = true;

    stream s;
    s.bufferSize = 8;
    s.init();

    StringSender   p1;
    StringReceiver p2;

    p1 >> s;
    s >> p2;

    list<string> args1;
    list<string> args2;
    p1.run(args1);
    p2.run(args2);

    p1.WaitForExit();
    s.close();
    p2.WaitForExit();

    result &= Test("stream string match1", p2.match1, 1);
    result &= Test("stream string match2", p2.match2, 1);
    result &= Test("stream string match3", p2.match3, 1);
    result &= Test("stream string exit",   p2.exitCode, 3);
    return result;
}

// ---------------------------------------------------------------------------
// char* (raw null-terminated string) test
// ---------------------------------------------------------------------------

// Sends 3 raw char* strings via printf("%s\n", ptr).
program CharPtrSender {
    int main(move list<string> args) {
        const char* first  = "raw_one";
        const char* second = "raw_two";
        const char* third  = "raw_three";
        printf("%s\n", first);
        printf("%s\n", second);
        printf("%s\n", third);
        return 0;
    }
};

// Reads 3 lines via fgets, verifies content with strcmp.
program CharPtrReceiver {
    int match1 = 0;
    int match2 = 0;
    int match3 = 0;

    int main(move list<string> args) {
        char* buf = (char*)malloc(256);
        void* stdinStream = __std_iob(0);
        if (fgets(buf, 256, stdinStream) != nullptr) {
            match1 = strcmp(buf, "raw_one\n") == 0 ? 1 : 0;
        }
        if (fgets(buf, 256, stdinStream) != nullptr) {
            match2 = strcmp(buf, "raw_two\n") == 0 ? 1 : 0;
        }
        if (fgets(buf, 256, stdinStream) != nullptr) {
            match3 = strcmp(buf, "raw_three\n") == 0 ? 1 : 0;
        }
        free(buf);
        return match1 + match2 + match3;
    }
};

bool testStreamCharPtr() {
    bool result = true;

    stream s;
    s.bufferSize = 8;
    s.init();

    CharPtrSender   p1;
    CharPtrReceiver p2;

    p1 >> s;
    s >> p2;

    list<string> args1;
    list<string> args2;
    p1.run(args1);
    p2.run(args2);

    p1.WaitForExit();
    s.close();
    p2.WaitForExit();

    result &= Test("stream charptr match1", p2.match1, 1);
    result &= Test("stream charptr match2", p2.match2, 1);
    result &= Test("stream charptr match3", p2.match3, 1);
    result &= Test("stream charptr exit",   p2.exitCode, 3);
    return result;
}

// ---------------------------------------------------------------------------
// Mixed-types test - int, string, char*, float all in one stream
// ---------------------------------------------------------------------------

// Sends one of each: int, CFlat string, char*, float (as "%g" for clean formatting).
program MixedSender {
    int main(move list<string> args) {
        printf("%d\n", 99);
        string greeting = "greet";
        printf("%s\n", greeting.data());
        const char* raw = "rawline";
        printf("%s\n", raw);
        printf("%g\n", 2.5);
        return 0;
    }
};

// Reads the 4 mixed messages back via scanf / fgets, verifies each.
program MixedReceiver {
    int    intVal   = 0;
    int    strMatch = 0;
    int    rawMatch = 0;
    int    floatOk  = 0;

    int main(move list<string> args) {
        char* buf = (char*)malloc(256);
        void* stdinStream = __std_iob(0);

        // 1. integer
        scanf("%d", &intVal);

        // 2. CFlat string
        if (fgets(buf, 256, stdinStream) != nullptr) {
            strMatch = strcmp(buf, "greet\n") == 0 ? 1 : 0;
        }

        // 3. raw char*
        if (fgets(buf, 256, stdinStream) != nullptr) {
            rawMatch = strcmp(buf, "rawline\n") == 0 ? 1 : 0;
        }

        // 4. float - "%g" formats 2.5 as "2.5"; verify the exact string content
        if (fgets(buf, 256, stdinStream) != nullptr) {
            floatOk = strcmp(buf, "2.5\n") == 0 ? 1 : 0;
        }

        free(buf);
        return intVal + strMatch + rawMatch + floatOk;
    }
};

bool testStreamMixedTypes() {
    bool result = true;

    stream s;
    s.bufferSize = 8;
    s.init();

    MixedSender   p1;
    MixedReceiver p2;

    p1 >> s;
    s >> p2;

    list<string> args1;
    list<string> args2;
    p1.run(args1);
    p2.run(args2);

    p1.WaitForExit();
    s.close();
    p2.WaitForExit();

    result &= Test("stream mixed intVal",   p2.intVal,   99);
    result &= Test("stream mixed strMatch", p2.strMatch, 1);
    result &= Test("stream mixed rawMatch", p2.rawMatch, 1);
    result &= Test("stream mixed floatOk",  p2.floatOk,  1);
    // sum: 99 + 1 + 1 + 1 = 102
    result &= Test("stream mixed exit",     p2.exitCode, 102);
    return result;
}

// ---------------------------------------------------------------------------
// Bidirectional stdio test - "?" / "Y" handshake across two programs
// ---------------------------------------------------------------------------

// Sends "?\n" to stdout, then reads one reply line from stdin.
program Questioner {
    int gotAnswer = 0;

    int main(move list<string> args) {
        printf("?\n");
        char* buf = (char*)malloc(256);
        void* stdinStream = __std_iob(0);
        if (fgets(buf, 256, stdinStream) != nullptr) {
            gotAnswer = strcmp(buf, "Y\n") == 0 ? 1 : 0;
        }
        free(buf);
        return gotAnswer;
    }
};

// Reads one line from stdin; if it is "?\n", replies "Y\n" to stdout.
program Responder {
    int main(move list<string> args) {
        char* buf = (char*)malloc(256);
        void* stdinStream = __std_iob(0);
        if (fgets(buf, 256, stdinStream) != nullptr) {
            if (strcmp(buf, "?\n") == 0) {
                printf("Y\n");
            }
        }
        free(buf);
        return 0;
    }
};

bool testBidirectionalStdio() {
    bool result = true;

    // Two unidirectional streams form a bidirectional pipe.
    // bufferSize=1 means every write is published immediately so neither
    // program deadlocks while waiting for the other to respond.
    stream s1;   // Questioner stdout -> Responder stdin
    stream s2;   // Responder  stdout -> Questioner stdin
    s1.bufferSize = 1;
    s2.bufferSize = 1;
    s1.init();
    s2.init();

    Questioner q;
    Responder  r;

    q >> s1;
    s1 >> r;
    r >> s2;
    s2 >> q;

    list<string> args1;
    list<string> args2;
    q.run(args1);
    r.run(args2);

    q.WaitForExit();
    r.WaitForExit();

    result &= Test("bidirectional questioner got Y", q.gotAnswer, 1);
    result &= Test("bidirectional questioner exit",  q.exitCode, 1);
    result &= Test("bidirectional responder exit",   r.exitCode, 0);
    return result;
}

// ---------------------------------------------------------------------------

extern int main() {
    int passed = 0;
    int total  = 0;

    total++; passed += testStreamBasicPipe()    ? 1 : 0;
    total++; passed += testStreamSmallBuffer()  ? 1 : 0;
    total++; passed += testStreamDirectPipe()   ? 1 : 0;
    total++; passed += testStreamPrimitives()   ? 1 : 0;
    total++; passed += testStreamStringType()   ? 1 : 0;
    total++; passed += testStreamCharPtr()      ? 1 : 0;
    total++; passed += testStreamMixedTypes()   ? 1 : 0;
    total++; passed += testBidirectionalStdio() ? 1 : 0;

    printf("Stream tests: %d/%d passed.\n", passed, total);
    return passed == total ? 0 : 1;
}
