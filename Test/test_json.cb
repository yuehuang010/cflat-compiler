import "test_helper.cb";
import "json.cb";

annotation JsonName { string value; };
annotation Private { };

// ── Structs ──────────────────────────────────────────────────────────────────

struct Point {
    int x = 0;
    int y = 0;
};

struct AllPrimitives {
    int    i = 0;
    bool   b = false;
    float  f = 0;
    string s = default;
};

struct Address {
    [JsonName("street_name")]
    string street = default;
    int zip = 0;
};

struct Employee {
    [JsonName("full_name")]
    string name = default;
    int id = 0;
    [Private]
    string _token = default;
    Address addr = default;
};

struct Level3 { int val = 0; };
struct Level2 { Level3 deep = default; int mid = 0; };
struct Level1 { Level2 inner = default; string top = default; };

// ── Class ─────────────────────────────────────────────────────────────────────

class Config {
    [JsonName("max_retries")]
    int maxRetries = 0;
    bool enabled = false;
    [Private]
    string secretKey = default;
    float threshold = 0;
};

// ── Helpers ───────────────────────────────────────────────────────────────────

// Verify that '{' and '}' in string literals are not treated as interpolation.
string buildBraces()
{
    stringbuilder sb;
    sb.append("{");
    sb.append("}");
    return sb.toString();
}

// Float comparison with tolerance
bool floatNear(float a, float b)
{
    float diff = a - b;
    if (diff < 0) diff = -diff;
    return diff < 0.001f;
}

extern int main()
{
    int passed = 0;
    int total  = 0;

    // ── curly-brace literals ─────────────────────────────────────────────────
    total++; passed += Test("curly_braces", buildBraces(), "{}");

    // ── flat struct - toJson ─────────────────────────────────────────────────
    Point p;
    p.x = 3;
    p.y = 7;
    total++; passed += Test("toJson_flat", JsonBuilder.toJson(p), "{\"x\":3,\"y\":7}");

    // ── all primitives - toJson ──────────────────────────────────────────────
    AllPrimitives ap;
    ap.i = 42;
    ap.b = true;
    ap.f = 1.5f;
    ap.s = "hello";
    string apJson = JsonBuilder.toJson(ap);
    total++; passed += Test("toJson_int_field",    apJson, "{\"i\":42,\"b\":true,\"f\":1.5,\"s\":\"hello\"}");

    AllPrimitives apFalse;
    apFalse.i = -7;
    apFalse.b = false;
    apFalse.f = 0;
    apFalse.s = "";
    total++; passed += Test("toJson_bool_false",   JsonBuilder.toJson(apFalse), "{\"i\":-7,\"b\":false,\"f\":0,\"s\":\"\"}");

    // ── nested struct - toJson ───────────────────────────────────────────────
    Employee e;
    e.name = "Alice";
    e.id = 42;
    e._token = "secret";
    e.addr.street = "Main St";
    e.addr.zip = 12345;
    total++; passed += Test("toJson_nested", JsonBuilder.toJson(e),
        "{\"full_name\":\"Alice\",\"id\":42,\"addr\":{\"street_name\":\"Main St\",\"zip\":12345}}");

    // ── deeply nested - toJson ───────────────────────────────────────────────
    Level1 l1;
    l1.top = "root";
    l1.inner.mid = 99;
    l1.inner.deep.val = 7;
    total++; passed += Test("toJson_deep", JsonBuilder.toJson(l1),
        "{\"inner\":{\"deep\":{\"val\":7},\"mid\":99},\"top\":\"root\"}");

    // ── class - toJson ───────────────────────────────────────────────────────
    Config cfg;
    cfg.maxRetries = 3;
    cfg.enabled = true;
    cfg.secretKey = "hidden";
    cfg.threshold = 0.5f;
    total++; passed += Test("toJson_class", JsonBuilder.toJson(cfg),
        "{\"max_retries\":3,\"enabled\":true,\"threshold\":0.5}");

    // ── fromJson - flat struct ───────────────────────────────────────────────
    Point p2 = JsonBuilder.fromJson<Point>("{\"x\":3,\"y\":7}");
    total++; passed += Test("fromJson_flat_x", p2.x, 3);
    total++; passed += Test("fromJson_flat_y", p2.y, 7);

    // ── fromJson - all primitives ────────────────────────────────────────────
    AllPrimitives ap2 = JsonBuilder.fromJson<AllPrimitives>("{\"i\":42,\"b\":true,\"f\":1.5,\"s\":\"hello\"}");
    total++; passed += Test("fromJson_int",    ap2.i, 42);
    total++; passed += Test("fromJson_bool",   ap2.b, true);
    total++; passed += Test("fromJson_string", ap2.s, "hello");
    total++;
    if (!floatNear(ap2.f, 1.5f)) { printf("fromJson_float MISMATCH (expected 1.5 got %f)\n", ap2.f); }
    else { passed++; if (printOnPass) printf("fromJson_float passed.\n"); }

    // ── fromJson - negative int ──────────────────────────────────────────────
    AllPrimitives ap3 = JsonBuilder.fromJson<AllPrimitives>("{\"i\":-7,\"b\":false,\"f\":0,\"s\":\"\"}");
    total++; passed += Test("fromJson_neg_int",   ap3.i, -7);
    total++; passed += Test("fromJson_bool_false", ap3.b, false);
    total++; passed += Test("fromJson_empty_str",  ap3.s, "");

    // ── fromJson - [JsonName] ────────────────────────────────────────────────
    Employee e2 = JsonBuilder.fromJson<Employee>(
        "{\"full_name\":\"Alice\",\"id\":42,\"addr\":{\"street_name\":\"Main St\",\"zip\":12345}}");
    total++; passed += Test("fromJson_name",   e2.name,        "Alice");
    total++; passed += Test("fromJson_id",     e2.id,          42);
    total++; passed += Test("fromJson_street", e2.addr.street, "Main St");
    total++; passed += Test("fromJson_zip",    e2.addr.zip,    12345);

    // ── fromJson - [Private] field must stay default ──────────────────────────
    total++; passed += Test("fromJson_private_skipped", e2._token, "");

    // ── fromJson - class with [JsonName] and [Private] ───────────────────────
    Config cfg2 = JsonBuilder.fromJson<Config>(
        "{\"max_retries\":5,\"enabled\":false,\"secretKey\":\"attempt\",\"threshold\":0.75}");
    total++; passed += Test("fromJson_class_retries", cfg2.maxRetries, 5);
    total++; passed += Test("fromJson_class_enabled", cfg2.enabled,    false);
    total++; passed += Test("fromJson_class_private", cfg2.secretKey,  "");
    total++;
    if (!floatNear(cfg2.threshold, 0.75f)) { printf("fromJson_class_threshold MISMATCH (expected 0.75 got %f)\n", cfg2.threshold); }
    else { passed++; if (printOnPass) printf("fromJson_class_threshold passed.\n"); }

    // ── fromJson - deep nesting ──────────────────────────────────────────────
    Level1 l2 = JsonBuilder.fromJson<Level1>(
        "{\"inner\":{\"deep\":{\"val\":7},\"mid\":99},\"top\":\"root\"}");
    total++; passed += Test("fromJson_deep_top",  l2.top,            "root");
    total++; passed += Test("fromJson_deep_mid",  l2.inner.mid,      99);
    total++; passed += Test("fromJson_deep_val",  l2.inner.deep.val, 7);

    // ── round-trip - Employee ────────────────────────────────────────────────
    Employee e3 = JsonBuilder.fromJson<Employee>(JsonBuilder.toJson(e));
    total++; passed += Test("roundtrip_name",   e3.name,        e.name);
    total++; passed += Test("roundtrip_id",     e3.id,          e.id);
    total++; passed += Test("roundtrip_street", e3.addr.street, e.addr.street);
    total++; passed += Test("roundtrip_zip",    e3.addr.zip,    e.addr.zip);

    // ── round-trip - AllPrimitives ───────────────────────────────────────────
    AllPrimitives ap4 = JsonBuilder.fromJson<AllPrimitives>(JsonBuilder.toJson(ap));
    total++; passed += Test("roundtrip_prim_int",    ap4.i, ap.i);
    total++; passed += Test("roundtrip_prim_bool",   ap4.b, ap.b);
    total++; passed += Test("roundtrip_prim_string", ap4.s, ap.s);
    total++;
    if (!floatNear(ap4.f, ap.f)) { printf("roundtrip_prim_float MISMATCH (expected %f got %f)\n", ap.f, ap4.f); }
    else { passed++; if (printOnPass) printf("roundtrip_prim_float passed.\n"); }

    // ── zero / default values ────────────────────────────────────────────────
    Point p0;
    Point p0rt = JsonBuilder.fromJson<Point>(JsonBuilder.toJson(p0));
    total++; passed += Test("roundtrip_zero_x", p0rt.x, 0);
    total++; passed += Test("roundtrip_zero_y", p0rt.y, 0);

    printf("%d/%d tests passed.\n", passed, total);
    return passed == total ? 0 : 1;
}
