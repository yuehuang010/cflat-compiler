import "arena.cb";
import "block_allocator.cb";
import "entry_allocator.cb";
import "fit_allocator.cb";
import "bucket_allocator.cb";
import "arena_allocator.cb";
import "page_pool.cb";
import "thread.cb";
import "arena_channel.cb";

// =============================================================
// Arena bump allocator tests
// =============================================================

bool testArena()
{
    Arena arena;

    void* p1 = arena.alloc(16);
    void* p2 = arena.alloc(32);
    if (p1 == nullptr) return false;
    if (p2 == nullptr) return false;
    if (p1 == p2)      return false;

    if (arena.used() != 48)          return false;
    if (arena.allocated() < 48)      return false;

    i32* nums = (i32*)arena.alloc(16);
    if (nums == nullptr) return false;
    nums[0] = 10; nums[1] = 20; nums[2] = 30; nums[3] = 40;
    if (nums[0] != 10) return false;
    if (nums[1] != 20) return false;
    if (nums[2] != 30) return false;
    if (nums[3] != 40) return false;

    i32* zeroed = (i32*)arena.zalloc(16);
    if (zeroed == nullptr) return false;
    if (zeroed[0] != 0)    return false;
    if (zeroed[3] != 0)    return false;

    i64 allocBefore = arena.allocated();
    arena.reset();
    if (arena.used() != 0)               return false;
    if (arena.allocated() != allocBefore) return false;

    void* p3 = arena.alloc(16);
    if (p3 == nullptr) return false;
    if (p3 != p1)      return false;

    arena.reset();
    void* big = arena.alloc(131072);
    if (big == nullptr)               return false;
    if (arena.allocated() < 131072)   return false;

    arena.reset();
    arena.setBlockSize(64);
    arena.alloc(64);
    arena.alloc(64);
    arena.alloc(64);
    if (arena.used() != 192) return false;

    return true;
}

// =============================================================
// BlockAllocator fixed-block-size tests
// =============================================================

bool testBlockAllocator()
{
    BlockAllocator ba;

    void* p1 = ba.alloc(32);
    if (p1 == nullptr) return false;

    void* p2 = ba.alloc(16);
    if (p2 == nullptr) return false;
    if (p1 == p2)      return false;

    if (ba.usedBlocks() != 2) return false;
    if (ba.totalBlocks() < 2) return false;

    ba.dealloc(p1);
    if (ba.usedBlocks() != 1) return false;

    void* p3 = ba.alloc(8);
    if (p3 == nullptr) return false;
    if (p3 != p1)      return false;
    if (ba.usedBlocks() != 2) return false;

    void* big = ba.alloc(128);
    if (big != nullptr) return false;

    i32* nums = (i32*)ba.alloc(16);
    if (nums == nullptr) return false;
    nums[0] = 10; nums[1] = 20; nums[2] = 30; nums[3] = 40;
    if (nums[0] != 10) return false;
    if (nums[3] != 40) return false;
    ba.dealloc((void*)nums);

    ba.PrintUsage();

    BlockAllocator ba2;

    void* first = ba2.alloc(1);
    if (first == nullptr) return false;

    i64 pageCapacity = ba2.totalBlocks();
    if (pageCapacity < 2) return false;

    i64 filled = 1;
    while (filled < pageCapacity)
    {
        void* slot = ba2.alloc(1);
        if (slot == nullptr) return false;
        filled = filled + 1;
    }
    if (ba2.usedBlocks() != pageCapacity)  return false;
    if (ba2.totalBlocks() != pageCapacity) return false;

    void* overflow = ba2.alloc(1);
    if (overflow == nullptr)               return false;
    if (ba2.totalBlocks() <= pageCapacity) return false;

    ba2.PrintUsage();

    return true;
}

// =============================================================
// EntryAllocator tests
// =============================================================

bool testEntryAllocatorBasic()
{
    EntryAllocator ea;

    if (ea.alloc(0) != nullptr) return false;  // zero-size -> null
    ea.dealloc(nullptr);                        // no-op - must not crash

    void* p1 = ea.alloc(4);
    if (p1 == nullptr) return false;
    if (ea.usedBytes() != 4) return false;

    void* p2 = ea.alloc(4);
    if (p2 == nullptr) return false;
    if (p1 == p2) return false;
    if (ea.usedBytes() != 8) return false;

    ea.dealloc(p1);
    if (ea.usedBytes() != 4) return false;

    ea.dealloc(p2);
    if (ea.usedBytes() != 0) return false;

    return true;
}

bool testEntryAllocatorWriteRead()
{
    EntryAllocator ea;

    i32* arr = (i32*)ea.alloc(16);
    if (arr == nullptr) return false;
    arr[0] = 10; arr[1] = 20; arr[2] = 30; arr[3] = 40;
    if (arr[0] != 10) return false;
    if (arr[1] != 20) return false;
    if (arr[2] != 30) return false;
    if (arr[3] != 40) return false;

    ea.dealloc((void*)arr);
    return true;
}

bool testEntryAllocatorLargeAlloc()
{
    EntryAllocator ea;

    // 131072 bytes exceeds the page data area (~61 KB), so it falls through
    // to system malloc.  usedBytes() does not track large allocs.
    void* p = ea.alloc(131072);
    if (p == nullptr) return false;

    i32* arr = (i32*)p;
    arr[0] = 111; arr[1] = 222; arr[2] = 333;
    if (arr[0] != 111) return false;
    if (arr[1] != 222) return false;
    if (arr[2] != 333) return false;

    ea.dealloc(p);
    if (ea.usedBytes() != 0) return false;

    return true;
}

bool testEntryAllocatorEntryTableFull()
{
    EntryAllocator ea;

    // Each leaf holds up to 1024 entry-table slots.  1025 simultaneous live
    // allocs must spill onto a second vmem page.  Pointers are not stored -
    // the destructor reclaims all vmem pages on scope exit.
    int i = 0;
    while (i < 1025)
    {
        void* p = ea.alloc(4);
        if (p == nullptr) return false;
        i = i + 1;
    }
    if (ea.usedBytes() != (i64)1025 * 4) return false;
    // Windows allocation granularity is 65536, so two pages = at least 131072.
    if (ea.totalBytes() < 131072) return false;

    return true;
}

bool testEntryAllocatorGarbageCollect()
{
    EntryAllocator ea;

    void* p = ea.alloc(4);
    if (p == nullptr) return false;

    // GC on a single page is a no-op (current page is always kept).
    ea.garbageCollect();
    if (ea.usedBytes() != 4) return false;

    ea.dealloc(p);
    ea.garbageCollect();
    if (ea.usedBytes() != 0) return false;
    // Current page is kept even when empty - at least one page remains.
    if (ea.totalBytes() < 65536) return false;

    return true;
}

bool testEntryAllocatorPeakReserve()
{
    EntryAllocator ea;

    void* p1 = ea.alloc(64);
    i64 peak1 = ea.peakReserve();
    if (peak1 <= 0) return false;

    void* p2 = ea.alloc(64);
    i64 peak2 = ea.peakReserve();
    if (peak2 < peak1) return false;

    ea.dealloc(p1);
    ea.dealloc(p2);
    // Dealloc must not reduce peakReserve.
    if (ea.peakReserve() != peak2) return false;
    // Peak must be >= current committed bytes.
    if (ea.peakReserve() < ea.totalBytes()) return false;

    return true;
}

bool testEntryAllocatorPrintUsage()
{
    EntryAllocator ea;
    ea.alloc(64);
    ea.alloc(131072);  // one in-page, one large-alloc fallback
    ea.printUsage();
    return true;
}

// =============================================================
// FitAllocator tests
// =============================================================

bool testFitBasic()
{
    FitAllocator fa;

    void* p1 = fa.alloc(64);
    if (p1 == nullptr) return false;

    void* p2 = fa.alloc(64);
    if (p2 == nullptr) return false;
    if (p1 == p2)      return false;

    if (fa.usedBytes() != 128) return false;

    fa.dealloc(p1);
    if (fa.usedBytes() != 64) return false;

    fa.dealloc(p2);
    if (fa.usedBytes() != 0) return false;

    return true;
}

bool testFitWriteRead()
{
    FitAllocator fa;

    i32* arr = (i32*)fa.alloc(32);
    if (arr == nullptr) return false;
    arr[0] = 10; arr[1] = 20; arr[2] = 30; arr[3] = 40;
    if (arr[0] != 10) return false;
    if (arr[1] != 20) return false;
    if (arr[2] != 30) return false;
    if (arr[3] != 40) return false;

    fa.dealloc((void*)arr);
    return true;
}

bool testFitMixedSizes()
{
    FitAllocator fa;

    void* a = fa.alloc(16);
    void* b = fa.alloc(64);
    void* c = fa.alloc(128);
    void* d = fa.alloc(32);
    if (a == nullptr) return false;
    if (b == nullptr) return false;
    if (c == nullptr) return false;
    if (d == nullptr) return false;

    fa.dealloc(b);
    fa.dealloc(d);

    // Two gaps exist. A 64-byte request should fit in the former b slot.
    void* e = fa.alloc(64);
    if (e == nullptr) return false;

    if (fa.usedBytes() != 16 + 128 + 64) return false;

    fa.dealloc(a);
    fa.dealloc(c);
    fa.dealloc(e);
    if (fa.usedBytes() != 0) return false;

    return true;
}

bool testFitCoalescing()
{
    FitAllocator fa;

    void* a = fa.alloc(128);
    void* b = fa.alloc(128);
    void* c = fa.alloc(128);
    if (a == nullptr) return false;
    if (b == nullptr) return false;
    if (c == nullptr) return false;

    i64 freeBefore = fa.freeBytes();

    fa.dealloc(a);
    fa.dealloc(c);
    fa.dealloc(b);  // b is between a and c - should coalesce all three

    if (fa.usedBytes() != 0)         return false;
    if (fa.freeBytes() <= freeBefore) return false;

    // The coalesced block should be large enough for a 384-byte alloc.
    void* big = fa.alloc(128 * 3);
    if (big == nullptr) return false;
    fa.dealloc(big);

    return true;
}

bool testFitSegmentGrowth()
{
    FitAllocator fa;

    // Allocate ~600K in 4K chunks to exhaust the default 1MB segment.
    int N = 160;
    int i = 0;
    while (i < N)
    {
        void* p = fa.alloc(4096);
        if (p == nullptr) return false;
        i = i + 1;
    }
    if (fa.usedBytes() != (i64)N * 4096) return false;

    return true;
}

bool testFitLargeAlloc()
{
    FitAllocator fa;

    void* p = fa.alloc(1048576);  // 1 MB - goes to large path
    if (p == nullptr) return false;
    if (fa.usedBytes() != 1048576) return false;

    i32* arr = (i32*)p;
    arr[0] = 777;
    if (arr[0] != 777) return false;

    fa.dealloc(p);
    if (fa.usedBytes() != 0) return false;

    return true;
}

bool testFitEdgeCases()
{
    FitAllocator fa;

    void* p = fa.alloc(0);
    if (p != nullptr) return false;

    fa.dealloc(nullptr);  // must not crash

    return true;
}

bool testFitPrintUsage()
{
    FitAllocator fa;
    fa.alloc(64);
    fa.alloc(2097152);
    fa.printUsage();
    return true;
}

// =============================================================
// BucketAllocator tests
// =============================================================

bool testBucketBasic()
{
    BucketAllocator ba;

    void* p1 = ba.alloc(64);
    if (p1 == nullptr) return false;

    void* p2 = ba.alloc(64);
    if (p2 == nullptr) return false;
    if (p1 == p2)      return false;

    if (ba.usedBytes() != 128) return false;

    ba.dealloc(p1);
    if (ba.usedBytes() != 64) return false;

    // LIFO: next alloc should reuse p1
    void* p3 = ba.alloc(64);
    if (p3 != p1) return false;

    ba.dealloc(p3);
    ba.dealloc(p2);
    if (ba.usedBytes() != 0) return false;

    return true;
}

bool testBucketSizeClasses()
{
    BucketAllocator ba;

    void* p8    = ba.alloc(8);
    void* p16   = ba.alloc(16);
    void* p32   = ba.alloc(32);
    void* p64   = ba.alloc(64);
    void* p128  = ba.alloc(128);
    void* p256  = ba.alloc(256);
    void* p512  = ba.alloc(512);
    void* p1024 = ba.alloc(1024);

    if (p8    == nullptr) return false;
    if (p16   == nullptr) return false;
    if (p32   == nullptr) return false;
    if (p64   == nullptr) return false;
    if (p128  == nullptr) return false;
    if (p256  == nullptr) return false;
    if (p512  == nullptr) return false;
    if (p1024 == nullptr) return false;

    if (p8   == p16)   return false;
    if (p16  == p32)   return false;
    if (p32  == p64)   return false;
    if (p64  == p128)  return false;
    if (p128 == p256)  return false;
    if (p256 == p512)  return false;
    if (p512 == p1024) return false;

    i64 expected = 8 + 16 + 32 + 64 + 128 + 256 + 512 + 1024;
    if (ba.usedBytes() != expected) return false;

    ba.dealloc(p8);
    ba.dealloc(p16);
    ba.dealloc(p32);
    ba.dealloc(p64);
    ba.dealloc(p128);
    ba.dealloc(p256);
    ba.dealloc(p512);
    ba.dealloc(p1024);
    if (ba.usedBytes() != 0) return false;

    return true;
}

bool testBucketLargeAlloc()
{
    BucketAllocator ba;

    void* p = ba.alloc(4096);
    if (p == nullptr) return false;
    if (ba.usedBytes() != 4096) return false;

    i32* arr = (i32*)p;
    arr[0] = 111; arr[1] = 222; arr[2] = 333;
    if (arr[0] != 111) return false;
    if (arr[1] != 222) return false;
    if (arr[2] != 333) return false;

    ba.dealloc(p);
    if (ba.usedBytes() != 0) return false;

    return true;
}

bool testBucketMultipleLargeAllocs()
{
    BucketAllocator ba;

    void* a = ba.alloc(2048);
    void* b = ba.alloc(8192);
    void* c = ba.alloc(65536);
    if (a == nullptr) return false;
    if (b == nullptr) return false;
    if (c == nullptr) return false;
    if (ba.usedBytes() != 2048 + 8192 + 65536) return false;

    ba.dealloc(b);  // free middle
    if (ba.usedBytes() != 2048 + 65536) return false;

    ba.dealloc(a);
    ba.dealloc(c);
    if (ba.usedBytes() != 0) return false;

    return true;
}

bool testBucketPageCommit()
{
    BucketAllocator ba;

    // 64-byte blocks fit 64 per page; allocate 65 to force a second page commit.
    int N = 65;
    int i = 0;
    while (i < N)
    {
        void* p = ba.alloc(64);
        if (p == nullptr) return false;
        i = i + 1;
    }
    if (ba.committedBytes() < (i64)2 * 4096) return false;
    if (ba.usedBytes() != (i64)N * 64) return false;

    return true;
}

bool testBucketWriteRead()
{
    BucketAllocator ba;

    i32* nums = (i32*)ba.alloc(32);
    if (nums == nullptr) return false;
    nums[0] = 10; nums[1] = 20; nums[2] = 30; nums[3] = 40;
    if (nums[0] != 10) return false;
    if (nums[1] != 20) return false;
    if (nums[2] != 30) return false;
    if (nums[3] != 40) return false;

    ba.dealloc((void*)nums);
    return true;
}

bool testBucketEdgeCases()
{
    BucketAllocator ba;

    void* p = ba.alloc(0);
    if (p != nullptr) return false;

    ba.dealloc(nullptr);  // must not crash

    return true;
}

bool testBucketPrintUsage()
{
    BucketAllocator ba;
    ba.alloc(8);
    ba.alloc(1024);
    ba.alloc(2048);
    ba.printUsage();
    return true;
}

// =============================================================
// ArenaAllocator tests
// =============================================================
//
// usedBytes() reports allocator-side live bytes, which include each block's
// 8-byte header and the 8-byte payload rounding. For a request of `s`, a block
// consumes `roundup8(s) + 8` bytes.

bool testArenaBasic()
{
    ArenaAllocator ar;

    void* p1 = ar.alloc(64);
    if (p1 == nullptr) return false;

    void* p2 = ar.alloc(64);
    if (p2 == nullptr) return false;
    if (p1 == p2)      return false;

    // Each 64-byte request consumes 64 + 8 (header) = 72 bytes.
    if (ar.usedBytes() != 144) return false;

    ar.dealloc(p1);
    if (ar.usedBytes() != 72) return false;

    ar.dealloc(p2);
    if (ar.usedBytes() != 0) return false;

    // The active chunk drained to zero, so its bump pointer reset: the next
    // allocation reuses the very first block address.
    void* p3 = ar.alloc(64);
    if (p3 != p1) return false;

    ar.dealloc(p3);
    return true;
}

bool testArenaMixedSizes()
{
    ArenaAllocator ar;

    void* a = ar.alloc(8);
    void* b = ar.alloc(40);
    void* c = ar.alloc(100);
    void* d = ar.alloc(7);
    if (a == nullptr) return false;
    if (b == nullptr) return false;
    if (c == nullptr) return false;
    if (d == nullptr) return false;

    // roundup8+8: 16 + 48 + 112 + 16 = 192
    if (ar.usedBytes() != 192) return false;

    ar.dealloc(a);
    ar.dealloc(b);
    ar.dealloc(c);
    ar.dealloc(d);
    if (ar.usedBytes() != 0) return false;

    return true;
}

bool testArenaWriteRead()
{
    ArenaAllocator ar;

    i32* nums = (i32*)ar.alloc(32);
    if (nums == nullptr) return false;
    nums[0] = 10; nums[1] = 20; nums[2] = 30; nums[3] = 40;
    if (nums[0] != 10) return false;
    if (nums[1] != 20) return false;
    if (nums[2] != 30) return false;
    if (nums[3] != 40) return false;

    ar.dealloc((void*)nums);
    if (ar.usedBytes() != 0) return false;
    return true;
}

bool testArenaLargeAlloc()
{
    ArenaAllocator ar;

    // Exceeds a chunk's usable space (~65504 bytes) -> large vmem path.
    void* p = ar.alloc(100000);
    if (p == nullptr) return false;
    if (ar.usedBytes() != 100000) return false;

    i32* arr = (i32*)p;
    arr[0] = 111; arr[1] = 222; arr[2] = 333;
    if (arr[0] != 111) return false;
    if (arr[1] != 222) return false;
    if (arr[2] != 333) return false;

    ar.dealloc(p);
    if (ar.usedBytes() != 0) return false;

    return true;
}

bool testArenaManyChunks()
{
    ArenaAllocator ar;

    // Allocate enough 512-byte blocks to span many 64 KB chunks, then free
    // them all - exercises the chunk hashset add/remove and whole-chunk recycle
    // back to g_page_pool.
    int N = 2000;
    list<i64> ptrs;

    int i = 0;
    while (i < N)
    {
        void* p = ar.alloc(512);
        if (p == nullptr) return false;
        ptrs.add((i64)p);
        i = i + 1;
    }
    // 512 + 8 = 520 bytes per block.
    if (ar.usedBytes() != (i64)N * 520) return false;

    i = 0;
    while (i < N)
    {
        ar.dealloc((void*)ptrs.get(i));
        i = i + 1;
    }
    if (ar.usedBytes() != 0) return false;

    return true;
}

bool testArenaEdgeCases()
{
    ArenaAllocator ar;

    void* p = ar.alloc(0);
    if (p != nullptr) return false;

    ar.dealloc(nullptr);  // must not crash
    return true;
}

bool testArenaPrintUsage()
{
    ArenaAllocator ar;
    ar.alloc(8);
    ar.alloc(1024);
    ar.alloc(100000);
    ar.printUsage();
    return true;
}

// =============================================================
// PagePool tests
// =============================================================

bool testPagePoolAcquireZeroed()
{
    void* p = g_page_pool.acquire();
    if (p == nullptr) return false;

    i8* bytes = (i8*)p;
    int i = 0;
    while (i < 65536)
    {
        if (bytes[i] != 0) { g_page_pool.release(p); return false; }
        i = i + 1;
    }
    g_page_pool.release(p);
    return true;
}

bool testPagePoolRecycle()
{
    g_page_pool.cleanup();

    void* a = g_page_pool.acquire();
    if (a == nullptr) return false;

    i8* bytes = (i8*)a;
    bytes[100] = (i8)42;

    g_page_pool.release(a);

    void* b = g_page_pool.acquire();
    if (b != a) return false;

    i8* bytesB = (i8*)b;
    if (bytesB[100] != 0) return false;

    g_page_pool.release(b);
    return true;
}

bool testPagePoolSoftCap()
{
    g_page_pool.cleanup();

    int total = 270;
    list<i64> arr;   // store page addresses as i64 (list<void*> not yet supported)

    int i = 0;
    while (i < total)
    {
        void* p = g_page_pool.acquire();
        if (p == nullptr) return false;
        arr.add((i64)p);
        i = i + 1;
    }

    i = 0;
    while (i < total)
    {
        g_page_pool.release((void*)arr.get(i));
        i = i + 1;
    }

    if (g_page_pool.cachedPages() > 256) return false;

    g_page_pool.cleanup();
    if (g_page_pool.cachedPages() != 0) return false;

    return true;
}

// =============================================================
// arena_channel tests
// =============================================================

class ChannelPayload : IMessage
{
    int   _value = 0;
    int*  _data  = nullptr;
    int   _count = 0;
};

class ProgramPayload : IMessage
{
    int _value = 0;
};

arena_channel<IMessage> g_ac_chan = default;
int g_chan_errors = 0;

int producer(void* unused)
{
    int i = 0;
    while (i < 1000)
    {
        page_arena<IMessage>* pa = g_ac_chan.acquire_arena();

        ChannelPayload* msg = (ChannelPayload*)pa->alloc(sizeof(ChannelPayload));
        msg->_value     = i;
        msg->_count     = 10;
        msg->_data      = (int*)pa->alloc(10 * sizeof(int));
        pa->_root       = msg;

        int j = 0;
        while (j < 10)
        {
            msg->_data[j] = i * 10 + j;
            j = j + 1;
        }

        g_ac_chan.send(pa);
        i = i + 1;
    }
    g_ac_chan.send(nullptr);
    return 0;
}

int consumer(void* unused)
{
    while (true)
    {
        page_arena<IMessage>* pa = g_ac_chan.recv();
        if (pa == nullptr) break;

        IMessage root = pa->_root;
        ChannelPayload* msg = root as ChannelPayload;

        int j = 0;
        while (j < msg->_count)
        {
            int expected = msg->_value * 10 + j;
            if (msg->_data[j] != expected)
            {
                printf("ERROR: arena %lld msg[%d][%d]: expected %d got %d\n",
                    pa->_id, msg->_value, j, expected, msg->_data[j]);
                g_chan_errors = g_chan_errors + 1;
            }
            j = j + 1;
        }

        g_ac_chan.release_arena(pa);
    }
    return 0;
}

bool testArenaChannel()
{
    g_ac_chan.init(128, 65536);

    Thread prod = default;
    Thread cons = default;

    prod.start(producer, nullptr);
    cons.start(consumer, nullptr);

    prod.join();
    cons.join();

    g_ac_chan.destroy();
    return g_chan_errors == 0;
}

arena_channel<IMessage> g_ac_prog = default;

program ArenaConsumerGlobal
{
    int total = 0;

    int main(move list<string> args)
    {
        while (true)
        {
            page_arena<IMessage>* pa = g_ac_prog.recv();
            if (pa == nullptr) break;

            IMessage root = pa->_root;
            ProgramPayload* msg = root as ProgramPayload;
            total = total + msg->_value;
            g_ac_prog.release_arena(pa);
        }
        return total;
    }
};

bool testArenaProgram()
{
    g_ac_prog.init(128, 65536);

    ArenaConsumerGlobal w;
    list<string> args;
    w.run(args);

    int i = 0;
    while (i < 100)
    {
        page_arena<IMessage>* pa = g_ac_prog.acquire_arena();

        ProgramPayload* msg = (ProgramPayload*)pa->alloc(sizeof(ProgramPayload));
        msg->_value = i + 1;
        pa->_root   = msg;

        g_ac_prog.send(pa);
        i = i + 1;
    }
    g_ac_prog.send(nullptr);

    w.WaitForExit();
    g_ac_prog.destroy();

    return w.exitCode == 5050;
}

program ArenaConsumerField
{
    arena_channel<IMessage> ac = default;
    int total = 0;

    int main(move list<string> args)
    {
        while (true)
        {
            page_arena<IMessage>* pa = ac.recv();
            if (pa == nullptr) break;

            IMessage root = pa->_root;
            ProgramPayload* msg = root as ProgramPayload;
            total = total + msg->_value;
            ac.release_arena(pa);
        }
        return total;
    }
};

bool testArenaProgramField()
{
    ArenaConsumerField w;
    w.ac.init(128, 65536);

    list<string> args;
    w.run(args);

    int i = 0;
    while (i < 100)
    {
        page_arena<IMessage>* pa = w.ac.acquire_arena();

        ProgramPayload* msg = (ProgramPayload*)pa->alloc(sizeof(ProgramPayload));
        msg->_value = i + 1;
        pa->_root   = msg;

        w.ac.send(pa);
        i = i + 1;
    }
    w.ac.send(nullptr);

    w.WaitForExit();
    w.ac.destroy();

    return w.exitCode == 5050;
}

extern int main()
{
    int passed = 0;
    int total  = 0;
    total++; passed += testArena()                        ? 1 : 0;
    total++; passed += testBlockAllocator()               ? 1 : 0;
    total++; passed += testEntryAllocatorBasic()          ? 1 : 0;
    total++; passed += testEntryAllocatorWriteRead()      ? 1 : 0;
    total++; passed += testEntryAllocatorLargeAlloc()     ? 1 : 0;
    total++; passed += testEntryAllocatorEntryTableFull() ? 1 : 0;
    total++; passed += testEntryAllocatorGarbageCollect() ? 1 : 0;
    total++; passed += testEntryAllocatorPeakReserve()    ? 1 : 0;
    total++; passed += testEntryAllocatorPrintUsage()     ? 1 : 0;
    total++; passed += testFitBasic()                     ? 1 : 0;
    total++; passed += testFitWriteRead()                 ? 1 : 0;
    total++; passed += testFitMixedSizes()                ? 1 : 0;
    total++; passed += testFitCoalescing()                ? 1 : 0;
    total++; passed += testFitSegmentGrowth()             ? 1 : 0;
    total++; passed += testFitLargeAlloc()                ? 1 : 0;
    total++; passed += testFitEdgeCases()                 ? 1 : 0;
    total++; passed += testFitPrintUsage()                ? 1 : 0;
    total++; passed += testBucketBasic()                  ? 1 : 0;
    total++; passed += testBucketSizeClasses()            ? 1 : 0;
    total++; passed += testBucketLargeAlloc()             ? 1 : 0;
    total++; passed += testBucketMultipleLargeAllocs()    ? 1 : 0;
    total++; passed += testBucketPageCommit()             ? 1 : 0;
    total++; passed += testBucketWriteRead()              ? 1 : 0;
    total++; passed += testBucketEdgeCases()              ? 1 : 0;
    total++; passed += testBucketPrintUsage()             ? 1 : 0;
    total++; passed += testArenaBasic()                   ? 1 : 0;
    total++; passed += testArenaMixedSizes()              ? 1 : 0;
    total++; passed += testArenaWriteRead()               ? 1 : 0;
    total++; passed += testArenaLargeAlloc()              ? 1 : 0;
    total++; passed += testArenaManyChunks()              ? 1 : 0;
    total++; passed += testArenaEdgeCases()               ? 1 : 0;
    total++; passed += testArenaPrintUsage()              ? 1 : 0;
    total++; passed += testPagePoolAcquireZeroed()        ? 1 : 0;
    total++; passed += testPagePoolRecycle()              ? 1 : 0;
    total++; passed += testPagePoolSoftCap()              ? 1 : 0;
    total++; passed += testArenaChannel()                 ? 1 : 0;
    total++; passed += testArenaProgram()                 ? 1 : 0;
    total++; passed += testArenaProgramField()            ? 1 : 0;
    printf("%d/%d tests passed.\n", passed, total);
    return passed == total ? 0 : 1;
}
