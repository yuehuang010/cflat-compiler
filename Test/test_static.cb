
extern bool printOnPass;

int Test(const char* name, int actual, int expected)
{
    if (actual == expected) { if (printOnPass) printf("%s passed.\n", name); return 1; }
    printf("%s MISMATCH (expected %d got %d).\n", name, expected, actual);
    return 0;
}

// ── Basic static method on a struct ──────────────────────────────────────────

struct MathUtils
{
    static int add(int a, int b) { return a + b; }
    static int mul(int a, int b) { return a * b; }
    static int square(int x)     { return x * x; }
};

int testStaticOnStruct()
{
    int passed = 0;
    passed += Test("MathUtils.add",    MathUtils.add(3, 4),  7);
    passed += Test("MathUtils.mul",    MathUtils.mul(3, 4),  12);
    passed += Test("MathUtils.square", MathUtils.square(5),  25);
    return passed;
}

// ── Static method on a class ─────────────────────────────────────────────────

class Counter
{
    int _count = 0;

    static int zero()       { return 0; }
    static int maxValue()   { return 2147483647; }

    void increment()        { _count = _count + 1; }
    int  value()            { return _count; }
};

int testStaticOnClass()
{
    int passed = 0;
    passed += Test("Counter.zero",     Counter.zero(),     0);
    passed += Test("Counter.maxValue", Counter.maxValue(), 2147483647);

    // Instance methods still work alongside static
    Counter c = Counter();
    c.increment();
    c.increment();
    passed += Test("Counter.value",    c.value(), 2);
    return passed;
}

// ── Static factory-style method ───────────────────────────────────────────────

struct Point
{
    int x = 0;
    int y = 0;

    static int origin_x() { return 0; }
    static int origin_y() { return 0; }
};

int testStaticFactory()
{
    int passed = 0;
    passed += Test("Point.origin_x", Point.origin_x(), 0);
    passed += Test("Point.origin_y", Point.origin_y(), 0);
    return passed;
}

// ── main ─────────────────────────────────────────────────────────────────────

extern int main()
{
    int passed = 0;
    int total  = 0;

    passed += testStaticOnStruct();  total += 3;
    passed += testStaticOnClass();   total += 3;
    passed += testStaticFactory();   total += 2;

    printf("\n%d / %d tests passed.\n", passed, total);
    return passed == total ? 0 : 1;
}
