void testForNDynamic_pool_autoChunk() {
    i64 n = 20000;
    double[] y = new double[n];
    ThreadPool pool;
    pool.init(4);
    parallel_for_n_dynamic_pool(&pool, n, 0, 0, (i64 lo, i64 hi) => {   // chunk<=0 -> auto
