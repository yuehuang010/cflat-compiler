import "test_helper.cb";
import "hpc/parallel.cb";

// Exercises core/hpc/parallel.cb: parallel_for_n (map) and parallel_reduce<T>
// (reduction), each on both the raw-thread and the ThreadPool backend. Bodies
// are CAPTURING lambdas - they reach their buffers/scalars directly, with no
// context struct and no void* cast.

int g_pass = 0;
int g_total = 0;

void check(const char* name, bool cond) {
    g_total = g_total + 1;
    g_pass = g_pass + Test(name, cond, true);
}

bool approx(double a, double b) {
    double d = a - b;
    if (d < 0.0) { d = -d; }
    return d < 0.000001;
}

// ---- parallel_for_n: axpy y[i] = y[i] + alpha*x[i] ------------------------

void fillAxpy(double[] x, double[] y, i64 n) {
    i64 i = 0;
    while (i < n) { x[i] = (double)i; y[i] = 2.0 * (double)i; i = i + 1; }
}

bool checkAxpy(double[] y, i64 n) {
    // y started at 2i, alpha=3, x=i -> expect 5i.
    i64 i = 0;
    while (i < n) {
        if (!approx(y[i], 5.0 * (double)i)) { return false; }
        i = i + 1;
    }
    return true;
}

void testForN_thread() {
    i64 n = 100000;
    double[] x = new double[n];
    double[] y = new double[n];
    fillAxpy(x, y, n);

    double alpha = 3.0;
    parallel_for_n(n, 4, (i64 lo, i64 hi) => {
        i64 i = lo;
        while (i < hi) { y[i] = y[i] + alpha * x[i]; i = i + 1; }   // x, y, alpha captured
    });

    check("parallel_for_n thread axpy", checkAxpy(y, n));
    delete[_] x;
    delete[_] y;
}

void testForN_pool() {
    i64 n = 100000;
    double[] x = new double[n];
    double[] y = new double[n];
    fillAxpy(x, y, n);

    ThreadPool pool;
    pool.init(4);

    double alpha = 3.0;
    parallel_for_n_pool(&pool, n, 0, (i64 lo, i64 hi) => {
        i64 i = lo;
        while (i < hi) { y[i] = y[i] + alpha * x[i]; i = i + 1; }
    });

    pool.shutdown();
    check("parallel_for_n pool axpy", checkAxpy(y, n));
    delete[_] x;
    delete[_] y;
}

// ---- reduction combine functions (associative, no capture) ----------------
// The per-chunk `partial` captures its buffers, so it is built as a typed local
// lambda at each call site (an inline value-returning lambda passed directly as
// an argument does not pick up its return type). `combine` needs no capture, so
// it stays a plain named function.

double addDouble(double a, double b) { return a + b; }
i64    addI64(i64 a, i64 b)          { return a + b; }

// ---- parallel_reduce: dot product (double) --------------------------------

void testReduce_thread_dot() {
    i64 n = 100000;
    double[] x = new double[n];
    double[] y = new double[n];
    i64 i = 0;
    while (i < n) { x[i] = 1.0; y[i] = 2.0; i = i + 1; }   // dot = 2*n

    Lambda<double(i64, i64)> partial = (i64 lo, i64 hi) => {
        double s = 0.0;
        i64 j = lo;
        while (j < hi) { s = s + x[j] * y[j]; j = j + 1; }   // x, y captured
        return s;
    };
    double dot = parallel_reduce<double>(n, 4, 0.0, partial, addDouble);

    check("parallel_reduce thread dot", approx(dot, 2.0 * (double)n));
    delete[_] x;
    delete[_] y;
}

void testReduce_pool_dot() {
    i64 n = 100000;
    double[] x = new double[n];
    double[] y = new double[n];
    i64 i = 0;
    while (i < n) { x[i] = 1.0; y[i] = 2.0; i = i + 1; }

    ThreadPool pool;
    pool.init(4);

    Lambda<double(i64, i64)> partial = (i64 lo, i64 hi) => {
        double s = 0.0;
        i64 j = lo;
        while (j < hi) { s = s + x[j] * y[j]; j = j + 1; }
        return s;
    };
    double dot = parallel_reduce_pool<double>(&pool, n, 0, 0.0, partial, addDouble);

    pool.shutdown();
    check("parallel_reduce pool dot", approx(dot, 2.0 * (double)n));
    delete[_] x;
    delete[_] y;
}

// ---- parallel_reduce: integer sum (generic over i64) ----------------------

void testReduce_thread_sum() {
    i64 n = 100000;
    i64[] v = new i64[n];
    i64 i = 0;
    while (i < n) { v[i] = i; i = i + 1; }   // sum 0..n-1 = n*(n-1)/2

    Lambda<i64(i64, i64)> partial = (i64 lo, i64 hi) => {
        i64 s = 0;
        i64 j = lo;
        while (j < hi) { s = s + v[j]; j = j + 1; }   // v captured
        return s;
    };
    i64 sum = parallel_reduce<i64>(n, 8, (i64)0, partial, addI64);

    i64 expect = n * (n - 1) / 2;
    check("parallel_reduce thread i64 sum", sum == expect);
    delete[_] v;
}

// ---- I2 regression: by-reference struct capture + overloaded operator -----
// A named struct local captured by reference inside a parallel_for_n lambda,
// used with an overloaded operator (vec3 * double), used to emit `fmul ptr,
// double` (the captured reference was treated as the struct value) and fail
// module verification. The operator must now lower the same as on an ordinary
// struct local. We assert the parallel result is byte-identical to a serial
// computation of the same expression.

struct vec3
{
    double x = 0.0;
    double y = 0.0;
    double z = 0.0;
    vec3 operator*(double s) { vec3 r; r.x = x * s; r.y = y * s; r.z = z * s; return r; }
    vec3 operator+(vec3 o)   { vec3 r; r.x = x + o.x; r.y = y + o.y; r.z = z + o.z; return r; }
};

void testForN_capturedStructOperator() {
    i64 n = 1000;
    vec3 base = default;
    base.x = 1.5; base.y = -2.0; base.z = 0.25;
    vec3 bias = default;
    bias.x = 0.1; bias.y = 0.2; bias.z = 0.3;

    double[] par = new double[n];
    double[] ser = new double[n];

    // Serial reference.
    i64 i = 0;
    while (i < n) {
        vec3 v = base * (double)i + bias;   // overloaded * and + on captured structs
        ser[i] = v.x + v.y + v.z;
        i = i + 1;
    }

    // Parallel: base and bias are named struct locals -> captured by reference.
    parallel_for_n(n, 4, (i64 lo, i64 hi) => {
        i64 j = lo;
        while (j < hi) {
            vec3 v = base * (double)j + bias;
            par[j] = v.x + v.y + v.z;
            j = j + 1;
        }
    });

    bool same = true;
    i = 0;
    while (i < n) {
        if (!approx(par[i], ser[i])) { same = false; }
        i = i + 1;
    }
    check("parallel_for_n captured-struct overloaded operator == serial", same);
    delete[_] par;
    delete[_] ser;
}

// ---- edge: more workers than elements -------------------------------------

void testReduce_moreWorkersThanN() {
    i64 n = 3;
    i64[] v = new i64[n];
    v[0] = 10; v[1] = 20; v[2] = 30;

    Lambda<i64(i64, i64)> partial = (i64 lo, i64 hi) => {
        i64 s = 0;
        i64 j = lo;
        while (j < hi) { s = s + v[j]; j = j + 1; }
        return s;
    };
    i64 sum = parallel_reduce<i64>(n, 16, (i64)0, partial, addI64);

    check("parallel_reduce workers>n", sum == 60);
    delete[_] v;
}

// ---- parallel_for_n_dynamic / parallel_for_n_dynamic_pool ------------------
// Same axpy-style body shape as parallel_for_n, but every case below also
// checks the dynamic chunk-dispenser's edge behavior (uneven division, chunk
// bigger than n, n==0, more workers than n, auto chunk sizing) plus a
// triangular-cost body to prove the result is race-free / element-exact
// against serial even though chunk boundaries land on different workers than
// the static split would produce.

double fillFunc(i64 i) {
    return (double)(i * i) - 3.0 * (double)i + 1.0;
}

void fillSerialDyn(double[] y, i64 n) {
    i64 i = 0;
    while (i < n) { y[i] = fillFunc(i); i = i + 1; }
}

bool checkFillDyn(double[] y, i64 n) {
    i64 i = 0;
    while (i < n) {
        if (!approx(y[i], fillFunc(i))) { return false; }
        i = i + 1;
    }
    return true;
}

void testForNDynamic_thread_notDivisible() {
    i64 n = 1003;   // not divisible by chunk=16
    double[] y = new double[n];
    parallel_for_n_dynamic(n, 4, 16, (i64 lo, i64 hi) => {
        i64 i = lo;
        while (i < hi) { y[i] = fillFunc(i); i = i + 1; }
    });
    check("parallel_for_n_dynamic thread: n not divisible by chunk", checkFillDyn(y, n));
    delete[_] y;
}

void testForNDynamic_thread_chunkBiggerThanN() {
    i64 n = 50;
    double[] y = new double[n];
    parallel_for_n_dynamic(n, 4, 10000, (i64 lo, i64 hi) => {
        i64 i = lo;
        while (i < hi) { y[i] = fillFunc(i); i = i + 1; }
    });
    check("parallel_for_n_dynamic thread: chunk > n", checkFillDyn(y, n));
    delete[_] y;
}

void testForNDynamic_thread_zeroN() {
    i64 n = 5;
    double[] y = new double[n];
    y[0] = 42.0;   // sentinel: must survive an n==0 call untouched
    parallel_for_n_dynamic(0, 4, 8, (i64 lo, i64 hi) => {
        y[0] = -1.0;   // must never run
    });
    check("parallel_for_n_dynamic thread: n==0 is a no-op", approx(y[0], 42.0));
    delete[_] y;
}

void testForNDynamic_thread_moreWorkersThanN() {
    i64 n = 3;
    double[] y = new double[n];
    parallel_for_n_dynamic(n, 16, 1, (i64 lo, i64 hi) => {
        i64 i = lo;
        while (i < hi) { y[i] = fillFunc(i); i = i + 1; }
    });
    check("parallel_for_n_dynamic thread: workers > n", checkFillDyn(y, n));
    delete[_] y;
}

void testForNDynamic_thread_autoChunk() {
    i64 n = 20000;
    double[] y = new double[n];
    parallel_for_n_dynamic(n, 4, 0, (i64 lo, i64 hi) => {   // chunk<=0 -> auto
        i64 i = lo;
        while (i < hi) { y[i] = fillFunc(i); i = i + 1; }
    });
    check("parallel_for_n_dynamic thread: auto chunk", checkFillDyn(y, n));
    delete[_] y;
}

// Triangular-cost body: index k costs ~(n-k) inner iterations. Kept small
// (n in the low thousands) so this correctness test stays fast - timing
// comparisons live in performance/hpc/pfor_dynamic_bench.cb, not here.
void triangularFill(double[] out, i64 lo, i64 hi, i64 n) {
    i64 k = lo;
    while (k < hi) {
        double s = 0.0;
        i64 cost = n - k;
        i64 t = 0;
        while (t < cost) { s = s + 1.0; t = t + 1; }
        out[k] = s;
        k = k + 1;
    }
}

void testForNDynamic_thread_triangularSkew() {
    i64 n = 2000;
    double[] ser = new double[n];
    double[] par = new double[n];
    triangularFill(ser, 0, n, n);

    parallel_for_n_dynamic(n, 4, 0, (i64 lo, i64 hi) => {
        triangularFill(par, lo, hi, n);
    });

    bool same = true;
    i64 i = 0;
    while (i < n) {
        if (!approx(par[i], ser[i])) { same = false; }
        i = i + 1;
    }
    check("parallel_for_n_dynamic thread: triangular skew == serial", same);
    delete[_] ser;
    delete[_] par;
}

void testForNDynamic_pool_notDivisible() {
    i64 n = 1003;
    double[] y = new double[n];
    ThreadPool pool;
    pool.init(4);
    parallel_for_n_dynamic_pool(&pool, n, 0, 16, (i64 lo, i64 hi) => {
        i64 i = lo;
        while (i < hi) { y[i] = fillFunc(i); i = i + 1; }
    });
    pool.shutdown();
    check("parallel_for_n_dynamic pool: n not divisible by chunk", checkFillDyn(y, n));
    delete[_] y;
}

void testForNDynamic_pool_chunkBiggerThanN() {
    i64 n = 50;
    double[] y = new double[n];
    ThreadPool pool;
    pool.init(4);
    parallel_for_n_dynamic_pool(&pool, n, 0, 10000, (i64 lo, i64 hi) => {
        i64 i = lo;
        while (i < hi) { y[i] = fillFunc(i); i = i + 1; }
    });
    pool.shutdown();
    check("parallel_for_n_dynamic pool: chunk > n", checkFillDyn(y, n));
    delete[_] y;
}

void testForNDynamic_pool_zeroN() {
    i64 n = 5;
