void testForNDynamic_pool_triangularSkew() {
    i64 n = 2000;
    double[] ser = new double[n];
    double[] par = new double[n];
    triangularFill(ser, 0, n, n);

    ThreadPool pool;
    pool.init(4);
    parallel_for_n_dynamic_pool(&pool, n, 0, 0, (i64 lo, i64 hi) => {
        triangularFill(par, lo, hi, n);
    });
    pool.shutdown();

    bool same = true;
    i64 i = 0;
    while (i < n) {
        if (!approx(par[i], ser[i])) { same = false; }
        i = i + 1;
    }
    check("parallel_for_n_dynamic pool: triangular skew == serial", same);
    delete[_] ser;
    delete[_] par;
}

// ---- parallel_reduce_dynamic / parallel_reduce_dynamic_pool ----------------
// Same chunk-pulling scheduler as parallel_for_n_dynamic, but each worker
// folds every chunk it pulls into ONE local accumulator via combine, then
// writes that accumulator to its slot once at exhaustion (see doc/HPC.md).
// Integer sum is the exact-match workload here: integer addition is
// associative AND commutative exactly (no rounding), so the total is
// order-independent no matter which chunks land on which worker's
// accumulator - unlike floating point, whose run-to-run reproducibility
// caveat gets its own tolerance-based test further below.

void fillSumV(i64[] v, i64 n) {
    i64 i = 0;
    while (i < n) { v[i] = i; i = i + 1; }
}

i64 sumExpect(i64 n) { return n * (n - 1) / 2; }

void testReduceDynamic_thread_notDivisible() {
    i64 n = 1003;   // not divisible by chunk=16
    i64[] v = new i64[n];
    fillSumV(v, n);
    Lambda<i64(i64, i64)> partial = (i64 lo, i64 hi) => {
        i64 s = 0;
        i64 j = lo;
        while (j < hi) { s = s + v[j]; j = j + 1; }   // v captured
        return s;
    };
    i64 sum = parallel_reduce_dynamic<i64>(n, 4, 16, (i64)0, partial, addI64);
    check("parallel_reduce_dynamic thread: n not divisible by chunk", sum == sumExpect(n));
    delete[_] v;
}

void testReduceDynamic_thread_chunkBiggerThanN() {
    i64 n = 50;
    i64[] v = new i64[n];
    fillSumV(v, n);
    Lambda<i64(i64, i64)> partial = (i64 lo, i64 hi) => {
        i64 s = 0;
        i64 j = lo;
        while (j < hi) { s = s + v[j]; j = j + 1; }
        return s;
    };
    i64 sum = parallel_reduce_dynamic<i64>(n, 4, 10000, (i64)0, partial, addI64);
    check("parallel_reduce_dynamic thread: chunk > n", sum == sumExpect(n));
    delete[_] v;
}

void testReduceDynamic_thread_zeroN() {
    Lambda<i64(i64, i64)> partial = (i64 lo, i64 hi) => {
        return (i64)999;   // must never run
    };
    i64 result = parallel_reduce_dynamic<i64>(0, 4, 8, (i64)42, partial, addI64);
    check("parallel_reduce_dynamic thread: n==0 returns identity", result == 42);
}

void testReduceDynamic_thread_moreWorkersThanN() {
    i64 n = 3;
