import "test_helper.cb";
import "array.cb";

int g_dtor_count = 0;

struct Tracked
{
    int _val = 0;

    ~Tracked()
    {
        g_dtor_count++;
    }
};

extern int main()
{
    int result = 1;

    // ---- delete[n] destructor invocation ----

    g_dtor_count = 0;
    Tracked* arr = new Tracked[5];
    delete[5] arr;
    result &= Test("delete[5] 5 elements", g_dtor_count, 5);

    g_dtor_count = 0;
    Tracked* one = new Tracked[1];
    delete[1] one;
    result &= Test("delete[1] 1 element", g_dtor_count, 1);

    g_dtor_count = 0;
    Tracked* zero = new Tracked[0];
    delete[_] zero;
    result &= Test("delete[_] 0 elements", g_dtor_count, 0);

    // Primitive array — no cookie, no destructor (must not crash)
    int* ints = new int[10];
    ints[0] = 42;
    delete[] ints;

    // ---- array<int> ----

    array<int> ai;
    ai.init(4);
    ai.set(0, 10);
    ai.set(1, 20);
    ai.set(2, 30);
    ai.set(3, 40);
    result &= Test("array<int> count", ai.count(), 4);
    result &= Test("array<int> get(0)", ai.get(0), 10);
    result &= Test("array<int> get(3)", ai.get(3), 40);
    result &= Test("array<int> [1]", ai[1], 20);
    result &= Test("array<int> [2]", ai[2], 30);

    // ---- array<Tracked>: destructor fires on scope exit ----

    g_dtor_count = 0;
    {
        array<Tracked> at;
        at.init(3);
    }
    result &= Test("array<Tracked> dtor count", g_dtor_count, 3);

    // ---- foreach over array<int> ----

    array<int> af;
    af.init(5);
    af.set(0, 1);
    af.set(1, 2);
    af.set(2, 3);
    af.set(3, 4);
    af.set(4, 5);

    int sum = 0;
    for (int v in af)
        sum += v;
    result &= Test("foreach sum", sum, 15);

    int fcount = 0;
    for (int v in af)
        fcount++;
    result &= Test("foreach count", fcount, 5);

    // ---- heap-allocated array<int> ----

    array<int>* ha = new array<int>;
    ha->init(3);
    ha->set(0, 100);
    ha->set(1, 200);
    ha->set(2, 300);
    result &= Test("heap array count", ha->count(), 3);
    result &= Test("heap array get(1)", ha->get(1), 200);
    delete ha;

    // ---- array<Tracked>: destructor fires when heap array is deleted ----

    g_dtor_count = 0;
    {
        array<Tracked>* ht = new array<Tracked>;
        ht->init(4);
        delete ht;
    }
    result &= Test("heap array<Tracked> dtor count", g_dtor_count, 4);

    if (result) { printf("test_array: PASS\n"); return 0; }
    return 1;
}
