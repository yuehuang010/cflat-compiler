// Verifies that C function signatures are auto-extracted from the imported .c via
// clang's AST dump, so no hand-written 'extern' declarations are needed. The same
// cinterop.c is reused; its definitions are compiled by clang and linked by lld.
import "library/cinterop.c";

extern int main()
{
    if (c_add(40, 2) != 42) return 1;
    if (c_square(7) != 49) return 2;
    return 0;
}
