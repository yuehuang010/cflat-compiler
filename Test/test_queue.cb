// Test queue data structure
import "queue.cb";

extern int main()
{
    queue<i32> q;

    // Test empty check
    if (!q.isEmpty()) return 1;

    // Enqueue values
    q.enqueue(10);
    q.enqueue(20);
    q.enqueue(30);

    if (q.count() != 3) return 1;
    if (!(!q.isEmpty())) return 1;

    // Peek front
    if (q.peek() != 10) return 1;

    // Dequeue should be FIFO
    if (q.dequeue() != 10) return 1;
    if (q.dequeue() != 20) return 1;
    if (q.dequeue() != 30) return 1;

    if (!q.isEmpty()) return 1;

    return 0;
}
