// Test math utilities
import "math.cb";

extern int main()
{
    i32 a = 5;
    i32 b = 3;
    i32 c = 7;

    // Test that basic comparisons work
    printf("Testing a < b: 5 < 3\n");
    if (a < b) { printf("FAIL: 5 < 3\n"); return 1; }
    printf("Testing !(b < c): !(3 < 7)\n");
    if (!(b < c)) { printf("FAIL: !(3 < 7)\n"); return 1; }

    // Test min/max
    printf("Testing min(3, 7) = 3\n");
    i32 minRes = Math.min(b, c);
    printf("min result: %d\n", minRes);
    if (minRes != b) { printf("FAIL: min(3, 7) != 3\n"); return 1; }

    printf("Testing max(3, 7) = 7\n");
    i32 maxRes = Math.max(b, c);
    printf("max result: %d\n", maxRes);
    if (maxRes != c) { printf("FAIL: max(3, 7) != 7\n"); return 1; }

    printf("All math tests passed!\n");
    return 0;
}
