import "test_helper.cb";
import "math.cb";

extern int main()
{
    int passed = 0;
    int total = 0;
    i32 a = 5;
    i32 b = 3;
    i32 c = 7;

    total++; passed += Test("a_not_less_than_b", a < b, false);
    total++; passed += Test("b_less_than_c",     b < c, true);
    total++; passed += Test("min(3,7)=3",        Math.min(b, c), (i32)b);
    total++; passed += Test("max(3,7)=7",        Math.max(b, c), (i32)c);

    printf("\n%d / %d tests passed.\n", passed, total);
    return passed == total ? 0 : 1;
}
