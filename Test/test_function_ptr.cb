import "test_helper.cb";
import "list.cb";
import "string.cb";

// ── Named functions used throughout ──────────────────────────────────────────

int add(int a, int b)     { return a + b; }
int sub(int a, int b)     { return a - b; }
int mul(int a, int b)     { return a * b; }
int doubleIt(int x)       { return x * 2; }
int square(int x)         { return x * x; }
int negate(int x)         { return -x; }
int clamp100(int x)       { return x > 100 ? 100 : (x < 0 ? 0 : x); }
bool isEven(int x)        { return x % 2 == 0; }
void doNothing()          { }

// ── Higher-order named helpers ────────────────────────────────────────────────

int apply(function<int(int, int)> f, int a, int b) { return f(a, b); }
int transform(function<int(int)> f, int x)         { return f(x); }
bool applyPred(function<bool(int)> f, int x)       { return f(x); }
void callVoid(function<void()> f)                   { f(); }

// Reduce: fold an array with a binary function
int reduce(function<int(int, int)> f, int* arr, int len, int init)
{
    int acc = init;
    for (int i = 0; i < len; i++)
        acc = f(acc, arr[i]);
    return acc;
}

// Map-and-sum: apply unary f to each element then sum
int mapSum(function<int(int)> f, int* arr, int len)
{
    int total = 0;
    for (int i = 0; i < len; i++)
        total = total + f(arr[i]);
    return total;
}

// Apply f n times to x
int applyN(function<int(int)> f, int x, int n)
{
    int v = x;
    for (int i = 0; i < n; i++)
        v = f(v);
    return v;
}

// Count elements satisfying predicate
int countIf(function<bool(int)> pred, int* arr, int len)
{
    int count = 0;
    for (int i = 0; i < len; i++)
        if (pred(arr[i])) count++;
    return count;
}

// ─────────────────────────────────────────────────────────────────────────────
// FUNCTION POINTER TESTS
// ─────────────────────────────────────────────────────────────────────────────

bool testExplicitFunctionPointer()
{
    bool result = true;

    function<int(int, int)> f = add;
    result &= Test("explicit add",    f(3, 4),  7);

    f = mul;
    result &= Test("reassign to mul", f(3, 4), 12);

    f = sub;
    result &= Test("reassign to sub", f(10, 3), 7);

    function<int(int)> g = doubleIt;
    result &= Test("unary funcptr",          g(6),  12);

    g = square;
    result &= Test("unary reassign square",  g(5),  25);

    g = negate;
    result &= Test("negate funcptr", g(7), -7);

    function<bool(int)> pred = isEven;
    result &= Test("bool funcptr even", pred(4), true);
    result &= Test("bool funcptr odd",  pred(7), false);

    return result;
}

bool testBareFunctionPointer()
{
    bool result = true;

    function f = add;
    result &= Test("bare add",     f(10, 5), 15);

    function g = doubleIt;
    result &= Test("bare doubleIt", g(9),    18);

    return result;
}

bool testFunctionPointerAsArgument()
{
    bool result = true;

    result &= Test("pass add",           apply(add,     6, 7), 13);
    result &= Test("pass mul",           apply(mul,     6, 7), 42);
    result &= Test("pass sub",           apply(sub,    10, 4),  6);
    result &= Test("transform doubleIt", transform(doubleIt, 7), 14);
    result &= Test("transform square",   transform(square,   5), 25);
    result &= Test("predicate even",     applyPred(isEven, 8), true);
    result &= Test("predicate odd",      applyPred(isEven, 9), false);

    return result;
}

bool testFunctionPointerInLoop()
{
    bool result = true;

    int* vals = new int[5];
    vals[0] = 1; vals[1] = 2; vals[2] = 3; vals[3] = 4; vals[4] = 5;
    int n5 = 5; int n1 = 1; int n0 = 0; int n7 = 7;

    // reduce with add -> sum 1..5 = 15
    result &= Test("reduce add",       reduce(add, vals, n5, n0), 15);
    // reduce with mul -> product 1..5 = 120
    result &= Test("reduce mul",       reduce(mul, vals, n5, n1), 120);
    // mapSum doubleIt -> 2+4+6+8+10 = 30
    result &= Test("mapSum double",    mapSum(doubleIt, vals, n5), 30);
    // mapSum square -> 1+4+9+16+25 = 55
    result &= Test("mapSum square",    mapSum(square,   vals, n5), 55);
    // applyN doubleIt 3 times on 1 -> 1*2*2*2 = 8
    int n3 = 3;
    result &= Test("applyN 3x double", applyN(doubleIt, n1, n3), 8);
    // applyN 0 times -> identity
    result &= Test("applyN 0x",        applyN(doubleIt, n7, n0), 7);

    delete vals;
    return result;
}

bool testFunctionPointerCountIf()
{
    bool result = true;

    int* vals = new int[6];
    vals[0] = 1; vals[1] = 2; vals[2] = 3; vals[3] = 4; vals[4] = 5; vals[5] = 6;
    int n6 = 6;

    result &= Test("countIf even", countIf(isEven, vals, n6), 3);

    delete vals;
    return result;
}

bool testVoidFunctionPointer()
{
    bool result = true;

    function<void()> f = doNothing;
    callVoid(f);
    callVoid(doNothing);
    result &= Test("void funcptr", 1, 1);

    return result;
}

bool testFunctionPointerClamp()
{
    bool result = true;

    function<int(int)> f = clamp100;
    result &= Test("clamp mid",  f(50),   50);
    result &= Test("clamp high", f(200), 100);
    result &= Test("clamp low", f(-5), 0);

    return result;
}

// ─────────────────────────────────────────────────────────────────────────────
// LAMBDA TESTS
// ─────────────────────────────────────────────────────────────────────────────

bool testLambdaBasic()
{
    bool result = true;

    function<int(int, int)> addL = (int a, int b) => { return a + b; };
    result &= Test("lambda add",   addL(3, 4),  7);
    result &= Test("lambda add 0", addL(0, 0),  0);

    function<int(int, int)> mulL = (int a, int b) => { return a * b; };
    result &= Test("lambda mul",   mulL(3, 4), 12);
    result &= Test("lambda mul 7", mulL(7, 7), 49);

    function<int()> getK = () => { return 42; };
    result &= Test("zero-param lambda", getK(), 42);

    return result;
}

bool testLambdaControlFlow()
{
    bool result = true;

    // Lambda with if/else
    function<int(int, int)> maxL = (int a, int b) => {
        if (a > b) return a;
        return b;
    };
    result &= Test("lambda max(3,7)", maxL(3, 7), 7);
    result &= Test("lambda max(9,2)", maxL(9, 2), 9);
    result &= Test("lambda max(5,5)", maxL(5, 5), 5);

    // Lambda with multi-branch if/else
    function<int(int)> sign = (int x) => {
        if (x > 0) return 1;
        if (x < 0) return -1;
        return 0;
    };
    result &= Test("sign positive", sign(42),  1);
    result &= Test("sign negative", sign(-7), -1);
    result &= Test("sign zero",     sign(0),   0);

    return result;
}

bool testLambdaLocalVars()
{
    bool result = true;

    // Lambda that uses local variables in its body
    function<int(int, int)> hypoSq = (int a, int b) => {
        int aa = a * a;
        int bb = b * b;
        return aa + bb;
    };
    result &= Test("hypoSq 3,4",   hypoSq(3, 4),   25);
    result &= Test("hypoSq 5,12",  hypoSq(5, 12), 169);

    // Lambda with a loop body
    function<int(int)> sumTo = (int n) => {
        int s = 0;
        for (int i = 1; i <= n; i++)
            s = s + i;
        return s;
    };
    result &= Test("sumTo 5",  sumTo(5),   15);
    result &= Test("sumTo 10", sumTo(10),  55);

    return result;
}

bool testLambdaCallsNamedFunction()
{
    bool result = true;

    // Lambda body calling regular functions
    function<int(int)> doubleSq = (int x) => { return square(doubleIt(x)); };
    result &= Test("doubleSq 3", doubleSq(3),  36);   // square(6)=36
    result &= Test("doubleSq 5", doubleSq(5), 100);   // square(10)=100

    // isEven(square(x)): even input -> even square; odd input -> odd square
    function<bool(int)> evenSquare = (int x) => { return isEven(square(x)); };
    result &= Test("evenSquare even",  evenSquare(4), true);   // square(4)=16, even
    result &= Test("evenSquare odd",   evenSquare(3), false);  // square(3)=9, odd

    return result;
}

bool testLambdaBoolReturn()
{
    bool result = true;

    function<bool(int)> gt10  = (int x) => { return x > 10; };
    function<bool(int)> ltNeg = (int x) => { return x < 0; };

    result &= Test("gt10 true",   gt10(15),   true);
    result &= Test("gt10 false",  gt10(5),    false);
    result &= Test("ltNeg true", ltNeg(-1), true);
    result &= Test("ltNeg false", ltNeg(0), false);

    return result;
}

bool testLambdaReassignment()
{
    bool result = true;

    function<int(int)> f = (int x) => { return x + 1; };
    result &= Test("lambda f=x+1",    f(5),  6);

    // Reassign to a different lambda
    f = (int x) => { return x * 3; };
    result &= Test("lambda f=x*3",    f(5), 15);

    // Reassign to a named function
    f = doubleIt;
    result &= Test("lambda f=doubleIt", f(5), 10);

    // Reassign back to another lambda
    f = (int x) => { return x - 2; };
    result &= Test("lambda f=x-2",    f(5),  3);

    return result;
}

bool testLambdaAsArgument()
{
    bool result = true;

    result &= Test("lambda arg add",    apply((int a, int b) => { return a + b; }, 5, 6),  11);
    result &= Test("lambda arg mul",    apply((int a, int b) => { return a * b; }, 5, 6),  30);
    result &= Test("lambda arg sub",    apply((int a, int b) => { return a - b; }, 9, 4),   5);
    result &= Test("lambda unary arg",  transform((int x) => { return x + 10; }, 7),       17);
    result &= Test("lambda square arg", transform((int x) => { return x * x; }, 6),        36);
    result &= Test("lambda pred even",  applyPred((int x) => { return x % 2 == 0; }, 8), true);
    result &= Test("lambda pred odd",   applyPred((int x) => { return x % 2 == 0; }, 7), false);

    return result;
}

bool testLambdaInHigherOrder()
{
    bool result = true;

    int* vals = new int[5];
    vals[0] = 1; vals[1] = 2; vals[2] = 3; vals[3] = 4; vals[4] = 5;
    int n5 = 5; int n0 = 0; int n1 = 1; int n3 = 3; int n4 = 4;

    // reduce with lambdas
    result &= Test("reduce lambda add",  reduce((int a, int b) => { return a + b; }, vals, n5, n0), 15);
    result &= Test("reduce lambda max",  reduce((int a, int b) => { return a > b ? a : b; }, vals, n5, n0), 5);

    // mapSum with lambda
    result &= Test("mapSum +1", mapSum((int x) => { return x + 1; }, vals, n5), 20); // 2+3+4+5+6
    result &= Test("mapSum sq", mapSum((int x) => { return x * x; }, vals, n5), 55); // 1+4+9+16+25

    // applyN with lambda
    result &= Test("applyN +2 x3", applyN((int x) => { return x + 2; }, n0, n3),  6); // 0->2->4->6
    result &= Test("applyN *2 x4", applyN((int x) => { return x * 2; }, n1, n4), 16); // 1->2->4->8->16

    // countIf with lambda
    result &= Test("countIf >3", countIf((int x) => { return x > 3; }, vals, n5), 2);
    result &= Test("countIf <3", countIf((int x) => { return x < 3; }, vals, n5), 2);

    delete vals;

    return result;
}

bool testLambdaThreeParam()
{
    bool result = true;

    // Lambda with 3 parameters
    function<int(int, int, int)> fmaL = (int a, int b, int c) => { return a * b + c; };
    result &= Test("fma 2*3+4", fmaL(2, 3, 4),  10);
    result &= Test("fma 5*5+1", fmaL(5, 5, 1),  26);
    result &= Test("fma 0*9+7", fmaL(0, 9, 7),   7);

    function<int(int, int, int)> clampL = (int v, int lo, int hi) => {
        if (v < lo) return lo;
        if (v > hi) return hi;
        return v;
    };
    result &= Test("clampL mid",  clampL(5,  0, 10),  5);
    result &= Test("clampL low", clampL(-3, 0, 10), 0);
    result &= Test("clampL high", clampL(15, 0, 10), 10);

    return result;
}

bool testVoidLambda()
{
    bool result = true;

    function<void()> noopLambda = () => { };
    callVoid(noopLambda);
    callVoid(() => { doNothing(); });
    result &= Test("void lambda", 1, 1);

    return result;
}

// ─────────────────────────────────────────────────────────────────────────────
// LAMBDA CAPTURE TESTS
// ─────────────────────────────────────────────────────────────────────────────

struct Counter {
    int value = 0;
};

struct Stats {
    float min   = 0.0f;
    float max   = 0.0f;
    int   count = 0;
};

interface ITransform {
    int apply(int x);
};

class Multiplier : ITransform {
    int factor = 1;
    int apply(int x) { return x * factor; }
};

class Adder : ITransform {
    int offset = 0;
    int apply(int x) { return x + offset; }
};

bool testCapturePrimitives()
{
    bool result = true;

    // int - value copy; outer mutation does not affect captured snapshot
    {
        int x = 10;
        function<int()> getX = () => { return x; };
        result &= Test("int capture",        getX(), 10);
        x = 99;
        result &= Test("int capture stable", getX(), 10);
    }

    // float - value copy
    {
        float factor = 2.5f;
        function<float(float)> scale = (float v) => { return v * factor; };
        result &= Test("float capture",        scale(4.0f), 10.0f);
        factor = 999.0f;
        result &= Test("float capture stable", scale(4.0f), 10.0f);
    }

    // bool - value copy
    {
        bool enabled = true;
        function<bool()> check = () => { return enabled; };
        result &= Test("bool capture", check(), true);
        enabled = false;
        result &= Test("bool capture stable", check(), true);
    }

    // i64 - value copy
    {
        i64 big = 4000000000;
        function<i64()> getBig = () => { return big; };
        result &= Test("i64 capture",        getBig(), 4000000000);
        big = 0;
        result &= Test("i64 capture stable", getBig(), 4000000000);
    }

    // char* - pointer copy; both sides read the same bytes
    {
        char* msg = "hello";
        function<int()> getLen = () => { return strlen(msg); };
        result &= Test("char* capture", getLen(), 5);
    }

    // int* - pointer copy; writes through shared pointer are visible
    {
        int* p = new int;
        *p = 42;
        function<int()> read = () => { return *p; };
        result &= Test("int* initial",  read(), 42);
        *p = 77;
        result &= Test("int* mutation", read(), 77);
        delete p;
    }

    return result;
}

bool testCaptureString()
{
    bool result = true;

    // string - value copy taken at capture time; outer reassignment invisible
    {
        string label = "world";
        function<int()> getLen = () => { return label.length(); };
        result &= Test("string capture len",    getLen(), 5);
        label = "hi";
        result &= Test("string capture stable", getLen(), 5);
    }

    // string equality check inside lambda
    {
        string greeting = "hello";
        function<bool(string)> matches = (string s) => { return greeting == s; };
        result &= Test("string eq match",    matches("hello"), true);
        result &= Test("string eq no-match", matches("world"), false);
    }

    // string data() access inside lambda
    {
        string word = "abc";
        function<char*()> getPtr = () => { return word.data(); };
        char* ptr = getPtr();
        result &= Test("string data() non-null", ptr != nullptr, true);
        result &= Test("string data() len",      strlen(ptr),    3);
    }

    return result;
}

bool testCaptureStructRef()
{
    bool result = true;

    // struct (Counter) - reference capture; lambda mutations visible to caller
    {
        Counter c;
        function<void()> inc = () => { c.value = c.value + 1; };
        inc(); inc(); inc();
        result &= Test("struct ref capture", c.value, 3);
    }

    // struct (Stats) - reference capture of multi-field struct
    {
        Stats s;
        function<void(float)> observe = (float v) => {
            if (s.count == 0 || v < s.min) s.min = v;
            if (s.count == 0 || v > s.max) s.max = v;
            s.count = s.count + 1;
        };
        observe(3.0f);
        observe(1.0f);
        observe(5.0f);
        result &= Test("stats count", s.count, 3);
        result &= Test("stats min",   s.min,   1.0f);
        result &= Test("stats max",   s.max,   5.0f);
    }

    // class (Multiplier) - reference capture; caller mutations visible in lambda
    {
        Multiplier m;
        m.factor = 3;
        function<int(int)> tripleIt = (int x) => { return m.apply(x); };
        result &= Test("class ref factor=3", tripleIt(7), 21);
        m.factor = 5;
        result &= Test("class ref factor=5", tripleIt(7), 35);
    }

    // class (Adder) - reference capture with method call
    {
        Adder a;
        a.offset = 100;
        function<int(int)> add100 = (int x) => { return a.apply(x); };
        result &= Test("adder +100 5",  add100(5),  105);
        result &= Test("adder +100 -3", add100(-3),  97);
    }

    // interface - value capture (fat ptr {vtable,data} copied)
    {
        Multiplier m;
        m.factor = 4;
        ITransform t = m;
        function<int(int)> callT = (int x) => { return t.apply(x); };
        result &= Test("iface capture 6", callT(6), 24);
        result &= Test("iface capture 3", callT(3), 12);
    }

    return result;
}

bool testCaptureMultiple()
{
    bool result = true;

    // int + float + struct
    {
        int base = 10;
        float rate = 1.5f;
        Counter total;
        function<void(int)> accumulate = (int n) => {
            total.value = total.value + (int)(n * rate) + base;
        };
        accumulate(2);   // (int)(2*1.5) + 10 = 3+10 = 13
        accumulate(4);   // (int)(4*1.5) + 10 = 6+10 = 16  -> total=29
        result &= Test("multi int+float+struct", total.value, 29);
    }

    // string (value) + Counter (reference)
    {
        string prefix = "item_";
        Counter counter;
        function<int()> nextId = () => {
            counter.value = counter.value + 1;
            return prefix.length() + counter.value;
        };
        result &= Test("multi str+counter 1", nextId(), 6);
        result &= Test("multi str+counter 2", nextId(), 7);
        result &= Test("multi counter value", counter.value, 2);
    }

    // lambda passed as argument, captures struct
    {
        Counter c;
        function<int(int)> addToC = (int n) => { c.value = c.value + n; return c.value; };
        result &= Test("capture in arg 5",     transform(addToC, 5), 5);
        result &= Test("capture in arg 3",     transform(addToC, 3), 8);
        result &= Test("capture struct after",  c.value,              8);
    }

    // function<T> variable - value capture of fat struct
    {
        int base = 100;
        function<int(int)> addBase = (int x) => { return x + base; };
        function<int(int)> doubleAndAdd = (int x) => { return addBase(x * 2); };
        result &= Test("nested lambda 5", doubleAndAdd(5),  110);
        result &= Test("nested lambda 0", doubleAndAdd(0),  100);
    }

    return result;
}

bool testCaptureRegression()
{
    bool result = true;

    // Regression: lambda before list<string>->add(string) must not corrupt overload
    // resolution. lastLambdaType was not cleared after ParsePostfixExpression consumed
    // it, causing CompareUpconvert on a struct arg to return -1 (no match).
    {
        function<void(int)> cb = (int x) => { };

        list<string>* L = new list<string>;
        string s = "world";
        L->add(s);
        result &= Test("lambda before list<string> add", L->count(), 1);
        delete L;
    }

    return result;
}

// Regression: a captured local whose NAME collides with an in-scope function or
// method must still be captured - the local shadows the callable. The capture
// collector used to skip any identifier present in the function table, so a captured
// local that shared a name with a function/method was dropped, and the body then
// referenced the OUTER frame's storage across the closure boundary (LLVM verify:
// "instruction does not dominate all uses"). Surfaced by mc_pi.cb capturing `seed`
// while random.cb's Random.seed method was in scope.
bool testCaptureNameCollidesWithFunction()
{
    bool result = true;

    // 'doubleIt' is a top-level function in this file; the same-named local must
    // shadow it and be captured by value.
    int doubleIt = 21;
    function<int()> f = () => { return doubleIt + doubleIt; };
    result &= Test("capture shadows function name", f(), 42);

    // The bug only bit when a struct ctor/method call sat between the capture
    // unpack and the captured use (Random's ctor in mc_pi). Mirror that: capture a
    // local across a struct local + method-style write, with the captured name
    // colliding with a function ('square').
    int square = 5;
    Counter acc;
    acc.value = 0;
    function<void()> g = () => { acc.value = acc.value + square; };
    g();
    g();
    result &= Test("capture name collision w/ struct local", acc.value, 10);

    return result;
}

// Regression: capturing a local T arr[N] by reference must store T* in the closure
// (element pointer), not [N x T]*.  Wrong type caused GEP to stride by N*sizeof(T)
// instead of sizeof(T), so arr[1], arr[2], etc. read from garbage addresses.
bool testCaptureLocalArray()
{
    bool result = true;

    Counter[3] pts;
    pts[0].value = 10;
    pts[1].value = 20;
    pts[2].value = 30;

    // Use a Counter (struct, captured by reference) to accumulate so writes
    // from the lambda are visible to the caller.
    Counter acc;
    int i = 0;
    while (i < 3)
    {
        callVoid(() => { acc.value = acc.value + pts[i].value; });
        i++;
    }
    result &= Test("capture array sum", acc.value, 60);

    return result;
}

// Regression: closure alloca created inside a loop body must be hoisted to the
// function entry block.  Loop-body allocas grow the stack on every iteration,
// causing stack overflow (0xC00000FD) on large trip counts.
bool testLambdaAllocaInLoop()
{
    bool result = true;

    Counter c;
    int n = 5;
    for (int i = 0; i < n; i++)
    {
        int delta = i + 1;
        function<void()> inc = () => { c.value = c.value + delta; };
        inc();
    }
    // 1+2+3+4+5 = 15
    result &= Test("lambda alloca in loop", c.value, 15);

    return result;
}

// Regression: a capture-bond (lambda holding &source by address) must NOT block
// reassigning the captured source. The closure stores the alloca address, so writing
// a new value into a still-live slot is safe - the canonical double-buffer swap idiom.
// Previously rejected with "cannot reassign 'a' while 'f' holds a bonded reference to
// it". The bond's escape guard still fires for both bond kinds; only the in-frame
// reassignment block is lifted for by-address capture-bonds.
bool testCaptureBondReassign()
{
    bool result = true;

    Counter a; a.value = 1;
    Counter b; b.value = 2;

    // Build the closure ONCE, capturing both struct locals by reference.
    function<int()> f = () => { return a.value + b.value; };

    // Double-buffer swap: reassign the captured sources. Must compile without the
    // spurious bond-reassignment error; the closure observes the new slot contents.
    Counter tmp = a;
    a = b;
    b = tmp;

    // After swap a.value==2, b.value==1, so f() returns 3.
    result &= Test("capture-bond swap then call", f(), 3);

    return result;
}

// ─────────────────────────────────────────────────────────────────────────────
// GENERIC FUNCTION POINTER TESTS
// ─────────────────────────────────────────────────────────────────────────────

// Read a T through a void* and return it as int.
int readAs<T>(void* raw) {
    T* p = (T*)raw;
    return (int)*p;
}

// Write val into a T through a void*.
int writeAs<T>(void* raw) {
    T* p = (T*)raw;
    *p = (T)7;
    return 0;
}

// Return sizeof(T) - uses a type parameter in sizeof(), not in a pointer cast.
int sizeOf<T>(void* ignored) {
    return (int)sizeof(T);
}

// Multiply the value at raw by 2 in-place.
int doubleInPlace<T>(void* raw) {
    T* p = (T*)raw;
    T v = *p;
    *p = v + v;
    return 0;
}

bool testGenericFuncPtrBasic()
{
    bool result = true;

    function<int(void*)> fn = readAs<int>;
    int x = 42;
    result &= Test("generic read int", fn((void*)&x), 42);

    fn = readAs<i64>;
    i64 big = 123;
    result &= Test("generic read i64", fn((void*)&big), 123);

    return result;
}

bool testGenericFuncPtrSizeof()
{
    bool result = true;

    function<int(void*)> fn = sizeOf<int>;
    result &= Test("sizeof<int>",  fn(nullptr), 4);

    fn = sizeOf<i64>;
    result &= Test("sizeof<i64>",  fn(nullptr), 8);

    fn = sizeOf<bool>;
    result &= Test("sizeof<bool>", fn(nullptr), 1);

    return result;
}

bool testGenericFuncPtrWrite()
{
    bool result = true;

    function<int(void*)> fn = writeAs<int>;
    int x = 0;
    fn((void*)&x);
    result &= Test("generic write int", x, 7);

    return result;
}

bool testGenericFuncPtrDoubleInPlace()
{
    bool result = true;

    function<int(void*)> fn = doubleInPlace<int>;
    int v = 5;
    fn((void*)&v);
    result &= Test("doubleInPlace<int>", v, 10);

    fn = doubleInPlace<i64>;
    i64 big = 3;
    fn((void*)&big);
    result &= Test("doubleInPlace<i64>", (int)big, 6);

    return result;
}

// Pass a generic-instantiated function pointer through a regular higher-order function.
bool testGenericFuncPtrHigherOrder()
{
    bool result = true;

    function<int(void*)> fn = readAs<int>;
    int a = 99;
    result &= Test("higher order int", fn((void*)&a), 99);

    fn = readAs<i64>;
    i64 b = 77;
    result &= Test("higher order i64", fn((void*)&b), 77);

    // Switch between two unrelated generic functions via reassignment.
    fn = sizeOf<int>;
    result &= Test("switch to sizeOf<int>", fn(nullptr), 4);

    fn = readAs<int>;
    int x = 55;
    result &= Test("switch back to readAs<int>", fn((void*)&x), 55);

    return result;
}

// ─────────────────────────────────────────────────────────────────────────────
// FUNCTION POINTER IN STRUCT FIELD TESTS
// ─────────────────────────────────────────────────────────────────────────────

struct Handler {
    function<int(int)> fn = default;
};

struct VoidHandler {
    function<void()> fn = default;
};

bool testFuncPtrInStructField()
{
    bool result = true;

    Handler h;
    h.fn = doubleIt;
    result &= Test("struct field call doubleIt", h.fn(6), 12);

    h.fn = square;
    result &= Test("struct field reassign square", h.fn(5), 25);

    h.fn = (int x) => { return x + 100; };
    result &= Test("struct field lambda", h.fn(3), 103);

    return result;
}

bool testFuncPtrInStructFieldVoid()
{
    bool result = true;

    // Void function pointer stored in struct field.  Use doNothing (no capture
    // needed) to avoid the known limitation where captures through struct-field
    // closures are not yet propagated correctly.
    VoidHandler vh;
    vh.fn = doNothing;
    vh.fn();
    result &= Test("void struct field call", 1, 1);

    return result;
}

// ─────────────────────────────────────────────────────────────────────────────
// DISPATCH TABLE TESTS
// ─────────────────────────────────────────────────────────────────────────────

struct DispatchEntry {
    function<int(void*)> fn  = default;
    void*                ctx = nullptr;
};

bool testDispatchTable()
{
    bool result = true;

    int[4] vals;
    vals[0] = 1; vals[1] = 2; vals[2] = 3; vals[3] = 4;

    DispatchEntry[4] table;
    table[0].fn = readAs<int>; table[0].ctx = (void*)&vals[0];
    table[1].fn = readAs<int>; table[1].ctx = (void*)&vals[1];
    table[2].fn = readAs<int>; table[2].ctx = (void*)&vals[2];
    table[3].fn = readAs<int>; table[3].ctx = (void*)&vals[3];

    int sum = 0;
    int i = 0;
    while (i < 4) {
        sum = sum + table[i].fn(table[i].ctx);
        i++;
    }
    result &= Test("dispatch table sum", sum, 10);  // 1+2+3+4

    return result;
}

// ─────────────────────────────────────────────────────────────────────────────
// LIST SORT TESTS
// ─────────────────────────────────────────────────────────────────────────────

bool testListSortAscending()
{
    bool result = true;

    list<int> nums;
    nums.add(5); nums.add(2); nums.add(8); nums.add(1); nums.add(9); nums.add(3);
    nums.sort((int a, int b) => { return a < b; });

    result &= Test("sort[0]==1", nums.get(0), 1);
    result &= Test("sort[1]==2", nums.get(1), 2);
    result &= Test("sort[2]==3", nums.get(2), 3);
    result &= Test("sort[3]==5", nums.get(3), 5);
    result &= Test("sort[4]==8", nums.get(4), 8);
    result &= Test("sort[5]==9", nums.get(5), 9);

    return result;
}

bool testListSortDescending()
{
    bool result = true;

    list<int> nums;
    nums.add(5); nums.add(2); nums.add(8); nums.add(1); nums.add(9); nums.add(3);
    nums.sort((int a, int b) => { return a > b; });

    result &= Test("desc[0]==9", nums.get(0), 9);
    result &= Test("desc[1]==8", nums.get(1), 8);
    result &= Test("desc[2]==5", nums.get(2), 5);
    result &= Test("desc[3]==3", nums.get(3), 3);
    result &= Test("desc[4]==2", nums.get(4), 2);
    result &= Test("desc[5]==1", nums.get(5), 1);

    return result;
}

bool testListSortEdgeCases()
{
    bool result = true;

    // Single element
    list<int> one;
    one.add(42);
    one.sort((int a, int b) => { return a < b; });
    result &= Test("single elem", one.get(0), 42);

    // Already sorted
    list<int> sorted;
    sorted.add(1); sorted.add(2); sorted.add(3);
    sorted.sort((int a, int b) => { return a < b; });
    result &= Test("already sorted[0]", sorted.get(0), 1);
    result &= Test("already sorted[2]", sorted.get(2), 3);

    // Reverse sorted
    list<int> rev;
    rev.add(3); rev.add(2); rev.add(1);
    rev.sort((int a, int b) => { return a < b; });
    result &= Test("reverse sorted[0]", rev.get(0), 1);
    result &= Test("reverse sorted[2]", rev.get(2), 3);

    return result;
}

bool testListSortNamedComparator()
{
    bool result = true;

    list<int> nums;
    nums.add(7); nums.add(3); nums.add(5);

    function<bool(int, int)> asc = (int a, int b) => { return a < b; };
    nums.sort(asc);

    result &= Test("named cmp[0]", nums.get(0), 3);
    result &= Test("named cmp[1]", nums.get(1), 5);
    result &= Test("named cmp[2]", nums.get(2), 7);

    return result;
}

// ── 'move' in function pointer signatures ────────────────────────────────────
// function<R(move T*)> is a distinct type from function<R(T*)>. Calling through
// such a pointer transfers ownership of the matching argument to the callee
// (the caller's storage is auto-nulled), and the named function used to
// initialize the pointer must declare the same 'move' modifier on that param.

int g_move_fp_dtor_count = 0;
struct MovePayload {
    int value = 0;
    ~MovePayload() { g_move_fp_dtor_count = g_move_fp_dtor_count + 1; }
};

int consume_payload(move MovePayload* p) {
    int v = p->value;
    delete p;
    return v;
}

bool testFuncPtrMoveSignature()
{
    g_move_fp_dtor_count = 0;
    function<int(move MovePayload*)> fp = consume_payload;
    MovePayload* p = new MovePayload();
    p->value = 7;
    int got = fp(p);
    // Caller's pointer is auto-nulled by the funcptr's 'move' contract; scope-exit cleanup is a no-op.
    return got == 7 && g_move_fp_dtor_count == 1;
}

// ── Non-capturing lambda across the C ABI ────────────────────────────────────
// A C function pointer is a bare code address with no env slot. The closure ABI is
// env-last, so the invoker of a *non-capturing* lambda is directly callable as a
// C callback - the C caller never supplies the trailing (unused) env arg. A capturing
// lambda or a function<> variable still cannot cross the C ABI (see err_lambda_to_c_funcptr).

extern void qsort(void* base, u64 num, u64 size, function<int(void*, void*)> cmp);

bool testNonCapturingLambdaToCFuncPtr()
{
    bool result = true;

    int[5] a = {5, 2, 8, 1, 9};
    // Non-capturing comparator: references only its own parameters, captures nothing.
    qsort(&a[0], 5u, (u64)sizeof(int), (void* x, void* y) => {
        int* ix = (int*)x;
        int* iy = (int*)y;
        return *ix - *iy;
    });

    result &= Test("c-funcptr lambda sort[0]", a[0], 1);
    result &= Test("c-funcptr lambda sort[1]", a[1], 2);
    result &= Test("c-funcptr lambda sort[2]", a[2], 5);
    result &= Test("c-funcptr lambda sort[3]", a[3], 8);
    result &= Test("c-funcptr lambda sort[4]", a[4], 9);

    return result;
}

// ─────────────────────────────────────────────────────────────────────────────
// MAIN
// ─────────────────────────────────────────────────────────────────────────────

extern int main()
{
    int passed = 0;
    int total  = 0;

    // Function pointer tests
    total++; passed += testExplicitFunctionPointer()   ? 1 : 0;
    total++; passed += testBareFunctionPointer()       ? 1 : 0;
    total++; passed += testFunctionPointerAsArgument() ? 1 : 0;
    total++; passed += testFunctionPointerInLoop()     ? 1 : 0;
    total++; passed += testFunctionPointerCountIf()    ? 1 : 0;
    total++; passed += testVoidFunctionPointer()       ? 1 : 0;
    total++; passed += testFunctionPointerClamp()      ? 1 : 0;

    // Lambda tests
    total++; passed += testLambdaBasic()               ? 1 : 0;
    total++; passed += testLambdaControlFlow()         ? 1 : 0;
    total++; passed += testLambdaLocalVars()           ? 1 : 0;
    total++; passed += testLambdaCallsNamedFunction()  ? 1 : 0;
    total++; passed += testLambdaBoolReturn()          ? 1 : 0;
    total++; passed += testLambdaReassignment()        ? 1 : 0;
    total++; passed += testLambdaAsArgument()          ? 1 : 0;
    total++; passed += testLambdaInHigherOrder()       ? 1 : 0;
    total++; passed += testLambdaThreeParam()          ? 1 : 0;
    total++; passed += testVoidLambda()               ? 1 : 0;

    // Lambda capture tests
    total++; passed += testCapturePrimitives()         ? 1 : 0;
    total++; passed += testCaptureString()             ? 1 : 0;
    total++; passed += testCaptureStructRef()          ? 1 : 0;
    total++; passed += testCaptureMultiple()           ? 1 : 0;
    total++; passed += testCaptureRegression()         ? 1 : 0;
    total++; passed += testCaptureNameCollidesWithFunction() ? 1 : 0;
    total++; passed += testCaptureLocalArray()         ? 1 : 0;
    total++; passed += testLambdaAllocaInLoop()        ? 1 : 0;
    total++; passed += testCaptureBondReassign()       ? 1 : 0;

    // Generic function pointer tests
    total++; passed += testGenericFuncPtrBasic()       ? 1 : 0;
    total++; passed += testGenericFuncPtrSizeof()      ? 1 : 0;
    total++; passed += testGenericFuncPtrWrite()       ? 1 : 0;
    total++; passed += testGenericFuncPtrDoubleInPlace() ? 1 : 0;
    total++; passed += testGenericFuncPtrHigherOrder() ? 1 : 0;

    // Function pointer in struct field tests
    total++; passed += testFuncPtrInStructField()      ? 1 : 0;
    total++; passed += testFuncPtrInStructFieldVoid()  ? 1 : 0;

    // Dispatch table tests
    total++; passed += testDispatchTable()             ? 1 : 0;

    // 'move' in function pointer signatures
    total++; passed += testFuncPtrMoveSignature()      ? 1 : 0;

    // Non-capturing lambda across the C ABI
    total++; passed += testNonCapturingLambdaToCFuncPtr() ? 1 : 0;

    // List sort tests
    total++; passed += testListSortAscending()         ? 1 : 0;
    total++; passed += testListSortDescending()        ? 1 : 0;
    total++; passed += testListSortEdgeCases()         ? 1 : 0;
    total++; passed += testListSortNamedComparator()   ? 1 : 0;

    printf("Function pointer / lambda tests: %d/%d passed.\n", passed, total);
    return passed == total ? 0 : 1;
}
