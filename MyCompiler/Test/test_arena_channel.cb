import "thread.cb";
import "arena_channel.cb";

struct Payload
{
    int   _value = 0;
    int*  _data  = nullptr;
    int   _count = 0;
};

// Shared channel between producer and consumer.
arena_channel g_ac = default;
int g_errors = 0;

int producer(void* unused)
{
    int i = 0;
    while (i < 1000)
    {
        page_arena* pa = g_ac.acquire_arena();

        Payload* msg    = (Payload*)pa->alloc((i64)sizeof(Payload));
        pa->_root       = (void*)msg;
        msg->_value     = i;
        msg->_count     = 10;
        msg->_data      = (int*)pa->alloc((i64)10 * (i64)sizeof(int));

        int j = 0;
        while (j < 10)
        {
            msg->_data[j] = i * 10 + j;
            j = j + 1;
        }

        g_ac.send(pa);
        i = i + 1;
    }
    // Send a nullptr sentinel to signal done.
    g_ac.send(nullptr);
    return 0;
}

int consumer(void* unused)
{
    while (true)
    {
        page_arena* pa = g_ac.recv();
        if (pa == nullptr) break;

        Payload* msg = (Payload*)pa->_root;

        int j = 0;
        while (j < msg->_count)
        {
            int expected = msg->_value * 10 + j;
            if (msg->_data[j] != expected)
            {
                printf("ERROR: arena %lld msg[%d][%d]: expected %d got %d\n",
                    pa->_id, msg->_value, j, expected, msg->_data[j]);
                g_errors = g_errors + 1;
            }
            j = j + 1;
        }

        g_ac.release_arena(pa);
    }
    return 0;
}

extern int main()
{
    g_ac.init(128, (i64)65536);

    Thread prod = default;
    Thread cons = default;

    prod.start(producer, nullptr);
    cons.start(consumer, nullptr);

    prod.join();
    cons.join();

    g_ac.destroy();

    if (g_errors == 0)
        printf("PASS: arena_channel test\n");
    else
        printf("FAIL: %d errors\n", g_errors);

    return g_errors;
}
