import "filesystem.cb";
import "test_helper.cb";

// ── File static methods: read/write/exists/remove ─────────────────────────────

int testFileReadWrite()
{
    int passed = 0;
    string path = "test_fs_tmp.txt";
    string hw   = "hello world";
    string again = " again";

    File.remove(path);
    passed += Test("file not exists before write", File.exists(path), false);

    passed += Test("writeAllText",            File.writeAllText(path, hw), true);
    passed += Test("file exists after write", File.exists(path),           true);

    string content = File.readAllText(path);
    passed += Test("readAllText content", content.data(), "hello world");
    passed += Test("readAllText length",  content.length(), 11);

    passed += Test("appendAllText", File.appendAllText(path, again), true);
    string content2 = File.readAllText(path);
    passed += Test("after append", content2.data(), "hello world again");

    passed += Test("File.remove",               File.remove(path), true);
    passed += Test("file not exists after del", File.exists(path), false);

    return passed;
}

// ── File class: open / writeLine / readLine / size ────────────────────────────

int testFileClass()
{
    int passed = 0;
    string path  = "test_fs_class.txt";
    string hello = "hello";
    string world = "world";
    File.remove(path);

    File* w = new File;
    passed += Test("openWrite",       w->openWrite(path), true);
    passed += Test("isOpen",          w->isOpen(),        true);
    passed += Test("writeLine hello", w->writeLine(hello), true);
    passed += Test("writeLine world", w->writeLine(world), true);
    w->close();
    passed += Test("isOpen after close", w->isOpen(), false);
    delete w;

    File* r = new File;
    passed += Test("openRead", r->openRead(path), true);
    string line1 = r->readLine();
    string line2 = r->readLine();
    passed += Test("readLine 1", line1.data(), "hello");
    passed += Test("readLine 2", line2.data(), "world");
    r->readLine();
    passed += Test("atEnd", r->atEnd(), true);
    delete r;

    // "hello\n" + "world\n" = 12 bytes
    File* s = new File;
    s->openRead(path);
    int sz = s->size();
    passed += Test("file size 12", sz == 12, true);
    delete s;

    File.remove(path);
    return passed;
}

// ── File.move ─────────────────────────────────────────────────────────────────

int testFileMove()
{
    int passed = 0;
    string src     = "test_fs_move_src.txt";
    string dst     = "test_fs_move_dst.txt";
    string moveme  = "move me";
    File.remove(src);
    File.remove(dst);

    File.writeAllText(src, moveme);
    passed += Test("File.move ok",           File.move(src, dst),  true);
    passed += Test("src gone after move",    File.exists(src),     false);
    passed += Test("dst exists after move",  File.exists(dst),     true);

    string content = File.readAllText(dst);
    passed += Test("moved content", content.data(), "move me");

    File.remove(dst);
    return passed;
}

// ── Directory static methods ──────────────────────────────────────────────────

int testDirectoryFunctions()
{
    int passed = 0;
    string testDir = "test_fs_dir";

    Directory.remove(testDir);
    passed += Test("dir not exists before create", Directory.exists(testDir), false);
    passed += Test("Directory.create",             Directory.create(testDir), true);
    passed += Test("dir exists after create",      Directory.exists(testDir), true);
    passed += Test("Directory.remove",             Directory.remove(testDir), true);
    passed += Test("dir not exists after delete",  Directory.exists(testDir), false);

    string cwd = Directory.getCurrent();
    passed += Test("getCurrent not empty", cwd.length() > 0, true);

    return passed;
}

// ── Directory class (instance methods) ───────────────────────────────────────

int testDirectoryClass()
{
    int passed = 0;
    string testDir = "test_fs_dir2";
    string atxt    = "test_fs_dir2\\a.txt";
    string btxt    = "test_fs_dir2\\b.txt";

    File.remove(atxt);
    File.remove(btxt);
    Directory.remove(testDir);

    Directory* d = new Directory;
    d->init(testDir);

    passed += Test("Directory.exists false",  d->exists(), false);
    passed += Test("Directory.create",        d->create(), true);
    passed += Test("Directory.exists true",   d->exists(), true);

    File.remove(atxt);
    File.remove(btxt);
    passed += Test("Directory.remove", d->remove(), true);
    delete d;

    return passed;
}

// ── main ─────────────────────────────────────────────────────────────────────

extern int main()
{
    int passed = 0;
    int total  = 0;

    int r;

    r = testFileReadWrite();      passed += r; total += 9;
    r = testFileClass();          passed += r; total += 10;
    r = testFileMove();           passed += r; total += 4;
    r = testDirectoryFunctions(); passed += r; total += 6;
    r = testDirectoryClass();     passed += r; total += 4;

    printf("\n%d / %d tests passed.\n", passed, total);
    return passed == total ? 0 : 1;
}
