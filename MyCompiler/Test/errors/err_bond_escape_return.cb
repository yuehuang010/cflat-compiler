// returning a bonded value from a function that does not declare the source as 'bond'
expect_error("is not a 'bond' parameter") {
    int* Borrow(bond int* src) { return src; }

    // src is NOT declared bond here — so returning v would let a bonded value escape
    int* Bad(int* src) {
        int* v = Borrow(src);
        return v;
    }
}
