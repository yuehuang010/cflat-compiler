extern void printf(const char* fmt, ...);

// ── Vec2: 2D vector with full arithmetic ────────────────────────────────────

struct Vec2
{
    float x = 0;
    float y = 0;

    Vec2 operator+(Vec2 other) { Vec2 r; r.x = x + other.x; r.y = y + other.y; return r; }
    Vec2 operator-(Vec2 other) { Vec2 r; r.x = x - other.x; r.y = y - other.y; return r; }
    Vec2 operator*(float s)    { Vec2 r; r.x = x * s;       r.y = y * s;       return r; }
    Vec2 operator/(float s)    { Vec2 r; r.x = x / s;       r.y = y / s;       return r; }
    bool operator==(Vec2 other) { return x == other.x && y == other.y; }
    bool operator!=(Vec2 other) { return x != other.x || y != other.y; }
};

// ── Fraction: rational number with arithmetic ────────────────────────────────

struct Fraction
{
    int num = 0;
    int den = 1;

    Fraction operator+(Fraction other)
    {
        Fraction r;
        r.num = num * other.den + other.num * den;
        r.den = den * other.den;
        return r;
    }

    Fraction operator-(Fraction other)
    {
        Fraction r;
        r.num = num * other.den - other.num * den;
        r.den = den * other.den;
        return r;
    }

    Fraction operator*(Fraction other)
    {
        Fraction r;
        r.num = num * other.num;
        r.den = den * other.den;
        return r;
    }

    bool operator==(Fraction other) { return num * other.den == other.num * den; }
    bool operator!=(Fraction other) { return num * other.den != other.num * den; }
    bool operator<(Fraction other)  { return num * other.den <  other.num * den; }
    bool operator>(Fraction other)  { return num * other.den >  other.num * den; }
};

// ── Counter: integer wrapper demonstrating overloaded +/== ──────────────────

struct Counter
{
    int value = 0;

    Counter operator+(Counter other) { Counter r; r.value = value + other.value; return r; }
    Counter operator-(Counter other) { Counter r; r.value = value - other.value; return r; }
    Counter operator*(int scale)     { Counter r; r.value = value * scale;       return r; }
    bool operator==(Counter other)   { return value == other.value; }
    bool operator<(Counter other)    { return value < other.value; }
};

// ── Helpers ──────────────────────────────────────────────────────────────────

int TestBool(const char* name, bool actual, bool expected)
{
    if (actual == expected) { printf("%s passed.\n", name); return 1; }
    printf("%s FAILED (expected %d got %d).\n", name, (int)expected, (int)actual);
    return 0;
}

int TestInt(const char* name, int actual, int expected)
{
    if (actual == expected) { printf("%s passed.\n", name); return 1; }
    printf("%s FAILED (expected %d got %d).\n", name, expected, actual);
    return 0;
}

int TestFloat(const char* name, float actual, float expected)
{
    if (actual == expected) { printf("%s passed.\n", name); return 1; }
    printf("%s FAILED (expected %f got %f).\n", name, expected, actual);
    return 0;
}

// ── Main ─────────────────────────────────────────────────────────────────────

extern int main()
{
    // Vec2 tests
    Vec2 a; a.x = 1.0f; a.y = 2.0f;
    Vec2 b; b.x = 3.0f; b.y = 4.0f;

    Vec2 sum = a + b;
    TestFloat("Vec2 + x", sum.x, 4.0f);
    TestFloat("Vec2 + y", sum.y, 6.0f);

    Vec2 diff = b - a;
    TestFloat("Vec2 - x", diff.x, 2.0f);
    TestFloat("Vec2 - y", diff.y, 2.0f);

    Vec2 scaled = a * 3.0f;
    TestFloat("Vec2 * x", scaled.x, 3.0f);
    TestFloat("Vec2 * y", scaled.y, 6.0f);

    Vec2 divided = b / 2.0f;
    TestFloat("Vec2 / x", divided.x, 1.5f);
    TestFloat("Vec2 / y", divided.y, 2.0f);

    Vec2 c; c.x = 1.0f; c.y = 2.0f;
    TestBool("Vec2 == (equal)",     a == c,  true);
    TestBool("Vec2 == (not equal)", a == b,  false);
    TestBool("Vec2 != (not equal)", a != b,  true);
    TestBool("Vec2 != (equal)",     a != c,  false);

    // Fraction tests:  1/2 + 1/3 = 5/6,  1/2 * 2/3 = 2/6 = 1/3
    Fraction half;  half.num  = 1; half.den  = 2;
    Fraction third; third.num = 1; third.den = 3;
    Fraction twothirds; twothirds.num = 2; twothirds.den = 3;

    Fraction fsum = half + third;          // 5/6
    TestInt("Frac + num", fsum.num, 5);
    TestInt("Frac + den", fsum.den, 6);

    Fraction fdiff = half - third;         // 1/6
    TestInt("Frac - num", fdiff.num, 1);
    TestInt("Frac - den", fdiff.den, 6);

    Fraction fprod = half * twothirds;     // 2/6
    Fraction oneThird; oneThird.num = 1; oneThird.den = 3;
    TestBool("Frac * ==",  fprod == oneThird, true);

    TestBool("Frac ==",    half == half,   true);
    TestBool("Frac !=",    half != third,  true);
    TestBool("Frac < ",    third < half,   true);
    TestBool("Frac > ",    half > third,   true);

    // Counter tests
    Counter p; p.value = 10;
    Counter q; q.value = 5;

    Counter csum  = p + q;
    Counter cdiff = p - q;
    Counter cmul  = q * 4;

    TestInt("Counter + value",  csum.value,  15);
    TestInt("Counter - value",  cdiff.value,  5);
    TestInt("Counter * value",  cmul.value,  20);
    TestBool("Counter == (eq)",  p == p,  true);
    TestBool("Counter == (ne)",  p == q,  false);
    TestBool("Counter <  ",      q < p,   true);

    // Chained: (a + b) + c  ==  a + (1,2) + (3,4)+(1,2) = (5,8)+(1,2) but let's just check addition chaining
    Vec2 chain = a + b + c;    // (1+3+1, 2+4+2) = (5, 8)
    TestFloat("Vec2 chain + x", chain.x, 5.0f);
    TestFloat("Vec2 chain + y", chain.y, 8.0f);
    return 0;
}
