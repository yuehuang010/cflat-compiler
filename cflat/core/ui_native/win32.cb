// core/ui_native/win32.cb - a native Win32 host that drives REAL OS controls.
//
// Where ui_canvas/win32.cb PAINTS the IElement tree through GDI (GdiCanvas), this
// host is the INativeHost output stage (see ui_native.cb): the reconciled tree's stable key
// paths map to real child controls (BUTTON/STATIC/EDIT/checkbox/msctls_progress32/
// trackbar/etched-panel/status bar), and the host creates/updates/destroys those
// controls to match the tree. The OS paints, handles IME + accessibility, and owns
// focus/Tab.
//
// The app-facing model (IComponent/IElement/Theme/controlled widgets) is UNCHANGED;
// an app that renders to the GDI host renders here too - it just imports this host
// instead.
//
// App-shell foundation: this host is now MULTI-WINDOW. A `Window` owns its
// {top-level HWND, root IElement/IComponent, UiContext, live-control bookkeeping,
// theme}; the app holds a list<Window*> driven by ONE message loop. The former
// single-editor host globals are gone: the free-function WndProc resolves the
// servicing window by finding its HWND in the registry, and app code reaches the
// window it is servicing through activeCtx()/activeApp() (set per message).
// ctx.post() marshals a closure back to the UI thread via PostMessage(WM_APP_CALL).
//
// This file has no main(); an app imports it and calls runAppGuiNative().
import "windows.h" lib { "user32.lib", "gdi32.lib", "comctl32.lib", "dwmapi.lib", "comdlg32.lib",
                         "uxtheme.lib" } cache;
import "ui_native.cb";
import "graphic/bitmap.cb";   // 24bpp BMP writer for nativeSaveWindowBmp (the shot() backend)

// -- APIs not surfaced by the windows.h binding (declared by hand) ------------
// InitCommonControls() (commctrl.h) registers the classic control classes;
// DwmSetWindowAttribute (dwmapi.h) drives the immersive dark-mode titlebar.
extern stdcall void InitCommonControls();
extern stdcall i32 DwmSetWindowAttribute(void* hwnd, u32 attr, void* pv, u32 cb);
// PrintWindow + GetDIBits back the offscreen screenshot path; not surfaced by the binding.
extern stdcall i32 PrintWindow(void* hwnd, void* hdc, u32 flags);
extern stdcall i32 GetDIBits(void* hdc, void* hbm, u32 start, u32 lines, void* bits, void* bmi, u32 usage);
// SetWindowTheme (uxtheme.h) is a DOCUMENTED, linkable API; only the theme NAME it is given
// ("DarkMode_Explorer") is undocumented. A wrong/absent name degrades to the light look.
extern stdcall i32 SetWindowTheme(void* hwnd, u16* subApp, u16* subIdList);

const int PBM_SETRANGE32 = 1030;   // WM_USER+6
const int PBM_SETPOS     = 1026;   // WM_USER+2
const int PBM_GETPOS     = 1032;   // WM_USER+8
const int TBM_GETPOS     = 1024;   // WM_USER+0
const int TBM_SETPOS     = 1029;   // WM_USER+5
const int TBM_SETRANGE   = 1030;   // WM_USER+6
const int DWMWA_USE_IMMERSIVE_DARK_MODE = 20;

// Status bar (msctls_statusbar32) messages.
const int SB_SETTEXTA   = 1025;   // WM_USER+1
const int SB_GETTEXTA   = 1026;   // WM_USER+2
const int SB_SETPARTS   = 1028;   // WM_USER+4
const int SB_SETBKCOLOR = 0x2001; // CCM_SETBKCOLOR (ignored while the control is visual-styled)
const int SBT_OWNERDRAW = 0x1000; // the part's text is drawn by the PARENT via WM_DRAWITEM
const int SBARS_SIZEGRIP = 0x0100;   // the status bar draws the window's resize grip
const u32 CLR_DEFAULT   = 0xFF000000u;   // "use the default background" for SB_SETBKCOLOR
const u32 CLR_NONE      = 0xFFFFFFFFu;   // "restore the system default" for the TreeView colors

// ProgressBar (msctls_progress32) colors. A visual-styled progress bar IGNORES both, so the
// dark path drops its theme first (see _themeControl).
const int PBM_SETBKCOLOR  = 0x2001;   // CCM_SETBKCOLOR, like the status bar's
const int PBM_SETBARCOLOR = 1033;     // WM_USER+9

// The owner-drawn item type (DRAWITEMSTRUCT.CtlType) for a tab item; ODS_SELECTED comes from
// the windows.h binding.
const int ODT_TAB = 101;

// Header (SysHeader32, the ListView's column bar) item read + the custom-draw stages its
// NM_CUSTOMDRAW walks. HDM_FIRST = 0x1200.
const int HDM_GETITEMCOUNT = 0x1200;   // HDM_FIRST+0
const int HDM_GETITEMA     = 0x1203;   // HDM_FIRST+3
const int HDM_GETITEMRECT  = 0x1207;   // HDM_FIRST+7
const int HDI_TEXT         = 0x0002;

// HDITEMA (ANSI, 64-bit): pszText@8, cchTextMax@24. Only the text fields are read.
struct HDItemA
{
    u32   mask       = 0u;
    i32   cxy        = 0;
    char* pszText    = nullptr;
    void* hbm        = nullptr;
    i32   cchTextMax = 0;
    i32   fmt        = 0;
    i64   lParam     = 0;
    i32   iImage     = 0;
    i32   iOrder     = 0;
    u32   type       = 0u;
    u32   _pad       = 0u;
    void* pvFilter   = nullptr;
    u32   state      = 0u;
};

// Tooltip (tooltips_class32) messages / flags.
const int TTM_ADDTOOLA       = 1028;   // WM_USER+4
const int TTM_UPDATETIPTEXTA = 1036;   // WM_USER+12
const int TTM_GETTOOLCOUNT   = 1037;   // WM_USER+13
const int TTF_IDISHWND       = 0x0001;
const int TTF_SUBCLASS       = 0x0010;
const int TTS_ALWAYSTIP      = 0x0001;

// Marshaled UI-thread call (ctx.post): WM_APP+1, lParam = the boxed closure pointer.
const int WM_APP_CALL = 0x8001;

// -- ListView (WC_LISTVIEW) messages / styles / notify codes -------------------
// The commctrl LV* constants are not surfaced by the windows.h binding (CB_* and
// NMHDR are), so they are declared by hand. LVM_FIRST = 0x1000, LVN_FIRST = -100.
const int LVM_DELETECOLUMN            = 0x101C;   // LVM_FIRST+28
const int LVM_INSERTCOLUMNA           = 0x101B;   // LVM_FIRST+27
const int LVM_SETITEMCOUNT            = 0x102F;   // LVM_FIRST+47
const int LVM_SETITEMSTATE            = 0x102B;   // LVM_FIRST+43
const int LVM_GETITEMTEXTA            = 0x102D;   // LVM_FIRST+45
const int LVM_GETNEXTITEM             = 0x100C;   // LVM_FIRST+12
const int LVM_SETEXTENDEDLISTVIEWSTYLE = 0x1036;  // LVM_FIRST+54
const int LVM_GETITEMCOUNT            = 0x1004;   // LVM_FIRST+4
// Dark-mode colors + the header (a SEPARATE control that needs its own theme).
const int LVM_SETBKCOLOR     = 0x1001;   // LVM_FIRST+1
const int LVM_GETHEADER      = 0x101F;   // LVM_FIRST+31
const int LVM_SETTEXTCOLOR   = 0x1024;   // LVM_FIRST+36
const int LVM_SETTEXTBKCOLOR = 0x1026;   // LVM_FIRST+38
const int LVS_REPORT       = 0x0001;
const int LVS_SINGLESEL    = 0x0004;
const int LVS_SHOWSELALWAYS = 0x0008;
const int LVS_OWNERDATA    = 0x1000;
const int LVS_EX_FULLROWSELECT = 0x0020;
const int LVCF_FMT     = 0x0001;
const int LVCF_WIDTH   = 0x0002;
const int LVCF_TEXT    = 0x0004;
const int LVCF_SUBITEM = 0x0008;
const int LVIF_TEXT    = 0x0001;
const int LVIS_FOCUSED  = 0x0001;
const int LVIS_SELECTED = 0x0002;
const int LVNI_SELECTED = 0x0002;
const int LVN_ITEMCHANGED = -101;   // LVN_FIRST-1
const int LVN_GETDISPINFOA = -150;  // LVN_FIRST-50
const int LVN_KEYDOWN     = -155;   // LVN_FIRST-55
const int NM_DBLCLK       = -3;     // NM_FIRST-3

// LVCOLUMNA (ANSI, natural 8-byte pointer alignment). pszText/iSubItem drive an
// LVM_INSERTCOLUMNA; _pad aligns pszText to offset 16.
struct LVColumnA
{
    u32   mask       = 0u;
    i32   fmt        = 0;
    i32   cx         = 0;
    i32   _pad       = 0;
    char* pszText    = nullptr;
    i32   cchTextMax = 0;
    i32   iSubItem   = 0;
    i32   iImage     = 0;
    i32   iOrder     = 0;
};

// LVITEMA (ANSI). Used for LVM_SETITEMSTATE (state+stateMask), LVM_GETITEMTEXTA
// (iSubItem+pszText+cchTextMax), and to read a GETDISPINFO item (offset 24 inside
// NMLVDISPINFO). pszText lands at struct offset 24, matching the Win32 layout.
struct LVItemA
{
    u32   mask       = 0u;
    i32   iItem      = 0;
    i32   iSubItem   = 0;
    u32   state      = 0u;
    u32   stateMask  = 0u;
    i32   _pad       = 0;
    char* pszText    = nullptr;
    i32   cchTextMax = 0;
    i32   iImage     = 0;
    i64   lParam     = 0;
};

// TOOLINFOA is not surfaced by the windows.h binding; declared by hand to match the
// comctl32 v6 ANSI layout (embedded RECT as 4 i32; natural 8-byte pointer alignment).
struct TTInfoA
{
    u32   cbSize     = 0u;
    u32   uFlags     = 0u;
    void* hwnd       = nullptr;
    u64   uId        = 0u;
    i32   rectLeft   = 0;
    i32   rectTop    = 0;
    i32   rectRight  = 0;
    i32   rectBottom = 0;
    void* hinst      = nullptr;
    char* lpszText   = nullptr;
    i64   lParam     = 0;
    void* lpReserved = nullptr;
};

// -- TabControl (WC_TABCONTROL) messages / notify codes -------------------------
// TCM_FIRST = 0x1300; TCN_FIRST = -550. Not surfaced by the windows.h binding.
const int TCM_INSERTITEMA   = 0x1307;   // TCM_FIRST+7
const int TCM_DELETEALLITEMS = 0x1309;  // TCM_FIRST+9
const int TCM_GETCURSEL     = 0x130B;   // TCM_FIRST+11
const int TCM_SETCURSEL     = 0x130C;   // TCM_FIRST+12
const int TCM_GETITEMCOUNT  = 0x1304;   // TCM_FIRST+4
const int TCM_GETITEMA      = 0x1305;   // TCM_FIRST+5
const int TCIF_TEXT         = 0x0001;
const int TCN_SELCHANGE     = -551;  // TCN_FIRST-1
// uxtheme ships NO dark theme for SysTabControl32 and the control does not support
// NM_CUSTOMDRAW, so the dark path owner-draws the tab ITEMS (WM_DRAWITEM at the frame).
const int TCS_OWNERDRAWFIXED = 0x2000;

// TCITEMA (ANSI, tightly packed like LVColumnA - cflat inserts no field padding, so
// pointers/i64 are hand-aligned). pszText lands at offset 16, lParam at 32.
struct TCItemA
{
    u32   mask        = 0u;
    u32   dwState     = 0u;
    u32   dwStateMask = 0u;
    u32   _pad        = 0u;
    char* pszText     = nullptr;
    i32   cchTextMax  = 0;
    i32   iImage      = 0;
    i64   lParam      = 0;
};

// -- TreeView (WC_TREEVIEW) messages / styles / notify codes --------------------
// TV_FIRST = 0x1100; TVN_FIRST = -400.
const int TVM_INSERTITEMA  = 0x1100;   // TV_FIRST+0
const int TVM_DELETEITEM   = 0x1101;   // TV_FIRST+1
const int TVM_EXPAND       = 0x1102;   // TV_FIRST+2
const int TVM_GETCOUNT     = 0x1105;   // TV_FIRST+5
const int TVM_GETNEXTITEM  = 0x110A;   // TV_FIRST+10
const int TVM_SELECTITEM   = 0x110B;   // TV_FIRST+11
const int TVM_GETITEMA     = 0x110C;   // TV_FIRST+12
const int TVS_HASBUTTONS   = 0x0001;
const int TVS_HASLINES     = 0x0002;
const int TVS_LINESATROOT  = 0x0004;
const int TVS_SHOWSELALWAYS = 0x0020;
const int TVM_SETBKCOLOR   = 0x111D;   // TV_FIRST+29
const int TVM_SETTEXTCOLOR = 0x111E;   // TV_FIRST+30
const int TVM_SETLINECOLOR = 0x1128;   // TV_FIRST+40
const int TVIF_TEXT        = 0x0001;
const int TVIF_PARAM       = 0x0004;
const int TVIF_CHILDREN    = 0x0040;
const int TVGN_ROOT        = 0x0000;
const int TVGN_CHILD       = 0x0004;
const int TVGN_CARET       = 0x0009;
const int TVE_EXPAND       = 0x0002;
const int TVN_SELCHANGEDA   = -402;  // TVN_FIRST-2
const int TVN_ITEMEXPANDINGA = -405; // TVN_FIRST-5

// TVITEMA (ANSI, tightly packed). hItem@8, pszText@24, lParam@48; size 56.
struct TVItemA
{
    u32   mask           = 0u;
    u32   _pad0          = 0u;
    void* hItem          = nullptr;
    u32   state          = 0u;
    u32   stateMask      = 0u;
    char* pszText        = nullptr;
    i32   cchTextMax     = 0;
    i32   iImage         = 0;
    i32   iSelectedImage = 0;
    i32   cChildren      = 0;
    i64   lParam         = 0;
};

// TVINSERTSTRUCTA (ANSI): hParent@0, hInsertAfter@8, then the embedded TVITEMA @16
// (mask@16 ... lParam@64). Flattened so the layout is explicit.
struct TVInsertA
{
    void* hParent        = nullptr;
    void* hInsertAfter   = nullptr;
    u32   mask           = 0u;
    u32   _pad0          = 0u;
    void* hItem          = nullptr;
    u32   state          = 0u;
    u32   stateMask      = 0u;
    char* pszText        = nullptr;
    i32   cchTextMax     = 0;
    i32   iImage         = 0;
    i32   iSelectedImage = 0;
    i32   cChildren      = 0;
    i64   lParam         = 0;
};

// The two HTREEITEM sentinels used at insert time (ULONG_PTR -0x10000 / -0xFFFE on
// 64-bit). Computed via subtraction so no negative literal is folded (see the note above).
void* tviRoot() { return (void*)((i64)0 - (i64)0x10000); }
void* tviLast() { return (void*)((i64)0 - (i64)0xFFFE); }

// -- Image / GroupBox / CanvasView --------------------------------------------
// STM_SETIMAGE / IMAGE_BITMAP / SS_BITMAP / SS_REALSIZECONTROL / BS_GROUPBOX /
// LR_LOADFROMFILE / DIB_RGB_COLORS / PW_RENDERFULLCONTENT / GWLP_USERDATA are all
// surfaced by the windows.h binding. The custom-draw NM_/CDDS_/CDRF_/CDIS_ codes are not.

// NM_CUSTOMDRAW for themed accent buttons. NM_FIRST = 0; NM_CUSTOMDRAW = NM_FIRST-12.
const int NM_CUSTOMDRAW      = -12;
const int CDDS_PREPAINT      = 0x00000001;
const int CDDS_POSTPAINT     = 0x00000002;
const int CDDS_ITEMPREPAINT  = 0x00010001;   // CDDS_ITEM | CDDS_PREPAINT
const int CDRF_DODEFAULT     = 0x00000000;
const int CDRF_NOTIFYPOSTPAINT = 0x00000010;
const int CDRF_NOTIFYITEMDRAW = 0x00000020;
const int CDRF_SKIPDEFAULT   = 0x00000004;
const int CDIS_SELECTED      = 0x00000001;
const int CDIS_FOCUS         = 0x00000010;
const int CDIS_HOT           = 0x00000040;

// GDI + shell APIs used by the image DIB upload, the canvas child, and screenshots that
// the windows.h binding may not surface; declared by hand to match the Win32 signatures.
extern stdcall void* CreateDIBSection(void* hdc, void* pbmi, u32 usage, void** bits, void* sect, u32 off);
extern stdcall void* LoadImageA(void* inst, char* name, u32 type, i32 cx, i32 cy, u32 fuLoad);

// A 40-byte BITMAPINFOHEADER (no color table for 32bpp BI_RGB). A negative biHeight
// makes the DIB top-down, matching the BGRA32 buffers Image carries.
struct BmiHeader
{
    u32 biSize        = 40u;
    i32 biWidth       = 0;
    i32 biHeight      = 0;
    u16 biPlanes      = 1;
    u16 biBitCount    = 32;
    u32 biCompression = 0u;
    u32 biSizeImage   = 0u;
    i32 biXPelsPerM   = 0;
    i32 biYPelsPerM   = 0;
    u32 biClrUsed     = 0u;
    u32 biClrImportant = 0u;
};

// Per-DIP base pixels at 96 dpi (100%). Layout math in ui.cb is unit-blind
// integers; a native host reads them as DIPs and scales by the monitor dpi:
// physical px = dip * BASE * dpi / 96. One layout column ~8px, one row ~26px so
// native controls get sensible heights.
const int BASE_X = 8;
const int BASE_Y = 26;

// Ceiling on the content pane's height. Mouse messages pack client coordinates as SIGNED
// 16-bit, so a pane past 32767px would corrupt hit-testing inside the controls it parents.
const int PANE_MAX_H = 32000;

// -- App-wide host state (NOT per-window) -------------------------------------
// The window class + hInstance + declarative menu are shared by every window; the
// per-window state lives in Window (below). _cur is the window currently being
// serviced (set by WndProc from the incoming HWND, and explicitly during a build).
void*          _hInst      = nullptr;
bool           _classReg   = false;
bool           _secClassReg = false;
void*          _accelTable = nullptr;

// The declarative menu bar. The app builds it once with menuReset/menuAddTop/
// menuAddItem before creating windows; each window realizes the SAME declaration into
// its own HMENU + the shared accelerator table. Parallel lists keep ownership simple.
list<string>          _menuTop        = default;   // top-level menu titles
list<int>             _menuItemTopIdx = default;   // per item: owning top index
list<string>          _menuItemLabel  = default;   // per item: label (with \t accel text)
list<int>             _menuItemCmd    = default;   // per item: app command id (0 = separator)
list<int>             _menuAccelKey   = default;   // per item: virtual key (0 = none)
list<int>             _menuAccelMods  = default;   // per item: FCONTROL|FSHIFT|FALT

// One app-wide command dispatcher + close guard. They reach the servicing window via
// activeApp()/activeCtx(), so a single closure serves every window.
Lambda<void(int)>     _menuHandler    = default;
bool                  _hasMenuHandler = false;
Lambda<bool()>        _closeQuery     = default;
bool                  _hasCloseQuery  = false;

void setMenuHandler(Lambda<void(int)> h) { _menuHandler = h; _hasMenuHandler = true; }
void setCloseQuery(Lambda<bool()> q) { _closeQuery = q; _hasCloseQuery = true; }

void* u2h(u64 u) { return (void*)u; }

// -- Dark mode for NON-CLIENT chrome (the frame's scrollbar) --------------------
// A WS_VSCROLL scrollbar is non-client area: Windows paints it from the process/window
// uxtheme app mode, which DWMWA_USE_IMMERSIVE_DARK_MODE (a titlebar attribute) does not
// touch. There is no documented API for it, so the two uxtheme entry points below are
// bound BY ORDINAL and every pointer is null-checked: if a future Windows build drops
// them, the binding no-ops and the scrollbar stays light (a cosmetic degradation, never
// a crash). SetWindowTheme itself is documented; only its theme-name string is not.
const int UXORD_ALLOW_DARK_MODE_FOR_WINDOW = 133;
const int UXORD_SET_PREFERRED_APP_MODE     = 135;
const int UX_APPMODE_DEFAULT   = 0;
const int UX_APPMODE_ALLOW_DARK = 1;

function<i32(void*, i32)> _uxAllowDarkForWindow = nullptr;
function<i32(i32)>        _uxSetPreferredAppMode = nullptr;
bool _uxBound = false;

// Bind uxtheme's dark-mode ordinals once. Absent ordinals leave the pointers null.
void _bindUxTheme()
{
    if (_uxBound) return;
    _uxBound = true;
    void* ux = LoadLibraryA("uxtheme.dll");
    if (ux == nullptr) return;
    _uxAllowDarkForWindow = (function<i32(void*, i32)>)
        GetProcAddress(ux, (const char*)(i64)UXORD_ALLOW_DARK_MODE_FOR_WINDOW);
    _uxSetPreferredAppMode = (function<i32(i32)>)
        GetProcAddress(ux, (const char*)(i64)UXORD_SET_PREFERRED_APP_MODE);
}

// A NUL-terminated UTF-16 copy of an ASCII string, for the LPCWSTR-only SetWindowTheme.
void _wideAscii(string s, u16* out, int cap)
{
    int i = 0;
    const char* p = s.data();
    while (i < s.length() && i < cap - 1) { out[i] = (u16)p[i]; i++; }
    out[i] = (u16)0;
}

// Opt one window into (or out of) the process dark mode. Ordinal-bound and null-checked:
// an absent ordinal degrades to the light look, never a crash (see the note above).
void _allowDark(void* hwnd, bool dark)
{
    _bindUxTheme();
    if (_uxAllowDarkForWindow != nullptr)
        _uxAllowDarkForWindow(hwnd, dark ? 1 : 0);
}

// SetWindowTheme with an ASCII sub-app name (the API takes LPCWSTR only).
void _ctlTheme(void* hwnd, string subApp)
{
    u16[32] name;
    _wideAscii(subApp, name, 32);
    SetWindowTheme(hwnd, name, nullptr);
}

// Drop the control's visual styles (L"", L""), which is what makes a common control honor
// its own color messages (SB_SETBKCOLOR, PBM_SETBKCOLOR) instead of painting themed.
void _ctlThemeNone(void* hwnd)
{
    u16[4] empty = default;
    empty[0] = (u16)0;        // L"" - the NUL terminator IS the whole string
    SetWindowTheme(hwnd, empty, empty);
}

// Back to the class default: the stock native look, byte-identical to never having themed it.
void _ctlThemeReset(void* hwnd) { SetWindowTheme(hwnd, nullptr, nullptr); }

// Put window `hwnd` (and thus its non-client scrollbar) into the dark or light theme.
void _applyDarkNonClient(void* hwnd, bool dark)
{
    _bindUxTheme();
    if (_uxSetPreferredAppMode != nullptr)
        _uxSetPreferredAppMode(dark ? UX_APPMODE_ALLOW_DARK : UX_APPMODE_DEFAULT);
    _allowDark(hwnd, dark);
    _ctlTheme(hwnd, dark ? "DarkMode_Explorer" : "Explorer");
    // The scrollbar lives in the frame, so only a FRAME redraw picks the new theme up.
    RedrawWindow(hwnd, nullptr, nullptr, (u32)(RDW_INVALIDATE | RDW_FRAME | RDW_NOCHILDREN));
}

// A node kind that maps to an OS control (vs a pure layout container that only
// contributes geometry to its children). VIEW/SCROLL/COMPONENT are containers.
bool nativeMappable(int kind)
{
    return kind == ELEM_BUTTON || kind == ELEM_TEXT || kind == ELEM_TEXTINPUT
        || kind == ELEM_CHECKBOX || kind == ELEM_PROGRESS || kind == ELEM_SLIDER
        || kind == ELEM_BOX || kind == ELEM_TEXTAREA || kind == ELEM_STATUSBAR
        || kind == ELEM_RADIO || kind == ELEM_COMBO || kind == ELEM_LIST
        || kind == ELEM_TABS || kind == ELEM_TREE
        || kind == ELEM_IMAGE || kind == ELEM_GROUPBOX || kind == ELEM_CANVAS;
}

// The style.backgroundColor of a plain (non-mapped) container - a View from view/row/
// column - or 0 for anything else. A non-zero value opts the container into a painted
// backdrop panel behind its children (Box maps to a real control, so it is excluded).
int _containerBg(IElement node)
{
    if (node.kind() == ELEM_VIEW) { IView v = node as IView; return v.style.backgroundColor; }
    return 0;
}

// A mappable node whose CHILDREN are laid out inside its own frame. Win32 does not parent a
// container control's contents to it (a group box / tab body / etched panel does not own its
// children), so they are flat siblings drawn on top - which only holds if the container is
// sunk below them in the sibling z-order. applyTree does that; these are the kinds it sinks.
bool _containerControl(int kind)
{
    return kind == ELEM_GROUPBOX || kind == ELEM_TABS || kind == ELEM_BOX;
}

// HWND_BOTTOM / HWND_TOP: the ends of the sibling z-order (cast macros the header binding
// does not surface). BOTTOM pushes a container backdrop behind its children; TOP lifts the
// docked status bar back above the content pane.
void* hwndBottom() { return (void*)((i64)1); }
void* hwndTop() { return nullptr; }

// The concrete tooltip text a mappable node carries ("" = none). Every tooltip-bearing
// class implements ITooltipped, so one downcast answers for all 15 of them.
string tooltipOf(IElement node)
{
    ITooltipped t = node as ITooltipped;
    if (t == nullptr) return "";
    return "" + t.tooltip;
}

// Accessibility: kinds whose window text is NOT their visible content, so they expose no
// MSAA/UIA Name on their own. For these, a tooltip is mirrored into the window text (which
// these classes do not paint) so a screen reader announces a Name - text-bearing controls
// (Button/Text/Checkbox/Radio/GroupBox/Edit) already get a Name from their window text.
bool accessibleNameKind(int k)
{
    return k == ELEM_PROGRESS || k == ELEM_SLIDER || k == ELEM_LIST || k == ELEM_TREE
        || k == ELEM_COMBO || k == ELEM_IMAGE || k == ELEM_CANVAS;
}

// -- Window: one top-level window + its IElement tree, context, and controls ----
// Implements INativeHost (each window drives its own controls). This replaces the old
// single-editor Win32Host globals; the app holds a list<Window*>. Menu declaration,
// hInstance, and the accelerator table stay app-wide (above).
class Window : INativeHost
{
    void* hwnd    = nullptr;
    // The ONE child window that carries all scrollable content (see ContentPaneProc).
    // Scrolling moves this, not the ~60 controls inside it.
    void* content = nullptr;
    // The root ScrollView's vertical scrollbar. It is the NON-CLIENT bar of a child "gutter"
    // window (see ScrollGutterProc) parked in the right column of the viewport, stopping above
    // the status bar - which owns the resize grip. The frame's own WS_VSCROLL bar cannot: it
    // spans the whole client height, status band included, and hangs a classic size box off it.
    void* vscroll = nullptr;
    void* font    = nullptr;
    void* tooltip = nullptr;         // lazily-created tooltips_class32 for this window
    bool  applying = false;          // guard: swallow self-inflicted EN_CHANGE
    u32   dpi     = 96u;             // window dpi (96 = 100%); drives DIP->px
    bool  dark    = false;           // last applied theme was dark (titlebar/bg)
    bool  themed  = false;           // the app set colors (a monochrome theme = native look)
    // The common controls (ListView/TreeView/TabControl/ProgressBar/scrollbar) currently carry
    // the DARK theming; ctlEverDark stays true once set. Until a dark theme is applied ONCE, a
    // light/monochrome app is never touched by SetWindowTheme or a color message (stock look).
    bool  ctlDark     = false;
    bool  ctlEverDark = false;
    u32   themeText = 0u;            // COLORREF for control text (WM_CTLCOLOR*)
    u32   themeBg   = 0xFFFFFFu;     // COLORREF for control/window background
    u32   themeField = 0xFFFFFFu;    // COLORREF for a data control's BODY (ListView/TreeView)
    u32   themeFieldText = 0u;       // COLORREF for a data control's row text
    u32   themeTrack = 0u;           // COLORREF for the ProgressBar trough
    u32   themeAccent = 0u;          // COLORREF for the ProgressBar filled bar
    void* bgBrush   = nullptr;       // cached solid brush of themeBg
    list<string> liveKeys    = default;   // keys with a live control this frame
    list<u64>    liveHandles = default;   // parallel handles (HWND as u64)
    // ListView rowText callback boxes: parallel HWND -> ListRowBox* (as u64). The
    // host owns these; freed on destroyControl and dispose. A Lambda cannot cross the
    // seam, so the callback rides as an opaque u64 (see setListOp / __uiListRowText).
    list<u64>    listBoxHandles = default;
    list<u64>    listBoxPtrs    = default;
    // TreeView node-source boxes: parallel HWND -> TreeBox* (as u64), like the list
    // boxes. Freed on destroyControl + dispose (a Lambda cannot cross the seam).
    list<u64>    treeBoxHandles = default;
    list<u64>    treeBoxPtrs    = default;
    // Per-key context menus: parallel key-path -> ContextMenu* (as u64). Host-owned;
    // registered via nativeSetContextMenu, freed on dispose.
    list<string> ctxKeys        = default;
    list<u64>    ctxMenus        = default;
    string       splitDragKey    = default;   // key path of a splitter being dragged ("" = none)
    // Image HBITMAPs: parallel control HWND -> HBITMAP (as u64) + the last pixel
    // buffer uploaded (to skip redundant DIB rebuilds). The host owns the bitmaps; they
    // are deleted on destroyControl + dispose (DestroyWindow does not free an STM image).
    list<u64>    imgHandles      = default;
    list<u64>    imgBitmaps      = default;
    list<u64>    imgLastPixels   = default;
    // CanvasView paint boxes: parallel child HWND -> CanvasBox* (as u64), like the
    // list/tree boxes; freed on destroyControl + dispose (a Lambda cannot cross the seam).
    list<u64>    canvasHandles   = default;
    list<u64>    canvasBoxes     = default;
    // Accent-button colors: parallel push-BUTTON HWND -> (bg, fg) COLORREF for
    // NM_CUSTOMDRAW. Only set when the theme gives a non-default button color, so a
    // monochrome theme leaves buttons at the native look (byte-identical).

    list<u64>    accentHandles   = default;
    list<u32>    accentBg        = default;
    list<u32>    accentFg        = default;
    // Container backdrops: a filled View maps to a plain STATIC keyed by the container's
    // own path. Parallel HWND -> fill COLORREF (read live by WM_CTLCOLORSTATIC), the
    // per-frame list in tree order (z-order fix), and a brush cache keyed by color.
    list<u64>    bdHandles       = default;
    list<u32>    bdColors        = default;
    list<u64>    bdFrame         = default;
    // Container CONTROLS (GroupBox/TabControl/Box) this frame, in tree order. Win32 does not
    // parent a container's contents to it - they are flat SIBLINGS - so the container must be
    // sunk below them in z, exactly like a backdrop (see applyTree's z pass).
    list<u64>    ctFrame         = default;
    bool         zDirty          = false;   // a control was created -> re-sink backdrops + containers
    list<u32>    bdBrushColors   = default;
    list<u64>    bdBrushes       = default;   // parallel HBRUSH (as u64); freed in dispose
    // Status bars: parallel HWND -> the pane text last pushed, and whether that push was
    // owner-drawn. The text is cached because SB_GETTEXT on an SBT_OWNERDRAW part returns
    // the part's item DATA, not its string - nativeStatusText reads this instead.
    list<u64>    sbHandles       = default;
    list<string> sbTexts         = default;
    list<bool>   sbOwnerDrawn    = default;
    // Host-owned vertical scroll offset for a root ScrollView (px). The element keeps
    // scrollY = 0 and lays children out at content coordinates; the host carries the offset
    // on the content pane's position, and owns the frame's scrollbar.
    int          scrollPx        = 0;
    int          scrollMaxPx     = 0;
    int          scrollContentPx = 0;
    bool         sbShown         = false;
    bool         paneClamped     = false;   // the content overflowed PANE_MAX_H (reported once)
    // The frame's client size in PHYSICAL px (WM_SIZE). The layout size (w/h, in DIPs) is
    // derived from it minus the scrollbar column, so showing the bar narrows the content.
    int          clientPxW       = 0;
    int          clientPxH       = 0;

    IComponent app   = default;       // the mounted component (this window owns it)
    IElement   tree  = default;       // the committed IElement tree
    UiContext ctx   = default;       // per-window runtime state
    bool      ready = false;
    int       w     = 80;            // client size in DIP units (layout width)
    int       h     = 30;            // client size in DIP units (layout height)

    // Physical pixels per layout DIP on each axis at the current dpi.
    int dipX() { return BASE_X * (int)this.dpi / 96; }
    int dipY() { return BASE_Y * (int)this.dpi / 96; }

    // The parent HWND a node of `elemKind` is created under. A status bar self-docks to the
    // FRAME (it must never scroll, and sitting above the pane is what clips the pane out of
    // its band); all other content lives in the content pane, which is what scrolls.
    void* parentFor(int elemKind)
    {
        if (elemKind == ELEM_STATUSBAR || this.content == nullptr) return this.hwnd;
        return this.content;
    }

    // INativeHost: create a control of `elemKind` under `parentHandle`. Returns the HWND.
    // Every control gets WS_CLIPSIBLINGS: a container control (group box, tab body) and its
    // contents are FLAT SIBLINGS, so without it the container repaints over content that was
    // never invalidated and erases it. Only a scroll's thin exposed band repaints, so any such
    // overpaint is permanent damage. Clipping + the z sink in applyTree are what prevent it.
    u64 createControl(int elemKind, u64 parentHandle, string key)
    {
        void* parent = u2h(parentHandle);
        string cls = "STATIC";
        u32 style = (u32)(WS_CHILD | WS_VISIBLE);
        if (elemKind == ELEM_BUTTON)
        {
            cls = "BUTTON";
            style = (u32)(WS_CHILD | WS_VISIBLE | WS_TABSTOP | BS_PUSHBUTTON);
        }
        else if (elemKind == ELEM_CHECKBOX)
        {
            cls = "BUTTON";
            style = (u32)(WS_CHILD | WS_VISIBLE | WS_TABSTOP | BS_AUTOCHECKBOX);
        }
        else if (elemKind == ELEM_TEXTINPUT)
        {
            cls = "EDIT";
            style = (u32)(WS_CHILD | WS_VISIBLE | WS_TABSTOP | WS_BORDER | ES_AUTOHSCROLL);
        }
        else if (elemKind == ELEM_TEXTAREA)
        {
            cls = "EDIT";
            style = (u32)(WS_CHILD | WS_VISIBLE | WS_TABSTOP | WS_BORDER | WS_VSCROLL
                          | ES_MULTILINE | ES_AUTOVSCROLL | ES_WANTRETURN);
        }
        else if (elemKind == ELEM_TEXT)
        {
            cls = "STATIC";
            style = (u32)(WS_CHILD | WS_VISIBLE | SS_LEFT);
        }
        else if (elemKind == ELEM_BOX)
        {
            cls = "STATIC";
            style = (u32)(WS_CHILD | WS_VISIBLE | SS_ETCHEDFRAME);
        }
        else if (elemKind == ELEM_PROGRESS)
        {
            cls = "msctls_progress32";
            style = (u32)(WS_CHILD | WS_VISIBLE);
        }
        else if (elemKind == ELEM_SLIDER)
        {
            cls = "msctls_trackbar32";
            style = (u32)(WS_CHILD | WS_VISIBLE | WS_TABSTOP);
        }
        else if (elemKind == ELEM_STATUSBAR)
        {
            // SBARS_SIZEGRIP: the strip owns the window's resize grip, which is where the user
            // expects it (the frame has no non-client scrollbar to hang a size box off).
            cls = "msctls_statusbar32";
            style = (u32)(WS_CHILD | WS_VISIBLE | SBARS_SIZEGRIP);
        }
        else if (elemKind == ELEM_RADIO)
        {
            cls = "BUTTON";
            style = (u32)(WS_CHILD | WS_VISIBLE | WS_TABSTOP | BS_AUTORADIOBUTTON);
        }
        else if (elemKind == ELEM_COMBO)
        {
            cls = "COMBOBOX";
            style = (u32)(WS_CHILD | WS_VISIBLE | WS_TABSTOP | CBS_DROPDOWNLIST | WS_VSCROLL);
        }
        else if (elemKind == ELEM_LIST)
        {
            cls = "SysListView32";
            style = (u32)(WS_CHILD | WS_VISIBLE | WS_TABSTOP | WS_BORDER
                          | LVS_REPORT | LVS_OWNERDATA | LVS_SINGLESEL | LVS_SHOWSELALWAYS);
        }
        else if (elemKind == ELEM_TABS)
        {
            cls = "SysTabControl32";
            style = (u32)(WS_CHILD | WS_VISIBLE);
        }
        else if (elemKind == ELEM_TREE)
        {
            cls = "SysTreeView32";
            style = (u32)(WS_CHILD | WS_VISIBLE | WS_TABSTOP | WS_BORDER
                          | TVS_HASBUTTONS | TVS_HASLINES | TVS_LINESATROOT | TVS_SHOWSELALWAYS);
        }
        else if (elemKind == ELEM_IMAGE)
        {
            // A STATIC that hosts an HBITMAP; SS_REALSIZECONTROL stretches the bitmap to
            // the control frame (the setImageData seam uploads the pixels).
            cls = "STATIC";
            style = (u32)(WS_CHILD | WS_VISIBLE | SS_BITMAP | SS_REALSIZECONTROL);
        }
        else if (elemKind == ELEM_GROUPBOX)
        {
            // A BUTTON with BS_GROUPBOX draws the titled frame; its children position as
            // siblings inside the frame (Win32 group boxes do not parent their contents).
            cls = "BUTTON";
            style = (u32)(WS_CHILD | WS_VISIBLE | BS_GROUPBOX);
        }
        else if (elemKind == ELEM_CANVAS)
        {
            // A GDI-backed child window the app paints via the ICanvas API; its own WndProc
            // (CanvasChildProc) invokes the boxed onPaint closure on WM_PAINT.
            ensureCanvasClass();
            void* ch = CreateWindowExA(0u, "CFlatCanvasChild", "",
                (u32)(WS_CHILD | WS_VISIBLE | WS_CLIPSIBLINGS),
                0, 0, 10, 10, parent, nullptr, _hInst, nullptr);
            return (u64)ch;
        }

        void* h = CreateWindowExA(0u, cls.data(), "", style | (u32)WS_CLIPSIBLINGS,
                                  0, 0, 10, 10, parent, nullptr, _hInst, nullptr);
        // A GroupBox (BS_GROUPBOX) and a Box (SS_ETCHEDFRAME) paint their frame and nothing else,
        // leaving the interior to a parent background that a WS_CLIPCHILDREN pane cannot supply.
        // Subclass them so they erase their own interior (see ContainerCtlProc). A TabControl
        // joins them in DARK mode only - its unthemed body is the same bare interior.
        if (elemKind == ELEM_GROUPBOX || elemKind == ELEM_BOX || elemKind == ELEM_TABS)
            _subclassContainerCtl(h);
        // A ListView's column header notifies the LISTVIEW, so its custom draw has to be
        // intercepted there (see ListCtlProc); a pass-through in every other theme.
        else if (elemKind == ELEM_LIST) _subclassCtl(h, (void*)ListCtlProc);
        if (this.font != nullptr)
            SendMessageA(h, (u32)WM_SETFONT, (u64)this.font, (i64)1);
        // Theme the fresh control NOW: applyTheme only re-themes on a real theme CHANGE, so a
        // control created later (a tab switch, a new card) would otherwise stay stock-light.
        this._themeControl((u64)h);
        return (u64)h;
    }

    void destroyControl(u64 h)
    {
        if (h == 0u) return;
        this._freeListBox(h);   // no-op unless h is a ListView with a boxed callback
        this._freeTreeBox(h);   // no-op unless h is a TreeView with a boxed node source
        this._freeImage(h);     // no-op unless h is an Image with an HBITMAP
        this._freeCanvasBox(h); // no-op unless h is a CanvasView with a boxed painter
        this._forgetAccent(h);
        this._freeBackdrop(h);  // no-op unless h is a container backdrop
        this._freeStatusBar(h); // no-op unless h is a status bar with cached pane text
        DestroyWindow(u2h(h));
    }

    // Batched elsewhere (applyTree uses DeferWindowPos); this immediate form is the
    // INativeHost contract for a one-off reposition. A status bar self-docks, so it is
    // repositioned by a WM_SIZE tickle rather than an absolute frame.
    void setFrame(u64 h, Rect frameDip)
    {
        MoveWindow(u2h(h), frameDip.x * this.dipX(), frameDip.y * this.dipY(),
                   frameDip.w * this.dipX(), frameDip.h * this.dipY(), 1);
    }

    // Only push text when it actually differs, so an EDIT does not reset its caret
    // (and STATIC/BUTTON do not needlessly invalidate) on every re-render.
    void setText(u64 h, const char* s)
    {
        char[512] cur;
        GetWindowTextA(u2h(h), cur, 512);
        if (strcmp(cur, (char*)s) == 0) return;
        SetWindowTextA(u2h(h), (char*)s);
    }

    void setBoolProp(u64 h, int prop, bool v)
    {
        if (prop == PROP_CHECKED)
            SendMessageA(u2h(h), (u32)BM_SETCHECK, v ? 1u : 0u, (i64)0);
        else if (prop == PROP_ENABLED)
            EnableWindow(u2h(h), v ? 1 : 0);
        else if (prop == PROP_VISIBLE)
            ShowWindow(u2h(h), v ? (int)SW_SHOW : SW_HIDE);
    }

    // Route a value/max set to the right control message by its class (keeps the
    // seam property-based: the host, not ui.cb, knows progress vs trackbar).
    void setIntProp(u64 h, int prop, int v)
    {
        char[32] cn;
        GetClassNameA(u2h(h), cn, 32);
        bool isProg = strcmp(cn, "msctls_progress32") == 0;
        bool isTrack = strcmp(cn, "msctls_trackbar32") == 0;
        if (prop == PROP_VALUE)
        {
            if (isProg)  SendMessageA(u2h(h), (u32)PBM_SETPOS, (u64)v, (i64)0);
            if (isTrack) SendMessageA(u2h(h), (u32)TBM_SETPOS, 1u, (i64)v);
        }
        else if (prop == PROP_MAX)
        {
            if (isProg)  SendMessageA(u2h(h), (u32)PBM_SETRANGE32, 0u, (i64)v);
            if (isTrack) SendMessageA(u2h(h), (u32)TBM_SETRANGE, 1u, (i64)(v << 16));
        }
    }

    // Store a push button's accent colors for NM_CUSTOMDRAW. A 0 (default) bg
    // forgets any prior accent so the button reverts to the native look; a set bg is
    // recorded as a COLORREF pair the custom-draw handler fills with. fgColor/bgColor are
    // framework colors (0 = default). Only ELEM_BUTTON calls this (see _syncProps).
    void setAccent(u64 h, int fgColor, int bgColor)
    {
        if (bgColor == 0) { this._forgetAccent(h); return; }
        u32 bg = this.colorRef(bgColor);
        u32 fg = fgColor != 0 ? this.colorRef(fgColor) : (u32)0xFFFFFFu;
        int i = 0;
        while (i < this.accentHandles.count())
        {
            if (this.accentHandles.get(i) == h)
            {
                this.accentBg.set(i, bg); this.accentFg.set(i, fg); return;
            }
            i++;
        }
        this.accentHandles.add(h); this.accentBg.add(bg); this.accentFg.add(fg);
    }

    void _forgetAccent(u64 h)
    {
        int i = 0;
        while (i < this.accentHandles.count())
        {
            if (this.accentHandles.get(i) == h)
            {
                this.accentHandles.removeAt(i); this.accentBg.removeAt(i); this.accentFg.removeAt(i);
                return;
            }
            i++;
        }
    }

    // True (with the accent colors) if control `h` has a stored accent. Drives NM_CUSTOMDRAW.
    bool accentFor(u64 h, u32* bg, u32* fg)
    {
        int i = 0;
        while (i < this.accentHandles.count())
        {
            if (this.accentHandles.get(i) == h)
            {
                bg[0] = this.accentBg.get(i); fg[0] = this.accentFg.get(i); return true;
            }
            i++;
        }
        return false;
    }

    // -- Container backdrops (a filled View painted behind its children) ------------
    // A solid brush for COLORREF `col`, created on first use. The cache holds one brush
    // per distinct backdrop color (a theme flip adds one); all are freed in dispose.
    void* _brushFor(u32 col)
    {
        int i = 0;
        while (i < this.bdBrushColors.count())
        {
            if (this.bdBrushColors.get(i) == col) return u2h(this.bdBrushes.get(i));
            i++;
        }
        void* br = CreateSolidBrush(col);
        this.bdBrushColors.add(col);
        this.bdBrushes.add((u64)br);
        return br;
    }

    // A backdrop control: a plain STATIC (no SS_NOTIFY, so it stays HTTRANSPARENT and the
    // frame still sees clicks) whose background WM_CTLCOLORSTATIC fills with its color.
    // WS_CLIPSIBLINGS is what keeps the fill BEHIND the card's controls: z-order alone only
    // sets the paint order, and an unclipped backdrop repaints its whole rect over them.
    u64 _createBackdrop()
    {
        void* h = CreateWindowExA(0u, "STATIC", "",
                                  (u32)(WS_CHILD | WS_VISIBLE | WS_CLIPSIBLINGS),
                                  0, 0, 10, 10, this.parentFor(ELEM_VIEW), nullptr, _hInst, nullptr);
        return (u64)h;
    }

    // Re-sync a backdrop's fill to the container's current color (so a theme flip
    // re-colors it) and remember it for WM_CTLCOLORSTATIC. Called every reconcile.
    void _syncBackdrop(u64 h, int bg)
    {
        u32 col = this.colorRef(bg);
        int i = 0;
        while (i < this.bdHandles.count())
        {
            if (this.bdHandles.get(i) == h)
            {
                if (this.bdColors.get(i) != col)
                {
                    this.bdColors.set(i, col);
                    InvalidateRect(u2h(h), nullptr, 1);
                }
                return;
            }
            i++;
        }
        this.bdHandles.add(h);
        this.bdColors.add(col);
    }

    void _freeBackdrop(u64 h)
    {
        int i = 0;
        while (i < this.bdHandles.count())
        {
            if (this.bdHandles.get(i) == h)
            {
                this.bdHandles.removeAt(i); this.bdColors.removeAt(i);
                return;
            }
            i++;
        }
    }

    // The brush control `h` paints its background with if it is a container backdrop
    // (nullptr otherwise); `bg` receives its COLORREF. Drives WM_CTLCOLORSTATIC.
    void* backdropBrush(u64 h, u32* bg)
    {
        int i = 0;
        while (i < this.bdHandles.count())
        {
            if (this.bdHandles.get(i) == h)
            {
                u32 col = this.bdColors.get(i);
                bg[0] = col;
                return this._brushFor(col);
            }
            i++;
        }
        return nullptr;
    }

    // -- Root ScrollView: the host owns the offset ----------------------------------
    // Re-measure the root ScrollView's content against the viewport and clamp the stored
    // offset to it. The content height is 0 when the root is not a ScrollView, so a
    // non-scrolling window ends up with scrollPx = 0 and a viewport-tall pane.
    void _updateScroll(IElement tree)
    {
        this.scrollContentPx = 0;
        if (tree.kind() == ELEM_SCROLL)
        {
            IScrollView sv = tree as IScrollView;
            if (sv != nullptr) this.scrollContentPx = sv.contentH * this.dipY();
        }
        int maxPx = this.scrollContentPx - this.h * this.dipY();
        if (maxPx < 0) maxPx = 0;
        this.scrollMaxPx = maxPx;
        if (this.scrollPx > maxPx) this.scrollPx = maxPx;
        if (this.scrollPx < 0) this.scrollPx = 0;
    }

    // Size + place the content pane: frame-wide, tall enough for the WHOLE content, and
    // shifted up by the scroll offset. Every control then sits at a fixed content
    // coordinate inside it and never moves again, so a scroll is one window move.
    void _layoutContentPane()
    {
        if (this.content == nullptr) return;
        int vw = this.w * this.dipX();
        int vh = this.h * this.dipY();
        int ph = this.scrollContentPx > vh ? this.scrollContentPx : vh;
        if (ph > PANE_MAX_H)
        {
            // Mouse messages pack client coords as SIGNED 16-bit, so a taller pane would
            // corrupt hit-testing inside its controls. Clamp, but say so - content past the
            // limit is unreachable, which is a bug in the app's layout, not a silent detail.
            if (!this.paneClamped)
                printf("ui(win32): content is %d px tall, past the %d px content-pane limit; clamped (content below is unreachable)\n",
                       ph, PANE_MAX_H);
            this.paneClamped = true;
            ph = PANE_MAX_H;
        }
        else this.paneClamped = false;
        SetWindowPos(this.content, nullptr, 0, 0 - this.scrollPx, vw, ph,
                     (u32)(SWP_NOZORDER | SWP_NOACTIVATE));
    }

    // The px column the scrollbar CONTROL occupies on the right of the viewport (0 when hidden).
    int _scrollColPx() { return this.sbShown ? GetSystemMetrics((int)SM_CXVSCROLL) : 0; }

    // The px height of the docked status bar (0 if the window has none). The scrollbar stops
    // above it, so the strip keeps the whole bottom band - including the resize grip.
    int _statusPx()
    {
        if (this.sbHandles.count() == 0) return 0;
        RECT r = default;
        GetWindowRect(u2h(this.sbHandles.get(0)), &r);
        return r.bottom - r.top;
    }

    // Derive the LAYOUT size (DIPs) from the client size, minus the scrollbar column. The old
    // non-client bar shrank the client area itself and got this for free.
    void _syncSizeDip()
    {
        if (this.clientPxW <= 0 || this.clientPxH <= 0) return;
        int nw = (this.clientPxW - this._scrollColPx()) / this.dipX();
        int nh = this.clientPxH / this.dipY();
        if (nw < 1) nw = 1;
        if (nh < 1) nh = 1;
        this.w = nw; this.h = nh;
    }

    // Park the scrollbar control in the right column of the viewport, above the status bar.
    void _layoutVScroll()
    {
        if (this.vscroll == nullptr || !this.sbShown) return;
        int col = this._scrollColPx();
        int vh = this.clientPxH - this._statusPx();
        if (vh < 0) vh = 0;
        SetWindowPos(this.vscroll, nullptr, this.clientPxW - col, 0, col, vh,
                     (u32)(SWP_NOZORDER | SWP_NOACTIVATE));
    }

    // Show (or hide) the root ScrollView's scrollbar CONTROL and size its thumb to the content.
    // A window with no overflowing root ScrollView never shows one. Showing it takes a column
    // out of the content width, so the tree has to be laid out again - which is exactly what the
    // old non-client bar got from the WM_SIZE its client-area change raised.
    void _syncScrollBar()
    {
        if (this.vscroll == nullptr) return;
        bool need = this.scrollMaxPx > 0;
        if (need != this.sbShown)
        {
            this.sbShown = need;
            ShowWindow(this.vscroll, need ? (int)SW_SHOW : SW_HIDE);
            this._syncSizeDip();
            this._layoutVScroll();
            // Re-lay-out at the new width. Inside a build this defers to the end of it
            // (_building/_rebuildPending), which is where the final geometry lands.
            int wi = findWindowIdx(this.hwnd);
            if (wi >= 0) buildWindowTree(wi);
            return;
        }
        if (!need) return;
        this._layoutVScroll();
        SCROLLINFO si = default;
        si.cbSize = (u32)sizeof(SCROLLINFO);
        si.fMask  = (u32)(SIF_RANGE | SIF_PAGE | SIF_POS);
        si.nMin   = 0;
        si.nMax   = this.scrollContentPx - 1;
        si.nPage  = (u32)(this.h * this.dipY());
        si.nPos   = this.scrollPx;
        SetScrollInfo(this.vscroll, (int)SB_VERT, &si, 1);
    }

    // The live 32-bit thumb position (WM_VSCROLL only carries 16 bits in wParam).
    int scrollTrackPos()
    {
        if (this.vscroll == nullptr) return this.scrollPx;
        SCROLLINFO si = default;
        si.cbSize = (u32)sizeof(SCROLLINFO);
        si.fMask  = (u32)SIF_TRACKPOS;
        GetScrollInfo(this.vscroll, (int)SB_VERT, &si);
        return si.nTrackPos;
    }

    // Move the root ScrollView to offset `px` (clamped). ONE window moves - the content
    // pane - so the OS blits the still-visible band and invalidates only the strip that
    // came into view; the controls inside never move and never repaint. (Re-positioning
    // all ~60 controls per notch, which is what this used to do, turned one notch into ~60
    // async WM_PAINTs and smeared the text mid-scroll.)
    void scrollTo(int px)
    {
        int p = px;
        if (p > this.scrollMaxPx) p = this.scrollMaxPx;
        if (p < 0) p = 0;
        if (p == this.scrollPx) return;
        this.scrollPx = p;
        if (this.content != nullptr)
            SetWindowPos(this.content, nullptr, 0, 0 - this.scrollPx, 0, 0,
                         (u32)(SWP_NOSIZE | SWP_NOZORDER | SWP_NOACTIVATE));
        this._syncScrollBar();   // keep the thumb on the new offset (applyTree is not run)
    }

    // -- Image DIB upload (setImageData seam + HBITMAP bookkeeping) -----------------
    // Upload a top-down BGRA32 buffer to control `h` as an HBITMAP (STM_SETIMAGE). Builds
    // a top-down 32bpp DIB section, copies the pixels into it, and swaps the control's
    // bitmap, deleting the previous one. The new HBITMAP is remembered so destroyControl /
    // dispose can free it (an STM image is not destroyed with the window).
    void setImageData(u64 h, u64 pixels, int w, int h2, int stride)
    {
        if (h == 0u || pixels == 0u || w <= 0 || h2 <= 0) return;
        void* dc = GetDC(this.hwnd);
        BmiHeader bi = default;
        bi.biSize = 40u; bi.biWidth = w; bi.biHeight = 0 - h2;   // negative = top-down
        bi.biPlanes = 1; bi.biBitCount = 32; bi.biCompression = 0u;
        void* bits = nullptr;
        void* bmp = CreateDIBSection(dc, &bi, (u32)DIB_RGB_COLORS, &bits, nullptr, 0u);
        ReleaseDC(this.hwnd, dc);
        if (bmp == nullptr || bits == nullptr) return;
        // Copy row by row (source stride may exceed w*4).
        char* src = (char*)u2h(pixels);
        char* dst = (char*)bits;
        int rowBytes = w * 4;
        int y = 0;
        while (y < h2)
        {
            memcpy((void*)(dst + (i64)(y * rowBytes)), (void*)(src + (i64)(y * stride)), (i64)rowBytes);
            y++;
        }
        void* old = (void*)SendMessageA(u2h(h), (u32)STM_SETIMAGE, (u64)IMAGE_BITMAP, (i64)bmp);
        this._rememberImage(h, (u64)bmp);
        if (old != nullptr && old != bmp) DeleteObject(old);
    }

    // Load a .bmp file into control `h` (host-internal decoder; no image library). WIC/
    // richer formats (PNG/JPG) would decode to the same BGRA buffer and ride setImageData.
    void setImageFile(u64 h, string path)
    {
        if (h == 0u || path.length() == 0) return;
        void* bmp = LoadImageA(nullptr, (char*)path.data(), (u32)IMAGE_BITMAP, 0, 0, (u32)LR_LOADFROMFILE);
        if (bmp == nullptr) return;
        void* old = (void*)SendMessageA(u2h(h), (u32)STM_SETIMAGE, (u64)IMAGE_BITMAP, (i64)bmp);
        this._rememberImage(h, (u64)bmp);
        if (old != nullptr && old != bmp) DeleteObject(old);
    }

    void _rememberImage(u64 h, u64 bmp)
    {
        int i = 0;
        while (i < this.imgHandles.count())
        {
            if (this.imgHandles.get(i) == h)
            {
                u64 prev = this.imgBitmaps.get(i);
                if (prev != 0u && prev != bmp) DeleteObject(u2h(prev));
                this.imgBitmaps.set(i, bmp); return;
            }
            i++;
        }
        this.imgHandles.add(h); this.imgBitmaps.add(bmp); this.imgLastPixels.add(0u);
    }

    // The last pixel buffer uploaded to `h` (0 if none) - lets _syncProps skip a rebuild
    // when the app hands down the same buffer pointer again.
    u64 _imgLastPixels(u64 h)
    {
        int i = 0;
        while (i < this.imgHandles.count())
        {
            if (this.imgHandles.get(i) == h) { u64 v = this.imgLastPixels.get(i); return v; }
            i++;
        }
        return 0u;
    }

    void _setImgLastPixels(u64 h, u64 px)
    {
        int i = 0;
        while (i < this.imgHandles.count())
        {
            if (this.imgHandles.get(i) == h) { this.imgLastPixels.set(i, px); return; }
            i++;
        }
        this.imgHandles.add(h); this.imgBitmaps.add(0u); this.imgLastPixels.add(px);
    }

    void _freeImage(u64 h)
    {
        int i = 0;
        while (i < this.imgHandles.count())
        {
            if (this.imgHandles.get(i) == h)
            {
                u64 bmp = this.imgBitmaps.get(i);
                if (bmp != 0u) DeleteObject(u2h(bmp));
                this.imgHandles.removeAt(i); this.imgBitmaps.removeAt(i); this.imgLastPixels.removeAt(i);
                return;
            }
            i++;
        }
    }

    // -- CanvasView paint-box bookkeeping (mirrors the list/tree boxes) -------------
    void _setCanvasBox(u64 h, u64 box)
    {
        int i = 0;
        while (i < this.canvasHandles.count())
        {
            if (this.canvasHandles.get(i) == h)
            {
                u64 old = this.canvasBoxes.get(i);
                if (old != 0u && old != box) __uiFreeCanvasBox(old);
                this.canvasBoxes.set(i, box); return;
            }
            i++;
        }
        this.canvasHandles.add(h); this.canvasBoxes.add(box);
    }

    void _freeCanvasBox(u64 h)
    {
        int i = 0;
        while (i < this.canvasHandles.count())
        {
            if (this.canvasHandles.get(i) == h)
            {
                u64 old = this.canvasBoxes.get(i);
                if (old != 0u) __uiFreeCanvasBox(old);
                this.canvasHandles.removeAt(i); this.canvasBoxes.removeAt(i);
                return;
            }
            i++;
        }
    }

    // -- ListView rowText box bookkeeping --------------------------------------
    u64 _listBoxFor(u64 h)
    {
        int i = 0;
        while (i < this.listBoxHandles.count())
        {
            if (this.listBoxHandles.get(i) == h)
            {
                u64 v = this.listBoxPtrs.get(i);
                return v;
            }
            i++;
        }
        return 0u;
    }

    // Store the box for control `h`, freeing any previous one (idempotent per frame).
    void _setListBox(u64 h, u64 box)
    {
        int i = 0;
        while (i < this.listBoxHandles.count())
        {
            if (this.listBoxHandles.get(i) == h)
            {
                u64 old = this.listBoxPtrs.get(i);
                if (old != 0u && old != box) __uiFreeListRowBox(old);
                this.listBoxPtrs.set(i, box);
                return;
            }
            i++;
        }
        this.listBoxHandles.add(h);
        this.listBoxPtrs.add(box);
    }

    void _freeListBox(u64 h)
    {
        int i = 0;
        while (i < this.listBoxHandles.count())
        {
            if (this.listBoxHandles.get(i) == h)
            {
                u64 old = this.listBoxPtrs.get(i);
                if (old != 0u) __uiFreeListRowBox(old);
                this.listBoxHandles.removeAt(i);
                this.listBoxPtrs.removeAt(i);
                return;
            }
            i++;
        }
    }

    // -- TreeView node-source box bookkeeping (mirrors the ListView boxes) ------
    u64 _treeBoxFor(u64 h)
    {
        int i = 0;
        while (i < this.treeBoxHandles.count())
        {
            if (this.treeBoxHandles.get(i) == h) { u64 v = this.treeBoxPtrs.get(i); return v; }
            i++;
        }
        return 0u;
    }

    void _setTreeBox(u64 h, u64 box)
    {
        int i = 0;
        while (i < this.treeBoxHandles.count())
        {
            if (this.treeBoxHandles.get(i) == h)
            {
                u64 old = this.treeBoxPtrs.get(i);
                if (old != 0u && old != box) __uiFreeTreeBox(old);
                this.treeBoxPtrs.set(i, box);
                return;
            }
            i++;
        }
        this.treeBoxHandles.add(h);
        this.treeBoxPtrs.add(box);
    }

    void _freeTreeBox(u64 h)
    {
        int i = 0;
        while (i < this.treeBoxHandles.count())
        {
            if (this.treeBoxHandles.get(i) == h)
            {
                u64 old = this.treeBoxPtrs.get(i);
                if (old != 0u) __uiFreeTreeBox(old);
                this.treeBoxHandles.removeAt(i);
                this.treeBoxPtrs.removeAt(i);
                return;
            }
            i++;
        }
    }

    // Read a tree item's lParam (the app's nodeId) via TVM_GETITEM.
    int _treeItemParam(void* ctrl, void* hItem)
    {
        TVItemA it = default;
        it.mask = (u32)TVIF_PARAM;
        it.hItem = hItem;
        SendMessageA(ctrl, (u32)TVM_GETITEMA, 0u, (i64)&it);
        return (int)it.lParam;
    }

    // Insert one node (nodeId) under `parent` (nullptr = root). The lParam carries the
    // nodeId; a node with children sets cChildren=1 so the OS shows an expander and
    // fires TVN_ITEMEXPANDING, at which point _treeExpandItem materializes the children.
    void* _treeInsert(u64 h, u64 box, void* parent, int nodeId)
    {
        void* ctrl = u2h(h);
        string lbl = __uiTreeLabel(box, nodeId);
        TVInsertA ins = default;
        ins.hParent = parent == nullptr ? tviRoot() : parent;
        ins.hInsertAfter = tviLast();
        ins.mask = (u32)(TVIF_TEXT | TVIF_PARAM);
        ins.pszText = (char*)lbl.data();
        ins.lParam = (i64)nodeId;
        if (__uiTreeChildCount(box, nodeId) > 0)
        {
            ins.mask = ins.mask | (u32)TVIF_CHILDREN;
            ins.cChildren = 1;
        }
        return (void*)SendMessageA(ctrl, (u32)TVM_INSERTITEMA, 0u, (i64)&ins);
    }

    // Clear the tree and insert the root's children (the top-level nodes), lazily.
    void _treeBuildRoot(u64 h)
    {
        u64 box = this._treeBoxFor(h);
        if (box == 0u) return;
        void* ctrl = u2h(h);
        SendMessageA(ctrl, (u32)TVM_DELETEITEM, 0u, (i64)tviRoot());   // TVI_ROOT clears all
        int n = __uiTreeChildCount(box, TREE_ROOT);
        int i = 0;
        while (i < n) { this._treeInsert(h, box, nullptr, __uiTreeChildId(box, TREE_ROOT, i)); i++; }
    }

    // Materialize a node's children on first expand (idempotent: skip if already done).
    void _treeExpandItem(u64 h, void* hItem)
    {
        u64 box = this._treeBoxFor(h);
        if (box == 0u) return;
        void* ctrl = u2h(h);
        void* firstChild = (void*)SendMessageA(ctrl, (u32)TVM_GETNEXTITEM, (u64)TVGN_CHILD, (i64)hItem);
        if (firstChild != nullptr) return;   // already materialized
        int nodeId = this._treeItemParam(ctrl, hItem);
        int n = __uiTreeChildCount(box, nodeId);
        int i = 0;
        while (i < n) { this._treeInsert(h, box, hItem, __uiTreeChildId(box, nodeId, i)); i++; }
    }

    // Rebuild a tab strip when its pane count changes, then set the controlled selection.
    void _syncTabs(u64 h, ITabControl tc)
    {
        void* ctrl = u2h(h);
        int have = (int)SendMessageA(ctrl, (u32)TCM_GETITEMCOUNT, 0u, (i64)0);
        if (have != tc.children.count())
        {
            this.setListOp(h, LISTOP_TAB_RESET, 0, 0, "", 0u);
            int i = 0;
            while (i < tc.children.count())
            {
                string t = tc._title(i);
                this.setListOp(h, LISTOP_TAB_ADD, i, 0, t.data(), 0u);
                i++;
            }
        }
        this.setListOp(h, LISTOP_TAB_SET_SEL, tc.selectedTab, 0, "", 0u);
    }

    // The setListOp seam (see ui_native.cb for the cross-toolkit protocol design).
    void setListOp(u64 h, int op, int arg0, int arg1, const char* text, u64 payload)
    {
        void* ctrl = u2h(h);
        if (op == LISTOP_RESET_COLUMNS)
        {
            while (SendMessageA(ctrl, (u32)LVM_DELETECOLUMN, 0u, (i64)0) != (i64)0) { }
        }
        else if (op == LISTOP_ADD_COLUMN)
        {
            LVColumnA col = default;
            col.mask = (u32)(LVCF_FMT | LVCF_WIDTH | LVCF_TEXT | LVCF_SUBITEM);
            col.cx = arg0 * this.dipX();
            col.pszText = (char*)text;
            col.iSubItem = arg1;
            SendMessageA(ctrl, (u32)LVM_INSERTCOLUMNA, (u64)arg1, (i64)&col);
        }
        else if (op == LISTOP_SET_ROWCOUNT)
        {
            SendMessageA(ctrl, (u32)LVM_SETITEMCOUNT, (u64)arg0, (i64)0);
        }
        else if (op == LISTOP_SET_ROWTEXT_CB)
        {
            this._setListBox(h, payload);
            SendMessageA(ctrl, (u32)LVM_SETEXTENDEDLISTVIEWSTYLE,
                         (u64)LVS_EX_FULLROWSELECT, (i64)LVS_EX_FULLROWSELECT);
        }
        else if (op == LISTOP_SET_SELECT_MODE)
        {
            i64 st = GetWindowLongPtrA(ctrl, (int)GWL_STYLE);
            if (arg0 == 0) st = st | (i64)LVS_SINGLESEL;
            else st = st & ~((i64)LVS_SINGLESEL);
            SetWindowLongPtrA(ctrl, (int)GWL_STYLE, st);
        }
        else if (op == LISTOP_SET_SELECTION)
        {
            int cur = (int)SendMessageA(ctrl, (u32)LVM_GETNEXTITEM, (u64)(i64)(-1), (i64)LVNI_SELECTED);
            if (cur == arg0) return;   // already in the requested state (incl. both -1)
            LVItemA clr = default;
            clr.stateMask = (u32)LVIS_SELECTED;
            SendMessageA(ctrl, (u32)LVM_SETITEMSTATE, (u64)(i64)(-1), (i64)&clr);
            if (arg0 >= 0)
            {
                LVItemA it = default;
                it.stateMask = (u32)(LVIS_SELECTED | LVIS_FOCUSED);
                it.state = (u32)(LVIS_SELECTED | LVIS_FOCUSED);
                SendMessageA(ctrl, (u32)LVM_SETITEMSTATE, (u64)arg0, (i64)&it);
            }
        }
        else if (op == LISTOP_INVALIDATE)
        {
            InvalidateRect(ctrl, nullptr, 1);
        }
        else if (op == LISTOP_TAB_RESET)
        {
            SendMessageA(ctrl, (u32)TCM_DELETEALLITEMS, 0u, (i64)0);
        }
        else if (op == LISTOP_TAB_ADD)
        {
            TCItemA ti = default;
            ti.mask = (u32)TCIF_TEXT;
            ti.pszText = (char*)text;
            SendMessageA(ctrl, (u32)TCM_INSERTITEMA, (u64)arg0, (i64)&ti);
        }
        else if (op == LISTOP_TAB_SET_SEL)
        {
            int cur = (int)SendMessageA(ctrl, (u32)TCM_GETCURSEL, 0u, (i64)0);
            if (cur != arg0) SendMessageA(ctrl, (u32)TCM_SETCURSEL, (u64)arg0, (i64)0);
        }
        else if (op == LISTOP_TREE_SET_SRC_CB)
        {
            this._setTreeBox(h, payload);
        }
        else if (op == LISTOP_TREE_REBUILD)
        {
            this._treeBuildRoot(h);
        }
    }

    // Text metrics in DIPs. Selects the UI font into a screen DC and measures.
    Size measureText(const char* s, int fontId, int wrapWidthDip)
    {
        Size sz = default;
        void* dc = GetDC(this.hwnd);
        void* oldF = nullptr;
        if (this.font != nullptr) oldF = SelectObject(dc, this.font);
        SIZE px = default;
        GetTextExtentPoint32A(dc, (char*)s, strlen((char*)s), &px);
        if (oldF != nullptr) SelectObject(dc, oldF);
        ReleaseDC(this.hwnd, dc);
        sz.w = ((int)px.cx + this.dipX() - 1) / this.dipX();
        sz.h = ((int)px.cy + this.dipY() - 1) / this.dipY();
        return sz;
    }

    void requestLayout()
    {
        if (!this.ready) return;
        layoutRootBounded(this.tree, 0, 0, this.w, this.h);
        this.applyTree(this.tree, &this.ctx);
    }

    // Ensure this window has a tooltip control, then set/update the tip text for the
    // control `hCtl`. A tooltip control tracks tools by (owner hwnd, uId=control hwnd).
    void setTooltip(u64 hCtl, string text)
    {
        if (text.length() == 0) return;
        if (this.tooltip == nullptr)
        {
            this.tooltip = CreateWindowExA(0u, "tooltips_class32", "",
                (u32)(WS_POPUP | TTS_ALWAYSTIP), 0, 0, 0, 0,
                this.hwnd, nullptr, _hInst, nullptr);
        }
        if (this.tooltip == nullptr) return;
        TTInfoA ti = default;
        ti.cbSize = (u32)sizeof(TTInfoA);
        ti.uFlags = (u32)(TTF_IDISHWND | TTF_SUBCLASS);
        // For a TTF_IDISHWND tool, uId is the control and hwnd is the window CONTAINING it -
        // the content pane for content controls, the frame for the docked status bar.
        ti.hwnd = GetParent(u2h(hCtl));
        ti.uId = (u64)u2h(hCtl);
        ti.lpszText = (char*)text.data();
        // ADD is idempotent-ish here; UPDATE keeps an existing tool's text fresh.
        SendMessageA(this.tooltip, (u32)TTM_ADDTOOLA, 0u, (i64)&ti);
        SendMessageA(this.tooltip, (u32)TTM_UPDATETIPTEXTA, 0u, (i64)&ti);
    }

    // Reconcile the IElement tree to native controls: ensure a control per mappable
    // node (create on first sight, reuse by key path), sync its props, collect its
    // frame, then batch-position everything and destroy controls that left the tree.
    void applyTree(IElement tree, IUiContext ctx)
    {
        this.applying = true;
        this.bdFrame.clear();
        this.ctFrame.clear();

        list<string> newKeys    = default;
        list<u64>    newHandles = default;
        list<int> fx = default; list<int> fy = default;
        list<int> fw = default; list<int> fh = default;

        this._applyNode(tree, keySegment(tree, 0), ctx,
                        &newKeys, &newHandles, &fx, &fy, &fw, &fh);

        // Re-measure the root ScrollView and clamp the offset; the content pane carries it.
        this._updateScroll(tree);

        // Destroy controls whose key path is no longer in the tree.
        int i = 0;
        while (i < this.liveKeys.count())
        {
            string k = this.liveKeys.get(i);
            if (!listHasStr(&newKeys, k))
            {
                u64 h = ctx.nativeHandle(k);
                this.destroyControl(h);
                ctx.removeNativeHandle(k);
            }
            i++;
        }

        // Grow/shrink the pane BEFORE placing the controls, so a control that moved into the
        // freshly grown band lands inside a pane that already covers it.
        this._layoutContentPane();
        this._positionControls(&newHandles, &fx, &fy, &fw, &fh);

        // Re-sink the layers a create disturbed. CreateWindow appends a child to the END of the
        // sibling z-order, so within the pane creation order IS top-to-bottom z: a backdrop and
        // a container control (both created before the content they sit behind) end up ON TOP of
        // it. Sink them, deepest first, so each list ends up bottom-most in its own tree order:
        // containers first, then backdrops under them. Final z, bottom -> top:
        //   backdrops (outermost lowest) < containers (outermost lowest) < every other control.
        if (this.zDirty)
        {
            this._sinkFrame(&this.ctFrame);
            this._sinkFrame(&this.bdFrame);
            this.zDirty = false;
        }

        // Replace the live sets with copies (clear + add, not a move-assign, which
        // repeated per frame corrupted the heap - avoid container move-into-field).
        this.liveKeys.clear();
        this.liveHandles.clear();
        int m = 0;
        while (m < newKeys.count())
        {
            this.liveKeys.add("" + newKeys.get(m));
            this.liveHandles.add(newHandles.get(m));
            m++;
        }
        this.applyTheme(ctx);
        this.applying = false;
        // Last: showing/hiding the scrollbar changes the client area, so let any WM_SIZE
        // it raises land on a fully reconciled window.
        this._syncScrollBar();
    }

    // Sink every window in `hs` to the bottom of the sibling z-order, LAST first, so that
    // hs[0] (the outermost node in tree order) ends up bottom-most and a nested one sits above
    // it. Everything not in `hs` is left above the whole group.
    void _sinkFrame(list<u64>* hs)
    {
        int z = hs.count() - 1;
        while (z >= 0)
        {
            SetWindowPos(u2h(hs.get(z)), hwndBottom(), 0, 0, 0, 0,
                         (u32)(SWP_NOMOVE | SWP_NOSIZE | SWP_NOACTIVATE));
            z--;
        }
    }

    // Batch-position controls at their CONTENT frames in one DeferWindowPos pass (flicker
    // defense: the OS moves them together rather than one repaint each). Frames are pure
    // content coordinates - the scroll offset rides on the content pane, so a scroll never
    // touches this. A frame width of -1 marks a self-docking status bar (a FRAME child, so
    // it is never batched: DeferWindowPos requires one common parent), tickled with WM_SIZE.
    void _positionControls(list<u64>* handles, list<int>* fx, list<int>* fy,
                           list<int>* fw, list<int>* fh)
    {
        int n = handles.count();
        if (n <= 0) return;
        u32 flags = (u32)(SWP_NOZORDER | SWP_NOACTIVATE);
        void* hdwp = BeginDeferWindowPos(n);
        int j = 0;
        while (j < n)
        {
            if (fw.get(j) < 0)
            {
                SendMessageA(u2h(handles.get(j)), (u32)WM_SIZE, 0u, (i64)0);
            }
            else
            {
                hdwp = DeferWindowPos(hdwp, u2h(handles.get(j)), nullptr,
                                      fx.get(j), fy.get(j), fw.get(j), fh.get(j),
                                      flags);
            }
            j++;
        }
        EndDeferWindowPos(hdwp);
    }

    // Recursive worker: `path` is this node's key path. Mappable nodes get a
    // control + synced props + a collected frame; every node recurses into its
    // children (containers contribute only geometry).
    void _applyNode(IElement node, string path, IUiContext ctx,
                    list<string>* keys, list<u64>* handles,
                    list<int>* fx, list<int>* fy, list<int>* fw, list<int>* fh)
    {
        if (nativeMappable(node.kind()))
        {
            u64 h = ctx.nativeHandle(path);
            if (h == 0u)
            {
                h = this.createControl(node.kind(), (u64)this.parentFor(node.kind()), path);
                ctx.setNativeHandle(path, h);
                // The new control landed at the BOTTOM of the sibling z-order, i.e. under the
                // backdrops and containers it must paint above. Re-sink them after this pass.
                this.zDirty = true;
                // One-time seed of a TextArea's buffer (it is uncontrolled after;
                // the native EDIT owns the text, further pushes are explicit).
                if (node.kind() == ELEM_TEXTAREA)
                {
                    ITextArea ta = node as ITextArea;
                    this.setText(h, ta.value.data());
                }
                else if (node.kind() == ELEM_LIST)
                {
                    // One-time ListView setup: columns, select mode, and the rowText
                    // callback box (captures the component pointer, so it reads live
                    // state across renders - no per-frame re-box). Rows/selection are
                    // pushed every frame in _syncProps.
                    IListView lv = node as IListView;
                    this.setListOp(h, LISTOP_RESET_COLUMNS, 0, 0, "", 0u);
                    int ci = 0;
                    while (ci < lv.columns.count())
                    {
                        int wdip = 12;
                        if (ci < lv.colWidths.count()) wdip = lv.colWidths.get(ci);
                        this.setListOp(h, LISTOP_ADD_COLUMN, wdip, ci, lv.columns.get(ci).data(), 0u);
                        ci++;
                    }
                    this.setListOp(h, LISTOP_SET_SELECT_MODE, lv.multiSelect ? 1 : 0, 0, "", 0u);
                    // Inline _boxListRow call-result cast to u64: no named owning local,
                    // so nothing auto-frees the box the host now owns (mirrors ctx.post).
                    this.setListOp(h, LISTOP_SET_ROWTEXT_CB, 0, 0, "", (u64)_boxListRow(lv.rowText));
                }
                else if (node.kind() == ELEM_RADIO)
                {
                    // Mark the first radio of a group as its WS_GROUP boundary so Win32
                    // auto-exclusivity is scoped correctly with multiple groups.
                    IRadioButton rb = node as IRadioButton;
                    if (rb.groupFirst)
                    {
                        i64 st = GetWindowLongPtrA(u2h(h), (int)GWL_STYLE);
                        SetWindowLongPtrA(u2h(h), (int)GWL_STYLE, st | (i64)WS_GROUP);
                    }
                }
                else if (node.kind() == ELEM_STATUSBAR)
                {
                    // A status bar is a FRAME child, and the common control self-docks itself
                    // to the BOTTOM of the z-order - i.e. under the content pane, which is
                    // content-tall and would cover it. Raise it above the pane once (this
                    // survives the per-reconcile WM_SIZE re-dock): the pane's WS_CLIPSIBLINGS
                    // then excludes the status band, so scrolled content never paints through
                    // the strip. That clipping is also what the old SWP_NOCOPYBITS was for.
                    SetWindowPos(u2h(h), hwndTop(), 0, 0, 0, 0,
                                 (u32)(SWP_NOMOVE | SWP_NOSIZE | SWP_NOACTIVATE));
                }
                else if (node.kind() == ELEM_TREE)
                {
                    // One-time TreeView setup: box the node-source callbacks (they capture
                    // the component pointer, so they read live state across renders) and
                    // build the root's children lazily. Rows expand on demand thereafter.
                    ITreeView tv = node as ITreeView;
                    this.setListOp(h, LISTOP_TREE_SET_SRC_CB, 0, 0, "",
                                   (u64)_boxTree(tv.childCount, tv.childId, tv.label));
                    this.setListOp(h, LISTOP_TREE_REBUILD, 0, 0, "", 0u);
                }
                else if (node.kind() == ELEM_CANVAS)
                {
                    // One-time CanvasView setup: box the onPaint closure (captures the
                    // component, so it reads live state across renders) and stash it in the
                    // child's USERDATA so CanvasChildProc reaches it on WM_PAINT.
                    ICanvasView cvw = node as ICanvasView;
                    u64 box = (u64)_boxCanvas(cvw.onPaint);
                    this._setCanvasBox(h, box);
                    SetWindowLongPtrA(u2h(h), (int)GWLP_USERDATA, (i64)box);
                }
            }
            this._syncProps(node, h);
            // A container control is drawn UNDER its (sibling) contents; remember it in tree
            // order so applyTree's z pass can sink it there.
            if (_containerControl(node.kind())) this.ctFrame.add(h);
            string tip = tooltipOf(node);
            if (tip.length() > 0) this.setTooltip(h, tip);
            // Name-only: mirror the tooltip into the window text of a textless control so it
            // exposes an accessible Name (no visual change - these classes do not paint it).
            if (tip.length() > 0 && accessibleNameKind(node.kind())) SetWindowTextA(u2h(h), tip.data());
            Rect b = node.nodeBounds();
            keys.add("" + path);
            handles.add(h);
            // A status bar self-docks (width -1 sentinel); others get an absolute frame.
            if (node.kind() == ELEM_STATUSBAR)
            {
                fx.add(0); fy.add(0); fw.add(-1); fh.add(0);
            }
            else
            {
                int fhpx = b.h * this.dipY();
                // A dropdown-list combo's height param sizes the dropped list; add rows
                // so the list is usable (the collapsed field height is fixed by the OS).
                if (node.kind() == ELEM_COMBO) fhpx = fhpx + 8 * this.dipY();
                fx.add(b.x * this.dipX()); fy.add(b.y * this.dipY());
                fw.add(b.w * this.dipX()); fh.add(fhpx);
            }
        }
        else if (_containerBg(node) != 0)
        {
            // A plain container with a fill gets a painted backdrop panel (keyed by the
            // container's OWN path) behind its children; it recurses into children below
            // like any container, and rides the same create/reuse/destroy/position pass.
            int bg = _containerBg(node);
            u64 h = ctx.nativeHandle(path);
            if (h == 0u)
            {
                h = this._createBackdrop();
                ctx.setNativeHandle(path, h);
                this.zDirty = true;
            }
            this._syncBackdrop(h, bg);
            this.bdFrame.add(h);
            Rect b = node.nodeBounds();
            keys.add("" + path);
            handles.add(h);
            fx.add(b.x * this.dipX()); fy.add(b.y * this.dipY());
            fw.add(b.w * this.dipX()); fh.add(b.h * this.dipY());
        }

        // A TabControl walks ONLY its active pane into native controls (lazy inactive
        // tabs). Every other container recurses into all children; leaves have none.
        if (node.kind() == ELEM_TABS)
        {
            ITabControl tc = node as ITabControl;
            list<IElement>* panes = node.childList();
            int sel = tc.selectedTab;
            if (panes != nullptr && sel >= 0 && sel < panes.count())
            {
                IElement pane = panes.get(sel);
                string cp = joinKeyPath(path, keySegment(pane, sel));
                this._applyNode(pane, cp, ctx, keys, handles, fx, fy, fw, fh);
            }
            return;
        }

        list<IElement>* kids = node.childList();
        if (kids != nullptr)
        {
            int i = 0;
            while (i < kids.count())
            {
                IElement c = kids.get(i);
                string cp = joinKeyPath(path, keySegment(c, i));
                this._applyNode(c, cp, ctx, keys, handles, fx, fy, fw, fh);
                i++;
            }
        }
    }

    // Set a status bar's part text (single pane spanning the strip). The push is skipped
    // when neither the text nor the draw mode changed, so a per-pump reconcile does not
    // invalidate the strip (that churn is a flicker source of its own).
    void _syncStatusBar(u64 h, IStatusBar sb)
    {
        int rightEdge = -1;   // one part filling the whole width
        SendMessageA(u2h(h), (u32)SB_SETPARTS, 1u, (i64)&rightEdge);
        string joined = "";
        int i = 0;
        while (i < sb.parts.count())
        {
            if (i > 0) joined = joined + "   ";
            joined = joined + sb.parts.get(i);
            i++;
        }
        bool owner = this.themed;
        int slot = this._sbSlot(h);
        if (this.sbTexts.get(slot) == joined && this.sbOwnerDrawn.get(slot) == owner) return;
        this.sbTexts.set(slot, "" + joined);
        this.sbOwnerDrawn.set(slot, owner);
        this._pushStatusText(h, joined, owner);
    }

    // Push the pane text with the current draw mode. An owner-drawn part makes the control
    // send the PARENT a WM_DRAWITEM instead of painting the text itself (see _drawStatusItem).
    void _pushStatusText(u64 h, string text, bool owner)
    {
        u64 part = owner ? (u64)((int)0 | SBT_OWNERDRAW) : 0u;
        SendMessageA(u2h(h), (u32)SB_SETTEXTA, part, (i64)text.data());
    }

    // The cache slot for status bar `h`, appended on first sight.
    int _sbSlot(u64 h)
    {
        int i = 0;
        while (i < this.sbHandles.count())
        {
            if (this.sbHandles.get(i) == h) return i;
            i++;
        }
        this.sbHandles.add(h);
        this.sbTexts.add("");
        this.sbOwnerDrawn.add(false);
        return this.sbHandles.count() - 1;
    }

    void _freeStatusBar(u64 h)
    {
        int i = 0;
        while (i < this.sbHandles.count())
        {
            if (this.sbHandles.get(i) == h)
            {
                this.sbHandles.removeAt(i); this.sbTexts.removeAt(i);
                this.sbOwnerDrawn.removeAt(i);
                return;
            }
            i++;
        }
    }

    // The text last pushed to status bar `h` ("" if none). SB_GETTEXT cannot serve this:
    // on an SBT_OWNERDRAW part it returns the part's item data, not the string.
    string statusTextOf(u64 h)
    {
        int i = 0;
        while (i < this.sbHandles.count())
        {
            if (this.sbHandles.get(i) == h) return "" + this.sbTexts.get(i);
            i++;
        }
        return "";
    }

    // True if `h` is one of this window's status bars.
    bool isStatusBar(u64 h)
    {
        int i = 0;
        while (i < this.sbHandles.count())
        {
            if (this.sbHandles.get(i) == h) return true;
            i++;
        }
        return false;
    }

    // Theme ONE status bar: a msctls_statusbar32 is a COMMON CONTROL - it paints itself and
    // ignores WM_CTLCOLORSTATIC, so the strip is colored with SB_SETBKCOLOR (which a
    // visual-styled control ignores, hence SetWindowTheme(sb, "", "") first) and the pane text
    // is owner-drawn by the parent. A monochrome theme keeps the native look.
    void _themeStatusBar(u64 h)
    {
        void* sbh = u2h(h);
        int slot = this._sbSlot(h);
        if (this.themed)
        {
            _ctlThemeNone(sbh);   // drop visual styles: SB_SETBKCOLOR is honored
            SendMessageA(sbh, (u32)SB_SETBKCOLOR, 0u, (i64)(u64)this.themeBg);
        }
        else
        {
            _ctlThemeReset(sbh);
            SendMessageA(sbh, (u32)SB_SETBKCOLOR, 0u, (i64)(u64)CLR_DEFAULT);
        }
        this.sbOwnerDrawn.set(slot, this.themed);
        // A copy: a by-value string arg MOVES, which would empty the cache element.
        string cur = "" + this.sbTexts.get(slot);
        this._pushStatusText(h, cur, this.themed);
        InvalidateRect(sbh, nullptr, 1);
    }

    // Re-theme every live status bar (a theme change).
    void _applyStatusTheme()
    {
        int i = 0;
        while (i < this.sbHandles.count()) { this._themeStatusBar(this.sbHandles.get(i)); i++; }
    }

    // -- Dark mode for the COMMON CONTROLS -------------------------------------------
    // A common control paints itself: it ignores WM_CTLCOLOR*, so the window brush that darkens
    // every STATIC/BUTTON/EDIT does nothing for it. Each class needs its own route, and each is
    // REVERSIBLE - the light path restores the class default, so a light or monochrome theme
    // keeps the stock native look. Dispatch is by class name (the live set carries handles only).
    void _themeControl(u64 h)
    {
        char[32] cn;
        GetClassNameA(u2h(h), cn, 32);
        if (strcmp(cn, "msctls_statusbar32") == 0) { this._themeStatusBar(h); return; }
        // The rest are only ever touched once the window HAS been dark: an app that never goes
        // dark keeps the stock control, untouched by SetWindowTheme or a color message.
        if (!this.ctlEverDark) return;
        if (strcmp(cn, "SysListView32") == 0)       this._themeListView(h);
        else if (strcmp(cn, "SysTreeView32") == 0)  this._themeTreeView(h);
        else if (strcmp(cn, "SysTabControl32") == 0) this._themeTabs(h);
        else if (strcmp(cn, "msctls_progress32") == 0) this._themeProgress(h);
    }

    // ListView: the body takes DarkMode_Explorer (dark scrollbars + hot track) plus explicit
    // row colors; the HEADER is a separate control with its own theme (ItemsView, which the
    // dark app mode renders dark).
    void _themeListView(u64 h)
    {
        void* ctrl = u2h(h);
        void* hdr = (void*)SendMessageA(ctrl, (u32)LVM_GETHEADER, 0u, (i64)0);
        bool dk = this.ctlDark;
        _allowDark(ctrl, dk);
        if (dk) _ctlTheme(ctrl, "DarkMode_Explorer"); else _ctlThemeReset(ctrl);
        if (hdr != nullptr)
        {
            _allowDark(hdr, dk);
            if (dk) _ctlTheme(hdr, "ItemsView"); else _ctlThemeReset(hdr);
        }
        u32 bg = dk ? this.themeField : (u32)GetSysColor((int)COLOR_WINDOW);
        u32 tx = dk ? this.themeFieldText : (u32)GetSysColor((int)COLOR_WINDOWTEXT);
        SendMessageA(ctrl, (u32)LVM_SETBKCOLOR, 0u, (i64)(u64)bg);
        SendMessageA(ctrl, (u32)LVM_SETTEXTBKCOLOR, 0u, (i64)(u64)bg);
        SendMessageA(ctrl, (u32)LVM_SETTEXTCOLOR, 0u, (i64)(u64)tx);
        InvalidateRect(ctrl, nullptr, 1);
    }

    // TreeView: DarkMode_Explorer gives the dark expander glyphs + scrollbars; the row/line
    // colors are control messages. CLR_NONE restores each to the system default.
    void _themeTreeView(u64 h)
    {
        void* ctrl = u2h(h);
        bool dk = this.ctlDark;
        _allowDark(ctrl, dk);
        if (dk) _ctlTheme(ctrl, "DarkMode_Explorer"); else _ctlThemeReset(ctrl);
        u32 bg = dk ? this.themeField : CLR_NONE;
        u32 tx = dk ? this.themeFieldText : CLR_NONE;
        u32 ln = dk ? shadeRef(this.themeField, 40) : CLR_DEFAULT;
        SendMessageA(ctrl, (u32)TVM_SETBKCOLOR, 0u, (i64)(u64)bg);
        SendMessageA(ctrl, (u32)TVM_SETTEXTCOLOR, 0u, (i64)(u64)tx);
        SendMessageA(ctrl, (u32)TVM_SETLINECOLOR, 0u, (i64)(u64)ln);
        InvalidateRect(ctrl, nullptr, 1);
    }

    // TabControl: no dark uxtheme class exists and it ignores NM_CUSTOMDRAW, so dark mode drops
    // its visual styles, owner-draws the tab ITEMS (WM_DRAWITEM -> _drawTabItem), and lets the
    // container subclass fill the body. Light restores the theme and the stock item draw.
    void _themeTabs(u64 h)
    {
        void* ctrl = u2h(h);
        bool dk = this.ctlDark;
        i64 st = GetWindowLongPtrA(ctrl, (int)GWL_STYLE);
        if (dk) st = st | (i64)TCS_OWNERDRAWFIXED;
        else st = st & ~((i64)TCS_OWNERDRAWFIXED);
        SetWindowLongPtrA(ctrl, (int)GWL_STYLE, st);
        if (dk) _ctlThemeNone(ctrl); else _ctlThemeReset(ctrl);
        SetWindowPos(ctrl, nullptr, 0, 0, 0, 0,
                     (u32)(SWP_NOMOVE | SWP_NOSIZE | SWP_NOZORDER | SWP_NOACTIVATE | SWP_FRAMECHANGED));
        InvalidateRect(ctrl, nullptr, 1);
    }

    // ProgressBar: a visual-styled bar IGNORES both color messages, so dark mode drops the
    // theme first and paints the trough/bar from the theme. CLR_DEFAULT restores the default.
    void _themeProgress(u64 h)
    {
        void* ctrl = u2h(h);
        bool dk = this.ctlDark;
        if (dk) _ctlThemeNone(ctrl); else _ctlThemeReset(ctrl);
        SendMessageA(ctrl, (u32)PBM_SETBKCOLOR, 0u, (i64)(u64)(dk ? this.themeTrack : CLR_DEFAULT));
        SendMessageA(ctrl, (u32)PBM_SETBARCOLOR, 0u, (i64)(u64)(dk ? this.themeAccent : CLR_DEFAULT));
        InvalidateRect(ctrl, nullptr, 1);
    }

    // Re-theme every live control. Driven ONLY by a real theme change (see applyTheme):
    // re-theming per pump would flicker. The scroll gutter's bar is NON-CLIENT, so it rides
    // _applyDarkNonClient with the frame instead.
    void _applyControlTheme()
    {
        int i = 0;
        while (i < this.liveHandles.count()) { this._themeControl(this.liveHandles.get(i)); i++; }
    }

    // Paint an owner-drawn LIST HEADER. The header is a separate control that paints itself from
    // the SYSTEM colors and carries no color message - NM_CUSTOMDRAW (which reaches us through
    // the ListView subclass, since the header notifies its parent) is the only way in. Each item
    // is drawn at CDDS_ITEMPREPAINT; the strip PAST the last column is only ours at
    // CDDS_POSTPAINT, because the control fills its own background after CDDS_PREPAINT.
    bool _drawListHeader(i64 lParam, i64* result)
    {
        if (!this.ctlDark) return false;
        char* p = (char*)u2h((u64)lParam);
        u32* stagePtr = (u32*)(p + 24);
        u32 stage = stagePtr[0];
        if (stage == (u32)CDDS_PREPAINT)
        {
            result[0] = (i64)(CDRF_NOTIFYITEMDRAW | CDRF_NOTIFYPOSTPAINT);
            return true;
        }
        if (stage != (u32)CDDS_ITEMPREPAINT && stage != (u32)CDDS_POSTPAINT) return false;

        NMHDR* nh = (NMHDR*)u2h((u64)lParam);
        void** hdcPtr = (void**)(p + 32);
        void* hdc = hdcPtr[0];
        i32* rcPtr = (i32*)(p + 40);
        i64* specPtr = (i64*)(p + 56);   // dwItemSpec = the column index
        u32 fill = shadeRef(this.themeBg, 14);

        RECT rc = default;
        rc.left = rcPtr[0]; rc.top = rcPtr[1]; rc.right = rcPtr[2]; rc.bottom = rcPtr[3];

        if (stage == (u32)CDDS_POSTPAINT)
        {
            // rc is the whole header; fill only what the columns left behind.
            int n = (int)SendMessageA(nh.hwndFrom, (u32)HDM_GETITEMCOUNT, 0u, (i64)0);
            if (n > 0)
            {
                RECT last = default;
                SendMessageA(nh.hwndFrom, (u32)HDM_GETITEMRECT, (u64)(i64)(n - 1), (i64)&last);
                rc.left = last.right;
            }
            if (rc.right > rc.left) FillRect(hdc, &rc, this._brushFor(fill));
            result[0] = (i64)CDRF_DODEFAULT;
            return true;
        }

        FillRect(hdc, &rc, this._brushFor(fill));
        RECT edge = default;   // a column separator, a shade up from the fill
        edge.left = rc.right - 1; edge.top = rc.top; edge.right = rc.right; edge.bottom = rc.bottom;
        FillRect(hdc, &edge, this._brushFor(shadeRef(this.themeBg, 40)));

        char[128] label;
        label[0] = (char)0;
        HDItemA hi = default;
        hi.mask = (u32)HDI_TEXT;
        hi.pszText = label;
        hi.cchTextMax = 128;
        SendMessageA(nh.hwndFrom, (u32)HDM_GETITEMA, (u64)(i64)specPtr[0], (i64)&hi);
        rc.left = rc.left + 6;
        SetBkMode(hdc, TRANSPARENT);
        SetTextColor(hdc, this.themeText);
        DrawTextA(hdc, label, -1, &rc,
                  (u32)(DT_LEFT | DT_VCENTER | DT_SINGLELINE | DT_NOPREFIX | DT_END_ELLIPSIS));
        result[0] = (i64)CDRF_SKIPDEFAULT;
        return true;
    }

    // Paint an owner-drawn TAB ITEM: the selected tab lifts a shade off the window background,
    // the rest sit a shade below it, and the label rides in the theme's ink. `dis` is a
    // DRAWITEMSTRUCT (CtlType@0, itemID@8, itemState@16, hwndItem@24, hDC@32, rcItem@40).
    bool _drawTabItem(u64 dis)
    {
        i64 p = (i64)dis;
        u32* typePtr = (u32*)p;
        if (typePtr[0] != (u32)ODT_TAB || !this.ctlDark) return false;
        u32* idPtr = (u32*)(p + 8);
        u32* statePtr = (u32*)(p + 16);
        void** itemPtr = (void**)(p + 24);
        void** hdcPtr = (void**)(p + 32);
        i32* rcPtr = (i32*)(p + 40);
        void* ctrl = itemPtr[0];
        void* hdc = hdcPtr[0];

        RECT rc = default;
        rc.left = rcPtr[0]; rc.top = rcPtr[1]; rc.right = rcPtr[2]; rc.bottom = rcPtr[3];
        bool sel = (statePtr[0] & (u32)ODS_SELECTED) != 0u;
        FillRect(hdc, &rc, this._brushFor(shadeRef(this.themeBg, sel ? 26 : 0 - 6)));

        char[128] label;
        label[0] = (char)0;
        TCItemA ti = default;
        ti.mask = (u32)TCIF_TEXT;
        ti.pszText = label;
        ti.cchTextMax = 128;
        SendMessageA(ctrl, (u32)TCM_GETITEMA, (u64)idPtr[0], (i64)&ti);
        SetBkMode(hdc, TRANSPARENT);
        SetTextColor(hdc, this.themeText);
        DrawTextA(hdc, label, -1, &rc,
                  (u32)(DT_CENTER | DT_VCENTER | DT_SINGLELINE | DT_NOPREFIX));
        return true;
    }

    // Paint an owner-drawn status pane: fill with the theme background, then the text in
    // the theme foreground. `dis` is a DRAWITEMSTRUCT (raw offsets: hwndItem@24, hDC@32,
    // rcItem@40). Returns false for any other owner-drawn item (a menu), which the caller
    // then leaves to DefWindowProc.
    bool _drawStatusItem(u64 dis)
    {
        i64 p = (i64)dis;
        void** hdcPtr = (void**)(p + 32);
        void* hdc = hdcPtr[0];
        i32* rcPtr = (i32*)(p + 40);
        void** itemPtr = (void**)(p + 24);
        u64 hItem = (u64)itemPtr[0];
        if (!this.isStatusBar(hItem)) return false;

        RECT rc = default;
        rc.left = rcPtr[0]; rc.top = rcPtr[1]; rc.right = rcPtr[2]; rc.bottom = rcPtr[3];
        FillRect(hdc, &rc, this._brushFor(this.themeBg));

        string text = this.statusTextOf(hItem);
        rc.left = rc.left + 2;
        SetBkMode(hdc, TRANSPARENT);
        SetTextColor(hdc, this.themeText);
        DrawTextA(hdc, (char*)text.data(), -1, &rc,
                  (u32)(DT_LEFT | DT_VCENTER | DT_SINGLELINE | DT_NOPREFIX));
        return true;
    }

    // Push a node's current props onto its control (one interface downcast per kind -
    // the same structured access the reconciler uses in propsEqual).
    void _syncProps(IElement node, u64 h)
    {
        int k = node.kind();
        if (k == ELEM_BUTTON)
        {
            IButton b = node as IButton;
            this.setText(h, b.title.data());
            this.setBoolProp(h, PROP_ENABLED, !b.disabled);
            // Accent-fill via NM_CUSTOMDRAW: a themed button gets its accent colors;
            // a monochrome theme (buttonBg 0) forgets the accent -> native look.
            int abg = pickColor(b.backgroundColor, this.ctx.theme.buttonBg);
            int afg = pickColor(b.color, this.ctx.theme.buttonText);
            this.setAccent(h, afg, abg);
        }
        else if (k == ELEM_TEXT)
        {
            IText t = node as IText;
            this.setText(h, t.text.data());
        }
        else if (k == ELEM_TEXTINPUT)
        {
            ITextInput ti = node as ITextInput;
            this.setText(h, ti.value.data());
            this.setBoolProp(h, PROP_ENABLED, !ti.disabled);
        }
        else if (k == ELEM_CHECKBOX)
        {
            ICheckbox c = node as ICheckbox;
            this.setText(h, c.label.data());
            this.setBoolProp(h, PROP_CHECKED, c.checked);
            this.setBoolProp(h, PROP_ENABLED, !c.disabled);
        }
        else if (k == ELEM_PROGRESS)
        {
            IProgressBar p = node as IProgressBar;
            this.setIntProp(h, PROP_MAX, 100);
            this.setIntProp(h, PROP_VALUE, p.value);
        }
        else if (k == ELEM_SLIDER)
        {
            ISlider s = node as ISlider;
            this.setIntProp(h, PROP_MAX, 100);
            this.setIntProp(h, PROP_VALUE, s.value);
            this.setBoolProp(h, PROP_ENABLED, !s.disabled);
        }
        else if (k == ELEM_TEXTAREA)
        {
            // Uncontrolled: never push text here (would clobber the buffer mid-edit);
            // only sync the enabled state. Text is seeded once at creation and
            // pushed explicitly via nativeSetControlText (file open).
            ITextArea ta = node as ITextArea;
            this.setBoolProp(h, PROP_ENABLED, !ta.disabled);
        }
        else if (k == ELEM_STATUSBAR)
        {
            IStatusBar sb = node as IStatusBar;
            this._syncStatusBar(h, sb);
        }
        else if (k == ELEM_RADIO)
        {
            IRadioButton rb = node as IRadioButton;
            this.setText(h, rb.label.data());
            this.setBoolProp(h, PROP_CHECKED, rb.checked);
            this.setBoolProp(h, PROP_ENABLED, !rb.disabled);
        }
        else if (k == ELEM_COMBO)
        {
            IComboBox cb = node as IComboBox;
            this._syncCombo(h, cb);
            this.setBoolProp(h, PROP_ENABLED, !cb.disabled);
        }
        else if (k == ELEM_LIST)
        {
            // Virtualized: push row count + controlled selection, then repaint. Cell
            // text is pulled on demand via the boxed rowText callback (LVN_GETDISPINFO).
            IListView lv = node as IListView;
            this.setListOp(h, LISTOP_SET_ROWCOUNT, lv.rowCount, 0, "", 0u);
            this.setListOp(h, LISTOP_SET_SELECTION, lv.selectedIndex, 0, "", 0u);
            this.setListOp(h, LISTOP_INVALIDATE, 0, 0, "", 0u);
            this.setBoolProp(h, PROP_ENABLED, !lv.disabled);
        }
        else if (k == ELEM_TABS)
        {
            // Rebuild the tab strip on a pane-count change, then push the controlled tab.
            ITabControl tc = node as ITabControl;
            this._syncTabs(h, tc);
            this.setBoolProp(h, PROP_ENABLED, !tc.disabled);
        }
        else if (k == ELEM_TREE)
        {
            // Expand-on-demand: the root children were inserted once at creation; the
            // native control owns the tree state, so only the enabled flag is synced here
            // (selection round-trips through TVN_SELCHANGED, not a per-frame push).
            ITreeView tv = node as ITreeView;
            this.setBoolProp(h, PROP_ENABLED, !tv.disabled);
        }
        else if (k == ELEM_IMAGE)
        {
            // Upload the image once per distinct pixel buffer (or once from a .bmp source),
            // via the toolkit-neutral setImageData seam. A re-render with the same buffer
            // pointer is a no-op (the last-uploaded pointer is remembered per control).
            IImage im = node as IImage;
            if (im.pixels != 0u)
            {
                if (im.pixels != this._imgLastPixels(h))
                {
                    this.setImageData(h, im.pixels, im.pxW, im.pxH, im.pxW * 4);
                    this._setImgLastPixels(h, im.pixels);
                }
            }
            else if (im.source.length() > 0 && this._imgLastPixels(h) == 0u)
            {
                this.setImageFile(h, im.source);
                this._setImgLastPixels(h, 1u);   // sentinel: file loaded once
            }
        }
        else if (k == ELEM_GROUPBOX)
        {
            IGroupBox g = node as IGroupBox;
            this.setText(h, g.title.data());
        }
        else if (k == ELEM_CANVAS)
        {
            // The paint closure was boxed at creation; just repaint so state changes redraw.
            InvalidateRect(u2h(h), nullptr, 1);
        }
    }

    // Repopulate a combo only when its item set changed (count differs), then set the
    // controlled selection. Refilling every frame would reset the list mid-interaction.
    void _syncCombo(u64 h, IComboBox cb)
    {
        void* ctrl = u2h(h);
        int have = (int)SendMessageA(ctrl, (u32)CB_GETCOUNT, 0u, (i64)0);
        if (have != cb.items.count())
        {
            SendMessageA(ctrl, (u32)CB_RESETCONTENT, 0u, (i64)0);
            int i = 0;
            while (i < cb.items.count())
            {
                SendMessageA(ctrl, (u32)CB_ADDSTRING, 0u, (i64)cb.items.get(i).data());
                i++;
            }
        }
        int cur = (int)SendMessageA(ctrl, (u32)CB_GETCURSEL, 0u, (i64)0);
        if (cur != cb.selectedIndex)
            SendMessageA(ctrl, (u32)CB_SETCURSEL, (u64)cb.selectedIndex, (i64)0);
    }

    // The key path bound to a control HWND this frame, or "" if none (linear scan
    // of the small live set - controls per window are few).
    string keyForHandle(u64 h)
    {
        int i = 0;
        while (i < this.liveHandles.count())
        {
            if (this.liveHandles.get(i) == h) return "" + this.liveKeys.get(i);
            i++;
        }
        return "";
    }

    // Convert a framework color (0x1RRGGBB with the marker bit) to a COLORREF
    // (0x00BBGGRR). A default/unset color (0) maps to black.
    u32 colorRef(int color)
    {
        int r = (color >> 16) & 0xFF;
        int g = (color >> 8) & 0xFF;
        int b = color & 0xFF;
        return (u32)(r | (g << 8) | (b << 16));
    }

    // Apply the app's Theme to the window chrome: immersive dark-mode titlebar,
    // themed control/window background + text colors (used by WM_CTLCOLOR* and
    // WM_ERASEBKGND). Called every frame from applyTree; cheap and idempotent.
    // Repainting the WHOLE frame (erase included) on every applyTree is what made a drag
    // flicker: applyTree runs per pumped event, so a pointer-move stream erased and redrew
    // every control ~100x/sec. The frame only needs a full invalidate when the theme
    // actually changed - individual controls invalidate themselves when their own props
    // change (setText/setBoolProp), and a CanvasView is invalidated by update().
    void applyTheme(IUiContext ctx)
    {
        int panel = pickColor(ctx.theme.panelBg, 0);
        int text  = pickColor(ctx.theme.textColor, 0);
        bool isDark = themeIsDark(&ctx.theme);
        bool changed = false;

        if (isDark != this.dark || this.bgBrush == nullptr)
        {
            this.dark = isDark;
            int one = isDark ? 1 : 0;
            DwmSetWindowAttribute(this.hwnd, (u32)DWMWA_USE_IMMERSIVE_DARK_MODE,
                                  (void*)&one, 4u);
            // The DWM attribute only darkens the TITLEBAR. A NON-CLIENT scrollbar is painted
            // from the uxtheme mode, which this sets - for the frame, and for the scroll gutter
            // whose non-client bar is the page's scrollbar.
            _applyDarkNonClient(this.hwnd, isDark);
            if (this.vscroll != nullptr) _applyDarkNonClient(this.vscroll, isDark);
            changed = true;
        }

        // A default (monochrome) theme leaves controls at the OS default look.
        u32 bg = panel != 0 ? this.colorRef(panel) : (u32)GetSysColor((int)COLOR_BTNFACE);
        u32 fg = text  != 0 ? this.colorRef(text)  : (u32)GetSysColor((int)COLOR_BTNTEXT);
        if (bg != this.themeBg || this.bgBrush == nullptr)
        {
            if (this.bgBrush != nullptr) DeleteObject(this.bgBrush);
            this.bgBrush = CreateSolidBrush(bg);
            changed = true;
        }
        if (fg != this.themeText) changed = true;
        bool nowThemed = panel != 0;
        if (nowThemed != this.themed) changed = true;
        this.themed = nowThemed;
        this.themeBg = bg;
        this.themeText = fg;
        // The data controls (ListView/TreeView) get their own body slot so a row does not melt
        // into the card behind it; the ProgressBar takes the trough/accent pair.
        int field  = pickColor(ctx.theme.inputBg, panel);
        int fieldT = pickColor(ctx.theme.inputText, text);
        this.themeField     = field  != 0 ? this.colorRef(field)  : bg;
        this.themeFieldText = fieldT != 0 ? this.colorRef(fieldT) : fg;
        this.themeTrack  = this.colorRef(pickColor(ctx.theme.track, panel));
        this.themeAccent = this.colorRef(pickColor(ctx.theme.accent, text));

        // Only on a real theme change: the common controls that ignore WM_CTLCOLOR* are
        // re-themed here, never per pump - that churn would flicker. RDW_ALLCHILDREN is required
        // because the frame is WS_CLIPCHILDREN: a plain InvalidateRect on the parent no longer
        // reaches the controls, and they would keep the OLD theme's colors.
        bool wantDark = nowThemed && isDark;
        if (wantDark != this.ctlDark || (changed && this.ctlEverDark))
        {
            this.ctlDark = wantDark;
            if (wantDark) this.ctlEverDark = true;
            this._applyControlTheme();
        }
        if (changed)
        {
            this._applyStatusTheme();
            RedrawWindow(this.hwnd, nullptr, nullptr,
                         (u32)(RDW_INVALIDATE | RDW_ERASE | RDW_ALLCHILDREN));
        }
    }

    // Free this window's owned cflat + GDI state (tree, component, brush, font). The
    // HWND + child controls are destroyed by Windows; deleting the Window later frees
    // the value members (ctx dictionary + strings, live lists) automatically. Moving
    // the app/tree fields is only legal from inside the owning class, hence a method.
    void dispose()
    {
        if (this.ready) { IElement t = this.tree; deleteTree(t); this.ready = false; }
        if (this.app != nullptr) { IComponent a = this.app; this.app = nullptr; delete a; }
        // The content pane (and the controls it parents) would cascade with the frame, but
        // teardown may run before the frame is gone - destroy it explicitly, after `ready`
        // is false so a control's parting notification cannot re-enter the routing.
        if (this.content != nullptr) { DestroyWindow(this.content); this.content = nullptr; }
        if (this.vscroll != nullptr) { DestroyWindow(this.vscroll); this.vscroll = nullptr; }
        if (this.bgBrush != nullptr) { DeleteObject(this.bgBrush); this.bgBrush = nullptr; }
        if (this.font != nullptr) { DeleteObject(this.font); this.font = nullptr; }
        // Free any ListView rowText boxes still live (DestroyWindow destroys the child
        // controls without routing through destroyControl, so free them here).
        int bi = 0;
        while (bi < this.listBoxPtrs.count())
        {
            u64 b = this.listBoxPtrs.get(bi);
            if (b != 0u) __uiFreeListRowBox(b);
            bi++;
        }
        this.listBoxHandles.clear();
        this.listBoxPtrs.clear();
        // Free any TreeView node-source boxes still live.
        int ti = 0;
        while (ti < this.treeBoxPtrs.count())
        {
            u64 b = this.treeBoxPtrs.get(ti);
            if (b != 0u) __uiFreeTreeBox(b);
            ti++;
        }
        this.treeBoxHandles.clear();
        this.treeBoxPtrs.clear();
        // Free the host-owned per-key context menus.
        int ci = 0;
        while (ci < this.ctxMenus.count())
        {
            u64 m = this.ctxMenus.get(ci);
            if (m != 0u) __uiFreeContextMenu(m);
            ci++;
        }
        this.ctxKeys.clear();
        this.ctxMenus.clear();
        // Free any Image HBITMAPs still live (STM images are not freed with the window).
        int ii = 0;
        while (ii < this.imgBitmaps.count())
        {
            u64 bmp = this.imgBitmaps.get(ii);
            if (bmp != 0u) DeleteObject(u2h(bmp));
            ii++;
        }
        this.imgHandles.clear();
        this.imgBitmaps.clear();
        this.imgLastPixels.clear();
        // Free any CanvasView paint boxes still live (DestroyWindow does not route through
        // destroyControl for cascaded children).
        int cvi = 0;
        while (cvi < this.canvasBoxes.count())
        {
            u64 box = this.canvasBoxes.get(cvi);
            if (box != 0u) __uiFreeCanvasBox(box);
            cvi++;
        }
        this.canvasHandles.clear();
        this.canvasBoxes.clear();
        this.accentHandles.clear();
        this.accentBg.clear();
        this.accentFg.clear();
        // Free the cached container-backdrop brushes (host-owned GDI objects).
        int bri = 0;
        while (bri < this.bdBrushes.count())
        {
            u64 br = this.bdBrushes.get(bri);
            if (br != 0u) DeleteObject(u2h(br));
            bri++;
        }
        this.bdBrushes.clear();
        this.bdBrushColors.clear();
        this.bdHandles.clear();
        this.bdColors.clear();
        this.bdFrame.clear();
        this.ctFrame.clear();
    }

    // Register (or replace) the context menu for a key path; the window takes ownership.
    void setContextMenu(string key, u64 menuPtr)
    {
        int i = 0;
        while (i < this.ctxKeys.count())
        {
            if (this.ctxKeys.get(i) == key)
            {
                u64 old = this.ctxMenus.get(i);
                if (old != 0u && old != menuPtr) __uiFreeContextMenu(old);
                this.ctxMenus.set(i, menuPtr);
                return;
            }
            i++;
        }
        this.ctxKeys.add("" + key);
        this.ctxMenus.add(menuPtr);
    }

    // The ContextMenu* (as u64) registered for a key path, or 0.
    u64 contextMenuFor(string key)
    {
        int i = 0;
        while (i < this.ctxKeys.count())
        {
            if (this.ctxKeys.get(i) == key) { u64 v = this.ctxMenus.get(i); return v; }
            i++;
        }
        return 0u;
    }

    // Show a control's context menu (WM_CONTEXTMENU); returns true if one was shown.
    bool showContextMenu(void* fromCtl, i64 screenXY)
    {
        string key = this.keyForHandle((u64)fromCtl);
        if (key.length() == 0) return false;
        return this.showContextMenuForKey(key, screenXY);
    }

    // Show the menu registered on the element under a SCREEN point, if any. A right-click over
    // a control that answers HTTRANSPARENT (a plain STATIC - the backdrops, Box panels and Text
    // labels all are) never reaches that control: it falls through the pane (HTTRANSPARENT by
    // design, so the frame keeps seeing the splitter gutter) onto the FRAME, whose WM_CONTEXTMENU
    // then carries the FRAME's handle. Resolving by point is what makes those elements clickable.
    bool showContextMenuAt(int screenX, int screenY, i64 screenXY)
    {
        if (!this.ready || this.content == nullptr) return false;
        // The pane carries the scroll offset (it sits at y = -scrollPx), so its CLIENT space is
        // content space - mapping through it converts the screen point without a manual bias.
        POINT pt = default;
        pt.x = screenX;
        pt.y = screenY;
        ScreenToClient(this.content, &pt);
        string key = this._ctxScan(this.tree, keySegment(this.tree, 0), pt.x, pt.y);
        if (key.length() == 0) return false;
        return this.showContextMenuForKey(key, screenXY);
    }

    // The deepest (and among peers, top-most) node containing the CONTENT-space point that has
    // a context menu registered, or "". Children are scanned last-first because a later sibling
    // is drawn over an earlier one. Ancestor bounds do NOT prune the walk: the root ScrollView's
    // bounds are the VIEWPORT, while its children live at content coordinates past its bottom.
    string _ctxScan(IElement node, string path, int px, int py)
    {
        list<IElement>* kids = node.childList();
        if (kids != nullptr)
        {
            int i = kids.count() - 1;
            while (i >= 0)
            {
                IElement c = kids.get(i);
                string cp = joinKeyPath(path, keySegment(c, i));
                string r = this._ctxScan(c, cp, px, py);
                if (r.length() > 0) return r;
                i--;
            }
        }
        if (this.contextMenuFor(path) == 0u) return "";
        Rect b = node.nodeBounds();
        int x0 = b.x * this.dipX(); int y0 = b.y * this.dipY();
        if (px < x0 || py < y0) return "";
        if (px >= x0 + b.w * this.dipX() || py >= y0 + b.h * this.dipY()) return "";
        return "" + path;
    }

    // Pop the menu registered on `key` at a screen point. The chosen command routes through the
    // app menu handler (routeMenu), like a menu-bar item.
    bool showContextMenuForKey(string key, i64 screenXY)
    {
        u64 mp = this.contextMenuFor(key);
        if (mp == 0u) return false;
        ContextMenu* cm = (ContextMenu*)mp;
        if (cm.count() == 0) return false;
        void* pop = CreatePopupMenu();
        int i = 0;
        while (i < cm.count())
        {
            if (cm.labels.get(i).length() == 0)
                AppendMenuA(pop, (u32)MF_SEPARATOR, 0u, nullptr);
            else
                AppendMenuA(pop, (u32)MF_STRING, (u64)cm.cmds.get(i), cm.labels.get(i).data());
            i++;
        }
        // The point is SIGNED 16-bit halves: a monitor left of / above the primary is negative.
        int cmd = (int)TrackPopupMenu(pop, (u32)(TPM_RETURNCMD | TPM_RIGHTBUTTON),
                                      _loWordSigned(screenXY), _hiWordSigned(screenXY),
                                      0, this.hwnd, nullptr);
        DestroyMenu(pop);
        if (cmd > 0) routeMenu(cmd);
        return true;
    }

    // Hit-test a pixel against every SplitView divider in the tree; returns the split's
    // key path (widened to a grabbable band) or "". Drives WM_LBUTTONDOWN drag capture.
    string splitAtPixel(int px, int py)
    {
        return this._splitScan(this.tree, keySegment(this.tree, 0), px, py);
    }

    string _splitScan(IElement node, string path, int px, int py)
    {
        if (node.kind() == ELEM_SPLIT)
        {
            ISplitView sv = node as ISplitView;
            Rect d = sv.dividerBounds;
            int x0 = d.x * this.dipX(); int y0 = d.y * this.dipY();
            int x1 = x0 + d.w * this.dipX(); int y1 = y0 + d.h * this.dipY();
            if (x1 - x0 < 6) { x0 = x0 - 3; x1 = x1 + 3; }   // widen a 1-DIP gutter
            if (y1 - y0 < 6) { y0 = y0 - 3; y1 = y1 + 3; }
            if (px >= x0 && px < x1 && py >= y0 && py < y1) return "" + path;
        }
        list<IElement>* kids = node.childList();
        if (kids != nullptr)
        {
            int i = 0;
            while (i < kids.count())
            {
                IElement c = kids.get(i);
                string cp = joinKeyPath(path, keySegment(c, i));
                string r = this._splitScan(c, cp, px, py);
                if (r.length() > 0) return r;
                i++;
            }
        }
        return "";
    }
};

// -- CanvasView: a GDI-backed child the app paints via the ICanvas API -----------
// The escape hatch. A CanvasView maps to a "CFlatCanvasChild" window whose WndProc
// invokes the app's boxed onPaint(ICanvas) closure on WM_PAINT, handing it a
// NativeGdiCanvas over the paint DC. The app draws in the SAME cell coordinates the
// framework paints through, so any custom widget is expressible.

// Free-function colorRef (the GdiCanvas needs one outside a Window). Masks the marker
// bit and swaps R/B to a COLORREF; a default/unset color (0) maps to black.
u32 gdiColorRef(int color)
{
    int r = (color >> 16) & 0xFF;
    int g = (color >> 8) & 0xFF;
    int b = color & 0xFF;
    return (u32)(r | (g << 8) | (b << 16));
}

// A GDI implementation of the ui.cb ICanvas interface, mirroring ui_canvas/win32.cb's
// GdiCanvas but living in the native host (which does not import ui_canvas/win32.cb). Borrows the HDC.
class NativeGdiCanvas : ICanvas
{
    void* hdc = nullptr;
    int cellW = BASE_X;
    int cellH = BASE_Y;
    double scale = 1.0;   // POINTS -> device px (dpi/96); drawImage takes points

    void clear() { }

    void drawText(int col, int row, const char* s, int color)
    {
        RECT rc = default;
        rc.left = col * this.cellW; rc.top = row * this.cellH;
        rc.right = rc.left + 4096; rc.bottom = rc.top + this.cellH;
        SetBkMode(this.hdc, TRANSPARENT);
        SetTextColor(this.hdc, gdiColorRef(color));
        DrawTextA(this.hdc, (char*)s, -1, &rc,
                  (u32)(DT_LEFT | DT_TOP | DT_SINGLELINE | DT_NOPREFIX));
    }

    void drawRect(Rect r, bool filled, int color)
    {
        RECT rc = default;
        rc.left = r.x * this.cellW; rc.top = r.y * this.cellH;
        rc.right = (r.x + r.w) * this.cellW; rc.bottom = (r.y + r.h) * this.cellH;
        if (color == 0)
        {
            void* br = GetStockObject(BLACK_BRUSH);
            if (filled) { FillRect(this.hdc, &rc, br); return; }
            FrameRect(this.hdc, &rc, br);
            return;
        }
        void* br = CreateSolidBrush(gdiColorRef(color));
        if (filled) FillRect(this.hdc, &rc, br);
        else        FrameRect(this.hdc, &rc, br);
        DeleteObject(br);
    }

    void pushClip(Rect r)
    {
        SaveDC(this.hdc);
        IntersectClipRect(this.hdc, r.x * this.cellW, r.y * this.cellH,
                          (r.x + r.w) * this.cellW, (r.y + r.h) * this.cellH);
    }
    void popClip() { RestoreDC(this.hdc, -1); }

    // Blit a canvas image (an HBITMAP handle from canvasCreateImage) into a POINTS rect,
    // scaled to device pixels. The destination edges are rounded independently (right/bottom
    // from the point extent, not width+origin) so adjacent tiles meet with no seam.
    void drawImage(u64 img, double dx, double dy, double dw, double dh)
    {
        if (img == 0u || this.hdc == nullptr) return;
        BITMAP bm = default;
        if (GetObjectA(u2h(img), (i32)sizeof(BITMAP), &bm) == 0) return;
        int srcW = bm.bmWidth;
        int srcH = bm.bmHeight;
        if (srcW <= 0 || srcH <= 0) return;
        int x0 = (int)(dx * this.scale);
        int y0 = (int)(dy * this.scale);
        int x1 = (int)((dx + dw) * this.scale);
        int y1 = (int)((dy + dh) * this.scale);
        if (x1 - x0 <= 0 || y1 - y0 <= 0) return;
        void* memDC = CreateCompatibleDC(this.hdc);
        if (memDC == nullptr) return;
        void* oldBmp = SelectObject(memDC, u2h(img));
        SetStretchBltMode(this.hdc, (int)COLORONCOLOR);
        StretchBlt(this.hdc, x0, y0, x1 - x0, y1 - y0,
                   memDC, 0, 0, srcW, srcH, (u32)SRCCOPY);
        SelectObject(memDC, oldBmp);
        DeleteDC(memDC);
    }
};

// -- Canvas image handles: DIB-backed HBITMAPs -----------------------------------
// canvasCreateImage copies the caller's top-down BGRA32 buffer into a 32bpp DIB section
// (so the caller may free its buffer immediately, like the Cocoa NSBitmapImageRep path)
// and returns the HBITMAP as the handle. drawImage recovers the source extent from the
// bitmap itself (GetObjectA), so no side registry is needed - handles stay pure GDI and
// nothing is tracked on the cflat heap. canvasReleaseImage deletes the bitmap.
u64 canvasCreateImage(u64 bgraPixels, int w, int h)
{
    if (bgraPixels == 0u || w <= 0 || h <= 0) return 0u;
    void* dc = GetDC(nullptr);
    BmiHeader bi = default;
    bi.biSize = 40u; bi.biWidth = w; bi.biHeight = 0 - h;   // negative = top-down
    bi.biPlanes = 1; bi.biBitCount = 32; bi.biCompression = 0u;
    void* bits = nullptr;
    void* bmp = CreateDIBSection(dc, &bi, (u32)DIB_RGB_COLORS, &bits, nullptr, 0u);
    ReleaseDC(nullptr, dc);
    if (bmp == nullptr || bits == nullptr) return 0u;
    memcpy(bits, u2h(bgraPixels), (i64)(w * h * 4));
    return (u64)bmp;
}

void canvasReleaseImage(u64 img)
{
    if (img == 0u) return;
    DeleteObject(u2h(img));
}

// -- Canvas input: OS routing (parity with the Cocoa host) -----------------------
// The CanvasView's pointer/wheel/pinch handlers take POINTS relative to the canvas
// origin. Win32 hands us device pixels in client coords, so every dispatch divides by
// the child's dpi scale. Three things AppKit does for free need doing by hand here:
//
//   1. Drag capture. Cocoa keeps routing mouseDragged:/mouseUp: to the mouseDown: view
//      even when the pointer leaves it; Win32 stops sending mouse messages the moment
//      the cursor exits the child. SetCapture on button-down (released on button-up)
//      reproduces it, and WM_CAPTURECHANGED synthesizes a pointer-up so an app can
//      never be stranded mid-drag if the capture is stolen (Alt-Tab, a modal dialog).
//   2. Wheel delivery. Cocoa sends scrollWheel: to the view UNDER THE CURSOR; Win32
//      sends WM_MOUSEWHEEL to the FOCUSED window, which for a plain child canvas is the
//      top-level frame. The frame's WndProc therefore hit-tests the cursor against its
//      canvas children and routes (see _routeCanvasWheel).
//   3. Pinch. Cocoa has magnifyWithEvent:. On Windows a precision touchpad's pinch-zoom
//      gesture is delivered as CTRL + wheel (the platform convention), so a ctrl-wheel
//      is dispatched to onPinch rather than onWheel.
//
// Handlers resolve the LIVE element per event (like routeClick), not a boxed clone: the
// tree is stable during the event pump. A canvas with no handlers installed is a no-op.

// The top-level frame above `hwnd`. A control's GetParent is the CONTENT PANE, not the
// frame, so walk up until the window is no longer a child.
void* _frameOf(void* hwnd)
{
    void* h = hwnd;
    while (h != nullptr && (GetWindowLongPtrA(h, (int)GWL_STYLE) & (i64)WS_CHILD) != (i64)0)
        h = GetParent(h);
    return h;
}

// Resolve the CanvasView element for a canvas child HWND, pointing _cur at its window.
ICanvasView _canvasViewForChild(void* hwnd)
{
    if (!_setCurFromFrame(_frameOf(hwnd))) return nullptr;
    if (!curWin().ready) return nullptr;
    string key = curWin().keyForHandle((u64)hwnd);
    if (key.length() == 0) return nullptr;
    IElement e = findByKey(curWin().tree, keySegment(curWin().tree, 0), key);
    if (e == nullptr) return nullptr;
    return e as ICanvasView;
}

// Device px -> POINTS for a canvas child (the inverse of NativeGdiCanvas.scale).
double _canvasPtScale(void* hwnd)
{
    u32 dpi = GetDpiForWindow(hwnd);
    if (dpi < 96u) dpi = 96u;
    return 96.0 / (double)dpi;
}

// GET_X_LPARAM / GET_Y_LPARAM: the coords are SIGNED 16-bit halves (negative while a
// captured drag runs outside the child), so sign-extend rather than mask.
int _loWordSigned(i64 v) { return (int)((v << 48) >> 48); }
int _hiWordSigned(i64 v) { return (int)((v << 32) >> 48); }

// Pressed-button bitmask, matching Cocoa's pressedMouseButtons (bit 0 = left, bit 1 =
// right). MK_LBUTTON/MK_RBUTTON already occupy those bits.
int _canvasButtons(u64 wParam)
{
    int b = 0;
    if ((wParam & (u64)MK_LBUTTON) != 0u) b = b | 1;
    if ((wParam & (u64)MK_RBUTTON) != 0u) b = b | 2;
    return b;
}

// Last pointer position in POINTS, so a capture-lost can synthesize an up at the spot
// the drag actually stopped.
double _canvasLastX = 0.0;
double _canvasLastY = 0.0;

// phase: 0 = down, 1 = move, 2 = up. Returns true if the canvas consumed the event.
bool _dispatchCanvasPointer(void* hwnd, int phase, int px, int py, int buttons)
{
    ICanvasView cv = _canvasViewForChild(hwnd);
    if (cv == nullptr) return false;
    double s = _canvasPtScale(hwnd);
    double x = (double)px * s;
    double y = (double)py * s;
    _canvasLastX = x; _canvasLastY = y;
    if (phase == 0) { if (!cv.hasPointerDown) return false; cv.onPointerDown(x, y, buttons); }
    else if (phase == 1) { if (!cv.hasPointerMove) return false; cv.onPointerMove(x, y, buttons); }
    else { if (!cv.hasPointerUp) return false; cv.onPointerUp(x, y, buttons); }
    pumpNative();
    return true;
}

// A wheel notch is WHEEL_DELTA (120); report it in LINES so the delta means the same
// thing a Cocoa legacy-mouse scrollingDelta does. precise = false: Win32 gives no
// trackpad/precise-delta distinction, so wheel input reads as discrete lines.
// A ctrl-wheel is the platform's pinch-zoom gesture and goes to onPinch instead.
bool _dispatchCanvasWheel(void* hwnd, int px, int py, double lines, bool horizontal, bool ctrl)
{
    ICanvasView cv = _canvasViewForChild(hwnd);
    if (cv == nullptr) return false;
    double s = _canvasPtScale(hwnd);
    double x = (double)px * s;
    double y = (double)py * s;
    if (ctrl && !horizontal)
    {
        if (!cv.hasPinch) return false;
        // Per-event zoom factor around 1.0, the shape magnifyWithEvent: reports.
        double scale = 1.0 + lines * 0.25;
        if (scale <= 0.0) return false;
        cv.onPinch(x, y, scale);
        pumpNative();
        return true;
    }
    if (!cv.hasWheel) return false;
    double dx = horizontal ? lines : 0.0;
    double dy = horizontal ? 0.0 : lines;
    cv.onWheel(x, y, dx, dy, false);
    pumpNative();
    return true;
}

// Hit-test a SCREEN point against the current window's canvas children and route a wheel
// to the one under the cursor. This is what gives Win32 the Cocoa "wheel goes to the view
// under the mouse" behaviour despite WM_MOUSEWHEEL being focus-directed.
bool _routeCanvasWheel(int sx, int sy, double lines, bool horizontal, bool ctrl)
{
    if (!hasCurWin()) return false;
    Window* wnd = curWin();
    int i = 0;
    while (i < wnd.canvasHandles.count())
    {
        void* ch = u2h(wnd.canvasHandles.get(i));
        RECT rc = default;
        GetWindowRect(ch, &rc);
        if (sx >= rc.left && sx < rc.right && sy >= rc.top && sy < rc.bottom)
            return _dispatchCanvasWheel(ch, sx - rc.left, sy - rc.top, lines, horizontal, ctrl);
        i++;
    }
    return false;
}

// -- Canvas input drivers (the host-neutral test seam) ---------------------------
// Synthesize a handler invocation on the CanvasView at keyPath. Like the Cocoa host's,
// these call the element handler directly (the oracle is app state, not OS plumbing), so
// they exercise the same closures the live WndProc routing invokes.
ICanvasView _nativeCanvasAt(string keyPath)
{
    if (!hasCurWin()) return nullptr;
    IElement e = findByKey(curWin().tree, keySegment(curWin().tree, 0), keyPath);
    if (e == nullptr) return nullptr;
    return e as ICanvasView;
}

void nativeCanvasPointer(string keyPath, int phase, double x, double y)
{
    ICanvasView cv = _nativeCanvasAt(keyPath);
    if (cv == nullptr) return;
    int buttons = phase == 2 ? 0 : 1;   // down/move = left held, up = released
    if (phase == 0) { if (cv.hasPointerDown) cv.onPointerDown(x, y, buttons); }
    else if (phase == 1) { if (cv.hasPointerMove) cv.onPointerMove(x, y, buttons); }
    else { if (cv.hasPointerUp) cv.onPointerUp(x, y, buttons); }
    pumpNative();
}

void nativeCanvasWheel(string keyPath, double x, double y, double dx, double dy)
{
    ICanvasView cv = _nativeCanvasAt(keyPath);
    if (cv == nullptr || !cv.hasWheel) return;
    cv.onWheel(x, y, dx, dy, true);
    pumpNative();
}

void nativeCanvasPinch(string keyPath, double x, double y, double scale)
{
    ICanvasView cv = _nativeCanvasAt(keyPath);
    if (cv == nullptr || !cv.hasPinch) return;
    cv.onPinch(x, y, scale);
    pumpNative();
}

bool _canvasClassReg = false;

// WndProc for a CanvasView child: on WM_PAINT, build a NativeGdiCanvas over the paint DC
// and invoke the boxed onPaint closure (stored in GWLP_USERDATA). The background is filled
// with the servicing window's theme brush so the custom drawing sits on the app palette.
// Paint a canvas child into `hdc`: fill the theme background, then invoke the boxed
// onPaint closure through a NativeGdiCanvas. Shared by WM_PAINT (live) and WM_PRINTCLIENT
// (so PrintWindow captures the canvas too - it sends WM_PRINTCLIENT, not WM_PAINT).
void _paintCanvasChild(void* hwnd, void* hdc)
{
    RECT rc = default; GetClientRect(hwnd, &rc);
    void* brush = nullptr;
    if (hasCurWin()) brush = curWin().bgBrush;
    if (brush != nullptr) FillRect(hdc, &rc, brush);
    else FillRect(hdc, &rc, GetStockObject(WHITE_BRUSH));
    u64 box = (u64)GetWindowLongPtrA(hwnd, (int)GWLP_USERDATA);
    if (box == 0u) return;
    u32 dpi = GetDpiForWindow(hwnd);
    if (dpi < 96u) dpi = 96u;
    NativeGdiCanvas cv = default;
    cv.hdc = hdc;
    cv.cellW = BASE_X * (int)dpi / 96;
    cv.cellH = BASE_Y * (int)dpi / 96;
    cv.scale = (double)dpi / 96.0;
    __uiCanvasPaint(box, cv);
}

stdcall i64 CanvasChildProc(void* hwnd, u32 msg, u64 wParam, i64 lParam)
{
    // Double-buffered: the painter fills the background and then blits over it, so
    // drawing straight to the window DC flashes when repaints stream in (a drag). Compose
    // the frame in a memory DC and BitBlt it in one go.
    if (msg == WM_PAINT)
    {
        PAINTSTRUCT ps = default;
        void* hdc = BeginPaint(hwnd, &ps);
        RECT rc = default; GetClientRect(hwnd, &rc);
        int cw = rc.right - rc.left;
        int chh = rc.bottom - rc.top;
        void* memDC = CreateCompatibleDC(hdc);
        void* bmp = (cw > 0 && chh > 0) ? CreateCompatibleBitmap(hdc, cw, chh) : nullptr;
        if (memDC != nullptr && bmp != nullptr)
        {
            void* oldBmp = SelectObject(memDC, bmp);
            _paintCanvasChild(hwnd, memDC);
            BitBlt(hdc, 0, 0, cw, chh, memDC, 0, 0, (u32)SRCCOPY);
            SelectObject(memDC, oldBmp);
        }
        else
        {
            _paintCanvasChild(hwnd, hdc);   // out of memory: draw direct rather than not at all
        }
        if (bmp != nullptr) DeleteObject(bmp);
        if (memDC != nullptr) DeleteDC(memDC);
        EndPaint(hwnd, &ps);
        return (i64)0;
    }
    if (msg == WM_PRINTCLIENT)
    {
        _paintCanvasChild(hwnd, u2h(wParam));
        return (i64)0;
    }
    if (msg == WM_ERASEBKGND) return (i64)1;   // WM_PAINT fills the background itself

    // Pointer routing. SetCapture on button-down is what makes a drag survive the cursor
    // leaving the child (AppKit does this implicitly); WM_LBUTTONUP arrives here even
    // outside the child while we hold it, with lParam going negative - hence the signed
    // coord extraction.
    if (msg == WM_LBUTTONDOWN || msg == WM_RBUTTONDOWN)
    {
        SetCapture(hwnd);
        _dispatchCanvasPointer(hwnd, 0, _loWordSigned(lParam), _hiWordSigned(lParam),
                               _canvasButtons(wParam));
        return (i64)0;
    }
    if (msg == WM_MOUSEMOVE)
    {
        _dispatchCanvasPointer(hwnd, 1, _loWordSigned(lParam), _hiWordSigned(lParam),
                               _canvasButtons(wParam));
        return (i64)0;
    }
    if (msg == WM_LBUTTONUP || msg == WM_RBUTTONUP)
    {
        if (GetCapture() == hwnd) ReleaseCapture();
        _dispatchCanvasPointer(hwnd, 2, _loWordSigned(lParam), _hiWordSigned(lParam),
                               _canvasButtons(wParam));
        return (i64)0;
    }
    // Capture stolen mid-drag (Alt-Tab, a modal): synthesize the pointer-up the app is
    // waiting for at the last known spot, so it cannot be stranded in a dragging state.
    if (msg == WM_CAPTURECHANGED)
    {
        ICanvasView cv = _canvasViewForChild(hwnd);
        if (cv != nullptr && cv.hasPointerUp)
        {
            cv.onPointerUp(_canvasLastX, _canvasLastY, 0);
            pumpNative();
        }
        return (i64)0;
    }
    // A wheel only reaches the child directly if it holds focus; the usual path is the
    // frame's hit-test (_routeCanvasWheel). Handled here too so both routes behave alike.
    if (msg == WM_MOUSEWHEEL || msg == WM_MOUSEHWHEEL)
    {
        RECT rc = default;
        GetWindowRect(hwnd, &rc);
        double lines = (double)_hiWordSigned((i64)wParam) / 120.0;
        bool ctrl = (wParam & (u64)MK_CONTROL) != 0u;
        _dispatchCanvasWheel(hwnd, _loWordSigned(lParam) - rc.left,
                             _hiWordSigned(lParam) - rc.top, lines,
                             msg == WM_MOUSEHWHEEL, ctrl);
        return (i64)0;
    }
    return DefWindowProcA(hwnd, msg, wParam, lParam);
}

// Register the canvas child window class once (CS_HREDRAW|CS_VREDRAW so a resize repaints).
void ensureCanvasClass()
{
    if (_canvasClassReg) return;
    WNDCLASSEXA wc = default;
    wc.cbSize = (u32)sizeof(WNDCLASSEXA);
    wc.style = (u32)(CS_HREDRAW | CS_VREDRAW);
    wc.lpfnWndProc = (void*)CanvasChildProc;
    wc.hInstance = _hInst;
    wc.hCursor = LoadCursorA(nullptr, (char*)IDC_ARROW);
    wc.hbrBackground = nullptr;
    wc.lpszClassName = "CFlatCanvasChild";
    RegisterClassExA(&wc);
    _canvasClassReg = true;
}

// -- App-wide window registry + the "current" window --------------------------
// One message loop drives every window. _cur is the window being serviced: the
// WndProc sets it from GWLP_USERDATA before dispatching, and a build sets it to its
// target. App code reaches the servicing window through activeCtx()/activeApp().
// The list OWNS the windows; app code reaches the servicing one by index (_cur). We
// never bind a Window* to a long-lived variable (an owning class pointer auto-frees at
// scope exit and cannot be re-aliased), so curWin() returns a borrow via `alias`.
list<Window*> _windows = default;
int           _cur     = -1;   // index into _windows of the servicing window
// Re-entrancy guard for buildCurrentTree: showing/hiding the root ScrollView's scrollbar
// resizes the client area, and the WM_SIZE it raises lands mid-build. A nested build is
// deferred to just after the outer one (which owns the tree it is committing).
bool          _building       = false;
bool          _rebuildPending = false;

alias Window* curWin() { return _windows.get(_cur); }
bool hasCurWin() { return _cur >= 0 && _cur < _windows.count(); }

// Index of the window owning `hwnd`, or -1 (small list; scanned per message).
int findWindowIdx(void* hwnd)
{
    int i = 0;
    while (i < _windows.count()) { if (_windows.get(i).hwnd == hwnd) return i; i++; }
    return -1;
}

// Point `_cur` at the window owning `hwnd` (mirrors the Cocoa host's _setCurFromView).
// The canvas-child routing lives above this registry, so it reaches _cur through here.
bool _setCurFromFrame(void* hwnd)
{
    int i = findWindowIdx(hwnd);
    if (i < 0) return false;
    _cur = i;
    return true;
}

// -- Frame-only containers: erase your own interior --------------------------------
// A visual-styled BS_GROUPBOX and an SS_ETCHEDFRAME STATIC both draw only their FRAME (and, for
// the group box, its title) - they never fill their interior, on the classic assumption that the
// parent already painted the background there. Nothing does here: the content pane is
// WS_CLIPCHILDREN (its erase skips every child rect) and the card backdrop beneath them is
// WS_CLIPSIBLINGS (its fill skips theirs). The interior therefore keeps whatever the scroll blit
// left in it. Neither asks the parent for a background either - the pane sees WM_ERASEBKGND only
// for its own exposed bands and NEVER a WM_PRINTCLIENT, so uxtheme's DrawThemeParentBackground
// hand-off is not in play. Subclass them to erase their own interior; the stock proc then draws
// the frame + title over a clean background, unchanged in either theme.
//
// The fill is the WINDOW background, which is what every other control's WM_CTLCOLOR* already
// gets - a control inside a colored card takes the theme background, not the card's fill.
stdcall i64 ContainerCtlProc(void* hwnd, u32 msg, u64 wParam, i64 lParam)
{
    // The stock proc this subclass displaced; parked per-window, so BUTTON and STATIC containers
    // share one subclass without a class-name test on every message.
    void* orig = (void*)GetWindowLongPtrA(hwnd, (int)GWLP_USERDATA);
    if (msg == WM_ERASEBKGND)
    {
        void* brush = nullptr;
        bool dk = false;
        if (_setCurFromFrame(_frameOf(hwnd))) { brush = curWin().bgBrush; dk = curWin().ctlDark; }
        // A TabControl only hands its body over in DARK mode: in light it is visual-styled and
        // paints its own body, which this flat fill would replace.
        char[32] cn;
        GetClassNameA(hwnd, cn, 32);
        bool isTab = strcmp(cn, "SysTabControl32") == 0;
        if (brush != nullptr && (dk || !isTab))
        {
            RECT rc = default;
            GetClientRect(hwnd, &rc);
            FillRect(u2h(wParam), &rc, brush);   // clipped to the update region by the DC
            return (i64)1;
        }
    }
    if (orig == nullptr) return DefWindowProcA(hwnd, msg, wParam, lParam);
    return CallWindowProcA(orig, hwnd, msg, wParam, lParam);
}

// Displace a control's WNDPROC with `proc`, parking the stock one in GWLP_USERDATA (which the
// subclass calls through). The ONE subclassing mechanism in this host - see ContainerCtlProc.
void _subclassCtl(void* h, void* proc)
{
    i64 prev = SetWindowLongPtrA(h, (int)GWLP_WNDPROC, (i64)proc);
    SetWindowLongPtrA(h, (int)GWLP_USERDATA, prev);
}

void _subclassContainerCtl(void* h) { _subclassCtl(h, (void*)ContainerCtlProc); }

// A ListView subclass, for ONE message: the column header is a child of the LISTVIEW, so its
// NM_CUSTOMDRAW (the only way to color a header - it has no color message and paints from the
// system colors) notifies the ListView, not us. Everything else falls through to the stock proc.
stdcall i64 ListCtlProc(void* hwnd, u32 msg, u64 wParam, i64 lParam)
{
    void* orig = (void*)GetWindowLongPtrA(hwnd, (int)GWLP_USERDATA);
    if (msg == WM_NOTIFY)
    {
        NMHDR* nh = (NMHDR*)u2h((u64)lParam);
        void* hdr = (void*)SendMessageA(hwnd, (u32)LVM_GETHEADER, 0u, (i64)0);
        if (nh != nullptr && nh.hwndFrom == hdr && (int)nh.code == NM_CUSTOMDRAW
            && _setCurFromFrame(_frameOf(hwnd)))
        {
            i64 res = (i64)CDRF_DODEFAULT;
            if (curWin()._drawListHeader(lParam, &res)) return res;
        }
    }
    if (orig == nullptr) return DefWindowProcA(hwnd, msg, wParam, lParam);
    return CallWindowProcA(orig, hwnd, msg, wParam, lParam);
}

// -- The scroll gutter: a window whose NON-CLIENT scrollbar is the page's scrollbar ---------
// A "SCROLLBAR" control paints its bar in its CLIENT area, which the classic (non-visual-styled)
// user32 never themes - it comes out as a 3D classic bar in both themes. A window's NON-CLIENT
// scrollbar is drawn by the themed path instead (it is what made the old frame bar dark), so the
// bar here is the non-client bar of this 0-client-width child. It exists to carry that bar: it
// paints nothing, and hands its WM_VSCROLL to the frame tagged with its own HWND.
bool _gutterClassReg = false;

stdcall i64 ScrollGutterProc(void* hwnd, u32 msg, u64 wParam, i64 lParam)
{
    if (msg == WM_VSCROLL)
        return SendMessageA(GetParent(hwnd), msg, wParam, (i64)hwnd);
    if (msg == WM_ERASEBKGND) return (i64)1;   // the client area is 0 px wide - nothing to paint
    return DefWindowProcA(hwnd, msg, wParam, lParam);
}

void ensureScrollGutterClass()
{
    if (_gutterClassReg) return;
    WNDCLASSEXA wc = default;
    wc.cbSize        = (u32)sizeof(WNDCLASSEXA);
    wc.style         = 0u;
    wc.lpfnWndProc   = (void*)ScrollGutterProc;
    wc.hInstance     = _hInst;
    wc.hCursor       = LoadCursorA(nullptr, (char*)IDC_ARROW);
    wc.hbrBackground = nullptr;
    wc.lpszClassName = "CFlatScrollGutter";
    RegisterClassExA(&wc);
    _gutterClassReg = true;
}

// Host-neutral accessors used by app code (mirrored by the Cocoa host). activeApp()
// borrows the component (alias) so the window keeps ownership of it.
IUiContext     activeCtx() { return &curWin().ctx; }
alias IComponent activeApp() { return curWin().app; }
bool           hostDark()  { if (!hasCurWin()) return false; return curWin().dark; }
int hostWidth()  { return curWin().w; }
int hostHeight() { return curWin().h; }
int hostWindowCount() { return _windows.count(); }

// Create a hidden window bound to `app` at DIP size w x h and build its tree. The
// host-neutral entry the headless self-tests use (mirrored by the Cocoa host).
void startHeadlessWindow(IComponent app, const char* title, int w, int h)
{
    int wi = createAppWindow(app, title, false);
    curWin().w = w; curWin().h = h;
    buildWindowTree(wi);
}

// Drain any pending posted UI-thread calls (WM_APP_CALL) + other queued messages.
// The headless self-tests call this after a worker thread posts, since there is no
// running message loop to dispatch the marshaled closure.
void hostDrainPosted()
{
    MSG msg = default;
    while (PeekMessageA(&msg, nullptr, 0u, 0u, (u32)PM_REMOVE) != 0)
    {
        TranslateMessage(&msg);
        DispatchMessageA(&msg);
    }
}

// A Theme is "dark" when its panel background is darker than mid-gray. A default
// (monochrome, all-zero) theme is treated as light.
bool themeIsDark(Theme* t)
{
    int c = t.panelBg;
    if (c == 0) return false;
    int r = (c >> 16) & 0xFF; int g = (c >> 8) & 0xFF; int b = c & 0xFF;
    return (r + g + b) < 384;
}

// True if `want` is present in the key list.
bool listHasStr(list<string>* xs, string want)
{
    int i = 0;
    while (i < xs.count()) { if (xs.get(i) == want) return true; i++; }
    return false;
}

// Find the live node whose key path equals `want`. `path` is `node`'s own path.
IElement findByKey(IElement node, string path, string want)
{
    if (path == want) return node;
    list<IElement>* kids = node.childList();
    if (kids != nullptr)
    {
        int i = 0;
        while (i < kids.count())
        {
            IElement c = kids.get(i);
            string cp = joinKeyPath(path, keySegment(c, i));
            IElement r = findByKey(c, cp, want);
            if (r != nullptr) return r;
            i++;
        }
    }
    return nullptr;
}


// -- ctx.post() marshaling hooks (installed into each window's ctx) ------------
extern stdcall u32 GetCurrentThreadId();

// Enqueue a boxed closure onto a window's UI thread. `target` is the window HWND.
void _win32PostEnqueue(u64 target, u64 boxPtr)
{
    PostMessageA(u2h(target), (u32)WM_APP_CALL, 0u, (i64)boxPtr);
}

u64 _win32CurTid() { return (u64)GetCurrentThreadId(); }

// Drain the dirty flag after a native event on `_cur`: re-render + reconcile,
// relayout, and reconcile the tree to native controls. The OS repaints itself.
void pumpNative()
{
    if (!hasCurWin()) return;
    Window* wnd = curWin();
    if (wnd.ctx.consumeDirty())
    {
        IElement wip = wnd.app.render(&wnd.ctx);
        list<Patch> patches = default;
        IElement committed = wnd.tree;
        wnd.tree = reconcile(committed, wip, &patches);
        layoutRootBounded(wnd.tree, 0, 0, wnd.w, wnd.h);
        wnd.applyTree(wnd.tree, &wnd.ctx);
    }
}

// -- Native event routing (parent WM_COMMAND / WM_HSCROLL -> element handler) --
void routeClick(void* ctrl)
{
    Window* wnd = curWin();
    string key = wnd.keyForHandle((u64)ctrl);
    if (key.length() == 0) return;
    IElement e = findByKey(wnd.tree, keySegment(wnd.tree, 0), key);
    if (e == nullptr) return;
    IButton b = e as IButton;
    if (b != nullptr) { b.fireClick(); pumpNative(); return; }
    ICheckbox c = e as ICheckbox;
    if (c != nullptr) { c.fireToggle(); pumpNative(); return; }
    // A radio button routes to its enclosing RadioGroup (one key-path segment up),
    // which owns the controlled `value` + onChange.
    IRadioButton rb = e as IRadioButton;
    if (rb != nullptr)
    {
        string pp = _parentPath(key);
        IElement pe = findByKey(wnd.tree, keySegment(wnd.tree, 0), pp);
        if (pe != nullptr)
        {
            IRadioGroup g = pe as IRadioGroup;
            if (g != nullptr) { g.fireChange(rb.index); pumpNative(); }
        }
    }
}

// Strip the last "/segment" from a key path ("root/rg/r1" -> "root/rg"); "" if none.
string _parentPath(string key)
{
    int last = -1; int i = 0; int n = (int)key.length();
    while (i < n) { if (key.data()[i] == '/') last = i; i++; }
    if (last < 0) return "";
    return substring(key, 0, last);
}

// A combo selection change (CBN_SELCHANGE): read the new index, fire onChange.
void routeCombo(void* ctrl)
{
    Window* wnd = curWin();
    string key = wnd.keyForHandle((u64)ctrl);
    if (key.length() == 0) return;
    IElement e = findByKey(wnd.tree, keySegment(wnd.tree, 0), key);
    if (e == nullptr) return;
    IComboBox cb = e as IComboBox;
    if (cb == nullptr) return;
    int sel = (int)SendMessageA(ctrl, (u32)CB_GETCURSEL, 0u, (i64)0);
    if (sel >= 0) { cb.fireChange(sel); pumpNative(); }
}

// -- ListView notifications (WM_NOTIFY) ---------------------------------------
// Fill a GETDISPINFO request (owner-data): call the boxed rowText callback for the
// requested (row, subitem) and copy the text into the OS-provided buffer.
void fillListDispInfo(i64 lParam)
{
    Window* wnd = curWin();
    NMHDR* nh = (NMHDR*)u2h((u64)lParam);
    void* hFrom = nh.hwndFrom;
    LVItemA* item = (LVItemA*)((char*)u2h((u64)lParam) + 24);   // LVITEM at NMHDR+24
    if ((item.mask & (u32)LVIF_TEXT) == 0u) return;
    if (item.pszText == nullptr || item.cchTextMax <= 0) return;
    u64 box = wnd._listBoxFor((u64)hFrom);
    if (box == 0u) { item.pszText[0] = '\0'; return; }
    string cell = __uiListRowText(box, item.iItem, item.iSubItem);
    int max = item.cchTextMax - 1;
    int i = 0; int len = (int)cell.length();
    while (i < len && i < max) { item.pszText[i] = cell.data()[i]; i++; }
    item.pszText[i] = '\0';
}

// The currently selected row of the ListView at `from`, or -1.
int _listSelectedRow(void* hFrom)
{
    return (int)SendMessageA(hFrom, (u32)LVM_GETNEXTITEM, (u64)(i64)(-1), (i64)LVNI_SELECTED);
}

// Route a selection change to the ListView's onSelect (guarded against the host's
// own selection pushes during applyTree, which would otherwise recurse).
void routeListSelect(void* hFrom)
{
    Window* wnd = curWin();
    if (wnd.applying) return;
    string key = wnd.keyForHandle((u64)hFrom);
    if (key.length() == 0) return;
    IElement e = findByKey(wnd.tree, keySegment(wnd.tree, 0), key);
    if (e == nullptr) return;
    IListView lv = e as IListView;
    if (lv == nullptr) return;
    int sel = _listSelectedRow(hFrom);
    if (sel >= 0 && sel != lv.selectedIndex) { lv.fireSelect(sel); pumpNative(); }
}

void routeListActivate(void* hFrom)
{
    Window* wnd = curWin();
    string key = wnd.keyForHandle((u64)hFrom);
    if (key.length() == 0) return;
    IElement e = findByKey(wnd.tree, keySegment(wnd.tree, 0), key);
    if (e == nullptr) return;
    IListView lv = e as IListView;
    if (lv == nullptr) return;
    int sel = _listSelectedRow(hFrom);
    if (sel >= 0) { lv.fireActivate(sel); pumpNative(); }
}

// Dispatch a WM_NOTIFY from a child control. Returns true if we consumed it.
bool routeNotify(i64 lParam)
{
    NMHDR* nh = (NMHDR*)u2h((u64)lParam);
    if (nh == nullptr) return false;
    int code = (int)nh.code;
    void* hFrom = nh.hwndFrom;
    if (code == LVN_GETDISPINFOA) { fillListDispInfo(lParam); return true; }
    if (code == LVN_ITEMCHANGED)  { routeListSelect(hFrom); return true; }
    if (code == NM_DBLCLK)        { routeListActivate(hFrom); return true; }
    if (code == LVN_KEYDOWN)
    {
        u16* pv = (u16*)((char*)u2h((u64)lParam) + 24);   // wVKey at NMHDR+24
        if ((int)pv[0] == (int)VK_RETURN) routeListActivate(hFrom);
        return true;
    }
    if (code == TCN_SELCHANGE)      { routeTabChange(hFrom); return true; }
    if (code == TVN_SELCHANGEDA)    { routeTreeSelect(lParam); return true; }
    if (code == TVN_ITEMEXPANDINGA) { routeTreeExpand(lParam); return true; }
    return false;
}

// -- NMTREEVIEW field readers ----------------------------------------------------
// NMTREEVIEWA = { NMHDR hdr; UINT action; TVITEMA itemOld; TVITEMA itemNew; POINT pt }.
// itemNew starts at offset 88 on Win64; its hItem is +8 (96) and its lParam is +48 (136).
void* _nmTreeItemNewHandle(i64 lParam)
{
    char* p = (char*)u2h((u64)lParam);
    void** slot = (void**)(p + 96);
    return slot[0];
}

i64 _nmTreeItemNewParam(i64 lParam)
{
    char* p = (char*)u2h((u64)lParam);
    i64* slot = (i64*)(p + 136);
    return slot[0];
}

// A tab selection change (TCN_SELCHANGE): read the new tab, fire onSelectTab.
void routeTabChange(void* hFrom)
{
    Window* wnd = curWin();
    if (wnd.applying) return;
    string key = wnd.keyForHandle((u64)hFrom);
    if (key.length() == 0) return;
    IElement e = findByKey(wnd.tree, keySegment(wnd.tree, 0), key);
    if (e == nullptr) return;
    ITabControl tc = e as ITabControl;
    if (tc == nullptr) return;
    int sel = (int)SendMessageA(hFrom, (u32)TCM_GETCURSEL, 0u, (i64)0);
    if (sel >= 0 && sel != tc.selectedTab) { tc.fireSelectTab(sel); pumpNative(); }
}

// A tree selection change (TVN_SELCHANGED): read the newly-selected node's id, fire onSelect.
void routeTreeSelect(i64 lParam)
{
    Window* wnd = curWin();
    if (wnd.applying) return;
    NMHDR* nh = (NMHDR*)u2h((u64)lParam);
    void* hFrom = nh.hwndFrom;
    string key = wnd.keyForHandle((u64)hFrom);
    if (key.length() == 0) return;
    IElement e = findByKey(wnd.tree, keySegment(wnd.tree, 0), key);
    if (e == nullptr) return;
    ITreeView tv = e as ITreeView;
    if (tv == nullptr) return;
    int nid = (int)_nmTreeItemNewParam(lParam);
    if (nid != tv.selectedNode) { tv.fireSelect(nid); pumpNative(); }
}

// A tree node is expanding (TVN_ITEMEXPANDING): materialize its children on demand, then
// fire onExpand. Returning 0 from WM_NOTIFY allows the expansion to proceed.
void routeTreeExpand(i64 lParam)
{
    Window* wnd = curWin();
    NMHDR* nh = (NMHDR*)u2h((u64)lParam);
    void* hFrom = nh.hwndFrom;
    void* hItem = _nmTreeItemNewHandle(lParam);
    wnd._treeExpandItem((u64)hFrom, hItem);
    string key = wnd.keyForHandle((u64)hFrom);
    if (key.length() == 0) return;
    IElement e = findByKey(wnd.tree, keySegment(wnd.tree, 0), key);
    if (e == nullptr) return;
    ITreeView tv = e as ITreeView;
    if (tv == nullptr) return;
    tv.fireExpand((int)_nmTreeItemNewParam(lParam));
    pumpNative();
}

// Drag a splitter's divider to a pixel position (WM_MOUSEMOVE while captured). Converts
// to DIPs, recomputes the ratio, and fires onRatioChange so the app re-lays-out.
void splitDragTo(Window* wnd, string key, int px, int py)
{
    IElement e = findByKey(wnd.tree, keySegment(wnd.tree, 0), key);
    if (e == nullptr) return;
    ISplitView sv = e as ISplitView;
    if (sv == nullptr) return;
    sv.fireRatioChange(sv._ratioAt(px / wnd.dipX(), py / wnd.dipY()));
    pumpNative();
}

// -- ListView driver API (host-neutral; used by the gallery self-test) ---------
void nativeListSelect(string keyPath, int row)
{
    u64 h = curWin().ctx.nativeHandle(keyPath);
    if (h == 0u) return;
    void* ctrl = u2h(h);
    LVItemA clr = default;
    clr.stateMask = (u32)(LVIS_SELECTED | LVIS_FOCUSED);
    SendMessageA(ctrl, (u32)LVM_SETITEMSTATE, (u64)(i64)(-1), (i64)&clr);
    if (row < 0) return;
    LVItemA it = default;
    it.stateMask = (u32)(LVIS_SELECTED | LVIS_FOCUSED);
    it.state = (u32)(LVIS_SELECTED | LVIS_FOCUSED);
    SendMessageA(ctrl, (u32)LVM_SETITEMSTATE, (u64)row, (i64)&it);
}

int nativeListSelectedRow(string keyPath)
{
    u64 h = curWin().ctx.nativeHandle(keyPath);
    if (h == 0u) return -1;
    return (int)SendMessageA(u2h(h), (u32)LVM_GETNEXTITEM, (u64)(i64)(-1), (i64)LVNI_SELECTED);
}

// Read a cell's text (drives the rowText callback for owner-data). Owned string.
string nativeListCellText(string keyPath, int row, int col)
{
    u64 h = curWin().ctx.nativeHandle(keyPath);
    if (h == 0u) return "";
    char[512] buf; buf[0] = '\0';
    LVItemA it = default;
    it.iSubItem = col;
    it.pszText = buf;
    it.cchTextMax = 512;
    SendMessageA(u2h(h), (u32)LVM_GETITEMTEXTA, (u64)row, (i64)&it);
    return "" + buf;   // owned copy (buf is a stack buffer)
}

int nativeListRowCount(string keyPath)
{
    u64 h = curWin().ctx.nativeHandle(keyPath);
    if (h == 0u) return 0;
    return (int)SendMessageA(u2h(h), (u32)LVM_GETITEMCOUNT, 0u, (i64)0);
}

void routeEdit(void* ctrl)
{
    Window* wnd = curWin();
    string key = wnd.keyForHandle((u64)ctrl);
    if (key.length() == 0) return;
    IElement e = findByKey(wnd.tree, keySegment(wnd.tree, 0), key);
    if (e == nullptr) return;
    ITextInput ti = e as ITextInput;
    if (ti != nullptr)
    {
        char[512] buf;
        GetWindowTextA(ctrl, buf, 512);
        string nv = (string)buf;
        ti.fireChangeText(nv);
        pumpNative();
        return;
    }
    // A TextArea is uncontrolled: EN_CHANGE is just a dirty NOTIFICATION; do not
    // read/push the (potentially large) buffer here.
    ITextArea ta = e as ITextArea;
    if (ta != nullptr)
    {
        ta.fireChange();
        pumpNative();
    }
}

// Read the current text of the control at `keyPath` on the active window (owned
// string). Used to PULL a TextArea's buffer on save. Returns "" if no such control.
string nativeControlText(string keyPath)
{
    u64 h = curWin().ctx.nativeHandle(keyPath);
    if (h == 0u) return "";
    void* ctrl = u2h(h);
    int n = (int)GetWindowTextLengthA(ctrl);
    if (n <= 0) return "";
    char* buf = (char*)malloc((i64)(n + 1));
    GetWindowTextA(ctrl, buf, n + 1);
    // Deep-copy into an owned string BEFORE freeing buf ('(string)buf' aliases it).
    string s = "" + buf;
    free((void*)buf);
    return s;
}

// Push text into the control at `keyPath` (file open / clear). Guards the reentrant
// EN_CHANGE so the push does not register as a user edit.
void nativeSetControlText(string keyPath, string s)
{
    u64 h = curWin().ctx.nativeHandle(keyPath);
    if (h == 0u) return;
    bool prev = curWin().applying;
    curWin().applying = true;
    SetWindowTextA(u2h(h), s.data());
    curWin().applying = prev;
}

// -- Host-neutral driver API (tabs / tree / splitter / context menu) ------------
// Register (or replace) the context menu for a key path; the window takes ownership of
// the boxed ContextMenu* (freed on teardown). The app builds it once (sugar + addItem).
void nativeSetContextMenu(string keyPath, u64 menuPtr) { curWin().setContextMenu(keyPath, menuPtr); }

// Simulate the user picking item `itemIndex` of the context menu registered on keyPath
// (headless: TrackPopupMenu cannot run unattended). Routes the item's command.
void nativeFireContextMenu(string keyPath, int itemIndex)
{
    u64 mp = curWin().contextMenuFor(keyPath);
    if (mp == 0u) return;
    ContextMenu* cm = (ContextMenu*)mp;
    if (itemIndex < 0 || itemIndex >= cm.count()) return;
    int cmd = cm.cmds.get(itemIndex);
    if (cmd > 0) routeMenu(cmd);
}

// Drive a splitter to a DIP position along its axis (headless drag). Fires onRatioChange.
void nativeSplitterDrag(string keyPath, int dipX, int dipY)
{
    Window* wnd = curWin();
    IElement e = findByKey(wnd.tree, keySegment(wnd.tree, 0), keyPath);
    if (e == nullptr) return;
    ISplitView sv = e as ISplitView;
    if (sv == nullptr) return;
    sv.fireRatioChange(sv._ratioAt(dipX, dipY));
    pumpNative();
}

// The absolute frame (DIP) of the node at keyPath, or a zero rect (layout assertions).
Rect nativeNodeBounds(string keyPath)
{
    Window* wnd = curWin();
    IElement e = findByKey(wnd.tree, keySegment(wnd.tree, 0), keyPath);
    if (e == nullptr) { Rect z = default; return z; }
    return e.nodeBounds();
}

// The committed View container's backgroundColor (its host backdrop fill), or 0. Reads
// the reconciled tree, so it verifies a theme flip actually re-colored the card.
int nativeContainerBg(string keyPath)
{
    Window* wnd = curWin();
    IElement e = findByKey(wnd.tree, keySegment(wnd.tree, 0), keyPath);
    if (e == nullptr) return 0;
    IView v = e as IView;
    if (v != nullptr) return v.style.backgroundColor;
    return 0;
}

// Tab driver: read/count the native tab strip; SETCURSEL does not notify, so it routes
// the selection change like the user clicking a tab header.
int nativeTabSelected(string keyPath)
{
    u64 h = curWin().ctx.nativeHandle(keyPath);
    if (h == 0u) return 0 - 1;
    return (int)SendMessageA(u2h(h), (u32)TCM_GETCURSEL, 0u, (i64)0);
}

int nativeTabCount(string keyPath)
{
    u64 h = curWin().ctx.nativeHandle(keyPath);
    if (h == 0u) return 0;
    return (int)SendMessageA(u2h(h), (u32)TCM_GETITEMCOUNT, 0u, (i64)0);
}

void nativeTabSelect(string keyPath, int idx)
{
    u64 h = curWin().ctx.nativeHandle(keyPath);
    if (h == 0u) return;
    SendMessageA(u2h(h), (u32)TCM_SETCURSEL, (u64)idx, (i64)0);
    routeTabChange(u2h(h));
}

// Tree driver: root/child item handles, count, expand (fires lazy insert), select, node id.
u64 nativeTreeRootItem(string keyPath)
{
    u64 h = curWin().ctx.nativeHandle(keyPath);
    if (h == 0u) return 0u;
    return (u64)SendMessageA(u2h(h), (u32)TVM_GETNEXTITEM, (u64)TVGN_ROOT, (i64)0);
}

u64 nativeTreeChildItem(string keyPath, u64 hItem)
{
    u64 h = curWin().ctx.nativeHandle(keyPath);
    if (h == 0u) return 0u;
    return (u64)SendMessageA(u2h(h), (u32)TVM_GETNEXTITEM, (u64)TVGN_CHILD, (i64)u2h(hItem));
}

int nativeTreeItemCount(string keyPath)
{
    u64 h = curWin().ctx.nativeHandle(keyPath);
    if (h == 0u) return 0;
    return (int)SendMessageA(u2h(h), (u32)TVM_GETCOUNT, 0u, (i64)0);
}

void nativeTreeExpandItem(string keyPath, u64 hItem)
{
    u64 h = curWin().ctx.nativeHandle(keyPath);
    if (h == 0u) return;
    SendMessageA(u2h(h), (u32)TVM_EXPAND, (u64)TVE_EXPAND, (i64)u2h(hItem));
}

void nativeTreeSelectItem(string keyPath, u64 hItem)
{
    u64 h = curWin().ctx.nativeHandle(keyPath);
    if (h == 0u) return;
    SendMessageA(u2h(h), (u32)TVM_SELECTITEM, (u64)TVGN_CARET, (i64)u2h(hItem));
}

int nativeTreeItemNodeId(string keyPath, u64 hItem)
{
    u64 h = curWin().ctx.nativeHandle(keyPath);
    if (h == 0u) return 0 - 1;
    return curWin()._treeItemParam(u2h(h), u2h(hItem));
}

void routeSlider(void* ctrl)
{
    Window* wnd = curWin();
    string key = wnd.keyForHandle((u64)ctrl);
    if (key.length() == 0) return;
    IElement e = findByKey(wnd.tree, keySegment(wnd.tree, 0), key);
    if (e == nullptr) return;
    ISlider s = e as ISlider;
    if (s == nullptr) return;
    int pos = (int)SendMessageA(ctrl, (u32)TBM_GETPOS, 0u, (i64)0);
    s.fireSet(pos);
    pumpNative();
}

// Mirror OS focus into ctx.focusKey (the framework's keyed focus becomes a mirror
// of real focus, so app code that reads ctx.focusKey stays correct).
void mirrorFocus(void* ctrl)
{
    Window* wnd = curWin();
    string key = wnd.keyForHandle((u64)ctrl);
    if (key.length() > 0) wnd.ctx.focus(key);
}

// -- Menu bar + accelerators ----------------------------------------------------
bool strContains(string s, const char* sub)
{
    return strstr(s.data(), (char*)sub) != nullptr;
}

// Parse an accelerator like "Ctrl+Shift+S" or "F3" into a virtual key. 0 = none.
int parseAccelKey(string a)
{
    int plus = -1; int i = 0; int n = (int)a.length();
    while (i < n) { if (a.data()[i] == '+') plus = i; i++; }
    string keyTok = plus >= 0 ? substring(a, plus + 1, n - plus - 1) : a;
    int kn = (int)keyTok.length();
    if (kn == 1)
    {
        char c = keyTok.data()[0];
        if (c >= 'a' && c <= 'z') return (int)(c - 32);   // -> uppercase VK
        return (int)c;                                    // A-Z, 0-9 map to VK
    }
    if (kn >= 2 && (keyTok.data()[0] == 'F' || keyTok.data()[0] == 'f'))
    {
        int num = atoi(keyTok.data() + 1);
        if (num >= 1 && num <= 12) return (int)VK_F1 + (num - 1);
    }
    return 0;
}

int parseAccelMods(string a)
{
    int m = 0;
    if (strContains(a, "Ctrl"))  m = m | (int)FCONTROL;
    if (strContains(a, "Shift")) m = m | (int)FSHIFT;
    if (strContains(a, "Alt"))   m = m | (int)FALT;
    return m;
}

void menuReset()
{
    _menuTop.clear();
    _menuItemTopIdx.clear();
    _menuItemLabel.clear();
    _menuItemCmd.clear();
    _menuAccelKey.clear();
    _menuAccelMods.clear();
}

int menuAddTop(string title)
{
    _menuTop.add("" + title);
    return _menuTop.count() - 1;
}

// Add a command item to top-level menu `top` with app command id `cmd`. `accel`
// (e.g. "Ctrl+S", "" for none) both labels the item and registers an accelerator.
void menuAddItem(int top, string label, string accel, int cmd)
{
    string shown = "" + label;
    int vk = 0; int mods = 0;
    if (accel.length() > 0)
    {
        vk = parseAccelKey(accel);
        mods = parseAccelMods(accel);
        shown = label + "\t" + accel;
    }
    _menuItemTopIdx.add(top);
    _menuItemLabel.add(shown);
    _menuItemCmd.add(cmd);
    _menuAccelKey.add(vk);
    _menuAccelMods.add(mods);
}

void menuAddSeparator(int top)
{
    _menuItemTopIdx.add(top);
    _menuItemLabel.add("");
    _menuItemCmd.add(0);
    _menuAccelKey.add(0);
    _menuAccelMods.add(0);
}

// Realize the declared menu into an HMENU on `hwnd`; build the shared accelerator
// table on first use (every window uses the same accelerators).
void buildMenuBar(void* hwnd)
{
    if (_menuTop.count() == 0) return;
    void* bar = CreateMenu();
    int t = 0;
    while (t < _menuTop.count())
    {
        void* pop = CreatePopupMenu();
        int i = 0;
        while (i < _menuItemTopIdx.count())
        {
            if (_menuItemTopIdx.get(i) == t)
            {
                if (_menuItemLabel.get(i).length() == 0)
                    AppendMenuA(pop, (u32)MF_SEPARATOR, 0u, nullptr);
                else
                    AppendMenuA(pop, (u32)MF_STRING, (u64)_menuItemCmd.get(i),
                                _menuItemLabel.get(i).data());
            }
            i++;
        }
        AppendMenuA(bar, (u32)MF_POPUP, (u64)pop, _menuTop.get(t).data());
        t++;
    }
    SetMenu(hwnd, bar);

    if (_accelTable != nullptr) return;   // accelerators are app-wide; build once
    int cnt = 0; int k = 0;
    while (k < _menuAccelKey.count()) { if (_menuAccelKey.get(k) != 0) cnt++; k++; }
    if (cnt > 0)
    {
        ACCEL* acc = (ACCEL*)malloc((i64)cnt * (i64)sizeof(ACCEL));
        int w = 0; int j = 0;
        while (j < _menuAccelKey.count())
        {
            if (_menuAccelKey.get(j) != 0)
            {
                acc[w].fVirt = (u8)((int)FVIRTKEY | _menuAccelMods.get(j));
                acc[w].key = (u16)_menuAccelKey.get(j);
                acc[w].cmd = (u16)_menuItemCmd.get(j);
                w++;
            }
            j++;
        }
        _accelTable = CreateAcceleratorTableA(acc, cnt);
        free((void*)acc);
    }
}

// A menu command / accelerator (WM_COMMAND, lParam == 0) fired on `_cur`: dispatch
// it to the app's handler, then pump.
void routeMenu(int id)
{
    if (id <= 0) return;
    if (_hasMenuHandler) _menuHandler(id);
    pumpNative();
}

// -- File dialogs + message boxes ---------------------------------------------
int _filterZ(char* buf, int p, const char* s)
{
    int i = 0;
    while (s[i] != '\0') { buf[p] = s[i]; p++; i++; }
    buf[p] = '\0'; p++;
    return p;
}

string nativeOpenFile()
{
    char[128] filt;
    int p = 0;
    p = _filterZ(filt, p, "Text files (*.txt;*.md;*.cb)");
    p = _filterZ(filt, p, "*.txt;*.md;*.cb");
    p = _filterZ(filt, p, "All files (*.*)");
    p = _filterZ(filt, p, "*.*");
    filt[p] = '\0';

    char[520] path; path[0] = '\0';
    OPENFILENAMEA ofn = default;
    ofn.lStructSize = (u32)sizeof(OPENFILENAMEA);
    ofn.hwndOwner = curWin().hwnd;
    ofn.lpstrFilter = filt;
    ofn.lpstrFile = path;
    ofn.nMaxFile = 520u;
    ofn.Flags = (u32)((int)OFN_FILEMUSTEXIST | (int)OFN_PATHMUSTEXIST);
    if (GetOpenFileNameA(&ofn) == 0) return "";
    return "" + path;   // owned copy (path is a stack buffer)
}

string nativeSaveFile()
{
    char[128] filt;
    int p = 0;
    p = _filterZ(filt, p, "Text files (*.txt;*.md;*.cb)");
    p = _filterZ(filt, p, "*.txt;*.md;*.cb");
    p = _filterZ(filt, p, "All files (*.*)");
    p = _filterZ(filt, p, "*.*");
    filt[p] = '\0';

    char[520] path; path[0] = '\0';
    OPENFILENAMEA ofn = default;
    ofn.lStructSize = (u32)sizeof(OPENFILENAMEA);
    ofn.hwndOwner = curWin().hwnd;
    ofn.lpstrFilter = filt;
    ofn.lpstrFile = path;
    ofn.nMaxFile = 520u;
    ofn.lpstrDefExt = "txt";
    ofn.Flags = (u32)((int)OFN_PATHMUSTEXIST | (int)OFN_OVERWRITEPROMPT);
    if (GetSaveFileNameA(&ofn) == 0) return "";
    return "" + path;   // owned copy (path is a stack buffer)
}

// Modal confirm with Yes/No/Cancel. Returns 1 = Yes, 0 = No, -1 = Cancel.
int nativeConfirm(string title, string text)
{
    int r = (int)MessageBoxA(curWin().hwnd, text.data(), title.data(),
                             (u32)((int)MB_YESNOCANCEL | (int)MB_ICONWARNING));
    if (r == (int)IDYES) return 1;
    if (r == (int)IDNO) return 0;
    return -1;
}

void nativeInfo(string title, string text)
{
    MessageBoxA(curWin().hwnd, text.data(), title.data(), (u32)MB_OK);
}

// Close the active window (bypasses the WM_CLOSE guard - the caller already decided).
void nativeCloseWindow()
{
    if (hasCurWin() && curWin().hwnd != nullptr) DestroyWindow(curWin().hwnd);
}

// -- Host-neutral driver API (selection / insertion / menu) -------------------
// Same surface as the Cocoa host; fedit uses these to stay platform-portable.

void nativeSelect(string keyPath, int start, int end)
{
    u64 h = curWin().ctx.nativeHandle(keyPath);
    if (h == 0u) return;
    void* ctrl = u2h(h);
    SendMessageA(ctrl, (u32)EM_SETSEL, (u64)start, (i64)end);
    SendMessageA(ctrl, (u32)EM_SCROLLCARET, 0u, (i64)0);
    SetFocus(ctrl);
}

int nativeSelectionStart(string keyPath)
{
    u64 h = curWin().ctx.nativeHandle(keyPath);
    if (h == 0u) return 0;
    void* ctrl = u2h(h);
    u32 selA = 0u; u32 selB = 0u;
    SendMessageA(ctrl, (u32)EM_GETSEL, (u64)&selA, (i64)&selB);
    return (int)selA;
}

void nativeInsertTextAt(string keyPath, int pos, string s)
{
    u64 h = curWin().ctx.nativeHandle(keyPath);
    if (h == 0u) return;
    void* ctrl = u2h(h);
    SendMessageA(ctrl, (u32)EM_SETSEL, (u64)pos, (i64)pos);
    SendMessageA(ctrl, (u32)EM_REPLACESEL, 1u, (i64)s.data());
}

// Fire a menu command as if the user selected it (used by fedit's self-test).
void nativeTestFireMenu(int cmd)
{
    routeMenu(cmd);
}

// Read a status bar pane's text (used by fedit's self-test to read the status line).
// Served from the host's cache: SB_GETTEXT on an owner-drawn (themed) part returns the
// part's item DATA, not its string, so it cannot answer this once a theme is applied.
string nativeStatusText(string keyPath)
{
    u64 h = curWin().ctx.nativeHandle(keyPath);
    if (h == 0u) return "";
    if (curWin().isStatusBar(h)) return curWin().statusTextOf(h);
    char[512] buf; buf[0] = '\0';
    SendMessageA(u2h(h), (u32)SB_GETTEXTA, 0u, (i64)buf);
    return "" + buf;   // owned copy (buf is a stack buffer)
}

// -- Secondary window (read-only About) ---------------------------------------
// A separate top-level window with static read-only content, sharing the app's
// message loop. Closing it does NOT quit the app. Used by fedit's Help > About.
stdcall i64 SecondaryWndProc(void* hwnd, u32 msg, u64 wParam, i64 lParam)
{
    // Snapshot the servicing window's theme into plain scalars (a Window* alias local
    // may not have field-derived values returned from it - borrow-checker restriction).
    void* brush = nullptr; u32 txt = 0u; u32 bg = 0u;
    if (hasCurWin()) { brush = curWin().bgBrush; txt = curWin().themeText; bg = curWin().themeBg; }
    if (msg == WM_CTLCOLORSTATIC && brush != nullptr)
    {
        void* hdc = u2h(wParam);
        SetTextColor(hdc, txt);
        SetBkColor(hdc, bg);
        return (i64)(u64)brush;
    }
    if (msg == WM_ERASEBKGND && brush != nullptr)
    {
        RECT rc = default; GetClientRect(hwnd, &rc);
        FillRect(u2h(wParam), &rc, brush);
        return (i64)1;
    }
    return DefWindowProcA(hwnd, msg, wParam, lParam);
}

void showSecondaryWindow(string title, string message)
{
    Window* wnd = curWin();
    if (!_secClassReg)
    {
        WNDCLASSEXA wc = default;
        wc.cbSize = (u32)sizeof(WNDCLASSEXA);
        wc.lpfnWndProc = (void*)SecondaryWndProc;
        wc.hInstance = _hInst;
        wc.hCursor = LoadCursorA(nullptr, (char*)IDC_ARROW);
        wc.hbrBackground = (void*)((i64)COLOR_BTNFACE + 1);
        wc.lpszClassName = "CFlatSecondary";
        RegisterClassExA(&wc);
        _secClassReg = true;
    }
    u32 dpi = wnd != nullptr ? wnd.dpi : 96u;
    int w = 360 * (int)dpi / 96;
    int h = 200 * (int)dpi / 96;
    void* owner = wnd != nullptr ? wnd.hwnd : nullptr;
    void* wndH = CreateWindowExA(0u, "CFlatSecondary", title.data(),
        (u32)(WS_OVERLAPPEDWINDOW & ~(WS_THICKFRAME | WS_MAXIMIZEBOX)),
        CW_USEDEFAULT, CW_USEDEFAULT, w, h,
        owner, nullptr, _hInst, nullptr);
    void* st = CreateWindowExA(0u, "STATIC", message.data(),
        (u32)(WS_CHILD | WS_VISIBLE | SS_LEFT),
        16 * (int)dpi / 96, 16 * (int)dpi / 96,
        320 * (int)dpi / 96, 140 * (int)dpi / 96,
        wndH, nullptr, _hInst, nullptr);
    void* font = wnd != nullptr ? wnd.font : nullptr;
    if (font != nullptr) SendMessageA(st, (u32)WM_SETFONT, (u64)font, (i64)1);
    if (wnd != nullptr && wnd.dark)
    {
        int one = 1;
        DwmSetWindowAttribute(wndH, (u32)DWMWA_USE_IMMERSIVE_DARK_MODE, (void*)&one, 4u);
    }
    ShowWindow(wndH, (int)SW_SHOW);
    UpdateWindow(wndH);
}

// Render + reconcile-to-native the ACTIVE window's tree at its current client size.
// Controls are reused by key path, so only new/removed nodes create/destroy controls.
void buildCurrentTree()
{
    // A build that re-enters (the scrollbar's WM_SIZE) would overwrite the tree the outer
    // build is still committing - and leak it. Defer it to the end of the outer build.
    if (_building) { _rebuildPending = true; return; }
    _building = true;

    Window* wnd = curWin();
    if (wnd.ready) { IElement old = wnd.tree; deleteTree(old); wnd.ready = false; }
    wnd.tree = wnd.app.render(&wnd.ctx);
    layoutRootBounded(wnd.tree, 0, 0, wnd.w, wnd.h);
    wnd.applyTree(wnd.tree, &wnd.ctx);
    wnd.ready = true;

    _building = false;
    // The deferred rebuild picks up the client size the scrollbar left behind (wnd.w/h
    // were already updated by the WM_SIZE handler).
    if (_rebuildPending) { _rebuildPending = false; buildCurrentTree(); }
}

// Build the window at registry index `wi` (makes it active first).
void buildWindowTree(int wi) { _cur = wi; buildCurrentTree(); }

// Backward-compatible name: build the ACTIVE window's tree.
void buildNativeTree() { buildCurrentTree(); }

// A Segoe UI Variable Text face (fallback Segoe UI) sized to the dpi.
void* createUiFontDpi(u32 dpi)
{
    int h = -(15 * (int)dpi / 96);
    void* f = CreateFontA(h, 0, 0, 0, FW_NORMAL, 0u, 0u, 0u,
                          (u32)DEFAULT_CHARSET, (u32)OUT_DEFAULT_PRECIS,
                          (u32)CLIP_DEFAULT_PRECIS, (u32)CLEARTYPE_QUALITY,
                          (u32)(VARIABLE_PITCH | FF_SWISS), "Segoe UI Variable Text");
    return f;
}

// Lighten/darken a COLORREF by shifting every channel (clamped), for the hover/pressed
// button states in custom draw.
u32 shadeRef(u32 c, int delta)
{
    int r = (int)(c & 0xFFu) + delta;
    int g = (int)((c >> 8) & 0xFFu) + delta;
    int b = (int)((c >> 16) & 0xFFu) + delta;
    if (r < 0) r = 0; if (r > 255) r = 255;
    if (g < 0) g = 0; if (g > 255) g = 255;
    if (b < 0) b = 0; if (b > 255) b = 255;
    return (u32)(r | (g << 8) | (b << 16));
}

// NM_CUSTOMDRAW accent draw for a themed push button. Reads the NMCUSTOMDRAW at
// `lParam`; if the notifying control has a stored accent, fills the accent background,
// draws a focus ring when focused, paints the centered label in the accent text color,
// and returns CDRF_SKIPDEFAULT (fully owning the draw). Returns true (with the LRESULT in
// *result) only when it custom-drew; false lets the caller fall through to the default.
bool tryCustomDrawButton(Window* wnd, i64 lParam, i64* result)
{
    char* p = (char*)u2h((u64)lParam);
    u32* stagePtr = (u32*)(p + 24);
    if (stagePtr[0] != (u32)CDDS_PREPAINT) { result[0] = (i64)CDRF_DODEFAULT; return false; }
    NMHDR* nh = (NMHDR*)u2h((u64)lParam);
    u64 hFrom = (u64)nh.hwndFrom;
    u32 bg = 0u; u32 fg = 0u;
    if (!wnd.accentFor(hFrom, &bg, &fg)) return false;   // not an accent button

    void** hdcPtr = (void**)(p + 32);
    void* hdc = hdcPtr[0];
    i32* rcPtr = (i32*)(p + 40);
    u32* statePtr = (u32*)(p + 64);
    u32 state = statePtr[0];

    RECT rc = default;
    rc.left = rcPtr[0]; rc.top = rcPtr[1]; rc.right = rcPtr[2]; rc.bottom = rcPtr[3];

    u32 fill = bg;
    if ((state & (u32)CDIS_SELECTED) != 0u) fill = shadeRef(bg, 0 - 40);
    else if ((state & (u32)CDIS_HOT) != 0u) fill = shadeRef(bg, 28);
    void* br = CreateSolidBrush(fill);
    FillRect(hdc, &rc, br);
    DeleteObject(br);
    if ((state & (u32)CDIS_FOCUS) != 0u)
    {
        void* ring = CreateSolidBrush(shadeRef(bg, 60));
        FrameRect(hdc, &rc, ring);
        DeleteObject(ring);
    }
    char[256] label; GetWindowTextA(u2h(hFrom), label, 256);
    SetBkMode(hdc, TRANSPARENT);
    SetTextColor(hdc, fg);
    DrawTextA(hdc, label, -1, &rc,
              (u32)(DT_CENTER | DT_VCENTER | DT_SINGLELINE | DT_NOPREFIX));
    result[0] = (i64)CDRF_SKIPDEFAULT;
    return true;
}

// Headless verification of the accent-button DRAW. NM_CUSTOMDRAW cannot be captured
// by PrintWindow (it re-renders controls default), so this drives the custom-draw path into
// a memory DC with a synthetic NMCUSTOMDRAW and returns the filled pixel as a COLORREF. The
// self-test asserts it equals the button's stored accent, proving the accent renders.
u32 nativeTestCustomDrawFill(string keyPath)
{
    u64 h = curWin().ctx.nativeHandle(keyPath);
    if (h == 0u) return 0u;
    void* screenDC = GetDC(nullptr);
    void* memDC = CreateCompatibleDC(screenDC);
    void* bmp = CreateCompatibleBitmap(screenDC, 32, 16);
    void* oldBmp = SelectObject(memDC, bmp);
    char* buf = (char*)malloc((i64)96);
    int z = 0; while (z < 96) { buf[z] = (char)0; z++; }
    void** pHwnd = (void**)buf;              pHwnd[0]  = u2h(h);                 // hwndFrom@0
    u32*   pCode = (u32*)(buf + 16);         pCode[0]  = (u32)NM_CUSTOMDRAW;     // code@16
    u32*   pStage = (u32*)(buf + 24);        pStage[0] = (u32)CDDS_PREPAINT;     // dwDrawStage@24
    void** pHdc  = (void**)(buf + 32);       pHdc[0]   = memDC;                  // hdc@32
    i32*   pRc   = (i32*)(buf + 40);         pRc[0] = 0; pRc[1] = 0; pRc[2] = 32; pRc[3] = 16;
    u32*   pState = (u32*)(buf + 64);        pState[0] = (u32)CDIS_FOCUS;        // uItemState@64
    i64 res = 0;
    tryCustomDrawButton(curWin(), (i64)buf, &res);
    u32 px = (u32)GetPixel(memDC, 2, 2);
    free((void*)buf);
    SelectObject(memDC, oldBmp);
    DeleteObject(bmp);
    DeleteDC(memDC);
    ReleaseDC(nullptr, screenDC);
    return px;
}

// -- Host-neutral test drivers (form + data controls) ---------------------------
// These drive controls by KEY PATH through the same routing the OS uses on real input,
// so the gallery self-test contains no toolkit-typed calls and runs against any host.
// The Cocoa/WinUI hosts implement the SAME names (best-effort on Cocoa; WinUI too).

// Click a Button / Checkbox / RadioButton by key: mirror the OS auto-toggle for the two
// state controls, then route the click so the model fires + the tree re-renders.
void nativeClickButton(string keyPath)
{
    u64 h = curWin().ctx.nativeHandle(keyPath);
    if (h == 0u) return;
    void* ctrl = u2h(h);
    Window* wnd = curWin();
    IElement e = findByKey(wnd.tree, keySegment(wnd.tree, 0), keyPath);
    if (e != nullptr && e.kind() == ELEM_CHECKBOX)
    {
        int cur = (int)SendMessageA(ctrl, (u32)BM_GETCHECK, 0u, (i64)0);
        SendMessageA(ctrl, (u32)BM_SETCHECK, cur == 0 ? 1u : 0u, (i64)0);
    }
    else if (e != nullptr && e.kind() == ELEM_RADIO)
    {
        SendMessageA(ctrl, (u32)BM_SETCHECK, 1u, (i64)0);
    }
    routeClick(ctrl);
}

// True if the checkbox / radio at keyPath is checked (native BM_GETCHECK).
bool nativeIsChecked(string keyPath)
{
    u64 h = curWin().ctx.nativeHandle(keyPath);
    if (h == 0u) return false;
    return (int)SendMessageA(u2h(h), (u32)BM_GETCHECK, 0u, (i64)0) == 1;
}

// True if the control at keyPath is enabled (native IsWindowEnabled). Host-neutral
// reader for the disabled-until-enabled pattern (Save button, etc.).
bool nativeIsEnabled(string keyPath)
{
    u64 h = curWin().ctx.nativeHandle(keyPath);
    if (h == 0u) return false;
    return IsWindowEnabled(u2h(h)) != 0;
}

// The combo box selection index (-1 if none / not a combo).
int nativeComboSelected(string keyPath)
{
    u64 h = curWin().ctx.nativeHandle(keyPath);
    if (h == 0u) return 0 - 1;
    return (int)SendMessageA(u2h(h), (u32)CB_GETCURSEL, 0u, (i64)0);
}

// Select combo index `idx` and route CBN_SELCHANGE (controlled: the model follows).
void nativeComboSelect(string keyPath, int idx)
{
    u64 h = curWin().ctx.nativeHandle(keyPath);
    if (h == 0u) return;
    SendMessageA(u2h(h), (u32)CB_SETCURSEL, (u64)idx, (i64)0);
    routeCombo(u2h(h));
}

// Type `s` into a text input and route EN_CHANGE (controlled: onChangeText fires).
void nativeTypeText(string keyPath, string s)
{
    u64 h = curWin().ctx.nativeHandle(keyPath);
    if (h == 0u) return;
    SetWindowTextA(u2h(h), s.data());
    routeEdit(u2h(h));
}

// Select row `row` (if >= 0) then activate it (double-click / Enter) -> onActivate.
void nativeListActivate(string keyPath, int row)
{
    u64 h = curWin().ctx.nativeHandle(keyPath);
    if (h == 0u) return;
    if (row >= 0) nativeListSelect(keyPath, row);
    routeListActivate(u2h(h));
}

// The progress bar position (PBM_GETPOS); -1 if no control.
int nativeProgressValue(string keyPath)
{
    u64 h = curWin().ctx.nativeHandle(keyPath);
    if (h == 0u) return 0 - 1;
    return (int)SendMessageA(u2h(h), (u32)PBM_GETPOS, 0u, (i64)0);
}

// Drag a slider to position `v` and route WM_HSCROLL (controlled: onChange fires).
void nativeSliderSet(string keyPath, int v)
{
    u64 h = curWin().ctx.nativeHandle(keyPath);
    if (h == 0u) return;
    SendMessageA(u2h(h), (u32)TBM_SETPOS, 1u, (i64)v);
    routeSlider(u2h(h));
}

// True if the Image control at keyPath has an uploaded bitmap (setImageData ran).
bool nativeImageHasBitmap(string keyPath)
{
    u64 h = curWin().ctx.nativeHandle(keyPath);
    if (h == 0u) return false;
    return (void*)SendMessageA(u2h(h), (u32)STM_GETIMAGE, (u64)IMAGE_BITMAP, (i64)0) != nullptr;
}

// The stored accent background (COLORREF) of the button at keyPath, or 0 if none.
u32 nativeAccentBg(string keyPath)
{
    u64 h = curWin().ctx.nativeHandle(keyPath);
    if (h == 0u) return 0u;
    u32 bg = 0u; u32 fg = 0u;
    if (curWin().accentFor(h, &bg, &fg)) return bg;
    return 0u;
}

// Number of tooltips registered on the window's shared tooltip control (0 if none
// exists yet). Host-neutral reader proving a declared `tooltip` reached the OS.
int nativeTooltipCount()
{
    if (!hasCurWin() || curWin().tooltip == nullptr) return 0;
    return (int)SendMessageA(curWin().tooltip, (u32)TTM_GETTOOLCOUNT, 0u, (i64)0);
}

// Render the current window into an offscreen bitmap via PrintWindow and write a 24bpp BMP
// (through core/graphic/bitmap.cb) to `path`. This is the Win32 backend for ui_test.cb's
// shot()/uiShot() verb; cocoa/winui return false. Promoted from the gallery launcher's
// saveWindowBmp so any ui_native app (and the runner's --shot-dir auto-capture) can use it.
bool nativeSaveWindowBmp(string path)
{
    if (!hasCurWin() || curWin().hwnd == nullptr) return false;
    void* hwnd = curWin().hwnd;
    RECT rc = default;
    GetClientRect(hwnd, &rc);
    int W = rc.right - rc.left;
    int H = rc.bottom - rc.top;
    if (W <= 0 || H <= 0) return false;

    void* screenDC = GetDC(nullptr);
    void* memDC = CreateCompatibleDC(screenDC);
    void* bmp = CreateCompatibleBitmap(screenDC, W, H);
    void* oldBmp = SelectObject(memDC, bmp);
    // Pre-fill with the theme background so any region PrintWindow leaves unrendered (a
    // window taller than the screen work area PrintWindow clamps to) reads as the app
    // background rather than uninitialized black.
    if (curWin().bgBrush != nullptr) FillRect(memDC, &rc, curWin().bgBrush);
    else FillRect(memDC, &rc, GetStockObject(WHITE_BRUSH));
    PrintWindow(hwnd, memDC, (u32)PW_RENDERFULLCONTENT);
    SelectObject(memDC, oldBmp);

    // Pull the pixels as top-down BGRA32 in one GetDIBits call (fast; no per-pixel GetPixel).
    BmiHeader bi = default;
    bi.biSize = 40u; bi.biWidth = W; bi.biHeight = 0 - H; bi.biPlanes = 1; bi.biBitCount = 32;
    u64 bufN = (u64)(W * H * 4);
    char* buf = (char*)malloc((i64)bufN);
    GetDIBits(memDC, bmp, 0u, (u32)H, (void*)buf, &bi, (u32)DIB_RGB_COLORS);

    Bitmap* out = new Bitmap;
    out.create(W, H);
    int y = 0;
    while (y < H)
    {
        int x = 0;
        while (x < W)
        {
            int idx = (y * W + x) * 4;
            BitmapPixel px = default;
            px.b = (u8)buf[idx + 0]; px.g = (u8)buf[idx + 1]; px.r = (u8)buf[idx + 2]; px.a = (u8)255;
            out.set(x, y, px);
            x++;
        }
        y++;
    }
    bool ok = out.save(path);
    delete out;
    free((void*)buf);
    DeleteObject(bmp);
    DeleteDC(memDC);
    ReleaseDC(nullptr, screenDC);
    return ok;
}

// -- Host-neutral hardening drivers (Win32 bodies) ------------------------------
// The MSAA/UIA accessible Name of the control at keyPath (its window text - the OS Name
// source; for a textless control this is the tooltip mirrored in by applyTree).
string nativeAccessibleName(string keyPath)
{
    u64 h = curWin().ctx.nativeHandle(keyPath);
    if (h == 0u) return "";
    char[512] buf;
    GetWindowTextA(u2h(h), buf, 512);
    return "" + buf;
}

// Host-side logical Tab focus. A headless window is never foreground, so GetFocus() reads
// NULL there; the tests chain focus through this tracked handle (GetNextDlgTabItem is the
// real Tab ring, independent of OS foreground) and SetFocus is called for fidelity.
u64 _testFocusH = 0u;

// Advance logical Tab focus to the tabstop after `from` (nullptr = the first tabstop),
// tracking + real-SetFocus-ing it; returns the new focus handle (0 if none).
u64 _focusStep(void* fromCtl)
{
    void* n = GetNextDlgTabItem(curWin().hwnd, fromCtl, 0);
    if (n != nullptr) { _testFocusH = (u64)n; SetFocus(n); } else _testFocusH = 0u;
    return _testFocusH;
}

// Handle-valued ring walk (leak-free: no owned key string allocated per step).
u64 nativeFocusFirstH() { return _focusStep(nullptr); }
u64 nativeFocusNextH()  { return _focusStep(u2h(_testFocusH)); }

// Focus the first WS_TABSTOP control in the dialog Tab ring; return its key path.
string nativeFocusFirst() { return curWin().keyForHandle(nativeFocusFirstH()); }

// Advance focus to the next control in the Tab ring (Tab key equivalent); return its key.
string nativeFocusNext() { return curWin().keyForHandle(nativeFocusNextH()); }

// The key path / handle of the control that currently holds logical Tab focus.
string nativeFocusedKey() { return curWin().keyForHandle(_testFocusH); }
u64    nativeFocusedHandle() { return _testFocusH; }

// Drive a live client-area resize (WM_SIZE) to w x h DIPs, so the host relayouts + reconciles.
void nativeResizeClient(int wDip, int hDip)
{
    Window* wnd = curWin();
    int px = wDip * wnd.dipX();
    int py = hDip * wnd.dipY();
    i64 lp = (i64)(((py & 0xFFFF) << 16) | (px & 0xFFFF));
    SendMessageA(wnd.hwnd, (u32)WM_SIZE, 0u, lp);
}

// LRESULT CALLBACK shared by all windows. Resolves the servicing window by scanning
// the (small) registry for its HWND and sets `_cur` so app handlers reach it.
stdcall i64 NativeWndProc(void* hwnd, u32 msg, u64 wParam, i64 lParam)
{
    int wi = findWindowIdx(hwnd);
    if (wi < 0) return DefWindowProcA(hwnd, msg, wParam, lParam);
    _cur = wi;
    Window* wnd = curWin();

    if (msg == WM_APP_CALL)
    {
        // A worker thread marshaled a closure here via ctx.post(); run + free it.
        __uiRunPostBox((u64)lParam);
        // A posted closure is a UI-thread mutation like any native event handler: if it
        // called ctx.invalidate() it expects a repaint, so pump here (handlers do the same).
        pumpNative();
        return (i64)0;
    }

    // WM_MOUSEWHEEL is focus-directed, so a wheel over an unfocused canvas child lands
    // here on the frame. Hit-test the cursor (lParam is in SCREEN coords for wheel
    // messages) against this window's canvas children so the wheel reaches the canvas
    // under the pointer, the way Cocoa's scrollWheel: already does.
    if (msg == WM_MOUSEWHEEL || msg == WM_MOUSEHWHEEL)
    {
        double lines = (double)_hiWordSigned((i64)wParam) / 120.0;
        bool ctrl = (wParam & (u64)MK_CONTROL) != 0u;
        if (_routeCanvasWheel(_loWordSigned(lParam), _hiWordSigned(lParam), lines,
                              msg == WM_MOUSEHWHEEL, ctrl))
            return (i64)0;
        // Not consumed by a canvas child: scroll the page (3 rows per notch, wheel-up
        // moves the content down, i.e. a smaller offset).
        if (msg == WM_MOUSEWHEEL && wnd.ready && wnd.scrollMaxPx > 0)
        {
            wnd.scrollTo(wnd.scrollPx - (int)(lines * 3.0 * (double)wnd.dipY()));
            return (i64)0;
        }
        return DefWindowProcA(hwnd, msg, wParam, lParam);
    }

    // The root ScrollView's scrollbar CONTROL (lParam is the notifying bar's HWND; a TextArea's
    // own WS_VSCROLL bar forwards through the pane with a different one and falls through).
    if (msg == WM_VSCROLL && wnd.vscroll != nullptr && lParam == (i64)wnd.vscroll)
    {
        if (wnd.ready && wnd.scrollMaxPx > 0)
        {
            int code = (int)(wParam & (u64)0xFFFF);
            int line = wnd.dipY();
            int page = wnd.h * wnd.dipY() - line;
            if (page < line) page = line;
            int pos = wnd.scrollPx;
            if (code == (int)SB_LINEUP)             pos = pos - line;
            else if (code == (int)SB_LINEDOWN)      pos = pos + line;
            else if (code == (int)SB_PAGEUP)        pos = pos - page;
            else if (code == (int)SB_PAGEDOWN)      pos = pos + page;
            else if (code == (int)SB_TOP)           pos = 0;
            else if (code == (int)SB_BOTTOM)        pos = wnd.scrollMaxPx;
            else if (code == (int)SB_THUMBTRACK || code == (int)SB_THUMBPOSITION)
                                                    pos = wnd.scrollTrackPos();
            wnd.scrollTo(pos);
        }
        return (i64)0;
    }

    // An owner-drawn status bar pane / tab item: the control hands its drawing to the parent,
    // which is how a common control (it ignores WM_CTLCOLOR*) gets the theme's colors.
    if (msg == WM_DRAWITEM && lParam != (i64)0)
    {
        if (wnd._drawStatusItem((u64)lParam)) return (i64)1;
        if (wnd._drawTabItem((u64)lParam)) return (i64)1;
        return DefWindowProcA(hwnd, msg, wParam, lParam);
    }

    if (msg == WM_SIZE)
    {
        wnd.clientPxW = (int)(lParam & (i64)0xFFFF);
        wnd.clientPxH = (int)((lParam >> 16) & (i64)0xFFFF);
        wnd._syncSizeDip();      // the scrollbar column is not layout width
        wnd._layoutVScroll();
        buildCurrentTree();
        return (i64)0;
    }

    if (msg == WM_COMMAND)
    {
        int code = (int)((wParam >> 16) & (u64)0xFFFF);
        void* ctrl = u2h((u64)lParam);
        if (ctrl == nullptr)
        {
            if (wnd.ready) routeMenu((int)(wParam & (u64)0xFFFF));
        }
        else if (wnd.ready)
        {
            if (code == BN_CLICKED)                          routeClick(ctrl);
            else if (code == EN_CHANGE && !wnd.applying)     routeEdit(ctrl);
            else if (code == CBN_SELCHANGE && !wnd.applying) routeCombo(ctrl);
            else if (code == BN_SETFOCUS || code == EN_SETFOCUS) mirrorFocus(ctrl);
        }
        return (i64)0;
    }

    if (msg == WM_NOTIFY)
    {
        // NM_CUSTOMDRAW accent buttons: intercept before the data-control routing so
        // a themed push button paints its accent fill + focus ring (fixing dark mode).
        NMHDR* nh = (NMHDR*)u2h((u64)lParam);
        if (wnd.ready && nh != nullptr && (int)nh.code == NM_CUSTOMDRAW)
        {
            i64 cdr = (i64)CDRF_DODEFAULT;
            if (tryCustomDrawButton(wnd, lParam, &cdr)) return cdr;
        }
        if (wnd.ready && routeNotify(lParam)) return (i64)0;
        return DefWindowProcA(hwnd, msg, wParam, lParam);
    }

    // Right-click over a control with a registered context menu -> TrackPopupMenu. wParam is the
    // control the click landed on - but an HTTRANSPARENT one (a STATIC: every Box, Text and
    // backdrop) is fallen THROUGH, so wParam is then this frame and resolves to no key. Hit-test
    // the point against the element tree in that case. lParam = -1 is the keyboard menu key
    // (no point), which has no element to resolve and falls through to the default handling.
    if (msg == WM_CONTEXTMENU)
    {
        if (wnd.ready)
        {
            if (wnd.showContextMenu((void*)wParam, lParam)) return (i64)0;
            if (lParam != (i64)(-1)
                && wnd.showContextMenuAt(_loWordSigned(lParam), _hiWordSigned(lParam), lParam))
                return (i64)0;
        }
        return DefWindowProcA(hwnd, msg, wParam, lParam);
    }

    // Splitter drag: a press in a divider gutter (client area, no child control there)
    // captures the mouse; moves re-ratio the split; release ends the drag.
    if (msg == WM_LBUTTONDOWN)
    {
        if (wnd.ready)
        {
            int mx = (int)(lParam & (i64)0xFFFF);
            int my = (int)((lParam >> 16) & (i64)0xFFFF);
            string sk = wnd.splitAtPixel(mx, my);
            if (sk.length() > 0) { wnd.splitDragKey = "" + sk; SetCapture(hwnd); return (i64)0; }
        }
        return DefWindowProcA(hwnd, msg, wParam, lParam);
    }

    if (msg == WM_MOUSEMOVE)
    {
        if (wnd.splitDragKey.length() > 0)
        {
            int mx = (int)(lParam & (i64)0xFFFF);
            int my = (int)((lParam >> 16) & (i64)0xFFFF);
            splitDragTo(wnd, wnd.splitDragKey, mx, my);
            return (i64)0;
        }
        return DefWindowProcA(hwnd, msg, wParam, lParam);
    }

    if (msg == WM_LBUTTONUP)
    {
        if (wnd.splitDragKey.length() > 0) { wnd.splitDragKey = ""; ReleaseCapture(); return (i64)0; }
        return DefWindowProcA(hwnd, msg, wParam, lParam);
    }

    if (msg == WM_HSCROLL)
    {
        void* ctrl = u2h((u64)lParam);
        if (ctrl != nullptr && wnd.ready) routeSlider(ctrl);
        return (i64)0;
    }

    if (msg == WM_DPICHANGED)
    {
        u32 nd = (u32)((wParam >> 16) & (u64)0xFFFF);
        if (nd < 96u) nd = 96u;
        wnd.dpi = nd;
        if (wnd.font != nullptr) DeleteObject(wnd.font);
        wnd.font = createUiFontDpi(nd);
        int i = 0;
        while (i < wnd.liveHandles.count())
        {
            SendMessageA(u2h(wnd.liveHandles.get(i)), (u32)WM_SETFONT,
                         (u64)wnd.font, (i64)1);
            i++;
        }
        RECT* pr = (RECT*)u2h((u64)lParam);
        if (pr != nullptr)
            SetWindowPos(hwnd, nullptr, pr.left, pr.top,
                         pr.right - pr.left, pr.bottom - pr.top,
                         (u32)(SWP_NOZORDER | SWP_NOACTIVATE));
        if (wnd.ready) { layoutRootBounded(wnd.tree, 0, 0, wnd.w, wnd.h); wnd.applyTree(wnd.tree, &wnd.ctx); }
        return (i64)0;
    }

    if (msg == WM_CTLCOLORSTATIC || msg == WM_CTLCOLORBTN || msg == WM_CTLCOLOREDIT)
    {
        // A container backdrop paints its own fill; every other control takes the theme.
        if (msg == WM_CTLCOLORSTATIC)
        {
            u32 bdBg = 0u;
            void* bdBrush = wnd.backdropBrush((u64)lParam, &bdBg);
            if (bdBrush != nullptr)
            {
                void* bdc = u2h(wParam);
                SetTextColor(bdc, wnd.themeText);
                SetBkColor(bdc, bdBg);
                return (i64)(u64)bdBrush;
            }
        }
        void* brush = wnd.bgBrush;
        if (brush != nullptr)
        {
            void* hdc = u2h(wParam);
            SetTextColor(hdc, wnd.themeText);
            SetBkColor(hdc, wnd.themeBg);
            return (i64)(u64)brush;
        }
        return DefWindowProcA(hwnd, msg, wParam, lParam);
    }

    if (msg == WM_ERASEBKGND)
    {
        void* brush = wnd.bgBrush;
        if (brush != nullptr)
        {
            void* hdc = u2h(wParam);
            RECT rc = default;
            GetClientRect(hwnd, &rc);
            FillRect(hdc, &rc, brush);
            return (i64)1;
        }
        return DefWindowProcA(hwnd, msg, wParam, lParam);
    }

    // Close guard: let the app veto (dirty-save prompt) before the window closes.
    if (msg == WM_CLOSE)
    {
        if (_hasCloseQuery && !_closeQuery()) return (i64)0;
        DestroyWindow(hwnd);
        return (i64)0;
    }

    if (msg == WM_DESTROY)
    {
        destroyWindowStateAt(wi);
        // Quit the message loop only when the last window is gone.
        if (_windows.count() == 0) PostQuitMessage(0);
        return (i64)0;
    }

    return DefWindowProcA(hwnd, msg, wParam, lParam);
}

// Tear down the window at index `idx`: free its cflat + GDI state, remove it from the
// registry, and delete it. The HWND + child controls are destroyed by Windows; child
// controls cascade. `list.take` transfers ownership so the Window is deletable.
void destroyWindowStateAt(int idx)
{
    if (idx < 0 || idx >= _windows.count()) return;
    _cur = idx;
    curWin().dispose();
    Window* owned = _windows.take(idx);
    delete owned;
    _cur = _windows.count() > 0 ? 0 : -1;
}

// -- The content pane: the one window that scrolls -------------------------------
// Every scrollable control is a child of this pane rather than of the frame, so a scroll
// moves ONE window: the OS blits the still-visible band and invalidates only the strip
// that came into view. The controls never move, so they never repaint - which is what
// killed the mid-scroll smearing (~60 controls x 1 async WM_PAINT per wheel notch).
//
// The pane is deliberately inert: it owns no state and paints nothing but its background.
// Parent notifications from the controls now land here instead of on the frame, so the
// handful the frame's WndProc handles are forwarded up verbatim.
bool _paneClassReg = false;

stdcall i64 ContentPaneProc(void* hwnd, u32 msg, u64 wParam, i64 lParam)
{
    // Child notifications: the frame's handlers look their Window up by the FRAME HWND, so
    // forwarding keeps them working unchanged. WM_CTLCOLOR*'s brush return value and
    // NM_CUSTOMDRAW's CDRF_* pass straight back through the SendMessage result.
    if (msg == WM_COMMAND || msg == WM_NOTIFY || msg == WM_HSCROLL || msg == WM_VSCROLL
        || msg == WM_DRAWITEM || msg == WM_MEASUREITEM || msg == WM_CONTEXTMENU
        || msg == WM_CTLCOLORSTATIC || msg == WM_CTLCOLORBTN || msg == WM_CTLCOLOREDIT)
    {
        return SendMessageA(GetParent(hwnd), msg, wParam, lParam);
    }
    // The pane is a carrier, not a surface: a press on its bare background (a SplitView
    // gutter, or a backdrop STATIC that already answers HTTRANSPARENT) has to reach the
    // FRAME, which owns the splitter hit-test. HTTRANSPARENT passes it through - and the
    // pane's own children still win the hit-test, since they are searched first.
    if (msg == WM_NCHITTEST) return (i64)HTTRANSPARENT;
    // Paint the band a scroll just exposed in the app background; without this it flashes
    // the wrong color on every notch.
    if (msg == WM_ERASEBKGND)
    {
        void* brush = nullptr;
        if (_setCurFromFrame(GetParent(hwnd))) brush = curWin().bgBrush;
        if (brush == nullptr) return DefWindowProcA(hwnd, msg, wParam, lParam);
        RECT rc = default;
        GetClientRect(hwnd, &rc);
        FillRect(u2h(wParam), &rc, brush);   // clipped to the update region by the DC
        return (i64)1;
    }
    // Everything else (WM_MOUSEWHEEL above all) defaults through to the frame.
    return DefWindowProcA(hwnd, msg, wParam, lParam);
}

// Register the content-pane class once. No CS_HREDRAW/CS_VREDRAW (a resize must not
// invalidate the whole content-tall pane) and no class brush (WM_ERASEBKGND fills it).
void ensureContentPaneClass()
{
    if (_paneClassReg) return;
    WNDCLASSEXA wc = default;
    wc.cbSize        = (u32)sizeof(WNDCLASSEXA);
    wc.style         = 0u;
    wc.lpfnWndProc   = (void*)ContentPaneProc;
    wc.hInstance     = _hInst;
    wc.hCursor       = LoadCursorA(nullptr, (char*)IDC_ARROW);
    wc.hbrBackground = nullptr;
    wc.lpszClassName = "CFlatContentPane";
    RegisterClassExA(&wc);
    _paneClassReg = true;
}

// Register the window class once.
void ensureWindowClass()
{
    if (_classReg) return;
    SetProcessDpiAwarenessContext((void*)(i64)(-4));
    InitCommonControls();
    _hInst = GetModuleHandleA(nullptr);

    WNDCLASSEXA wc = default;
    wc.cbSize        = (u32)sizeof(WNDCLASSEXA);
    wc.style         = (u32)(CS_HREDRAW | CS_VREDRAW);
    wc.lpfnWndProc   = (void*)NativeWndProc;
    wc.hInstance     = _hInst;
    wc.hCursor       = LoadCursorA(nullptr, (char*)IDC_ARROW);
    wc.hbrBackground = (void*)((i64)COLOR_BTNFACE + 1);
    wc.lpszClassName = "CFlatNativeWindow";
    RegisterClassExA(&wc);
    _classReg = true;
}

// Create a new top-level window bound to `app`, register it in the owning list,
// install the ctx.post marshaling hooks, and (if shown) let WM_SIZE build its tree.
// Returns the window's registry INDEX and leaves it active (_cur). We return an int,
// not a Window*: an owning class pointer bound to a caller local would auto-free the
// window at scope exit and double-free with teardown - callers use curWin() instead.
// `show` controls visibility (the self-test creates it hidden and builds explicitly).
int createAppWindow(IComponent app, const char* title, bool show)
{
    ensureWindowClass();

    Window* fresh = new Window();
    fresh.app = app;
    _windows.add(fresh);            // moves the window into the owning registry
    _cur = _windows.count() - 1;
    Window* wnd = curWin();         // borrow the just-added window

    // WS_CLIPCHILDREN keeps the frame's background erase OUT of every child control's
    // rectangle: without it the parent paints over each child before the child repaints,
    // which is the classic Win32 flicker (very visible while scrolling).
    void* hwnd = CreateWindowExA(
        0u, "CFlatNativeWindow", title, (u32)(WS_OVERLAPPEDWINDOW | WS_CLIPCHILDREN),
        CW_USEDEFAULT, CW_USEDEFAULT, 760, 560,
        nullptr, nullptr, _hInst, nullptr);
    wnd.hwnd = hwnd;               // findWindowIdx now resolves this window's messages
    wnd.dpi = GetDpiForWindow(hwnd);
    if (wnd.dpi < 96u) wnd.dpi = 96u;
    wnd.font = createUiFontDpi(wnd.dpi);

    // The content pane, created before any control so every control can be parented to it.
    // WS_EX_CONTROLPARENT is required: without it IsDialogMessageA / GetNextDlgTabItem would
    // not recurse into the pane and the Tab ring would find no controls at all. It starts as
    // a stub - applyTree gives it its real geometry (_layoutContentPane). A status bar must
    // end up ABOVE it in the frame's z-order; creation order does NOT do that (the common
    // control self-docks to the bottom), so _applyNode raises it explicitly.
    ensureContentPaneClass();
    wnd.content = CreateWindowExA((u32)WS_EX_CONTROLPARENT, "CFlatContentPane", "",
        (u32)(WS_CHILD | WS_VISIBLE | WS_CLIPCHILDREN | WS_CLIPSIBLINGS),
        0, 0, 10, 10, hwnd, nullptr, _hInst, nullptr);

    // The scroll gutter, whose NON-CLIENT bar is the page's scrollbar (see ScrollGutterProc):
    // it stops above the status bar, and unlike the frame's own WS_VSCROLL bar it brings no
    // size box. Hidden until the content overflows; _syncScrollBar shows + sizes it. Raised
    // above the content pane in z, like the status bar (a later-created sibling lands below).
    ensureScrollGutterClass();
    wnd.vscroll = CreateWindowExA(0u, "CFlatScrollGutter", "",
        (u32)(WS_CHILD | WS_CLIPSIBLINGS | WS_VSCROLL),
        0, 0, 10, 10, hwnd, nullptr, _hInst, nullptr);
    SetWindowPos(wnd.vscroll, hwndTop(), 0, 0, 0, 0,
                 (u32)(SWP_NOMOVE | SWP_NOSIZE | SWP_NOACTIVATE));

    // Install the thread-marshaling hooks so this window's ctx.post() delivers here.
    wnd.ctx.bindPost((u64)hwnd, _win32PostEnqueue);
    wnd.ctx.bindThreadId(_win32CurTid(), _win32CurTid);

    buildMenuBar(hwnd);
    if (show)
    {
        ShowWindow(hwnd, (int)SW_SHOW);
        UpdateWindow(hwnd);
    }
    return _cur;
}

// Open a second (or Nth) top-level application window running `app`, built + shown,
// sharing the one message loop. This is the genuine multi-window feature ("New Window").
void openAppWindow(IComponent app, const char* title)
{
    createAppWindow(app, title, true);
    buildNativeTree();   // build the just-created (now active) window
}

// Register the class, create + show the primary window, and run the message loop
// until every window is closed. IsDialogMessageA on the active window gives OS-owned
// Tab/arrow navigation and default-button handling among the WS_TABSTOP controls.
//
// The component MUST be heap-allocated (`new`): a Window stashes it and `delete`s it
// on teardown, so it has to outlive this call.
int runAppGuiNative(IComponent app, const char* title)
{
    createAppWindow(app, title, true);
    if (curWin().hwnd == nullptr) { printf("CreateWindowExA failed\n"); return 1; }
    if (!curWin().ready) buildNativeTree();   // in case WM_SIZE did not fire on show

    MSG msg = default;
    while (GetMessageA(&msg, nullptr, 0u, 0u) > 0)
    {
        void* activeHwnd = GetActiveWindow();
        if (activeHwnd == nullptr && _windows.count() > 0) activeHwnd = _windows.get(0).hwnd;
        if (activeHwnd != nullptr && _accelTable != nullptr && TranslateAcceleratorA(activeHwnd, _accelTable, &msg) != 0)
            continue;
        if (IsDialogMessageA(activeHwnd, &msg) == 0)
        {
            TranslateMessage(&msg);
            DispatchMessageA(&msg);
        }
    }
    return (int)msg.wParam;
}

// Fully release all host + context state - for the headless self-tests, so
// --heap-audit sees no residue. Destroys every window (each `delete Window` frees its
// ctx + live lists), then releases the app-wide menu declaration + closures.
void nativeTeardownForTest()
{
    // DestroyWindow synchronously sends WM_DESTROY -> destroyWindowStateAt, which frees
    // the Window and drops it from _windows (via list.take, transferring ownership).
    while (_windows.count() > 0)
    {
        Window* wnd = _windows.get(0);
        void* hwnd = wnd.hwnd;
        if (hwnd != nullptr) DestroyWindow(hwnd);
        else destroyWindowStateAt(0);
    }
    _cur = -1;
    { list<Window*> lw = move _windows; }
    { list<string> a3 = move _menuTop; }
    { list<int>    a4 = move _menuItemTopIdx; }
    { list<string> a5 = move _menuItemLabel; }
    { list<int>    a6 = move _menuItemCmd; }
    { list<int>    a7 = move _menuAccelKey; }
    { list<int>    a8 = move _menuAccelMods; }
    if (_hasMenuHandler) { Lambda<void(int)> a9 = move _menuHandler; _hasMenuHandler = false; }
    if (_hasCloseQuery)  { Lambda<bool()> a10 = move _closeQuery; _hasCloseQuery = false; }
}
