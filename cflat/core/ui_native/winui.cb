using XamlTextChangedHandler       = Microsoft.UI.Xaml.Controls.TextChangedEventHandler;
using XamlDoubleTappedHandler      = Microsoft.UI.Xaml.Input.DoubleTappedEventHandler;
using XamlTabView                  = Microsoft.UI.Xaml.Controls.ITabView;
using XamlTabViewFactory           = Microsoft.UI.Xaml.Controls.ITabViewFactory;
using XamlTabViewItem              = Microsoft.UI.Xaml.Controls.ITabViewItem;
using XamlTabViewItemFactory       = Microsoft.UI.Xaml.Controls.ITabViewItemFactory;
using XamlTextBlock                = Microsoft.UI.Xaml.Controls.ITextBlock;
using XamlTextBox                  = Microsoft.UI.Xaml.Controls.ITextBox;
using XamlTreeView                 = Microsoft.UI.Xaml.Controls.ITreeView;
using XamlTreeView2                = Microsoft.UI.Xaml.Controls.ITreeView2;
using XamlTreeView3                = Microsoft.UI.Xaml.Controls.ITreeView3;
using XamlTreeViewFactory          = Microsoft.UI.Xaml.Controls.ITreeViewFactory;
using XamlTreeViewNode             = Microsoft.UI.Xaml.Controls.ITreeViewNode;
using XamlTreeViewNodeFactory      = Microsoft.UI.Xaml.Controls.ITreeViewNodeFactory;
using XamlTreeExpandingArgs        = Microsoft.UI.Xaml.Controls.ITreeViewExpandingEventArgs;
using XamlMenuFlyout               = Microsoft.UI.Xaml.Controls.IMenuFlyout;
using XamlMenuFlyoutFactory        = Microsoft.UI.Xaml.Controls.IMenuFlyoutFactory;
using XamlMenuFlyoutItem           = Microsoft.UI.Xaml.Controls.IMenuFlyoutItem;
using XamlMenuFlyoutItemFactory    = Microsoft.UI.Xaml.Controls.IMenuFlyoutItemFactory;
using XamlMenuFlyoutItemBase       = Microsoft.UI.Xaml.Controls.IMenuFlyoutItemBase;
using XamlFlyoutBase               = Microsoft.UI.Xaml.Controls.Primitives.IFlyoutBase;
