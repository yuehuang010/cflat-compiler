// ui.cb - a small React-Native-style declarative UI library for CFlat.
//
// Design (see doc/UI.md for the frozen v0.4 contract):
//   - IElement is an interface; every host node (View/Text/Button) implements it.
//   - Nodes are heap-allocated and owned by their parent through the IElement
//     interface; teardown walks the tree via destroyTree().
//   - Children are list<IElement> (avoids the T[] length-inference gap).
//   - Events are Lambda<void()> closures with automatic capture.
//   - Input flows through a single dispatch(Event) seam (pointer + key), focus is
//     a keyed identity tracked in UiContext, layout is one constraints-in /
//     size-out pass with a flexDirection strategy, and prop change-detection is a
//     structured propsEqual() (no stringly-typed signatures).
//   - The library carries NO process-global mutable state: the dirty flag and the
//     focused-node identity live in a host-owned UiContext, threaded through
//     render(UiContext*). Single mounted app, single thread (see doc/UI.md).
//   - v0.4 does not paint pixels in the library; nodes paint via the ICanvas seam
//     and serialize to a renderer-friendly JSON shape.

import "list.cb";
import "string.cb";
import "dictionary.cb";

// Flex main-axis direction for a View's children (the layout pass strategy).
int DIR_COLUMN = 0;   // stack children top-to-bottom (default)
int DIR_ROW    = 1;   // place children left-to-right

// Flex wrap mode (DIR_ROW only; see doc/UI.md "Flex weights" / flexWrap).
int WRAP_NONE = 0;   // single line, the default (unchanged behavior)
int WRAP_WRAP = 1;   // children that would overflow availW start a new line

// Shared layout/style props. Plain value struct carried by host elements. Field
// names track React Native (flexDirection); a typed struct, not an open bag.
// COLOR_DEFAULT (0) means "no explicit color": the ICanvas falls back to its
// monochrome default (black ink / black border / no fill), so a tree that sets no
// colors renders exactly as it did before colors existed. 0 is deliberately the
// sentinel because a default/zero-initialized struct field is then automatically
// "unset" - the framework never depends on a -1 field initializer surviving (a
// nested `Struct f = default;` field is zero-filled in CFlat, not initializer-run).
//
// Build explicit colors with rgb(): it packs 0xRRGGBB AND sets a high marker bit so
// even pure black (rgb(0,0,0)) is non-zero and distinct from "unset". colorRef() in
// the GDI host masks the marker off.
int COLOR_DEFAULT = 0;
int COLOR_SET_BIT = 0x1000000;   // marks an explicit color; masked off at draw time

int rgb(int r, int g, int b)
{
    return COLOR_SET_BIT | ((r & 0xFF) << 16) | ((g & 0xFF) << 8) | (b & 0xFF);
}

int clampByte(int v)
{
    if (v < 0) return 0;
    if (v > 255) return 255;
    return v;
}

// Lighten (delta > 0) or darken (delta < 0) a color by shifting every channel.
// Used for hover/pressed shades of a base color. An unset color (0) stays unset,
// so a monochrome widget shows no hover/press fill (it had none to shade).
int shade(int color, int delta)
{
    if (color == 0) return 0;
    int r = clampByte(((color >> 16) & 0xFF) + delta);
    int g = clampByte(((color >> 8) & 0xFF) + delta);
    int b = clampByte((color & 0xFF) + delta);
    return rgb(r, g, b);
}

// Collapse a color halfway toward mid-gray for a disabled/dimmed look. An unset
// color (0, i.e. default black ink) dims to a plain gray rather than staying black.
int dimColor(int color)
{
    if (color == 0) return rgb(150, 150, 150);
    int r = (((color >> 16) & 0xFF) + 150) / 2;
    int g = (((color >> 8) & 0xFF) + 150) / 2;
    int b = ((color & 0xFF) + 150) / 2;
    return rgb(r, g, b);
}

struct Style
{
    int padding = 0;
    int width = 0;
    int height = 0;
    int flexDirection = 0;          // DIR_COLUMN | DIR_ROW
    int color = 0;                  // foreground (text / border); 0 = default
    int backgroundColor = 0;        // fill; 0 = no fill
    int gap = 0;                    // cells of space between stacked children
    int flex = 0;                   // main-axis weight; 0 = intrinsic size (unset)
    int flexWrap = 0;               // WRAP_NONE | WRAP_WRAP (DIR_ROW only)
};

Style makeStyle(int padding, int width, int height)
{
    Style s = default;
    s.padding = padding;
    s.width = width;
    s.height = height;
    return s;
}

// A Style carrying only a flex weight (main-axis grow factor in a DIR_ROW /
// DIR_COLUMN parent). Pair with field assignment for width/height/etc.
Style flexStyle(int flex)
{
    Style s = default;
    s.flex = flex;
    return s;
}

bool styleIsEmpty(Style s)
{
    return s.padding == 0 && s.width == 0 && s.height == 0 && s.flexDirection == 0
        && s.color == 0 && s.backgroundColor == 0 && s.gap == 0 && s.flex == 0
        && s.flexWrap == 0;
}

bool styleEquals(Style a, Style b)
{
    return a.padding == b.padding && a.width == b.width
        && a.height == b.height && a.flexDirection == b.flexDirection
        && a.color == b.color && a.backgroundColor == b.backgroundColor
        && a.gap == b.gap && a.flex == b.flex && a.flexWrap == b.flexWrap;
}

string styleToJson(Style s)
{
    return "{\"padding\":" + s.padding.toString()
         + ",\"width\":" + s.width.toString()
         + ",\"height\":" + s.height.toString()
         + ",\"flexDirection\":" + s.flexDirection.toString()
         + ",\"color\":" + s.color.toString()
         + ",\"backgroundColor\":" + s.backgroundColor.toString()
         + ",\"gap\":" + s.gap.toString()
         + ",\"flex\":" + s.flex.toString()
         + ",\"flexWrap\":" + s.flexWrap.toString() + "}";
}

// -- Rect: an absolute cell rectangle assigned during layout ------------------
// Each node stores its own bounds so paint and hit-testing agree on geometry.
struct Rect
{
    int x = 0;
    int y = 0;
    int w = 0;
    int h = 0;

    bool contains(int px, int py)
    {
        return px >= x && px < x + w && py >= y && py < y + h;
    }
};

// Intersection of two rects (empty - zero w/h - if they do not overlap). Drives
// the ICanvas clip stack so a ScrollView only paints inside its viewport.
Rect intersectRect(Rect a, Rect b)
{
    int x0 = a.x; if (b.x > x0) x0 = b.x;
    int y0 = a.y; if (b.y > y0) y0 = b.y;
    int x1 = a.x + a.w; int bx1 = b.x + b.w; if (bx1 < x1) x1 = bx1;
    int y1 = a.y + a.h; int by1 = b.y + b.h; if (by1 < y1) y1 = by1;
    Rect r = default;
    r.x = x0; r.y = y0;
    r.w = x1 - x0; if (r.w < 0) r.w = 0;
    r.h = y1 - y0; if (r.h < 0) r.h = 0;
    return r;
}

// -- Layout protocol: constraints in -> size out -------------------------------
// A node lays out within a LayoutConstraints (its origin + the space available)
// and returns the Size it consumed; it also stamps its own absolute `bounds` so
// paint and hit-test agree. Container nodes drive their children with this one
// pass; flex/row/column/scroll are STRATEGIES over it, not bespoke per-node math.
// Layout stays in CELL units - the ICanvas owns the cell->pixel mapping.
int LAYOUT_UNBOUNDED = 1000000;   // "no height limit" sentinel for a root pass

struct LayoutConstraints
{
    int x = 0;
    int y = 0;
    int availW = 0;
    int availH = 0;
};

struct Size
{
    int w = 0;
    int h = 0;
};

// -- Surface: a headless width x height character grid -------------------------
// Nodes paint into a Surface; the host then blits it to the terminal. Keeping
// paint off the real console makes layout/paint/hit-test deterministically
// testable with no console attached. Mirrors TerminalSnapshot in core/terminal.cb.
struct Surface
{
    char* _buf  = nullptr;
    int   width  = 0;
    int   height = 0;

    void init(int w, int h)
    {
        if (_buf != nullptr) free((void*)_buf);
        width  = w;
        height = h;
        _buf = (char*)malloc((i64)(w * h));
        this.fill(' ');
    }

    void fill(char c)
    {
        int n = width * height;
        int i = 0;
        while (i < n) { _buf[i] = c; i++; }
    }

    // Write one cell, clipping silently when out of bounds.
    void put(int x, int y, char c)
    {
        if (x < 0 || x >= width || y < 0 || y >= height) return;
        _buf[y * width + x] = c;
    }

    // Write s starting at (x, y), clipping at the grid edges.
    void text(int x, int y, const char* s)
    {
        int i = 0;
        while (s[i] != '\0')
        {
            this.put(x + i, y, s[i]);
            i++;
        }
    }

    // Heap-allocated null-terminated copy of row r with trailing spaces trimmed.
    // Caller frees. Same idiom as TerminalSnapshot.getRow.
    char* row(int r)
    {
        char* out = (char*)malloc((i64)(width + 1));
        int i = 0;
        while (i < width) { out[i] = _buf[r * width + i]; i++; }
        int end = width;
        while (end > 0 && out[end - 1] == ' ') end--;
        out[end] = '\0';
        return out;
    }

    // True if text appears on any single row (does not match across row breaks).
    bool contains(const char* text)
    {
        int tlen = strlen(text);
        if (tlen == 0) return true;
        int row = 0;
        while (row < height)
        {
            int col = 0;
            while (col <= width - tlen)
            {
                int j = 0;
                bool match = true;
                while (j < tlen)
                {
                    if (_buf[row * width + col + j] != text[j]) { match = false; break; }
                    j++;
                }
                if (match) return true;
                col++;
            }
            row++;
        }
        return false;
    }

    // True if row r differs from the same row of `o`. Drives minimal repaint:
    // the host paints into a back buffer, then blits only the rows that changed.
    bool rowDiffers(Surface* o, int r)
    {
        if (o.width != width || o.height != height) return true;
        int base = r * width;
        int i = 0;
        while (i < width) { if (_buf[base + i] != o._buf[base + i]) return true; i++; }
        return false;
    }

    // Copy another same-sized surface's cells into this one (front <- back).
    void copyFrom(Surface* src)
    {
        if (src.width != width || src.height != height) return;
        int n = width * height;
        int i = 0;
        while (i < n) { _buf[i] = src._buf[i]; i++; }
    }

    ~Surface()
    {
        if (_buf != nullptr) { free((void*)_buf); _buf = nullptr; }
    }
};

// Draw a single-cell border around rect b: '+' corners, '-'/'|' edges. Silently
// no-ops on a degenerate rect (a box needs at least 2x2 to have an interior).
void drawBorder(Surface* s, Rect b)
{
    if (b.w < 2 || b.h < 2) return;
    int right  = b.x + b.w - 1;
    int bottom = b.y + b.h - 1;
    s.put(b.x, b.y, '+');
    s.put(right, b.y, '+');
    s.put(b.x, bottom, '+');
    s.put(right, bottom, '+');
    int x = b.x + 1;
    while (x < right) { s.put(x, b.y, '-'); s.put(x, bottom, '-'); x++; }
    int y = b.y + 1;
    while (y < bottom) { s.put(b.x, y, '|'); s.put(right, y, '|'); y++; }
}

// -- ICanvas: the surface-agnostic draw target nodes paint into -----------------
// Nodes paint via ICanvas primitives (in CELL coordinates) instead of poking a
// Surface's cells directly, so the SAME tree can render to a char grid (TUI) or a
// GDI window (Win32). A ICanvas implementation owns the cell->pixel mapping.
// pushClip/popClip bound subsequent drawing to a rectangle (in cells). A
// ScrollView pushes its viewport so off-viewport children are clipped; calls
// nest (each push intersects with the active clip) and must be balanced.
// color is 0xRRGGBB, or COLOR_DEFAULT (-1) for the backend's monochrome default.
// A backend with no color (the TUI char grid) ignores it.
interface ICanvas
{
    void clear();
    void drawText(int col, int row, const char* s, int color);
    void drawRect(Rect r, bool filled, int color);   // filled=false border, true fill
    void pushClip(Rect r);
    void popClip();
};

// TUI ICanvas: a thin adapter over a Surface. (Surface is a struct and cannot
// implement an interface directly, so the adapter carries the contract.) Holds a
// borrowed Surface*; it never owns the grid. The clip stack is a fixed inline
// array (no heap) so this stays a pure value type with no destructor - it is
// passed as a ICanvas (interface) temporary, which is not auto-destructed.
int CLIP_STACK_MAX = 8;

class SurfaceCanvas : ICanvas
{
    Surface* target = nullptr;
    Rect[8] clipStack;
    int clipDepth = 0;

    void clear() { this.target.fill(' '); }

    // True if (x,y) passes the active clip (the innermost pushed rect).
    bool _visible(int x, int y)
    {
        if (this.clipDepth == 0) return true;
        return this.clipStack[this.clipDepth - 1].contains(x, y);
    }

    void _putClipped(int x, int y, char c)
    {
        if (this._visible(x, y)) this.target.put(x, y, c);
    }

    // The terminal grid has no color; `color` is accepted for the ICanvas contract
    // and ignored.
    void drawText(int col, int row, const char* s, int color)
    {
        int i = 0;
        while (s[i] != '\0') { this._putClipped(col + i, row, s[i]); i++; }
    }

    void drawRect(Rect r, bool filled, int color)
    {
        if (!filled)
        {
            if (r.w < 2 || r.h < 2) return;
            int right  = r.x + r.w - 1;
            int bottom = r.y + r.h - 1;
            this._putClipped(r.x, r.y, '+');
            this._putClipped(right, r.y, '+');
            this._putClipped(r.x, bottom, '+');
            this._putClipped(right, bottom, '+');
            int x = r.x + 1;
            while (x < right) { this._putClipped(x, r.y, '-'); this._putClipped(x, bottom, '-'); x++; }
            int y = r.y + 1;
            while (y < bottom) { this._putClipped(r.x, y, '|'); this._putClipped(right, y, '|'); y++; }
            return;
        }
        int yy = r.y;
        while (yy < r.y + r.h)
        {
            int xx = r.x;
            while (xx < r.x + r.w) { this._putClipped(xx, yy, ' '); xx++; }
            yy++;
        }
    }

    void pushClip(Rect r)
    {
        Rect eff = r;
        if (this.clipDepth > 0) eff = intersectRect(this.clipStack[this.clipDepth - 1], r);
        if (this.clipDepth < CLIP_STACK_MAX)
        {
            this.clipStack[this.clipDepth] = eff;
            this.clipDepth = this.clipDepth + 1;
        }
    }

    void popClip()
    {
        if (this.clipDepth > 0) this.clipDepth = this.clipDepth - 1;
    }
};

// A SurfaceCanvas value bound to `s`, ready to pass as a ICanvas. No heap, no owner:
// it just wraps the borrowed pointer for the duration of a paint call.
SurfaceCanvas canvasFor(Surface* s)
{
    SurfaceCanvas c = default;
    c.target = s;
    return c;
}

// -- Input events: one dispatch path for pointer and key ----------------------
// The host translates native input (terminal pollEvent / WM_LBUTTONDOWN /
// WM_KEYDOWN) into an Event and calls tree.dispatch(e, ctx). Pointer events
// hit-test down the tree; key events route to the focused node (see UiContext).
int EV_MOUSE_DOWN = 1;
int EV_KEY        = 2;
int EV_MOUSE_MOVE = 3;   // pointer moved: updates hover state (no state change)
int EV_MOUSE_UP   = 4;   // pointer released: clears pressed state

// Key codes the framework understands; the host maps native codes onto these.
// EV_KEY also carries printable ASCII codes (32..126) for text entry; a focused
// TextInput inserts them, KEY_BACKSPACE deletes, the arrows scroll a ScrollView.
int KEY_BACKSPACE = 8;
int KEY_TAB       = 9;
int KEY_ENTER     = 13;
int KEY_SPACE     = 32;
int KEY_LEFT      = 37;
int KEY_UP        = 38;
int KEY_RIGHT     = 39;
int KEY_DOWN      = 40;

struct Event
{
    int kind = 0;   // EV_*
    int x = 0;      // EV_MOUSE_DOWN: cell coords
    int y = 0;
    int key = 0;    // EV_KEY: KEY_* code
};

Event mouseDown(int x, int y)
{
    Event e = default;
    e.kind = EV_MOUSE_DOWN; e.x = x; e.y = y;
    return e;
}

Event keyPress(int key)
{
    Event e = default;
    e.kind = EV_KEY; e.key = key;
    return e;
}

Event mouseMove(int x, int y)
{
    Event e = default;
    e.kind = EV_MOUSE_MOVE; e.x = x; e.y = y;
    return e;
}

Event mouseUp(int x, int y)
{
    Event e = default;
    e.kind = EV_MOUSE_UP; e.x = x; e.y = y;
    return e;
}

// -- Theme: the app's styling preference (per-widget default colors) ----------
// A widget that sets no explicit color falls back to the theme slot for its role,
// so styling is declared once on the context instead of on every node. A
// default-constructed Theme is MONOCHROME (every slot COLOR_DEFAULT): a host that
// sets no theme renders exactly as the pre-color framework did, which keeps the
// GDI self-test and the TUI hosts byte-identical. An app opts into styling by
// assigning ctx.theme = lightTheme() (or its own Theme) in render().
struct Theme
{
    int textColor   = 0;   // Text ink
    int panelBg     = 0;   // Box fill
    int panelBorder = 0;   // Box border
    int buttonBg    = 0;   // Button fill
    int buttonText  = 0;   // Button label ink
    int inputBg     = 0;   // TextInput fill
    int inputText   = 0;   // TextInput ink
    int focusRing   = 0;   // border drawn around the focused widget
    int track       = 0;   // ProgressBar / Slider trough
    int accent      = 0;   // ProgressBar / Slider filled portion + thumb
};

// Resolve a color: an explicit per-node color (anything but COLOR_DEFAULT/0) wins;
// otherwise fall back to the theme slot (itself 0 in the monochrome theme, which
// the ICanvas renders as its default ink).
int pickColor(int nodeColor, int themeColor)
{
    if (nodeColor != 0) return nodeColor;
    return themeColor;
}

// A light theme: slate-on-near-white with a blue primary button.
Theme lightTheme()
{
    Theme t = default;
    t.textColor   = rgb(28, 32, 38);
    t.panelBg     = rgb(245, 247, 250);
    t.panelBorder = rgb(170, 178, 190);
    t.buttonBg    = rgb(52, 120, 247);
    t.buttonText  = rgb(255, 255, 255);
    t.inputBg     = rgb(255, 255, 255);
    t.inputText   = rgb(20, 20, 20);
    t.focusRing   = rgb(52, 120, 247);
    t.track       = rgb(210, 214, 220);
    t.accent      = rgb(52, 120, 247);
    return t;
}

// A dark theme: light ink on charcoal panels with a brighter blue button.
Theme darkTheme()
{
    Theme t = default;
    t.textColor   = rgb(225, 228, 233);
    t.panelBg     = rgb(34, 38, 46);
    t.panelBorder = rgb(80, 88, 100);
    t.buttonBg    = rgb(88, 150, 255);
    t.buttonText  = rgb(12, 16, 22);
    t.inputBg     = rgb(52, 58, 68);
    t.inputText   = rgb(235, 238, 242);
    t.focusRing   = rgb(120, 170, 255);
    t.track       = rgb(60, 66, 76);
    t.accent      = rgb(88, 150, 255);
    return t;
}

// -- ctx.post() thread marshaling ---------------------------------------------
// A closure queued to run on the UI thread. ctx.post() clones the closure into a
// heap PostBox and hands the host an opaque pointer; the host marshals that pointer
// to the UI thread (PostMessage on Win32) and calls __uiRunPostBox to run + free it.
// Keeping the box + run/free in ui.cb means the seam carries only an opaque u64 - no
// closure type crosses the host boundary (a Lambda-typed hook breaks monomorphization).
class PostBox { Lambda<void()> work = default; };

// Heap-box a closure. Returns a TYPED pointer so escape analysis keeps the cloned
// closure alive past this call; a u64 cast inside the creating function would let the
// field be destructed at scope exit. The caller casts to u64 at its own site.
PostBox* _boxClosure(Lambda<void()> work)
{
    PostBox* box = new PostBox();
    box.work = work;   // clone-in (lambdas are clone-by-default; the arg keeps its copy)
    return box;
}

// Run a boxed closure on the current thread, then free the box. The host calls this
// from its UI-thread message handler (Win32 WM_APP_CALL). Leak-clean.
void __uiRunPostBox(u64 boxPtr)
{
    if (boxPtr == 0u) return;
    PostBox* b = (PostBox*)boxPtr;
    b.work();
    delete b;
}

// -- UiContext: the host-owned per-app runtime state ---------------------------
// Replaces the former library globals. A handler calls ctx.invalidate() to mark
// the UI dirty; the host drains it once per loop (consumeDirty) and re-renders
// only on a change. focusKey is the KEYED IDENTITY of the focused node, so focus
// survives reconcile (a re-render keeps the same key -> same focus), unlike a
// list index. Single mounted app, single thread: one UiContext per host loop,
// threaded into render() so event closures can reach it.
struct UiContext
{
    bool   dirty    = false;     // a handler changed state -> re-render the tree
    bool   repaint  = false;     // layout/paint changed but the tree did not (scroll)
    string focusKey = default;   // "" = nothing focused
    string hoverKey = default;   // "" = pointer over nothing interactive
    string pressKey = default;   // "" = nothing pressed/held
    Theme  theme    = default;   // styling preference; default = monochrome

    // Shadow map from a node's stable key path to its native control handle (an
    // opaque u64: HWND on Windows, NSView* on macOS). Populated ONLY by a
    // INativeHost (see ui_native.cb); the ICanvas hosts (TUI/GDI) never touch it, so
    // it stays empty and inert for them - this is the key->handle plumbing. The
    // handles are non-owning integers, so destroying the map destroys no windows;
    // the host explicitly destroys controls.
    dictionary<string, u64> nativeByKey = default;

    // Thread marshaling. The host installs a marshal hook + the UI thread id so
    // ctx.post() can run a closure back on the UI thread from a worker. These are thin
    // function pointers (no owning closure type crosses the seam), set by the host at
    // window creation; with none bound, post() runs inline (TUI / headless).
    u64  postTarget  = 0u;                        // opaque UI-thread target (HWND on Win32)
    function<void(u64, u64)> postHook = default;  // (target, boxPtr) -> marshal to UI thread
    bool hasPostHook = false;
    u64  uiThreadId  = 0u;                        // the UI thread's OS id (host-set)
    function<u64()> tidHook = default;            // returns the CURRENT thread id (host-set)
    bool hasTidHook  = false;

    void invalidate() { this.dirty = true; }

    // Install the host's thread-marshaling hook. `target` is the UI-thread post target
    // (a window handle on Win32); `hook(target, boxPtr)` enqueues a boxed closure.
    void bindPost(u64 target, function<void(u64, u64)> hook)
    {
        this.postTarget = target; this.postHook = hook; this.hasPostHook = true;
    }
    void bindThreadId(u64 uiTid, function<u64()> tidFn)
    {
        this.uiThreadId = uiTid; this.tidHook = tidFn; this.hasTidHook = true;
    }

    // Run `work` on the UI thread. Safe to call from any thread: the closure is cloned
    // into a heap box here and the host marshals it (PostMessage) to the UI thread,
    // where it runs once and is freed. With no host bound, it runs inline.
    void post(Lambda<void()> work)
    {
        PostBox* box = _boxClosure(work);
        if (this.hasPostHook) this.postHook(this.postTarget, (u64)box);
        else __uiRunPostBox((u64)box);
    }

    // Debug guard: warn if called off the UI thread. A no-op until a host binds ids.
    void assertUiThread()
    {
        if (this.hasTidHook && this.tidHook() != this.uiThreadId)
            printf("ui: assertUiThread() called off the UI thread\n");
    }

    // Request a re-layout + repaint without a re-render. Used when a node's own
    // view state changes (e.g. a ScrollView offset) but the component tree does
    // not, so reconcile would produce no patches for the host to repaint on.
    void requestRepaint() { this.repaint = true; }

    // Return whether a render is pending, clearing the flag.
    bool consumeDirty()
    {
        bool d = this.dirty;
        this.dirty = false;
        return d;
    }

    bool consumeRepaint()
    {
        bool r = this.repaint;
        this.repaint = false;
        return r;
    }

    void focus(string key) { this.focusKey = "" + key; }
    void blur() { this.focusKey = ""; }
    bool hasFocus(string key) { return this.focusKey.length() > 0 && this.focusKey == key; }

    // Hover and press are pure PAINT state (no re-render): they request a repaint
    // only when the identity actually changes, so dragging the pointer within one
    // widget does not churn. The host clears hover (setHover("")) when a move hits
    // nothing, and clears press on mouse-up.
    void setHover(string key)
    {
        if (this.hoverKey == key) return;
        this.hoverKey = "" + key;
        this.repaint = true;
    }
    bool hasHover(string key) { return this.hoverKey.length() > 0 && this.hoverKey == key; }

    void setPress(string key)
    {
        if (this.pressKey == key) return;
        this.pressKey = "" + key;
        this.repaint = true;
    }
    void clearPress()
    {
        if (this.pressKey.length() == 0) return;
        this.pressKey = "";
        this.repaint = true;
    }
    bool hasPress(string key) { return this.pressKey.length() > 0 && this.pressKey == key; }

    // Native-handle shadow map accessors (used by a INativeHost). 0 = no handle.
    void setNativeHandle(string key, u64 h) { this.nativeByKey.set(key, h); }
    bool hasNativeHandle(string key) { return this.nativeByKey.contains(key); }
    u64  nativeHandle(string key)
    {
        if (!this.nativeByKey.contains(key)) return 0u;
        return this.nativeByKey.get(key);
    }
    void removeNativeHandle(string key) { this.nativeByKey.remove(key); }
};

// -- ContextMenu: a per-element right-click menu --------------------------------
// Reuses the declarative menu model as a popup attached to ONE element. The app
// builds it (addItem(label, cmd)) and hangs it on an element's `contextMenu` field; on
// a right-click over that control the native host shows a TrackPopupMenu and routes the
// chosen cmd through the SAME app menu handler (setMenuHandler). An empty label is a
// separator. Owned by the element it is attached to (freed in that element's
// destroyTree). A plain default-constructible class, so `<ContextMenu/>` sugar works.
class ContextMenu
{
    string       title  = default;   // optional label (unused by the popup; sugar-friendly)
    list<string> labels = default;   // per item: menu text ("" = separator)
    list<int>    cmds   = default;   // per item: app command id (routed via setMenuHandler)

    void addItem(string label, int cmd) { this.labels.add("" + label); this.cmds.add(cmd); }
    void addSeparator() { this.labels.add(""); this.cmds.add(0); }
    int count() { return this.labels.count(); }
};

// Node-kind tags - returned by IElement.kind() so the reconciler can compare node
// types WITHOUT an `as` downcast in the hot diff path.
int ELEM_VIEW      = 1;
int ELEM_TEXT      = 2;
int ELEM_BUTTON    = 3;
int ELEM_COMPONENT = 4;
int ELEM_BOX       = 5;
int ELEM_TEXTINPUT = 6;
int ELEM_SCROLL    = 7;
int ELEM_CHECKBOX  = 8;
int ELEM_PROGRESS  = 9;
int ELEM_SLIDER    = 10;
int ELEM_TEXTAREA  = 11;
int ELEM_STATUSBAR = 12;
int ELEM_RADIOGROUP = 13;   // container of RadioButtons; not native-mapped
int ELEM_RADIO      = 14;   // one radio button inside a RadioGroup
int ELEM_COMBO      = 15;   // dropdown list
int ELEM_LIST       = 16;   // report-mode list view, virtualized
int ELEM_TABS       = 17;   // tab control; keyed panes, active-only native
int ELEM_TABPANE    = 18;   // one pane inside a TabControl; container, not native-mapped
int ELEM_TREE       = 19;   // tree view, expand-on-demand callback children
int ELEM_SPLIT      = 20;   // split view: two weighted panes + divider; container
int ELEM_IMAGE      = 21;   // bitmap image; BGRA32 pixels pushed via setImageData
int ELEM_GROUPBOX   = 22;   // titled group frame; container, native-mapped
int ELEM_CANVAS     = 23;   // app-painted canvas child; paint callback via ICanvas

// The node interface. Typed host structs implement these so the tree can be
// walked uniformly (serialize, layout, paint, dispatch, reconcile, teardown)
// while keeping props compile-checked.
//   - layout takes constraints and returns the size consumed, stamping bounds.
//   - paint draws self (and children) into the ICanvas using bounds.
//   - dispatch routes one Event: pointer events hit-test, key events go to the
//     focused node. Returns true if a node consumed it. Virtual on purpose: the
//     host never downcasts a child, it lets each node decide.
//   - kind / propsEqual / childList drive the reconciler: kind() compares node
//     type, propsEqual() is a structured same-kind props compare for change
//     detection, childList() exposes a container's children (nullptr for leaves).
interface IElement
{
    move string toJson();
    void destroyTree();
    Size layout(LayoutConstraints c);
    void paint(ICanvas c, UiContext* ctx);
    bool dispatch(Event e, UiContext* ctx);
    int  kind();
    // Main-axis flex weight for a View-row/column distribution pass; 0 = not
    // flexible (intrinsic size). Only View carries a real Style; every other
    // IElement implementor returns 0 (leaves are never flex children).
    int  flexWeight();
    bool propsEqual(IElement other);   // other is guaranteed same kind() by reconcile
    list<IElement>* childList();
    string keyOf();          // "" if unkeyed; drives keyed child reconciliation
    void setKey(string k);
    // Append the keys of focusable descendants (Button/TextInput) in tree order,
    // so Tab/Shift-Tab can build a focus ring. Leaves that cannot focus no-op.
    void collectFocusables(list<string>* keys);
    // The absolute frame stamped by the last layout pass (in DIP/cell units). A
    // INativeHost reads this to position the node's OS control (v9).
    Rect nodeBounds();
};

// -- Per-widget interfaces ------------------------------------------------------
// One interface per element class, carrying the props the reconciler and the native
// hosts actually reach. An interface FIELD is a vtable slot holding the implementor's
// byte offset, so `b.title` through a fat pointer is a true lvalue (read, write, and
// nested-struct write all work). The concrete classes stay the CONSTRUCTION type
// (JSX names them and writes their fields); these interfaces are the USAGE type.
//
// Two shared levels avoid repeating the two near-universal props: `tooltip` (15 of
// the 23 classes) and `disabled` (10, all of which also carry `tooltip`), so a host
// can resolve either with ONE downcast instead of a 15- or 10-way `as`-chain.
// Everything else is per-widget: `value`/`label` are same-name-different-type across
// widgets, so no further hoist is possible.
//
// Event closures are NOT interface fields where a fire* wrapper serves instead
// (mirroring Button.fireClick): a closure that is only ever INVOKED is reached via
// its wrapper. The five closures that are genuinely READ AS VALUES (boxed across the
// INativeHost u64 seam - ListView.rowText, TreeView.childCount/childId/label,
// CanvasView.onPaint) stay fields, since the host must clone them out.
interface ITooltipped : IElement
{
    string tooltip;          // native hover tooltip; "" = none
};

interface IDisableable : ITooltipped
{
    bool disabled;           // dimmed + ignores input
};

interface IView : IElement
{
    Style style;
    list<IElement> children;
    void add(IElement child);
};

interface IText : ITooltipped
{
    string text;
    int    color;
};

// NOT `IButton`: the WinUI winmd that ui_native/winui.cb imports projects a WinRT
// `IButton`, and a cflat interface cannot share a name with a consumed WinMD type.
interface IButtonElement : IDisableable
{
    string title;
    int    color;
    int    backgroundColor;
    void   fireClick();
};

interface IBox : IElement
{
    Style style;
    void  add(IElement child);
};

interface ITextInput : IDisableable
{
    string value;
    string placeholder;
    int    width;
    void   fireChangeText(string s);
};

interface ICheckbox : IDisableable
{
    string label;
    bool   checked;
    void   fireToggle();
};

interface IProgressBar : ITooltipped
{
    int value;
    int width;
};

interface ISlider : IDisableable
{
    int  value;
    int  width;
    void fireSet(int v);
};

interface ITextArea : IDisableable
{
    string value;
    void   fireChange();
};

interface IStatusBar : IElement
{
    list<string> parts;
    void addPart(string s);
};

interface IScrollView : IElement
{
    Style style;
    int   contentH;
    void  add(IElement child);
};

interface IRadioButton : IDisableable
{
    string label;
    bool   checked;
    int    index;
    bool   groupFirst;
};

interface IRadioGroup : IElement
{
    int   value;
    Style style;
    void  add(IElement child);
    void  addOption(string label);
    void  fireChange(int v);
};

interface IComboBox : IDisableable
{
    list<string> items;
    int  selectedIndex;
    int  width;
    void addItem(string s);
    void fireChange(int v);
};

interface IListView : IDisableable
{
    list<string> columns;
    list<int>    colWidths;
    int  rowCount;
    int  selectedIndex;
    bool multiSelect;
    Lambda<string(int,int)> rowText;   // read as a value: boxed across the host seam
    void addColumn(string title, int widthDip);
    void fireSelect(int row);
    void fireActivate(int row);
};

interface ITabPane : IElement
{
    string title;
    void   add(IElement child);
};

interface ITabControl : IDisableable
{
    list<IElement> children;
    int    selectedTab;
    int    width;
    int    height;
    string _title(int i);
    void   add(IElement child);
    void   fireSelectTab(int i);
};

interface ITreeView : IDisableable
{
    // The three node-source closures are read as values and boxed into a TreeBox.
    Lambda<int(int)>     childCount;
    Lambda<int(int,int)> childId;
    Lambda<string(int)>  label;
    int  selectedNode;
    void fireSelect(int nodeId);
    void fireExpand(int nodeId);
};

interface ISplitView : IElement
{
    int   ratio;
    bool  vertical;
    Style style;
    Rect  dividerBounds;
    int   _ratioAt(int px, int py);
    void  add(IElement child);
    void  fireRatioChange(int r);
};

// NOT `IImage`: same WinRT name collision as IButtonElement (winui.cb reaches the
// XAML Image control through the projected WinRT `IImage`).
interface IImageElement : ITooltipped
{
    u64    pixels;
    int    pxW;
    int    pxH;
    int    width;
    int    height;
    string source;
};

interface IGroupBox : ITooltipped
{
    string title;
    Style  style;
    void   add(IElement child);
};

interface ICanvasView : ITooltipped
{
    int width;
    int height;
    Lambda<void(ICanvas)> onPaint;   // read as a value: boxed across the host seam
};

// ComponentElement needs no interface: nothing outside the class reaches a field of
// it, and its propsEqual is unconditionally true. IElement covers every use.

// Lay out a root element to fill (w) cells wide at (x, y), height unbounded.
Size layoutRoot(IElement root, int x, int y, int w)
{
    LayoutConstraints c = default;
    c.x = x; c.y = y; c.availW = w; c.availH = LAYOUT_UNBOUNDED;
    return root.layout(c);
}

// Like layoutRoot but with a BOUNDED height (h). A native host uses this so that
// (a) DIR_COLUMN flex distributes at the root, and (b) a root ScrollView can fill
// the window viewport. TUI/canvas hosts keep using layoutRoot (unbounded).
Size layoutRootBounded(IElement root, int x, int y, int w, int h)
{
    LayoutConstraints c = default;
    c.x = x; c.y = y; c.availW = w; c.availH = h;
    return root.layout(c);
}

// -- View: a flex container with a style and children -------------------------
class View : IView
{
    Style style = default;
    list<IElement> children = default;
    Rect bounds = default;
    string key = default;

    void add(IElement child)
    {
        this.children.add(child);
    }

    // A flex child's weight counts only when its own explicit size (width for a
    // row, height for a column) is unset - an explicit size wins over flex,
    // mirroring RN's flexBasis-with-grow-0 (see the plan doc).
    bool isRowFlexChild(IElement child)
    {
        if (child.flexWeight() <= 0) return false;
        IView v = child as IView;
        return v == nullptr || v.style.width <= 0;
    }

    bool isColumnFlexChild(IElement child)
    {
        if (child.flexWeight() <= 0) return false;
        IView v = child as IView;
        return v == nullptr || v.style.height <= 0;
    }

    // One layout pass; flexDirection picks the strategy. Column stacks children
    // top-to-bottom, row places them left-to-right; both inset by style.padding.
    // A DIR_ROW/DIR_COLUMN View with no flex child (the common case) takes the
    // original single-pass path untouched, so a no-flex tree lays out identically.
    Size layout(LayoutConstraints c)
    {
        int pad = this.style.padding;
        Size sz = default;
        int gap = this.style.gap;
        if (this.style.flexDirection == DIR_ROW && this.style.flexWrap == WRAP_WRAP)
        {
            int innerW = c.availW - 2 * pad;

            // Phase 1: intrinsic width of every child, used only to decide
            // line breaks. style.width wins when set (explicit fixed size);
            // otherwise probe layout the same way the non-wrap measure pass
            // probes fixed children - including flex children, whose
            // line-breaking basis is measured identically (see plan doc).
            list<int> widths;
            int mx = c.x + pad;
            int mi = 0;
            for (IElement child in this.children)
            {
                if (mi > 0) mx = mx + gap;
                int w = 0;
                IView v = child as IView;
                if (v != nullptr && v.style.width > 0)
                {
                    w = v.style.width;
                }
                else
                {
                    LayoutConstraints cc = default;
                    cc.x = mx; cc.y = c.y + pad;
                    cc.availW = c.availW - 2 * pad; cc.availH = c.availH - 2 * pad;
                    Size cs = child.layout(cc);
                    w = cs.w;
                }
                widths.add(w);
                mx = mx + w;
                mi++;
            }

            // Phase 2: greedily break children into lines. A line always
            // takes at least one child, so an over-wide child gets its own
            // line rather than looping forever.
            list<int> lineStart;
            list<int> lineCount;
            int n = this.children.count();
            int idx = 0;
            while (idx < n)
            {
                int start = idx;
                int lineW = widths[idx];
                idx++;
                while (idx < n)
                {
                    int cand = lineW + gap + widths[idx];
                    if (cand > innerW) break;
                    lineW = cand;
                    idx++;
                }
                lineStart.add(start);
                lineCount.add(idx - start);
            }

            // Phase 3: lay out each line exactly like a non-wrapping flex
            // row (weights + left-to-right remainder handout), then stack
            // lines top to bottom; line height is the max child height.
            int cy = c.y + pad;
            int li = 0;
            int totalLineH = 0;
            while (li < lineStart.count())
            {
                int start = lineStart[li];
                int count = lineCount[li];

                int lineFlexSum = 0;
                int fixedSum = 0;
                int k = 0;
                while (k < count)
                {
                    IElement child = this.children.get(start + k);
                    if (this.isRowFlexChild(child)) lineFlexSum = lineFlexSum + child.flexWeight();
                    else fixedSum = fixedSum + widths[start + k];
                    k++;
                }
                int gapSum = 0;
                if (count > 1) gapSum = gap * (count - 1);
                int leftover = innerW - fixedSum - gapSum;
                if (leftover < 0) leftover = 0;

                list<int> shares;
                int allocated = 0;
                k = 0;
                while (k < count)
                {
                    IElement child = this.children.get(start + k);
                    if (this.isRowFlexChild(child))
                    {
                        int share = 0;
                        if (lineFlexSum > 0) share = leftover * child.flexWeight() / lineFlexSum;
                        shares.add(share);
                        allocated = allocated + share;
                    }
                    k++;
                }
                int remainder = leftover - allocated;
                int ri = 0;
                while (remainder > 0 && ri < shares.count())
                {
                    shares.set(ri, shares[ri] + 1);
                    remainder--;
                    ri++;
                }

                int cx = c.x + pad;
                int lineH = 0;
                int si = 0;
                k = 0;
                while (k < count)
                {
                    if (k > 0) cx = cx + gap;
                    IElement child = this.children.get(start + k);
                    LayoutConstraints cc = default;
                    cc.x = cx; cc.y = cy;
                    cc.availH = c.availH - 2 * pad;
                    if (this.isRowFlexChild(child))
                    {
                        int share = shares[si];
                        si++;
                        cc.availW = share;
                        Size cs = child.layout(cc);
                        if (cs.h > lineH) lineH = cs.h;
                        cx = cx + share;
                    }
                    else
                    {
                        cc.availW = c.availW - 2 * pad;
                        Size cs = child.layout(cc);
                        if (cs.h > lineH) lineH = cs.h;
                        cx = cx + cs.w;
                    }
                    k++;
                }

                if (li > 0) totalLineH = totalLineH + gap;
                totalLineH = totalLineH + lineH;
                cy = cy + lineH + gap;
                li++;
            }

            sz.w = c.availW;
            sz.h = totalLineH + 2 * pad;
        }
        else if (this.style.flexDirection == DIR_ROW)
        {
            int rowFlexSum = 0;
            for (IElement child in this.children)
                if (this.isRowFlexChild(child)) rowFlexSum = rowFlexSum + child.flexWeight();

            if (rowFlexSum > 0)
            {
                // Measure pass: probe each fixed (flex==0 or width-overridden)
                // child once at a tentative x to learn its intrinsic width.
                int fixedSum = 0;
                int mx = c.x + pad;
                int mi = 0;
                for (IElement child in this.children)
                {
                    if (mi > 0) mx = mx + gap;
                    if (!this.isRowFlexChild(child))
                    {
                        LayoutConstraints cc = default;
                        cc.x = mx; cc.y = c.y + pad;
                        cc.availW = c.availW - 2 * pad; cc.availH = c.availH - 2 * pad;
                        Size cs = child.layout(cc);
                        fixedSum = fixedSum + cs.w;
                        mx = mx + cs.w;
                    }
                    mi++;
                }
                int n = this.children.count();
                int gapSum = 0;
                if (n > 1) gapSum = gap * (n - 1);
                int leftover = c.availW - 2 * pad - fixedSum - gapSum;
                if (leftover < 0) leftover = 0;

                // Base share = floor(leftover * flex / flexSum); the remainder
                // is handed out one cell at a time, left to right, so shares
                // sum to exactly `leftover`.
                list<int> shares;
                int allocated = 0;
                for (IElement child in this.children)
                {
                    if (this.isRowFlexChild(child))
                    {
                        int share = leftover * child.flexWeight() / rowFlexSum;
                        shares.add(share);
                        allocated = allocated + share;
                    }
                }
                int remainder = leftover - allocated;
                int ri = 0;
                while (remainder > 0 && ri < shares.count())
                {
                    shares.set(ri, shares[ri] + 1);
                    remainder--;
                    ri++;
                }

                // Placement pass: lay out every child at its real x. A flex
                // child's availW is its share and the cursor advances by the
                // share regardless of the Size the child returns - this is
                // what keeps columns aligned even if a leaf paints narrower.
                int cx = c.x + pad;
                int maxH = 0;
                int pi = 0;
                int si = 0;
                for (IElement child in this.children)
                {
                    if (pi > 0) cx = cx + gap;
                    LayoutConstraints cc = default;
                    cc.x = cx; cc.y = c.y + pad;
                    cc.availH = c.availH - 2 * pad;
                    if (this.isRowFlexChild(child))
                    {
                        int share = shares[si];
                        si++;
                        cc.availW = share;
                        Size cs = child.layout(cc);
                        if (cs.h > maxH) maxH = cs.h;
                        cx = cx + share;
                    }
                    else
                    {
                        cc.availW = c.availW - 2 * pad;
                        Size cs = child.layout(cc);
                        if (cs.h > maxH) maxH = cs.h;
                        cx = cx + cs.w;
                    }
                    pi++;
                }
                sz.w = c.availW;
                sz.h = maxH + 2 * pad;
            }
            else
            {
                int cx = c.x + pad;
                int maxH = 0;
                int i = 0;
                for (IElement child in this.children)
                {
                    if (i > 0) cx = cx + gap;
                    LayoutConstraints cc = default;
                    cc.x = cx; cc.y = c.y + pad;
                    cc.availW = c.availW - 2 * pad; cc.availH = c.availH - 2 * pad;
                    Size cs = child.layout(cc);
                    cx = cx + cs.w;
                    if (cs.h > maxH) maxH = cs.h;
                    i++;
                }
                sz.w = c.availW;
                sz.h = maxH + 2 * pad;
            }
        }
        else
        {
            // flexWrap is a DIR_ROW-only feature (phase 2 scope); DIR_COLUMN
            // ignores it and keeps the single-line stacking behavior below.
            int colFlexSum = 0;
            if (c.availH < LAYOUT_UNBOUNDED)
                for (IElement child in this.children)
                    if (this.isColumnFlexChild(child)) colFlexSum = colFlexSum + child.flexWeight();

            if (colFlexSum > 0)
            {
                // Same algorithm as the row case, on the height axis. Only
                // reached when availH is bounded - under LAYOUT_UNBOUNDED a
                // flex child has no leftover to grow into, so it falls back
                // to the intrinsic-height path below (matches RN's behavior
                // for flex on an unbounded scroll axis).
                int fixedSum = 0;
                int my = c.y + pad;
                int mi = 0;
                for (IElement child in this.children)
                {
                    if (mi > 0) my = my + gap;
                    if (!this.isColumnFlexChild(child))
                    {
                        LayoutConstraints cc = default;
                        cc.x = c.x + pad; cc.y = my;
                        cc.availW = c.availW - 2 * pad; cc.availH = c.availH - 2 * pad;
                        Size cs = child.layout(cc);
                        fixedSum = fixedSum + cs.h;
                        my = my + cs.h;
                    }
                    mi++;
                }
                int n = this.children.count();
                int gapSum = 0;
                if (n > 1) gapSum = gap * (n - 1);
                int leftover = c.availH - 2 * pad - fixedSum - gapSum;
                if (leftover < 0) leftover = 0;

                list<int> shares;
                int allocated = 0;
                for (IElement child in this.children)
                {
                    if (this.isColumnFlexChild(child))
                    {
                        int share = leftover * child.flexWeight() / colFlexSum;
                        shares.add(share);
                        allocated = allocated + share;
                    }
                }
                int remainder = leftover - allocated;
                int ri = 0;
                while (remainder > 0 && ri < shares.count())
                {
                    shares.set(ri, shares[ri] + 1);
                    remainder--;
                    ri++;
                }

                int cy = c.y + pad;
                int pi = 0;
                int si = 0;
                for (IElement child in this.children)
                {
                    if (pi > 0) cy = cy + gap;
                    LayoutConstraints cc = default;
                    cc.x = c.x + pad; cc.y = cy;
                    cc.availW = c.availW - 2 * pad;
                    if (this.isColumnFlexChild(child))
                    {
                        int share = shares[si];
                        si++;
                        cc.availH = share;
                        child.layout(cc);
                        cy = cy + share;
                    }
                    else
                    {
                        cc.availH = c.availH - 2 * pad;
                        Size cs = child.layout(cc);
                        cy = cy + cs.h;
                    }
                    pi++;
                }
                sz.w = c.availW;
                sz.h = (cy - c.y) + pad;
            }
            else
            {
                int cy = c.y + pad;
                int i = 0;
                for (IElement child in this.children)
                {
                    if (i > 0) cy = cy + gap;
                    LayoutConstraints cc = default;
                    cc.x = c.x + pad; cc.y = cy;
                    cc.availW = c.availW - 2 * pad; cc.availH = c.availH - 2 * pad;
                    Size cs = child.layout(cc);
                    cy = cy + cs.h;
                    i++;
                }
                sz.w = c.availW;
                sz.h = (cy - c.y) + pad;
            }
        }

        Rect b = default;
        b.x = c.x; b.y = c.y; b.w = sz.w; b.h = sz.h;
        this.bounds = b;
        return sz;
    }

    void paint(ICanvas cv, UiContext* ctx)
    {
        if (this.style.backgroundColor != 0)
            cv.drawRect(this.bounds, true, this.style.backgroundColor);
        for (IElement c in this.children)
            c.paint(cv, ctx);
    }

    bool dispatch(Event e, UiContext* ctx)
    {
        for (IElement c in this.children)
        {
            if (c.dispatch(e, ctx))
                return true;
        }
        return false;
    }

    move string toJson()
    {
        string out = "{\"type\":\"View\"";
        if (!styleIsEmpty(this.style))
            out = out + ",\"style\":" + styleToJson(this.style);

        out = out + ",\"children\":[";
        int i = 0;
        for (IElement c in this.children)
        {
            if (i > 0)
                out = out + ",";
            out = out + c.toJson();
            i++;
        }
        out = out + "]}";
        return out;
    }

    // Recursively free the owning child subtree (descendants first, then each
    // child node), then drop the now-dangling list entries.
    void destroyTree()
    {
        for (IElement c in this.children)
        {
            c.destroyTree();
            delete c;
        }
        this.children.clear();
    }

    int kind() { return ELEM_VIEW; }
    int flexWeight() { return this.style.flex; }
    void collectFocusables(list<string>* keys)
    {
        for (IElement c in this.children) c.collectFocusables(keys);
    }
    // Containers are reconciled by child diffing, not propsEqual; compare style
    // anyway so the contract is honest if a caller ever diffs a View directly.
    bool propsEqual(IElement other)
    {
        IView o = other as IView;
        return o != nullptr && styleEquals(this.style, o.style);
    }
    list<IElement>* childList() { return &this.children; }
    string keyOf() { return "" + this.key; }
    void setKey(string k) { this.key = k; }
    Rect nodeBounds() { return this.bounds; }
};

// -- Text: a leaf displaying a string -----------------------------------------
class Text : IText
{
    string text = default;
    int    color = 0;           // rgb(); 0 = default ink
    string tooltip = default;   // native hover tooltip; "" = none. Use a literal.
    Rect bounds = default;
    string key = default;

    move string toJson()
    {
        return "{\"type\":\"Text\",\"text\":\"" + this.text + "\"}";
    }

    Size layout(LayoutConstraints c)
    {
        Rect b = default;
        b.x = c.x; b.y = c.y; b.w = (int)this.text.length(); b.h = 1;
        this.bounds = b;
        Size s = default; s.w = b.w; s.h = 1;
        return s;
    }

    void paint(ICanvas cv, UiContext* ctx)
    {
        cv.drawText(this.bounds.x, this.bounds.y, this.text.data(),
                    pickColor(this.color, ctx.theme.textColor));
    }

    bool dispatch(Event e, UiContext* ctx) { return false; }

    void destroyTree() { }

    int kind() { return ELEM_TEXT; }
    int flexWeight() { return 0; }
    void collectFocusables(list<string>* keys) { }
    bool propsEqual(IElement other)
    {
        IText o = other as IText;
        return o != nullptr && this.text == o.text;
    }
    list<IElement>* childList() { return nullptr; }
    string keyOf() { return "" + this.key; }
    void setKey(string k) { this.key = k; }
    Rect nodeBounds() { return this.bounds; }
};

// -- Button: a leaf with a title and a press handler --------------------------
// Names track React Native: `title` + `onPress`. A keyed button also takes focus
// on press and re-fires on Enter/Space while focused (the keyboard-activation
// half of the focus seam).
class Button : IButtonElement
{
    string title = default;
    Lambda<void()> onPress = default;
    int    color = 0;               // label ink; 0 = default
    int    backgroundColor = 0;     // button fill; 0 = no fill
    bool   disabled = false;        // dimmed + ignores input
    string tooltip = default;       // native hover tooltip; "" = none
    Rect bounds = default;
    string key = default;

    void fireClick()
    {
        this.onPress();
    }

    move string toJson()
    {
        return "{\"type\":\"Button\",\"title\":\"" + this.title
             + "\",\"clickable\":true}";
    }

    // Rendered as "[ title ]", so the width is the title plus the 4 framing chars.
    Size layout(LayoutConstraints c)
    {
        Rect b = default;
        b.x = c.x; b.y = c.y; b.w = (int)this.title.length() + 4; b.h = 1;
        this.bounds = b;
        Size s = default; s.w = b.w; s.h = 1;
        return s;
    }

    void paint(ICanvas cv, UiContext* ctx)
    {
        // Disabled: a flat dimmed fill + gray label, no hover/press/focus affordance.
        if (this.disabled)
        {
            int dbg = dimColor(pickColor(this.backgroundColor, ctx.theme.buttonBg));
            if (dbg != 0)
                cv.drawRect(this.bounds, true, dbg);
            string dl = "[ " + this.title + " ]";
            cv.drawText(this.bounds.x, this.bounds.y, dl.data(),
                        dimColor(pickColor(this.color, ctx.theme.buttonText)));
            return;
        }
        // Pressed darkens the fill, hover lightens it (shade() leaves an unset
        // monochrome button untouched). Pressed wins over hover.
        int bg = pickColor(this.backgroundColor, ctx.theme.buttonBg);
        if (ctx.hasPress(this.key))      bg = shade(bg, -40);
        else if (ctx.hasHover(this.key)) bg = shade(bg, 28);
        if (bg != 0)
            cv.drawRect(this.bounds, true, bg);
        if (ctx.hasFocus(this.key) && ctx.theme.focusRing != 0)
            cv.drawRect(this.bounds, false, ctx.theme.focusRing);
        string rendered = "[ " + this.title + " ]";
        cv.drawText(this.bounds.x, this.bounds.y, rendered.data(),
                    pickColor(this.color, ctx.theme.buttonText));
    }

    bool dispatch(Event e, UiContext* ctx)
    {
        if (this.disabled) return false;
        if (e.kind == EV_MOUSE_DOWN)
        {
            if (this.bounds.contains(e.x, e.y))
            {
                ctx.focus(this.key);       // a press also moves focus here
                ctx.setPress(this.key);    // held until the host sees mouse-up
                this.fireClick();
                return true;
            }
            return false;
        }
        if (e.kind == EV_MOUSE_MOVE)
        {
            if (this.bounds.contains(e.x, e.y)) { ctx.setHover(this.key); return true; }
            return false;
        }
        if (e.kind == EV_KEY)
        {
            // A focused button activates on Enter/Space.
            if (ctx.hasFocus(this.key) && (e.key == KEY_ENTER || e.key == KEY_SPACE))
            {
                this.fireClick();
                return true;
            }
        }
        return false;
    }

    void destroyTree() { }

    int kind() { return ELEM_BUTTON; }
    int flexWeight() { return 0; }
    void collectFocusables(list<string>* keys)
    {
        if (!this.disabled && this.key.length() > 0) keys.add("" + this.key);
    }
    bool propsEqual(IElement other)
    {
        IButtonElement o = other as IButtonElement;
        return o != nullptr && this.title == o.title && this.disabled == o.disabled;
    }
    list<IElement>* childList() { return nullptr; }
    string keyOf() { return "" + this.key; }
    void setKey(string k) { this.key = k; }
    Rect nodeBounds() { return this.bounds; }
};

// -- Box: a bordered container that fills a width x height region ---------------
// Unlike View (a flow container), a Box is sized: it draws a border around
// style.width x style.height and stacks its children in the interior, inset by
// the border plus style.padding. A box whose style.width/height is 0 falls back
// to availW x 1, so an outer box driven by the host size scales on re-render.
class Box : IBox
{
    Style style = default;
    list<IElement> children = default;
    Rect bounds = default;
    string key = default;

    void add(IElement child)
    {
        this.children.add(child);
    }

    Size layout(LayoutConstraints c)
    {
        int w = c.availW;
        if (this.style.width > 0) w = this.style.width;
        int h = 1;
        if (this.style.height > 0) h = this.style.height;

        Rect b = default;
        b.x = c.x; b.y = c.y; b.w = w; b.h = h;
        this.bounds = b;

        int inset = 1 + this.style.padding;
        int cy = c.y + inset;
        int gi = 0;
        for (IElement child in this.children)
        {
            if (gi > 0) cy = cy + this.style.gap;
            LayoutConstraints cc = default;
            cc.x = c.x + inset; cc.y = cy;
            cc.availW = w - 2 * inset; cc.availH = h - 2 * inset;
            Size cs = child.layout(cc);
            cy = cy + cs.h;
            gi++;
        }

        Size sz = default; sz.w = w; sz.h = h;
        return sz;
    }

    void paint(ICanvas cv, UiContext* ctx)
    {
        int bg = pickColor(this.style.backgroundColor, ctx.theme.panelBg);
        if (bg != 0)
            cv.drawRect(this.bounds, true, bg);
        cv.drawRect(this.bounds, false, pickColor(this.style.color, ctx.theme.panelBorder));
        for (IElement c in this.children)
            c.paint(cv, ctx);
    }

    bool dispatch(Event e, UiContext* ctx)
    {
        for (IElement c in this.children)
        {
            if (c.dispatch(e, ctx))
                return true;
        }
        return false;
    }

    move string toJson()
    {
        string out = "{\"type\":\"Box\",\"style\":" + styleToJson(this.style);
        out = out + ",\"children\":[";
        int i = 0;
        for (IElement c in this.children)
        {
            if (i > 0)
                out = out + ",";
            out = out + c.toJson();
            i++;
        }
        out = out + "]}";
        return out;
    }

    void destroyTree()
    {
        for (IElement c in this.children)
        {
            c.destroyTree();
            delete c;
        }
        this.children.clear();
    }

    int kind() { return ELEM_BOX; }
    int flexWeight() { return 0; }
    void collectFocusables(list<string>* keys)
    {
        for (IElement c in this.children) c.collectFocusables(keys);
    }
    bool propsEqual(IElement other)
    {
        IBox o = other as IBox;
        return o != nullptr && styleEquals(this.style, o.style);
    }
    list<IElement>* childList() { return &this.children; }
    string keyOf() { return "" + this.key; }
    void setKey(string k) { this.key = k; }
    Rect nodeBounds() { return this.bounds; }
};

// -- TextInput: a single-line editable text field -----------------------------
// A CONTROLLED widget (React Native style): the host component owns the text in
// its state and passes it down as `value` each render; on a keystroke the field
// fires onChangeText(newValue) and the component updates its state + invalidates,
// so the next render flows the new value back in. The field takes focus on click
// and, while focused, inserts printable keys and deletes on Backspace. The buffer
// it builds per keystroke is an owning `string` - exactly the field-store path
// that string stabilization unblocked.
class TextInput : ITextInput
{
    string value       = default;
    string placeholder = default;
    Lambda<void(string)> onChangeText = default;
    int    width  = 0;          // 0 -> sized to content
    int    color = 0;               // text ink; 0 = default
    int    backgroundColor = 0;     // field fill; 0 = no fill
    bool   disabled = false;        // dimmed + ignores input
    string tooltip = default;       // native hover tooltip; "" = none
    Rect   bounds = default;
    string key    = default;

    void fireChangeText(string s) { this.onChangeText(s); }

    move string toJson()
    {
        return "{\"type\":\"TextInput\",\"value\":\"" + this.value + "\"}";
    }

    Size layout(LayoutConstraints c)
    {
        int w = this.width;
        if (w <= 0) w = (int)this.value.length() + 1;   // +1 for the caret cell
        if (w < 3) w = 3;
        Rect b = default;
        b.x = c.x; b.y = c.y; b.w = w; b.h = 1;
        this.bounds = b;
        Size s = default; s.w = w; s.h = 1;
        return s;
    }

    void paint(ICanvas cv, UiContext* ctx)
    {
        // Show the value, or the placeholder when empty; a focused field shows a
        // trailing '_' caret in the next cell.
        int bg = pickColor(this.backgroundColor, ctx.theme.inputBg);
        if (this.disabled) bg = dimColor(bg);
        if (bg != 0)
            cv.drawRect(this.bounds, true, bg);
        if (!this.disabled && ctx.hasFocus(this.key) && ctx.theme.focusRing != 0)
            cv.drawRect(this.bounds, false, ctx.theme.focusRing);
        int ink = pickColor(this.color, ctx.theme.inputText);
        if (this.disabled) ink = dimColor(ink);
        bool empty = this.value.length() == 0;
        string shown = empty ? this.placeholder : this.value;
        cv.drawText(this.bounds.x, this.bounds.y, shown.data(), ink);
        if (!this.disabled && ctx.hasFocus(this.key))
        {
            int caretX = this.bounds.x + (int)this.value.length();
            cv.drawText(caretX, this.bounds.y, "_", ink);
        }
    }

    bool dispatch(Event e, UiContext* ctx)
    {
        if (this.disabled) return false;
        if (e.kind == EV_MOUSE_DOWN)
        {
            if (this.bounds.contains(e.x, e.y)) { ctx.focus(this.key); return true; }
            return false;
        }
        if (e.kind == EV_MOUSE_MOVE)
        {
            if (this.bounds.contains(e.x, e.y)) { ctx.setHover(this.key); return true; }
            return false;
        }
        if (e.kind == EV_KEY)
        {
            if (!ctx.hasFocus(this.key)) return false;
            if (e.key == KEY_BACKSPACE)
            {
                int n = (int)this.value.length();
                if (n == 0) return true;
                string nv = substring(this.value, 0, n - 1);
                this.onChangeText(nv);
                return true;
            }
            if (e.key >= 32 && e.key <= 126)
            {
                char[2] cb;
                cb[0] = (char)e.key; cb[1] = '\0';
                string nv = this.value + cb;
                this.onChangeText(nv);
                return true;
            }
            return false;   // other keys (arrows/tab/enter) are not ours
        }
        return false;
    }

    void destroyTree() { }

    int kind() { return ELEM_TEXTINPUT; }
    int flexWeight() { return 0; }
    void collectFocusables(list<string>* keys)
    {
        if (!this.disabled && this.key.length() > 0) keys.add("" + this.key);
    }
    bool propsEqual(IElement other)
    {
        ITextInput o = other as ITextInput;
        return o != nullptr && this.value == o.value && this.disabled == o.disabled;
    }
    list<IElement>* childList() { return nullptr; }
    string keyOf() { return "" + this.key; }
    void setKey(string k) { this.key = k; }
    Rect nodeBounds() { return this.bounds; }
};

// -- Checkbox: a controlled on/off toggle with a label ------------------------
// Controlled like TextInput: the parent owns `checked` and passes it down; a click
// or Enter/Space while focused fires onChange(!checked) and the parent flips its
// state + invalidates, so the next render flows the new value back. Rendered as
// "[x] label" / "[ ] label"; themed ink, hover-highlights the label, focus ring,
// disabled dims and ignores input - all via the same UiContext state as Button.
class Checkbox : ICheckbox
{
    string label    = default;
    bool   checked  = false;
    bool   disabled = false;
    Lambda<void(bool)> onChange = default;
    int    color = 0;            // label ink; 0 = default
    string tooltip = default;    // native hover tooltip; "" = none
    Rect   bounds = default;
    string key   = default;

    void fireToggle() { this.onChange(!this.checked); }

    move string toJson()
    {
        string c = this.checked ? "true" : "false";
        return "{\"type\":\"Checkbox\",\"checked\":" + c
             + ",\"label\":\"" + this.label + "\"}";
    }

    Size layout(LayoutConstraints c)
    {
        Rect b = default;
        b.x = c.x; b.y = c.y; b.w = (int)this.label.length() + 4; b.h = 1;  // "[x] " + label
        this.bounds = b;
        Size s = default; s.w = b.w; s.h = 1;
        return s;
    }

    void paint(ICanvas cv, UiContext* ctx)
    {
        int ink = pickColor(this.color, ctx.theme.textColor);
        if (this.disabled) ink = dimColor(ink);
        else if (ctx.hasHover(this.key) && ctx.theme.focusRing != 0) ink = ctx.theme.focusRing;
        if (!this.disabled && ctx.hasFocus(this.key) && ctx.theme.focusRing != 0)
            cv.drawRect(this.bounds, false, ctx.theme.focusRing);
        string mark = this.checked ? "[x] " : "[ ] ";
        string shown = mark + this.label;
        cv.drawText(this.bounds.x, this.bounds.y, shown.data(), ink);
    }

    bool dispatch(Event e, UiContext* ctx)
    {
        if (this.disabled) return false;
        if (e.kind == EV_MOUSE_DOWN)
        {
            if (this.bounds.contains(e.x, e.y)) { ctx.focus(this.key); this.fireToggle(); return true; }
            return false;
        }
        if (e.kind == EV_MOUSE_MOVE)
        {
            if (this.bounds.contains(e.x, e.y)) { ctx.setHover(this.key); return true; }
            return false;
        }
        if (e.kind == EV_KEY)
        {
            if (ctx.hasFocus(this.key) && (e.key == KEY_ENTER || e.key == KEY_SPACE))
            {
                this.fireToggle();
                return true;
            }
        }
        return false;
    }

    void destroyTree() { }

    int kind() { return ELEM_CHECKBOX; }
    int flexWeight() { return 0; }
    void collectFocusables(list<string>* keys)
    {
        if (!this.disabled && this.key.length() > 0) keys.add("" + this.key);
    }
    bool propsEqual(IElement other)
    {
        ICheckbox o = other as ICheckbox;
        return o != nullptr && this.checked == o.checked && this.label == o.label
            && this.disabled == o.disabled;
    }
    list<IElement>* childList() { return nullptr; }
    string keyOf() { return "" + this.key; }
    void setKey(string k) { this.key = k; }
    Rect nodeBounds() { return this.bounds; }
};

// -- ProgressBar: a non-interactive themed fill bar (value 0..100) -------------
// Draws a trough (theme.track) with the filled fraction in theme.accent. Width is
// in cells. Purely presentational - it takes no input and no focus.
class ProgressBar : IProgressBar
{
    int    value = 0;          // 0..100
    int    width = 20;         // cells
    int    color = 0;          // fill override; 0 = theme accent
    string tooltip = default;  // native hover tooltip; "" = none
    Rect   bounds = default;
    string key = default;

    int _clampPct(int v) { if (v < 0) return 0; if (v > 100) return 100; return v; }

    move string toJson()
    {
        return "{\"type\":\"ProgressBar\",\"value\":" + this.value.toString() + "}";
    }

    Size layout(LayoutConstraints c)
    {
        int w = this.width; if (w < 2) w = 2;
        Rect b = default; b.x = c.x; b.y = c.y; b.w = w; b.h = 1;
        this.bounds = b;
        Size s = default; s.w = w; s.h = 1;
        return s;
    }

    void paint(ICanvas cv, UiContext* ctx)
    {
        int track = ctx.theme.track;
        int fill  = pickColor(this.color, ctx.theme.accent);
        if (track != 0) cv.drawRect(this.bounds, true, track);
        cv.drawRect(this.bounds, false, track);   // outline (0 -> default black border)
        int fw = this._clampPct(this.value) * this.bounds.w / 100;
        if (fw > 0)
        {
            Rect fr = this.bounds; fr.w = fw;
            cv.drawRect(fr, true, fill);
        }
    }

    bool dispatch(Event e, UiContext* ctx) { return false; }
    void destroyTree() { }
    int kind() { return ELEM_PROGRESS; }
    int flexWeight() { return 0; }
    void collectFocusables(list<string>* keys) { }
    bool propsEqual(IElement other)
    {
        IProgressBar o = other as IProgressBar;
        return o != nullptr && this.value == o.value && this.width == o.width;
    }
    list<IElement>* childList() { return nullptr; }
    string keyOf() { return "" + this.key; }
    void setKey(string k) { this.key = k; }
    Rect nodeBounds() { return this.bounds; }
};

// -- Slider: an interactive value (0..100) set by click/drag or arrow keys -----
// Click or drag along the track to set the value; while focused, Left/Right step
// it by 5. Renders a filled portion + a thumb in theme.accent and a focus ring.
// Controlled: fires onChange(newValue); the parent owns the value.
class Slider : ISlider
{
    int    value = 0;          // 0..100
    int    width = 20;         // cells
    bool   disabled = false;
    Lambda<void(int)> onChange = default;
    string tooltip = default;  // native hover tooltip; "" = none
    Rect   bounds = default;
    string key = default;

    void fireSet(int v)
    {
        if (v < 0) v = 0; if (v > 100) v = 100;
        this.onChange(v);
    }

    // Map a cell x along the track to a 0..100 value.
    int _valueAt(int px)
    {
        int span = this.bounds.w - 1; if (span < 1) span = 1;
        int v = (px - this.bounds.x) * 100 / span;
        if (v < 0) v = 0; if (v > 100) v = 100;
        return v;
    }

    move string toJson()
    {
        return "{\"type\":\"Slider\",\"value\":" + this.value.toString() + "}";
    }

    Size layout(LayoutConstraints c)
    {
        int w = this.width; if (w < 3) w = 3;
        Rect b = default; b.x = c.x; b.y = c.y; b.w = w; b.h = 1;
        this.bounds = b;
        Size s = default; s.w = w; s.h = 1;
        return s;
    }

    void paint(ICanvas cv, UiContext* ctx)
    {
        int track = ctx.theme.track;
        int fill  = ctx.theme.accent;
        if (this.disabled) { track = dimColor(track); fill = dimColor(fill); }
        if (track != 0) cv.drawRect(this.bounds, true, track);
        cv.drawRect(this.bounds, false, track);
        int v = this.value; if (v < 0) v = 0; if (v > 100) v = 100;
        int fw = v * this.bounds.w / 100;
        if (fw > 0) { Rect fr = this.bounds; fr.w = fw; cv.drawRect(fr, true, fill); }
        // Thumb: a one-cell marker at the filled end.
        int tx = this.bounds.x + fw;
        if (tx >= this.bounds.x + this.bounds.w) tx = this.bounds.x + this.bounds.w - 1;
        Rect th = default; th.x = tx; th.y = this.bounds.y; th.w = 1; th.h = 1;
        cv.drawRect(th, true, fill);
        if (!this.disabled && ctx.hasFocus(this.key) && ctx.theme.focusRing != 0)
            cv.drawRect(this.bounds, false, ctx.theme.focusRing);
    }

    bool dispatch(Event e, UiContext* ctx)
    {
        if (this.disabled) return false;
        if (e.kind == EV_MOUSE_DOWN)
        {
            if (this.bounds.contains(e.x, e.y))
            {
                ctx.focus(this.key);
                ctx.setPress(this.key);
                this.fireSet(this._valueAt(e.x));
                return true;
            }
            return false;
        }
        if (e.kind == EV_MOUSE_MOVE)
        {
            // While pressed, dragging anywhere updates the value (basic capture).
            if (ctx.hasPress(this.key)) { this.fireSet(this._valueAt(e.x)); return true; }
            if (this.bounds.contains(e.x, e.y)) { ctx.setHover(this.key); return true; }
            return false;
        }
        if (e.kind == EV_KEY)
        {
            if (ctx.hasFocus(this.key))
            {
                if (e.key == KEY_LEFT)  { this.fireSet(this.value - 5); return true; }
                if (e.key == KEY_RIGHT) { this.fireSet(this.value + 5); return true; }
            }
        }
        return false;
    }

    void destroyTree() { }
    int kind() { return ELEM_SLIDER; }
    int flexWeight() { return 0; }
    void collectFocusables(list<string>* keys)
    {
        if (!this.disabled && this.key.length() > 0) keys.add("" + this.key);
    }
    bool propsEqual(IElement other)
    {
        ISlider o = other as ISlider;
        return o != nullptr && this.value == o.value && this.disabled == o.disabled;
    }
    list<IElement>* childList() { return nullptr; }
    string keyOf() { return "" + this.key; }
    void setKey(string k) { this.key = k; }
    Rect nodeBounds() { return this.bounds; }
};

// -- TextArea: a multiline, scrollable text region (the editor's core widget) --
// Deliberately NOT controlled per keystroke (round-tripping a large buffer per key
// is the Electron-class mistake): the NATIVE control's buffer is the source of
// truth. `value` is the text to PUSH (initial content / file open); `onChange` is a
// dirty NOTIFICATION (no payload) fired on edits. The app pulls the current text
// with a host helper (nativeControlText) keyed by this node's key path. A ICanvas
// host falls back to painting `value` line by line (read-only preview).
class TextArea : ITextArea
{
    string value    = default;   // pushed content (setText); not per-keystroke state
    Lambda<void()> onChange = default;   // dirty notify (no payload)
    int    width  = 40;
    int    height = 10;
    int    color = 0;
    int    backgroundColor = 0;
    bool   disabled = false;
    string tooltip = default;  // native hover tooltip; "" = none
    Rect   bounds = default;
    string key    = default;

    void fireChange() { this.onChange(); }

    move string toJson() { return "{\"type\":\"TextArea\"}"; }

    Size layout(LayoutConstraints c)
    {
        int w = this.width;  if (w > c.availW && c.availW > 0) w = c.availW;
        if (w < 4) w = 4;
        int h = this.height; if (h < 2) h = 2;
        Rect b = default; b.x = c.x; b.y = c.y; b.w = w; b.h = h;
        this.bounds = b;
        Size s = default; s.w = w; s.h = h;
        return s;
    }

    // ICanvas fallback: draw the pushed text, one grid row per '\n'-delimited line,
    // clipped to the region. Native hosts ignore this (the EDIT paints itself).
    void paint(ICanvas cv, UiContext* ctx)
    {
        int bg = pickColor(this.backgroundColor, ctx.theme.inputBg);
        if (bg != 0) cv.drawRect(this.bounds, true, bg);
        cv.drawRect(this.bounds, false, pickColor(this.color, ctx.theme.panelBorder));
        int ink = pickColor(this.color, ctx.theme.inputText);
        int row = 0; int start = 0; int n = (int)this.value.length();
        int i = 0;
        while (i <= n && row < this.bounds.h - 1)
        {
            bool eol = i == n || this.value.data()[i] == '\n';
            if (eol)
            {
                string line = substring(this.value, start, i - start);
                cv.drawText(this.bounds.x + 1, this.bounds.y + 1 + row, line.data(), ink);
                row++; start = i + 1;
            }
            i++;
        }
    }

    bool dispatch(Event e, UiContext* ctx)
    {
        if (this.disabled) return false;
        if (e.kind == EV_MOUSE_DOWN && this.bounds.contains(e.x, e.y))
        {
            ctx.focus(this.key);
            return true;
        }
        return false;
    }

    void destroyTree() { }
    int kind() { return ELEM_TEXTAREA; }
    int flexWeight() { return 0; }
    void collectFocusables(list<string>* keys)
    {
        if (!this.disabled && this.key.length() > 0) keys.add("" + this.key);
    }
    // Uncontrolled: the value flowing down is a PUSH, not per-keystroke state, so
    // do not treat a value difference as a prop change (that would clobber the
    // native buffer mid-edit). Same kind + same key = the same editor.
    bool propsEqual(IElement other)
    {
        ITextArea o = other as ITextArea;
        return o != nullptr && this.disabled == o.disabled;
    }
    list<IElement>* childList() { return nullptr; }
    string keyOf() { return "" + this.key; }
    void setKey(string k) { this.key = k; }
    Rect nodeBounds() { return this.bounds; }
};

// A multiline text region seeded with `value` and notifying `onChange` on edits.
TextArea* textArea(string value, Lambda<void()> onChange)
{
    TextArea* t = new TextArea();
    t.value = value;
    t.onChange = onChange;
    return t;
}

// -- StatusBar: a bottom strip of text parts (msctls_statusbar32 on Win32) -----
// App-shell chrome: one or more text panes. `parts` is a plain public list so
// the <StatusBar/> sugar and imperative addPart() both work; the native host maps it
// to a real status bar (which self-docks at the window bottom), and a ICanvas host
// falls back to one row of " | "-joined parts.
class StatusBar : IStatusBar
{
    list<string> parts = default;   // text per pane; parts[0] is the main pane
    Rect   bounds = default;
    string key    = default;

    void addPart(string s) { this.parts.add("" + s); }

    move string toJson()
    {
        string out = "{\"type\":\"StatusBar\",\"parts\":[";
        int i = 0;
        while (i < this.parts.count())
        {
            if (i > 0) out = out + ",";
            out = out + "\"" + this.parts.get(i) + "\"";
            i++;
        }
        out = out + "]}";
        return out;
    }

    Size layout(LayoutConstraints c)
    {
        Rect b = default;
        b.x = c.x; b.y = c.y; b.w = c.availW; b.h = 1;
        this.bounds = b;
        Size s = default; s.w = b.w; s.h = 1;
        return s;
    }

    // ICanvas fallback: the panes joined by " | " on the strip's row.
    void paint(ICanvas cv, UiContext* ctx)
    {
        string line = "";
        int i = 0;
        while (i < this.parts.count())
        {
            if (i > 0) line = line + " | ";
            line = line + this.parts.get(i);
            i++;
        }
        cv.drawText(this.bounds.x, this.bounds.y, line.data(),
                    pickColor(0, ctx.theme.textColor));
    }

    bool dispatch(Event e, UiContext* ctx) { return false; }
    void destroyTree() { }
    int kind() { return ELEM_STATUSBAR; }
    int flexWeight() { return 0; }
    void collectFocusables(list<string>* keys) { }
    bool propsEqual(IElement other)
    {
        IStatusBar o = other as IStatusBar;
        if (o == nullptr) return false;
        if (this.parts.count() != o.parts.count()) return false;
        int i = 0;
        while (i < this.parts.count())
        {
            if (this.parts.get(i) != o.parts.get(i)) return false;
            i++;
        }
        return true;
    }
    list<IElement>* childList() { return nullptr; }
    string keyOf() { return "" + this.key; }
    void setKey(string k) { this.key = k; }
    Rect nodeBounds() { return this.bounds; }
};

// A status bar seeded with a main-pane string (add more panes with addPart()).
StatusBar* statusBar(string text)
{
    StatusBar* s = new StatusBar();
    s.parts.add("" + text);
    return s;
}

// -- ScrollView: a clipped, vertically scrollable viewport ---------------------
// Lays its children out in a tall virtual column shifted up by scrollY, then
// paints them clipped to its viewport (style.width x style.height cells) via the
// ICanvas clip seam. A focused ScrollView scrolls on Up/Down; scrolling changes
// layout but not the component tree, so it asks the host to repaint via
// ctx.requestRepaint() (reconcile would otherwise produce no patches).
// On a native host (Cocoa) the host maps this to a real NSScrollView and owns the
// offset: it never changes scrollY (stays 0), so children lay out at content
// coordinates from the viewport top and contentH sizes the native document view.
// Nested ScrollViews are out of scope for the native mapping (one level only).
class ScrollView : IScrollView
{
    Style style    = default;   // width x height = the viewport
    list<IElement> children = default;
    int    scrollY  = 0;
    int    contentH = 0;        // total laid-out child height (set during layout)
    Rect   bounds   = default;
    string key      = default;

    void add(IElement child) { this.children.add(child); }

    int _viewH()
    {
        if (this.style.height > 0) return this.style.height;
        return 1;
    }

    int _maxScroll()
    {
        int over = this.contentH - this._viewH();
        if (over < 0) return 0;
        return over;
    }

    Size layout(LayoutConstraints c)
    {
        int w = c.availW;
        if (this.style.width > 0) w = this.style.width;
        int h = this._viewH();
        // No explicit height + a bounded height available (native host): fill the
        // viewport. Under LAYOUT_UNBOUNDED (TUI/canvas) _viewH()'s fallback stands.
        if (this.style.height == 0 && c.availH < LAYOUT_UNBOUNDED)
            h = c.availH;

        Rect b = default;
        b.x = c.x; b.y = c.y; b.w = w; b.h = h;
        this.bounds = b;

        int top = c.y - this.scrollY;
        int cy = top;
        for (IElement child in this.children)
        {
            LayoutConstraints cc = default;
            cc.x = c.x; cc.y = cy;
            cc.availW = w; cc.availH = LAYOUT_UNBOUNDED;
            Size cs = child.layout(cc);
            cy = cy + cs.h;
        }
        this.contentH = cy - top;

        Size sz = default; sz.w = w; sz.h = h;
        return sz;
    }

    void paint(ICanvas cv, UiContext* ctx)
    {
        if (this.style.backgroundColor != 0)
            cv.drawRect(this.bounds, true, this.style.backgroundColor);
        cv.pushClip(this.bounds);
        for (IElement c in this.children)
            c.paint(cv, ctx);
        cv.popClip();
    }

    bool dispatch(Event e, UiContext* ctx)
    {
        if (e.kind == EV_MOUSE_DOWN)
        {
            if (!this.bounds.contains(e.x, e.y)) return false;   // outside viewport
            for (IElement c in this.children)
            {
                if (c.dispatch(e, ctx)) return true;
            }
            ctx.focus(this.key);   // empty viewport area -> focus for keyboard scroll
            return true;
        }
        if (e.kind == EV_MOUSE_MOVE || e.kind == EV_MOUSE_UP)
        {
            // Forward hover/release to children only while the pointer is inside
            // the viewport, so a child inside the scroll area can hover.
            if (!this.bounds.contains(e.x, e.y)) return false;
            for (IElement c in this.children)
            {
                if (c.dispatch(e, ctx)) return true;
            }
            return false;
        }
        if (e.kind == EV_KEY)
        {
            for (IElement c in this.children)
            {
                if (c.dispatch(e, ctx)) return true;   // a focused child consumes first
            }
            if (ctx.hasFocus(this.key))
            {
                if (e.key == KEY_DOWN && this.scrollY < this._maxScroll())
                {
                    this.scrollY = this.scrollY + 1; ctx.requestRepaint(); return true;
                }
                if (e.key == KEY_UP && this.scrollY > 0)
                {
                    this.scrollY = this.scrollY - 1; ctx.requestRepaint(); return true;
                }
            }
            return false;
        }
        return false;
    }

    move string toJson()
    {
        string out = "{\"type\":\"ScrollView\",\"scrollY\":" + this.scrollY.toString();
        out = out + ",\"children\":[";
        int i = 0;
        for (IElement c in this.children)
        {
            if (i > 0) out = out + ",";
            out = out + c.toJson();
            i++;
        }
        out = out + "]}";
        return out;
    }

    void destroyTree()
    {
        for (IElement c in this.children)
        {
            c.destroyTree();
            delete c;
        }
        this.children.clear();
    }

    int kind() { return ELEM_SCROLL; }
    int flexWeight() { return 0; }
    void collectFocusables(list<string>* keys)
    {
        if (this.key.length() > 0) keys.add("" + this.key);
        for (IElement c in this.children) c.collectFocusables(keys);
    }
    bool propsEqual(IElement other)
    {
        IScrollView o = other as IScrollView;
        return o != nullptr && styleEquals(this.style, o.style);
    }
    list<IElement>* childList() { return &this.children; }
    string keyOf() { return "" + this.key; }
    void setKey(string k) { this.key = k; }
    Rect nodeBounds() { return this.bounds; }
};

// Convenience constructors returning the concrete heap pointer (so callers can
// set typed props), assignable to an IElement slot at the use site.
View* view(Style style)
{
    View* v = new View();
    v.style = style;
    return v;
}

// A View whose children flow left-to-right (row) or top-to-bottom (column). Thin
// helpers over flexDirection so callers read declaratively.
View* row(Style style)
{
    View* v = new View();
    v.style = style;
    v.style.flexDirection = DIR_ROW;
    return v;
}

View* column(Style style)
{
    View* v = new View();
    v.style = style;
    v.style.flexDirection = DIR_COLUMN;
    return v;
}

// Plain string params: assigning an alias/param to an owning-string field
// deep-copies, so the field keeps its own buffer after the arg is freed.
Text* text(string s)
{
    Text* t = new Text();
    t.text = s;
    return t;
}

Button* button(string title, Lambda<void()> onPress)
{
    Button* b = new Button();
    b.title = title;
    b.onPress = onPress;
    return b;
}

Box* box(Style style)
{
    Box* b = new Box();
    b.style = style;
    return b;
}

// A controlled text field bound to `value` with an onChangeText handler.
TextInput* textInput(string value, Lambda<void(string)> onChangeText)
{
    TextInput* t = new TextInput();
    t.value = value;
    t.onChangeText = onChangeText;
    return t;
}

// A controlled checkbox bound to `checked` with an onChange(bool) handler.
Checkbox* checkbox(string label, bool checked, Lambda<void(bool)> onChange)
{
    Checkbox* c = new Checkbox();
    c.label = label;
    c.checked = checked;
    c.onChange = onChange;
    return c;
}

// A presentational progress bar (value 0..100) `width` cells wide.
ProgressBar* progressBar(int value, int width)
{
    ProgressBar* p = new ProgressBar();
    p.value = value;
    p.width = width;
    return p;
}

// A controlled slider bound to `value` (0..100) with an onChange(int) handler.
Slider* slider(int value, int width, Lambda<void(int)> onChange)
{
    Slider* s = new Slider();
    s.value = value;
    s.width = width;
    s.onChange = onChange;
    return s;
}

ScrollView* scrollView(Style style)
{
    ScrollView* s = new ScrollView();
    s.style = style;
    return s;
}

// -- RadioButton: one option inside a RadioGroup --------------------------------
// A dumb controlled leaf: `checked` is pushed down each render (index == group
// value), `index` is its position. The enclosing RadioGroup owns selection and
// hit-testing; a bare radio is inert on its own (the native host routes a click to
// the group by key path). Rendered "(o) label" / "( ) label" on a ICanvas host, a
// BS_AUTORADIOBUTTON on Win32 (WS_GROUP on the first radio of the group).
class RadioButton : IRadioButton
{
    string label      = default;
    int    index      = 0;          // position within the group (drives selection)
    bool   checked    = false;      // controlled: index == group.value
    bool   disabled   = false;
    bool   groupFirst = false;      // host puts WS_GROUP on the first radio of a group
    string tooltip    = default;    // native hover tooltip; "" = none
    Rect   bounds = default;
    string key    = default;

    move string toJson()
    {
        string c = this.checked ? "true" : "false";
        return "{\"type\":\"RadioButton\",\"checked\":" + c
             + ",\"label\":\"" + this.label + "\"}";
    }

    Size layout(LayoutConstraints c)
    {
        Rect b = default;
        b.x = c.x; b.y = c.y; b.w = (int)this.label.length() + 4; b.h = 1;  // "(o) " + label
        this.bounds = b;
        Size s = default; s.w = b.w; s.h = 1;
        return s;
    }

    void paint(ICanvas cv, UiContext* ctx)
    {
        int ink = pickColor(0, ctx.theme.textColor);
        if (this.disabled) ink = dimColor(ink);
        string mark = this.checked ? "(o) " : "( ) ";
        string shown = mark + this.label;
        cv.drawText(this.bounds.x, this.bounds.y, shown.data(), ink);
    }

    bool dispatch(Event e, UiContext* ctx) { return false; }
    void destroyTree() { }
    int kind() { return ELEM_RADIO; }
    int flexWeight() { return 0; }
    void collectFocusables(list<string>* keys)
    {
        if (!this.disabled && this.key.length() > 0) keys.add("" + this.key);
    }
    bool propsEqual(IElement other)
    {
        IRadioButton o = other as IRadioButton;
        return o != nullptr && this.checked == o.checked && this.label == o.label
            && this.disabled == o.disabled;
    }
    list<IElement>* childList() { return nullptr; }
    string keyOf() { return "" + this.key; }
    void setKey(string k) { this.key = k; }
    Rect nodeBounds() { return this.bounds; }
};

// -- RadioGroup: a controlled single-choice group of RadioButtons --------------
// Owns the selected `value` (an index) and `onChange`. It is a layout container
// (not itself a native control, like View); its RadioButton children ARE controls.
// Selection is controlled: each render sets each child's `checked` (via addOption or
// sugar `checked={value==i}`), and a click fires onChange(index). The group is where
// hit-testing lives on a ICanvas host; the native host routes a radio click here by
// walking the key path up one segment.
class RadioGroup : IRadioGroup
{
    list<IElement> children = default;   // RadioButton*
    int   value    = 0;                 // selected index (controlled)
    Lambda<void(int)> onChange = default;
    Style style    = default;
    Rect  bounds   = default;
    string key     = default;

    void add(IElement child) { this.children.add(child); }

    void fireChange(int v) { this.onChange(v); }

    // Append a wired option. `checked` is seeded from the current value at render time
    // (the controlled contract); reconcile propagates a later selection change through
    // each child's propsEqual (checked), so the committed tree the host syncs is right.
    void addOption(string label)
    {
        RadioButton* r = new RadioButton();
        r.label = label;
        r.index = this.children.count();
        r.checked = r.index == this.value;
        r.key = "r" + r.index.toString();
        this.children.add(r);
    }

    // Mark the first child as the WS_GROUP boundary (position-based, so it is stable
    // across reconcile even though container props are otherwise treated as stable),
    // then stack the radios in a column.
    Size layout(LayoutConstraints c)
    {
        int pad = this.style.padding;
        int gap = this.style.gap;
        int cy = c.y + pad;
        int i = 0;
        for (IElement child in this.children)
        {
            if (child.kind() == ELEM_RADIO)
            {
                IRadioButton rb = child as IRadioButton;
                rb.groupFirst = i == 0;
            }
            if (i > 0) cy = cy + gap;
            LayoutConstraints cc = default;
            cc.x = c.x + pad; cc.y = cy;
            cc.availW = c.availW - 2 * pad; cc.availH = c.availH - 2 * pad;
            Size cs = child.layout(cc);
            cy = cy + cs.h;
            i++;
        }
        Rect b = default;
        b.x = c.x; b.y = c.y; b.w = c.availW; b.h = (cy - c.y) + pad;
        this.bounds = b;
        Size sz = default; sz.w = b.w; sz.h = b.h;
        return sz;
    }

    void paint(ICanvas cv, UiContext* ctx)
    {
        for (IElement c in this.children) c.paint(cv, ctx);
    }

    bool dispatch(Event e, UiContext* ctx)
    {
        if (e.kind == EV_MOUSE_DOWN)
        {
            for (IElement c in this.children)
            {
                if (c.kind() != ELEM_RADIO) continue;
                IRadioButton rb = c as IRadioButton;
                Rect rbb = rb.nodeBounds();   // `bounds` is not an interface field; IElement exposes it
                if (!rb.disabled && rbb.contains(e.x, e.y))
                {
                    ctx.focus(this.key);
                    this.onChange(rb.index);
                    return true;
                }
            }
        }
        return false;
    }

    move string toJson()
    {
        string out = "{\"type\":\"RadioGroup\",\"value\":" + this.value.toString();
        out = out + ",\"children\":[";
        int i = 0;
        for (IElement c in this.children)
        {
            if (i > 0) out = out + ",";
            out = out + c.toJson();
            i++;
        }
        out = out + "]}";
        return out;
    }

    void destroyTree()
    {
        for (IElement c in this.children) { c.destroyTree(); delete c; }
        this.children.clear();
    }

    int kind() { return ELEM_RADIOGROUP; }
    int flexWeight() { return 0; }
    void collectFocusables(list<string>* keys)
    {
        for (IElement c in this.children) c.collectFocusables(keys);
    }
    bool propsEqual(IElement other)
    {
        IRadioGroup o = other as IRadioGroup;
        return o != nullptr && this.value == o.value && styleEquals(this.style, o.style);
    }
    list<IElement>* childList() { return &this.children; }
    string keyOf() { return "" + this.key; }
    void setKey(string k) { this.key = k; }
    Rect nodeBounds() { return this.bounds; }
};

// -- ComboBox: a controlled dropdown --------------------------------------------
// A CBS_DROPDOWNLIST on Win32 (NSPopUpButton on Cocoa later). Controlled like the
// other widgets: `selectedIndex` + `items` flow down, a selection fires
// onChange(index). ICanvas fallback shows "[selected v]" and cycles on click.
class ComboBox : IComboBox
{
    list<string> items = default;
    int   selectedIndex = 0;
    Lambda<void(int)> onChange = default;
    int   width    = 0;             // 0 -> sized to the widest item
    bool  disabled = false;
    string tooltip = default;
    Rect  bounds = default;
    string key   = default;

    void addItem(string s) { this.items.add("" + s); }

    void fireChange(int v) { this.onChange(v); }

    string _selectedText()
    {
        if (this.selectedIndex < 0 || this.selectedIndex >= this.items.count()) return "";
        return "" + this.items.get(this.selectedIndex);
    }

    move string toJson()
    {
        int n = this.items.count();
        return "{\"type\":\"ComboBox\",\"selectedIndex\":" + this.selectedIndex.toString()
             + ",\"count\":" + n.toString() + "}";
    }

    Size layout(LayoutConstraints c)
    {
        int w = this.width;
        if (w <= 0)
        {
            int mx = 4;
            int i = 0;
            while (i < this.items.count())
            {
                int l = (int)this.items.get(i).length();
                if (l > mx) mx = l;
                i++;
            }
            w = mx + 4;   // room for the dropdown arrow
        }
        if (w < 6) w = 6;
        Rect b = default; b.x = c.x; b.y = c.y; b.w = w; b.h = 1;
        this.bounds = b;
        Size s = default; s.w = w; s.h = 1;
        return s;
    }

    void paint(ICanvas cv, UiContext* ctx)
    {
        int ink = pickColor(0, ctx.theme.inputText);
        if (this.disabled) ink = dimColor(ink);
        int bg = pickColor(0, ctx.theme.inputBg);
        if (bg != 0) cv.drawRect(this.bounds, true, bg);
        string shown = "[" + this._selectedText() + " v]";
        cv.drawText(this.bounds.x, this.bounds.y, shown.data(), ink);
    }

    bool dispatch(Event e, UiContext* ctx)
    {
        if (this.disabled) return false;
        if (e.kind == EV_MOUSE_DOWN && this.bounds.contains(e.x, e.y))
        {
            ctx.focus(this.key);
            int n = this.items.count();
            if (n > 0) this.onChange((this.selectedIndex + 1) % n);
            return true;
        }
        if (e.kind == EV_KEY && ctx.hasFocus(this.key))
        {
            int n = this.items.count();
            if (n == 0) return false;
            if (e.key == KEY_DOWN) { this.onChange((this.selectedIndex + 1) % n); return true; }
            if (e.key == KEY_UP)   { this.onChange((this.selectedIndex - 1 + n) % n); return true; }
        }
        return false;
    }

    void destroyTree() { }
    int kind() { return ELEM_COMBO; }
    int flexWeight() { return 0; }
    void collectFocusables(list<string>* keys)
    {
        if (!this.disabled && this.key.length() > 0) keys.add("" + this.key);
    }
    bool propsEqual(IElement other)
    {
        IComboBox o = other as IComboBox;
        if (o == nullptr) return false;
        if (this.selectedIndex != o.selectedIndex || this.disabled != o.disabled) return false;
        if (this.items.count() != o.items.count()) return false;
        int i = 0;
        while (i < this.items.count())
        {
            if (this.items.get(i) != o.items.get(i)) return false;
            i++;
        }
        return true;
    }
    list<IElement>* childList() { return nullptr; }
    string keyOf() { return "" + this.key; }
    void setKey(string k) { this.key = k; }
    Rect nodeBounds() { return this.bounds; }
};

// -- ListView: a virtualized report-mode list -----------------------------------
// The item SOURCE is a callback, not a copied list: `rowText(row, col)` supplies a
// cell on demand, so `rowCount` can be 100k+ and only the visible rows are ever
// queried (LVS_OWNERDATA on Win32; NSTableView's dataSource is naturally the same
// shape). Selection is controlled (`selectedIndex`); onSelect fires on a selection
// change, onActivate on double-click / Enter. Column headers/widths are set through
// the setListOp seam by the host. rowText/onSelect/onActivate are owning closures
// that capture the component pointer, so they read current state even when the
// committed node is reused across renders (no per-frame re-box needed).
class ListView : IListView
{
    list<string> columns   = default;   // header titles
    list<int>    colWidths = default;    // per-column width in DIPs (parallel to columns)
    int   rowCount = 0;
    Lambda<string(int,int)> rowText = default;   // (row, col) -> cell text
    int   selectedIndex = -1;            // controlled single selection (-1 = none)
    bool  multiSelect = false;
    Lambda<void(int)> onSelect   = default;      // selection changed to row
    Lambda<void(int)> onActivate = default;      // double-click / Enter on row
    int   width  = 40;
    int   height = 10;
    bool  disabled = false;
    string tooltip = default;
    Rect  bounds = default;
    string key = default;

    void addColumn(string title, int widthDip)
    {
        this.columns.add("" + title);
        this.colWidths.add(widthDip);
    }

    void fireSelect(int row)   { this.onSelect(row); }
    void fireActivate(int row) { this.onActivate(row); }

    move string toJson()
    {
        int nc = this.columns.count();
        return "{\"type\":\"ListView\",\"rowCount\":" + this.rowCount.toString()
             + ",\"columns\":" + nc.toString()
             + ",\"selectedIndex\":" + this.selectedIndex.toString() + "}";
    }

    Size layout(LayoutConstraints c)
    {
        int w = this.width;  if (w > c.availW && c.availW > 0) w = c.availW;
        if (w < 6) w = 6;
        int h = this.height; if (h < 3) h = 3;
        Rect b = default; b.x = c.x; b.y = c.y; b.w = w; b.h = h;
        this.bounds = b;
        Size s = default; s.w = w; s.h = h;
        return s;
    }

    // ICanvas fallback: header row + only the rows that fit (virtualization is visible
    // here too - the callback is asked for at most bounds.h-1 rows regardless of count).
    void paint(ICanvas cv, UiContext* ctx)
    {
        int bg = pickColor(0, ctx.theme.inputBg);
        if (bg != 0) cv.drawRect(this.bounds, true, bg);
        cv.drawRect(this.bounds, false, pickColor(0, ctx.theme.panelBorder));
        int ink = pickColor(0, ctx.theme.textColor);
        string hdr = "";
        int c = 0;
        while (c < this.columns.count())
        {
            if (c > 0) hdr = hdr + " | ";
            hdr = hdr + this.columns.get(c);
            c++;
        }
        cv.drawText(this.bounds.x + 1, this.bounds.y, hdr.data(), ink);
        int ncol = this.columns.count(); if (ncol < 1) ncol = 1;
        int visible = this.bounds.h - 1;
        int r = 0;
        while (r < visible && r < this.rowCount)
        {
            string line = "";
            int cc = 0;
            while (cc < ncol)
            {
                if (cc > 0) line = line + " | ";
                line = line + this.rowText(r, cc);
                cc++;
            }
            if (r == this.selectedIndex) line = ">" + line;
            cv.drawText(this.bounds.x + 1, this.bounds.y + 1 + r, line.data(), ink);
            r++;
        }
    }

    bool dispatch(Event e, UiContext* ctx)
    {
        if (this.disabled) return false;
        if (e.kind == EV_MOUSE_DOWN && this.bounds.contains(e.x, e.y))
        {
            ctx.focus(this.key);
            int r = e.y - (this.bounds.y + 1);
            if (r >= 0 && r < this.rowCount) this.onSelect(r);
            return true;
        }
        if (e.kind == EV_KEY && ctx.hasFocus(this.key))
        {
            if (e.key == KEY_ENTER && this.selectedIndex >= 0) { this.onActivate(this.selectedIndex); return true; }
            if (e.key == KEY_DOWN && this.selectedIndex + 1 < this.rowCount) { this.onSelect(this.selectedIndex + 1); return true; }
            if (e.key == KEY_UP && this.selectedIndex > 0) { this.onSelect(this.selectedIndex - 1); return true; }
        }
        return false;
    }

    void destroyTree() { }
    int kind() { return ELEM_LIST; }
    int flexWeight() { return 0; }
    void collectFocusables(list<string>* keys)
    {
        if (!this.disabled && this.key.length() > 0) keys.add("" + this.key);
    }
    bool propsEqual(IElement other)
    {
        IListView o = other as IListView;
        if (o == nullptr) return false;
        return this.rowCount == o.rowCount && this.selectedIndex == o.selectedIndex
            && this.multiSelect == o.multiSelect && this.disabled == o.disabled
            && this.columns.count() == o.columns.count();
    }
    list<IElement>* childList() { return nullptr; }
    string keyOf() { return "" + this.key; }
    void setKey(string k) { this.key = k; }
    Rect nodeBounds() { return this.bounds; }
};

// -- IElement factories (thin field-setters; sugar-ready fields elsewhere) -------
// A controlled radio group; append options with addOption(), which wires index/key
// and seeds checked from `value`.
RadioGroup* radioGroup(int value, Lambda<void(int)> onChange)
{
    RadioGroup* g = new RadioGroup();
    g.value = value;
    g.onChange = onChange;
    return g;
}

// A controlled dropdown; add items with addItem().
ComboBox* comboBox(int selectedIndex, Lambda<void(int)> onChange)
{
    ComboBox* c = new ComboBox();
    c.selectedIndex = selectedIndex;
    c.onChange = onChange;
    return c;
}

// A virtualized list; add columns with addColumn() and set `rowText`/`rowCount`.
ListView* listView(int rowCount, Lambda<string(int,int)> rowText)
{
    ListView* lv = new ListView();
    lv.rowCount = rowCount;
    lv.rowText = rowText;
    return lv;
}

// -- ListView rowText callback boxing (the setListOp seam carries an opaque u64) -
// The native host must call back into a `Lambda<string(int,int)>` when the OS asks
// for a cell (LVN_GETDISPINFO). A Lambda type cannot cross the INativeHost interface
// (it breaks the monomorphizer - same constraint as ctx.post), so ui.cb heap-boxes
// the closure and the seam carries the box as a u64. The host stores the box per
// control, invokes it through __uiListRowText, and frees it via __uiFreeListRowBox
// when the control is destroyed. Mirrors the PostBox pattern above.
class ListRowBox { Lambda<string(int,int)> cb = default; };

// Heap-box a rowText closure. Returns a TYPED pointer so escape analysis keeps the
// cloned closure alive past this call; the caller casts to u64 at its own site.
ListRowBox* _boxListRow(Lambda<string(int,int)> cb)
{
    ListRowBox* b = new ListRowBox();
    b.cb = cb;   // clone-in (lambdas are clone-by-default)
    return b;
}

// Invoke a boxed rowText callback (called by the host from its cell-data handler).
// Returns an owned string; the host copies the bytes into the OS buffer then lets it
// drop. An empty/zero box yields "".
move string __uiListRowText(u64 boxPtr, int row, int col)
{
    if (boxPtr == 0u) return "";
    ListRowBox* b = (ListRowBox*)boxPtr;
    return b.cb(row, col);
}

void __uiFreeListRowBox(u64 boxPtr)
{
    if (boxPtr == 0u) return;
    ListRowBox* b = (ListRowBox*)boxPtr;
    delete b;
}

// -- TabPane: one titled pane inside a TabControl --------------------------------
// A pure layout container (like View), NOT itself a native control. Its `title`
// labels the tab; its children are the pane content. Only the ACTIVE pane is walked
// into native controls by the host (lazy inactive tabs), so a re-render never
// materializes an inactive pane's controls.
class TabPane : ITabPane
{
    string title = default;
    list<IElement> children = default;
    Rect bounds = default;
    string key = default;

    void add(IElement child) { this.children.add(child); }

    Size layout(LayoutConstraints c)
    {
        int cy = c.y;
        for (IElement child in this.children)
        {
            LayoutConstraints cc = default;
            cc.x = c.x; cc.y = cy; cc.availW = c.availW; cc.availH = c.availH;
            Size cs = child.layout(cc);
            cy = cy + cs.h;
        }
        Rect b = default; b.x = c.x; b.y = c.y; b.w = c.availW; b.h = cy - c.y;
        this.bounds = b;
        Size s = default; s.w = b.w; s.h = b.h;
        return s;
    }

    void paint(ICanvas cv, UiContext* ctx) { for (IElement c in this.children) c.paint(cv, ctx); }

    bool dispatch(Event e, UiContext* ctx)
    {
        for (IElement c in this.children) { if (c.dispatch(e, ctx)) return true; }
        return false;
    }

    move string toJson()
    {
        string out = "{\"type\":\"TabPane\",\"title\":\"" + this.title + "\",\"children\":[";
        int i = 0;
        for (IElement c in this.children) { if (i > 0) out = out + ","; out = out + c.toJson(); i++; }
        out = out + "]}";
        return out;
    }

    void destroyTree()
    {
        for (IElement c in this.children) { c.destroyTree(); delete c; }
        this.children.clear();
    }

    int kind() { return ELEM_TABPANE; }
    int flexWeight() { return 0; }
    void collectFocusables(list<string>* keys)
    {
        for (IElement c in this.children) c.collectFocusables(keys);
    }
    bool propsEqual(IElement other)
    {
        ITabPane o = other as ITabPane;
        return o != nullptr && this.title == o.title;
    }
    list<IElement>* childList() { return &this.children; }
    string keyOf() { return "" + this.key; }
    void setKey(string k) { this.key = k; }
    Rect nodeBounds() { return this.bounds; }
};

// -- TabControl: keyed child panes with lazy inactive tabs ----------------------
// A native SysTabControl32 header strip (WC_TABCONTROL) plus one active pane whose
// content maps to native controls; inactive panes are NOT walked into native (so a
// per-tab editor buffer must live in the app model, not an inactive native control).
// Controlled: `selectedTab` flows down, a header click fires onSelectTab(index).
class TabControl : ITabControl
{
    list<IElement> children = default;   // TabPane*
    int selectedTab = 0;                 // controlled active pane index
    Lambda<void(int)> onSelectTab = default;
    int width = 40;
    int height = 10;
    bool disabled = false;
    string tooltip = default;
    Rect bounds = default;
    string key = default;

    void add(IElement child) { this.children.add(child); }
    void addPane(TabPane* p) { this.children.add(p); }

    void fireSelectTab(int i) { this.onSelectTab(i); }

    string _title(int i)
    {
        if (i < 0 || i >= this.children.count()) return "";
        IElement c = this.children.get(i);
        ITabPane p = c as ITabPane;
        if (p == nullptr) return "";
        return "" + p.title;
    }

    Size layout(LayoutConstraints c)
    {
        int w = this.width;  if (w > c.availW && c.availW > 0) w = c.availW;
        if (w < 6) w = 6;
        int h = this.height; if (h < 3) h = 3;
        Rect b = default; b.x = c.x; b.y = c.y; b.w = w; b.h = h;
        this.bounds = b;
        int hdr = 2;   // the tab header strip reserves two rows
        int i = 0;
        for (IElement child in this.children)
        {
            LayoutConstraints cc = default;
            if (i == this.selectedTab)
            {
                cc.x = c.x + 1; cc.y = c.y + hdr;
                cc.availW = w - 2; cc.availH = h - hdr - 1;
            }
            else
            {
                cc.x = c.x; cc.y = c.y; cc.availW = 0; cc.availH = 0;   // inactive: zero-area
            }
            child.layout(cc);
            i++;
        }
        Size s = default; s.w = w; s.h = h;
        return s;
    }

    void paint(ICanvas cv, UiContext* ctx)
    {
        int bg = pickColor(0, ctx.theme.panelBg);
        if (bg != 0) cv.drawRect(this.bounds, true, bg);
        cv.drawRect(this.bounds, false, pickColor(0, ctx.theme.panelBorder));
        int ink = pickColor(0, ctx.theme.textColor);
        string hdr = "";
        int i = 0;
        while (i < this.children.count())
        {
            if (i > 0) hdr = hdr + " ";
            string t = this._title(i);
            if (i == this.selectedTab) hdr = hdr + "[" + t + "]";
            else hdr = hdr + " " + t + " ";
            i++;
        }
        cv.drawText(this.bounds.x + 1, this.bounds.y, hdr.data(), ink);
        if (this.selectedTab >= 0 && this.selectedTab < this.children.count())
            this.children.get(this.selectedTab).paint(cv, ctx);
    }

    bool dispatch(Event e, UiContext* ctx)
    {
        if (this.disabled) return false;
        if (e.kind == EV_MOUSE_DOWN && e.y == this.bounds.y && this.bounds.contains(e.x, e.y))
        {
            int rel = e.x - (this.bounds.x + 1);
            int cx = 0; int i = 0;
            while (i < this.children.count())
            {
                string t = this._title(i);
                int seg = (int)t.length() + 2 + 1;   // "[t]" plus a gap
                if (rel >= cx && rel < cx + seg) { this.onSelectTab(i); return true; }
                cx = cx + seg; i++;
            }
            return true;
        }
        if (this.selectedTab >= 0 && this.selectedTab < this.children.count())
            return this.children.get(this.selectedTab).dispatch(e, ctx);
        return false;
    }

    move string toJson()
    {
        string out = "{\"type\":\"TabControl\",\"selectedTab\":" + this.selectedTab.toString()
                   + ",\"children\":[";
        int i = 0;
        for (IElement c in this.children) { if (i > 0) out = out + ","; out = out + c.toJson(); i++; }
        out = out + "]}";
        return out;
    }

    void destroyTree()
    {
        for (IElement c in this.children) { c.destroyTree(); delete c; }
        this.children.clear();
    }

    int kind() { return ELEM_TABS; }
    int flexWeight() { return 0; }
    void collectFocusables(list<string>* keys)
    {
        if (this.selectedTab >= 0 && this.selectedTab < this.children.count())
            this.children.get(this.selectedTab).collectFocusables(keys);
    }
    bool propsEqual(IElement other)
    {
        ITabControl o = other as ITabControl;
        return o != nullptr && this.selectedTab == o.selectedTab
            && this.children.count() == o.children.count();
    }
    list<IElement>* childList() { return &this.children; }
    string keyOf() { return "" + this.key; }
    void setKey(string k) { this.key = k; }
    Rect nodeBounds() { return this.bounds; }
};

// -- TreeView: an expand-on-demand tree ------------------------------------------
// The node source is a set of callbacks keyed by an integer nodeId (the app's own
// ids), so the tree is virtualized: children(nodeId) is queried only when a node is
// expanded. childCount(TREE_ROOT) gives the top-level nodes; childId(nodeId, i) the
// i-th child's id; label(nodeId) its text. Controlled selection is `selectedNode`;
// onSelect(nodeId) fires on a selection change, onExpand(nodeId) on expand. Native =
// WC_TREEVIEW (SysTreeView32); the ICanvas fallback renders the top-level nodes.
const int TREE_ROOT = -1;   // virtual root nodeId; its children are the top-level nodes

class TreeView : ITreeView
{
    Lambda<int(int)>     childCount = default;   // nodeId -> number of children
    Lambda<int(int,int)> childId    = default;   // (nodeId, i) -> child nodeId
    Lambda<string(int)>  label      = default;   // nodeId -> display text
    int selectedNode = 0 - 1;                      // controlled selection (nodeId; -1 = none)
    Lambda<void(int)> onSelect = default;
    Lambda<void(int)> onExpand = default;
    int width = 24;
    int height = 10;
    bool disabled = false;
    string tooltip = default;
    Rect bounds = default;
    string key = default;

    void fireSelect(int nodeId) { this.onSelect(nodeId); }
    void fireExpand(int nodeId) { this.onExpand(nodeId); }

    move string toJson()
    {
        return "{\"type\":\"TreeView\",\"selectedNode\":" + this.selectedNode.toString() + "}";
    }

    Size layout(LayoutConstraints c)
    {
        int w = this.width;  if (w > c.availW && c.availW > 0) w = c.availW;
        if (w < 4) w = 4;
        int h = this.height; if (h < 3) h = 3;
        Rect b = default; b.x = c.x; b.y = c.y; b.w = w; b.h = h;
        this.bounds = b;
        Size s = default; s.w = w; s.h = h;
        return s;
    }

    void paint(ICanvas cv, UiContext* ctx)
    {
        int bg = pickColor(0, ctx.theme.inputBg);
        if (bg != 0) cv.drawRect(this.bounds, true, bg);
        cv.drawRect(this.bounds, false, pickColor(0, ctx.theme.panelBorder));
        int ink = pickColor(0, ctx.theme.textColor);
        int n = this.childCount(TREE_ROOT);
        int visible = this.bounds.h - 1;
        int r = 0;
        while (r < n && r < visible)
        {
            int nid = this.childId(TREE_ROOT, r);
            string mark = this.childCount(nid) > 0 ? "+ " : "  ";
            string line = mark + this.label(nid);
            if (nid == this.selectedNode) line = ">" + line;
            cv.drawText(this.bounds.x + 1, this.bounds.y + 1 + r, line.data(), ink);
            r++;
        }
    }

    bool dispatch(Event e, UiContext* ctx)
    {
        if (this.disabled) return false;
        if (e.kind == EV_MOUSE_DOWN && this.bounds.contains(e.x, e.y))
        {
            ctx.focus(this.key);
            int r = e.y - (this.bounds.y + 1);
            int n = this.childCount(TREE_ROOT);
            if (r >= 0 && r < n) { int nid = this.childId(TREE_ROOT, r); this.onSelect(nid); }
            return true;
        }
        return false;
    }

    void destroyTree() { }
    int kind() { return ELEM_TREE; }
    int flexWeight() { return 0; }
    void collectFocusables(list<string>* keys)
    {
        if (!this.disabled && this.key.length() > 0) keys.add("" + this.key);
    }
    bool propsEqual(IElement other)
    {
        ITreeView o = other as ITreeView;
        return o != nullptr && this.selectedNode == o.selectedNode && this.disabled == o.disabled;
    }
    list<IElement>* childList() { return nullptr; }
    string keyOf() { return "" + this.key; }
    void setKey(string k) { this.key = k; }
    Rect nodeBounds() { return this.bounds; }
};

// -- SplitView: two weighted panes + a draggable divider ------------------------
// A pure layout container (not itself a native control): it splits the available
// space between exactly two child panes by `ratio` (the first pane's percentage
// along the split axis), reserving a 1-DIP divider gutter between them. `vertical`
// true = side-by-side (a vertical divider), false = stacked. Dragging the divider
// fires onRatioChange(newRatio) - the app owns the ratio (controlled), the host hit-
// tests the gutter. The ICanvas fallback draws the two panes and the divider line.
const int SPLIT_DIVIDER = 1;   // DIP thickness of the divider gutter

class SplitView : ISplitView
{
    list<IElement> children = default;   // exactly two panes
    int   ratio    = 50;                 // first pane's percentage of the split axis (5..95)
    bool  vertical = true;               // true = side-by-side, false = stacked
    Lambda<void(int)> onRatioChange = default;
    Style style    = default;
    Rect  bounds   = default;
    Rect  dividerBounds = default;       // the draggable gutter (host hit-test target)
    string key     = default;

    void add(IElement child) { this.children.add(child); }

    void fireRatioChange(int r) { this.onRatioChange(r); }

    int _clampRatio(int v) { if (v < 5) return 5; if (v > 95) return 95; return v; }

    Size layout(LayoutConstraints c)
    {
        int w = c.availW; if (this.style.width > 0) w = this.style.width;
        int h = this.style.height > 0 ? this.style.height : c.availH;
        if (h >= LAYOUT_UNBOUNDED) h = 1;
        Rect b = default; b.x = c.x; b.y = c.y; b.w = w; b.h = h;
        this.bounds = b;
        int rt = this._clampRatio(this.ratio);
        if (this.vertical)
        {
            int firstW = (w - SPLIT_DIVIDER) * rt / 100;
            if (this.children.count() > 0)
            {
                LayoutConstraints cc = default;
                cc.x = c.x; cc.y = c.y; cc.availW = firstW; cc.availH = h;
                this.children.get(0).layout(cc);
            }
            Rect d = default; d.x = c.x + firstW; d.y = c.y; d.w = SPLIT_DIVIDER; d.h = h;
            this.dividerBounds = d;
            if (this.children.count() > 1)
            {
                LayoutConstraints cc = default;
                cc.x = c.x + firstW + SPLIT_DIVIDER; cc.y = c.y;
                cc.availW = w - firstW - SPLIT_DIVIDER; cc.availH = h;
                this.children.get(1).layout(cc);
            }
        }
        else
        {
            int firstH = (h - SPLIT_DIVIDER) * rt / 100;
            if (this.children.count() > 0)
            {
                LayoutConstraints cc = default;
                cc.x = c.x; cc.y = c.y; cc.availW = w; cc.availH = firstH;
                this.children.get(0).layout(cc);
            }
            Rect d = default; d.x = c.x; d.y = c.y + firstH; d.w = w; d.h = SPLIT_DIVIDER;
            this.dividerBounds = d;
            if (this.children.count() > 1)
            {
                LayoutConstraints cc = default;
                cc.x = c.x; cc.y = c.y + firstH + SPLIT_DIVIDER;
                cc.availW = w; cc.availH = h - firstH - SPLIT_DIVIDER;
                this.children.get(1).layout(cc);
            }
        }
        Size s = default; s.w = w; s.h = h;
        return s;
    }

    // Map a pointer position along the split axis to a ratio (clamped 5..95).
    int _ratioAt(int px, int py)
    {
        if (this.vertical)
        {
            if (this.bounds.w <= 1) return this.ratio;
            return this._clampRatio((px - this.bounds.x) * 100 / this.bounds.w);
        }
        if (this.bounds.h <= 1) return this.ratio;
        return this._clampRatio((py - this.bounds.y) * 100 / this.bounds.h);
    }

    void paint(ICanvas cv, UiContext* ctx)
    {
        for (IElement c in this.children) c.paint(cv, ctx);
        cv.drawRect(this.dividerBounds, true, pickColor(this.style.color, ctx.theme.panelBorder));
    }

    bool dispatch(Event e, UiContext* ctx)
    {
        if (e.kind == EV_MOUSE_DOWN && this.dividerBounds.contains(e.x, e.y))
        {
            ctx.setPress(this.key); return true;
        }
        if (e.kind == EV_MOUSE_MOVE && ctx.hasPress(this.key))
        {
            this.onRatioChange(this._ratioAt(e.x, e.y)); return true;
        }
        for (IElement c in this.children) { if (c.dispatch(e, ctx)) return true; }
        return false;
    }

    move string toJson()
    {
        string out = "{\"type\":\"SplitView\",\"ratio\":" + this.ratio.toString()
                   + ",\"children\":[";
        int i = 0;
        for (IElement c in this.children) { if (i > 0) out = out + ","; out = out + c.toJson(); i++; }
        out = out + "]}";
        return out;
    }

    void destroyTree()
    {
        for (IElement c in this.children) { c.destroyTree(); delete c; }
        this.children.clear();
    }

    int kind() { return ELEM_SPLIT; }
    int flexWeight() { return 0; }
    void collectFocusables(list<string>* keys)
    {
        for (IElement c in this.children) c.collectFocusables(keys);
    }
    bool propsEqual(IElement other)
    {
        ISplitView o = other as ISplitView;
        return o != nullptr && this.ratio == o.ratio && this.vertical == o.vertical
            && styleEquals(this.style, o.style);
    }
    list<IElement>* childList() { return &this.children; }
    string keyOf() { return "" + this.key; }
    void setKey(string k) { this.key = k; }
    Rect nodeBounds() { return this.bounds; }
};

// Copy controlled CONTAINER scalars from a wip node onto the retained committed node
// during reconcile. Only the containers whose native host layout reads a scalar
// need this - see the call in reconcilePath. Both args are named borrows (safe `as`).
void adoptContainerProps(IElement committed, IElement wip)
{
    int k = committed.kind();
    if (k == ELEM_TABS)
    {
        ITabControl a = committed as ITabControl;
        ITabControl b = wip as ITabControl;
        if (a != nullptr && b != nullptr) a.selectedTab = b.selectedTab;
    }
    else if (k == ELEM_SPLIT)
    {
        ISplitView a = committed as ISplitView;
        ISplitView b = wip as ISplitView;
        if (a != nullptr && b != nullptr) { a.ratio = b.ratio; a.vertical = b.vertical; }
    }
}

// -- TreeView node-source boxing (the setListOp seam carries an opaque u64) ------
// The native host must call back into the tree's childCount/childId/label closures
// when the OS asks to expand a node (TVN_ITEMEXPANDING) or reports selection. Lambdas
// cannot cross the INativeHost interface (monomorphizer limit - same as ctx.post /
// ListRowBox), so ui.cb heap-boxes the three closures and the seam carries the box as
// a u64. The host invokes them through __uiTree* and frees via __uiFreeTreeBox.
class TreeBox
{
    Lambda<int(int)>     childCount = default;
    Lambda<int(int,int)> childId    = default;
    Lambda<string(int)>  label      = default;
};

TreeBox* _boxTree(Lambda<int(int)> cc, Lambda<int(int,int)> ci, Lambda<string(int)> lb)
{
    TreeBox* b = new TreeBox();
    b.childCount = cc; b.childId = ci; b.label = lb;   // clone-in (lambdas clone-by-default)
    return b;
}

int __uiTreeChildCount(u64 boxPtr, int nodeId)
{
    if (boxPtr == 0u) return 0;
    TreeBox* b = (TreeBox*)boxPtr;
    return b.childCount(nodeId);
}

int __uiTreeChildId(u64 boxPtr, int nodeId, int i)
{
    if (boxPtr == 0u) return 0;
    TreeBox* b = (TreeBox*)boxPtr;
    return b.childId(nodeId, i);
}

move string __uiTreeLabel(u64 boxPtr, int nodeId)
{
    if (boxPtr == 0u) return "";
    TreeBox* b = (TreeBox*)boxPtr;
    return b.label(nodeId);
}

void __uiFreeTreeBox(u64 boxPtr)
{
    if (boxPtr == 0u) return;
    TreeBox* b = (TreeBox*)boxPtr;
    delete b;
}

// Free a boxed ContextMenu (host-owned; registered by key via nativeSetContextMenu,
// freed on window teardown). Mirrors __uiFreeListRowBox / __uiFreeTreeBox.
void __uiFreeContextMenu(u64 menuPtr)
{
    if (menuPtr == 0u) return;
    ContextMenu* m = (ContextMenu*)menuPtr;
    delete m;
}

// -- IElement factories (thin field-setters; sugar-ready fields elsewhere) -------
TabPane* tabPane(string title)
{
    TabPane* p = new TabPane();
    p.title = title;
    return p;
}

TabControl* tabControl(int selectedTab, Lambda<void(int)> onSelectTab)
{
    TabControl* t = new TabControl();
    t.selectedTab = selectedTab;
    t.onSelectTab = onSelectTab;
    return t;
}

// A tree with its node source. onSelect/onExpand default to no-ops so the native host
// never invokes an unset closure; the app overrides them.
TreeView* treeView(Lambda<int(int)> childCount, Lambda<int(int,int)> childId, Lambda<string(int)> label)
{
    TreeView* t = new TreeView();
    t.childCount = childCount;
    t.childId = childId;
    t.label = label;
    t.onSelect = (int nid) => { };
    t.onExpand = (int nid) => { };
    return t;
}

SplitView* splitView(int ratio, bool vertical)
{
    SplitView* s = new SplitView();
    s.ratio = ratio;
    s.vertical = vertical;
    return s;
}

// A toolbar is a styled row of Buttons - no new native control. This factory is
// the documented pattern: a DIR_ROW View with a small gap. Icons arrive with Image.
View* toolbar()
{
    View* v = new View();
    v.style.flexDirection = DIR_ROW;
    v.style.gap = 1;
    return v;
}

// -- Image: a bitmap leaf -----------------------------------------------------
// Displays a 32-bit BGRA image. The pixel source is toolkit-neutral: the app hands
// down a BORROWED top-down BGRA32 buffer (`pixels` + `pxW`/`pxH`) that the native host
// uploads through the setImageData seam (an HBITMAP + STM_SETIMAGE on Win32). The app
// owns the buffer (a component field / global freed on teardown), so the element never
// owns pixel memory - it just points at it, like the borrowed `tooltip`/`source`
// string literals. Alternatively `source` names a .bmp file the host decodes directly.
// A ICanvas host has no bitmap surface, so it falls back to a bordered placeholder box
// with the `altText` centered.
class Image : IImageElement
{
    u64    pixels  = 0u;         // borrowed top-down BGRA32 buffer (app-owned); 0 = none
    int    pxW     = 0;          // source pixel width
    int    pxH     = 0;          // source pixel height
    int    width   = 8;          // layout width (DIP)
    int    height  = 4;          // layout height (DIP)
    string source  = default;    // optional .bmp file path (host-decoded); use a literal
    string altText = default;    // placeholder / accessibility text; use a literal
    string tooltip = default;    // native hover tooltip; "" = none
    Rect   bounds = default;
    string key    = default;

    move string toJson()
    {
        return "{\"type\":\"Image\",\"pxW\":" + this.pxW.toString()
             + ",\"pxH\":" + this.pxH.toString() + "}";
    }

    Size layout(LayoutConstraints c)
    {
        int w = this.width;  if (w < 1) w = 1;
        int h = this.height; if (h < 1) h = 1;
        Rect b = default; b.x = c.x; b.y = c.y; b.w = w; b.h = h;
        this.bounds = b;
        Size s = default; s.w = w; s.h = h;
        return s;
    }

    // ICanvas fallback: a bordered box with the alt text (a char grid has no bitmap).
    void paint(ICanvas cv, UiContext* ctx)
    {
        cv.drawRect(this.bounds, false, pickColor(0, ctx.theme.panelBorder));
        string t = this.altText.length() > 0 ? this.altText : "[img]";
        cv.drawText(this.bounds.x + 1, this.bounds.y + this.bounds.h / 2, t.data(),
                    pickColor(0, ctx.theme.textColor));
    }

    bool dispatch(Event e, UiContext* ctx) { return false; }
    void destroyTree() { }
    int kind() { return ELEM_IMAGE; }
    int flexWeight() { return 0; }
    void collectFocusables(list<string>* keys) { }
    bool propsEqual(IElement other)
    {
        IImageElement o = other as IImageElement;
        return o != nullptr && this.pixels == o.pixels && this.pxW == o.pxW
            && this.pxH == o.pxH && this.width == o.width && this.height == o.height;
    }
    list<IElement>* childList() { return nullptr; }
    string keyOf() { return "" + this.key; }
    void setKey(string k) { this.key = k; }
    Rect nodeBounds() { return this.bounds; }
};

// An image bound to a borrowed BGRA32 buffer (top-down, stride = pxW*4).
Image* image(u64 pixels, int pxW, int pxH)
{
    Image* im = new Image();
    im.pixels = pixels;
    im.pxW = pxW;
    im.pxH = pxH;
    return im;
}

// -- GroupBox: a titled group frame -------------------------------------------
// The classic-forms grouping frame: a border with a caption, wrapping related
// controls. A pure sized container (like Box) whose native mapping is a BS_GROUPBOX
// (a BUTTON that draws the frame + caption); its children position as siblings inside
// the frame. A ICanvas host draws a bordered box with the title on the top edge.
class GroupBox : IGroupBox
{
    string title = default;
    Style  style = default;
    list<IElement> children = default;
    string tooltip = default;
    Rect   bounds = default;
    string key    = default;

    void add(IElement child) { this.children.add(child); }

    Size layout(LayoutConstraints c)
    {
        int w = c.availW;
        if (this.style.width > 0) w = this.style.width;
        int h = 2;
        if (this.style.height > 0) h = this.style.height;
        Rect b = default; b.x = c.x; b.y = c.y; b.w = w; b.h = h;
        this.bounds = b;

        int inset = 1 + this.style.padding;
        int cy = c.y + inset;   // one row down for the caption + frame
        int gi = 0;
        for (IElement child in this.children)
        {
            if (gi > 0) cy = cy + this.style.gap;
            LayoutConstraints cc = default;
            cc.x = c.x + inset; cc.y = cy;
            cc.availW = w - 2 * inset; cc.availH = h - 2 * inset;
            Size cs = child.layout(cc);
            cy = cy + cs.h;
            gi++;
        }
        Size sz = default; sz.w = w; sz.h = h;
        return sz;
    }

    void paint(ICanvas cv, UiContext* ctx)
    {
        cv.drawRect(this.bounds, false, pickColor(this.style.color, ctx.theme.panelBorder));
        cv.drawText(this.bounds.x + 2, this.bounds.y, this.title.data(),
                    pickColor(0, ctx.theme.textColor));
        for (IElement c in this.children) c.paint(cv, ctx);
    }

    bool dispatch(Event e, UiContext* ctx)
    {
        for (IElement c in this.children) { if (c.dispatch(e, ctx)) return true; }
        return false;
    }

    move string toJson()
    {
        string out = "{\"type\":\"GroupBox\",\"title\":\"" + this.title + "\",\"children\":[";
        int i = 0;
        for (IElement c in this.children) { if (i > 0) out = out + ","; out = out + c.toJson(); i++; }
        out = out + "]}";
        return out;
    }

    void destroyTree()
    {
        for (IElement c in this.children) { c.destroyTree(); delete c; }
        this.children.clear();
    }

    int kind() { return ELEM_GROUPBOX; }
    int flexWeight() { return 0; }
    void collectFocusables(list<string>* keys)
    {
        for (IElement c in this.children) c.collectFocusables(keys);
    }
    bool propsEqual(IElement other)
    {
        IGroupBox o = other as IGroupBox;
        return o != nullptr && this.title == o.title && styleEquals(this.style, o.style);
    }
    list<IElement>* childList() { return &this.children; }
    string keyOf() { return "" + this.key; }
    void setKey(string k) { this.key = k; }
    Rect nodeBounds() { return this.bounds; }
};

// A titled group frame sized to style.width x style.height (add children with .add()).
GroupBox* groupBox(string title, Style style)
{
    GroupBox* g = new GroupBox();
    g.title = title;
    g.style = style;
    return g;
}

// -- CanvasView: the app-painted escape hatch ---------------------------------
// Hosts a child surface the app draws with the SAME ICanvas API the framework paints
// through. `onPaint(ICanvas)` receives a ICanvas whose cell origin is the view's top-left;
// the app draws text/rects freely. This closes the "the framework cannot do X" gap: any
// custom widget (a chart, a game board) is a CanvasView with a paint closure. On a native
// host the view maps to a GDI-backed child window that invokes the boxed closure on
// WM_PAINT (see the CanvasBox seam below); on a ICanvas host, paint() delegates straight
// to onPaint with the host's own ICanvas.
class CanvasView : ICanvasView
{
    Lambda<void(ICanvas)> onPaint = default;
    int    width   = 20;         // layout width (DIP)
    int    height  = 8;          // layout height (DIP)
    string tooltip = default;
    Rect   bounds = default;
    string key    = default;

    move string toJson() { return "{\"type\":\"CanvasView\"}"; }

    Size layout(LayoutConstraints c)
    {
        int w = this.width;  if (w > c.availW && c.availW > 0) w = c.availW;
        if (w < 1) w = 1;
        int h = this.height; if (h < 1) h = 1;
        Rect b = default; b.x = c.x; b.y = c.y; b.w = w; b.h = h;
        this.bounds = b;
        Size s = default; s.w = w; s.h = h;
        return s;
    }

    // ICanvas fallback: the host IS a ICanvas, so delegate straight to the app's painter.
    void paint(ICanvas cv, UiContext* ctx) { this.onPaint(cv); }

    bool dispatch(Event e, UiContext* ctx) { return false; }
    void destroyTree() { }
    int kind() { return ELEM_CANVAS; }
    int flexWeight() { return 0; }
    void collectFocusables(list<string>* keys) { }
    bool propsEqual(IElement other) { ICanvasView o = other as ICanvasView; return o != nullptr; }
    list<IElement>* childList() { return nullptr; }
    string keyOf() { return "" + this.key; }
    void setKey(string k) { this.key = k; }
    Rect nodeBounds() { return this.bounds; }
};

// A canvas view driven by an onPaint(ICanvas) closure.
CanvasView* canvasView(Lambda<void(ICanvas)> onPaint)
{
    CanvasView* c = new CanvasView();
    c.onPaint = onPaint;
    return c;
}

// -- CanvasView paint-callback boxing (the seam carries an opaque u64) ----------
// The native host must invoke the app's onPaint(ICanvas) closure when the OS asks the
// child window to repaint (WM_PAINT). A Lambda cannot cross the INativeHost interface
// (monomorphizer limit - same as ctx.post / ListRowBox / TreeBox), so ui.cb heap-boxes
// the closure and the seam carries the box as a u64. The host constructs its own ICanvas
// (a GDI-backed one) and invokes the box through __uiCanvasPaint; it frees the box via
// __uiFreeCanvasBox when the control is destroyed.
class CanvasBox { Lambda<void(ICanvas)> paint = default; };

CanvasBox* _boxCanvas(Lambda<void(ICanvas)> p)
{
    CanvasBox* b = new CanvasBox();
    b.paint = p;   // clone-in (lambdas clone-by-default)
    return b;
}

void __uiCanvasPaint(u64 boxPtr, ICanvas c)
{
    if (boxPtr == 0u) return;
    CanvasBox* b = (CanvasBox*)boxPtr;
    b.paint(c);
}

void __uiFreeCanvasBox(u64 boxPtr)
{
    if (boxPtr == 0u) return;
    CanvasBox* b = (CanvasBox*)boxPtr;
    delete b;
}

// Move focus to the next (or previous, when backward) focusable node in tree
// order, wrapping around. Built fresh from the live tree each time, so it tracks
// keyed identity across re-renders. The host calls this on Tab / Shift-Tab.
void moveFocus(IElement tree, UiContext* ctx, bool backward)
{
    list<string> keys = default;
    tree.collectFocusables(&keys);
    int n = keys.count();
    if (n == 0) return;

    int cur = -1;
    int i = 0;
    while (i < n)
    {
        string k = keys.get(i);
        if (ctx.hasFocus(k)) { cur = i; break; }
        i++;
    }

    int next = 0;
    if (cur < 0) next = backward ? n - 1 : 0;
    else if (backward) next = (cur - 1 + n) % n;
    else next = (cur + 1) % n;

    ctx.focus(keys.get(next));
}

// Tear down and free an entire owning tree: descendants first (via the node's
// own destroyTree), then the root node itself. `move` transfers ownership of the
// root in, so the delete is authorized; delete dispatches virtually.
void deleteTree(move IElement root)
{
    root.destroyTree();
    delete root;
}

// -- Reconciler / patch stream -------------------------------------------------
//
// reconcile() diffs a freshly-rendered WIP tree against the committed (live)
// tree, mutating the committed tree in place and recording what changed as a
// list<Patch>. It keeps a single owning tree across renders: unchanged nodes keep
// their identity; changed nodes are swapped in from the WIP tree; the rest of the
// WIP tree is freed. The patch log is in-memory only (not a serialized wire
// format - that, and OTA, are deliberately out of scope here).

int PATCH_UPDATE  = 0;   // a leaf's props changed (committed leaf swapped for the new one)
int PATCH_REPLACE = 1;   // node type changed at a slot
int PATCH_INSERT  = 2;   // a new child was added
int PATCH_REMOVE  = 3;   // a child was dropped (and freed)

struct Patch
{
    int    op       = 0;          // PATCH_*
    int    nodeKind = 0;          // ELEM_* of the affected node
    string detail   = default;    // human-readable, for tests/debug
    string key      = default;    // stable key path of the affected node ("" if unkeyed)
};

Patch makePatch(int op, int nodeKind, string detail)
{
    Patch p = default;
    p.op = op;
    p.nodeKind = nodeKind;
    p.detail = detail;
    return p;
}

// Patch identity: the affected node's stable key path lets a INativeHost route
// a create/update/destroy to the right control without re-walking the tree. `key`
// is the parent key-path joined with the node's own key; unkeyed nodes carry the
// positional path the reconciler synthesizes at the call site.
Patch makePatchKeyed(int op, int nodeKind, string detail, string key)
{
    Patch p = default;
    p.op = op;
    p.nodeKind = nodeKind;
    p.detail = detail;
    p.key = key;
    return p;
}

// Join a parent key path with a child segment, e.g. "root" + "save" -> "root/save".
string joinKeyPath(string parent, string seg)
{
    if (parent.length() == 0) return "" + seg;
    return parent + "/" + seg;
}

// Index of the first element in `pool` whose key equals `key`, or -1. Used to
// match keyed children by identity instead of position (so middle insert/remove
// and reorder preserve the right nodes).
int indexByKey(list<IElement>* pool, string key)
{
    int i = 0;
    while (i < pool.count())
    {
        string ek = pool.get(i).keyOf();
        bool match = ek == key;
        if (match) return i;
        i++;
    }
    return -1;
}

// Diff `wip` into `committed`, appending patches. Returns the node to keep in the
// committed tree (usually `committed`; the WIP node on a replace/leaf-update).
// Frees whichever subtree it discards. Ownership of both args transfers in.
move IElement reconcile(move IElement committed, move IElement wip, list<Patch>* patches)
{
    // Public entry: the root has no parent path. reconcilePath threads a stable
    // key path down the tree so each patch carries its node's identity.
    return reconcilePath(committed, wip, patches, "");
}

// The child segment for a node at position `pos`: its own key if keyed, else the
// synthesized positional segment "#pos" so unkeyed nodes still get a stable path.
string keySegment(IElement node, int pos)
{
    string k = node.keyOf();
    if (k.length() > 0) return k;
    return "#" + pos.toString();
}

// Reconcile threading the parent key path. Behavior (patch op/kind/count/order and
// which subtree is freed) is IDENTICAL to the earlier reconcile; the only addition
// is populating each patch's `key` with the affected node's joined key path.
move IElement reconcilePath(move IElement committed, move IElement wip, list<Patch>* patches, string parentPath)
{
    // The committed node's own segment (keyed identity; "" at the unkeyed root).
    string selfPath = joinKeyPath(parentPath, keySegment(committed, 0));

    // Different node type at this slot: replace the whole subtree.
    if (committed.kind() != wip.kind())
    {
        patches.add(makePatchKeyed(PATCH_REPLACE, wip.kind(), "replace", selfPath));
        deleteTree(committed);
        return wip;
    }

    // Same type. Leaves: structured props compare (same kind guaranteed above).
    list<IElement>* kids = committed.childList();
    if (kids == nullptr)
    {
        if (!committed.propsEqual(wip))
        {
            // Adopt the new leaf (new props, and a fresh onPress for Button).
            patches.add(makePatchKeyed(PATCH_UPDATE, wip.kind(), "update", selfPath));
            deleteTree(committed);
            return wip;
        }
        // Unchanged: keep the committed node's identity, drop the WIP node.
        deleteTree(wip);
        return committed;
    }

    // Same type, container: reconcile children by key (or position when unkeyed).
    list<IElement>* newKids = wip.childList();
    int newN = newKids.count();

    // Controlled CONTAINER props: reconcile keeps the committed container node and
    // frees the wip, so a controlled scalar authored on the wip (tab selection / split
    // ratio) would be lost. Copy those forward for the containers whose host layout reads
    // them - the leaf-prop RadioGroup pattern does not apply since these drive geometry.
    adoptContainerProps(committed, wip);

    // Drain committed's children into a staging list so we can rebuild in order.
    list<IElement> staged = default;
    while (kids.count() > 0)
        staged.add(kids.take(0));

    int i = 0;
    while (i < newN)
    {
        IElement newC = newKids.take(0);

        // Match a committed child to reuse: by key if this child is keyed (so it
        // can move position), else positionally from the front of the staged list.
        string k = newC.keyOf();
        int idx = -1;
        if (k.length() > 0) idx = indexByKey(&staged, k);
        else if (staged.count() > 0) idx = 0;

        if (idx >= 0)
        {
            IElement oldC = staged.take(idx);
            kids.add(reconcilePath(oldC, newC, patches, selfPath));
        }
        else
        {
            string childPath = joinKeyPath(selfPath, keySegment(newC, i));
            patches.add(makePatchKeyed(PATCH_INSERT, newC.kind(), "insert", childPath));
            kids.add(newC);
        }
        i++;
    }

    // Any committed children left over were removed.
    while (staged.count() > 0)
    {
        IElement rem = staged.take(0);
        string remPath = joinKeyPath(selfPath, keySegment(rem, 0));
        patches.add(makePatchKeyed(PATCH_REMOVE, rem.kind(), "remove", remPath));
        deleteTree(rem);
    }

    // WIP children all drained; free just the WIP container shell.
    // (Container style itself is treated as stable in this phase - see v3 plan.)
    deleteTree(wip);
    return committed;
}

// -- Components (model layer) --------------------------------------------------
//
// A component renders itself to a host IElement tree. render() receives the
// host-owned UiContext so its event closures can call ctx.invalidate() (mark the
// UI dirty) and the host can drain it once per loop. Threading the context in
// keeps the framework free of process-global mutable state.
interface IComponent
{
    IElement render(UiContext* ctx);
};

// -- ComponentElement: a reconciler node wrapping a component's rendered subtree -
//
// Lets a parent render child components as nodes in its own tree. A parent owns
// its child components (e.g. list<Counter*>) and, each render, re-mounts them by
// key; the reconciler matches ComponentElements by key (kind ELEM_COMPONENT) and
// descends into the single inner child, so each child's subtree - and the state
// behind it - keeps its identity across add/remove/reorder. The wrapper has no
// style of its own; layout/paint/dispatch delegate to the inner subtree.
class ComponentElement : IElement
{
    list<IElement> inner = default;   // exactly one child: the component's render()
    Rect bounds = default;
    string key = default;

    Size layout(LayoutConstraints c)
    {
        Size total = default;
        int cy = c.y;
        for (IElement child in this.inner)
        {
            LayoutConstraints cc = default;
            cc.x = c.x; cc.y = cy;
            cc.availW = c.availW; cc.availH = c.availH;
            Size cs = child.layout(cc);
            cy = cy + cs.h;
            total.h = total.h + cs.h;
        }
        total.w = c.availW;

        Rect b = default;
        b.x = c.x; b.y = c.y; b.w = total.w; b.h = total.h;
        this.bounds = b;
        return total;
    }

    void paint(ICanvas cv, UiContext* ctx)
    {
        for (IElement c in this.inner)
            c.paint(cv, ctx);
    }

    bool dispatch(Event e, UiContext* ctx)
    {
        for (IElement c in this.inner)
        {
            if (c.dispatch(e, ctx))
                return true;
        }
        return false;
    }

    move string toJson()
    {
        string out = "{\"type\":\"Component\",\"child\":";
        for (IElement c in this.inner)
            out = out + c.toJson();
        return out + "}";
    }

    void destroyTree()
    {
        for (IElement c in this.inner)
        {
            c.destroyTree();
            delete c;
        }
        this.inner.clear();
    }

    int kind() { return ELEM_COMPONENT; }
    int flexWeight() { return 0; }
    void collectFocusables(list<string>* keys)
    {
        for (IElement c in this.inner) c.collectFocusables(keys);
    }
    bool propsEqual(IElement other) { return true; }
    list<IElement>* childList() { return &this.inner; }
    string keyOf() { return "" + this.key; }
    void setKey(string k) { this.key = k; }
    Rect nodeBounds() { return this.bounds; }
};

// Render a component now and wrap its subtree as a keyed reconciler node. The
// component itself is owned by the caller (typically a parent component holding
// its children by pointer); mount only renders it, it does not take ownership.
// The UiContext threads through so the child's event closures can invalidate.
ComponentElement* mount(IComponent c, string key, UiContext* ctx)
{
    ComponentElement* ce = new ComponentElement();
    ce.setKey(key);
    ce.inner.add(c.render(ctx));
    return ce;
}

// ============================================================================
// INativeHost seam (merged from the former example/ui/ui_native.cb).
// The framework above and this seam were separate files whose combined name
// collided with the chosen module name; they ship as one core module now.
// ============================================================================
// Boolean control properties (setBoolProp). Values are stable so a future backend
// can switch on them directly.
int PROP_CHECKED = 1;   // Checkbox/radio checked state
int PROP_ENABLED = 2;   // control is interactive (vs disabled/dimmed)
int PROP_VISIBLE = 3;   // control is shown

// Integer control properties (setIntProp).
int PROP_VALUE   = 1;   // ProgressBar/Slider position (0..100)
int PROP_MAX     = 2;   // range maximum (default 100)
int PROP_CARET   = 3;   // text caret index
int PROP_SCROLLY = 4;   // vertical scroll offset (DIPs)

// Font ids for measureText; a host maps these to a concrete typeface + size.
int FONT_UI      = 0;   // the default UI font (Segoe UI Variable / system)
int FONT_MONO    = 1;   // a monospace face (editor / code)

// -- setListOp: the item-data batch protocol -----------------------------------
// Property sets (setText/setBoolProp/setIntProp) cannot express a data-control's
// columns + item source, so a ListView drives its native control through one op-coded
// call. The ops below are the DELIBERATE common denominator of three toolkits, chosen
// so the Cocoa/WinUI backends implement the SAME protocol without a redesign:
//   * Win32 WC_LISTVIEW (report + LVS_OWNERDATA): RESET/ADD_COLUMN -> LVM_INSERTCOLUMN;
//     SET_ROWCOUNT -> LVM_SETITEMCOUNT; SET_ROWTEXT_CB stores the callback that
//     LVN_GETDISPINFO invokes; SELECT_MODE -> LVS_SINGLESEL; SET_SELECTION ->
//     LVM_SETITEMSTATE; INVALIDATE -> LVM_REDRAWITEMS.
//   * macOS NSTableView (view-based, dataSource-virtualized): ADD_COLUMN ->
//     addTableColumn:; SET_ROWCOUNT -> numberOfRowsInTableView + noteNumberOfRows;
//     SET_ROWTEXT_CB feeds tableView:objectValueForTableColumn:row:; SET_SELECTION ->
//     selectRowIndexes:; INVALIDATE -> reloadData.
//   * WinUI ItemsView/ListView: ADD_COLUMN -> a column in the layout/template;
//     SET_ROWCOUNT + SET_ROWTEXT_CB back a virtualized ItemsSource adapter;
//     SET_SELECTION -> SelectedIndex; INVALIDATE -> refresh the source.
// The rowText callback is an OPAQUE u64 (a ui.cb ListRowBox*, see __uiListRowText) -
// no Lambda type crosses the seam, mirroring ctx.post. Reads (current selection /
// a cell's text) are host free functions, not interface methods, since they return
// values; see nativeListSelectedRow / nativeListCellText in the Win32 host.
int LISTOP_RESET_COLUMNS  = 1;   // remove every column (start a fresh header set)
int LISTOP_ADD_COLUMN     = 2;   // arg0 = width in DIPs, text = header title
int LISTOP_SET_ROWCOUNT   = 3;   // arg0 = number of (virtual) rows
int LISTOP_SET_ROWTEXT_CB = 4;   // payload = boxed rowText callback (ListRowBox* as u64)
int LISTOP_SET_SELECT_MODE = 5;  // arg0 = 0 single-select, 1 multi-select
int LISTOP_SET_SELECTION  = 6;   // arg0 = row to select (-1 clears selection)
int LISTOP_INVALIDATE     = 7;   // redraw / reload the visible (virtual) rows

// -- Tab + tree ops on the SAME setListOp seam ---------------------------------
// TabControl and TreeView reuse setListOp rather than adding new interface methods
// (keeps the seam surface flat - one batch call for every data/navigation control).
//   * TabControl (WC_TABCONTROL): TAB_RESET -> TCM_DELETEALLITEMS; TAB_ADD -> TCM_INSERTITEM
//     (arg0 = index, text = title); TAB_SET_SEL -> TCM_SETCURSEL (arg0 = index). Cocoa maps
//     these to a tabless NSTabView / segmented control; WinUI to a TabView.
//   * TreeView (WC_TREEVIEW): TREE_SET_SRC_CB stores the boxed node-source (TreeBox* as u64,
//     like ROWTEXT_CB); TREE_REBUILD clears + inserts the root's children (lazy, cChildren
//     drives the expander, TVN_ITEMEXPANDING materializes on demand). Cocoa -> NSOutlineView
//     dataSource, WinUI -> TreeView ItemsSource. Selection round-trips through the
//     native control (TVN_SELCHANGED), so there is no SET_SELECTION op for the tree.
int LISTOP_TAB_RESET       = 10;  // remove every tab
int LISTOP_TAB_ADD         = 11;  // arg0 = index, text = tab title
int LISTOP_TAB_SET_SEL     = 12;  // arg0 = selected tab index
int LISTOP_TREE_SET_SRC_CB = 20;  // payload = boxed TreeBox* (child/label callbacks) as u64
int LISTOP_TREE_REBUILD    = 21;  // clear + insert the root's children (expand-on-demand)

// The native backend contract. One instance per app drives all its windows'
// controls. A method that takes a handle `h` operates on a control previously
// returned by createControl.
interface INativeHost
{
    // Create a control of the given ELEM_* kind under `parentHandle` (0 = the
    // window's client area). `key` is the node's stable key path, for the host's
    // own reverse map (handle -> key) used to route events. Returns the handle.
    u64  createControl(int elemKind, u64 parentHandle, string key);
    void destroyControl(u64 h);

    // Geometry + content, all property-style so they map to XAML setters later.
    void setFrame(u64 h, Rect frameDip);
    void setText(u64 h, const char* s);
    void setBoolProp(u64 h, int prop, bool v);
    void setIntProp(u64 h, int prop, int v);
    void setAccent(u64 h, int fgColor, int bgColor);   // 0 = native default

    // Text metrics for layout (replaces the 1-cell-per-char assumption). Returns
    // the size in DIPs the string needs in font `fontId`, wrapped to
    // `wrapWidthDip` (0 = single line, unbounded).
    Size measureText(const char* s, int fontId, int wrapWidthDip);

    // Ask the host to relayout the tree and reposition controls (e.g. after a
    // content change that alters intrinsic sizes).
    void requestLayout();

    // Item-data batch op for data controls (ListView). `op` is a LISTOP_* code;
    // `arg0`/`arg1` are integer operands, `text` a UTF-8 string operand (column
    // titles), `payload` an opaque u64 (the boxed rowText callback). See the LISTOP_*
    // design block above - this is the one seam call that is NOT a plain property set.
    void setListOp(u64 h, int op, int arg0, int arg1, const char* text, u64 payload);

    // -- setImageData: push decoded pixels to an Image control --------------------
    // An Image's content is a toolkit-neutral 32-bit BGRA buffer, NOT a Win32 HBITMAP:
    // `pixels` is an opaque u64 pointing at `h`-row x `stride`-byte top-down BGRA32 data;
    // the host uploads it to the control however its toolkit prefers (Win32: a top-down
    // 32bpp DIB section + STM_SETIMAGE; WinUI: a WriteableBitmap; macOS: an NSImage from
    // the same bytes). A dedicated method rather than an overloaded setListOp op because
    // the operand shape (a raw pixel pointer + w/h/stride) is unlike the LISTOP_* integer/
    // string/box operands, and image data never rides the item-data virtualization path.
    // The decoder (a file -> BGRA buffer) is host-internal (WIC / LoadImage on Windows), so
    // no image-library type crosses the seam; the app hands down only the BGRA bytes.
    void setImageData(u64 h, u64 pixels, int w, int h2, int stride);
};
