// -- Objective-C callback IMPs (D5: one shared CfHostTarget carries them all) --
// Plain non-capturing cflat functions; state flows through the host globals - no
// Lambda crosses the C ABI.

// isFlipped -> YES: the content view's origin is top-left, like Win32.
i8 _isFlippedImp(void* self, void* cmd) { return (i8)1; }

// applicationShouldTerminateAfterLastWindowClosed: -> NO. The host controls exit
// itself (the main window's windowWillClose: stops the run loop) so runAppGuiNative
// can delete the heap component after [NSApp run] returns (D9).
i8 _shouldTerminateImp(void* self, void* cmd, void* app) { return (i8)0; }

// The control to focus on show: prefer a TextArea (a scroll view's NSTextView),
// otherwise the first editable NSTextField. Returns nullptr if the tree has neither.
void* _firstEditableControl()
{
    void* field = nullptr;
    int n = _nHost.liveHandles.count();
    int i = 0;
    while (i < n)
    {
        void* ctrl = u2h(_nHost.liveHandles.get(i));
        if (ctrl != nullptr)
        {
            if (_isScroll(ctrl)) return msg0(ctrl, "documentView");
            if (field == nullptr
                && msgBool1(ctrl, "isKindOfClass:", cls("NSTextField")) != (i8)0
                && msgBool1(ctrl, "isEditable", nullptr) != (i8)0)
                field = ctrl;
        }
        i++;
    }
    return field;
}

// applicationDidFinishLaunching: bring the app to the foreground and make the main
// window key. A CLI-launched (non-.app-bundle) binary does NOT reliably become the
// active app when activateIgnoringOtherApps: is called synchronously around window
// creation on modern macOS; the window comes up behind the launching terminal and
// keystrokes go there, so text controls look "not editable". Doing it here - after
// the run loop has started - is the point at which activation reliably sticks, and
// makeFirstResponder puts the caret in the first editable control right away.
void _didFinishLaunchingImp(void* self, void* cmd, void* note)
{
    void* app = msg0(cls("NSApplication"), "sharedApplication");
    // activateIgnoringOtherApps: is deprecated and unreliable for a CLI-launched
    // binary on modern macOS (the launching terminal keeps focus). Go through
    // NSRunningApplication, which foregrounds a non-.app process reliably. Options
    // 3 = ActivateAllWindows | ActivateIgnoringOtherApps.
    void* self2 = msg0(cls("NSRunningApplication"), "currentApplication");
    if (self2 != nullptr) msgInt(self2, "activateWithOptions:", 3);
    msgBool(app, "activateIgnoringOtherApps:", true);
    if (_nHost.window != nullptr)
    {
        msg1(_nHost.window, "makeKeyAndOrderFront:", nullptr);
        void* fr = _firstEditableControl();
        if (fr != nullptr) msg1(_nHost.window, "makeFirstResponder:", fr);
    }
}

// A control fired its action: a slider routes by value, everything else (button /
// checkbox) routes as a click.
void _onActionImp(void* self, void* cmd, void* sender)
{
    if (!_nReady) return;
    if (msgBool1(sender, "isKindOfClass:", cls("NSSlider")) != (i8)0) { routeSlider(sender); return; }
    routeClick(sender);
}

// A menu item fired: its command id rides on the tag.
void _onMenuImp(void* self, void* cmd, void* sender)
{
    i64 tag = msgGetI64(sender, "tag");
    if (_nReady) routeMenu((int)tag);
}

// controlTextDidChange: (NSTextField edit). The notification object is the field.
void _controlTextChangedImp(void* self, void* cmd, void* note)
{
    if (_nHost.applying || !_nReady) return;
    void* field = msg0(note, "object");
    routeEdit(field);
}

// textDidChange: (NSTextView edit). The object is the text view; route through its
// enclosing scroll view (the live handle).
void _textDidChangeImp(void* self, void* cmd, void* note)
{
    if (_nHost.applying || !_nReady) return;
    void* tv = msg0(note, "object");
    void* scroll = msg0(tv, "enclosingScrollView");
    if (scroll == nullptr) scroll = tv;
    routeEdit(scroll);
}

// windowDidResize: read the content view's size (D10 Plan A struct return) and
// relayout at the new DIP client size.
void _windowResizeImp(void* self, void* cmd, void* note)
{
    if (!_nReady) return;
    void* win = msg0(note, "object");
    void* cv = msg0(win, "contentView");
    function<RectD(void*, void*)> ff = (function<RectD(void*, void*)>)__objcMsgSendPtr;
    RectD r = ff(cv, sel("frame"));
    int nw = (int)(r.w / (double)BASE_X);
    int nh = (int)(r.h / (double)BASE_Y);
    if (nw < 1) nw = 1;
    if (nh < 1) nh = 1;
    _nW = nw; _nH = nh;
    buildNativeTree();
}

// windowShouldClose: the app's close guard vetoes (dirty-save prompt) before close.
i8 _windowShouldCloseImp(void* self, void* cmd, void* sender)
{
    if (_hasCloseQuery) return _closeQuery() ? (i8)1 : (i8)0;
    return (i8)1;
}

// windowWillClose: (main window only) stop the run loop so [NSApp run] returns and
// runAppGuiNative can delete the heap component. stop: is deferred until the next
// event, so post a dummy application-defined event to wake the loop.
void _windowWillCloseImp(void* self, void* cmd, void* note)
{
    void* app = msg0(cls("NSApplication"), "sharedApplication");
    msg1(app, "stop:", nullptr);
    _postWakeEvent(app);
}

// Post a no-op NSApplicationDefined event so a pending stop: takes effect promptly
// (nextEventMatchingMask would otherwise block until real input arrives).
void _postWakeEvent(void* app)
{
    // otherEventWithType:location:modifierFlags:timestamp:windowNumber:context:
    //   subtype:data1:data2: - type/flags/windowNumber/context/subtype/data1/data2
    // are integer/pointer args (x2..), location (NSPoint) is d0/d1, timestamp is d2.
    function<void*(void*, void*, u64, double, double, u64, double, i64, void*, i16, i64, i64)> f =
        (function<void*(void*, void*, u64, double, double, u64, double, i64, void*, i16, i64, i64)>)__objcMsgSendPtr;
    void* ev = f(cls("NSEvent"), sel("otherEventWithType:location:modifierFlags:timestamp:windowNumber:context:subtype:data1:data2:"),
                 15u, 0.0, 0.0, 0u, 0.0, (i64)0, nullptr, (i16)0, (i64)0, (i64)0);
    // postEvent:atStart: takes (id event, BOOL atStart).
    if (ev != nullptr)
    {
        function<void*(void*, void*, void*, i8)> p = (function<void*(void*, void*, void*, i8)>)__objcMsgSendPtr;
        p(app, sel("postEvent:atStart:"), ev, (i8)1);
    }
}

// -- Menu bar + accelerators --------------------------------------------------
bool strContains(string s, const char* sub)
{
    return strstr(s.data(), (char*)sub) != nullptr;
}

void menuReset()
{
    _menuTop.clear();
    _menuItemTopIdx.clear();
    _menuItemLabel.clear();
    _menuItemCmd.clear();
    _menuAccel.clear();
}

int menuAddTop(string title)
{
    _menuTop.add("" + title);
    return _menuTop.count() - 1;
}

void menuAddItem(int top, string label, string accel, int cmd)
{
    _menuItemTopIdx.add(top);
    _menuItemLabel.add("" + label);
    _menuItemCmd.add(cmd);
    _menuAccel.add("" + accel);
}

void menuAddSeparator(int top)
{
    _menuItemTopIdx.add(top);
    _menuItemLabel.add("");
    _menuItemCmd.add(0);
    _menuAccel.add("");
}

// The accel key token (after the last '+'), or the whole string if there is no '+'.
string _accelKeyToken(string a)
{
    int plus = -1; int i = 0; int n = (int)a.length();
    while (i < n) { if (a.data()[i] == '+') plus = i; i++; }
    if (plus >= 0) return substring(a, plus + 1, n - plus - 1);
    return "" + a;
}

// The NSMenuItem key equivalent NSString for an accel: a lowercase letter, or the
// Unicode function-key char for F1..F12 (NSF1FunctionKey = 0xF704) built directly
// from the unichar via stringWithCharacters:length: (a hand-encoded UTF-8 PUA byte
// sequence does not round-trip through stringWithUTF8String:), else [NSString string].
void* _accelKeyEquivObj(string a)
{
    string k = _accelKeyToken(a);
    int kn = (int)k.length();
    if (kn == 1)
    {
        char c = k.data()[0];
        char[2] b;
        b[0] = (c >= 'A' && c <= 'Z') ? (char)(c + 32) : c;
        b[1] = '\0';
        return nsStr(b);
    }
    if (kn >= 2 && (k.data()[0] == 'F' || k.data()[0] == 'f'))
    {
        int num = atoi(k.data() + 1);
        if (num >= 1 && num <= 12)
        {
            u16 uc = (u16)(0xF704 + (num - 1));
            return msg2(cls("NSString"), "stringWithCharacters:length:", (void*)&uc, (void*)1);
        }
    }
    return msg0(cls("NSString"), "string");
}

// The key-equivalent modifier mask for an accel. F-keys carry no modifier of their
// own (D7); Ctrl maps to Cmd.
int _accelMask(string a)
{
    string k = _accelKeyToken(a);
    if (k.length() >= 2 && (k.data()[0] == 'F' || k.data()[0] == 'f')) return 0;
    int m = 0;
    if (strContains(a, "Ctrl"))  m = m | MOD_CMD;
    if (strContains(a, "Shift")) m = m | MOD_SHIFT;
    if (strContains(a, "Alt"))   m = m | MOD_ALT;
    return m;
}

// Realize the declared menu into the application main menu. Slot 0 is a leading app
// menu with Quit (Cmd+Q) routed through the close guard via performClose: on the
// main window; the rest mirror the declared top-level menus + items.
void buildMenuBar()
{
    void* app = msg0(cls("NSApplication"), "sharedApplication");
    void* mainMenu = msg0(msg0(cls("NSMenu"), "alloc"), "init");

    // App menu (slot 0): the system shows the process name; Quit -> performClose:.
    void* appItem = msg0(msg0(cls("NSMenuItem"), "alloc"), "init");
    msg1(mainMenu, "addItem:", appItem);
    void* appMenu = msg0(msg0(cls("NSMenu"), "alloc"), "init");
    msg1(appItem, "setSubmenu:", appMenu);
    void* quit = msg3(msg0(cls("NSMenuItem"), "alloc"), "initWithTitle:action:keyEquivalent:",
                      nsStr("Quit"), sel("performClose:"), nsStr("q"));
    msg1(quit, "setTarget:", _nHost.window);
    msgInt(quit, "setKeyEquivalentModifierMask:", (i64)MOD_CMD);
    msg1(appMenu, "addItem:", quit);

    int t = 0;
    while (t < _menuTop.count())
    {
        void* topItem = msg0(msg0(cls("NSMenuItem"), "alloc"), "init");
        msg1(topItem, "setTitle:", nsStr(_menuTop.get(t).data()));
        msg1(mainMenu, "addItem:", topItem);
        void* sub = msg1(msg0(cls("NSMenu"), "alloc"), "initWithTitle:", nsStr(_menuTop.get(t).data()));
        msg1(topItem, "setSubmenu:", sub);

        int i = 0;
        while (i < _menuItemTopIdx.count())
        {
            if (_menuItemTopIdx.get(i) == t)
            {
                if (_menuItemLabel.get(i).length() == 0)
                {
                    msg1(sub, "addItem:", msg0(cls("NSMenuItem"), "separatorItem"));
                }
                else
                {
                    string accel = _menuAccel.get(i);
                    void* keqObj = _accelKeyEquivObj(accel);
                    void* item = msg3(msg0(cls("NSMenuItem"), "alloc"), "initWithTitle:action:keyEquivalent:",
                                      _nsStrSafe(_menuItemLabel.get(i)), sel("onMenu:"), keqObj);
                    msg1(item, "setTarget:", _nHost.target);
                    msgInt(item, "setTag:", (i64)_menuItemCmd.get(i));
                    if (accel.length() > 0)
                        msgInt(item, "setKeyEquivalentModifierMask:", (i64)_accelMask(accel));
                    msg1(sub, "addItem:", item);
                }
            }
            i++;
        }
        t++;
    }

    msg1(app, "setMainMenu:", mainMenu);
}

// A menu command / accelerator fired: dispatch it to the app's handler, then pump.
void routeMenu(int id)
{
    if (id <= 0) return;
    _menuHandler(id);
    pumpNative();
}

