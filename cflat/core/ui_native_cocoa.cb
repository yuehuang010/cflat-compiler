// Modal confirm with Yes/No/Cancel. Returns 1 = Yes, 0 = No, -1 = Cancel. NSAlert
// button responses are 1000/1001/1002 in add order.
int nativeConfirm(string title, string text)
{
    void* alert = msg0(msg0(cls("NSAlert"), "alloc"), "init");
    msg1(alert, "setMessageText:", nsStr(title.data()));
    msg1(alert, "setInformativeText:", nsStr(text.data()));
    msg1(alert, "addButtonWithTitle:", nsStr("Yes"));
    msg1(alert, "addButtonWithTitle:", nsStr("No"));
    msg1(alert, "addButtonWithTitle:", nsStr("Cancel"));
    i64 r = msgGetI64(alert, "runModal");
    msg0(alert, "release");
    if (r == (i64)1000) return 1;
    if (r == (i64)1001) return 0;
    return -1;
}

void nativeInfo(string title, string text)
{
    void* alert = msg0(msg0(cls("NSAlert"), "alloc"), "init");
    msg1(alert, "setMessageText:", nsStr(title.data()));
    msg1(alert, "setInformativeText:", nsStr(text.data()));
    msg1(alert, "addButtonWithTitle:", nsStr("OK"));
    msgGetI64(alert, "runModal");
    msg0(alert, "release");
}

// -- Secondary window (Help > About) ------------------------------------------
// A genuinely separate top-level window with read-only content, sharing the app's
// run loop. It has NO window delegate, so closing it does NOT stop the app (only the
// main window's windowWillClose: does).
string _normalizeNewlines(string s)
{
    string out = "";
    int i = 0; int n = (int)s.length();
    while (i < n)
    {
        char c = s.data()[i];
        if (c == '\r')
        {
            if (i + 1 < n && s.data()[i + 1] == '\n') { i++; }   // collapse CRLF -> LF
            out = out + "\n";
        }
        else
        {
            char[2] cb; cb[0] = c; cb[1] = '\0';
            out = out + cb;
        }
        i++;
    }
    return out;
}

void showSecondaryWindow(string title, string message)
{
    string norm = _normalizeNewlines(message);
    // styleMask 7 = Titled|Closable|Miniaturizable (no resize), backing 2 = Buffered.
    void* win = msgRect3i(msg0(cls("NSWindow"), "alloc"),
                          "initWithContentRect:styleMask:backing:defer:",
                          0.0, 0.0, 360.0, 200.0, 7u, 2u, false);
    msg1(win, "setTitle:", nsStr(title.data()));
    msgBool(win, "setReleasedWhenClosed:", true);

    void* cv = msgRect(msg0(cls("CfFlippedView"), "alloc"), "initWithFrame:", 0.0, 0.0, 360.0, 200.0);
    msg1(win, "setContentView:", cv);

    void* label = msgRect(msg0(cls("NSTextField"), "alloc"), "initWithFrame:", 16.0, 16.0, 328.0, 168.0);
    msgBool(label, "setBezeled:", false);
    msgBool(label, "setDrawsBackground:", false);
    msgBool(label, "setEditable:", false);
    msgBool(label, "setSelectable:", false);
    void* cell = msg0(label, "cell");
    msgBool(cell, "setWraps:", true);
    msg1(label, "setStringValue:", nsStr(norm.data()));
    msg1(cv, "addSubview:", label);

    if (_nHost.dark)
    {
        void* ap = msg1(cls("NSAppearance"), "appearanceNamed:", nsStr("NSAppearanceNameDarkAqua"));
        msg1(win, "setAppearance:", ap);
    }
    msg1(win, "center", nullptr);
    msg1(win, "makeKeyAndOrderFront:", nullptr);
}

// -- Bring-up -----------------------------------------------------------------
// Register the objc classes the host needs (idempotent - newClass returns null for
// an already-registered name). One CfHostTarget instance carries every callback.
bool _hostClassesReg = false;
void registerHostClasses()
{
    if (_hostClassesReg) return;
    _hostClassesReg = true;

    void* fv = newClass("CfFlippedView", "NSView");
    if (fv != nullptr)
    {
        function<i8(void*, void*)> impF = _isFlippedImp;
        addMethodBool0(fv, "isFlipped", impF);
        finishClass(fv);
    }

    void* tg = newClass("CfHostTarget", "NSObject");
    if (tg != nullptr)
    {
        function<void(void*, void*, void*)> a  = _onActionImp;
        function<void(void*, void*, void*)> m  = _onMenuImp;
        function<void(void*, void*, void*)> ct = _controlTextChangedImp;
        function<void(void*, void*, void*)> td = _textDidChangeImp;
        function<void(void*, void*, void*)> wr = _windowResizeImp;
        function<void(void*, void*, void*)> ww = _windowWillCloseImp;
        function<i8(void*, void*, void*)>   wc = _windowShouldCloseImp;
        addMethod0(tg, "onAction:", a);
        addMethod0(tg, "onMenu:", m);
        addMethod0(tg, "controlTextDidChange:", ct);
        addMethod0(tg, "textDidChange:", td);
        addMethod0(tg, "windowDidResize:", wr);
        addMethod0(tg, "windowWillClose:", ww);
        addMethodBool(tg, "windowShouldClose:", wc);

        // Data-control target/action + dataSource methods (P11).
        function<void(void*, void*, void*)> lc = _onListClickImp;
        function<void(void*, void*, void*)> ld = _onListDoubleClickImp;
        function<void(void*, void*, void*)> tsg = _onTabSegmentImp;
        function<void(void*, void*, void*)> trc = _onTreeClickImp;
        function<void(void*, void*, void*)> rpb = _runPostBoxImp;
        addMethod0(tg, "onListClick:", lc);
        addMethod0(tg, "onListDoubleClick:", ld);
        addMethod0(tg, "onTabSegment:", tsg);
        addMethod0(tg, "onTreeClick:", trc);
        addMethod0(tg, "runPostBox:", rpb);
        function<i64(void*, void*, void*)> nr = _numberOfRowsImp;
        function<void*(void*, void*, void*, void*, i64)> tov = _tableObjectValueImp;
        addMethodI64_1(tg, "numberOfRowsInTableView:", nr);
        addMethodIdIdIdI64(tg, "tableView:objectValueForTableColumn:row:", tov);
        function<i64(void*, void*, void*, void*)> onc = _outlineNumChildrenImp;
        function<void*(void*, void*, void*, i64, void*)> och = _outlineChildImp;
        function<i8(void*, void*, void*, void*)> oex = _outlineExpandableImp;
        function<void*(void*, void*, void*, void*, void*)> oov = _outlineObjectValueImp;
        addMethodI64_2(tg, "outlineView:numberOfChildrenOfItem:", onc);
        addMethodIdIdI64Id(tg, "outlineView:child:ofItem:", och);
        addMethodBool2(tg, "outlineView:isItemExpandable:", oex);
        addMethodIdIdIdId(tg, "outlineView:objectValueForTableColumn:byItem:", oov);
        finishClass(tg);
    }

    // CfCanvasView: a flipped custom NSView whose drawRect: bridges to onPaint(Canvas).
    void* cvv = newClass("CfCanvasView", "NSView");
    if (cvv != nullptr)
    {
        function<i8(void*, void*)> flip = _canvasIsFlippedImp;
        addMethodBool0(cvv, "isFlipped", flip);
        function<void(void*, void*, double, double, double, double)> dr = _canvasDrawRectImp;
        __classAddMethod(cvv, sel("drawRect:"), (void*)dr, "v@:{{CGRect={{CGPoint=dd}}{{CGSize=dd}}}}");
        finishClass(cvv);
    }

    void* ad = newClass("CfHostAppDelegate", "NSObject");
    if (ad != nullptr)
    {
        function<i8(void*, void*, void*)> t = _shouldTerminateImp;
        addMethodBool(ad, "applicationShouldTerminateAfterLastWindowClosed:", t);
        function<void(void*, void*, void*)> dfl = _didFinishLaunchingImp;
        addMethod0(ad, "applicationDidFinishLaunching:", dfl);
        finishClass(ad);
    }
}

// Register the classes + create the top-level window. `show` controls whether it is
// made visible (the self-test creates it hidden). Sets up the host globals.
void* createNativeWindow(const char* title, bool show)
{
    if (!cocoaInit()) { printf("failed to load AppKit\n"); return nullptr; }
    void* app = msg0(cls("NSApplication"), "sharedApplication");
    msgInt(app, "setActivationPolicy:", 0);   // NSApplicationActivationPolicyRegular

    registerHostClasses();
    void* del = msg0(msg0(cls("CfHostAppDelegate"), "alloc"), "init");
    msg1(app, "setDelegate:", del);
    _nHost.appDelegate = del;

    // One shared target: control action, menu action, window delegate, data sources.
    _nHost.target = msg0(msg0(cls("CfHostTarget"), "alloc"), "init");

    // ctx.post() marshaling: run a boxed closure on the main thread via the target's
    // runPostBox: (performSelectorOnMainThread). Same opaque-u64 contract as Win32.
    _nCtx.bindPost((u64)_nHost.target, _cocoaPostEnqueue);
    _nCtx.bindThreadId(_cocoaCurTid(), _cocoaCurTid);

    // Content 760x560 pt -> _nW=95, _nH=21 DIP. styleMask 15 = Titled|Closable|
    // Miniaturizable|Resizable, backing 2 = Buffered.
    void* win = msgRect3i(msg0(cls("NSWindow"), "alloc"),
                          "initWithContentRect:styleMask:backing:defer:",
                          0.0, 0.0, 760.0, 560.0, 15u, 2u, false);
    msg1(win, "setTitle:", nsStr((char*)title));
    msgBool(win, "setReleasedWhenClosed:", false);
    _nHost.window = win;
    _nW = 95; _nH = 21;

    void* cv = msgRect(msg0(cls("CfFlippedView"), "alloc"), "initWithFrame:", 0.0, 0.0, 760.0, 560.0);
    msg1(win, "setContentView:", cv);
    _nHost.contentView = cv;

    msg1(win, "setDelegate:", _nHost.target);
    buildMenuBar();

    if (show)
    {
        msg1(win, "center", nullptr);
        msg1(win, "makeKeyAndOrderFront:", nullptr);
        msgBool(app, "activateIgnoringOtherApps:", true);
    }
    return win;
}

// Free the old tree (if any) and render + reconcile-to-native a fresh one at the
// current client size. Controls are reused by key path.
void buildNativeTree()
{
    if (_nReady) { deleteTree(_nTree); _nReady = false; }
    _nTree = _nApp.render(&_nCtx);
    layoutRoot(_nTree, 0, 0, _nW);
    _nHost.applyTree(_nTree, &_nCtx);
    _nReady = true;
}

// Register the classes, create + show the window, and run the AppKit event loop
// until the main window closes (windowWillClose: -> [NSApp stop:]).
//
// The component MUST be heap-allocated (`new`): the host stashes it in `_nApp` and
// `delete`s it after the loop, so it has to outlive this call and be a heap object.
int runAppGuiNative(Component app, const char* title)
{
    _nApp = app;
    if (!cocoaInit()) { printf("failed to load AppKit\n"); return 1; }
    void* pool = poolPush();
    void* win = createNativeWindow(title, true);
    if (win == nullptr) { poolPop(pool); return 1; }
    if (!_nReady) buildNativeTree();

    void* nsapp = msg0(cls("NSApplication"), "sharedApplication");
    msg0(nsapp, "run");

    poolPop(pool);
    delete _nApp;
    _nApp = nullptr;
    return 0;
}

// Fully release all global host + context state - for the headless self-tests, so
// --heap-audit sees no cflat residue (globals are not destructed at process exit,
// and list/dictionary clear() keeps its capacity, so each backing is moved into a
// scoped local whose destructor frees it). ObjC objects live on the objc heap (not
// cflat malloc), so closing the window is enough for the audit.
void nativeTeardownForTest()
{
    if (_nReady) { deleteTree(_nTree); _nReady = false; }
    if (_nApp != nullptr) { delete _nApp; _nApp = nullptr; }
    if (_nHost.window != nullptr) { msg0(_nHost.window, "close"); _nHost.window = nullptr; }
    _nHost.contentView = nullptr;
    _nHost.target = nullptr;
    _nHost.appDelegate = nullptr;
    // Free any remaining boxed callbacks + registered context menus (host-owned).
    { int i = 0; while (i < _nHost.listBoxPtrs.count()) { u64 b = _nHost.listBoxPtrs.get(i); if (b != 0u) __uiFreeListRowBox(b); i++; } }
    { int i = 0; while (i < _nHost.treeBoxPtrs.count()) { u64 b = _nHost.treeBoxPtrs.get(i); if (b != 0u) __uiFreeTreeBox(b); i++; } }
    { int i = 0; while (i < _nHost.canvasBoxes.count()) { u64 b = _nHost.canvasBoxes.get(i); if (b != 0u) __uiFreeCanvasBox(b); i++; } }
    { int i = 0; while (i < _nHost.ctxMenus.count()) { u64 b = _nHost.ctxMenus.get(i); if (b != 0u) __uiFreeContextMenu(b); i++; } }
    { dictionary<string, u64> d = move _nCtx.nativeByKey; }
    { list<string> a1 = move _nHost.liveKeys; }
    { list<u64>    a2 = move _nHost.liveHandles; }
    { list<u64>    b1 = move _nHost.listBoxHandles; }
    { list<u64>    b2 = move _nHost.listBoxPtrs; }
    { list<u64>    b3 = move _nHost.listSelHandles; }
    { list<int>    b4 = move _nHost.listSelRows; }
    { list<u64>    b5 = move _nHost.listRowCounts; }
    { list<int>    b6 = move _nHost.listRowCountV; }
    { list<u64>    b7 = move _nHost.treeBoxHandles; }
    { list<u64>    b8 = move _nHost.treeBoxPtrs; }
    { list<string> b9 = move _nHost.ctxKeys; }
    { list<u64>    b10 = move _nHost.ctxMenus; }
    { list<u64>    b11 = move _nHost.canvasHandles; }
    { list<u64>    b12 = move _nHost.canvasBoxes; }
    { list<u64>    b13 = move _nHost.imgHandles; }
    { list<u64>    b14 = move _nHost.imgLastPixels; }
    { list<string> a3 = move _menuTop; }
    { list<int>    a4 = move _menuItemTopIdx; }
    { list<string> a5 = move _menuItemLabel; }
    { list<int>    a6 = move _menuItemCmd; }
    { list<string> a7 = move _menuAccel; }
    { Lambda<void(int)> a8 = move _menuHandler; }
    { Lambda<bool()>    a9 = move _closeQuery; }
    _hasCloseQuery = false;
    _nCtx.blur();
}
