// cocoa_native_host.cb - a native macOS (AppKit) host that drives REAL OS controls.
//
// This is the macOS counterpart of win32_native_host.cb: the NativeHost output
// stage of the CFlat UI framework (see ui_native.cb). The reconciled Element tree's
// stable key paths map to real AppKit controls (NSButton / NSTextField / NSSlider /
// NSProgressIndicator / NSBox / NSTextView), and the host creates / updates /
// destroys those controls to match the tree. AppKit paints them, handles IME +
// accessibility, and owns focus / Tab. The app-facing model is UNCHANGED; an app
// that renders to the Win32 host renders here too - it just imports this host
// (via native_host.cb) instead.
//
// It drives AppKit through the dlopen/objc_msgSend bridge in cocoa.cb (no SDK, no
// Xcode, no -framework linking). Coordinates use a FLIPPED content view so every
// frame is top-left like Win32; DIP->points is x*BASE_X, y*BASE_Y with NO DPI
// scaling (Cocoa points are already density-independent, so the Win32 WM_DPICHANGED
// machinery is dropped here).
//
// This file has no main(); an app imports it and calls runAppGuiNative().
import "ui_native.cb";
import "cocoa.cb";

// Per-DIP base points. Layout math in ui.cb is unit-blind integers; a native host
// reads them as DIPs. One layout column ~8pt, one row ~26pt so native controls get
// sensible heights. Unlike Win32, there is no DPI multiplier (Cocoa points scale).
const int BASE_X = 8;
const int BASE_Y = 26;

// NSEventModifierFlag masks (accelerators). Ctrl maps to Cmd per mac convention.
const int MOD_CMD   = 0x100000;   // 1<<20  NSEventModifierFlagCommand
const int MOD_SHIFT = 0x20000;    // 1<<17  NSEventModifierFlagShift
const int MOD_ALT   = 0x80000;    // 1<<19  NSEventModifierFlagOption

// A 4-double aggregate matching NSRect. On arm64 an HFA of 4 doubles is returned in
// d0-d3; the M1 probe (cocoa_probe --selftest) confirmed the cflat function<> ABI
// matches, so -[NSView frame] is read this way for the resize path (D10 Plan A).
struct RectD
{
    double x = 0.0;
    double y = 0.0;
    double w = 0.0;
    double h = 0.0;
};

// -- The running app + its tree + context, reached from the free-function IMPs
// (a plain objc callback cannot capture `this`). Single window / single thread, so
// these host globals are the right tool; they live in the HOST file, not ui.cb.
CocoaHost _nHost  = default;
Component _nApp   = default;
Element   _nTree  = default;
UiContext _nCtx   = default;
bool      _nReady = false;
int       _nW     = 95;   // client size in DIP units (760pt / 8)
int       _nH     = 21;   // 560pt / 26

// -- Declarative menu bar -----------------------------------------------------
// Same surface + globals as the Win32 host. Parallel lists (not a struct with a
// closure) keep ownership simple; an item's app command id is carried on the
// NSMenuItem via setTag:. The app provides ONE dispatch closure (setMenuHandler).
list<string>          _menuTop        = default;   // top-level menu titles
list<int>             _menuItemTopIdx = default;   // per item: owning top index
list<string>          _menuItemLabel  = default;   // per item: label
list<int>             _menuItemCmd    = default;   // per item: app command id (0 = separator)
list<string>          _menuAccel      = default;   // per item: accel text (e.g. "Ctrl+S")
Lambda<void(int)>     _menuHandler    = default;   // app's command dispatcher

// Optional close guard: the app returns true to allow the window to close, false to
// veto. Default (unset) always allows.
Lambda<bool()>        _closeQuery     = default;
bool                  _hasCloseQuery  = false;

void setMenuHandler(Lambda<void(int)> h) { _menuHandler = h; }
void setCloseQuery(Lambda<bool()> q) { _closeQuery = q; _hasCloseQuery = true; }

int hostWidth()  { return _nW; }
int hostHeight() { return _nH; }

void* u2h(u64 u) { return (void*)u; }

// A node kind that maps to an OS control (vs a pure layout container). Same set as
// the Win32 host.
bool nativeMappable(int kind)
{
    return kind == ELEM_BUTTON || kind == ELEM_TEXT || kind == ELEM_TEXTINPUT
        || kind == ELEM_CHECKBOX || kind == ELEM_PROGRESS || kind == ELEM_SLIDER
        || kind == ELEM_BOX || kind == ELEM_TEXTAREA || kind == ELEM_STATUSBAR
        || kind == ELEM_RADIO || kind == ELEM_COMBO || kind == ELEM_LIST
        || kind == ELEM_TABS || kind == ELEM_TREE
        || kind == ELEM_IMAGE || kind == ELEM_GROUPBOX || kind == ELEM_CANVAS;
}

// The concrete tooltip text a mappable node carries ("" = none), read via downcast
// (mirror of the Win32 host); every mappable class exposes a `tooltip` field.
string tooltipOf(Element node)
{
    int k = node.kind();
    if (k == ELEM_BUTTON)    { Button* b = node as Button; return "" + b.tooltip; }
    if (k == ELEM_TEXT)      { Text* t = node as Text; return "" + t.tooltip; }
    if (k == ELEM_TEXTINPUT) { TextInput* t = node as TextInput; return "" + t.tooltip; }
    if (k == ELEM_CHECKBOX)  { Checkbox* c = node as Checkbox; return "" + c.tooltip; }
    if (k == ELEM_PROGRESS)  { ProgressBar* p = node as ProgressBar; return "" + p.tooltip; }
    if (k == ELEM_SLIDER)    { Slider* s = node as Slider; return "" + s.tooltip; }
    if (k == ELEM_TEXTAREA)  { TextArea* a = node as TextArea; return "" + a.tooltip; }
    if (k == ELEM_RADIO)     { RadioButton* r = node as RadioButton; return "" + r.tooltip; }
    if (k == ELEM_COMBO)     { ComboBox* c = node as ComboBox; return "" + c.tooltip; }
    if (k == ELEM_LIST)      { ListView* l = node as ListView; return "" + l.tooltip; }
    if (k == ELEM_TABS)      { TabControl* t = node as TabControl; return "" + t.tooltip; }
    if (k == ELEM_TREE)      { TreeView* t = node as TreeView; return "" + t.tooltip; }
    if (k == ELEM_IMAGE)     { Image* im = node as Image; return "" + im.tooltip; }
    if (k == ELEM_GROUPBOX)  { GroupBox* g = node as GroupBox; return "" + g.tooltip; }
    if (k == ELEM_CANVAS)    { CanvasView* c = node as CanvasView; return "" + c.tooltip; }
    return "";
}

// An NSString for `s`, safe for an empty cflat string (whose data() can be null):
// an empty value maps to [NSString string] (@"") rather than a nil arg.
void* _nsStrSafe(string s)
{
    if (s.length() == 0) return msg0(cls("NSString"), "string");
    return nsStr(s.data());
}

// True if `ctrl` is an NSScrollView (a TextArea's handle is its scroll view; text
// ops resolve the documentView first).
bool _isScroll(void* ctrl)
{
    return msgBool1(ctrl, "isKindOfClass:", cls("NSScrollView")) != (i8)0;
}

// -- CocoaHost: the NativeHost implementation ---------------------------------
// Owns the top-level window, the flipped content view, the one shared callback
// target (CfHostTarget), the reentrancy guard, and the per-frame live-control
// bookkeeping (parallel key/handle lists) used to route events and destroy controls
// that fell out of the tree.
class CocoaHost : NativeHost
{
    void* window      = nullptr;
    void* contentView = nullptr;   // the flipped CfFlippedView
    void* target      = nullptr;   // shared CfHostTarget (control + menu + window delegate)
    void* appDelegate = nullptr;
    bool  applying    = false;     // guard: swallow self-inflicted change notifications
    bool  dark        = false;     // last applied theme was dark
    list<string> liveKeys    = default;   // keys with a live control this frame
    list<u64>    liveHandles = default;   // parallel handles (NSView* as u64)

    // ── P11 data/visual-control bookkeeping (mirror of the Win32 host lists) ──────
    // ListView rowText boxes: parallel table-view handle -> ListRowBox* (as u64), plus
    // the controlled selection (NSTableView owns no owner-data virtualization the way
    // Win32 LVS_OWNERDATA does, but the boxed rowText is still the single item source).
    list<u64>    listBoxHandles = default;
    list<u64>    listBoxPtrs    = default;
    list<u64>    listSelHandles = default;   // parallel handle -> selected row
    list<int>    listSelRows    = default;
    list<u64>    listRowCounts  = default;   // parallel handle -> virtual row count
    list<int>    listRowCountV  = default;
    // TreeView node-source boxes: parallel outline-view handle -> TreeBox* (as u64).
    list<u64>    treeBoxHandles = default;
    list<u64>    treeBoxPtrs    = default;
    // Per-key context menus: parallel key path -> ContextMenu* (as u64), host-owned.
    list<string> ctxKeys        = default;
    list<u64>    ctxMenus        = default;
    // CanvasView paint boxes: parallel view handle -> CanvasBox* (as u64).
    list<u64>    canvasHandles   = default;
    list<u64>    canvasBoxes     = default;
    // Image last-uploaded pixel pointer per handle (skip redundant NSImage rebuilds).
    list<u64>    imgHandles      = default;
    list<u64>    imgLastPixels   = default;

    // NativeHost: create a control of `elemKind` under the flipped content view.
    // `key` is the node's key path (kept by the caller in the shadow map). Returns
    // the control (NSView*) as a u64; a TextArea returns its enclosing scroll view.
    u64 createControl(int elemKind, u64 parentHandle, string key)
    {
        void* ctrl = nullptr;
        if (elemKind == ELEM_BUTTON)
        {
            ctrl = msgRect(msg0(cls("NSButton"), "alloc"), "initWithFrame:", 0.0, 0.0, 10.0, 10.0);
            msgInt(ctrl, "setBezelStyle:", 1);            // NSBezelStyleRounded
            msg1(ctrl, "setTarget:", this.target);
            msg1(ctrl, "setAction:", sel("onAction:"));
        }
        else if (elemKind == ELEM_CHECKBOX)
        {
            ctrl = msgRect(msg0(cls("NSButton"), "alloc"), "initWithFrame:", 0.0, 0.0, 10.0, 10.0);
            msgInt(ctrl, "setButtonType:", 3);            // NSButtonTypeSwitch
            msg1(ctrl, "setTarget:", this.target);
            msg1(ctrl, "setAction:", sel("onAction:"));
        }
        else if (elemKind == ELEM_TEXTINPUT)
        {
            ctrl = msgRect(msg0(cls("NSTextField"), "alloc"), "initWithFrame:", 0.0, 0.0, 10.0, 10.0);
            msg1(ctrl, "setDelegate:", this.target);
        }
        else if (elemKind == ELEM_TEXT)
        {
            ctrl = msgRect(msg0(cls("NSTextField"), "alloc"), "initWithFrame:", 0.0, 0.0, 10.0, 10.0);
            msgBool(ctrl, "setBezeled:", false);
            msgBool(ctrl, "setDrawsBackground:", false);
            msgBool(ctrl, "setEditable:", false);
            msgBool(ctrl, "setSelectable:", false);
        }
        else if (elemKind == ELEM_BOX)
        {
            ctrl = msgRect(msg0(cls("NSBox"), "alloc"), "initWithFrame:", 0.0, 0.0, 10.0, 10.0);
            msgInt(ctrl, "setTitlePosition:", 0);         // NSNoTitle
        }
        else if (elemKind == ELEM_PROGRESS)
        {
            ctrl = msgRect(msg0(cls("NSProgressIndicator"), "alloc"), "initWithFrame:", 0.0, 0.0, 10.0, 10.0);
            msgInt(ctrl, "setStyle:", 0);                 // NSProgressIndicatorStyleBar
            msgBool(ctrl, "setIndeterminate:", false);
            msgSetDouble(ctrl, "setMinValue:", 0.0);
        }
        else if (elemKind == ELEM_SLIDER)
        {
            ctrl = msgRect(msg0(cls("NSSlider"), "alloc"), "initWithFrame:", 0.0, 0.0, 10.0, 10.0);
            msgBool(ctrl, "setContinuous:", true);
            msg1(ctrl, "setTarget:", this.target);
            msg1(ctrl, "setAction:", sel("onAction:"));
        }
        else if (elemKind == ELEM_TEXTAREA)
        {
            // NSTextView inside an NSScrollView; the u64 handle IS the scroll view
            // (framing / destroy). Text/selection ops resolve documentView first.
            void* scroll = msgRect(msg0(cls("NSScrollView"), "alloc"), "initWithFrame:", 0.0, 0.0, 10.0, 10.0);
            msgBool(scroll, "setHasVerticalScroller:", true);
            msgInt(scroll, "setBorderType:", 2);          // NSBezelBorder
            void* tv = msgRect(msg0(cls("NSTextView"), "alloc"), "initWithFrame:", 0.0, 0.0, 10.0, 10.0);
            msgBool(tv, "setEditable:", true);
            msgBool(tv, "setSelectable:", true);
            msgBool(tv, "setRichText:", false);
            // Make the text view fill (and track) the scroll view's content width, and
            // grow vertically with the text. Without this, initWithFrame leaves a ~10pt
            // text container that never resizes, so only one character column is visible
            // even though the buffer holds the full text. This is Apple's canonical
            // NSScrollView + NSTextView setup. NSViewWidthSizable = 1<<1 = 2.
            double big = 10000000.0;
            msgSize(tv, "setMinSize:", 0.0, 0.0);
            msgSize(tv, "setMaxSize:", big, big);
            msgBool(tv, "setVerticallyResizable:", true);
            msgBool(tv, "setHorizontallyResizable:", false);
            msgInt(tv, "setAutoresizingMask:", 2);
            void* tc = msg0(tv, "textContainer");
            if (tc != nullptr)
            {
                msgBool(tc, "setWidthTracksTextView:", true);
                msgSize(tc, "setContainerSize:", big, big);
            }
            msg1(tv, "setDelegate:", this.target);
            msg1(scroll, "setDocumentView:", tv);
            ctrl = scroll;
        }
        else if (elemKind == ELEM_STATUSBAR)
        {
            // A read-only text strip stands in for the status bar (P7); macOS has no
            // NSStatusBar equivalent for an in-window strip, so we use an NSTextField.
            ctrl = msgRect(msg0(cls("NSTextField"), "alloc"), "initWithFrame:", 0.0, 0.0, 10.0, 10.0);
            msgBool(ctrl, "setBezeled:", false);
            msgBool(ctrl, "setDrawsBackground:", false);
            msgBool(ctrl, "setEditable:", false);
            msgBool(ctrl, "setSelectable:", false);
        }
        else if (elemKind == ELEM_RADIO)
        {
            // NSButtonTypeRadio: AppKit auto-groups radios that share the same
            // target+action within a superview, matching the RadioGroup semantics.
            ctrl = msgRect(msg0(cls("NSButton"), "alloc"), "initWithFrame:", 0.0, 0.0, 10.0, 10.0);
            msgInt(ctrl, "setButtonType:", 4);            // NSButtonTypeRadio
            msg1(ctrl, "setTarget:", this.target);
            msg1(ctrl, "setAction:", sel("onAction:"));
        }
        else if (elemKind == ELEM_COMBO)
        {
            // NSPopUpButton (pull-down NO = a select-one popup). Items are populated in
            // _syncCombo; selection routes onChange through onAction:.
            ctrl = msgRect(msg0(cls("NSPopUpButton"), "alloc"), "initWithFrame:", 0.0, 0.0, 10.0, 10.0);
            msgBool(ctrl, "setPullsDown:", false);
            msg1(ctrl, "setTarget:", this.target);
            msg1(ctrl, "setAction:", sel("onAction:"));
        }
        else if (elemKind == ELEM_LIST)
        {
            // NSScrollView + NSTableView. The scroll view is the live handle (framing /
            // destroy); the table's dataSource is the shared target, which queries the
            // boxed rowText through the setListOp protocol (naturally virtualized).
            void* scroll = msgRect(msg0(cls("NSScrollView"), "alloc"), "initWithFrame:", 0.0, 0.0, 10.0, 10.0);
            msgBool(scroll, "setHasVerticalScroller:", true);
            msgInt(scroll, "setBorderType:", 2);          // NSBezelBorder
            void* table = msgRect(msg0(cls("NSTableView"), "alloc"), "initWithFrame:", 0.0, 0.0, 10.0, 10.0);
            msgInt(table, "setUsesAlternatingRowBackgroundColors:", 1);
            msg1(table, "setDataSource:", this.target);
            msg1(table, "setDelegate:", this.target);
            msg1(table, "setTarget:", this.target);
            msg1(table, "setAction:", sel("onListClick:"));
            msg1(table, "setDoubleAction:", sel("onListDoubleClick:"));
            msg1(scroll, "setDocumentView:", table);
            ctrl = scroll;
        }
        else if (elemKind == ELEM_TABS)
        {
            // A tab strip = an NSSegmentedControl; the active pane's controls map as
            // siblings (lazy inactive panes) exactly like the Win32 header + panes.
            ctrl = msgRect(msg0(cls("NSSegmentedControl"), "alloc"), "initWithFrame:", 0.0, 0.0, 10.0, 10.0);
            msgInt(ctrl, "setSegmentStyle:", 8);          // NSSegmentStyleTexturedSquare
            msg1(ctrl, "setTarget:", this.target);
            msg1(ctrl, "setAction:", sel("onTabSegment:"));
        }
        else if (elemKind == ELEM_TREE)
        {
            // NSScrollView + NSOutlineView. Expand-on-demand rides the outline's
            // dataSource (numberOfChildren / child:ofItem: / isItemExpandable), which
            // resolves the boxed TreeBox callbacks keyed by nodeId.
            void* scroll = msgRect(msg0(cls("NSScrollView"), "alloc"), "initWithFrame:", 0.0, 0.0, 10.0, 10.0);
            msgBool(scroll, "setHasVerticalScroller:", true);
            msgInt(scroll, "setBorderType:", 2);          // NSBezelBorder
            void* outline = msgRect(msg0(cls("NSOutlineView"), "alloc"), "initWithFrame:", 0.0, 0.0, 10.0, 10.0);
            void* col = msg0(msg0(cls("NSTableColumn"), "alloc"), "initWithIdentifier:");
            msg1(outline, "addTableColumn:", col);
            msg1(outline, "setOutlineTableColumn:", col);
            msg1(outline, "setDataSource:", this.target);
            msg1(outline, "setDelegate:", this.target);
            msg1(outline, "setTarget:", this.target);
            msg1(outline, "setAction:", sel("onTreeClick:"));
            msg1(scroll, "setDocumentView:", outline);
            ctrl = scroll;
        }
        else if (elemKind == ELEM_IMAGE)
        {
            // NSImageView; setImageData uploads an NSImage from the borrowed BGRA bytes.
            ctrl = msgRect(msg0(cls("NSImageView"), "alloc"), "initWithFrame:", 0.0, 0.0, 10.0, 10.0);
            msgInt(ctrl, "setImageScaling:", 0);          // NSImageScaleProportionallyDown
        }
        else if (elemKind == ELEM_GROUPBOX)
        {
            // A titled NSBox; children position as siblings inside the frame (like Win32).
            ctrl = msgRect(msg0(cls("NSBox"), "alloc"), "initWithFrame:", 0.0, 0.0, 10.0, 10.0);
            msgInt(ctrl, "setTitlePosition:", 2);         // NSAtTop
        }
        else if (elemKind == ELEM_CANVAS)
        {
            // A custom CfCanvasView whose drawRect: bridges to the boxed onPaint(Canvas)
            // via a CoreGraphics-backed Canvas (CocoaCanvas). The box is stashed in
            // setListOp-style bookkeeping and reached through the view's key path.
            ctrl = msgRect(msg0(cls("CfCanvasView"), "alloc"), "initWithFrame:", 0.0, 0.0, 10.0, 10.0);
        }
        else
        {
            ctrl = msgRect(msg0(cls("NSTextField"), "alloc"), "initWithFrame:", 0.0, 0.0, 10.0, 10.0);
        }

        if (this.contentView != nullptr && ctrl != nullptr)
            msg1(this.contentView, "addSubview:", ctrl);
        return (u64)ctrl;
    }

    void destroyControl(u64 h)
    {
        if (h == 0u) return;
        this._freeListBox(h);    // no-op unless h is a list with a boxed rowText
        this._freeTreeBox(h);    // no-op unless h is a tree with a boxed node source
        this._freeCanvasBox(h);  // no-op unless h is a canvas with a boxed painter
        void* ctrl = u2h(h);
        msg0(ctrl, "removeFromSuperview");   // drops the superview's retain
        msg0(ctrl, "release");               // drops our alloc/init retain -> dealloc
    }

    // Position + size in points (flipped view, so no y-flip). DIP -> points by
    // BASE_X / BASE_Y; the M3 resize path feeds the client size back in DIPs.
    void setFrame(u64 h, Rect frameDip)
    {
        void* ctrl = u2h(h);
        msgRect(ctrl, "setFrame:",
                (double)(frameDip.x * BASE_X), (double)(frameDip.y * BASE_Y),
                (double)(frameDip.w * BASE_X), (double)(frameDip.h * BASE_Y));
    }

    // Only push text when it actually differs, so an NSTextField does not reset its
    // caret / selection on every re-render (mirror win32:181). Class-sniffed: a
    // scroll view (TextArea) writes its text view; an NSButton writes its title; an
    // NSTextField writes its string value.
    void setText(u64 h, const char* s)
    {
        void* ctrl = u2h(h);
        if (_isScroll(ctrl))
        {
            void* tv = msg0(ctrl, "documentView");
            char* cur = cStr(msg0(tv, "string"));
            if (cur != nullptr && strcmp(cur, (char*)s) == 0) return;
            msg1(tv, "setString:", nsStr((char*)s));
            return;
        }
        if (msgBool1(ctrl, "isKindOfClass:", cls("NSButton")) != (i8)0)
        {
            char* cur = cStr(msg0(ctrl, "title"));
            if (cur != nullptr && strcmp(cur, (char*)s) == 0) return;
            msg1(ctrl, "setTitle:", nsStr((char*)s));
            return;
        }
        char* cur = cStr(msg0(ctrl, "stringValue"));
        if (cur != nullptr && strcmp(cur, (char*)s) == 0) return;
        msg1(ctrl, "setStringValue:", nsStr((char*)s));
    }

    void setBoolProp(u64 h, int prop, bool v)
    {
        void* ctrl = u2h(h);
        if (prop == PROP_CHECKED)
        {
            msgInt(ctrl, "setState:", v ? (i64)1 : (i64)0);   // NSControlStateValueOn = 1
        }
        else if (prop == PROP_ENABLED)
        {
            // Only touch editability when it actually changes. applyTree runs on every
            // keystroke (edit -> invalidate -> reconcile), and re-sending setEditable:
            // / setEnabled: to a control that is MID-EDIT ends its input session and
            // resigns first responder - the "type one char then nothing" bug. Mirror
            // the differ-guard in setText.
            if (_isScroll(ctrl))
            {
                void* tv = msg0(ctrl, "documentView");
                if ((msgBool1(tv, "isEditable", nullptr) != (i8)0) != v)
                {
                    msgBool(tv, "setEditable:", v);
                    msgBool(tv, "setSelectable:", v);
                }
            }
            else if ((msgBool1(ctrl, "isEnabled", nullptr) != (i8)0) != v)
            {
                msgBool(ctrl, "setEnabled:", v);
            }
        }
        else if (prop == PROP_VISIBLE)
        {
            msgBool(ctrl, "setHidden:", !v);
        }
    }

    // Route a value/max set to the right control by class (keeps the seam
    // property-based: the host, not ui.cb, knows progress vs slider). Both take
    // doubles; the DIP int value is promoted.
    void setIntProp(u64 h, int prop, int v)
    {
        void* ctrl = u2h(h);
        bool isProg = msgBool1(ctrl, "isKindOfClass:", cls("NSProgressIndicator")) != (i8)0;
        bool isSlider = msgBool1(ctrl, "isKindOfClass:", cls("NSSlider")) != (i8)0;
        if (prop == PROP_VALUE)
        {
            if (isProg || isSlider) msgSetDouble(ctrl, "setDoubleValue:", (double)v);
        }
        else if (prop == PROP_MAX)
        {
            if (isProg || isSlider) msgSetDouble(ctrl, "setMaxValue:", (double)v);
        }
    }

    // ── box + per-control state bookkeeping (mirror of the Win32 host lists) ──────
    // The NSTableView / NSOutlineView backing the list/tree handle `h` (its scroll
    // view's documentView), or the handle itself as a fallback.
    void* _tableOf(u64 h)
    {
        void* ctrl = u2h(h);
        if (_isScroll(ctrl)) return msg0(ctrl, "documentView");
        return ctrl;
    }

    void _setListBox(u64 h, u64 box)
    {
        void* table = this._tableOf(h);
        int i = 0;
        while (i < this.listBoxHandles.count())
        {
            if (this.listBoxHandles.get(i) == (u64)table)
            {
                u64 old = this.listBoxPtrs.get(i);
                if (old != 0u && old != box) __uiFreeListRowBox(old);
                this.listBoxPtrs.set(i, box);
                return;
            }
            i++;
        }
        this.listBoxHandles.add((u64)table);
        this.listBoxPtrs.add(box);
    }

    u64 _listBoxForTable(u64 tablePtr)
    {
        int i = 0;
        while (i < this.listBoxHandles.count())
        {
            if (this.listBoxHandles.get(i) == tablePtr) { u64 v = this.listBoxPtrs.get(i); return v; }
            i++;
        }
        return 0u;
    }

    void _setListRows(u64 h, int rows)
    {
        void* table = this._tableOf(h);
        int i = 0;
        while (i < this.listRowCounts.count())
        {
            if (this.listRowCounts.get(i) == (u64)table) { this.listRowCountV.set(i, rows); return; }
            i++;
        }
        this.listRowCounts.add((u64)table); this.listRowCountV.add(rows);
    }

    int _listRowsForTable(u64 tablePtr)
    {
        int i = 0;
        while (i < this.listRowCounts.count())
        {
            if (this.listRowCounts.get(i) == tablePtr) { int v = this.listRowCountV.get(i); return v; }
            i++;
        }
        return 0;
    }

    int _listRows(u64 h) { void* t = this._tableOf(h); return this._listRowsForTable((u64)t); }

    void _setListSel(u64 h, int row)
    {
        void* table = this._tableOf(h);
        int i = 0;
        while (i < this.listSelHandles.count())
        {
            if (this.listSelHandles.get(i) == (u64)table) { this.listSelRows.set(i, row); return; }
            i++;
        }
        this.listSelHandles.add((u64)table); this.listSelRows.add(row);
    }

    int _listSel(u64 h)
    {
        void* table = this._tableOf(h);
        int i = 0;
        while (i < this.listSelHandles.count())
        {
            if (this.listSelHandles.get(i) == (u64)table) { int v = this.listSelRows.get(i); return v; }
            i++;
        }
        return 0 - 1;
    }

    void _freeListBox(u64 h)
    {
        void* table = this._tableOf(h);
        int i = 0;
        while (i < this.listBoxHandles.count())
        {
            if (this.listBoxHandles.get(i) == (u64)table)
            {
                u64 old = this.listBoxPtrs.get(i);
                if (old != 0u) __uiFreeListRowBox(old);
                this.listBoxHandles.removeAt(i); this.listBoxPtrs.removeAt(i);
                return;
            }
            i++;
        }
    }

    void _setTreeBox(u64 h, u64 box)
    {
        void* outline = this._tableOf(h);
        int i = 0;
        while (i < this.treeBoxHandles.count())
        {
            if (this.treeBoxHandles.get(i) == (u64)outline)
            {
                u64 old = this.treeBoxPtrs.get(i);
                if (old != 0u && old != box) __uiFreeTreeBox(old);
                this.treeBoxPtrs.set(i, box);
                return;
            }
            i++;
        }
        this.treeBoxHandles.add((u64)outline);
        this.treeBoxPtrs.add(box);
    }

    u64 _treeBoxForOutline(u64 outlinePtr)
    {
        int i = 0;
        while (i < this.treeBoxHandles.count())
        {
            if (this.treeBoxHandles.get(i) == outlinePtr) { u64 v = this.treeBoxPtrs.get(i); return v; }
            i++;
        }
        return 0u;
    }

    u64 _treeBox(u64 h) { void* o = this._tableOf(h); return this._treeBoxForOutline((u64)o); }

    void _freeTreeBox(u64 h)
    {
        void* outline = this._tableOf(h);
        int i = 0;
        while (i < this.treeBoxHandles.count())
        {
            if (this.treeBoxHandles.get(i) == (u64)outline)
            {
                u64 old = this.treeBoxPtrs.get(i);
                if (old != 0u) __uiFreeTreeBox(old);
                this.treeBoxHandles.removeAt(i); this.treeBoxPtrs.removeAt(i);
                return;
            }
            i++;
        }
    }

    void _setCanvasBox(u64 h, u64 box)
    {
        int i = 0;
        while (i < this.canvasHandles.count())
        {
            if (this.canvasHandles.get(i) == h)
            {
                u64 old = this.canvasBoxes.get(i);
                if (old != 0u && old != box) __uiFreeCanvasBox(old);
                this.canvasBoxes.set(i, box); return;
            }
            i++;
        }
        this.canvasHandles.add(h); this.canvasBoxes.add(box);
    }

    u64 _canvasBoxFor(u64 h)
    {
        int i = 0;
        while (i < this.canvasHandles.count())
        {
            if (this.canvasHandles.get(i) == h) { u64 v = this.canvasBoxes.get(i); return v; }
            i++;
        }
        return 0u;
    }

    void _freeCanvasBox(u64 h)
    {
        int i = 0;
        while (i < this.canvasHandles.count())
        {
            if (this.canvasHandles.get(i) == h)
            {
                u64 old = this.canvasBoxes.get(i);
                if (old != 0u) __uiFreeCanvasBox(old);
                this.canvasHandles.removeAt(i); this.canvasBoxes.removeAt(i);
                return;
            }
            i++;
        }
    }

    void setContextMenu(string keyPath, u64 menuPtr)
    {
        int i = 0;
        while (i < this.ctxKeys.count())
        {
            if (this.ctxKeys.get(i) == keyPath)
            {
                u64 old = this.ctxMenus.get(i);
                if (old != 0u && old != menuPtr) __uiFreeContextMenu(old);
                this.ctxMenus.set(i, menuPtr); return;
            }
            i++;
        }
        this.ctxKeys.add("" + keyPath); this.ctxMenus.add(menuPtr);
    }

    u64 contextMenuFor(string keyPath)
    {
        int i = 0;
        while (i < this.ctxKeys.count())
        {
            if (this.ctxKeys.get(i) == keyPath) { u64 v = this.ctxMenus.get(i); return v; }
            i++;
        }
        return 0u;
    }

    u64 _imgLastPixels(u64 h)
    {
        int i = 0;
        while (i < this.imgHandles.count())
        {
            if (this.imgHandles.get(i) == h) { u64 v = this.imgLastPixels.get(i); return v; }
            i++;
        }
        return 0u;
    }

    void _setImgLastPixels(u64 h, u64 px)
    {
        int i = 0;
        while (i < this.imgHandles.count())
        {
            if (this.imgHandles.get(i) == h) { this.imgLastPixels.set(i, px); return; }
            i++;
        }
        this.imgHandles.add(h); this.imgLastPixels.add(px);
    }

    // A framework color (0x1RRGGBB with the marker bit, 0 = default) as an NSColor,
    // or nullptr for a default/unset color (native look).
    void* colorFor(int color)
    {
        if (color == 0) return nullptr;
        double r = (double)((color >> 16) & 0xFF) / 255.0;
        double g = (double)((color >> 8) & 0xFF) / 255.0;
        double b = (double)(color & 0xFF) / 255.0;
        return nsColor(r, g, b, 1.0);
    }

    // Accent a push button via bezelColor (documented-API accent, look policy). A 0 bg
    // clears the accent (native look); a set bg tints the bezel + the title (fg).
    void setAccent(u64 h, int fgColor, int bgColor)
    {
        void* ctrl = u2h(h);
        if (msgBool1(ctrl, "isKindOfClass:", cls("NSButton")) == (i8)0) return;
        void* bg = this.colorFor(bgColor);
        msg1(ctrl, "setBezelColor:", bg);   // nil clears the accent
        void* fg = fgColor != 0 ? this.colorFor(fgColor) : nullptr;
        if (fg != nullptr) msg1(ctrl, "setContentTintColor:", fg);
    }

    // The setListOp seam (see ui_native.cb for the cross-toolkit protocol design).
    // Columns/rowCount/selection drive an NSTableView; the tab ops an NSSegmentedControl;
    // the tree ops an NSOutlineView. The rowText / node-source boxes are stored (not
    // freed immediately) so the dataSource can query them; freed on destroy + teardown.
    void setListOp(u64 h, int op, int arg0, int arg1, const char* text, u64 payload)
    {
        void* ctrl = u2h(h);
        if (op == LISTOP_RESET_COLUMNS)
        {
            void* table = this._tableOf(h);
            void* cols = msg0(table, "tableColumns");
            i64 n = msgGetI64(cols, "count");
            while (n > (i64)0)
            {
                void* c = msgIntArg(cols, "objectAtIndex:", (i64)0);
                msg1(table, "removeTableColumn:", c);
                cols = msg0(table, "tableColumns");
                n = msgGetI64(cols, "count");
            }
        }
        else if (op == LISTOP_ADD_COLUMN)
        {
            void* table = this._tableOf(h);
            void* col = msg1(msg0(cls("NSTableColumn"), "alloc"), "initWithIdentifier:", nsStr((char*)text));
            msg1(msg0(col, "headerCell"), "setStringValue:", nsStr((char*)text));
            msgSetDouble(col, "setWidth:", (double)(arg0 * BASE_X));
            msg1(table, "addTableColumn:", col);
        }
        else if (op == LISTOP_SET_ROWCOUNT)
        {
            this._setListRows(h, arg0);
            msg0(this._tableOf(h), "reloadData");
        }
        else if (op == LISTOP_SET_ROWTEXT_CB)
        {
            this._setListBox(h, payload);
        }
        else if (op == LISTOP_SET_SELECT_MODE)
        {
            void* table = this._tableOf(h);
            msgBool(table, "setAllowsMultipleSelection:", arg0 != 0);
        }
        else if (op == LISTOP_SET_SELECTION)
        {
            void* table = this._tableOf(h);
            this._setListSel(h, arg0);
            if (arg0 < 0) { msg0(table, "deselectAll:"); }
            else
            {
                void* idx = msgIntArg(cls("NSIndexSet"), "indexSetWithIndex:", (i64)arg0);
                function<void*(void*, void*, void*, i8)> f = (function<void*(void*, void*, void*, i8)>)__objcMsgSendPtr;
                f(table, sel("selectRowIndexes:byExtendingSelection:"), idx, (i8)0);
            }
        }
        else if (op == LISTOP_INVALIDATE)
        {
            msg0(this._tableOf(h), "reloadData");
        }
        else if (op == LISTOP_TAB_RESET)
        {
            msgInt(ctrl, "setSegmentCount:", (i64)0);
        }
        else if (op == LISTOP_TAB_ADD)
        {
            int have = (int)msgGetI64(ctrl, "segmentCount");
            if (arg0 >= have) msgInt(ctrl, "setSegmentCount:", (i64)(arg0 + 1));
            function<void*(void*, void*, void*, i64)> f = (function<void*(void*, void*, void*, i64)>)__objcMsgSendPtr;
            f(ctrl, sel("setLabel:forSegment:"), nsStr((char*)text), (i64)arg0);
        }
        else if (op == LISTOP_TAB_SET_SEL)
        {
            msgInt(ctrl, "setSelectedSegment:", (i64)arg0);
        }
        else if (op == LISTOP_TREE_SET_SRC_CB)
        {
            this._setTreeBox(h, payload);
        }
        else if (op == LISTOP_TREE_REBUILD)
        {
            msg0(this._tableOf(h), "reloadData");
        }
    }

    // Upload a top-down BGRA32 buffer to an NSImageView as an NSImage. Builds an
    // NSBitmapImageRep (it copies the bytes), wraps it in an NSImage, and sets it.
    void setImageData(u64 h, u64 pixels, int w, int h2, int stride)
    {
        if (h == 0u || pixels == 0u || w <= 0 || h2 <= 0) return;
        void* ctrl = u2h(h);
        // NSBitmapImageRep with an explicit bytesPerRow copies row-by-row from the source.
        // colorSpaceName NSDeviceRGBColorSpace; 8 bits/sample, 4 samples, hasAlpha, 32bpp.
        void* rep = nsBitmapRep((void*)pixels, (i64)w, (i64)h2, (i64)8, (i64)4,
                                (i8)1, (i8)0, nsStr("NSDeviceRGBColorSpace"), (i64)stride, (i64)32);
        if (rep == nullptr) return;
        void* img = msg0(msg0(cls("NSImage"), "alloc"), "init");
        msg1(img, "addRepresentation:", rep);
        msg1(ctrl, "setImage:", img);
    }

    // Text metrics in DIPs. A length-based estimate is enough: the layout pass in
    // ui.cb never calls measureText today (the winui host uses the same stub).
    Size measureText(const char* s, int fontId, int wrapWidthDip)
    {
        Size sz = default;
        sz.w = (int)strlen((char*)s) + 1;
        sz.h = 1;
        return sz;
    }

    void requestLayout()
    {
        if (!_nReady) return;
        layoutRoot(_nTree, 0, 0, _nW);
        this.applyTree(_nTree, &_nCtx);
    }

    // Reconcile the Element tree to native controls: ensure a control per mappable
    // node (create on first sight, reuse by key path), sync its props, collect its
    // DIP frame, position everything, then destroy controls that left the tree.
    void applyTree(Element tree, UiContext* ctx)
    {
        this.applying = true;

        list<string> newKeys    = default;
        list<u64>    newHandles = default;
        list<int> fx = default; list<int> fy = default;
        list<int> fw = default; list<int> fh = default;

        this._applyNode(tree, keySegment(tree, 0), ctx,
                        &newKeys, &newHandles, &fx, &fy, &fw, &fh);

        // Destroy controls whose key path is no longer in the tree.
        int i = 0;
        while (i < this.liveKeys.count())
        {
            string k = this.liveKeys.get(i);
            if (!listHasStr(&newKeys, k))
            {
                u64 h = ctx.nativeHandle(k);
                this.destroyControl(h);
                ctx.removeNativeHandle(k);
            }
            i++;
        }

        // Position all live controls (no batch API needed; AppKit coalesces the
        // relayout on the next display cycle).
        int n = newHandles.count();
        int j = 0;
        while (j < n)
        {
            int rx = fx.get(j); int ry = fy.get(j);
            int rw = fw.get(j); int rh = fh.get(j);
            Rect r = default;
            r.x = rx; r.y = ry; r.w = rw; r.h = rh;
            this.setFrame(newHandles.get(j), r);
            j++;
        }

        // Replace the live sets with COPIES (clear + add, not a move-assign, which
        // repeated per frame corrupted the heap on Win32 - avoid container move-into-field).
        this.liveKeys.clear();
        this.liveHandles.clear();
        int m = 0;
        while (m < newKeys.count())
        {
            this.liveKeys.add("" + newKeys.get(m));
            this.liveHandles.add(newHandles.get(m));
            m++;
        }
        this.applyTheme(ctx);
        this.applying = false;
    }

    // Recursive worker: `path` is this node's key path. Mappable nodes get a control
    // + synced props + a collected DIP frame; every node recurses into its children
    // (containers contribute only geometry).
    void _applyNode(Element node, string path, UiContext* ctx,
                    list<string>* keys, list<u64>* handles,
                    list<int>* fx, list<int>* fy, list<int>* fw, list<int>* fh)
    {
        if (nativeMappable(node.kind()))
        {
            u64 h = ctx.nativeHandle(path);
            if (h == 0u)
            {
                h = this.createControl(node.kind(), (u64)this.contentView, path);
                ctx.setNativeHandle(path, h);
                // One-time seed of a TextArea's buffer (uncontrolled after; the
                // native view owns the text, further pushes are explicit).
                if (node.kind() == ELEM_TEXTAREA)
                {
                    TextArea* ta = node as TextArea;
                    this.setText(h, ta.value.data());
                }
                else if (node.kind() == ELEM_LIST)
                {
                    // One-time ListView setup: columns, select mode, and the boxed rowText
                    // source (captures the component, so it reads live state across renders).
                    ListView* lv = node as ListView;
                    this.setListOp(h, LISTOP_RESET_COLUMNS, 0, 0, "", 0u);
                    int ci = 0;
                    while (ci < lv.columns.count())
                    {
                        int wdip = 12;
                        if (ci < lv.colWidths.count()) wdip = lv.colWidths.get(ci);
                        this.setListOp(h, LISTOP_ADD_COLUMN, wdip, ci, lv.columns.get(ci).data(), 0u);
                        ci++;
                    }
                    this.setListOp(h, LISTOP_SET_SELECT_MODE, lv.multiSelect ? 1 : 0, 0, "", 0u);
                    this.setListOp(h, LISTOP_SET_ROWTEXT_CB, 0, 0, "", (u64)_boxListRow(lv.rowText));
                }
                else if (node.kind() == ELEM_TREE)
                {
                    // One-time TreeView setup: box the node-source callbacks + build the root.
                    TreeView* tv = node as TreeView;
                    this.setListOp(h, LISTOP_TREE_SET_SRC_CB, 0, 0, "",
                                   (u64)_boxTree(tv.childCount, tv.childId, tv.label));
                    this.setListOp(h, LISTOP_TREE_REBUILD, 0, 0, "", 0u);
                }
                else if (node.kind() == ELEM_CANVAS)
                {
                    // One-time CanvasView setup: box the onPaint closure so CfCanvasView's
                    // drawRect: (which resolves the view handle -> box) can invoke it.
                    CanvasView* cvw = node as CanvasView;
                    this._setCanvasBox(h, (u64)_boxCanvas(cvw.onPaint));
                }
            }
            this._syncProps(node, h);
            string tip = tooltipOf(node);
            if (tip.length() > 0) msg1(u2h(h), "setToolTip:", nsStr(tip.data()));
            Rect b = node.nodeBounds();
            keys.add("" + path);
            handles.add(h);
            fx.add(b.x); fy.add(b.y); fw.add(b.w); fh.add(b.h);
        }

        // A TabControl walks ONLY its active pane into native controls (lazy inactive
        // tabs), mirroring the Win32 host.
        if (node.kind() == ELEM_TABS)
        {
            TabControl* tc = node as TabControl;
            list<Element>* panes = node.childList();
            int sel = tc.selectedTab;
            if (panes != nullptr && sel >= 0 && sel < panes.count())
            {
                Element pane = panes.get(sel);
                string cp = joinKeyPath(path, keySegment(pane, sel));
                this._applyNode(pane, cp, ctx, keys, handles, fx, fy, fw, fh);
            }
            return;
        }

        list<Element>* kids = node.childList();
        if (kids != nullptr)
        {
            int i = 0;
            while (i < kids.count())
            {
                Element c = kids.get(i);
                string cp = joinKeyPath(path, keySegment(c, i));
                this._applyNode(c, cp, ctx, keys, handles, fx, fy, fw, fh);
                i++;
            }
        }
    }

    // Push a node's current props onto its control (downcast per kind - the same
    // structured access the reconciler uses in propsEqual).
    void _syncProps(Element node, u64 h)
    {
        int k = node.kind();
        if (k == ELEM_BUTTON)
        {
            Button* b = node as Button;
            this.setText(h, b.title.data());
            this.setBoolProp(h, PROP_ENABLED, !b.disabled);
            this._syncButtonAccent(h, b);
        }
        else if (k == ELEM_TEXT)
        {
            Text* t = node as Text;
            this.setText(h, t.text.data());
        }
        else if (k == ELEM_TEXTINPUT)
        {
            TextInput* ti = node as TextInput;
            this.setText(h, ti.value.data());
            this.setBoolProp(h, PROP_ENABLED, !ti.disabled);
        }
        else if (k == ELEM_CHECKBOX)
        {
            Checkbox* c = node as Checkbox;
            this.setText(h, c.label.data());
            this.setBoolProp(h, PROP_CHECKED, c.checked);
            this.setBoolProp(h, PROP_ENABLED, !c.disabled);
        }
        else if (k == ELEM_PROGRESS)
        {
            ProgressBar* p = node as ProgressBar;
            this.setIntProp(h, PROP_MAX, 100);
            this.setIntProp(h, PROP_VALUE, p.value);
        }
        else if (k == ELEM_SLIDER)
        {
            Slider* s = node as Slider;
            this.setIntProp(h, PROP_MAX, 100);
            this.setIntProp(h, PROP_VALUE, s.value);
            this.setBoolProp(h, PROP_ENABLED, !s.disabled);
        }
        else if (k == ELEM_TEXTAREA)
        {
            // Uncontrolled: never push text here (would clobber the buffer mid-edit);
            // only sync enabled. Text is seeded once at creation and pushed
            // explicitly via nativeSetControlText (file open).
            TextArea* ta = node as TextArea;
            this.setBoolProp(h, PROP_ENABLED, !ta.disabled);
        }
        else if (k == ELEM_STATUSBAR)
        {
            StatusBar* sb = node as StatusBar;
            string joined = "";
            int i = 0;
            while (i < sb.parts.count())
            {
                if (i > 0) joined = joined + "   ";
                joined = joined + sb.parts.get(i);
                i++;
            }
            this.setText(h, joined.data());
        }
        else if (k == ELEM_RADIO)
        {
            RadioButton* rb = node as RadioButton;
            this.setText(h, rb.label.data());
            this.setBoolProp(h, PROP_CHECKED, rb.checked);
            this.setBoolProp(h, PROP_ENABLED, !rb.disabled);
        }
        else if (k == ELEM_COMBO)
        {
            ComboBox* cb = node as ComboBox;
            this._syncCombo(h, cb);
            this.setBoolProp(h, PROP_ENABLED, !cb.disabled);
        }
        else if (k == ELEM_LIST)
        {
            // Virtualized: push row count + controlled selection, then reload. Cell text
            // is pulled on demand via the boxed rowText (the table's dataSource).
            ListView* lv = node as ListView;
            this.setListOp(h, LISTOP_SET_ROWCOUNT, lv.rowCount, 0, "", 0u);
            this.setListOp(h, LISTOP_SET_SELECTION, lv.selectedIndex, 0, "", 0u);
            this.setBoolProp(h, PROP_ENABLED, !lv.disabled);
        }
        else if (k == ELEM_TABS)
        {
            TabControl* tc = node as TabControl;
            this._syncTabs(h, tc);
        }
        else if (k == ELEM_TREE)
        {
            // Expand-on-demand: the outline owns its tree state (built once at creation);
            // only the enabled flag is synced (selection round-trips through the delegate).
            TreeView* tv = node as TreeView;
            this.setBoolProp(h, PROP_ENABLED, !tv.disabled);
        }
        else if (k == ELEM_IMAGE)
        {
            // Upload once per distinct pixel buffer (a re-render with the same pointer is
            // a no-op); the toolkit-neutral setImageData seam builds the NSImage.
            Image* im = node as Image;
            if (im.pixels != 0u && im.pixels != this._imgLastPixels(h))
            {
                this.setImageData(h, im.pixels, im.pxW, im.pxH, im.pxW * 4);
                this._setImgLastPixels(h, im.pixels);
            }
        }
        else if (k == ELEM_GROUPBOX)
        {
            GroupBox* g = node as GroupBox;
            msg1(u2h(h), "setTitle:", nsStr(g.title.data()));
        }
        else if (k == ELEM_CANVAS)
        {
            // The paint closure was boxed at creation; mark the view dirty so state
            // changes redraw (drawRect: re-invokes onPaint through the CG-backed Canvas).
            msgBool(u2h(h), "setNeedsDisplay:", true);
        }
    }

    // Accent-fill for a themed button (P10 parity): the same buttonBg/buttonText the
    // Win32 host feeds NM_CUSTOMDRAW is applied here through bezelColor (look policy).
    void _syncButtonAccent(u64 h, Button* b)
    {
        int abg = pickColor(b.backgroundColor, _nCtx.theme.buttonBg);
        int afg = pickColor(b.color, _nCtx.theme.buttonText);
        this.setAccent(h, afg, abg);
    }

    // Repopulate an NSPopUpButton only when its item set changed, then set the
    // controlled selection (refilling every frame would reset the popup mid-interaction).
    void _syncCombo(u64 h, ComboBox* cb)
    {
        void* ctrl = u2h(h);
        int have = (int)msgGetI64(ctrl, "numberOfItems");
        if (have != cb.items.count())
        {
            msg0(ctrl, "removeAllItems");
            int i = 0;
            while (i < cb.items.count())
            {
                msg1(ctrl, "addItemWithTitle:", nsStr(cb.items.get(i).data()));
                i++;
            }
        }
        int cur = (int)msgGetI64(ctrl, "indexOfSelectedItem");
        if (cur != cb.selectedIndex) msgInt(ctrl, "selectItemAtIndex:", (i64)cb.selectedIndex);
    }

    // Rebuild the segmented tab strip on a pane-count change, then set the selection.
    void _syncTabs(u64 h, TabControl* tc)
    {
        void* ctrl = u2h(h);
        int have = (int)msgGetI64(ctrl, "segmentCount");
        if (have != tc.children.count())
        {
            this.setListOp(h, LISTOP_TAB_RESET, 0, 0, "", 0u);
            int i = 0;
            while (i < tc.children.count())
            {
                string t = tc._title(i);
                this.setListOp(h, LISTOP_TAB_ADD, i, 0, t.data(), 0u);
                i++;
            }
        }
        this.setListOp(h, LISTOP_TAB_SET_SEL, tc.selectedTab, 0, "", 0u);
    }

    // The key path bound to a control this frame, or "" if none (linear scan of the
    // small live set - controls per window are few).
    string keyForHandle(u64 h)
    {
        int i = 0;
        while (i < this.liveHandles.count())
        {
            if (this.liveHandles.get(i) == h) return "" + this.liveKeys.get(i);
            i++;
        }
        return "";
    }

    // Apply the app's Theme to the window chrome: dark vs aqua appearance. Called
    // every frame from applyTree; cheap and idempotent. Control accent colors are
    // left at the OS default (setAccent is a no-op), matching the Win32 host's
    // monochrome-default behavior.
    void applyTheme(UiContext* ctx)
    {
        bool isDark = themeIsDark(&ctx.theme);
        this.dark = isDark;
        if (this.window != nullptr)
        {
            void* apName = isDark ? nsStr("NSAppearanceNameDarkAqua") : nsStr("NSAppearanceNameAqua");
            void* ap = msg1(cls("NSAppearance"), "appearanceNamed:", apName);
            msg1(this.window, "setAppearance:", ap);
        }
    }
};

// A Theme is "dark" when its panel background is darker than mid-gray. A default
// (monochrome, all-zero) theme is treated as light.
bool themeIsDark(Theme* t)
{
    int c = t.panelBg;
    if (c == 0) return false;
    int r = (c >> 16) & 0xFF; int g = (c >> 8) & 0xFF; int b = c & 0xFF;
    return (r + g + b) < 384;
}

// ── CanvasView bridge (P11): a CoreGraphics-backed Canvas ────────────────────
// CocoaCanvas implements the ui.cb Canvas interface using AppKit drawing primitives
// (NSBezierPath fill/stroke, NSString drawAtPoint - both CoreGraphics-backed), so the
// app's onPaint(Canvas) closure paints into a CfCanvasView's drawRect:. Cell coords map
// to points via BASE_X/BASE_Y (like the Win32 NativeGdiCanvas). The view is flipped, so
// row 0 is at the top, matching the framework's top-left convention.
class CocoaCanvas : Canvas
{
    void clear() { }   // drawRect: already erased to the view background

    void drawText(int col, int row, const char* s, int color)
    {
        void* str = nsStr((char*)s);
        void* attrs = msg0(msg0(cls("NSMutableDictionary"), "alloc"), "init");
        void* col2 = _nsColorFromFramework(color);
        if (col2 != nullptr) msg2(attrs, "setObject:forKey:", col2, _nsForegroundColorKey());
        function<void(void*, void*, double, double, void*)> f =
            (function<void(void*, void*, double, double, void*)>)__objcMsgSendPtr;
        f(str, sel("drawAtPoint:withAttributes:"), (double)(col * BASE_X), (double)(row * BASE_Y), attrs);
    }

    void drawRect(Rect r, bool filled, int color)
    {
        function<void*(void*, void*, double, double, double, double)> mk =
            (function<void*(void*, void*, double, double, double, double)>)__objcMsgSendPtr;
        void* path = mk(cls("NSBezierPath"), sel("bezierPathWithRect:"),
                        (double)(r.x * BASE_X), (double)(r.y * BASE_Y),
                        (double)(r.w * BASE_X), (double)(r.h * BASE_Y));
        void* col2 = _nsColorFromFramework(color);
        if (col2 != nullptr) msg0(col2, "set");
        if (filled) msg0(path, "fill"); else msg0(path, "stroke");
    }

    void pushClip(Rect r) { }   // per-region clipping not bridged (best-effort)
    void popClip() { }
};

// The NSAttributedString foreground-color attribute key (a global NSString symbol);
// resolved via a small class method wrapper is overkill, so a literal name is used.
void* _nsForegroundColorKey() { return nsStr("NSColor"); }

// A framework color (0x1RRGGBB with the marker bit; 0 = default) as an NSColor, or a
// mid-gray fallback for a default color.
void* _nsColorFromFramework(int color)
{
    if (color == 0) return nsColor(0.2, 0.2, 0.2, 1.0);
    double r = (double)((color >> 16) & 0xFF) / 255.0;
    double g = (double)((color >> 8) & 0xFF) / 255.0;
    double b = (double)(color & 0xFF) / 255.0;
    return nsColor(r, g, b, 1.0);
}

// CfCanvasView.drawRect: - resolve the view's boxed onPaint and invoke it with a
// CocoaCanvas. NSRect arrives as 4 doubles (d0-d3) which we ignore (we paint the full
// content each time). isFlipped -> YES so row 0 is at the top.
void _canvasDrawRectImp(void* self, void* cmd, double x, double y, double w, double h)
{
    u64 box = _nHost._canvasBoxFor((u64)self);
    if (box == 0u) return;
    CocoaCanvas cv = default;
    __uiCanvasPaint(box, cv);
}

i8 _canvasIsFlippedImp(void* self, void* cmd) { return (i8)1; }

// ── NSTableView dataSource IMPs (ListView; the boxed rowText is the item source) ──
i64 _numberOfRowsImp(void* self, void* cmd, void* table)
{
    return (i64)_nHost._listRowsForTable((u64)table);
}

void* _tableObjectValueImp(void* self, void* cmd, void* table, void* column, i64 row)
{
    u64 box = _nHost._listBoxForTable((u64)table);
    if (box == 0u) return nsStr("");
    void* cols = msg0(table, "tableColumns");
    i64 ci = msgGetI64Arg(cols, "indexOfObject:", column);
    if (ci < (i64)0) ci = (i64)0;
    string cell = __uiListRowText(box, (int)row, (int)ci);
    return nsStr(cell.data());
}

// A table row clicked (single) / double-clicked -> onSelect / onActivate.
void _onListClickImp(void* self, void* cmd, void* table)
{
    if (!_nReady || _nHost.applying) return;
    string key = _nHost.keyForHandle((u64)msg0(table, "enclosingScrollView"));
    if (key.length() == 0) return;
    Element e = findByKey(_nTree, keySegment(_nTree, 0), key);
    if (e == nullptr) return;
    ListView* lv = e as ListView;
    if (lv == nullptr) return;
    int sel = (int)msgGetI64(table, "selectedRow");
    if (sel >= 0 && sel != lv.selectedIndex) { lv.onSelect(sel); pumpNative(); }
}

void _onListDoubleClickImp(void* self, void* cmd, void* table)
{
    if (!_nReady) return;
    string key = _nHost.keyForHandle((u64)msg0(table, "enclosingScrollView"));
    if (key.length() == 0) return;
    Element e = findByKey(_nTree, keySegment(_nTree, 0), key);
    if (e == nullptr) return;
    ListView* lv = e as ListView;
    if (lv == nullptr) return;
    int sel = (int)msgGetI64(table, "selectedRow");
    if (sel >= 0) { lv.onActivate(sel); pumpNative(); }
}

// The segmented tab strip changed -> onSelectTab.
void _onTabSegmentImp(void* self, void* cmd, void* seg) { if (_nReady) routeTabChange(seg); }

// ── NSOutlineView dataSource IMPs (TreeView; items are NSNumber(nodeId)) ──────
i64 _outlineNumChildrenImp(void* self, void* cmd, void* outline, void* item)
{
    u64 box = _nHost._treeBoxForOutline((u64)outline);
    if (box == 0u) return (i64)0;
    int nodeId = item != nullptr ? (int)msgGetI64(item, "integerValue") : TREE_ROOT;
    return (i64)__uiTreeChildCount(box, nodeId);
}

void* _outlineChildImp(void* self, void* cmd, void* outline, i64 index, void* item)
{
    u64 box = _nHost._treeBoxForOutline((u64)outline);
    if (box == 0u) return nullptr;
    int nodeId = item != nullptr ? (int)msgGetI64(item, "integerValue") : TREE_ROOT;
    int childNid = __uiTreeChildId(box, nodeId, (int)index);
    return msgIntArg(cls("NSNumber"), "numberWithInteger:", (i64)childNid);
}

i8 _outlineExpandableImp(void* self, void* cmd, void* outline, void* item)
{
    u64 box = _nHost._treeBoxForOutline((u64)outline);
    if (box == 0u) return (i8)0;
    int nodeId = item != nullptr ? (int)msgGetI64(item, "integerValue") : TREE_ROOT;
    return __uiTreeChildCount(box, nodeId) > 0 ? (i8)1 : (i8)0;
}

void* _outlineObjectValueImp(void* self, void* cmd, void* outline, void* column, void* item)
{
    u64 box = _nHost._treeBoxForOutline((u64)outline);
    if (box == 0u || item == nullptr) return nsStr("");
    int nodeId = (int)msgGetI64(item, "integerValue");
    string lbl = __uiTreeLabel(box, nodeId);
    return nsStr(lbl.data());
}

// The outline selection changed (via its target/action) -> onSelect.
void _onTreeClickImp(void* self, void* cmd, void* outline)
{
    if (!_nReady) return;
    i64 row = msgGetI64(outline, "selectedRow");
    if (row < (i64)0) return;
    void* item = msgIntArg(outline, "itemAtRow:", row);
    routeTreeSelectItem(outline, item);
}

// ── ctx.post() marshaling (performSelectorOnMainThread with an NSNumber box) ───
void _cocoaPostEnqueue(u64 target, u64 boxPtr)
{
    void* num = msgIntArg(cls("NSNumber"), "numberWithUnsignedLongLong:", (i64)boxPtr);
    msgPerformOnMain(_nHost.target, "runPostBox:", num, false);
}

u64 _cocoaCurTid() { return (u64)msg0(cls("NSThread"), "currentThread"); }

// runPostBox: (main thread) - unwrap the NSNumber and run + free the boxed closure.
void _runPostBoxImp(void* self, void* cmd, void* num)
{
    if (num == nullptr) return;
    u64 boxPtr = (u64)msgGetI64(num, "unsignedLongLongValue");
    __uiRunPostBox(boxPtr);
}

// ── Host-neutral accessors (P7; mirror the Win32 host) ───────────────────────
// macOS stays single-window in P7 - multi-window + ctx.post marshaling parity is P11
// (see the plan). These keep the shared apps (fedit) compiling and correct on Darwin.
// (Defined after CocoaHost so _nHost's field types are known.)
UiContext*      activeCtx() { return &_nCtx; }
alias Component activeApp() { return _nApp; }
bool            hostDark()  { return _nHost.dark; }
int hostWindowCount() { return _nApp != nullptr ? 1 : 0; }

// Create a hidden window bound to `app` and build its tree (mirror of the Win32
// startHeadlessWindow; the headless self-tests use it).
void startHeadlessWindow(Component app, const char* title, int w, int h)
{
    createNativeWindow(title, false);
    _nApp = app;
    _nW = w; _nH = h;
    buildNativeTree();
}

// No queued UI-thread calls on macOS yet (ctx.post runs inline; marshaling is P11).
void hostDrainPosted() { }

// macOS multi-window is P11: opening a second top-level window is not wired here yet.
// `app` is consumed (freed at scope exit) so it does not leak.
void openAppWindow(Component app, const char* title) { }

// True if `want` is present in the key list.
bool listHasStr(list<string>* xs, string want)
{
    int i = 0;
    while (i < xs.count()) { if (xs.get(i) == want) return true; i++; }
    return false;
}

// Find the live node whose key path equals `want`. `path` is `node`'s own path.
Element findByKey(Element node, string path, string want)
{
    if (path == want) return node;
    list<Element>* kids = node.childList();
    if (kids != nullptr)
    {
        int i = 0;
        while (i < kids.count())
        {
            Element c = kids.get(i);
            string cp = joinKeyPath(path, keySegment(c, i));
            Element r = findByKey(c, cp, want);
            if (r != nullptr) return r;
            i++;
        }
    }
    return nullptr;
}

// Drain the dirty flag after a native event: re-render + reconcile, relayout, and
// reconcile the tree to native controls. AppKit repaints the controls itself.
void pumpNative()
{
    if (_nCtx.consumeDirty())
    {
        Element wip = _nApp.render(&_nCtx);
        list<Patch> patches = default;
        _nTree = reconcile(_nTree, wip, &patches);
        layoutRoot(_nTree, 0, 0, _nW);
        _nHost.applyTree(_nTree, &_nCtx);
    }
}

// -- Native event routing (target/action + delegate -> element handler) --------
void routeClick(void* ctrl)
{
    string key = _nHost.keyForHandle((u64)ctrl);
    if (key.length() == 0) return;
    Element e = findByKey(_nTree, keySegment(_nTree, 0), key);
    if (e == nullptr) return;
    Button* b = e as Button;
    if (b != nullptr) { b.fireClick(); pumpNative(); return; }
    Checkbox* c = e as Checkbox;
    if (c != nullptr) { c.fireToggle(); pumpNative(); return; }
    // A radio routes to its enclosing RadioGroup (one key-path segment up), which owns
    // the controlled value + onChange (mirror of the Win32 host).
    RadioButton* rb = e as RadioButton;
    if (rb != nullptr)
    {
        string pp = _parentPath(key);
        Element pe = findByKey(_nTree, keySegment(_nTree, 0), pp);
        if (pe != nullptr)
        {
            RadioGroup* g = pe as RadioGroup;
            if (g != nullptr) { g.onChange(rb.index); pumpNative(); }
        }
    }
}

// Strip the last "/segment" from a key path ("root/rg/r1" -> "root/rg"); "" if none.
string _parentPath(string key)
{
    int last = -1; int i = 0; int n = (int)key.length();
    while (i < n) { if (key.data()[i] == '/') last = i; i++; }
    if (last < 0) return "";
    return substring(key, 0, last);
}

// A combo selection change: read the new index, fire onChange.
void routeCombo(void* ctrl)
{
    string key = _nHost.keyForHandle((u64)ctrl);
    if (key.length() == 0) return;
    Element e = findByKey(_nTree, keySegment(_nTree, 0), key);
    if (e == nullptr) return;
    ComboBox* cb = e as ComboBox;
    if (cb == nullptr) return;
    int sel = (int)msgGetI64(ctrl, "indexOfSelectedItem");
    if (sel >= 0 && sel != cb.selectedIndex) { cb.onChange(sel); pumpNative(); }
}

// A tab strip selection change: read the segment, fire onSelectTab.
void routeTabChange(void* ctrl)
{
    if (_nHost.applying) return;
    string key = _nHost.keyForHandle((u64)ctrl);
    if (key.length() == 0) return;
    Element e = findByKey(_nTree, keySegment(_nTree, 0), key);
    if (e == nullptr) return;
    TabControl* tc = e as TabControl;
    if (tc == nullptr) return;
    int sel = (int)msgGetI64(ctrl, "selectedSegment");
    if (sel >= 0 && sel != tc.selectedTab) { tc.onSelectTab(sel); pumpNative(); }
}

// A tree selection change: read the selected item's nodeId, fire onSelect + onExpand.
void routeTreeSelectItem(void* outline, void* item)
{
    if (_nHost.applying) return;
    string key = _nHost.keyForHandle((u64)msg0(outline, "enclosingScrollView"));
    if (key.length() == 0) return;
    Element e = findByKey(_nTree, keySegment(_nTree, 0), key);
    if (e == nullptr) return;
    TreeView* tv = e as TreeView;
    if (tv == nullptr) return;
    int nid = item != nullptr ? (int)msgGetI64(item, "integerValue") : (0 - 1);
    if (nid != tv.selectedNode) { tv.onSelect(nid); pumpNative(); }
}

void routeEdit(void* ctrl)
{
    string key = _nHost.keyForHandle((u64)ctrl);
    if (key.length() == 0) return;
    Element e = findByKey(_nTree, keySegment(_nTree, 0), key);
    if (e == nullptr) return;
    TextInput* ti = e as TextInput;
    if (ti != nullptr)
    {
        char* c = cStr(msg0(ctrl, "stringValue"));
        string nv = c != nullptr ? (string)c : "";
        ti.onChangeText(nv);
        pumpNative();
        return;
    }
    // A TextArea is uncontrolled: textDidChange is just a dirty NOTIFICATION; do
    // not read / push the (potentially large) buffer here.
    TextArea* ta = e as TextArea;
    if (ta != nullptr)
    {
        ta.onChange();
        pumpNative();
    }
}

void routeSlider(void* ctrl)
{
    string key = _nHost.keyForHandle((u64)ctrl);
    if (key.length() == 0) return;
    Element e = findByKey(_nTree, keySegment(_nTree, 0), key);
    if (e == nullptr) return;
    Slider* s = e as Slider;
    if (s == nullptr) return;
    int pos = (int)msgGetDouble(ctrl, "doubleValue");
    s.fireSet(pos);
    pumpNative();
}

// Read the current text of the control at `keyPath` (owned string). Used to PULL a
// TextArea's buffer on save. Returns "" if there is no such control.
string nativeControlText(string keyPath)
{
    u64 h = _nCtx.nativeHandle(keyPath);
    if (h == 0u) return "";
    void* ctrl = u2h(h);
    void* pool = poolPush();
    void* text = nullptr;
    if (_isScroll(ctrl))
    {
        void* tv = msg0(ctrl, "documentView");
        text = msg0(tv, "string");
    }
    else
    {
        text = msg0(ctrl, "stringValue");
    }
    char* c = text != nullptr ? cStr(text) : nullptr;
    // Deep-copy into an owned string BEFORE the pool pops ('(string)c' would alias the
    // autoreleased buffer, which poolPop then frees). "" + c allocates a fresh buffer.
    string s = c != nullptr ? "" + c : "";
    poolPop(pool);
    return s;
}

// Read a status bar pane's text (mirror of the Win32 nativeStatusText). The macOS
// status strip is an NSTextField, so its stringValue is the joined pane text.
string nativeStatusText(string keyPath)
{
    u64 h = _nCtx.nativeHandle(keyPath);
    if (h == 0u) return "";
    void* pool = poolPush();
    char* c = cStr(msg0(u2h(h), "stringValue"));
    string s = c != nullptr ? "" + c : "";
    poolPop(pool);
    return s;
}

// Push text into the control at `keyPath` (file open / clear). Guards the reentrant
// change notification so the push does not register as a user edit.
void nativeSetControlText(string keyPath, string s)
{
    u64 h = _nCtx.nativeHandle(keyPath);
    if (h == 0u) return;
    void* ctrl = u2h(h);
    void* ns = _nsStrSafe(s);   // avoid a null NSString arg for an empty push
    bool prev = _nHost.applying;
    _nHost.applying = true;
    if (_isScroll(ctrl))
    {
        void* tv = msg0(ctrl, "documentView");
        msg1(tv, "setString:", ns);
    }
    else
    {
        msg1(ctrl, "setStringValue:", ns);
    }
    _nHost.applying = prev;
}

// -- Host-neutral driver API (selection / insertion / menu) -------------------
// Same surface as the Win32 host; fedit uses these to stay platform-portable.

// The NSTextView backing the control at `keyPath` (documentView of a scroll view),
// or the control itself for a plain field.
void* _textViewFor(string keyPath)
{
    u64 h = _nCtx.nativeHandle(keyPath);
    if (h == 0u) return nullptr;
    void* ctrl = u2h(h);
    if (_isScroll(ctrl)) return msg0(ctrl, "documentView");
    return ctrl;
}

// Select [start, end) in the control and scroll it into view + focus it (mirror of
// Win32 EM_SETSEL + EM_SCROLLCARET + SetFocus).
void nativeSelect(string keyPath, int start, int end)
{
    void* tv = _textViewFor(keyPath);
    if (tv == nullptr) return;
    u64 len = end >= start ? (u64)(end - start) : 0u;
    msgRange(tv, "setSelectedRange:", (u64)start, len);
    msgRange(tv, "scrollRangeToVisible:", (u64)start, len);
    void* win = msg0(tv, "window");
    if (win == nullptr) win = _nHost.window;
    if (win != nullptr) msg1(win, "makeFirstResponder:", tv);
}

// The selection start (NSRange location) of the control (mirror of EM_GETSEL selA).
int nativeSelectionStart(string keyPath)
{
    void* tv = _textViewFor(keyPath);
    if (tv == nullptr) return 0;
    return (int)msgRangeLoc(tv, "selectedRange");
}

// Insert `s` at character `pos`, firing the change notification like a keystroke
// (insertText:replacementRange: FIRES textDidChange:, mirror of EM_SETSEL +
// EM_REPLACESEL).
void nativeInsertTextAt(string keyPath, int pos, string s)
{
    void* tv = _textViewFor(keyPath);
    if (tv == nullptr) return;
    msgIdRange(tv, "insertText:replacementRange:", nsStr(s.data()), (u64)pos, 0u);
}

// Fire a menu command as if the user selected it (used by fedit's self-test).
void nativeTestFireMenu(int cmd)
{
    routeMenu(cmd);
}

// Register (or replace) the context menu for a key path; the host takes ownership of
// the boxed ContextMenu* (freed on teardown). Right-click shows it via NSMenu.
void nativeSetContextMenu(string keyPath, u64 menuPtr)
{
    _nHost.setContextMenu(keyPath, menuPtr);
}

// Simulate the user picking item `itemIndex` of the context menu on keyPath (headless:
// popUpMenuPositioningItem cannot run unattended). Routes the item's command.
void nativeFireContextMenu(string keyPath, int itemIndex)
{
    u64 mp = _nHost.contextMenuFor(keyPath);
    if (mp == 0u) return;
    ContextMenu* cm = (ContextMenu*)mp;
    if (itemIndex < 0 || itemIndex >= cm.count()) return;
    int cmd = cm.cmds.get(itemIndex);
    if (cmd > 0) routeMenu(cmd);
}

// Drive a splitter to a DIP position along its axis (headless drag). Fires onRatioChange
// (the SplitView is a layout container, like Win32 - the divider is a parent-tracked gap,
// not an NSSplitView, so the layout model stays single-source per the plan).
void nativeSplitterDrag(string keyPath, int dipX, int dipY)
{
    Element e = findByKey(_nTree, keySegment(_nTree, 0), keyPath);
    if (e == nullptr) return;
    SplitView* sv = e as SplitView;
    if (sv == nullptr) return;
    sv.onRatioChange(sv._ratioAt(dipX, dipY));
    pumpNative();
}

Rect nativeNodeBounds(string keyPath)
{
    Element e = findByKey(_nTree, keySegment(_nTree, 0), keyPath);
    if (e == nullptr) { Rect z = default; return z; }
    return e.nodeBounds();
}

// ── Tab drivers (NSSegmentedControl strip + the controlled model) ─────────────
int nativeTabSelected(string keyPath)
{
    u64 h = _nCtx.nativeHandle(keyPath);
    if (h == 0u) return 0 - 1;
    return (int)msgGetI64(u2h(h), "selectedSegment");
}

int nativeTabCount(string keyPath)
{
    u64 h = _nCtx.nativeHandle(keyPath);
    if (h == 0u) return 0;
    return (int)msgGetI64(u2h(h), "segmentCount");
}

void nativeTabSelect(string keyPath, int idx)
{
    u64 h = _nCtx.nativeHandle(keyPath);
    if (h == 0u) return;
    msgInt(u2h(h), "setSelectedSegment:", (i64)idx);
    routeTabChange(u2h(h));
}

// ── Tree drivers (real NSOutlineView item API; items are NSNumber(nodeId)) ─────
void* _outlineOf(string keyPath)
{
    u64 h = _nCtx.nativeHandle(keyPath);
    if (h == 0u) return nullptr;
    return _nHost._tableOf(h);
}

u64 nativeTreeRootItem(string keyPath)
{
    void* ov = _outlineOf(keyPath);
    if (ov == nullptr) return 0u;
    return (u64)msgIntArg(ov, "itemAtRow:", (i64)0);
}

u64 nativeTreeChildItem(string keyPath, u64 hItem)
{
    void* ov = _outlineOf(keyPath);
    if (ov == nullptr) return 0u;
    function<void*(void*, void*, i64, void*)> f = (function<void*(void*, void*, i64, void*)>)__objcMsgSendPtr;
    return (u64)f(ov, sel("child:ofItem:"), (i64)0, u2h(hItem));
}

int nativeTreeItemCount(string keyPath)
{
    void* ov = _outlineOf(keyPath);
    if (ov == nullptr) return 0;
    return (int)msgGetI64(ov, "numberOfRows");
}

void nativeTreeExpandItem(string keyPath, u64 hItem)
{
    void* ov = _outlineOf(keyPath);
    if (ov == nullptr) return;
    msg1(ov, "expandItem:", u2h(hItem));
}

void nativeTreeSelectItem(string keyPath, u64 hItem)
{
    void* ov = _outlineOf(keyPath);
    if (ov == nullptr) return;
    i64 row = msgGetI64Arg(ov, "rowForItem:", u2h(hItem));
    if (row >= (i64)0)
    {
        void* idx = msgIntArg(cls("NSIndexSet"), "indexSetWithIndex:", row);
        function<void*(void*, void*, void*, i8)> f = (function<void*(void*, void*, void*, i8)>)__objcMsgSendPtr;
        f(ov, sel("selectRowIndexes:byExtendingSelection:"), idx, (i8)0);
    }
    routeTreeSelectItem(ov, u2h(hItem));
}

int nativeTreeItemNodeId(string keyPath, u64 hItem)
{
    if (hItem == 0u) return 0 - 1;
    return (int)msgGetI64(u2h(hItem), "integerValue");   // items are NSNumber(nodeId)
}

// ── ListView drivers (NSTableView + the boxed rowText item source) ────────────
int nativeListRowCount(string keyPath)
{
    u64 h = _nCtx.nativeHandle(keyPath);
    if (h == 0u) return 0;
    return _nHost._listRows(h);
}

string nativeListCellText(string keyPath, int row, int col)
{
    u64 h = _nCtx.nativeHandle(keyPath);
    if (h == 0u) return "";
    void* table = _nHost._tableOf(h);
    u64 box = _nHost._listBoxForTable((u64)table);
    if (box == 0u) return "";
    return __uiListRowText(box, row, col);
}

void nativeListSelect(string keyPath, int row)
{
    u64 h = _nCtx.nativeHandle(keyPath);
    if (h == 0u) return;
    _nHost.setListOp(h, LISTOP_SET_SELECTION, row, 0, "", 0u);
}

int nativeListSelectedRow(string keyPath)
{
    u64 h = _nCtx.nativeHandle(keyPath);
    if (h == 0u) return 0 - 1;
    void* table = _nHost._tableOf(h);
    return (int)msgGetI64(table, "selectedRow");
}

void nativeListActivate(string keyPath, int row)
{
    u64 h = _nCtx.nativeHandle(keyPath);
    if (h == 0u) return;
    if (row >= 0) nativeListSelect(keyPath, row);
    Element e = findByKey(_nTree, keySegment(_nTree, 0), keyPath);
    if (e == nullptr) return;
    ListView* lv = e as ListView;
    if (lv == nullptr) return;
    if (row >= 0) { lv.onActivate(row); pumpNative(); }
}

// ── P11 host-neutral form/data test drivers (mirror the Win32 names) ──────────
void nativeClickButton(string keyPath)
{
    u64 h = _nCtx.nativeHandle(keyPath);
    if (h == 0u) return;
    void* ctrl = u2h(h);
    Element e = findByKey(_nTree, keySegment(_nTree, 0), keyPath);
    // Mirror the OS auto-toggle for the two state controls before routing the click.
    if (e != nullptr && e.kind() == ELEM_CHECKBOX)
    {
        i64 cur = msgGetI64(ctrl, "state");
        msgInt(ctrl, "setState:", cur == (i64)0 ? (i64)1 : (i64)0);
    }
    else if (e != nullptr && e.kind() == ELEM_RADIO)
    {
        msgInt(ctrl, "setState:", (i64)1);
    }
    routeClick(ctrl);
}

