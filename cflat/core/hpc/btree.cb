// btree<K,V> - in-memory B+tree ordered map, with an optimistic-lock-coupling concurrent
// lookup/insert path on top of the single-threaded core (see CONCURRENCY below).
//
// This is NOT a general-purpose container. dictionary<K,V> (hash map) beats it on point
// lookups, and list<T> beats it on plain iteration - reach for those first. Use btree<K,V>
// only when you need ordered iteration, range scans by key, or (later, once the concurrent
// B-link phase lands - see internal/plan/optimistic-lock-coupling.md) many-core read scaling.
// It lives under hpc/ so that reaching for it is a deliberate act, not the default.
//
// This is a B+tree, not a classic B-tree: all key/value pairs live in the leaves; internal
// nodes hold separator keys and child pointers only. Leaves are singly linked left-to-right
// via `next`, so a range scan walks the leaf chain without re-descending from the root - this
// link is also load-bearing for the future concurrent B-link version, so it is kept even
// though this single-threaded tree never needs to "catch up" a stale traversal.
//
// One node type (`isLeaf` flag) instead of separate leaf/internal structs: every node carries
// both a `values` array and a `children` array, which wastes some memory on internal nodes
// (unused `values`) and on leaves (unused `children`) - but it keeps a uniform node header,
// which is what the concurrent version (per-node version lock, uniform layout) wants. A split
// leaf/internal layout is a possible v2 memory optimization once the concurrent phase is not
// still pending.
//
// Ordering comes from operator< on K (there is no IComparable interface in this codebase);
// equality and greater-than are derived from < so K only needs to supply <. operator< exists
// natively for primitive types and for `string` (core/string.cb).
//
// Ownership mirrors dictionary<K,V> exactly - BARE BORROWS, `unique` OWNS:
//
//   btree<K, V>              value elements, deep-COPIED on insert
//   btree<K, V*>             BORROWS the value - never freed (the caller owns it)
//   btree<K, IShape>         BORROWS - never freed
//   btree<K, unique V*>      OWNS: freed on overwrite, on remove(), and at teardown
//   btree<K, unique IShape>  OWNS and frees
//
//   - KEYS are always BORROWED, exactly as dictionary<K,V> does. Primitive and pointer keys are
//     stored as-is; an OWNING key (a string, or a struct that owns buffers) is deep-copied on
//     insert and destructed on removal (dictionary.cb's rationale: a plain store would alias the
//     caller's soon-freed argument). The caller's own key is never consumed. NOTE: owning keys are
//     sound only for the SINGLE-THREADED API; the concurrent lookup()/insert() family requires a
//     primitive K whose operator< does not dereference (see the speculative-descent contract).
//   - A VALUE-TYPE V is COPIED on insert - `t.add(k, s)` leaves the caller's `s` intact. Write
//     `t.add(k, move s)` / `t.set(k, move s)` / `t.insert(k, move s)` to transfer instead; those
//     transfer overloads exist for value types only (a borrowing container must not take
//     ownership, and for `unique V*` the plain parameter is already a synthesized move sink).
//   - get() returns `alias V`: the returned value stays owned by the tree and must not be
//     destructed by the caller; a miss returns default(V).
//
// CONCURRENCY. Two APIs coexist on the same tree:
//
//   single-threaded: add() / set() / get() / contains() / remove() / clear() / cursors.
//                    No locks are taken. Use these when only one thread touches the tree.
//   concurrent:      lookup() / insert(). Optimistic lock coupling (Leis et al.) on the
//                    per-node `olock ver`. Safe against each other and against themselves
//                    from any number of threads.
//
// Do not mix the two families on a live tree: remove()/set()/clear() FREE memory (a merge
// frees a node, an overwrite frees a value) and an optimistic reader holds no lock, so a
// free under it is a use-after-free. Reclamation is deferred (see Phase 6 of
// internal/plan/optimistic-lock-coupling.md); lookup() and insert() are sound WITHOUT it
// precisely because they never free anything - a split only allocates. Build the tree
// single-threaded, or build it with insert(), then read it with lookup().
//
// See "concurrent (optimistic lock coupling) API" further down for the full contract.

import "hpc/olock.cb";

int BTREE_FANOUT = 16;   // max keys per node; internal nodes have up to 17 children

// btree_node<K,V> - one node, leaf or internal, selected by isLeaf. Fixed inline arrays
// (precedent: core/regex.cb's Match.caps) keep node storage a single flat allocation - and
// they are what makes an optimistic (unvalidated) read safe: an index computed from a torn
// `count` still lands inside the array, so it reads in-bounds garbage instead of faulting.
//
// `ver` guards every other field for the concurrent API. The fields are deliberately NOT
// wrapped in a lock(ver) { } group: the `.optimistic` lock mode does not exist yet
// (Phase 3/7), so the descent below is written with raw read_begin/read_validate/upgrade
// calls and the no-side-effects rule inside a speculative region is enforced by review.
// See optimistic-lock-coupling.md section 4b, "Option A".
//
// `isLeaf` is written once, before the node is published into the tree, and never again -
// so it alone may be read without validation.
struct btree_node<K, V>
{
    olock         ver          = default;    // version lock; guards everything below
    bool          isLeaf       = true;       // immutable after publication
    int           count        = 0;          // number of keys in use
    K             keys[16]     = default;
    V             values[16]   = default;     // leaf only: values[i] pairs with keys[i]
    btree_node<K, V>* children[17] = default; // internal only: count+1 live entries
    btree_node<K, V>* next      = nullptr;    // leaf only: next leaf in ascending key order
};

// btree_cursor<K,V> - a snapshot position in the leaf chain, produced by btree.first()/
// seek() and advanced with next(). valid()/key()/value() read the current position.
// Read-only: mutating the tree while a cursor is live is unchecked.
struct btree_cursor<K, V>
{
    btree_node<K, V>* _leaf = nullptr;
    int               _slot = 0;
    V                 _missing = default;

    bool valid()
    {
        return _leaf != nullptr && _slot < _leaf->count;
    }

    K key()
    {
        return _leaf->keys[_slot];
    }

    // `alias`: aliases the tree's storage, matching btree.get()'s contract.
    alias V value()
    {
        if (!valid()) return _missing;
        return _leaf->values[_slot];
    }

    void next()
    {
        if (_leaf == nullptr) return;
        _slot++;
        while (_leaf != nullptr && _slot >= _leaf->count)
        {
            _leaf = _leaf->next;
            _slot = 0;
        }
    }
};

// btree<K,V> - ordered map on top of btree_node<K,V>. Bare borrows, `unique` owns; keys are
// always borrowed. See the header comment above for the full ownership contract.
struct btree<K, V>
{
    btree_node<K, V>* _root  = nullptr;
    int               _count = 0;
    V                 _missing = default;   // value returned by get() on a miss

    // Concurrent-API state. `_ver` guards `_root` itself - a root change (tree creation,
    // height growth) is a write to the tree's own "child pointer", and an optimistic
    // descent couples through it exactly as it couples through an internal node.
    olock             _ver     = default;
    atomic_counter    _mtCount = default;   // entries added by insert(); count() adds it in
    // Optimistic descents that failed validation and restarted, split by caller. Diagnostic
    // only, and the ONLY store either path can issue on a lookup - and only on the rare
    // restart edge, never on the validated path, so a successful lookup still dirties no
    // shared cache line. A concurrent test where _readRestarts stays 0 never actually
    // raced: the seqlock was never exercised and the test proves nothing.
    atomic_counter    _readRestarts  = default;
    atomic_counter    _writeRestarts = default;

    // -- key ordering, derived entirely from operator< --------------------------------

    bool _lt(K a, K b) { return a < b; }
    bool _le(K a, K b) { return !(b < a); }
    bool _eq(K a, K b) { return !(a < b) && !(b < a); }

    // -- node helpers -------------------------------------------------------------------

    btree_node<K, V>* _newLeaf()
    {
        btree_node<K, V>* n = new btree_node<K, V>();
        n->isLeaf = true;
        return n;
    }

    btree_node<K, V>* _newInternal()
    {
        btree_node<K, V>* n = new btree_node<K, V>();
        n->isLeaf = false;
        return n;
    }

    // Store a key into slot i of a node, deep-copying an owning key (mirrors dictionary.cb).
    void _storeKey(btree_node<K, V>* n, int i, K key)
    {
        if const (is_primitive(K))    n->keys[i] = key;
        else if const (is_pointer(K)) n->keys[i] = key;
        else                          n->keys[i] = key.copy();
    }

    // Return an OWNED deep copy of a key: a fresh clone of an owning key (string or a struct that
    // owns buffers), or the value for a primitive/pointer key. A leaf-split separator is lifted
    // into the parent, which must own it independently of the leaf's copy (the key stays in the leaf).
    K _dupKey(K k)
    {
        K r = default;
        if const (is_primitive(K))    r = k;
        else if const (is_pointer(K)) r = k;
        else                          r = k.copy();
        return r;
    }

    // Abandon a key/value slot: overwrite it with a default WITHOUT freeing, for when its owned
    // buffer was shallow-copied into another slot that now owns it. The node is a borrowed pointer
    // parameter here, so `move` is not allowed (ownership model, see _freeValue); a plain store of
    // a default local is a pure overwrite that never frees the old slot. The synthesized node
    // destructor frees ALL OWNING slots - value types, and (since 2026-07-20) every slot of a
    // `unique`-substituted array - so an abandoned owning-typed tail slot must read as empty or
    // it is freed twice. Gated to owning types: a BARE pointer / interface slot is borrowed and
    // the destructor still leaves it alone, so clearing it would be pure cost.
    void _clearKey(btree_node<K, V>* n, int i)
    {
        if const (!is_primitive(K)) if const (!is_pointer(K)) { K e = default; n->keys[i] = e; }
    }
    void _clearValue(btree_node<K, V>* n, int i)
    {
        if const (is_unique(V))       { V e = default; n->values[i] = e; }
        else if const (!is_pointer(V)) if const (!is_primitive(V)) { V e = default; n->values[i] = e; }
    }

    // Destruct an owned key slot in place (frees an owning key and zeroes it; a no-op for a
    // borrowed/primitive key). `.~()` is a destructor call, not a `move`, so it is legal through a
    // borrowed node parameter - used to drop a separator the tree no longer holds.
    void _destroyKey(btree_node<K, V>* n, int i) { if const (!is_primitive(K)) if const (!is_pointer(K)) n->keys[i].~(); }

    // Release a value taken out of a leaf slot: an owned (`unique`) value is deleted, a value
    // type is destructed, a bare pointer / interface value is BORROWED and left to its real
    // owner, a primitive is trivial.
    //
    // Takes the value BY MOVE rather than a node+index, and that is LOAD-BEARING on two counts.
    // (1) This language's ownership model will not let a helper delete or move a field reached
    // through its own borrowed (non-move) parameter, so callers extract "move node->values[i]"
    // themselves - legal there because at every call site `node` is a genuine local or a `move`
    // parameter. (2) The `move` CLEARS the slot, and that is what keeps the synthesized node
    // destructor (which walks all 16 slots) from destructing the same value a second time. An
    // in-place `.~()` is NOT a substitute: it zeroes a `string`, but it does not clear a struct
    // that owns a `unique` field, and the node destructor then double-frees (measured).
    //
    // The workaround therefore SURVIVED the borrow migration unchanged: the flip changed WHICH
    // values get freed, not the mechanics of how a helper is allowed to free one.
    // CALL SITES MUST GATE: a `move` parameter of a POINTER type is freed at this function's
    // scope exit whether or not the body touches it, so a bare pointer / interface value must
    // never be handed here at all - it would delete a borrow. Every site spells the chain
    //     if const (is_unique(V))         _freeValue(move n->values[i]);
    //     else if const (is_pointer(V))   { }             // borrowed - do not even extract
    //     else if const (is_primitive(V)) { }
    //     else                            _freeValue(move n->values[i]);   // value type
    // The body is EMPTY on purpose: `value` is an owning `move` parameter, so its scope-exit
    // destructor releases it exactly once - deleting a `unique` pointee, destructing a value
    // type. An explicit `.~()` here would DOUBLE free a struct that owns a `unique` field,
    // because `.~()` frees the field without nulling it and the scope exit frees again
    // (measured). This function exists for its PARAMETER, not its body.
    void _freeValue(move V value)
    {
    }

    // Free an owning key taken out of a leaf slot; a no-op for a primitive/pointer key (those
    // are borrowed, never owned). See _freeValue for why this takes the key by move instead
    // of a node+index. Key ownership is UNCHANGED by the borrow migration.
    // Gated at the call sites exactly like _freeValue: a primitive or pointer key is borrowed
    // and must not be extracted here (an unconsumed pointer-typed `move` parameter is freed at
    // scope exit, which would delete a key the tree never owned).
    void _freeKey(move K key)
    {
    }

    // Store a value into a slot that holds NO live value yet, per the ownership rule: `unique`
    // is TAKEN (a unique-substituted parameter is a synthesized move sink); a bare pointer or
    // interface value is aliased (BORROWED); a value type is deep-copied so the caller's
    // original stays independent. `is_pointer(V)` is true for a bare or `unique` pointer AND
    // for an interface value, so it covers every borrowed spelling.
    // Mirrors list._placeAt / dictionary._placeValueAt exactly.
    //
    // Writes straight into the destination slot rather than returning the value: a
    // `move V`-RETURNING helper leaks a value type's owning fields, see
    // internal/issue/move-return-named-struct-local-leaks-fields.md. Storing INTO a borrowed
    // node parameter is fine - only moving a value OUT of one is not (see _freeValue).
    void _placeValue(btree_node<K, V>* n, int i, V value)
    {
        // A bare INTERFACE value is a borrow and lands in the is_pointer arm below (is_pointer(V)
        // is true for bare, `unique`, `alias` and interface values alike). `unique IFace` OWNS and
        // takes the is_unique arm, releasing through _freeValue's move parameter like any other
        // owning value.
        if const (is_unique(V))          n->values[i] = move value;
        else if const (is_pointer(V))    n->values[i] = value;
        else if const (is_primitive(V))  n->values[i] = value;
        else if const (!is_copyable(V))  compile_error("this btree value type owns a 'unique' pointer and has no 'copy()'; write 'move' at the call site (t.add(k, move x) / t.set(k, move x) / t.insert(k, move x)) to transfer ownership instead, or give the type a 'copy()' method");
        else                             n->values[i] = value.copy();
    }

    // Insert (sep, rightChild) into internal node parent at position idx: parent->keys[idx]
    // = sep, parent->children[idx+1] = rightChild, shifting existing entries right. Takes
    // ownership of rightChild (a freshly new'd node from _splitChild) - without `move` here,
    // an unconsumed owning parameter is freed at the caller's scope exit, use-after-freeing
    // the node this just stored into the tree.
    void _insertChildAt(btree_node<K, V>* parent, int idx, move K sep, move btree_node<K, V>* rightChild)
    {
        int j = parent->count;
        while (j > idx)
        {
            // Plain rotation opens a gap at idx: `parent` is a borrowed pointer parameter, so its
            // inline-array fields cannot be `move`d out (ownership model, see _freeValue). The
            // rotation is sound because it only shifts entries UP into the empty tail - the source
            // of each copy is overwritten by the next iteration, so no slot is left double-owned.
            parent->keys[j] = parent->keys[j - 1];
            parent->children[j + 1] = parent->children[j];
            j--;
        }
        // `sep` is a `move` PARAMETER (owned by this call), so moving it into the freed slot i is
        // legal and transfers the buffer; the old alias at slot idx was preserved one slot up.
        parent->keys[idx] = move sep;
        parent->children[idx + 1] = rightChild;
        parent->count++;
    }

    // Split parent->children[idx], which is full (count == BTREE_FANOUT). Leaf split: the
    // upper half moves to a new right leaf, linked into the chain; the right leaf's first
    // key is COPIED up as the separator (the key itself stays in the leaf). Internal split:
    // the median key MOVES up into the parent and is removed from both children.
    void _splitChild(btree_node<K, V>* parent, int idx)
    {
        btree_node<K, V>* left = parent->children[idx];
        btree_node<K, V>* right = new btree_node<K, V>();
        right->isLeaf = left->isLeaf;

        // `left` is `parent->children[idx]` - reached through the borrowed `parent`, so it carries
        // the same ownership taint and its inline arrays cannot be `move`d. Transfer keys/values to
        // `right` by shallow copy, then abandon-clear left's vacated slots so left's dead tail
        // holds no owned duplicate for the node destructor (which now frees all slots) to re-free.
        if (left->isLeaf)
        {
            int mid = BTREE_FANOUT / 2;
            int rightCount = left->count - mid;
            int i = 0;
            while (i < rightCount)
            {
                right->keys[i] = left->keys[mid + i];
                right->values[i] = left->values[mid + i];
                _clearKey(left, mid + i);
                _clearValue(left, mid + i);
                i++;
            }
            right->count = rightCount;
            left->count = mid;
            right->next = left->next;
            left->next = right;

            // Separator is a COPY of right's first key (the key stays in the leaf), so the parent
            // owns it independently. _dupKey deep-copies an owning key, or copies a primitive value.
            _insertChildAt(parent, idx, _dupKey(right->keys[0]), right);
        }
        else
        {
            int mid = BTREE_FANOUT / 2;
            int rightCount = left->count - mid - 1;
            int i = 0;
            while (i < rightCount)
            {
                right->keys[i] = left->keys[mid + 1 + i];
                _clearKey(left, mid + 1 + i);
                i++;
            }
            i = 0;
            while (i <= rightCount)
            {
                right->children[i] = left->children[mid + 1 + i];
                i++;
            }
            right->count = rightCount;
            left->count = mid;
            // Median key is REMOVED from left and lifted into the parent: an owned copy goes to the
            // parent, then left's original is freed in place (copy+free, since left cannot be moved).
            _insertChildAt(parent, idx, _dupKey(left->keys[mid]), right);
            _destroyKey(left, mid);
        }
    }

    // Index of the child to descend into for key, in an internal node: the first i with
    // key < node->keys[i], or node->count if key >= every separator.
    int _childIndex(btree_node<K, V>* n, K key)
    {
        int i = 0;
        while (i < n->count && _le(n->keys[i], key)) i++;
        return i;
    }

    // Slot holding key in leaf n, or -1 if key is absent. Read-only.
    int _leafFind(btree_node<K, V>* n, K key)
    {
        int i = 0;
        while (i < n->count && _lt(n->keys[i], key)) i++;
        if (i < n->count && _eq(n->keys[i], key)) return i;
        return -1;
    }

    // Open the sorted insertion slot for key in leaf n and return its index: find the position,
    // then rotate the tail up one. The caller must have confirmed that key is absent
    // (_leafFind == -1) and that n has room. Leaves slot i holding a stale duplicate of its old
    // occupant, which the caller immediately overwrites.
    int _leafOpenSlot(btree_node<K, V>* n, K key)
    {
        int i = 0;
        while (i < n->count && _lt(n->keys[i], key)) i++;

        int j = n->count;
        while (j > i)
        {
            // Plain rotation up: `n` is a borrowed pointer parameter, so its inline arrays cannot
            // be `move`d. Shifting into the empty tail leaves no double-owned slot; the caller
            // then overwrites the vacated slot i (its old alias survives one slot up).
            n->keys[j] = n->keys[j - 1];
            n->values[j] = n->values[j - 1];
            j--;
        }
        return i;
    }

    // Place a NEW (key, value) at its sorted position in leaf n, COPYING a value type and
    // borrowing/taking a pointer per the ownership rule (see _placeValue). Never allocates or
    // frees a node, and never frees a value - so it is safe to call with only n's own lock
    // held, which is what the concurrent fast path does.
    void _leafInsertNew(btree_node<K, V>* n, K key, V value)
    {
        // Poisoned for a non-copyable V like every other copying entry point, so that the call to
        // the (also poisoned) _placeValue sits in a dead arm and is never emitted. Guarding only
        // the public add()/set()/insert() is NOT enough: this helper is instantiated regardless.
        if const (!is_copyable(V)) compile_error("this btree value type owns a 'unique' pointer and has no 'copy()'; write 'move' at the call site (t.add(k, move x) / t.set(k, move x) / t.insert(k, move x)) to transfer ownership instead, or give the type a 'copy()' method");
        else
        {
            int i = _leafOpenSlot(n, key);
            _storeKey(n, i, key);
            _placeValue(n, i, value);
            n->count++;
        }
    }

    // _leafInsertNew's transfer counterpart: consumes value on every path.
    void _leafInsertNewMoved(btree_node<K, V>* n, K key, move V value)
    {
        int i = _leafOpenSlot(n, key);
        _storeKey(n, i, key);
        n->values[i] = move value;
        n->count++;
    }

    // Descend to the leaf that will hold key, splitting full nodes on the way down (single
    // top-down pass), so the leaf returned is never full. Single-threaded: takes no locks.
    // Extracted so that every insert entry point holds the leaf as a genuine LOCAL: the
    // ownership model will not let a helper move a value out through a borrowed node
    // parameter (see _freeValue), which is what the overwrite release below needs.
    btree_node<K, V>* _descendSplitting(K key)
    {
        if (_root == nullptr) _root = _newLeaf();

        if (_root->count == BTREE_FANOUT)
        {
            btree_node<K, V>* newRoot = _newInternal();
            newRoot->children[0] = _root;
            _splitChild(newRoot, 0);
            _root = newRoot;
        }

        btree_node<K, V>* n = _root;
        while (!n->isLeaf)
        {
            int i = _childIndex(n, key);
            if (n->children[i]->count == BTREE_FANOUT)
            {
                _splitChild(n, i);
                i = _childIndex(n, key);
            }
            n = n->children[i];
        }
        return n;
    }

    // Insert a new entry. Returns false if key is already present (existing value is left
    // untouched - use set() to overwrite). A value type V is COPIED (the caller's value is left
    // intact); a bare pointer / interface value is BORROWED; a `unique` value is TAKEN.
    bool add(K key, V value)
    {
        // Poison the copying overload for a non-copyable V so the class still instantiates and
        // `add(k, move x)` stays usable; the dead arm emits no call to the poisoned _placeValue.
        if const (!is_copyable(V)) compile_error("this btree value type owns a 'unique' pointer and has no 'copy()'; write 'move' at the call site (t.add(k, move x) / t.set(k, move x) / t.insert(k, move x)) to transfer ownership instead, or give the type a 'copy()' method");
        else
        {
            btree_node<K, V>* n = _descendSplitting(key);
            // Materialize the stored value ONLY once the key is known absent. On a duplicate the
            // caller's argument must be left completely untouched - not copied, and for a `unique`
            // V not consumed either (an unconsumed sink argument is freed by the caller's scope,
            // which is the right outcome: the tree did not take it).
            if (_leafFind(n, key) >= 0)
            {
                // Duplicate: the tree refuses the entry. A `unique` argument was already handed
                // over (a unique-substituted plain parameter is a synthesized move sink) and the
                // caller kept no handle to it, so it must be freed here or it leaks. A borrowed
                // pointer / interface / value-type argument is left completely untouched.
                if const (is_unique(V)) _freeValue(move value);
                return false;
            }
            _leafInsertNew(n, key, value);
            _count++;
        }
        return true;
    }

    // Insert or overwrite the value for key. A value type V is COPIED; a bare pointer /
    // interface value is BORROWED; a `unique` value is TAKEN. On overwrite the old value is
    // released first (a `unique` value is freed, a value type destructed, a borrow dropped).
    void set(K key, V value)
    {
        if const (!is_copyable(V)) compile_error("this btree value type owns a 'unique' pointer and has no 'copy()'; write 'move' at the call site (t.add(k, move x) / t.set(k, move x) / t.insert(k, move x)) to transfer ownership instead, or give the type a 'copy()' method");
        else
        {
            btree_node<K, V>* n = _descendSplitting(key);
            int s = _leafFind(n, key);
            if (s >= 0)
            {
                // Release the old value first. `n` is a genuine LOCAL here, which is exactly what
                // makes `move n->values[s]` legal - see _freeValue for the chain, and for why a
                // borrowed node parameter could not do this.
                if const (is_unique(V))         _freeValue(move n->values[s]);
                else if const (is_pointer(V))   { }
                else if const (is_primitive(V)) { }
                else                            _freeValue(move n->values[s]);
                _placeValue(n, s, value);
            }
            else
            {
                _leafInsertNew(n, key, value);
                _count++;
            }
        }
    }

    // Transfer overloads - the caller writes `move` to give up ownership instead of paying for
    // a deep copy. Offered for VALUE elements only; the `!is_pointer(V)` guard is the design,
    // not a workaround: a bare pointer / interface value is BORROWED, so accepting ownership
    // would strand it (nothing ever frees it), and for `unique V*` the plain parameter is
    // already a synthesized move sink. is_pointer(V) covers bare, `unique`, `alias` and
    // interface values alike. Declared AFTER the plain overloads (first-declaration matching).
    if const (!is_pointer(V))
    {
        bool add(K key, move V value)
        {
            btree_node<K, V>* n = _descendSplitting(key);
            // On a duplicate `value` is dropped and destructed at scope exit. That is correct:
            // the caller wrote `move`, so it has already given the value up.
            if (_leafFind(n, key) >= 0) return false;
            _leafInsertNewMoved(n, key, move value);
            _count++;
            return true;
        }

        void set(K key, move V value)
        {
            btree_node<K, V>* n = _descendSplitting(key);
            int s = _leafFind(n, key);
            if (s >= 0)
            {
                // The `!is_pointer(V)` guard means V is a value type or a primitive here.
                if const (!is_primitive(V)) _freeValue(move n->values[s]);
                n->values[s] = move value;
            }
            else
            {
                _leafInsertNewMoved(n, key, move value);
                _count++;
            }
        }
    }

    // Find the leaf that would contain key, and the in-leaf slot (or -1 on a miss).
    // Out-params: *leafOut receives the leaf, *slotOut the slot.
    void _find(K key, btree_node<K, V>** leafOut, int* slotOut)
    {
        btree_node<K, V>* n = _root;
        while (n != nullptr && !n->isLeaf)
            n = n->children[_childIndex(n, key)];

        *leafOut = n;
        *slotOut = -1;
        if (n == nullptr) return;

        int i = 0;
        while (i < n->count && _lt(n->keys[i], key)) i++;
        if (i < n->count && _eq(n->keys[i], key)) *slotOut = i;
    }

    // Returns true if key is present.
    bool contains(K key)
    {
        btree_node<K, V>* leaf = nullptr;
        int slot = -1;
        _find(key, &leaf, &slot);
        return slot != -1;
    }

    // Read the value for key. Returns default(V) if not present. `alias`: the value stays
    // owned by the tree, so the caller must not destruct the returned value.
    alias V get(K key)
    {
        btree_node<K, V>* leaf = nullptr;
        int slot = -1;
        _find(key, &leaf, &slot);
        if (slot == -1) return _missing;
        return leaf->values[slot];
    }

    // =====================================================================================
    // concurrent (optimistic lock coupling) API - lookup() and insert()
    // =====================================================================================
    //
    // Contract:
    //   - lookup() and insert() are safe from any number of threads, against each other and
    //     against themselves. Everything else on this type is single-threaded-only.
    //   - remove() / set() / clear() / the destructor must NOT run concurrently with them.
    //     They free memory (merge frees a node; overwrite frees a value) and an optimistic
    //     reader holds no lock, so a free under it is a use-after-free. That needs epoch
    //     reclamation, which is deferred - see Phase 6 of optimistic-lock-coupling.md.
    //     insert() never frees: a split only allocates, which is exactly why it is sound
    //     with no reclamation at all. insert() therefore has add() semantics (returns false
    //     on a duplicate) and never overwrites.
    //   - K must be a type whose operator< does not dereference - i.e. a primitive. The
    //     descent compares keys read SPECULATIVELY, and a torn string/pointer key would be
    //     dereferenced before there is any chance to validate it. int keys are the case
    //     this is built for. V may be anything: values are only ever copied out and
    //     validated before use, never dereferenced speculatively.
    //
    // The speculative-region rules, enforced here by review and not by the compiler (the
    // node's fields are ungrouped - Option A, section 4b):
    //   - no stores to shared memory, no allocation, no delete, no I/O;
    //   - every array index stays inside the node's fixed storage even when `count` is torn
    //     (hence the clamps in _childIndexSpec / _leafSlotSpec);
    //   - nothing read speculatively is USED until validation succeeds - copy out first.

    // Speculative _childIndex. `count` may be torn, so it is clamped to the node's capacity
    // before it bounds the scan; the result is in 0..BTREE_FANOUT, always a live index of
    // children[17]. Read-only. Garbage in, in-bounds garbage out - never a fault.
    int _childIndexSpec(btree_node<K, V>* n, K key)
    {
        int c = n->count;
        if (c < 0) c = 0;
        if (c > BTREE_FANOUT) c = BTREE_FANOUT;
        int i = 0;
        while (i < c && _le(n->keys[i], key)) i++;
        return i;
    }

    // Speculative in-leaf search: the slot holding key, or -1. Same clamp, same rules.
    // The answer is meaningless until the caller validates the leaf's version.
    int _leafSlotSpec(btree_node<K, V>* n, K key)
    {
        int c = n->count;
        if (c < 0) c = 0;
        if (c > BTREE_FANOUT) c = BTREE_FANOUT;
        int i = 0;
        while (i < c && _lt(n->keys[i], key)) i++;
        if (i < c && _eq(n->keys[i], key)) return i;
        return -1;
    }

    // Optimistic lock-coupled descent to the leaf that would hold key. Takes NO locks and
    // issues NO stores.
    //
    // Returns false when the descent must be restarted (a validation failed - the tree
    // changed under us and everything read is garbage). Returns true on success, with
    // *leafOut set to the leaf and *verOut to the version snapshot that was validated for
    // it - nullptr/0 when the tree is genuinely (and validatedly) empty.
    //
    // The coupling is the ORDER: snapshot the parent, read the child pointer, snapshot the
    // CHILD's version, and only THEN validate the parent. Validating the parent after the
    // child snapshot is what makes the child pointer trustworthy: if the parent did not
    // move, the pointer we read out of it was real, and any later change to the child is
    // caught by the child's own snapshot.
    bool _descendOptimistic(K key, btree_node<K, V>** leafOut, i64* verOut)
    {
        *leafOut = nullptr;
        *verOut = 0;

        // The tree itself is the first "parent": _ver guards the _root slot.
        i64 tv = _ver.read_begin();
        btree_node<K, V>* n = _root;
        if (n == nullptr) return _ver.read_validate(tv);   // empty only if validated

        i64 v = n->ver.read_begin();
        if (!_ver.read_validate(tv)) return false;         // couple through the root slot

        while (!n->isLeaf)                                 // isLeaf: immutable, needs no guard
        {
            int slot = _childIndexSpec(n, key);
            btree_node<K, V>* child = n->children[slot];   // speculative
            // A live child pointer is never null; reading one means `count` was torn ahead
            // of the store that filled the slot. Restart rather than dereference it.
            if (child == nullptr) return false;

            i64 cv = child->ver.read_begin();
            if (!n->ver.read_validate(v)) return false;    // <- the coupling point
            n = child;
            v = cv;
        }

        *leafOut = n;
        *verOut = v;
        return true;
    }

    // Concurrent lookup. Fully optimistic: no locks, and on the validated path no stores at
    // all, so a hot node's cache line stays Shared in every core's L1 - the whole point of
    // OLC. Returns true and writes the value to *out when key is present.
    //
    // *out is an ALIAS for a pointer or `unique` V, exactly like get(): the tree keeps the
    // slot, and for a borrowing tree the real owner is elsewhere. Do not free through it.
    bool lookup(K key, V* out)
    {
        while (true)
        {
            btree_node<K, V>* leaf = nullptr;
            i64 lv = 0;
            if (!_descendOptimistic(key, &leaf, &lv)) { _readRestarts.increment(); continue; }
            if (leaf == nullptr) return false;               // validated empty tree

            // Speculative: search the leaf and COPY the value out. Nothing below the
            // validate may be used, so `found` is a copy, not a reference into the node.
            int slot = _leafSlotSpec(leaf, key);
            V found = default;
            if (slot >= 0) found = leaf->values[slot];

            if (!leaf->ver.read_validate(lv)) { _readRestarts.increment(); continue; }

            // Validated: `slot` and `found` are now real.
            if (slot < 0) return false;
            *out = found;
            return true;
        }
        return false;
    }

    // Fast-path half of insert(): descend optimistically and hand back the target leaf
    // EXCLUSIVELY LOCKED and with room for one more entry. Returns nullptr when the slow
    // path is needed (empty tree, or the leaf is full and a split must happen).
    //
    // upgrade() is where the optimistic snapshot becomes a real exclusive lock. It is
    // acquired NON-LEXICALLY - there is no lock() block - so every caller path must
    // release() it by hand. That is expected and legal (lock-guard-mandatory.md).
    btree_node<K, V>* _fastLockLeafWithRoom(K key)
    {
        while (true)
        {
            btree_node<K, V>* leaf = nullptr;
            i64 lv = 0;
            if (!_descendOptimistic(key, &leaf, &lv)) { _writeRestarts.increment(); continue; }
            if (leaf == nullptr) return nullptr;              // empty tree -> slow path

            // Optimistic -> exclusive. Fails if any writer touched the leaf since lv,
            // which also means the leaf may no longer be the right one: restart.
            if (!leaf->ver.upgrade(lv)) { _writeRestarts.increment(); continue; }

            // From here `leaf` is locked, and its count can no longer move.
            if (leaf->count >= BTREE_FANOUT)
            {
                leaf->ver.release();
                return nullptr;                              // needs a split -> slow path
            }
            return leaf;
        }
        return nullptr;
    }

    // Concurrent insert. Fast path: optimistic descent + upgrade() at the leaf, touching
    // exactly one node's lock and no parent. Slow path (rare): the leaf is full, so a
    // split is needed - retake the whole descent under real exclusive locks.
    //
    // add() semantics: false if key was already present (the tree is left untouched). Value
    // ownership follows add(): a value type is COPIED, a bare pointer / interface is BORROWED,
    // a `unique` value is TAKEN. Write `insert(k, move x)` to transfer a value type instead.
    bool insert(K key, V value)
    {
        if const (!is_copyable(V)) compile_error("this btree value type owns a 'unique' pointer and has no 'copy()'; write 'move' at the call site (t.add(k, move x) / t.set(k, move x) / t.insert(k, move x)) to transfer ownership instead, or give the type a 'copy()' method");
        else
        {
            btree_node<K, V>* leaf = _lockLeafForInsert(key);
            if (_leafFind(leaf, key) >= 0)
            {
                leaf->ver.release();                         // non-lexical: every path
                if const (is_unique(V)) _freeValue(move value);   // duplicate: see add()
                return false;
            }
            // The value is copied under the leaf's exclusive lock, and only once the key is
            // known absent (see add()). For a primitive or pointer V this is free; for a value
            // type it adds one deep copy to the lock hold time, which is the price of not copying
            // on a refused duplicate. The copy touches no tree state, so it cannot deadlock.
            _leafInsertNew(leaf, key, value);
            leaf->ver.release();
            _mtCount.increment();
        }
        return true;
    }

    // insert()'s transfer counterpart, guarded exactly like add(move V) above.
    if const (!is_pointer(V))
    {
        bool insert(K key, move V value)
        {
            btree_node<K, V>* leaf = _lockLeafForInsert(key);
            if (_leafFind(leaf, key) >= 0)
            {
                leaf->ver.release();
                return false;                                // duplicate; `value` is dropped
            }
            _leafInsertNewMoved(leaf, key, move value);
            leaf->ver.release();
            _mtCount.increment();
            return true;
        }
    }

    // Hand back the target leaf EXCLUSIVELY LOCKED and with room for one more entry - fast
    // (optimistic) path first, falling back to the pessimistic lock-coupled descent. The
    // caller must release() the lock on every path. Split out of insert() so both overloads
    // share one descent and neither materializes a value before the duplicate check.
    btree_node<K, V>* _lockLeafForInsert(K key)
    {
        btree_node<K, V>* leaf = _fastLockLeafWithRoom(key);
        if (leaf != nullptr) return leaf;
        return _lockLeafPessimistic(key);
    }

    // Slow path (rare): exclusive lock-coupled top-down descent with preemptive splitting -
    // the single-threaded algorithm with real locks. Hold the parent, take the child, split the
    // child if it is full (which writes to the parent, hence the parent must still be held),
    // then release the parent. Locks are only ever taken root-to-leaf, so there is no cycle
    // and no deadlock. Rare, so it is written for correctness, not for speed. Returns the
    // target leaf EXCLUSIVELY LOCKED and with room; the caller releases it.
    btree_node<K, V>* _lockLeafPessimistic(K key)
    {
        while (true)
        {
            // The tree's own lock guards _root; it is the parent of the root node and is
            // coupled through in the same way - released only once the root is locked.
            _ver.acquire();
            if (_root == nullptr) _root = _newLeaf();
            btree_node<K, V>* n = _root;
            n->ver.acquire();

            if (n->count == BTREE_FANOUT)
            {
                // Grow the height. newRoot is invisible until _root is stored, so locking
                // it cannot contend; lock it BEFORE publishing so no racer can slip in.
                btree_node<K, V>* newRoot = _newInternal();
                newRoot->children[0] = n;
                _splitChild(newRoot, 0);
                newRoot->ver.acquire();
                _root = newRoot;
                n->ver.release();
                n = newRoot;
            }
            _ver.release();                                  // coupled: n is locked

            bool restart = false;
            while (!n->isLeaf)
            {
                int i = _childIndex(n, key);
                btree_node<K, V>* child = n->children[i];
                child->ver.acquire();

                if (child->count == BTREE_FANOUT)
                {
                    // n was not full when we took it, and holding its lock is what keeps it
                    // that way - no other thread can reach n's children while n is held, so
                    // it always has room for the separator. Defensive only: restart rather
                    // than overflow keys[16] if that invariant were ever violated.
                    if (n->count >= BTREE_FANOUT)
                    {
                        child->ver.release();
                        n->ver.release();
                        restart = true;
                        break;
                    }
                    _splitChild(n, i);                       // writes n and child, both held
                    child->ver.release();
                    continue;                                // re-pick under the still-held n
                }

                n->ver.release();                            // coupled: child is locked
                n = child;
            }
            if (restart) { _writeRestarts.increment(); continue; }

            // Preemptive splitting guarantees the leaf has room; the guard is defensive
            // (and a restart, not a corruption, if the invariant ever slipped).
            if (n->count >= BTREE_FANOUT)
            {
                n->ver.release();
                _writeRestarts.increment();
                continue;
            }

            return n;                                        // locked, and has room
        }
        return nullptr;
    }

    // Minimum keys a non-root node must hold after a remove.
    int _minKeys()
    {
        return (BTREE_FANOUT / 2) - 1;
    }

    // Descend from the root toward key, recording the path of internal nodes visited into
    // path/pathIdx (path[0] is the root, pathIdx[0] the child index taken from path[0], etc;
    // path[depth-1] is the returned leaf's immediate parent) and writing the leaf reached
    // into *leafOut. Fixed-size path buffer: a BTREE_FANOUT-ary tree at int-count scale
    // never exceeds a depth remotely close to 64.
    int _pathTo(K key, btree_node<K, V>** path, int* pathIdx, btree_node<K, V>** leafOut)
    {
        int depth = 0;
        btree_node<K, V>* n = _root;
        while (!n->isLeaf)
        {
            int i = _childIndex(n, key);
            path[depth] = n;
            pathIdx[depth] = i;
            depth++;
            n = n->children[i];
        }
        *leafOut = n;
        return depth;
    }

    // Remove an entry by key. Returns true if removed (and frees the value); false if not
    // found. Rebalances (borrow or merge) up the path on underflow, and shrinks the tree's
    // height if the root becomes a childless internal node. The walk itself lives in
    // _rebalanceFrom() below.
    //
    // SINGLE-THREADED ONLY. A merge FREES a node, and an optimistic reader inside that node
    // holds no lock - so running this against a concurrent lookup()/insert() is a
    // use-after-free. Concurrent remove needs epoch reclamation and is deferred (Phase 6 of
    // internal/plan/optimistic-lock-coupling.md).
    bool remove(K key)
    {
        if (_root == nullptr) return false;

        btree_node<K, V>*[64] path = default;
        int[64] pathIdx = default;
        btree_node<K, V>* leaf = nullptr;
        int depth = _pathTo(key, path, pathIdx, &leaf);

        int i = 0;
        while (i < leaf->count && _lt(leaf->keys[i], key)) i++;
        if (i >= leaf->count || !_eq(leaf->keys[i], key)) return false;

        // Release the entry: `unique` value freed, value type destructed, a borrowed pointer /
        // interface value left to its real owner. The key is freed only if it is an owning key.
        // Release the entry. `unique` value freed, value type destructed, a bare pointer /
        // interface value left to its real owner; an owning key destructed, a borrowed key not.
        if const (is_unique(V))         _freeValue(move leaf->values[i]);
        else if const (is_pointer(V))   { }
        else if const (is_primitive(V)) { }
        else                            _freeValue(move leaf->values[i]);
        if const (!is_primitive(K)) if const (!is_pointer(K)) _freeKey(move leaf->keys[i]);
        int j = i;
        while (j < leaf->count - 1)
        {
            // `move` down-shift clears each vacated source; the last iteration clears the old
            // top slot [count-1], so the shrunk tail holds no stale owned duplicate for the
            // node destructor to double-free. A primitive is copied without clearing.
            leaf->keys[j] = move leaf->keys[j + 1];
            leaf->values[j] = move leaf->values[j + 1];
            j++;
        }
        leaf->count--;
        _count--;

        // Rebalance (borrow or merge) up the path on underflow, and shrink the tree's
        // height if the root collapses. `leaf` is only ever borrowed here - remove() does
        // not own it (it is already linked into the tree); ownership only moves at the
        // point a helper actually frees a node (see _mergeWithLeft/_mergeWithRight/
        // _collapseEmptyRoot, all of which take their doomed node by `move`).
        _rebalanceFrom(path, pathIdx, depth, leaf);

        return true;
    }

    // Walk up from `node` (the node just modified by remove(), at depth `d` in the path
    // recorded by _pathTo) rebalancing via borrow or merge on underflow. Both borrow and
    // merge only ever touch node's immediate parent's separator (a borrow moves one entry
    // across a single sibling boundary; a merge deletes the separator between the two
    // nodes it joins), so no fixup above the immediate parent is ever required. `node` is
    // borrowed - it is already part of the tree, and this function only sometimes hands
    // it off (via `move`) to a helper that frees it.
    void _rebalanceFrom(btree_node<K, V>** path, int* pathIdx, int depth, btree_node<K, V>* node)
    {
        int d = depth;
        while (true)
        {
            if (d == 0)
            {
                // node is the root: shrink the tree's height if it is now empty (a
                // childless internal node collapses to its only child; an empty leaf
                // collapses the tree to nullptr). Otherwise node stays the root untouched.
                if (node->count == 0) _collapseEmptyRoot(node->isLeaf, move node);
                break;
            }
            if (node->count >= _minKeys()) break;

            btree_node<K, V>* parent = path[d - 1];
            int idx = pathIdx[d - 1];

            btree_node<K, V>* leftSib = idx > 0 ? parent->children[idx - 1] : nullptr;
            btree_node<K, V>* rightSib = idx < parent->count ? parent->children[idx + 1] : nullptr;

            if (leftSib != nullptr && leftSib->count > _minKeys())
            {
                _borrowFromLeft(parent, idx, node, leftSib);
                break;
            }
            if (rightSib != nullptr && rightSib->count > _minKeys())
            {
                _borrowFromRight(parent, idx, node, rightSib);
                break;
            }

            if (leftSib != nullptr)
                _mergeWithLeft(parent, idx, move node, leftSib);
            else
                _mergeWithRight(parent, idx, node, move rightSib);

            node = parent;
            d--;
        }
    }

    // Merge node into leftSib (node is parent->children[idx], leftSib is its left sibling);
    // node disappears. Frees node, so it is taken by move.
    void _mergeWithLeft(btree_node<K, V>* parent, int idx, move btree_node<K, V>* node, btree_node<K, V>* leftSib)
    {
        bool leafMerge = node->isLeaf;
        int k = 0;
        if (node->isLeaf)
        {
            // `node` is a `move` parameter, so `move node->keys[k]` is legal: it transfers the
            // owning key/value into leftSib and clears node's slot, so `delete node` (whose
            // destructor now frees all slots) sees them empty - no double free.
            while (k < node->count)
            {
                leftSib->keys[leftSib->count] = move node->keys[k];
                leftSib->values[leftSib->count] = move node->values[k];
                leftSib->count++;
                k++;
            }
            leftSib->next = node->next;
        }
        else
        {
            // Internal merge pulls the parent separator DOWN into leftSib by shallow copy (parent
            // is borrowed - no `move`); the fixup below overwrites that parent slot without freeing,
            // so leftSib keeps the buffer. node's keys transfer by move (move parameter).
            leftSib->keys[leftSib->count] = parent->keys[idx - 1];
            leftSib->count++;
            while (k < node->count)
            {
                leftSib->keys[leftSib->count] = move node->keys[k];
                leftSib->count++;
                k++;
            }
            k = 0;
            int c = leftSib->count - node->count;
            while (k <= node->count)
            {
                leftSib->children[c] = node->children[k];
                c++;
                k++;
            }
        }
        delete node;

        // Drop the parent's now-defunct separator. A leaf merge DISCARDS it - free the owned key in
        // place (`.~()` is legal through the borrowed parent). An internal merge already handed it
        // to leftSib, so the shift below (which overwrites without freeing) drops it there. Then
        // clear the vacated top slot so the node destructor never frees a stale owned duplicate.
        if (leafMerge) _destroyKey(parent, idx - 1);
        int m = idx - 1;
        while (m < parent->count - 1)
        {
            parent->keys[m] = parent->keys[m + 1];
            parent->children[m + 1] = parent->children[m + 2];
            m++;
        }
        _clearKey(parent, parent->count - 1);
        parent->count--;
    }

    // Merge rightSib into node (node is parent->children[idx], rightSib is its right
    // sibling); rightSib disappears. Frees rightSib, so it is taken by move.
    void _mergeWithRight(btree_node<K, V>* parent, int idx, btree_node<K, V>* node, move btree_node<K, V>* rightSib)
    {
        bool leafMerge = node->isLeaf;
        int k = 0;
        if (node->isLeaf)
        {
            // `rightSib` is a `move` parameter, so `move rightSib->keys[k]` transfers the owning
            // key/value into node and clears rightSib's slot; `delete rightSib` then frees empties.
            while (k < rightSib->count)
            {
                node->keys[node->count] = move rightSib->keys[k];
                node->values[node->count] = move rightSib->values[k];
                node->count++;
                k++;
            }
            node->next = rightSib->next;
        }
        else
        {
            // Internal merge pulls the parent separator DOWN into node by shallow copy (parent is
            // borrowed); the fixup below drops the parent slot without freeing so node keeps it.
            node->keys[node->count] = parent->keys[idx];
            node->count++;
            while (k < rightSib->count)
            {
                node->keys[node->count] = move rightSib->keys[k];
                node->count++;
                k++;
            }
            k = 0;
            int c = node->count - rightSib->count;
            while (k <= rightSib->count)
            {
                node->children[c] = rightSib->children[k];
                c++;
                k++;
            }
        }
        delete rightSib;

        // Drop the parent's defunct separator: leaf merge frees it in place; internal merge handed
        // it to node, so the shift drops it there. Clear the vacated top slot for the destructor.
        if (leafMerge) _destroyKey(parent, idx);
        int m = idx;
        while (m < parent->count - 1)
        {
            parent->keys[m] = parent->keys[m + 1];
            parent->children[m + 1] = parent->children[m + 2];
            m++;
        }
        _clearKey(parent, parent->count - 1);
        parent->count--;
    }

    // Free an empty root node (node->count == 0, already verified by the caller) and shrink
    // the tree: an internal node collapses to its only remaining child; a leaf collapses to
    // an empty tree. Always frees node, so it is taken by move.
    void _collapseEmptyRoot(bool wasLeaf, move btree_node<K, V>* node)
    {
        if (!wasLeaf)
        {
            btree_node<K, V>* onlyChild = node->children[0];
            delete node;
            _root = onlyChild;
        }
        else
        {
            delete node;
            _root = nullptr;
        }
    }

    // Borrow the last entry of leftSib into node (node is parent->children[idx]).
    void _borrowFromLeft(btree_node<K, V>* parent, int idx, btree_node<K, V>* node, btree_node<K, V>* leftSib)
    {
        // All three nodes are borrowed pointer parameters, so their inline arrays cannot be `move`d
        // (ownership model, see _freeValue). Handoffs are shallow copies paired with an explicit
        // abandon-clear of the vacated source slot; separators are freed/copied via _destroyKey /
        // _storeKey. The synthesized node destructor frees all slots, so every vacated tail slot
        // must be cleared. Net ownership is conserved: each buffer ends up referenced exactly once.
        if (node->isLeaf)
        {
            // Shift node up (plain rotation into the empty tail), take leftSib's last entry by
            // shallow copy, then abandon leftSib's vacated slot. Rewrite the separator to an owned
            // COPY of node's new first key (the key stays in the leaf), freeing the old one first.
            int j = node->count;
            while (j > 0) { node->keys[j] = node->keys[j - 1]; node->values[j] = node->values[j - 1]; j--; }
            node->keys[0] = leftSib->keys[leftSib->count - 1];
            node->values[0] = leftSib->values[leftSib->count - 1];
            node->count++;
            leftSib->count--;
            _clearKey(leftSib, leftSib->count);
            _clearValue(leftSib, leftSib->count);
            _destroyKey(parent, idx - 1);
            _storeKey(parent, idx - 1, node->keys[0]);
        }
        else
        {
            // Rotation: separator down into node's slot 0, leftSib's last key up as the new
            // separator - both shallow copies whose overwritten sources are preserved elsewhere,
            // then abandon leftSib's vacated key. Children (raw pointers) shift by plain copy.
            int j = node->count;
            while (j > 0) { node->keys[j] = node->keys[j - 1]; j--; }
            int c = node->count + 1;
            while (c > 0) { node->children[c] = node->children[c - 1]; c--; }
            node->keys[0] = parent->keys[idx - 1];
            node->children[0] = leftSib->children[leftSib->count];
            parent->keys[idx - 1] = leftSib->keys[leftSib->count - 1];
            node->count++;
            leftSib->count--;
            _clearKey(leftSib, leftSib->count);
        }
    }

    // Borrow the first entry of rightSib into node (node is parent->children[idx]).
    void _borrowFromRight(btree_node<K, V>* parent, int idx, btree_node<K, V>* node, btree_node<K, V>* rightSib)
    {
        // Same ownership constraints as _borrowFromLeft: shallow-copy handoffs + explicit
        // abandon-clear of vacated slots (all nodes are borrowed parameters).
        if (node->isLeaf)
        {
            // Take rightSib's first entry (shallow), plain down-shift the rest, then clear the
            // stale top slot the rotation leaves; set the separator to an owned COPY of rightSib's
            // new first key, freeing the old separator first.
            node->keys[node->count] = rightSib->keys[0];
            node->values[node->count] = rightSib->values[0];
            node->count++;
            int j = 0;
            while (j < rightSib->count - 1) { rightSib->keys[j] = rightSib->keys[j + 1]; rightSib->values[j] = rightSib->values[j + 1]; j++; }
            rightSib->count--;
            _clearKey(rightSib, rightSib->count);
            _clearValue(rightSib, rightSib->count);
            _destroyKey(parent, idx);
            _storeKey(parent, idx, rightSib->keys[0]);
        }
        else
        {
            // Rotation: parent separator down into node, rightSib's first key up as the new
            // separator (shallow copies), plain down-shift rightSib, clear its stale top slot.
            node->keys[node->count] = parent->keys[idx];
            node->children[node->count + 1] = rightSib->children[0];
            node->count++;
            parent->keys[idx] = rightSib->keys[0];
            int j = 0;
            while (j < rightSib->count - 1) { rightSib->keys[j] = rightSib->keys[j + 1]; j++; }
            int c = 0;
            while (c < rightSib->count) { rightSib->children[c] = rightSib->children[c + 1]; c++; }
            rightSib->count--;
            _clearKey(rightSib, rightSib->count);
        }
    }

    // Number of entries currently in the tree. The two insert families keep separate
    // tallies (_count is plain, _mtCount is atomic because concurrent inserters race on
    // it) and the total is their sum, so the answer is right whichever family was used.
    int count()
    {
        return _count + (int)_mtCount.read();
    }

    // lookup() descents that failed validation and had to restart - i.e. reads that saw a
    // torn tree and threw the result away. Zero under no contention.
    i64 read_restarts()
    {
        return _readRestarts.read();
    }

    // insert() fast-path descents that failed validation or lost the upgrade() race.
    i64 write_restarts()
    {
        return _writeRestarts.read();
    }

    // Free every node below n (post-order), including n itself, releasing each live entry:
    // a `unique` value is freed, a value type destructed, a bare pointer / interface value
    // left to its real owner; an owning key is destructed.
    void _freeSubtree(move btree_node<K, V>* n)
    {
        if (n == nullptr) return;
        if (n->isLeaf)
        {
            int i = 0;
            while (i < n->count)
            {
                if const (is_unique(V))         _freeValue(move n->values[i]);
                else if const (is_pointer(V))   { }
                else if const (is_primitive(V)) { }
                else                            _freeValue(move n->values[i]);
                if const (!is_primitive(K)) if const (!is_pointer(K)) _freeKey(move n->keys[i]);
                i++;
            }
        }
        else
        {
            int i = 0;
            while (i <= n->count)
            {
                _freeSubtree(n->children[i]);
                i++;
            }
        }
        delete n;
    }

    // Remove all entries: frees every node, every `unique` value and every owning key.
    // Borrowed (bare pointer / interface) values are left to their real owner.
    // The tree is empty afterward.
    void clear()
    {
        _freeSubtree(_root);
        _root = nullptr;
        _count = 0;
    }

    // Free every node, every `unique` value and every owning key.
    void destroy()
    {
        clear();
    }

    // -- ordered iteration ----------------------------------------------------------------

    // Cursor at the smallest key (invalid/empty if the tree has no entries).
    btree_cursor<K, V> first()
    {
        btree_cursor<K, V> c;
        btree_node<K, V>* n = _root;
        while (n != nullptr && !n->isLeaf) n = n->children[0];
        c._leaf = n;
        c._slot = 0;
        while (c._leaf != nullptr && c._slot >= c._leaf->count)
        {
            c._leaf = c._leaf->next;
            c._slot = 0;
        }
        return c;
    }

    // Cursor at the first key >= key (invalid if every key is smaller).
    btree_cursor<K, V> seek(K key)
    {
        btree_cursor<K, V> c;
        btree_node<K, V>* n = _root;
        while (n != nullptr && !n->isLeaf)
            n = n->children[_childIndex(n, key)];

        c._leaf = n;
        c._slot = 0;
        if (n == nullptr) return c;

        int i = 0;
        while (i < n->count && _lt(n->keys[i], key)) i++;
        c._slot = i;
        while (c._leaf != nullptr && c._slot >= c._leaf->count)
        {
            c._leaf = c._leaf->next;
            c._slot = 0;
        }
        return c;
    }

    // Free all nodes, `unique` values and owning keys.
    ~btree()
    {
        clear();
    }
};
