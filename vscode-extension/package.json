{
  "name": "mycompiler-language",
  "displayName": "MyCompiler Language Support",
  "description": "Syntax highlighting, diagnostics, and completions for MyCompiler C dialect",
  "version": "0.1.0",
  "publisher": "mycompiler",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "cflat",
        "aliases": [
          "CFlat",
          "cflat",
          "C-flat"
        ],
        "extensions": [
          ".cb"
        ],
        "filenames": [],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "cflat",
        "scopeName": "source.cflat",
        "path": "./syntaxes/cflat.tmLanguage.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "MyCompiler",
      "properties": {
        "mycompiler.executablePath": {
          "type": "string",
          "default": "",
          "description": "Path to MyCompiler.exe. Leave blank to auto-detect from common build output locations relative to workspace."
        },
        "mycompiler.enableDiagnostics": {
          "type": "boolean",
          "default": true,
          "description": "Run MyCompiler.exe on save and show errors/warnings inline."
        },
        "mycompiler.diagnosticDelay": {
          "type": "number",
          "default": 500,
          "description": "Milliseconds to wait after a change before re-running diagnostics."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.11"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.4"
  }
}
