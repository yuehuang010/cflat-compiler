{
  "name": "cflat-language",
  "displayName": "cflat Language Support",
  "description": "Syntax highlighting, diagnostics, and completions for cflat C dialect",
  "version": "0.5.0",
  "publisher": "cflat",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:cflat",
    "onDebug",
    "onDebugResolve:cflat",
    "onDebugDynamicConfigurations:cflat"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "cflat",
        "aliases": [
          "CFlat",
          "cflat",
          "C-flat"
        ],
        "extensions": [
          ".cb"
        ],
        "filenames": [],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "cflat",
        "scopeName": "source.cflat",
        "path": "./syntaxes/cflat.tmLanguage.json"
      }
    ],
    "breakpoints": [
      {
        "language": "cflat"
      }
    ],
    "debuggers": [
      {
        "type": "cflat",
        "label": "cflat",
        "languages": [
          "cflat"
        ],
        "configurationAttributes": {
          "launch": {
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to the .cb source file to compile and debug.",
                "default": "${file}"
              },
              "args": {
                "type": "array",
                "description": "Command-line arguments passed to the compiled program.",
                "items": {
                  "type": "string"
                },
                "default": []
              },
              "cwd": {
                "type": "string",
                "description": "Working directory for the compiled program. Defaults to the directory of the output .exe.",
                "default": "${fileDirname}"
              },
              "stopAtEntry": {
                "type": "boolean",
                "description": "Break on entry to main.",
                "default": false
              },
              "console": {
                "type": "string",
                "enum": [
                  "integratedTerminal",
                  "externalTerminal",
                  "internalConsole"
                ],
                "description": "Where to host the program's stdio.",
                "default": "integratedTerminal"
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "cflat",
            "request": "launch",
            "name": "Run cflat file",
            "program": "${file}",
            "args": [],
            "stopAtEntry": false
          }
        ],
        "configurationSnippets": [
          {
            "label": "cflat: Run current file",
            "description": "Compile and debug the active .cb file with cppvsdbg.",
            "body": {
              "type": "cflat",
              "request": "launch",
              "name": "Run cflat file",
              "program": "^\"\\${file}\"",
              "args": [],
              "stopAtEntry": false
            }
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "cflat.runDiagnostics",
        "title": "cflat: Run Diagnostics on Current File"
      },
      {
        "command": "cflat.showOutput",
        "title": "cflat: Show Language Server Output"
      },
      {
        "command": "cflat.restartServer",
        "title": "cflat: Restart Language Server"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "cflat",
      "properties": {
        "cflat.executablePath": {
          "type": "string",
          "default": "",
          "description": "Path to cflat.exe. Required - the language server will not start until this is set. Changes take effect immediately (no reload required)."
        },
        "cflat.enableDiagnostics": {
          "type": "boolean",
          "default": true,
          "description": "Run cflat.exe on save and show errors/warnings inline."
        },
        "cflat.diagnosticDelay": {
          "type": "number",
          "default": 500,
          "description": "Milliseconds to wait after a change before re-running diagnostics."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.js --production",
    "compile": "node esbuild.js",
    "typecheck": "tsc -p ./ --noEmit",
    "watch": "node esbuild.js --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.11"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.25.12",
    "typescript": "^5.3.0",
    "vitest": "^4.1.4"
  }
}
