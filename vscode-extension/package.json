{
  "name": "cflat-language",
  "displayName": "cflat Language Support",
  "description": "Syntax highlighting, diagnostics, and completions for cflat C dialect",
  "version": "0.1.0",
  "publisher": "cflat",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "cflat",
        "aliases": [
          "CFlat",
          "cflat",
          "C-flat"
        ],
        "extensions": [
          ".cb"
        ],
        "filenames": [],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "cflat",
        "scopeName": "source.cflat",
        "path": "./syntaxes/cflat.tmLanguage.json"
      }
    ],
    "breakpoints": [
      {
        "language": "cflat"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "cflat",
      "properties": {
        "cflat.executablePath": {
          "type": "string",
          "default": "",
          "description": "Path to cflat.exe. Leave blank to auto-detect from common build output locations relative to workspace."
        },
        "cflat.enableDiagnostics": {
          "type": "boolean",
          "default": true,
          "description": "Run cflat.exe on save and show errors/warnings inline."
        },
        "cflat.diagnosticDelay": {
          "type": "number",
          "default": 500,
          "description": "Milliseconds to wait after a change before re-running diagnostics."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.11"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.4"
  }
}
