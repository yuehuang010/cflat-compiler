{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "MyC",
  "scopeName": "source.myc",
  "fileTypes": ["myc"],
  "patterns": [
    { "include": "#preprocessor" },
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#character-literal" },
    { "include": "#numbers" },
    { "include": "#keywords-control" },
    { "include": "#keywords-storage" },
    { "include": "#keywords-type" },
    { "include": "#keywords-qualifier" },
    { "include": "#keywords-myc-extension" },
    { "include": "#keywords-c11" },
    { "include": "#constants" },
    { "include": "#namespace-declaration" },
    { "include": "#interface-declaration" },
    { "include": "#struct-declaration" },
    { "include": "#function-definition" },
    { "include": "#function-call" },
    { "include": "#named-parameter" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "preprocessor": {
      "patterns": [
        {
          "name": "meta.preprocessor.include.myc",
          "match": "^\\s*(#\\s*include)\\s+([<\"].*?[>\"])",
          "captures": {
            "1": { "name": "keyword.control.directive.include.myc" },
            "2": { "name": "string.quoted.other.lt-gt.include.myc" }
          }
        },
        {
          "name": "meta.preprocessor.define.myc",
          "match": "^\\s*(#\\s*define)\\s+(\\w+)(?:\\(([^)]*)\\))?",
          "captures": {
            "1": { "name": "keyword.control.directive.define.myc" },
            "2": { "name": "entity.name.function.preprocessor.myc" },
            "3": { "name": "variable.parameter.preprocessor.myc" }
          }
        },
        {
          "name": "keyword.control.directive.myc",
          "match": "^\\s*#\\s*(if|ifdef|ifndef|elif|else|endif|undef|pragma|error|warning|line)\\b"
        },
        {
          "name": "meta.preprocessor.myc",
          "match": "^\\s*(#\\s*\\w+).*$",
          "captures": {
            "1": { "name": "keyword.control.directive.myc" }
          }
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.myc",
          "match": "//.*$"
        },
        {
          "name": "comment.block.myc",
          "begin": "/\\*",
          "end": "\\*/",
          "beginCaptures": { "0": { "name": "punctuation.definition.comment.begin.myc" } },
          "endCaptures": { "0": { "name": "punctuation.definition.comment.end.myc" } }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.myc",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.myc", "match": "\\\\." },
            { "name": "constant.other.placeholder.myc", "match": "%[-+0 #]*[0-9]*(?:\\.[0-9]+)?[diouxXeEfFgGaAcsSp%]" }
          ]
        }
      ]
    },
    "character-literal": {
      "name": "string.quoted.single.myc",
      "match": "'(?:[^'\\\\]|\\\\.)'",
      "captures": { "0": { "name": "string.quoted.single.myc" } }
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.myc",
          "match": "\\b[0-9]+\\.[0-9]*([eE][+-]?[0-9]+)?[fFlL]?\\b|\\b[0-9]+[eE][+-]?[0-9]+[fFlL]?\\b"
        },
        {
          "name": "constant.numeric.hex.myc",
          "match": "\\b0[xX][0-9a-fA-F]+[uUlLuU]*\\b"
        },
        {
          "name": "constant.numeric.octal.myc",
          "match": "\\b0[0-7]+[uUlL]*\\b"
        },
        {
          "name": "constant.numeric.integer.myc",
          "match": "\\b[0-9]+[uUlLuU]*\\b"
        }
      ]
    },
    "keywords-control": {
      "name": "keyword.control.myc",
      "match": "\\b(if|else|switch|case|default|while|do|for|break|continue|return|goto)\\b"
    },
    "keywords-storage": {
      "name": "storage.modifier.myc",
      "match": "\\b(typedef|extern|static|register|inline|auto|thread_local|_Thread_local|__inline__|__forceinline)\\b"
    },
    "keywords-type": {
      "patterns": [
        {
          "name": "storage.type.primitive.myc",
          "match": "\\b(void|char|short|int|long|float|double|bool|_Bool|_Complex|_Imaginary|signed|unsigned|__int8|__int16|__int32|__int64|i8|i16|i32|i64|u8|u16|u32|u64)\\b"
        },
        {
          "name": "storage.type.struct.myc",
          "match": "\\b(struct|union|enum|class)\\b"
        }
      ]
    },
    "keywords-qualifier": {
      "name": "storage.modifier.qualifier.myc",
      "match": "\\b(const|volatile|restrict|_Atomic)\\b"
    },
    "keywords-myc-extension": {
      "patterns": [
        {
          "name": "keyword.other.namespace.myc",
          "match": "\\b(namespace|using)\\b"
        },
        {
          "name": "keyword.other.interface.myc",
          "match": "\\binterface\\b"
        },
        {
          "name": "keyword.operator.expression.myc",
          "match": "\\b(nameof|typeof|sizeof)\\b"
        }
      ]
    },
    "keywords-c11": {
      "name": "keyword.other.c11.myc",
      "match": "\\b(_Alignas|_Alignof|alignas|alignof|_Static_assert|static_assert|_Generic|_Noreturn|noreturn)\\b"
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.myc",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.myc",
          "match": "\\b(NULL|nullptr)\\b"
        }
      ]
    },
    "namespace-declaration": {
      "name": "meta.namespace.myc",
      "match": "\\b(namespace)\\s+([A-Za-z_][A-Za-z0-9_:]*)\\s*(?=\\{)",
      "captures": {
        "1": { "name": "keyword.other.namespace.myc" },
        "2": { "name": "entity.name.namespace.myc" }
      }
    },
    "interface-declaration": {
      "name": "meta.interface.myc",
      "match": "\\b(interface)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\{)",
      "captures": {
        "1": { "name": "keyword.other.interface.myc" },
        "2": { "name": "entity.name.type.interface.myc" }
      }
    },
    "struct-declaration": {
      "patterns": [
        {
          "comment": "struct/class/union/enum keyword followed by a type name — covers declarations AND type-usage positions (variable declarations, casts, parameters)",
          "name": "meta.struct.myc",
          "match": "\\b(struct|class|union|enum)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.struct.myc" },
            "2": { "name": "entity.name.type.myc" }
          }
        },
        {
          "comment": "Destructor definition: ~TypeName()",
          "name": "meta.destructor.myc",
          "match": "(~)([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "keyword.operator.destructor.myc" },
            "2": { "name": "entity.name.function.destructor.myc" }
          }
        }
      ]
    },
    "function-definition": {
      "comment": "Function definition: returnType funcName(...) {",
      "name": "meta.function.definition.myc",
      "match": "\\b([A-Za-z_][A-Za-z0-9_:]*)\\s+([A-Za-z_][A-Za-z0-9_:]*)\\s*(?=\\([^;]*\\)\\s*(?:const\\s*)?(?:\\{|;))",
      "captures": {
        "1": { "name": "storage.type.return-type.myc" },
        "2": { "name": "entity.name.function.myc" }
      }
    },
    "function-call": {
      "name": "meta.function-call.myc",
      "match": "\\b([A-Za-z_][A-Za-z0-9_:]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.function.myc" }
      }
    },
    "named-parameter": {
      "comment": "Named parameters like func(x:1, y:2)",
      "name": "meta.named-parameter.myc",
      "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*:",
      "captures": {
        "1": { "name": "variable.parameter.named.myc" }
      }
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arithmetic.myc",
          "match": "\\+|-|\\*|/|%"
        },
        {
          "name": "keyword.operator.comparison.myc",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.myc",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.bitwise.myc",
          "match": "&|\\||\\^|~|<<|>>"
        },
        {
          "name": "keyword.operator.assignment.myc",
          "match": "\\+=|-=|\\*=|/=|%=|<<=|>>=|&=|\\|=|\\^=|="
        },
        {
          "name": "keyword.operator.increment.myc",
          "match": "\\+\\+|--"
        },
        {
          "name": "keyword.operator.member.myc",
          "match": "->|\\."
        },
        {
          "name": "keyword.operator.ternary.myc",
          "match": "\\?|:"
        },
        {
          "name": "keyword.operator.scope.myc",
          "match": "::"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.terminator.statement.myc",
          "match": ";"
        },
        {
          "name": "punctuation.separator.comma.myc",
          "match": ","
        },
        {
          "name": "punctuation.section.block.begin.myc",
          "match": "\\{"
        },
        {
          "name": "punctuation.section.block.end.myc",
          "match": "\\}"
        },
        {
          "name": "punctuation.section.parens.begin.myc",
          "match": "\\("
        },
        {
          "name": "punctuation.section.parens.end.myc",
          "match": "\\)"
        },
        {
          "name": "punctuation.section.brackets.begin.myc",
          "match": "\\["
        },
        {
          "name": "punctuation.section.brackets.end.myc",
          "match": "\\]"
        }
      ]
    }
  }
}
