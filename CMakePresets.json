{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },
  "configurePresets": [
    {
      "name": "vcpkg-base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "VCPKG_MANIFEST_INSTALL": "OFF"
      }
    },
    {
      "name": "win-x64",
      "hidden": true,
      "inherits": "vcpkg-base",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows-static",
        "VCPKG_HOST_TRIPLET": "x64-windows",
        "VCPKG_INSTALLED_DIR": "${sourceDir}/vcpkg_installed/x64-windows-static"
      },
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" }
    },
    {
      "name": "win-x64-debug",
      "displayName": "Windows x64 Debug",
      "inherits": "win-x64",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    },
    {
      "name": "win-x64-release",
      "displayName": "Windows x64 Release",
      "inherits": "win-x64",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    },

    {
      "name": "linux-x64",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "$env{HOME}/cflat-build/${presetName}",
      "cacheVariables": {
        "CMAKE_PREFIX_PATH": "/usr/lib/llvm-18",
        "ANTLR4_JAR": "/opt/antlr/antlr-4.10.1-complete.jar"
      },
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" }
    },
    {
      "name": "linux-x64-debug",
      "displayName": "Linux x64 Debug (WSL) - Stage 2+",
      "inherits": "linux-x64",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    },
    {
      "name": "linux-x64-release",
      "displayName": "Linux x64 Release (WSL) - Stage 2+",
      "inherits": "linux-x64",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    },

    {
      "name": "macos-arm64",
      "hidden": true,
      "inherits": "vcpkg-base",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "arm64-osx"
      },
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Darwin" }
    },
    {
      "name": "macos-arm64-debug",
      "displayName": "macOS arm64 Debug - Stage 4 (prepare)",
      "inherits": "macos-arm64",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    },
    {
      "name": "macos-arm64-release",
      "displayName": "macOS arm64 Release - Stage 4 (prepare)",
      "inherits": "macos-arm64",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    }
  ],
  "buildPresets": [
    { "name": "win-x64-debug",    "configurePreset": "win-x64-debug" },
    { "name": "win-x64-release",  "configurePreset": "win-x64-release" },
    { "name": "linux-x64-debug",  "configurePreset": "linux-x64-debug" },
    { "name": "linux-x64-release", "configurePreset": "linux-x64-release" },
    { "name": "macos-arm64-debug", "configurePreset": "macos-arm64-debug" },
    { "name": "macos-arm64-release", "configurePreset": "macos-arm64-release" }
  ]
}
