import "list.cb";
import "thread.cb";
import "time.cb";
import "channel.cb";
import "stop_token.cb";

channel<int> g_channel;

program YesProducer
{
    stop_token token = default;

    int main(move list<string> args)
    {
        while (!token.stop_requested())
        {
            g_channel.send(1);
        }
        return 0;
    }
};

program YesConsumer
{
    stop_token token = default;
    i64 count = default;

    int main(move list<string> args)
    {
        int val = 0;
        while (!token.stop_requested())
        {
            if (g_channel.try_receive(&val))
            {
                count = count + (i64)1;
            }
        }
        return 0;
    }
};

extern int main()
{
    list<string> args;

    g_channel.init(4096);

    YesProducer producer;
    YesConsumer consumer;
    stop_source src;
    src.init();
    producer.token = src.get_token();
    consumer.token = src.get_token();
    producer.run(args);
    consumer.run(args);

    sleep(10000);

    src.request_stop();
    producer.WaitForExit();
    consumer.WaitForExit();
    src.dispose();

    printf("\n--- Yes (channel) ---\n");
    printf("  %lld Y/s\n", consumer.count / (i64)10);

    g_channel.destroy();
    return 0;
}
