// ── entry point ──────────────────────────────────────────────────────────────

extern int main()
{
    printf("\n--- hashset<int>: add / contains / remove ---\n");
    RunHashset(10,    500000);
    RunHashset(500,   5000);
    RunHashset(10000, 250);

    printf("\n--- dictionary<int,int>: add / get / remove ---\n");
    RunDict(10,    500000);
    RunDict(500,   5000);
    RunDict(10000, 250);

    printf("\n--- list<string>: add / get (64-char keys; add uses pre-built keys) ---\n");
    RunListStr(10,    500000);
    RunListStr(500,   5000);
    RunListStr(10000, 250);

    printf("\n--- hashset<string>: add / contains / remove (add includes alloc; lookup uses pre-built keys) ---\n");
    RunHashsetStr(10,    100000);
    RunHashsetStr(500,   2000);
    RunHashsetStr(10000, 100);

    printf("\n--- dictionary<string,string>: add / get / remove (add includes alloc; lookup uses pre-built keys) ---\n");
    RunDictStr(10,    100000);
    RunDictStr(500,   2000);
    RunDictStr(10000, 100);

    return 0;
}
