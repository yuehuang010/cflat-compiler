    BenchListStrGet bg;
    bg.n = n; bg.repeats = repeats;
    bg.run(emptyArgs); bg.WaitForExit();

    i64 addUs = ba.measuredUs; if (addUs == (i64)0) addUs = (i64)1;
    i64 getUs = bg.measuredUs; if (getUs == (i64)0) getUs = (i64)1;

    printf("  N=%-6d  add %8lld us (%5lld ns/op)  get %8lld us (%5lld ns/op)\n",
        n,
        addUs, (addUs * (i64)1000) / totalOps,
        getUs, (getUs * (i64)1000) / totalOps);
