// Benchmark: hashset<int>, dictionary<int,int>, list<string>, hashset<string>,
// and dictionary<string,string> throughput.
//
// For each container, operations are timed at three sizes (N = 10, 500, 10000):
//   add      — fill a pre-warmed (capacity pre-allocated, clear()ed) container
//   contains — scan N lookups on a pre-filled container
//   remove   — drain a pre-filled container; clear() + refill happen outside timer
//
// String benchmarks use make_key(i) which produces 16-char keys ("bench_%010d"),
// exceeding MSVC's 15-char SSO limit so both CFlat and C++ always heap-allocate.
//
// The add benchmarks call make_key(i) inline so add times include one malloc+sprintf
// per op.  All other benchmarks (contains/get/remove) pre-build a list<string> of
// keys so the timed loop has no alloc cost.
//
// Note: add times exclude rehash cost because the container is pre-warmed via
// a warm-up fill + clear().  Remove times are isolated via stopwatch pause/resume.

import "list.cb";
import "hashset.cb";
import "dictionary.cb";
import "time.cb";
import "perf_framework.cb";

// Produces a 16-char heap-allocated string "bench_%010d" — longer than MSVC's
// 15-char SSO limit so the C++ comparison benchmark also always heap-allocates.
string make_key(int i)
{
    char* buf = malloc(32);
    int len = sprintf(buf, "bench_%010d", i);
    string result;
    result._ptr = buf;
    result._len = len;
    return result;
}

// Produces a 64-char string — well beyond any SSO limit — for list<string>
// benchmarks where we want to isolate list overhead from string-length effects.
string make_large_key(int i)
{
    char* buf = malloc(80);
    int len = sprintf(buf, "bench_%010d_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx", i);
    string result;
    result._ptr = buf;
    result._len = len;
    return result;
}

// ── hashset<int> ─────────────────────────────────────────────────────────────

program BenchHashsetAdd
{
    int n       = 0;
    int repeats = 0;
    i64 measuredUs = 0;

    int main(move list<string> args)
    {
        hashset<int> s;
        // warm-up: trigger all rehashes so capacity is stable for timed passes
        int i = 0;
        while (i < n) { s.add(i); i++; }
        s.clear();

        Stopwatch sw;
        sw.start();
        int r = 0;
        while (r < repeats)
        {
            i = 0;
            while (i < n) { s.add(i); i++; }
            s.clear();
            r++;
        }
        sw.stop();
        measuredUs = (i64)sw.elapsed().microseconds();
        return 0;
    }
};

program BenchHashsetContains
{
    int n       = 0;
    int repeats = 0;
    i64 measuredUs = 0;
    i64 found      = 0;

    int main(move list<string> args)
    {
        hashset<int> s;
        int i = 0;
        while (i < n) { s.add(i); i++; }

        Stopwatch sw;
        sw.start();
        int r = 0;
        while (r < repeats)
        {
            i = 0;
            while (i < n)
            {
                if (s.contains(i)) found++;
                i++;
            }
            r++;
        }
        sw.stop();
        measuredUs = (i64)sw.elapsed().microseconds();
        return 0;
    }
};

program BenchHashsetRemove
{
    int n       = 0;
    int repeats = 0;
    i64 measuredUs = 0;

    int main(move list<string> args)
    {
        hashset<int> s;
        int i = 0;
        while (i < n) { s.add(i); i++; }

        Stopwatch sw;
        int r = 0;
        while (r < repeats)
        {
            sw.start();
            i = 0;
            while (i < n) { s.remove(i); i++; }
            sw.stop();
            // reset with clear() to avoid tombstone buildup, then refill
            s.clear();
            i = 0;
            while (i < n) { s.add(i); i++; }
            r++;
        }
        measuredUs = (i64)sw.elapsed().microseconds();
        return 0;
    }
};

// ── dictionary<int,int> ──────────────────────────────────────────────────────

program BenchDictAdd
{
    int n       = 0;
    int repeats = 0;
    i64 measuredUs = 0;

    int main(move list<string> args)
    {
        dictionary<int, int> d;
        int i = 0;
        while (i < n) { d.add(i, i * 2); i++; }
        d.clear();

        Stopwatch sw;
        sw.start();
        int r = 0;
        while (r < repeats)
        {
            i = 0;
            while (i < n) { d.add(i, i * 2); i++; }
            d.clear();
            r++;
        }
        sw.stop();
        measuredUs = (i64)sw.elapsed().microseconds();
        return 0;
    }
};

program BenchDictGet
{
    int n       = 0;
    int repeats = 0;
    i64 measuredUs = 0;
    i64 sum        = 0;

    int main(move list<string> args)
    {
        dictionary<int, int> d;
        int i = 0;
        while (i < n) { d.add(i, i * 2); i++; }

        Stopwatch sw;
        sw.start();
        int r = 0;
        while (r < repeats)
        {
            i = 0;
            while (i < n)
            {
                sum = sum + (i64)d.get(i);
                i++;
            }
            r++;
        }
        sw.stop();
        measuredUs = (i64)sw.elapsed().microseconds();
        return 0;
    }
};

program BenchDictRemove
{
    int n       = 0;
    int repeats = 0;
    i64 measuredUs = 0;

    int main(move list<string> args)
    {
        dictionary<int, int> d;
        int i = 0;
        while (i < n) { d.add(i, i * 2); i++; }

        Stopwatch sw;
        int r = 0;
        while (r < repeats)
        {
            sw.start();
            i = 0;
            while (i < n) { d.remove(i); i++; }
            sw.stop();
            d.clear();
            i = 0;
            while (i < n) { d.add(i, i * 2); i++; }
            r++;
        }
        measuredUs = (i64)sw.elapsed().microseconds();
        return 0;
    }
};

// ── list<string> ─────────────────────────────────────────────────────────────
// Uses make_large_key (64 chars) — well above any SSO threshold.

program BenchListStrAdd
{
    int n       = 0;
    int repeats = 0;
    i64 measuredUs = 0;

    int main(move list<string> args)
    {
        list<string> keys;
        int i = 0;
        while (i < n) { keys.add(make_large_key(i)); i++; }

        list<string> lst;
        i = 0;
        while (i < n) { lst.add(keys.get(i)); i++; }
        lst.clear();

        Stopwatch sw;
        sw.start();
        int r = 0;
        while (r < repeats)
        {
            i = 0;
            while (i < n) { lst.add(keys.get(i)); i++; }
            lst.clear();
            r++;
        }
        sw.stop();
        measuredUs = (i64)sw.elapsed().microseconds();
        return 0;
    }
};

program BenchListStrGet
{
    int n       = 0;
    int repeats = 0;
    i64 measuredUs = 0;
    i64 sum        = 0;

    int main(move list<string> args)
    {
        list<string> keys;
        int i = 0;
        while (i < n) { keys.add(make_large_key(i)); i++; }

        list<string> lst;
        i = 0;
        while (i < n) { lst.add(keys.get(i)); i++; }

        Stopwatch sw;
        sw.start();
        int r = 0;
        while (r < repeats)
        {
            i = 0;
            while (i < n)
            {
                sum = sum + (i64)lst.get(i).length();
                i++;
            }
            r++;
        }
        sw.stop();
        measuredUs = (i64)sw.elapsed().microseconds();
        return 0;
    }
};

// ── hashset<string> ──────────────────────────────────────────────────────────

program BenchHashsetStrAdd
{
    int n       = 0;
    int repeats = 0;
    i64 measuredUs = 0;

    int main(move list<string> args)
    {
        hashset<string> s;
        int i = 0;
        while (i < n) { s.add(make_key(i)); i++; }
        s.clear();

        Stopwatch sw;
        sw.start();
        int r = 0;
        while (r < repeats)
        {
            i = 0;
            while (i < n) { s.add(make_key(i)); i++; }
            s.clear();
            r++;
        }
        sw.stop();
        measuredUs = (i64)sw.elapsed().microseconds();
        return 0;
    }
};

program BenchHashsetStrContains
{
    int n       = 0;
    int repeats = 0;
    i64 measuredUs = 0;
    i64 found      = 0;

    int main(move list<string> args)
    {
        // pre-build keys so neither fill nor timed loop allocates
        list<string> lookup_keys;
        int i = 0;
        while (i < n) { lookup_keys.add(make_key(i)); i++; }

        hashset<string> s;
        i = 0;
        while (i < n) { s.add(lookup_keys.get(i)); i++; }

        Stopwatch sw;
        sw.start();
        int r = 0;
        while (r < repeats)
        {
            i = 0;
            while (i < n)
            {
                if (s.contains(lookup_keys.get(i))) found++;
                i++;
            }
            r++;
        }
        sw.stop();
        measuredUs = (i64)sw.elapsed().microseconds();
        return 0;
    }
};

program BenchHashsetStrRemove
{
    int n       = 0;
    int repeats = 0;
    i64 measuredUs = 0;

    int main(move list<string> args)
    {
        // pre-build keys so neither fill, remove, nor refill allocates
        list<string> lookup_keys;
        int i = 0;
        while (i < n) { lookup_keys.add(make_key(i)); i++; }

        hashset<string> s;
        i = 0;
        while (i < n) { s.add(lookup_keys.get(i)); i++; }

        Stopwatch sw;
        int r = 0;
        while (r < repeats)
        {
            sw.start();
            i = 0;
            while (i < n) { s.remove(lookup_keys.get(i)); i++; }
            sw.stop();
            s.clear();
            i = 0;
            while (i < n) { s.add(lookup_keys.get(i)); i++; }
            r++;
        }
        measuredUs = (i64)sw.elapsed().microseconds();
        return 0;
    }
};

// ── dictionary<string,string> ────────────────────────────────────────────────

program BenchDictStrAdd
{
    int n       = 0;
    int repeats = 0;
    i64 measuredUs = 0;

    int main(move list<string> args)
    {
        dictionary<string, string> d;
        int i = 0;
        while (i < n) { d.add(make_key(i), make_key(i * 2)); i++; }
        d.clear();

        Stopwatch sw;
        sw.start();
        int r = 0;
        while (r < repeats)
        {
            i = 0;
            while (i < n) { d.add(make_key(i), make_key(i * 2)); i++; }
            d.clear();
            r++;
        }
        sw.stop();
        measuredUs = (i64)sw.elapsed().microseconds();
        return 0;
    }
};

program BenchDictStrGet
{
    int n       = 0;
    int repeats = 0;
    i64 measuredUs = 0;
    i64 sum        = 0;

    int main(move list<string> args)
    {
        // pre-build keys so neither fill nor timed loop allocates
        list<string> lookup_keys;
        int i = 0;
        while (i < n) { lookup_keys.add(make_key(i)); i++; }

        dictionary<string, string> d;
        i = 0;
        while (i < n) { d.add(lookup_keys.get(i), make_key(i * 2)); i++; }

        Stopwatch sw;
        sw.start();
        int r = 0;
        while (r < repeats)
        {
            i = 0;
            while (i < n)
            {
                string v = d.get(lookup_keys.get(i));
                sum = sum + (i64)v.length();
                i++;
            }
            r++;
        }
        sw.stop();
        measuredUs = (i64)sw.elapsed().microseconds();
        return 0;
    }
};

program BenchDictStrRemove
{
    int n       = 0;
    int repeats = 0;
    i64 measuredUs = 0;

    int main(move list<string> args)
    {
        // pre-build keys so neither fill, remove, nor refill allocates for keys
        list<string> lookup_keys;
        int i = 0;
        while (i < n) { lookup_keys.add(make_key(i)); i++; }

        dictionary<string, string> d;
        i = 0;
        while (i < n) { d.add(lookup_keys.get(i), make_key(i * 2)); i++; }

        Stopwatch sw;
        int r = 0;
        while (r < repeats)
        {
            sw.start();
            i = 0;
            while (i < n) { d.remove(lookup_keys.get(i)); i++; }
            sw.stop();
            d.clear();
            i = 0;
            while (i < n) { d.add(lookup_keys.get(i), make_key(i * 2)); i++; }
            r++;
        }
        measuredUs = (i64)sw.elapsed().microseconds();
        return 0;
    }
};

// ── helpers ──────────────────────────────────────────────────────────────────

void RunHashset(int n, int repeats)
{
    i64 totalOps = (i64)n * (i64)repeats;
    list<string> emptyArgs;

    BenchHashsetAdd ba;
    ba.n = n; ba.repeats = repeats;
    ba.run(emptyArgs); ba.WaitForExit();

    BenchHashsetContains bc;
    bc.n = n; bc.repeats = repeats;
    bc.run(emptyArgs); bc.WaitForExit();

    BenchHashsetRemove br;
    br.n = n; br.repeats = repeats;
    br.run(emptyArgs); br.WaitForExit();

    i64 addUs = ba.measuredUs; if (addUs == (i64)0) addUs = (i64)1;
    i64 cntUs = bc.measuredUs; if (cntUs == (i64)0) cntUs = (i64)1;
    i64 remUs = br.measuredUs; if (remUs == (i64)0) remUs = (i64)1;

    printf("  N=%-6d  add %8lld us (%5lld ns/op)  contains %8lld us (%5lld ns/op)  remove %8lld us (%5lld ns/op)\n",
        n,
        addUs, (addUs * (i64)1000) / totalOps,
        cntUs, (cntUs * (i64)1000) / totalOps,
        remUs, (remUs * (i64)1000) / totalOps);
}

void RunDict(int n, int repeats)
{
    i64 totalOps = (i64)n * (i64)repeats;
    list<string> emptyArgs;

    BenchDictAdd ba;
    ba.n = n; ba.repeats = repeats;
    ba.run(emptyArgs); ba.WaitForExit();

    BenchDictGet bg;
    bg.n = n; bg.repeats = repeats;
    bg.run(emptyArgs); bg.WaitForExit();

    BenchDictRemove br;
    br.n = n; br.repeats = repeats;
    br.run(emptyArgs); br.WaitForExit();

    i64 addUs = ba.measuredUs; if (addUs == (i64)0) addUs = (i64)1;
    i64 getUs = bg.measuredUs; if (getUs == (i64)0) getUs = (i64)1;
    i64 remUs = br.measuredUs; if (remUs == (i64)0) remUs = (i64)1;

    printf("  N=%-6d  add %8lld us (%5lld ns/op)  get %8lld us (%5lld ns/op)  remove %8lld us (%5lld ns/op)\n",
        n,
        addUs, (addUs * (i64)1000) / totalOps,
        getUs, (getUs * (i64)1000) / totalOps,
        remUs, (remUs * (i64)1000) / totalOps);
}

