{
    i64 totalOps = (i64)n * (i64)repeats;
    list<string> emptyArgs;

    BenchDictStrAdd ba;
    ba.n = n; ba.repeats = repeats;
    ba.run(emptyArgs); ba.WaitForExit();

    BenchDictStrGet bg;
    bg.n = n; bg.repeats = repeats;
    bg.run(emptyArgs); bg.WaitForExit();

    BenchDictStrRemove br;
